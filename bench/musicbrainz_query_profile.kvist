(defn time-direct-pull-many-artists [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (let [attrs ([]string [":artist/gid" ":artist/gid"])
        values ([]vev.Value [(vev.value-uuid beatles-gid) (vev.value-uuid miles-gid)])]
    (for [warmup-index (arr.range 0 warmups)]
      (discard warmup-index)
      (discard (vev.pull-many-text-lookup-refs-value db direct-artist-pull-pattern attrs values)))
    (let [samples (make [dynamic]f64 0 samples-count)]
      (defer (delete samples))
      (for [sample-index (arr.range 0 samples-count)]
        (discard sample-index)
        (let [start (time.now)
              value (vev.pull-many-text-lookup-refs-value db direct-artist-pull-pattern attrs values)
              elapsed (bench.elapsed-us start)]
          (discard value)
          (arr.push! samples elapsed)))
      (value-timing
        (vev.pull-many-text-lookup-refs-value db direct-artist-pull-pattern attrs values)
        (bench.timing-from-samples (slice samples 0))))))

(defn time-direct-pull-release [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-release-pull-pattern ":release/gid" (vev.value-uuid abbey-road-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-release-pull-pattern ":release/gid" (vev.value-uuid abbey-road-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
      (vev.pull-text-lookup-ref-value db direct-release-pull-pattern ":release/gid" (vev.value-uuid abbey-road-gid))
      (bench.timing-from-samples (slice samples 0)))))

(defn print-value-workload! [workload: string, measured: Value-Timing, print-rows: bool]
  (fmt.printf
    "engine=vev workload=%s ok=true rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f\n"
    workload
    (value-result-row-count measured.value)
    (value-result-fingerprint measured.value)
    measured.timing.min-us
    measured.timing.median-us
    measured.timing.p90-us
    measured.timing.max-us)
  (when print-rows
    (print-value-rows workload measured.value)))

(defn print-value-workload-without-db-id! [workload: string, measured: Value-Timing, print-rows: bool]
  (fmt.printf
    "engine=vev workload=%s ok=true rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f\n"
    workload
    (value-result-row-count measured.value)
    (value-result-fingerprint-without-db-id measured.value)
    measured.timing.min-us
    measured.timing.median-us
    measured.timing.p90-us
    measured.timing.max-us)
  (when print-rows
    (print-value-rows-without-db-id workload measured.value)))

(defn main []
  (defer (free_all context.allocator))
  (let [selected (cli.option os.args "--workload" "all")
        dataset (cli.option os.args "--dataset" "mini")
        store-path (cli.option os.args "--store" "")
        schema-path (cli.option os.args "--schema" "/Users/andreas/Projects/vev/build/musicbrainz/vev-mbrainz-subset-full-chunked-schema.edn")
        values-path (cli.option os.args "--values" "")
        values-prefix (cli.option os.args "--values-prefix" "/Users/andreas/Projects/vev/build/musicbrainz/vev-mbrainz-subset-full-chunked")
        values-chunks (max 0 (cli.int-option os.args "--values-chunks" 8))
        progress (= (cli.option os.args "--progress" "false") "true")
        print-rows (= (cli.option os.args "--print-rows" "false") "true")
        warmups (max 0 (cli.int-option os.args "--warmups" 10))
        samples (max 1 (cli.int-option os.args "--samples" 25))
        conn (if (= dataset "real")
               (vev.create-conn)
               (seed-mini))
        no-inputs ([]vev.Query-Input [])
        beatles-input ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "The Beatles"))])
        john-lennon-input ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "John Lennon"))])
        selected-artists-input ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "The Beatles") (vev.value-string "Miles Davis")]))])
        selected-date-releases-input ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "Abbey Road") (vev.value-string "In a Silent Way") (vev.value-string "Bitches Brew")]))])
        dynamic-attr-input ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "United Kingdom"))
                                               (vev.query-input-collection ([]vev.Value [(vev.value-keyword ":artist/country")]))])
        dynamic-pull-release-input ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Led Zeppelin"))
                                                       (vev.query-input-pull-pattern ([]vev.Pull-Spec [(vev.pull-spec ":release/name" ([]vev.Pull-Spec []))]))])
        relation-artist-release-input ([]vev.Query-Input [(vev.query-input-relation ([]vev.Value [(vev.value-string "The Beatles") (vev.value-string "Abbey Road") (vev.value-string "Miles Davis") (vev.value-string "Bitches Brew")]) 2)])
        short-track-input ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 200000))])
        selected-releases-input ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "Abbey Road") (vev.value-string "In a Silent Way")]))])]
    (when (!= store-path "")
      (run-store-workloads! store-path selected warmups samples)
      (return))
    (when (= dataset "real")
      (when (not (load-real! (addr conn) schema-path values-path values-prefix values-chunks progress))
        (return)))
    (let [release-first-workload (fmt.tprintf "musicbrainz-%s-release-first" dataset)
          track-first-workload (fmt.tprintf "musicbrainz-%s-track-first" dataset)
          john-lennon-pre-1970-tracks-workload (fmt.tprintf "musicbrainz-%s-john-lennon-pre-1970-tracks" dataset)
          beatles-releases-workload (fmt.tprintf "musicbrainz-%s-beatles-releases" dataset)
          beatles-short-track-collection-workload (fmt.tprintf "musicbrainz-%s-beatles-short-track-collection" dataset)
          abbey-road-release-date-tuple-workload (fmt.tprintf "musicbrainz-%s-abbey-road-release-date-tuple" dataset)
          beatles-start-year-scalar-workload (fmt.tprintf "musicbrainz-%s-beatles-start-year-scalar" dataset)
          abbey-road-track-minutes-workload (fmt.tprintf "musicbrainz-%s-abbey-road-track-minutes" dataset)
          miles-enum-id-workload (fmt.tprintf "musicbrainz-%s-miles-enum-id" dataset)
          track-count-workload (fmt.tprintf "musicbrainz-%s-beatles-track-count" dataset)
          min-max-duration-workload (fmt.tprintf "musicbrainz-%s-beatles-min-max-duration" dataset)
          beatles-duration-stats-workload (fmt.tprintf "musicbrainz-%s-beatles-duration-stats" dataset)
          beatles-duration-stddev-workload (fmt.tprintf "musicbrainz-%s-beatles-duration-stddev" dataset)
          beatles-duration-sum-workload (fmt.tprintf "musicbrainz-%s-beatles-duration-sum" dataset)
          track-name-statistics-workload (fmt.tprintf "musicbrainz-%s-track-name-statistics" dataset)
          lookup-country-workload (fmt.tprintf "musicbrainz-%s-lookup-country" dataset)
          selected-artists-releases-workload (fmt.tprintf "musicbrainz-%s-selected-artists-releases" dataset)
          release-date-workload (fmt.tprintf "musicbrainz-%s-release-date" dataset)
          fallback-start-month-workload (fmt.tprintf "musicbrainz-%s-fallback-start-month" dataset)
          get-some-country-workload (fmt.tprintf "musicbrainz-%s-get-some-country" dataset)
          missing-start-year-workload (fmt.tprintf "musicbrainz-%s-missing-start-year" dataset)
          dynamic-attr-workload (fmt.tprintf "musicbrainz-%s-dynamic-attr" dataset)
          top-duration-workload (fmt.tprintf "musicbrainz-%s-top-duration" dataset)
          not-beatles-male-workload (fmt.tprintf "musicbrainz-%s-not-beatles-male" dataset)
          or-two-artists-workload (fmt.tprintf "musicbrainz-%s-or-two-artists" dataset)
          relation-artist-release-workload (fmt.tprintf "musicbrainz-%s-relation-artist-release" dataset)
          not-join-release-workload (fmt.tprintf "musicbrainz-%s-not-join-release" dataset)
          or-join-release-workload (fmt.tprintf "musicbrainz-%s-or-join-release" dataset)
          map-beatles-releases-workload (fmt.tprintf "musicbrainz-%s-map-beatles-releases" dataset)
          keys-beatles-releases-workload (fmt.tprintf "musicbrainz-%s-keys-beatles-releases" dataset)
          strs-beatles-releases-workload (fmt.tprintf "musicbrainz-%s-strs-beatles-releases" dataset)
          syms-beatles-releases-workload (fmt.tprintf "musicbrainz-%s-syms-beatles-releases" dataset)
          rule-track-info-workload (fmt.tprintf "musicbrainz-%s-rule-track-info" dataset)
          rule-short-track-workload (fmt.tprintf "musicbrainz-%s-rule-short-track" dataset)
          pull-release-workload (fmt.tprintf "musicbrainz-%s-pull-release" dataset)
          dynamic-pull-release-workload (fmt.tprintf "musicbrainz-%s-dynamic-pull-release" dataset)
          pull-release-nested-workload (fmt.tprintf "musicbrainz-%s-pull-release-nested" dataset)
          direct-pull-artist-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist" dataset)
          direct-pull-artist-wildcard-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist-wildcard" dataset)
          direct-pull-artist-releases-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist-releases" dataset)
          direct-pull-artist-releases-limit-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist-releases-limit" dataset)
          direct-pull-artist-default-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist-default" dataset)
          direct-pull-artist-alias-workload (fmt.tprintf "musicbrainz-%s-direct-pull-artist-alias" dataset)
          direct-pull-many-artists-workload (fmt.tprintf "musicbrainz-%s-direct-pull-many-artists" dataset)
          direct-pull-release-workload (fmt.tprintf "musicbrainz-%s-direct-pull-release" dataset)]
      (when (should-run? selected release-first-workload)
        (print-workload! conn.db release-first-workload release-first-query beatles-input warmups samples print-rows))
      (when (should-run? selected track-first-workload)
        (print-workload! conn.db track-first-workload track-first-query beatles-input warmups samples print-rows))
      (when (should-run? selected john-lennon-pre-1970-tracks-workload)
        (print-workload! conn.db john-lennon-pre-1970-tracks-workload john-lennon-pre-1970-tracks-query john-lennon-input warmups samples print-rows))
      (when (should-run? selected beatles-releases-workload)
        (print-workload! conn.db beatles-releases-workload beatles-releases-query no-inputs warmups samples print-rows))
      (when (should-run? selected beatles-short-track-collection-workload)
        (print-find-value-workload! conn.db beatles-short-track-collection-workload beatles-short-track-collection-query .Collection warmups samples print-rows))
      (when (should-run? selected abbey-road-release-date-tuple-workload)
        (print-find-value-workload! conn.db abbey-road-release-date-tuple-workload abbey-road-release-date-tuple-query .Tuple warmups samples print-rows))
      (when (should-run? selected beatles-start-year-scalar-workload)
        (print-find-value-workload! conn.db beatles-start-year-scalar-workload beatles-start-year-scalar-query .Scalar warmups samples print-rows))
      (when (should-run? selected abbey-road-track-minutes-workload)
        (print-workload! conn.db abbey-road-track-minutes-workload abbey-road-track-minutes-query no-inputs warmups samples print-rows))
      (when (should-run? selected miles-enum-id-workload)
        (print-workload! conn.db miles-enum-id-workload miles-enum-id-query no-inputs warmups samples print-rows))
      (when (should-run? selected track-count-workload)
        (print-workload! conn.db track-count-workload track-count-query no-inputs warmups samples print-rows))
      (when (should-run? selected min-max-duration-workload)
        (print-workload! conn.db min-max-duration-workload min-max-duration-query no-inputs warmups samples print-rows))
      (when (should-run? selected beatles-duration-stats-workload)
        (print-workload! conn.db beatles-duration-stats-workload beatles-duration-stats-query no-inputs warmups samples print-rows))
      (when (should-run? selected beatles-duration-stddev-workload)
        (print-workload-normalized-floats! conn.db beatles-duration-stddev-workload beatles-duration-stddev-query no-inputs warmups samples print-rows))
      (when (should-run? selected beatles-duration-sum-workload)
        (print-workload! conn.db beatles-duration-sum-workload beatles-duration-sum-query no-inputs warmups samples print-rows))
      (when (should-run? selected track-name-statistics-workload)
        (print-workload-normalized-floats! conn.db track-name-statistics-workload track-name-statistics-query no-inputs warmups samples print-rows))
      (when (should-run? selected lookup-country-workload)
        (print-workload! conn.db lookup-country-workload lookup-country-query no-inputs warmups samples print-rows))
      (when (should-run? selected selected-artists-releases-workload)
        (print-workload! conn.db selected-artists-releases-workload selected-artists-releases-query selected-artists-input warmups samples print-rows))
      (when (should-run? selected release-date-workload)
        (print-workload! conn.db release-date-workload release-date-query selected-date-releases-input warmups samples print-rows))
      (when (should-run? selected fallback-start-month-workload)
        (print-workload! conn.db fallback-start-month-workload fallback-start-month-query selected-artists-input warmups samples print-rows))
      (when (should-run? selected get-some-country-workload)
        (print-workload! conn.db get-some-country-workload get-some-country-query no-inputs warmups samples print-rows))
      (when (should-run? selected missing-start-year-workload)
        (print-workload! conn.db missing-start-year-workload missing-start-year-query no-inputs warmups samples print-rows))
      (when (should-run? selected dynamic-attr-workload)
        (print-workload! conn.db dynamic-attr-workload dynamic-attr-query dynamic-attr-input warmups samples print-rows))
      (when (should-run? selected top-duration-workload)
        (print-workload! conn.db top-duration-workload top-duration-query no-inputs warmups samples print-rows))
      (when (should-run? selected not-beatles-male-workload)
        (print-workload! conn.db not-beatles-male-workload not-beatles-male-query no-inputs warmups samples print-rows))
      (when (should-run? selected or-two-artists-workload)
        (print-workload! conn.db or-two-artists-workload or-two-artists-query no-inputs warmups samples print-rows))
      (when (should-run? selected relation-artist-release-workload)
        (print-workload! conn.db relation-artist-release-workload relation-artist-release-query relation-artist-release-input warmups samples print-rows))
      (when (should-run? selected not-join-release-workload)
        (print-workload! conn.db not-join-release-workload not-join-release-query selected-releases-input warmups samples print-rows))
      (when (should-run? selected or-join-release-workload)
        (print-workload! conn.db or-join-release-workload or-join-release-query selected-releases-input warmups samples print-rows))
      (when (should-run? selected map-beatles-releases-workload)
        (print-workload! conn.db map-beatles-releases-workload map-beatles-releases-query no-inputs warmups samples print-rows))
      (when (should-run? selected keys-beatles-releases-workload)
        (print-keyed-workload! conn.db keys-beatles-releases-workload keys-beatles-releases-query ":keys" warmups samples print-rows))
      (when (should-run? selected strs-beatles-releases-workload)
        (print-keyed-workload! conn.db strs-beatles-releases-workload strs-beatles-releases-query ":strs" warmups samples print-rows))
      (when (should-run? selected syms-beatles-releases-workload)
        (print-keyed-workload! conn.db syms-beatles-releases-workload syms-beatles-releases-query ":syms" warmups samples print-rows))
      (when (should-run? selected rule-track-info-workload)
        (print-workload-with-rules! conn.db rule-track-info-workload rule-track-info-query beatles-input musicbrainz-rules true warmups samples print-rows))
      (when (should-run? selected rule-short-track-workload)
        (print-workload-with-rules! conn.db rule-short-track-workload rule-short-track-query short-track-input musicbrainz-rules true warmups samples print-rows))
      (when (should-run? selected pull-release-workload)
        (print-workload! conn.db pull-release-workload pull-release-query selected-releases-input warmups samples print-rows))
      (when (should-run? selected dynamic-pull-release-workload)
        (print-workload! conn.db dynamic-pull-release-workload dynamic-pull-release-query dynamic-pull-release-input warmups samples print-rows))
      (when (should-run? selected pull-release-nested-workload)
        (print-workload! conn.db pull-release-nested-workload pull-release-nested-query selected-releases-input warmups samples print-rows))
      (when (should-run? selected direct-pull-artist-workload)
        (print-value-workload! direct-pull-artist-workload (time-direct-pull-artist conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-artist-wildcard-workload)
        (print-value-workload-without-db-id! direct-pull-artist-wildcard-workload (time-direct-pull-artist-wildcard conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-artist-releases-workload)
        (print-value-workload! direct-pull-artist-releases-workload (time-direct-pull-artist-releases conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-artist-releases-limit-workload)
        (print-value-workload! direct-pull-artist-releases-limit-workload (time-direct-pull-artist-releases-limit conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-artist-default-workload)
        (print-value-workload! direct-pull-artist-default-workload (time-direct-pull-artist-default conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-artist-alias-workload)
        (print-value-workload! direct-pull-artist-alias-workload (time-direct-pull-artist-alias conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-many-artists-workload)
        (print-value-workload! direct-pull-many-artists-workload (time-direct-pull-many-artists conn.db warmups samples) print-rows))
      (when (should-run? selected direct-pull-release-workload)
        (print-value-workload! direct-pull-release-workload (time-direct-pull-release conn.db warmups samples) print-rows)))))
