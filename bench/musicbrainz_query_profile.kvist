(defstruct Profile-Timing {
  profiled: vev.Profiled-Result-Set
  timing: bench.Timing
})

(defstruct Store-Profile-Timing {
  profiled: vev.Profiled-Result-Set
  timing: bench.Timing
})

(defstruct Value-Timing {
  value: vev.Value
  timing: bench.Timing
})

(defstruct Keyed-Timing {
  rows: [dynamic]vev.Keyed-Row
  timing: bench.Timing
})

(defenum Find-Value-Kind [
  Collection
  Tuple
  Scalar
])

(defstruct Find-Value-Timing {
  value: vev.Value
  ok: bool
  kind: Find-Value-Kind
  timing: bench.Timing
})

(defn profile-timing [profiled: vev.Profiled-Result-Set, timing: bench.Timing] -> Profile-Timing
  (Profile-Timing {profiled: profiled timing: timing}))

(defn store-profile-timing [profiled: vev.Profiled-Result-Set, timing: bench.Timing] -> Store-Profile-Timing
  (Store-Profile-Timing {profiled: profiled timing: timing}))

(defn value-timing [value: vev.Value, timing: bench.Timing] -> Value-Timing
  (Value-Timing {value: value timing: timing}))

(defn keyed-timing [rows: [dynamic]vev.Keyed-Row, timing: bench.Timing] -> Keyed-Timing
  (Keyed-Timing {rows: rows timing: timing}))

(defn find-value-timing [value: vev.Value, ok: bool, kind: Find-Value-Kind, timing: bench.Timing] -> Find-Value-Timing
  (Find-Value-Timing {value: value ok: ok kind: kind timing: timing}))

(defn seed-mini [] -> vev.Conn
  (let [conn (vev.create-conn)
        report (vev.transact-text (addr conn) musicbrainz-mini-tx)]
    (when (not report.ok)
      (fmt.printf "engine=vev workload=musicbrainz-mini-seed ok=false error=%s\n" report.error))
    (vev.delete-live-tx-report-shallow report)
    conn))

(defn load-tx-file! [conn: ^vev.Conn, path: string, label: string, progress: bool] -> bool
  (let [[data read-err] (os.read_entire_file path context.allocator)]
    (when (!= read-err nil)
      (fmt.printf "engine=vev workload=musicbrainz-real-load ok=false stage=%s error=read_failed path=%s\n" label path)
      (return false))
    (defer (delete data))
    (let [parse-start (time.now)
          prepared (vev.prepare-tx-text (string data))
          parse-us (bench.elapsed-us parse-start)]
      (when (not prepared.ok)
        (fmt.printf "engine=vev workload=musicbrainz-real-load ok=false stage=%s error=%s parse_us=%.0f\n" label prepared.error parse-us)
        (vev.delete-prepared-tx-data-shallow prepared)
        (return false))
      (let [tx-start (time.now)
            report (vev.transact-prepared conn prepared)
            tx-us (bench.elapsed-us tx-start)]
        (when progress
          (fmt.printf "progress stage=%s items=%d ok=%v parse_us=%.0f tx_us=%.0f datoms=%d current=%d\n" label (count prepared.tx-data) report.ok parse-us tx-us (count conn^.db.datoms) (count conn^.db.current)))
        (vev.delete-prepared-tx-data-shallow prepared)
        (when (not report.ok)
          (fmt.printf "engine=vev workload=musicbrainz-real-load ok=false stage=%s error=%s parse_us=%.0f tx_us=%.0f\n" label report.error parse-us tx-us)
          (vev.delete-tx-report-shallow report)
          (return false))
        (vev.delete-live-tx-report-shallow report)
        (return true)))))

(defn load-real! [conn: ^vev.Conn, schema-path: string, values-path: string, values-prefix: string, values-chunks: int, progress: bool] -> bool
  (let [start (time.now)]
    (when (not (load-tx-file! conn schema-path "schema" progress))
      (return false))
    (if (> values-chunks 0)
      (let [index 0]
        (while (< index values-chunks)
          (let [path (fmt.tprintf "%s-values-%04d.edn" values-prefix index)
                label (fmt.tprintf "values-%04d" index)]
            (when (not (load-tx-file! conn path label progress))
              (return false)))
          (set! index (+ index 1))))
      (when (not (load-tx-file! conn values-path "values" progress))
        (return false)))
    (fmt.printf "engine=vev workload=musicbrainz-real-load ok=true datoms=%d current=%d import_us=%.0f\n" (count conn^.db.datoms) (count conn^.db.current) (bench.elapsed-us start))
    (return true)))

(defn time-profiled-query [db: vev.DB, query: string, inputs: []vev.Query-Input, rules: string, use-rules: bool, warmups: int, samples-count: int] -> Profile-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (let [warmup (if use-rules
                   (vev.q-text-profiled-with-rules db query rules inputs)
                   (vev.q-text-profiled-with-inputs db query inputs))]
      (vev.delete-profiled-result-set-shallow warmup)))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            profiled (if use-rules
                       (vev.q-text-profiled-with-rules db query rules inputs)
                       (vev.q-text-profiled-with-inputs db query inputs))
            elapsed (bench.elapsed-us start)]
        (arr.push! samples elapsed)
        (vev.delete-profiled-result-set-shallow profiled)))
    (profile-timing
      (if use-rules
        (vev.q-text-profiled-with-rules db query rules inputs)
        (vev.q-text-profiled-with-inputs db query inputs))
      (bench.timing-from-samples (slice samples 0)))))

(defn time-store-profiled-query [snapshot: ^vev.Store-DB, query: string, warmups: int, samples-count: int] -> Store-Profile-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (let [warmup (vev.q-profiled-store-db-text snapshot query)]
      (vev.delete-profiled-result-set-shallow warmup)))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            profiled (vev.q-profiled-store-db-text snapshot query)
            elapsed (bench.elapsed-us start)]
        (arr.push! samples elapsed)
        (vev.delete-profiled-result-set-shallow profiled)))
    (store-profile-timing
      (vev.q-profiled-store-db-text snapshot query)
      (bench.timing-from-samples (slice samples 0)))))

(defn fingerprint-text [seed: u64, text: string] -> u64
  (let [out seed]
    (for [ch text]
      (set! out (+ (* out 131) (u64 ch))))
    out))

(defn value-result-row-count [value: vev.Value] -> int
  (if (= value.kind .Vector)
    (count value.items)
    1))

(defn value-canonical-text-without-db-id [value: vev.Value] -> string
  (case value.kind
    .Vector (let [parts (make [dynamic]string) :defer
                  owned-parts (make [dynamic]string) :defer]
              (arr.push! parts "[")
              (for [item index value.items]
                (when (> index 0)
                  (arr.push! parts " "))
                (let [item-text (value-canonical-text-without-db-id item)]
                  (arr.push! parts item-text)
                  (arr.push! owned-parts item-text)))
              (arr.push! parts "]")
              (let [out (strings.concatenate (slice parts 0))]
                (for [part owned-parts]
                  (delete part))
                out))
    .Map (let [entries (make [dynamic]string) :defer]
           (let [index 0]
             (while (< (+ index 1) (count value.items))
               (let [key value.items[index]
                     map-value value.items[(+ index 1)]]
                 (when (not (and (= key.kind .Keyword) (= key.text ":db/id")))
                   (let [key-text (value-canonical-text-without-db-id key)
                         value-text (value-canonical-text-without-db-id map-value)
                         parts ([]string [key-text " " value-text])
                         entry (strings.concatenate parts)]
                     (delete key-text)
                     (delete value-text)
                     (arr.push! entries entry))))
               (set! index (+ index 2))))
           (arr.sort! entries)
           (let [parts (make [dynamic]string) :defer]
             (arr.push! parts "{")
             (for [entry index entries]
               (when (> index 0)
                 (arr.push! parts " "))
               (arr.push! parts entry))
             (arr.push! parts "}")
             (let [out (strings.concatenate (slice parts 0))]
               (for [entry entries]
                 (delete entry))
               out)))
     (vev.value-serializable-text value)))

(defn value-result-fingerprint-with [value: vev.Value, strip-db-id: bool] -> u64
  (let [keys (make [dynamic]string) :defer]
    (if (= value.kind .Vector)
      (for [item value.items]
        (arr.push! keys (if strip-db-id
                          (value-canonical-text-without-db-id item)
                          (vev.value-serializable-text item))))
      (arr.push! keys (if strip-db-id
                        (value-canonical-text-without-db-id value)
                        (vev.value-serializable-text value))))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      (for [key keys]
        (delete key))
      hash)))

(defn value-result-fingerprint [value: vev.Value] -> u64
  (value-result-fingerprint-with value false))

(defn value-result-fingerprint-without-db-id [value: vev.Value] -> u64
  (value-result-fingerprint-with value true))

(defn tuple-value-row-key [value: vev.Value] -> string
  (let [parts (make [dynamic]string) :defer
        owned-parts (make [dynamic]string) :defer]
    (if (= value.kind .Vector)
      (for [item index value.items]
        (when (> index 0)
          (let [[separator _] (strings.clone "|")]
            (arr.push! parts separator)
            (arr.push! owned-parts separator)))
        (let [text (vev.value-serializable-text item)]
          (arr.push! parts text)
          (arr.push! owned-parts text)))
      (let [text (vev.value-serializable-text value)]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (let [out (strings.concatenate (slice parts 0))]
      (for [part owned-parts]
        (delete part))
      out)))

(defn find-value-row-count [measured: Find-Value-Timing] -> int
  (case measured.kind
    .Collection (if (= measured.value.kind .Vector)
                  (return (count measured.value.items))
                  (return 1))
    .Tuple (return 1)
    .Scalar (return 1)
    (return 1))
  1)

(defn find-value-fingerprint [measured: Find-Value-Timing] -> u64
  (let [keys (make [dynamic]string) :defer]
    (case measured.kind
      .Collection (if (= measured.value.kind .Vector)
                    (for [item measured.value.items]
                      (arr.push! keys (vev.value-serializable-text item)))
                    (arr.push! keys (vev.value-serializable-text measured.value)))
      .Tuple (arr.push! keys (tuple-value-row-key measured.value))
      .Scalar (arr.push! keys (vev.value-serializable-text measured.value))
      (do))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      (for [key keys]
        (delete key))
      hash)))

(defn result-row-key [db: vev.DB, row: vev.Result-Row] -> string
  (let [parts (make [dynamic]string) :defer
        owned-parts (make [dynamic]string) :defer]
    (for [value index row.values]
      (when (> index 0)
        (let [[separator _] (strings.clone "|")]
          (arr.push! parts separator)
          (arr.push! owned-parts separator)))
      (let [text (vev.value-serializable-text value)]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (for [pull row.pulls]
      (when (> (count parts) 0)
        (let [[separator _] (strings.clone "|")]
          (arr.push! parts separator)
          (arr.push! owned-parts separator)))
      (let [text (vev.value-serializable-text (vev.pull-result-value db pull))]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (let [out (strings.concatenate (slice parts 0))]
      (for [part owned-parts]
        (delete part))
      out)))

(defn normalized-float-value-text [value: vev.Value] -> string
  (when (= value.kind .Float)
    (let [scaled (i64 (math.round (* value.float-value 1000000.0)))
          scaled-text (vev.value-serializable-text (vev.value-int scaled))
          parts ([]string ["[:vev/float6 " scaled-text "]"])
          out (strings.concatenate parts)]
      (delete scaled-text)
      (return out)))
  (vev.value-serializable-text value))

(defn result-row-key-normalized-floats [db: vev.DB, row: vev.Result-Row] -> string
  (let [parts (make [dynamic]string) :defer
        owned-parts (make [dynamic]string) :defer]
    (for [value index row.values]
      (when (> index 0)
        (let [[separator _] (strings.clone "|")]
          (arr.push! parts separator)
          (arr.push! owned-parts separator)))
      (let [text (normalized-float-value-text value)]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (for [pull row.pulls]
      (when (> (count parts) 0)
        (let [[separator _] (strings.clone "|")]
          (arr.push! parts separator)
          (arr.push! owned-parts separator)))
      (let [text (vev.value-serializable-text (vev.pull-result-value db pull))]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (let [out (strings.concatenate (slice parts 0))]
      (for [part owned-parts]
        (delete part))
      out)))

(defn result-row-key-normalized-floats-values-only [row: vev.Result-Row] -> string
  (let [parts (make [dynamic]string) :defer
        owned-parts (make [dynamic]string) :defer]
    (for [value index row.values]
      (when (> index 0)
        (let [[separator _] (strings.clone "|")]
          (arr.push! parts separator)
          (arr.push! owned-parts separator)))
      (let [text (normalized-float-value-text value)]
        (arr.push! parts text)
        (arr.push! owned-parts text)))
    (let [out (strings.concatenate (slice parts 0))]
      (for [part owned-parts]
        (delete part))
      out)))

(defn result-fingerprint [db: vev.DB, result: vev.Result-Set] -> u64
  (let [keys (make [dynamic]string) :defer]
    (for [row result.rows]
      (arr.push! keys (result-row-key db row)))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      (for [key keys]
        (delete key))
      hash)))

(defn result-fingerprint-normalized-floats [db: vev.DB, result: vev.Result-Set] -> u64
  (let [keys (make [dynamic]string) :defer]
    (for [row result.rows]
      (arr.push! keys (result-row-key-normalized-floats db row)))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      (for [key keys]
        (delete key))
      hash)))

(defn result-fingerprint-normalized-floats-values-only [result: vev.Result-Set] -> u64
  (let [keys (make [dynamic]string) :defer]
    (for [row result.rows]
      (arr.push! keys (result-row-key-normalized-floats-values-only row)))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      (for [key keys]
        (delete key))
      hash)))

(defn keyed-value-key-text [item: vev.Keyed-Value] -> string
  (case item.kind
    .Keyword (return (fmt.tprintf ":%s" item.key))
    .String (return (vev.value-serializable-text (vev.value-string item.key)))
    .Symbol (return (fmt.tprintf "%s" item.key))
    (return (fmt.tprintf "%s" item.key)))
  (fmt.tprintf "%s" item.key))

(defn keyed-row-key [row: vev.Keyed-Row] -> string
  (let [entries (make [dynamic]string) :defer]
    (for [item row.items]
      (let [key-text (keyed-value-key-text item)
            value-text (vev.value-serializable-text item.value)]
        (arr.push! entries (fmt.tprintf "%s %s" key-text value-text))))
    (arr.sort! entries)
    (let [parts (make [dynamic]string) :defer]
      (arr.push! parts "{")
      (for [entry index entries]
        (when (> index 0)
          (arr.push! parts " "))
        (arr.push! parts entry))
      (arr.push! parts "}")
      (strings.concatenate (slice parts 0)))))

(defn keyed-fingerprint [rows: []vev.Keyed-Row] -> u64
  (let [keys (make [dynamic]string) :defer]
    (for [row rows]
      (arr.push! keys (keyed-row-key row)))
    (arr.sort! keys)
    (let [hash (u64 0)]
      (for [key keys]
        (set! hash (fingerprint-text hash key))
        (set! hash (fingerprint-text hash "\n")))
      hash)))

(defn print-profile [db: vev.DB, workload: string, result: Profile-Timing]
  (fmt.printf
    "engine=vev workload=%s ok=%v rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f steps=%d clauses=%d candidates=%d max_bindings=%d output_rows=%d\n"
    workload
    result.profiled.result.ok
    (count result.profiled.result.rows)
    (result-fingerprint db result.profiled.result)
    result.timing.min-us
    result.timing.median-us
    result.timing.p90-us
    result.timing.max-us
    result.profiled.stats.steps
    result.profiled.stats.clauses
    result.profiled.stats.clause-candidates
    result.profiled.stats.max-intermediate-bindings
    result.profiled.stats.output-rows))

(defn print-profile-normalized-floats [db: vev.DB, workload: string, result: Profile-Timing]
  (fmt.printf
    "engine=vev workload=%s ok=%v rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f steps=%d clauses=%d candidates=%d max_bindings=%d output_rows=%d\n"
    workload
    result.profiled.result.ok
    (count result.profiled.result.rows)
    (result-fingerprint-normalized-floats db result.profiled.result)
    result.timing.min-us
    result.timing.median-us
    result.timing.p90-us
    result.timing.max-us
    result.profiled.stats.steps
    result.profiled.stats.clauses
    result.profiled.stats.clause-candidates
    result.profiled.stats.max-intermediate-bindings
    result.profiled.stats.output-rows))

(defn print-store-profile-normalized-floats [workload: string, result: Store-Profile-Timing]
  (if result.profiled.result.ok
    (fmt.printf
      "engine=vev-store workload=%s ok=true rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f steps=%d clauses=%d candidates=%d max_bindings=%d output_rows=%d\n"
      workload
      (count result.profiled.result.rows)
      (result-fingerprint-normalized-floats-values-only result.profiled.result)
      result.timing.min-us
      result.timing.median-us
      result.timing.p90-us
      result.timing.max-us
      result.profiled.stats.steps
      result.profiled.stats.clauses
      result.profiled.stats.clause-candidates
      result.profiled.stats.max-intermediate-bindings
      result.profiled.stats.output-rows)
    (fmt.printf
      "engine=vev-store workload=%s ok=false rows=%d error=%s min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f steps=%d clauses=%d candidates=%d max_bindings=%d output_rows=%d\n"
      workload
      (count result.profiled.result.rows)
      result.profiled.result.error
      result.timing.min-us
      result.timing.median-us
      result.timing.p90-us
      result.timing.max-us
      result.profiled.stats.steps
      result.profiled.stats.clauses
      result.profiled.stats.clause-candidates
      result.profiled.stats.max-intermediate-bindings
      result.profiled.stats.output-rows)))

(defn print-result-rows [db: vev.DB, workload: string, result: vev.Result-Set]
  (let [keys (make [dynamic]string) :defer]
    (for [row result.rows]
      (arr.push! keys (result-row-key db row)))
    (arr.sort! keys)
    (for [key keys]
      (fmt.printf "row engine=vev workload=%s key=%s\n" workload key)
      (delete key))))

(defn should-run? [selected: string, workload: string] -> bool
  (or (= selected "all")
      (= selected workload)
      (= selected (strings.trim_prefix workload "musicbrainz-mini-"))
      (= selected (strings.trim_prefix workload "musicbrainz-real-"))
      (= selected (strings.trim_prefix workload "musicbrainz-store-"))))

(defn print-workload-with-rules! [db: vev.DB, workload: string, query: string, inputs: []vev.Query-Input, rules: string, use-rules: bool, warmups: int, samples: int, print-rows: bool]
  (let [result (time-profiled-query db query inputs rules use-rules warmups samples)]
    (print-profile db workload result)
    (when print-rows
      (print-result-rows db workload result.profiled.result))
    (vev.delete-profiled-result-set-shallow result.profiled)))

(defn print-workload! [db: vev.DB, workload: string, query: string, inputs: []vev.Query-Input, warmups: int, samples: int, print-rows: bool]
  (print-workload-with-rules! db workload query inputs "" false warmups samples print-rows))

(defn print-workload-normalized-floats! [db: vev.DB, workload: string, query: string, inputs: []vev.Query-Input, warmups: int, samples: int, print-rows: bool]
  (let [result (time-profiled-query db query inputs "" false warmups samples)]
    (print-profile-normalized-floats db workload result)
    (when print-rows
      (print-result-rows db workload result.profiled.result))
    (vev.delete-profiled-result-set-shallow result.profiled)))

(defn print-store-workload-normalized-floats! [snapshot: ^vev.Store-DB, workload: string, query: string, warmups: int, samples: int]
  (let [result (time-store-profiled-query snapshot query warmups samples)]
    (print-store-profile-normalized-floats workload result)
    (vev.delete-profiled-result-set-shallow result.profiled)))

(defn run-store-workloads! [store-path: string, selected: string, warmups: int, samples: int]
  (let [[store store-ok store-error] (vev.open-store-read-only store-path)]
    (when (not store-ok)
      (fmt.printf "engine=vev-store workload=musicbrainz-store-open ok=false error=%s\n" store-error)
      (return))
    (defer (vev.close-store store))
    (let [[snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
      (when (not snapshot-ok)
        (fmt.printf "engine=vev-store workload=musicbrainz-store-db ok=false error=%s\n" snapshot-error)
        (return))
      (defer (vev.close-store-db! (addr snapshot)))
      (let [release-year-count-workload "musicbrainz-store-release-year-count"
            release-media-year-count-workload "musicbrainz-store-release-media-year-count"
            track-year-count-workload "musicbrainz-store-track-year-count"
            track-name-year-count-workload "musicbrainz-store-track-name-year-count"
            track-name-length-avg-workload "musicbrainz-store-track-name-length-avg"
            track-name-statistics-workload "musicbrainz-store-track-name-statistics"]
        (when (should-run? selected release-year-count-workload)
          (print-store-workload-normalized-floats! (addr snapshot) release-year-count-workload store-release-year-count-query warmups samples))
        (when (should-run? selected release-media-year-count-workload)
          (print-store-workload-normalized-floats! (addr snapshot) release-media-year-count-workload store-release-media-year-count-query warmups samples))
        (when (should-run? selected track-year-count-workload)
          (print-store-workload-normalized-floats! (addr snapshot) track-year-count-workload store-track-year-count-query warmups samples))
        (when (should-run? selected track-name-year-count-workload)
          (print-store-workload-normalized-floats! (addr snapshot) track-name-year-count-workload store-track-name-year-count-query warmups samples))
        (when (should-run? selected track-name-length-avg-workload)
          (print-store-workload-normalized-floats! (addr snapshot) track-name-length-avg-workload track-name-length-avg-query warmups samples))
        (when (should-run? selected track-name-statistics-workload)
          (print-store-workload-normalized-floats! (addr snapshot) track-name-statistics-workload track-name-statistics-query warmups samples))))))

(defn run-find-value [db: vev.DB, query: string, kind: Find-Value-Kind] -> [value: vev.Value, ok: bool]
  (case kind
    .Collection (return (vev.value-vector (slice (vev.q-text-collection db query) 0)) true)
    .Tuple (return (vev.value-vector (slice (vev.q-text-tuple db query) 0)) true)
    .Scalar (let [[value ok] (vev.q-text-scalar db query)]
              (return value ok))
    (return (vev.value-nil) false))
  (return (vev.value-nil) false))

(defn time-find-value-query [db: vev.DB, query: string, kind: Find-Value-Kind, warmups: int, samples-count: int] -> Find-Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (let [[value _] (run-find-value db query kind)]
      (discard value)))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            [value _] (run-find-value db query kind)
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (let [[value ok] (run-find-value db query kind)]
      (find-value-timing value ok kind (bench.timing-from-samples (slice samples 0))))))

(defn print-find-value-rows [workload: string, measured: Find-Value-Timing]
  (let [keys (make [dynamic]string) :defer]
    (case measured.kind
      .Collection (if (= measured.value.kind .Vector)
                    (for [item measured.value.items]
                      (arr.push! keys (vev.value-serializable-text item)))
                    (arr.push! keys (vev.value-serializable-text measured.value)))
      .Tuple (arr.push! keys (tuple-value-row-key measured.value))
      .Scalar (arr.push! keys (vev.value-serializable-text measured.value))
      (do))
    (arr.sort! keys)
    (for [key keys]
      (fmt.printf "row engine=vev workload=%s key=%s\n" workload key)
      (delete key))))

(defn print-find-value-workload! [db: vev.DB, workload: string, query: string, kind: Find-Value-Kind, warmups: int, samples: int, print-rows: bool]
  (let [measured (time-find-value-query db query kind warmups samples)]
    (fmt.printf
      "engine=vev workload=%s ok=%v rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f\n"
      workload
      measured.ok
      (find-value-row-count measured)
      (find-value-fingerprint measured)
      measured.timing.min-us
      measured.timing.median-us
      measured.timing.p90-us
      measured.timing.max-us)
    (when print-rows
      (print-find-value-rows workload measured))))

(defn q-text-keyed [db: vev.DB, query: string, kind: string] -> [dynamic]vev.Keyed-Row
  (if (= kind ":strs")
    (return (vev.q-text-strs db query)))
  (if (= kind ":syms")
    (return (vev.q-text-syms db query)))
  (vev.q-text-keys db query))

(defn time-keyed-query [db: vev.DB, query: string, kind: string, warmups: int, samples-count: int] -> Keyed-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (q-text-keyed db query kind)))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            rows (q-text-keyed db query kind)
            elapsed (bench.elapsed-us start)]
        (discard rows)
        (arr.push! samples elapsed)))
    (keyed-timing
      (q-text-keyed db query kind)
      (bench.timing-from-samples (slice samples 0)))))

(defn print-keyed-rows [workload: string, rows: []vev.Keyed-Row]
  (let [keys (make [dynamic]string) :defer]
    (for [row rows]
      (arr.push! keys (keyed-row-key row)))
    (arr.sort! keys)
    (for [key keys]
      (fmt.printf "row engine=vev workload=%s key=%s\n" workload key))))

(defn print-keyed-workload! [db: vev.DB, workload: string, query: string, kind: string, warmups: int, samples: int, print-rows: bool]
  (let [measured (time-keyed-query db query kind warmups samples)]
    (fmt.printf
      "engine=vev workload=%s ok=true rows=%d fingerprint=%016x min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f\n"
      workload
      (count measured.rows)
      (keyed-fingerprint (slice measured.rows 0))
      measured.timing.min-us
      measured.timing.median-us
      measured.timing.p90-us
      measured.timing.max-us)
    (when print-rows
      (print-keyed-rows workload (slice measured.rows 0)))))

(defn print-value-rows [workload: string, value: vev.Value]
  (let [keys (make [dynamic]string) :defer]
    (if (= value.kind .Vector)
      (for [item value.items]
        (arr.push! keys (vev.value-serializable-text item)))
      (arr.push! keys (vev.value-serializable-text value)))
    (arr.sort! keys)
    (for [key keys]
      (fmt.printf "row engine=vev workload=%s key=%s\n" workload key)
      (delete key))))

(defn print-value-rows-without-db-id [workload: string, value: vev.Value]
  (let [keys (make [dynamic]string) :defer]
    (if (= value.kind .Vector)
      (for [item value.items]
        (arr.push! keys (value-canonical-text-without-db-id item)))
      (arr.push! keys (value-canonical-text-without-db-id value)))
    (arr.sort! keys)
    (for [key keys]
      (fmt.printf "row engine=vev workload=%s key=%s\n" workload key)
      (delete key))))

(defn time-direct-pull-artist [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-artist-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-artist-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
      (vev.pull-text-lookup-ref-value db direct-artist-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
      (bench.timing-from-samples (slice samples 0)))))

(defn time-direct-pull-artist-wildcard [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-artist-wildcard-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-artist-wildcard-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
      (vev.pull-text-lookup-ref-value db direct-artist-wildcard-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
      (bench.timing-from-samples (slice samples 0)))))

(defn time-direct-pull-artist-releases [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-artist-releases-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-artist-releases-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
      (vev.pull-text-lookup-ref-value db direct-artist-releases-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
      (bench.timing-from-samples (slice samples 0)))))

(defn time-direct-pull-artist-releases-limit [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-artist-releases-limit-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 samples-count)]
      (discard sample-index)
      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-artist-releases-limit-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
      (vev.pull-text-lookup-ref-value db direct-artist-releases-limit-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
      (bench.timing-from-samples (slice samples 0)))))

