(def musicbrainz-mini-tx
  "[{:db/id 100 :db/ident :country/name :db/valueType :db.type/string :db/unique :db.unique/identity} {:db/id 101 :db/ident :artist/name :db/valueType :db.type/string :db/unique :db.unique/identity} {:db/id 102 :db/ident :artist/country :db/valueType :db.type/ref} {:db/id 103 :db/ident :artist/type :db/valueType :db.type/ref} {:db/id 104 :db/ident :artist/startYear :db/valueType :db.type/long} {:db/id 105 :db/ident :artist/startMonth :db/valueType :db.type/long} {:db/id 106 :db/ident :artist/startDay :db/valueType :db.type/long} {:db/id 107 :db/ident :artist/gender :db/valueType :db.type/ref} {:db/id 108 :db/ident :artist/gid :db/valueType :db.type/string :db/unique :db.unique/identity} {:db/id 110 :db/ident :release/name :db/valueType :db.type/string} {:db/id 111 :db/ident :release/year :db/valueType :db.type/long} {:db/id 112 :db/ident :release/artists :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 113 :db/ident :release/country :db/valueType :db.type/ref} {:db/id 114 :db/ident :release/media :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 115 :db/ident :release/artistCredit :db/valueType :db.type/string} {:db/id 120 :db/ident :medium/tracks :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 121 :db/ident :medium/trackCount :db/valueType :db.type/long} {:db/id 122 :db/ident :medium/position :db/valueType :db.type/long} {:db/id 123 :db/ident :medium/name :db/valueType :db.type/string} {:db/id 130 :db/ident :track/name :db/valueType :db.type/string} {:db/id 131 :db/ident :track/duration :db/valueType :db.type/long} {:db/id 132 :db/ident :track/artists :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 133 :db/ident :track/position :db/valueType :db.type/long} {:db/id 210 :db/ident :artist.type/group} {:db/id 211 :db/ident :artist.type/person} {:db/id 212 :db/ident :artist.gender/male} {:db/id 201 :country/name \"United Kingdom\"} {:db/id 202 :country/name \"United States\"} {:db/id 301 :artist/name \"The Beatles\" :artist/gid \"beatles-gid\" :artist/country 201 :artist/type 210 :artist/startYear 1960 :artist/startMonth 8 :artist/startDay 17} {:db/id 302 :artist/name \"Miles Davis\" :artist/gid \"miles-gid\" :artist/country 202 :artist/type 211 :artist/gender 212 :artist/startYear 1944} {:db/id 401 :release/name \"Abbey Road\" :release/year 1969 :release/artists [301] :release/country 201 :release/media [601] :release/artistCredit \"The Beatles\"} {:db/id 402 :release/name \"Kind of Blue\" :release/year 1959 :release/artists [302] :release/country 202 :release/media [602] :release/artistCredit \"Miles Davis\"} {:db/id 501 :track/name \"Come Together\" :track/duration 259000 :track/artists [301] :track/position 1} {:db/id 502 :track/name \"Something\" :track/duration 182000 :track/artists [301] :track/position 2} {:db/id 503 :track/name \"So What\" :track/duration 545000 :track/artists [302] :track/position 1} {:db/id 601 :medium/name \"CD 1\" :medium/position 1 :medium/trackCount 2 :medium/tracks [501 502]} {:db/id 602 :medium/name \"CD 1\" :medium/position 1 :medium/trackCount 1 :medium/tracks [503]}]")

(def release-first-query
  "[:find ?title ?album ?year :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [(< ?year 1970)] [?r :release/name ?album] [?r :release/media ?m] [?m :medium/tracks ?t] [?t :track/name ?title]]")

(def track-first-query
  "[:find ?title ?album ?year :in $ ?artist-name :where [?a :artist/name ?artist-name] [?t :track/artists ?a] [?t :track/name ?title] [?r :release/artists ?a] [?r :release/year ?year] [(< ?year 1970)] [?r :release/name ?album] [?r :release/media ?m] [?m :medium/tracks ?t]]")

(def john-lennon-pre-1970-tracks-query
  "[:find ?title ?album ?year :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [?r :release/name ?album] [(< ?year 1970)] [?r :release/media ?m] [?m :medium/tracks ?t] [?t :track/name ?title]]")

(def beatles-releases-query
  "[:find ?release-name :where [?artist :artist/name \"The Beatles\"] [?release :release/artists ?artist] [?release :release/name ?release-name]]")

(def beatles-short-track-collection-query
  "[:find [?track-name ...] :where [?artist :artist/name \"The Beatles\"] [?track :track/artists ?artist] [?track :track/name ?track-name] [?track :track/duration ?duration] [(< ?duration 300000)]]")

(def abbey-road-release-date-tuple-query
  "[:find [?year ?month ?day] :where [?release :release/gid #uuid \"eca8996a-a637-3259-ba07-d2573c601a1b\"] [?release :release/year ?year] [?release :release/month ?month] [?release :release/day ?day]]")

(def beatles-start-year-scalar-query
  "[:find ?year . :where [?artist :artist/name \"The Beatles\"] [?artist :artist/startYear ?year]]")

(def abbey-road-track-minutes-query
  "[:find ?track-name ?minutes :where [?release :release/gid #uuid \"eca8996a-a637-3259-ba07-d2573c601a1b\"] [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/name ?track-name] [?track :track/duration ?millis] [(quot ?millis 60000) ?minutes]]")

(def miles-enum-id-query
  "[:find ?id ?type ?gender :where [?artist :artist/name \"Miles Davis\"] [?artist :artist/gid ?id] [?artist :artist/type ?type-entity] [?type-entity :db/ident ?type] [?artist :artist/gender ?gender-entity] [?gender-entity :db/ident ?gender]]")

(def track-count-query
  "[:find (count ?track) :where [?artist :artist/name \"The Beatles\"] [?track :track/artists ?artist] [?track :track/name]]")

(def min-max-duration-query
  "[:find (min ?dur) (max ?dur) :where [?artist :artist/name \"The Beatles\"] [?track :track/artists ?artist] [?track :track/duration ?dur]]")

(def beatles-duration-stats-query
  "[:find ?year (median ?millis) (avg ?millis) :with ?track :where [?artist :artist/name \"The Beatles\"] [?release :release/artists ?artist] [?release :release/year ?year] [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/duration ?millis]]")

(def beatles-duration-stddev-query
  "[:find ?year (stddev ?millis) :with ?track :where [?artist :artist/name \"The Beatles\"] [?release :release/artists ?artist] [?release :release/year ?year] [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/duration ?millis]]")

(def beatles-duration-sum-query
  "[:find ?year (sum ?millis) :with ?track :where [?artist :artist/name \"The Beatles\"] [?release :release/artists ?artist] [?release :release/year ?year] [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/duration ?millis]]")

(def track-name-statistics-query
  "[:find ?year (median ?namelen) (avg ?namelen) (stddev ?namelen) :with ?track :where [?track :track/name ?name] [(count ?name) ?namelen] [?medium :medium/tracks ?track] [?release :release/media ?medium] [?release :release/year ?year]]")

(def track-name-length-avg-query
  "[:find ?year (avg ?namelen) :with ?track :where [?track :track/name ?name] [(count ?name) ?namelen] [?medium :medium/tracks ?track] [?release :release/media ?medium] [?release :release/year ?year]]")

(def store-release-year-count-query
  "[:find ?year (count ?release) :where [?release :release/year ?year]]")

(def store-release-media-year-count-query
  "[:find ?year (count ?medium) :where [?release :release/year ?year] [?release :release/media ?medium]]")

(def store-track-year-count-query
  "[:find ?year (count ?track) :where [?release :release/year ?year] [?release :release/media ?medium] [?medium :medium/tracks ?track]]")

(def store-track-name-year-count-query
  "[:find ?year (count ?track) :where [?release :release/year ?year] [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/name ?name]]")

(def lookup-country-query
  "[:find ?name :where [[:country/name \"United Kingdom\"] :country/name ?name]]")

(def selected-artists-releases-query
  "[:find ?artist-name ?release-name :in $ [?artist-name ...] :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]]")

(def release-date-query
  "[:find ?release-name ?year ?month ?day :in $ [?release-name ...] :where [?release :release/name ?release-name] [?release :release/year ?year] [?release :release/month ?month] [?release :release/day ?day]]")

(def fallback-start-month-query
  "[:find ?artist-name ?month :in $ [?artist-name ...] :where [?artist :artist/name ?artist-name] [(get-else $ ?artist :artist/startMonth \"N/A\") ?month]]")

(def get-some-country-query
  "[:find ?attr-ident ?name :where [?entity :country/name \"United Kingdom\"] [(get-some $ ?entity :country/name :artist/name) [?attr ?name]] [?attr :db/ident ?attr-ident]]")

(def missing-start-year-query
  "[:find ?artist-name :where [?artist :artist/name ?artist-name] [(missing? $ ?artist :artist/startYear)]]")

(def dynamic-attr-query
  "[:find ?artist-name :in $ ?country-name [?reference ...] :where [?country :country/name ?country-name] [?artist ?reference ?country] [?artist :artist/name ?artist-name]]")

(def top-duration-query
  "[:find (min 2 ?millis) (max 2 ?millis) :where [?track :track/duration ?millis]]")

(def not-beatles-male-query
  "[:find ?artist-name :where [?artist :artist/name \"The Beatles\"] (not [?artist :artist/gender :artist.gender/male]) [?artist :artist/name ?artist-name]]")

(def or-two-artists-query
  "[:find ?artist-name :where (or [?artist :artist/name \"The Beatles\"] [?artist :artist/name \"Miles Davis\"]) [?artist :artist/name ?artist-name]]")

(def relation-artist-release-query
  "[:find ?artist-name ?release-name :in $ [[?artist-name ?release-name]] :where [?artist :artist/name ?artist-name] [?release :release/name ?release-name] [?release :release/artists ?artist]]")

(def not-join-release-query
  "[:find ?release-name :in $ [?release-name ...] :where [?release :release/name ?release-name] (not-join [?release] [?release :release/artists ?artist] [?artist :artist/name \"The Beatles\"])]")

(def or-join-release-query
  "[:find ?release-name :in $ [?release-name ...] :where [?release :release/name ?release-name] (or-join [?release] (and [?release :release/artists ?artist] [?artist :artist/name \"The Beatles\"]) [?release :release/year 1969])]")

(def map-beatles-releases-query
  "{:find [?release-name] :where [[?artist :artist/name \"The Beatles\"] [?release :release/artists ?artist] [?release :release/name ?release-name]]}")

(def keys-beatles-releases-query
  "[:find ?artist-name ?release-name :keys artist release :where [?artist :artist/name \"The Beatles\"] [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]]")

(def strs-beatles-releases-query
  "[:find ?artist-name ?release-name :strs artist release :where [?artist :artist/name \"The Beatles\"] [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]]")

(def syms-beatles-releases-query
  "[:find ?artist-name ?release-name :syms artist release :where [?artist :artist/name \"The Beatles\"] [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]]")

(def musicbrainz-rules
  "[[(track-release ?t ?r) [?m :medium/tracks ?t] [?r :release/media ?m]] [(track-info ?t ?track-name ?artist-name ?album ?year) [?t :track/name ?track-name] [?t :track/artists ?a] [?a :artist/name ?artist-name] (track-release ?t ?r) [?r :release/name ?album] [?r :release/year ?year]] [(short-track ?a ?t ?len ?max) [?t :track/artists ?a] [?t :track/duration ?len] [(< ?len ?max)]]]")

(def rule-track-info-query
  "[:find ?track-name ?album ?year :in $ % ?artist-name :where (track-info ?track ?track-name ?artist-name ?album ?year) [(< ?year 1970)]]")

(def rule-short-track-query
  "[:find ?track-name ?len :in $ % ?max :where [?artist :artist/name \"The Beatles\"] (short-track ?artist ?track ?len ?max) [?track :track/name ?track-name]]")

(def pull-release-query
  "[:find (pull ?release [:release/name :release/year]) :in $ [?release-name ...] :where [?release :release/name ?release-name]]")

(def dynamic-pull-release-query
  "[:find (pull ?release pattern) :in $ ?artist-name pattern :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist]]")

(def pull-release-nested-query
  "[:find (pull ?release [:release/gid {:release/media [:medium/position :medium/trackCount {:medium/tracks [:track/duration :track/name :track/position]}]} :release/name :release/year]) :in $ [?release-name ...] :where [?release :release/name ?release-name]]")

(def direct-artist-pull-pattern
  "[:artist/gid :artist/name :artist/startYear]")

(def direct-artist-wildcard-pull-pattern
  "[*]")

(def direct-artist-releases-pull-pattern
  "[:artist/name {:release/_artists [:release/name :release/year]}]")

(def direct-artist-releases-limit-pull-pattern
  "[:artist/name {(limit :release/_artists 2) [:release/name :release/year]}]")

(def direct-artist-default-pull-pattern
  "[[:artist/gender :default \"group\"] :artist/name]")

(def direct-artist-alias-pull-pattern
  "[[:artist/name :as :artist] [:artist/gender :default \"group\" :as :kind]]")

(def direct-release-pull-pattern
  "[:release/gid {:release/media [:medium/position :medium/trackCount {:medium/tracks [:track/duration :track/name :track/position]}]} :release/name :release/year]")

