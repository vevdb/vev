      (vev.pull-text-lookup-ref-value db direct-artist-default-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
      (bench.timing-from-samples (slice samples 0)))))

(defn time-direct-pull-artist-alias [db: vev.DB, warmups: int, samples-count: int] -> Value-Timing
  (for [warmup-index (arr.range 0 warmups)]
    (discard warmup-index)
    (discard (vev.pull-text-lookup-ref-value db direct-artist-alias-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))))
  (let [samples (make [dynamic]f64 0 samples-count)]
