      (let [start (time.now)
            value (vev.pull-text-lookup-ref-value db direct-artist-alias-pull-pattern ":artist/gid" (vev.value-uuid beatles-gid))
            elapsed (bench.elapsed-us start)]
        (discard value)
        (arr.push! samples elapsed)))
    (value-timing
