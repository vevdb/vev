(package main)

(import arr "kvist:arr")
(import bench "./support")
(import cli "kvist:cli")
(import fmt "core:fmt")
(import os "core:os")
(import time "core:time")
(import vev "../src/vev")

(defn flag-present? [args: []string, name: string] -> bool
  (for [arg args]
    (when (= arg name)
      (return true)))
  false)

(defn remove-sqlite-files [path: string]
  (os.remove path)
  (os.remove (fmt.tprintf "%s-wal" path))
  (os.remove (fmt.tprintf "%s-shm" path)))

(defn seed-write-schema [store: ^vev.SQLite-Conn] -> bool
  (let [tx (make [dynamic]vev.Tx-Data 0 4) :defer]
    ;; Match Datalevin write-bench: :item/key is a plain long, not unique identity.
    (arr.push! tx (vev.add 201 ":db/ident" (vev.value-keyword ":item/key")))
    (arr.push! tx (vev.add 201 ":db/valueType" (vev.value-keyword ":db.type/long")))
    (arr.push! tx (vev.add 202 ":db/ident" (vev.value-keyword ":item/value")))
    (arr.push! tx (vev.add 202 ":db/valueType" (vev.value-keyword ":db.type/string")))
    (let [report (vev.transact-sqlite-tx-data store (slice tx 0))]
      (when (not report.ok)
        (fmt.printf "engine=vev-sqlite workload=write-schema ok=false error=%s\n" report.error)
        (vev.delete-tx-report-shallow report)
        (return false))
      (vev.delete-live-tx-report-shallow report)
      true)))

(defn seed-write-schema-store [store: ^vev.Store-Conn] -> bool
  (let [tx (make [dynamic]vev.Tx-Data 0 4) :defer]
    ;; Match Datalevin write-bench: :item/key is a plain long, not unique identity.
    (arr.push! tx (vev.add 201 ":db/ident" (vev.value-keyword ":item/key")))
    (arr.push! tx (vev.add 201 ":db/valueType" (vev.value-keyword ":db.type/long")))
    (arr.push! tx (vev.add 202 ":db/ident" (vev.value-keyword ":item/value")))
    (arr.push! tx (vev.add 202 ":db/valueType" (vev.value-keyword ":db.type/string")))
    (let [report (vev.transact-store-report-tx-data store (slice tx 0))]
      (when (not report.ok)
        (fmt.printf "engine=vev-store workload=write-schema ok=false error=%s\n" report.error)
        (vev.delete-store-tx-report report)
        (return false))
      (vev.delete-store-tx-report report)
      true)))

(defn seed-write-schema-shared [conn: ^vev.Shared-Conn] -> bool
  (let [tx (make [dynamic]vev.Tx-Data 0 4) :defer]
    ;; Match Datalevin write-bench: :item/key is a plain long, not unique identity.
    (arr.push! tx (vev.add 201 ":db/ident" (vev.value-keyword ":item/key")))
    (arr.push! tx (vev.add 201 ":db/valueType" (vev.value-keyword ":db.type/long")))
    (arr.push! tx (vev.add 202 ":db/ident" (vev.value-keyword ":item/value")))
    (arr.push! tx (vev.add 202 ":db/valueType" (vev.value-keyword ":db.type/string")))
    (let [report (vev.shared-conn-transact conn (slice tx 0))]
      (when (not report.ok)
        (fmt.printf "engine=vev-shared workload=write-schema ok=false error=%s\n" report.error)
        (vev.delete-tx-report-shallow report)
        (return false))
      (vev.delete-live-tx-report-shallow report)
      true)))

(defn item-entity [index: int] -> u64
  (+ (u64 index) 1000))

(defn item-value [key: i64, revision: i64] -> string
  (fmt.tprintf "value-%d-%d-000000000000000000000000000000000000" key revision))

(defn append-item-tx! [tx: ^[dynamic]vev.Tx-Data, entity: u64, key: i64, revision: i64]
  (arr.push! tx^ (vev.add entity ":item/key" (vev.value-int key)))
  (arr.push! tx^ (vev.add entity ":item/value" (vev.value-string (item-value key revision)))))

(defn item-batch-tx [start-index: int, batch-size: int, revision: i64] -> [dynamic]vev.Tx-Data
  (let [tx (make [dynamic]vev.Tx-Data 0 (* batch-size 2))]
    (for [offset (arr.range 0 batch-size)]
      (let [write-index (+ start-index offset)
            key (i64 (* write-index 2))]
        (append-item-tx! (addr tx) (item-entity write-index) key revision)))
    tx))

(defn item-single-tx-group [write-index: int, revision: i64] -> vev.Store-Tx-Data-Group
  (let [tx (item-batch-tx write-index 1 revision)]
    (vev.Store-Tx-Data-Group {tx-data: tx})))

(defn item-logical-tx-groups [start-index: int, group-size: int, revision: i64] -> [dynamic]vev.Store-Tx-Data-Group
  (let [groups (make [dynamic]vev.Store-Tx-Data-Group 0 group-size)]
    (for [offset (arr.range 0 group-size)]
      (arr.push! groups (item-single-tx-group (+ start-index offset) revision)))
    groups))

(defn delete-store-tx-data-groups [groups: [dynamic]vev.Store-Tx-Data-Group]
  (for [group groups]
    (vev.delete-store-tx-data-group group))
  (delete groups))

(defn print-write-header [workload: string, batch-size: int, total: int]
  (fmt.printf "engine=vev-sqlite workload=%s batch=%d total=%d columns=writes,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms\n"
              workload
              batch-size
              total))

(defn print-write-row [written: int, inserted: int, start: time.Time, interval-start: time.Time, call-us: f64, commit-us: f64, commits: int]
  (let [elapsed-us (bench.elapsed-us start)
        interval-us (bench.elapsed-us interval-start)
        elapsed-s (/ elapsed-us 1000000.0)
        throughput (if (> elapsed-us 0.0)
                     (/ (* (f64 inserted) 1000000.0) elapsed-us)
                     0.0)
        call-ms (if (> commits 0)
                  (/ call-us (* (f64 commits) 1000.0))
                  0.0)
        commit-ms (if (> commits 0)
                    (/ commit-us (* (f64 commits) 1000.0))
                    0.0)]
    (discard interval-us)
    (fmt.printf "%d,%.3f,%.2f,%.3f,%.3f\n"
                written
                elapsed-s
                throughput
                call-ms
                commit-ms)))

(defn profile-avg-ms [value-us: f64, writes: u64] -> f64
  (if (> writes 0)
    (/ value-us (* (f64 writes) 1000.0))
    0.0))

(defn print-store-report-write-row [written: int, inserted: int, start: time.Time, interval-start: time.Time, call-us: f64, commit-us: f64, maintenance-us: f64, commits: int, maintenance-runs: int, pending-maintenance: u64, max-merge-runs: int, eavt-root-level: i64, eavt-root-children: u64, eavt-tree-nodes: u64, eavt-tree-leaves: u64, profile: vev.SQLite-Direct-Write-Profile]
  (let [elapsed-us (bench.elapsed-us start)
        interval-us (bench.elapsed-us interval-start)
        elapsed-s (/ elapsed-us 1000000.0)
        throughput (if (> elapsed-us 0.0)
                     (/ (* (f64 inserted) 1000000.0) elapsed-us)
                     0.0)
        call-ms (if (> commits 0)
                  (/ call-us (* (f64 commits) 1000.0))
                  0.0)
        commit-ms (if (> commits 0)
                    (/ commit-us (* (f64 commits) 1000.0))
                    0.0)
        maintenance-ms (if (> maintenance-runs 0)
                         (/ maintenance-us (* (f64 maintenance-runs) 1000.0))
                         0.0)
        open-before-ms (profile-avg-ms profile.open-before-us profile.writes)
        read-source-ms (profile-avg-ms profile.read-source-us profile.writes)
        resolve-ms (profile-avg-ms profile.resolve-us profile.writes)
        overlay-ms (profile-avg-ms profile.overlay-us profile.writes)
        append-ms (profile-avg-ms profile.append-us profile.writes)
        report-open-ms (profile-avg-ms profile.report-open-us profile.writes)
        direct-call-ms (profile-avg-ms profile.direct-call-us profile.writes)
        auto-maintenance-ms (profile-avg-ms profile.auto-maintenance-us profile.writes)
        listener-ms (profile-avg-ms profile.listener-us profile.writes)
        direct-inner-accounted-ms (+ open-before-ms read-source-ms resolve-ms overlay-ms append-ms report-open-ms)
        direct-inner-unaccounted-ms (max 0.0 (- direct-call-ms direct-inner-accounted-ms))
        outer-unaccounted-ms (max 0.0 (- call-ms direct-call-ms auto-maintenance-ms listener-ms))]
    (discard interval-us)
    (fmt.printf "%d,%.3f,%.2f,%.3f,%.3f,%.3f,%d,%d,%d,%d,%d,%d,%d,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f\n"
                written
                elapsed-s
                throughput
                call-ms
                commit-ms
                maintenance-ms
                maintenance-runs
                pending-maintenance
                max-merge-runs
                eavt-root-level
                eavt-root-children
                eavt-tree-nodes
                eavt-tree-leaves
                outer-unaccounted-ms
                direct-call-ms
                direct-inner-unaccounted-ms
                auto-maintenance-ms
                listener-ms
                open-before-ms
                read-source-ms
                resolve-ms
                overlay-ms
                append-ms
                (profile-avg-ms profile.append-begin-us profile.writes)
                (profile-avg-ms profile.append-tx-us profile.writes)
                (profile-avg-ms profile.append-datoms-us profile.writes)
                (profile-avg-ms profile.append-meta-us profile.writes)
                (profile-avg-ms profile.append-roots-us profile.writes)
                (profile-avg-ms profile.append-root-build-us profile.writes)
                (profile-avg-ms profile.append-root-sort-us profile.writes)
                (profile-avg-ms profile.append-root-check-us profile.writes)
                (profile-avg-ms profile.append-root-persist-us profile.writes)
                (profile-avg-ms profile.append-eavt-root-build-us profile.writes)
                (profile-avg-ms profile.append-aevt-root-build-us profile.writes)
                (profile-avg-ms profile.append-avet-root-build-us profile.writes)
                (profile-avg-ms profile.append-vaet-root-build-us profile.writes)
                (profile-avg-ms profile.append-root-publish-us profile.writes)
                (profile-avg-ms profile.append-commit-us profile.writes)
                report-open-ms)))

(defn store-max-latest-index-merge-runs [store: ^vev.Store-Conn] -> [max-runs: int, ok: bool, error: string]
  (let [[eavt-runs _ eavt-ok eavt-error] (vev.store-latest-index-merge-run-count store ":eavt")]
    (when (not eavt-ok)
      (return 0 false eavt-error))
    (let [[aevt-runs _ aevt-ok aevt-error] (vev.store-latest-index-merge-run-count store ":aevt")]
      (when (not aevt-ok)
        (return 0 false aevt-error))
      (let [[avet-runs _ avet-ok avet-error] (vev.store-latest-index-merge-run-count store ":avet")]
        (when (not avet-ok)
          (return 0 false avet-error))
        (let [[vaet-runs _ vaet-ok vaet-error] (vev.store-latest-index-merge-run-count store ":vaet")]
          (if vaet-ok
            (return (max (max eavt-runs aevt-runs) (max avet-runs vaet-runs)) true "")
            (return 0 false vaet-error)))))))

(defn maintain-store-report-bench! [store: ^vev.Store-Conn, maintain-steps: int, maintain-target: int] -> [steps: int, compacted: bool, pending: u64, ok: bool, error: string]
  (if (>= maintain-target 0)
    (vev.maintain-store-indexes-to-target! store maintain-steps (u64 maintain-target))
    (let [[blind-steps blind-compacted blind-ok blind-error] (vev.maintain-store-indexes! store maintain-steps)
          [blind-pending pending-ok pending-error] (vev.store-index-maintenance-count store)]
      (if blind-ok
        (return blind-steps blind-compacted blind-pending pending-ok pending-error)
        (return blind-steps blind-compacted blind-pending blind-ok blind-error)))))

(defn drain-store-report-maintenance! [store: ^vev.Store-Conn, max-steps-per-pass: int] -> [passes: int, steps: int, pending: u64, ok: bool, error: string]
  (let [pass-count 0
        total-steps 0
        pending-count: u64 0]
    (while true
      (let [[before-pending before-ok before-error] (vev.store-index-maintenance-count store)]
        (when (not before-ok)
          (return pass-count total-steps pending-count false before-error))
        (set! pending-count before-pending)
        (when (= pending-count 0)
          (return pass-count total-steps pending-count true ""))
        (let [[steps _compacted after-pending maintain-ok maintain-error] (vev.maintain-store-indexes-to-target! store max-steps-per-pass (u64 0))]
          (when (not maintain-ok)
            (return pass-count total-steps after-pending false maintain-error))
          (set! pass-count (+ pass-count 1))
          (set! total-steps (+ total-steps steps))
          (set! pending-count after-pending)
          (when (= pending-count 0)
            (return pass-count total-steps pending-count true ""))
          (when (= steps 0)
            (return pass-count total-steps pending-count false "deferred maintenance made no progress")))))
    (return pass-count total-steps pending-count true "")))

(defn measure-pure-write [path: string, batch-size: int, total: int, report-every: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)]
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=pure-write ok=false error=%s\n" open-error)
      (return))
    (when (not (seed-write-schema (addr store)))
      (vev.close-sqlite-conn store)
      (return))
    (print-write-header "pure-write" batch-size total)
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))
              elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us elapsed))
          (set! commit-us (+ commit-us elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-sqlite workload=pure-write ok=false error=%s\n" report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (vev.close-sqlite-conn store)
            (return))
          (vev.delete-live-tx-report-shallow report)
          (delete tx)
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (print-write-row written inserted start interval-start call-us commit-us commits)
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (vev.close-sqlite-conn store)))

(defn measure-pure-store-report-write [path: string, batch-size: int, total: int, report-every: int, compact-every: int, maintain-every: int, maintain-steps: int, maintain-target: int, auto-maintain-steps: int, auto-maintain-target: int, auto-maintain-trigger: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-store path)]
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" open-error)
      (return))
    (when (not (seed-write-schema-store (addr store)))
      (vev.close-store store)
      (return))
    (when (> auto-maintain-steps 0)
      (let [target (max 0 auto-maintain-target)
            trigger (if (>= auto-maintain-trigger 0)
                      (max (+ target 1) auto-maintain-trigger)
                      (+ target 1))
            [auto-ok auto-error] (vev.configure-store-auto-maintenance-threshold! (addr store) auto-maintain-steps (u64 target) (u64 trigger))]
        (when (not auto-ok)
          (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" auto-error)
          (vev.close-store store)
          (return))))
    (fmt.printf "engine=vev-store workload=pure-store-report batch=%d total=%d compact_every=%d maintain_every=%d maintain_steps=%d maintain_target=%d auto_maintain_steps=%d auto_maintain_target=%d auto_maintain_trigger=%d columns=writes,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,maintenance_latency_ms,maintenance_runs,pending_maintenance,max_merge_runs,eavt_root_level,eavt_root_children,eavt_tree_nodes,eavt_tree_leaves,outer_unaccounted_ms,direct_call_ms,direct_inner_unaccounted_ms,auto_maintenance_ms,listener_ms,open_before_ms,read_source_ms,resolve_ms,overlay_ms,append_ms,append_begin_ms,append_tx_ms,append_datoms_ms,append_meta_ms,append_roots_ms,append_root_build_ms,append_root_sort_ms,append_root_check_ms,append_root_persist_ms,append_eavt_root_build_ms,append_aevt_root_build_ms,append_avet_root_build_ms,append_vaet_root_build_ms,append_root_publish_ms,append_commit_ms,report_open_ms\n"
                batch-size
                total
                compact-every
                maintain-every
                maintain-steps
                maintain-target
                auto-maintain-steps
                auto-maintain-target
                auto-maintain-trigger)
    (vev.reset-store-direct-write-profile! (addr store))
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          maintenance-us 0.0
          commits 0
          maintenance-runs 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (vev.transact-store-report-tx-data (addr store) (slice tx 0))
              elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us elapsed))
          (set! commit-us (+ commit-us elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" report.error)
            (vev.delete-store-tx-report report)
            (delete tx)
            (vev.close-store store)
            (return))
          (vev.delete-store-tx-report report)
          (delete tx)
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (and (> compact-every 0)
                     (= (% written compact-every) 0))
            (let [maintenance-before (time.now)
                  [compacted compact-ok compact-error] (vev.compact-store-indexes! (addr store))
                  maintenance-elapsed (bench.elapsed-us maintenance-before)]
              (discard compacted)
              (set! maintenance-us (+ maintenance-us maintenance-elapsed))
              (set! maintenance-runs (+ maintenance-runs 1))
              (when (not compact-ok)
                (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" compact-error)
                (vev.close-store store)
                (return))))
          (when (and (> maintain-every 0)
                     (= (% written maintain-every) 0))
            (let [maintenance-before (time.now)
                  [steps maintained pending-after-target maintain-ok maintain-error] (maintain-store-report-bench! (addr store) maintain-steps maintain-target)
                  maintenance-elapsed (bench.elapsed-us maintenance-before)]
              (discard maintained)
              (discard pending-after-target)
              (set! maintenance-us (+ maintenance-us maintenance-elapsed))
              (set! maintenance-runs (+ maintenance-runs steps))
              (when (not maintain-ok)
                (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" maintain-error)
                (vev.close-store store)
                (return))))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (let [[pending pending-ok pending-error] (vev.store-index-maintenance-count (addr store))]
              (when (not pending-ok)
                (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" pending-error)
                (vev.close-store store)
                (return))
              (let [[max-runs max-runs-ok max-runs-error] (store-max-latest-index-merge-runs (addr store))]
                (when (not max-runs-ok)
                  (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" max-runs-error)
                  (vev.close-store store)
                  (return))
                (let [[eavt-root-children eavt-root-children-ok eavt-root-children-error] (vev.store-latest-index-root-child-count (addr store) ":eavt")]
                  (when (not eavt-root-children-ok)
                    (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" eavt-root-children-error)
                    (vev.close-store store)
                    (return))
                  (let [[eavt-tree-nodes eavt-tree-leaves eavt-root-level eavt-tree-ok eavt-tree-error] (vev.store-latest-index-root-tree-stats (addr store) ":eavt")]
                    (when (not eavt-tree-ok)
                      (fmt.printf "engine=vev-store workload=pure-store-report ok=false error=%s\n" eavt-tree-error)
                      (vev.close-store store)
                      (return))
                    (let [profile (vev.store-direct-write-profile (addr store))]
                      (print-store-report-write-row written inserted start interval-start call-us commit-us maintenance-us commits maintenance-runs pending max-runs eavt-root-level eavt-root-children eavt-tree-nodes eavt-tree-leaves profile)
                      (vev.reset-store-direct-write-profile! (addr store)))))))
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! maintenance-us 0.0)
            (set! commits 0)
            (set! maintenance-runs 0)
            (set! interval-start (time.now))))))
    (vev.close-store store)))

(defn lcg-next [state: u64] -> u64
  (+ (* state (u64 6364136223846793005)) (u64 1442695040888963407)))

(defn random-key [state: u64, keyspace: int] -> i64
  (let [span (u64 keyspace)
        raw (% state span)]
    (+ (i64 raw) 1)))

(defn seed-pure-write [path: string, total: int, batch-size: int] -> bool
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)]
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=seed-write ok=false error=%s\n" open-error)
      (return false))
    (when (not (seed-write-schema (addr store)))
      (vev.close-sqlite-conn store)
      (return false))
    (let [written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))]
          (when (not report.ok)
            (fmt.printf "engine=vev-sqlite workload=seed-write ok=false error=%s\n" report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (vev.close-sqlite-conn store)
            (return false))
          (vev.delete-live-tx-report-shallow report)
          (delete tx)
          (set! written (+ written actual-batch)))))
    (vev.close-sqlite-conn store)
    true))

(defn measure-mixed-read-write [path: string, total: int, operations: int, report-every: int]
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        query (vev.prepare-query-text "[:find ?v :in ?k :where [?e :item/key ?k] [?e :item/value ?v]]")
        keyspace (* total 2)]
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=mixed-read-write ok=false error=%s\n" open-error)
      (vev.delete-prepared-query-shallow query)
      (return))
    (print-write-header "mixed-read-write" 1 operations)
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          commits 0
          writes 0
          op 0
          rng (u64 1)]
      (while (< op operations)
        (set! rng (lcg-next rng))
        (let [key (random-key rng keyspace)]
          (if (= (% op 2) 0)
            (let [inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int key))])
                  before (time.now)
                  result (vev.q-prepared-with-inputs store.conn.db query inputs)
                  elapsed (bench.elapsed-us before)]
              (discard (count result.rows))
              (set! call-us (+ call-us elapsed))
              (vev.delete-result-set-shallow result))
            (let [tx (make [dynamic]vev.Tx-Data 0 2)]
              (append-item-tx! (addr tx) (item-entity (+ total op 1)) key (i64 op))
              (let [before (time.now)
                    report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))
                    elapsed (bench.elapsed-us before)]
                (set! call-us (+ call-us elapsed))
                (set! commit-us (+ commit-us elapsed))
                (set! commits (+ commits 1))
                (when (not report.ok)
                  (fmt.printf "engine=vev-sqlite workload=mixed-read-write ok=false error=%s\n" report.error)
                  (vev.delete-tx-report-shallow report)
                  (delete tx)
                  (vev.delete-prepared-query-shallow query)
                  (vev.close-sqlite-conn store)
                  (return))
                (vev.delete-live-tx-report-shallow report)
                (delete tx)
                (set! writes (+ writes 1))))))
        (set! op (+ op 1))
        (when (or (= op operations)
                  (= (% op report-every) 0))
          (print-write-row op writes start interval-start call-us commit-us commits)
          (set! call-us 0.0)
          (set! commit-us 0.0)
          (set! commits 0)
          (set! interval-start (time.now)))))
    (vev.delete-prepared-query-shallow query)
    (vev.close-sqlite-conn store)))

(defn delete-retained-dbs [dbs: [dynamic]vev.DB]
  (for [snapshot dbs]
    (vev.delete-owned-db snapshot))
  (delete dbs))

(defn delete-retained-shared-snapshots [snapshots: [dynamic]vev.Shared-DB-Snapshot]
  (for [snapshot snapshots]
    (vev.delete-shared-db-snapshot snapshot))
  (delete snapshots))

(defn delete-retained-store-dbs [snapshots: [dynamic]vev.Store-DB]
  (for [i (arr.range 0 (count snapshots))]
    (vev.close-store-db! (addr snapshots[i])))
  (delete snapshots))

(defn print-snapshot-heavy-header [batch-size: int, total: int]
  (fmt.printf "engine=vev-sqlite workload=snapshot-heavy batch=%d total=%d columns=writes,retained_snapshots,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,snapshot_latency_ms\n"
              batch-size
              total))

(defn print-snapshot-heavy-row [written: int, retained: int, inserted: int, start: time.Time, interval-start: time.Time, call-us: f64, commit-us: f64, snapshot-us: f64, commits: int]
  (let [elapsed-us (bench.elapsed-us start)
        interval-us (bench.elapsed-us interval-start)
        elapsed-s (/ elapsed-us 1000000.0)
        throughput (if (> elapsed-us 0.0)
                     (/ (* (f64 inserted) 1000000.0) elapsed-us)
                     0.0)
        call-ms (if (> commits 0)
                  (/ call-us (* (f64 commits) 1000.0))
                  0.0)
        commit-ms (if (> commits 0)
                    (/ commit-us (* (f64 commits) 1000.0))
                    0.0)
        snapshot-ms (if (> commits 0)
                      (/ snapshot-us (* (f64 commits) 1000.0))
                      0.0)]
    (discard interval-us)
    (fmt.printf "%d,%d,%.3f,%.2f,%.3f,%.3f,%.3f\n"
                written
                retained
                elapsed-s
                throughput
                call-ms
                commit-ms
                snapshot-ms)))

(defn print-store-db-heavy-profile-row [written: int, retained: int, inserted: int, start: time.Time, interval-start: time.Time, call-us: f64, commit-us: f64, snapshot-us: f64, commits: int, profile: vev.SQLite-Direct-Write-Profile]
  (let [elapsed-us (bench.elapsed-us start)
        interval-us (bench.elapsed-us interval-start)
        elapsed-s (/ elapsed-us 1000000.0)
        throughput (if (> elapsed-us 0.0)
                     (/ (* (f64 inserted) 1000000.0) elapsed-us)
                     0.0)
        call-ms (if (> commits 0)
                  (/ call-us (* (f64 commits) 1000.0))
                  0.0)
        commit-ms (if (> commits 0)
                    (/ commit-us (* (f64 commits) 1000.0))
                    0.0)
        snapshot-ms (if (> commits 0)
                      (/ snapshot-us (* (f64 commits) 1000.0))
                      0.0)
        direct-call-ms (profile-avg-ms profile.direct-call-us profile.writes)
        open-before-ms (profile-avg-ms profile.open-before-us profile.writes)
        read-source-ms (profile-avg-ms profile.read-source-us profile.writes)
        resolve-ms (profile-avg-ms profile.resolve-us profile.writes)
        overlay-ms (profile-avg-ms profile.overlay-us profile.writes)
        append-ms (profile-avg-ms profile.append-us profile.writes)
        report-open-ms (profile-avg-ms profile.report-open-us profile.writes)
        append-roots-ms (profile-avg-ms profile.append-roots-us profile.writes)
        append-root-build-ms (profile-avg-ms profile.append-root-build-us profile.writes)
        append-root-persist-ms (profile-avg-ms profile.append-root-persist-us profile.writes)
        append-root-publish-ms (profile-avg-ms profile.append-root-publish-us profile.writes)
        append-commit-ms (profile-avg-ms profile.append-commit-us profile.writes)]
    (discard interval-us)
    (fmt.printf "%d,%d,%.3f,%.2f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f,%.3f\n"
                written
                retained
                elapsed-s
                throughput
                call-ms
                commit-ms
                snapshot-ms
                direct-call-ms
                open-before-ms
                read-source-ms
                resolve-ms
                overlay-ms
                append-ms
                report-open-ms
                append-roots-ms
                append-root-build-ms
                append-root-persist-ms
                append-root-publish-ms
                append-commit-ms)))

(defn measure-snapshot-heavy-write [path: string, batch-size: int, total: int, report-every: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        retained (make [dynamic]vev.DB)]
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=snapshot-heavy ok=false error=%s\n" open-error)
      (delete retained)
      (return))
    (when (not (seed-write-schema (addr store)))
      (delete retained)
      (vev.close-sqlite-conn store)
      (return))
    (print-snapshot-heavy-header batch-size total)
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          snapshot-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))
              commit-elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us commit-elapsed))
          (set! commit-us (+ commit-us commit-elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-sqlite workload=snapshot-heavy ok=false error=%s\n" report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (delete-retained-dbs retained)
            (vev.close-sqlite-conn store)
            (return))
          (vev.delete-live-tx-report-shallow report)
          (delete tx)
          (let [snapshot-before (time.now)
                snapshot (vev.db (addr store.conn))
                snapshot-elapsed (bench.elapsed-us snapshot-before)]
            (arr.push! retained snapshot)
            (set! call-us (+ call-us snapshot-elapsed))
            (set! snapshot-us (+ snapshot-us snapshot-elapsed)))
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (print-snapshot-heavy-row written (count retained) inserted start interval-start call-us commit-us snapshot-us commits)
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! snapshot-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (delete-retained-dbs retained)
    (vev.close-sqlite-conn store)
    (remove-sqlite-files path)))

(defn measure-shared-snapshot-heavy-write-mode [chunk-size: int, batch-size: int, total: int, report-every: int, direct: bool]
  (let [workload (if direct "shared-snapshot-heavy-direct" "shared-snapshot-heavy")
        conn (vev.create-shared-conn chunk-size)
        retained (make [dynamic]vev.Shared-DB-Snapshot)]
    (when (not (seed-write-schema-shared (addr conn)))
      (delete retained)
      (vev.delete-shared-conn conn)
      (return))
    (fmt.printf "engine=vev-shared workload=%s chunk=%d batch=%d total=%d columns=writes,retained_snapshots,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,snapshot_latency_ms\n"
                workload
                chunk-size
                batch-size
                total)
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          snapshot-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (if direct
                       (vev.shared-conn-transact-direct (addr conn) (slice tx 0))
                       (vev.shared-conn-transact (addr conn) (slice tx 0)))
              commit-elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us commit-elapsed))
          (set! commit-us (+ commit-us commit-elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-shared workload=%s ok=false error=%s\n" workload report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (delete-retained-shared-snapshots retained)
            (vev.delete-shared-conn conn)
            (return))
          (vev.delete-live-tx-report-shallow report)
          (delete tx)
          (let [snapshot-before (time.now)
                snapshot (vev.retain-shared-db-snapshot conn.snapshot)
                snapshot-elapsed (bench.elapsed-us snapshot-before)]
            (arr.push! retained snapshot)
            (set! call-us (+ call-us snapshot-elapsed))
            (set! snapshot-us (+ snapshot-us snapshot-elapsed)))
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (print-snapshot-heavy-row written (count retained) inserted start interval-start call-us commit-us snapshot-us commits)
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! snapshot-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (delete-retained-shared-snapshots retained)
    (vev.delete-shared-conn conn)))

(defn measure-shared-snapshot-heavy-write [chunk-size: int, batch-size: int, total: int, report-every: int]
  (measure-shared-snapshot-heavy-write-mode chunk-size batch-size total report-every false))

(defn measure-shared-snapshot-heavy-direct-write [chunk-size: int, batch-size: int, total: int, report-every: int]
  (measure-shared-snapshot-heavy-write-mode chunk-size batch-size total report-every true))

(defn measure-shared-store-db-heavy-write [chunk-size: int, batch-size: int, total: int, report-every: int]
  (let [store (vev.create-shared-store chunk-size)
        retained (make [dynamic]vev.Store-DB)]
    (when (not (seed-write-schema-shared (addr store.shared)))
      (delete retained)
      (vev.close-store store)
      (return))
    (fmt.printf "engine=vev-shared workload=shared-store-db-heavy chunk=%d batch=%d total=%d columns=writes,retained_snapshots,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,snapshot_latency_ms\n"
                chunk-size
                batch-size
                total)
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          snapshot-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (vev.transact-store-tx-data (addr store) (slice tx 0))
              commit-elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us commit-elapsed))
          (set! commit-us (+ commit-us commit-elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-shared workload=shared-store-db-heavy ok=false error=%s\n" report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (delete-retained-store-dbs retained)
            (vev.close-store store)
            (return))
          (vev.delete-live-tx-report-shallow report)
          (delete tx)
          (let [snapshot-before (time.now)
                [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
                snapshot-elapsed (bench.elapsed-us snapshot-before)]
            (when (not snapshot-ok)
              (fmt.printf "engine=vev-shared workload=shared-store-db-heavy ok=false error=%s\n" snapshot-error)
              (delete-retained-store-dbs retained)
              (vev.close-store store)
              (return))
            (arr.push! retained snapshot)
            (set! call-us (+ call-us snapshot-elapsed))
            (set! snapshot-us (+ snapshot-us snapshot-elapsed)))
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (print-snapshot-heavy-row written (count retained) inserted start interval-start call-us commit-us snapshot-us commits)
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! snapshot-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (delete-retained-store-dbs retained)
    (vev.close-store store)))

(defn measure-sqlite-store-db-heavy-write [path: string, batch-size: int, total: int, report-every: int, keep?: bool, durability-mode: string]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-store path)
        retained (make [dynamic]vev.Store-DB)]
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy ok=false error=%s\n" open-error)
      (delete retained)
      (return))
    (let [[durability-ok durability-error] (vev.configure-store-durability! (addr store) durability-mode)]
      (when (not durability-ok)
        (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy ok=false error=%s\n" durability-error)
        (delete retained)
        (vev.close-store store)
        (return)))
    (when (not (seed-write-schema-store (addr store)))
      (delete retained)
      (vev.close-store store)
      (when (not keep?)
        (remove-sqlite-files path))
      (return))
    (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy batch=%d total=%d durability=%s columns=writes,retained_snapshots,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,snapshot_latency_ms,direct_call_ms,open_before_ms,read_source_ms,resolve_ms,overlay_ms,append_ms,report_open_ms,append_roots_ms,append_root_build_ms,append_root_persist_ms,append_root_publish_ms,append_commit_ms\n"
                batch-size
                total
                durability-mode)
    (vev.reset-store-direct-write-profile! (addr store))
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          snapshot-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-batch (min batch-size remaining)
              tx (item-batch-tx (+ written 1) actual-batch 0)
              before (time.now)
              report (vev.transact-store-report-tx-data (addr store) (slice tx 0))
              commit-elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us commit-elapsed))
          (set! commit-us (+ commit-us commit-elapsed))
          (set! commits (+ commits 1))
          (when (not report.ok)
            (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy ok=false error=%s\n" report.error)
            (vev.delete-store-tx-report report)
            (delete tx)
            (delete-retained-store-dbs retained)
            (vev.close-store store)
            (when (not keep?)
              (remove-sqlite-files path))
            (return))
          (delete tx)
          (let [snapshot-before (time.now)
                retained-after (vev.retain-store-db report.db-after)
                snapshot-elapsed (bench.elapsed-us snapshot-before)]
            (arr.push! retained retained-after)
            (set! call-us (+ call-us snapshot-elapsed))
            (set! snapshot-us (+ snapshot-us snapshot-elapsed)))
          (vev.delete-store-tx-report report)
          (set! inserted (+ inserted actual-batch))
          (set! written (+ written actual-batch))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (let [profile (vev.store-direct-write-profile (addr store))]
              (print-store-db-heavy-profile-row written (count retained) inserted start interval-start call-us commit-us snapshot-us commits profile)
              (vev.reset-store-direct-write-profile! (addr store)))
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! snapshot-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (delete-retained-store-dbs retained)
    (vev.close-store store)
    (when (not keep?)
      (remove-sqlite-files path))))

(defn measure-sqlite-store-db-heavy-group-commit-write [path: string, group-size: int, total: int, report-every: int, keep?: bool, durability-mode: string]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-store path)
        retained (make [dynamic]vev.Store-DB)]
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy-group-commit ok=false error=%s\n" open-error)
      (delete retained)
      (return))
    (let [[durability-ok durability-error] (vev.configure-store-durability! (addr store) durability-mode)]
      (when (not durability-ok)
        (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy-group-commit ok=false error=%s\n" durability-error)
        (delete retained)
        (vev.close-store store)
        (return)))
    (when (not (seed-write-schema-store (addr store)))
      (delete retained)
      (vev.close-store store)
      (when (not keep?)
        (remove-sqlite-files path))
      (return))
    (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy-group-commit group=%d total=%d durability=%s columns=writes,retained_snapshots,elapsed_s,throughput_writes_per_s,call_latency_ms,commit_latency_ms,snapshot_latency_ms,direct_call_ms,open_before_ms,read_source_ms,resolve_ms,overlay_ms,append_ms,report_open_ms,append_roots_ms,append_root_build_ms,append_root_persist_ms,append_root_publish_ms,append_commit_ms\n"
                group-size
                total
                durability-mode)
    (vev.reset-store-direct-write-profile! (addr store))
    (let [start (time.now)
          interval-start start
          call-us 0.0
          commit-us 0.0
          snapshot-us 0.0
          commits 0
          inserted 0
          written 0]
      (while (< written total)
        (let [remaining (- total written)
              actual-group (min group-size remaining)
              groups (item-logical-tx-groups (+ written 1) actual-group 0)
              before (time.now)
              [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) (slice groups 0))
              commit-elapsed (bench.elapsed-us before)]
          (set! call-us (+ call-us commit-elapsed))
          (set! commit-us (+ commit-us commit-elapsed))
          (set! commits (+ commits 1))
          (when (not reports-ok)
            (fmt.printf "engine=vev-store workload=sqlite-store-db-heavy-group-commit ok=false error=%s\n" reports-error)
            (delete-store-tx-data-groups groups)
            (vev.delete-store-tx-reports reports)
            (delete-retained-store-dbs retained)
            (vev.close-store store)
            (when (not keep?)
              (remove-sqlite-files path))
            (return))
          (for [report reports]
            (let [snapshot-before (time.now)
                  retained-after (vev.retain-store-db report.db-after)
                  snapshot-elapsed (bench.elapsed-us snapshot-before)]
              (arr.push! retained retained-after)
              (set! call-us (+ call-us snapshot-elapsed))
              (set! snapshot-us (+ snapshot-us snapshot-elapsed))))
          (vev.delete-store-tx-reports reports)
          (delete-store-tx-data-groups groups)
          (set! inserted (+ inserted actual-group))
          (set! written (+ written actual-group))
          (when (or (= written total)
                    (= (% written report-every) 0))
            (let [profile (vev.store-direct-write-profile (addr store))]
              (print-store-db-heavy-profile-row written (count retained) inserted start interval-start call-us commit-us snapshot-us commits profile)
              (vev.reset-store-direct-write-profile! (addr store)))
            (set! call-us 0.0)
            (set! commit-us 0.0)
            (set! snapshot-us 0.0)
            (set! commits 0)
            (set! interval-start (time.now))))))
    (delete-retained-store-dbs retained)
    (vev.close-store store)
    (when (not keep?)
      (remove-sqlite-files path))))

(defn run-pure-workload [path: string, batch-size: int, total: int, report-every: int]
  (measure-pure-write path batch-size total report-every)
  (remove-sqlite-files path))

(defn run-pure-store-report-workload [path: string, batch-size: int, total: int, report-every: int, compact-every: int, maintain-every: int, maintain-steps: int, maintain-target: int, auto-maintain-steps: int, auto-maintain-target: int, auto-maintain-trigger: int, keep?: bool]
  (measure-pure-store-report-write path batch-size total report-every compact-every maintain-every maintain-steps maintain-target auto-maintain-steps auto-maintain-target auto-maintain-trigger)
  (when (not keep?)
    (remove-sqlite-files path)))

(defn run-pure-store-report-deferred-workload [path: string, batch-size: int, total: int, report-every: int, deferred-maintain-steps: int]
  (measure-pure-store-report-write path batch-size total report-every 0 0 1 -1 0 0 -1)
  (let [[store open-ok open-error] (vev.open-store path)]
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=pure-store-report-deferred-maintenance ok=false error=%s\n" open-error)
      (remove-sqlite-files path)
      (return))
    (let [[pending-before pending-before-ok pending-before-error] (vev.store-index-maintenance-count (addr store))]
      (when (not pending-before-ok)
        (fmt.printf "engine=vev-store workload=pure-store-report-deferred-maintenance ok=false error=%s\n" pending-before-error)
        (vev.close-store store)
        (remove-sqlite-files path)
        (return))
      (let [before (time.now)
            [passes steps pending-after drain-ok drain-error] (drain-store-report-maintenance! (addr store) deferred-maintain-steps)
            elapsed-us (bench.elapsed-us before)
            elapsed-ms (/ elapsed-us 1000.0)]
        (if drain-ok
          (fmt.printf "engine=vev-store workload=pure-store-report-deferred-maintenance batch=%d total=%d maintain_steps=%d columns=pending_before,pending_after,passes,steps,elapsed_ms\n%d,%d,%d,%d,%.3f\n"
                      batch-size
                      total
                      deferred-maintain-steps
                      pending-before
                      pending-after
                      passes
                      steps
                      elapsed-ms)
          (fmt.printf "engine=vev-store workload=pure-store-report-deferred-maintenance ok=false pending_before=%d pending_after=%d passes=%d steps=%d error=%s\n"
                      pending-before
                      pending-after
                      passes
                      steps
                      drain-error))))
    (vev.close-store store))
  (remove-sqlite-files path))

(defn print-manifest-read-timing [workload: string, total: int, samples: []f64]
  (let [timing (bench.timing-from-samples samples)]
    (fmt.printf
      "engine=vev-store workload=%s total=%d min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f samples=%d\n"
      workload
      total
      timing.min-us
      timing.median-us
      timing.p90-us
      timing.max-us
      (count samples))))

(defn print-manifest-retained-read-timing [workload: string, total: int, samples: []f64, cache-before: int, cache-after-warm: int, cache-after: int]
  (let [timing (bench.timing-from-samples samples)]
    (fmt.printf
      "engine=vev-store workload=%s total=%d min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f samples=%d cache_before=%d cache_after_warm=%d cache_after=%d\n"
      workload
      total
      timing.min-us
      timing.median-us
      timing.p90-us
      timing.max-us
      (count samples)
      cache-before
      cache-after-warm
      cache-after)))

(defn measure-manifest-chain-open [path: string, total: int, sample-count: int]
  (let [samples (make [dynamic]f64 0 sample-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [store open-ok open-error] (vev.open-store-read-only path)
            elapsed (bench.elapsed-us start)]
        (when (not open-ok)
          (fmt.printf "engine=vev-store workload=manifest-chain-open ok=false error=%s\n" open-error)
          (vev.close-store store)
          (return))
        (vev.close-store store)
        (arr.push! samples elapsed)))
    (print-manifest-read-timing "manifest-chain-open" total (slice samples 0))))

(defn measure-manifest-chain-store-query [path: string, total: int, sample-count: int, workload-name: string]
  (let [[store open-ok open-error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        prepared (vev.prepare-query-text "[:find ?v :where [?e :item/value ?v]]")]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=manifest-chain-store-query ok=false error=%s\n" open-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-store workload=manifest-chain-store-query ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-result-store-prepared (addr store) prepared)
            elapsed (bench.elapsed-us start)]
        (when (or (not result.result.ok)
                  (not (= (count result.result.rows) total)))
          (fmt.printf "engine=vev-store workload=manifest-chain-store-query ok=false expected=%d actual=%d error=%s\n" total (count result.result.rows) result.result.error)
          (vev.delete-query-result result)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store store)
          (return))
        (vev.delete-query-result result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store store)
    (print-manifest-read-timing workload-name total (slice samples 0))))

(defn measure-manifest-chain-store-selective-query [path: string, total: int, sample-count: int, workload-name: string]
  (let [key (i64 (* (/ total 2) 2))
        query-text (fmt.tprintf "[:find ?v :where [?e :item/key %d] [?e :item/value ?v]]" key)
        [store open-ok open-error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        prepared (vev.prepare-query-text query-text)]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=%s ok=false error=%s\n" workload-name open-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-store workload=%s ok=false error=%s\n" workload-name prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-result-store-prepared (addr store) prepared)
            elapsed (bench.elapsed-us start)]
        (when (or (not result.result.ok)
                  (not (= (count result.result.rows) 1)))
          (fmt.printf "engine=vev-store workload=%s ok=false expected=1 actual=%d error=%s\n" workload-name (count result.result.rows) result.result.error)
          (vev.delete-query-result result)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store store)
          (return))
        (vev.delete-query-result result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store store)
    (print-manifest-read-timing workload-name total (slice samples 0))))

