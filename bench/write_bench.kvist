(defn measure-manifest-chain-retained-store-db-query [path: string, total: int, sample-count: int, workload-name: string, query-text: string, expected-rows: int]
  (let [[store open-ok open-error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        prepared (vev.prepare-query-text query-text)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=%s ok=false error=%s\n" workload-name open-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-store workload=%s ok=false error=%s\n" workload-name snapshot-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-store workload=%s ok=false error=%s\n" workload-name prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (let [retained (vev.retain-store-db snapshot)
          cache-before (vev.store-db-sqlite-page-cache-count (addr retained))
          warm-result (vev.q-result-store-db-prepared (addr snapshot) prepared)]
      (when (or (not warm-result.result.ok)
                (not (= (count warm-result.result.rows) expected-rows)))
        (fmt.printf "engine=vev-store workload=%s ok=false expected=%d actual=%d error=%s\n" workload-name expected-rows (count warm-result.result.rows) warm-result.result.error)
        (vev.delete-query-result warm-result)
        (vev.close-store-db! (addr retained))
        (vev.delete-prepared-query-shallow prepared)
        (vev.close-store-db! (addr snapshot))
        (vev.close-store store)
        (return))
      (vev.delete-query-result warm-result)
      (let [cache-after-warm (vev.store-db-sqlite-page-cache-count (addr retained))]
        (for [sample-index (arr.range 0 sample-count)]
          (let [start (time.now)
                result (vev.q-result-store-db-prepared (addr retained) prepared)
                elapsed (bench.elapsed-us start)]
            (when (or (not result.result.ok)
                      (not (= (count result.result.rows) expected-rows)))
              (fmt.printf "engine=vev-store workload=%s ok=false expected=%d actual=%d error=%s\n" workload-name expected-rows (count result.result.rows) result.result.error)
              (vev.delete-query-result result)
              (vev.close-store-db! (addr retained))
              (vev.delete-prepared-query-shallow prepared)
              (vev.close-store-db! (addr snapshot))
              (vev.close-store store)
              (return))
            (vev.delete-query-result result)
            (arr.push! samples elapsed)))
        (print-manifest-retained-read-timing workload-name total (slice samples 0) cache-before cache-after-warm (vev.store-db-sqlite-page-cache-count (addr retained))))
      (vev.close-store-db! (addr retained)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)))

(defn measure-manifest-chain-store-db-selective-query [path: string, total: int, sample-count: int, workload-name: string]
  (let [key (i64 (* (/ total 2) 2))
        query-text (fmt.tprintf "[:find ?v :where [?e :item/key %d] [?e :item/value ?v]]" key)
        [store open-ok open-error] (vev.open-store-read-only path)
