(defn measure-manifest-chain-compaction [path: string, total: int]
  (let [[store open-ok open-error] (vev.open-store path)]
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=manifest-chain-compact ok=false error=%s\n" open-error)
      (vev.close-store store)
      (return))
    (let [start (time.now)
          [compacted compact-ok compact-error] (vev.compact-store-indexes! (addr store))
          elapsed (bench.elapsed-us start)]
      (if compact-ok
        (fmt.printf
          "engine=vev-store workload=manifest-chain-compact total=%d elapsed_us=%.0f compacted=%v\n"
          total
          elapsed
          compacted)
        (fmt.printf "engine=vev-store workload=manifest-chain-compact ok=false error=%s\n" compact-error)))
    (vev.close-store store)))

(defn run-manifest-chain-read-workload [path: string, batch-size: int, total: int, report-every: int, sample-count: int, auto-maintain-steps: int, auto-maintain-target: int, auto-maintain-trigger: int, keep?: bool]
  (measure-pure-store-report-write path batch-size total report-every 0 0 1 -1 auto-maintain-steps auto-maintain-target auto-maintain-trigger)
  (let [selective-query (fmt.tprintf "[:find ?v :where [?e :item/key %d] [?e :item/value ?v]]" (i64 (* (/ total 2) 2)))]
    (measure-manifest-chain-open path total sample-count)
    (measure-manifest-chain-store-query path total sample-count "manifest-chain-store-query")
    (measure-manifest-chain-store-db-query path total sample-count "manifest-chain-store-db-query")
    (measure-manifest-chain-retained-store-db-query path total sample-count "manifest-chain-retained-store-db-query" "[:find ?v :where [?e :item/value ?v]]" total)
    (measure-manifest-chain-store-selective-query path total sample-count "manifest-chain-store-selective-query")
    (measure-manifest-chain-store-db-selective-query path total sample-count "manifest-chain-store-db-selective-query")
    (measure-manifest-chain-retained-store-db-query path total sample-count "manifest-chain-retained-store-db-selective-query" selective-query 1))
  (measure-manifest-chain-compaction path total)
  (measure-manifest-chain-open path total sample-count)
  (let [selective-query (fmt.tprintf "[:find ?v :where [?e :item/key %d] [?e :item/value ?v]]" (i64 (* (/ total 2) 2)))]
    (measure-manifest-chain-store-query path total sample-count "manifest-chain-store-query-compacted")
    (measure-manifest-chain-store-db-query path total sample-count "manifest-chain-store-db-query-compacted")
    (measure-manifest-chain-retained-store-db-query path total sample-count "manifest-chain-retained-store-db-query-compacted" "[:find ?v :where [?e :item/value ?v]]" total)
    (measure-manifest-chain-store-selective-query path total sample-count "manifest-chain-store-selective-query-compacted")
    (measure-manifest-chain-store-db-selective-query path total sample-count "manifest-chain-store-db-selective-query-compacted")
    (measure-manifest-chain-retained-store-db-query path total sample-count "manifest-chain-retained-store-db-selective-query-compacted" selective-query 1))
  (when (not keep?)
    (remove-sqlite-files path)))

(defn run-all-pure-workloads [base-path: string, total: int, report-every: int]
  (let [batch-sizes ([]int [1 10 100 1000])
        batch-index 0]
    (while (< batch-index (count batch-sizes))
      (let [batch-size batch-sizes[batch-index]
            path (fmt.tprintf "%s.batch-%d" base-path batch-size)]
        (run-pure-workload path batch-size total report-every))
      (set! batch-index (+ batch-index 1)))))

(defn main []
  (defer (free_all context.allocator))
  (let [total (max 1 (cli.int-option os.args "--total" 200))
        report-every (max 1 (cli.int-option os.args "--report-every" 100))
        mixed-operations (max 1 (cli.int-option os.args "--mixed-operations" (* total 2)))
        seed-batch (max 1 (cli.int-option os.args "--seed-batch" 100))
        selected-batch (cli.int-option os.args "--batch" 0)
        compact-every (max 0 (cli.int-option os.args "--compact-every" 0))
        maintain-every (max 0 (cli.int-option os.args "--maintain-every" 0))
        maintain-steps (max 1 (cli.int-option os.args "--maintain-steps" 1))
        maintain-target (cli.int-option os.args "--maintain-target" -1)
        auto-maintain-steps (max 0 (cli.int-option os.args "--auto-maintain-steps" 0))
        auto-maintain-target (cli.int-option os.args "--auto-maintain-target" 0)
        auto-maintain-trigger (cli.int-option os.args "--auto-maintain-trigger" -1)
        deferred-maintain-steps (max 1 (cli.int-option os.args "--deferred-maintain-steps" 128))
        read-samples (max 1 (cli.int-option os.args "--read-samples" 10))
        chunk-size (max 1 (cli.int-option os.args "--chunk-size" 1024))
        workload (cli.option os.args "--workload" "both")
        durability-mode (cli.option os.args "--durability" ":normal")
        keep? (flag-present? os.args "--keep")
        path (cli.option os.args "--path" "tmp.vev.write-bench.sqlite")]
    (if (= workload "pure")
      (if (> selected-batch 0)
        (measure-pure-write path selected-batch total report-every)
        (run-all-pure-workloads path total report-every))
        (if (= workload "pure-store-report")
          (run-pure-store-report-workload path (max 1 selected-batch) total report-every compact-every maintain-every maintain-steps maintain-target auto-maintain-steps auto-maintain-target auto-maintain-trigger keep?)
        (if (= workload "pure-store-report-deferred")
          (run-pure-store-report-deferred-workload path (max 1 selected-batch) total report-every deferred-maintain-steps)
          (if (= workload "manifest-chain-read")
            (run-manifest-chain-read-workload path (max 1 selected-batch) total report-every read-samples auto-maintain-steps auto-maintain-target auto-maintain-trigger keep?)
          (if (= workload "sqlite-store-db-heavy")
            (measure-sqlite-store-db-heavy-write path (max 1 selected-batch) total report-every keep? durability-mode)
          (if (= workload "sqlite-store-db-heavy-group-commit")
            (measure-sqlite-store-db-heavy-group-commit-write path (max 1 selected-batch) total report-every keep? durability-mode)
          (if (= workload "mixed")
            (measure-mixed-read-write path total mixed-operations report-every)
            (if (= workload "snapshot-heavy")
              (measure-snapshot-heavy-write path (max 1 selected-batch) total report-every)
              (if (= workload "shared-snapshot-heavy")
                (measure-shared-snapshot-heavy-write chunk-size (max 1 selected-batch) total report-every)
                (if (= workload "shared-snapshot-heavy-direct")
                  (measure-shared-snapshot-heavy-direct-write chunk-size (max 1 selected-batch) total report-every)
                  (if (= workload "shared-store-db-heavy")
                    (measure-shared-store-db-heavy-write chunk-size (max 1 selected-batch) total report-every)
                    (if (= workload "both")
                      (let [mixed-path (fmt.tprintf "%s.mixed" path)
                            snapshot-path (fmt.tprintf "%s.snapshot" path)
                            store-report-path (fmt.tprintf "%s.store-report" path)]
                        (if (> selected-batch 0)
                          (run-pure-workload path selected-batch total report-every)
                          (run-all-pure-workloads path total report-every))
                        (run-pure-store-report-workload store-report-path (max 1 selected-batch) total report-every compact-every maintain-every maintain-steps maintain-target auto-maintain-steps auto-maintain-target auto-maintain-trigger keep?)
                        (when (seed-pure-write mixed-path total seed-batch)
                          (measure-mixed-read-write mixed-path total mixed-operations report-every))
                        (measure-snapshot-heavy-write snapshot-path (max 1 selected-batch) total report-every)
                        (measure-sqlite-store-db-heavy-write (fmt.tprintf "%s.sqlite-store-db-heavy" path) (max 1 selected-batch) total report-every keep? durability-mode)
                        (measure-sqlite-store-db-heavy-group-commit-write (fmt.tprintf "%s.sqlite-store-db-heavy-group-commit" path) (max 1 selected-batch) total report-every keep? durability-mode)
                        (measure-shared-snapshot-heavy-write chunk-size (max 1 selected-batch) total report-every)
                        (measure-shared-snapshot-heavy-direct-write chunk-size (max 1 selected-batch) total report-every)
                        (measure-shared-store-db-heavy-write chunk-size (max 1 selected-batch) total report-every)
                        (remove-sqlite-files mixed-path))
                      (fmt.printf "unknown --workload %s; expected pure, pure-store-report, pure-store-report-deferred, manifest-chain-read, sqlite-store-db-heavy, sqlite-store-db-heavy-group-commit, mixed, snapshot-heavy, shared-snapshot-heavy, shared-snapshot-heavy-direct, shared-store-db-heavy, or both\n" workload)))))))))))))))
