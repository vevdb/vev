(defn measure-persisted-db-snapshot-source-query [path: string, people-count: int, sample-count: int, page-size: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        entity (/ people-count 2)
        query-text (vev.string-owned (fmt.tprintf "[:find ?email :where [%d :user/email ?email]]" entity))
        [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-db-snapshot path page-size)]
    (defer (delete samples))
    (defer (delete query-text))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-source-query ok=false error=%s\n" snapshot-error)
      (return))
    (let [source (vev.sqlite-db-read-source (addr snapshot))]
      (for [sample-index (arr.range 0 sample-count)]
        (let [start (time.now)
              result (vev.q-text-db-read-source source query-text)
              elapsed (bench.elapsed-us start)]
          (when (or (not result.ok)
                    (not (= (count result.rows) 1))
                    (not (= (count result.rows[0].values) 1)))
            (vev.delete-result-set-owned-values result)
            (vev.close-sqlite-db-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-source-query ok=false error=unexpected-result\n")
            (return))
          (vev.delete-result-set-owned-values result)
          (arr.push! samples elapsed))))
    (vev.close-sqlite-db-snapshot! (addr snapshot))
    (print-timing "persisted-db-snapshot-source-query" people-count (slice samples 0))))

