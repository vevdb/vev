(defn measure-batch-split [path: string, batch-size: int, sample-count: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        memory-samples (make [dynamic]f64 0 sample-count)
        sqlite-samples (make [dynamic]f64 0 sample-count)]
    (defer (delete memory-samples))
    (defer (delete sqlite-samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=batch-split ok=false error=%s\n" open-error)
      (return))
    (for [i (arr.range 0 sample-count)]
      (let [tx (batch-people-tx (+ 1 (* i batch-size)) batch-size)
            memory-start (time.now)
            report (vev.transact-tx-data (addr store.conn) (slice tx 0))
            memory-elapsed (bench.elapsed-us memory-start)]
        (when (not report.ok)
          (fmt.printf "engine=vev-sqlite workload=batch-transact-memory ok=false error=%s\n" report.error)
          (vev.delete-tx-report-shallow report)
          (delete tx)
          (vev.close-sqlite-conn store)
          (return))
        (arr.push! memory-samples memory-elapsed)
        (let [sqlite-start (time.now)
              [append-ok append-error] (vev.append-tx-report-sqlite-handle store.handle report)
              sqlite-elapsed (bench.elapsed-us sqlite-start)]
          (when (not append-ok)
            (fmt.printf "engine=vev-sqlite workload=batch-append-sqlite ok=false error=%s\n" append-error)
            (vev.delete-live-tx-report-shallow report)
            (delete tx)
            (vev.close-sqlite-conn store)
            (return))
          (arr.push! sqlite-samples sqlite-elapsed))
        (vev.delete-live-tx-report-shallow report)
        (delete tx)))
    (vev.close-sqlite-conn store)
    (print-timing "batch-transact-memory" batch-size (slice memory-samples 0))
    (print-timing "batch-append-sqlite" batch-size (slice sqlite-samples 0))))

(defn measure-batch-pipeline-split [path: string, batch-size: int, sample-count: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        before-samples (make [dynamic]f64 0 sample-count)
        resolve-samples (make [dynamic]f64 0 sample-count)
        apply-samples (make [dynamic]f64 0 sample-count)]
    (defer (delete before-samples))
    (defer (delete resolve-samples))
    (defer (delete apply-samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=batch-pipeline-split ok=false error=%s\n" open-error)
      (return))
    (for [i (arr.range 0 sample-count)]
      (let [tx (batch-people-tx (+ 1 (* i batch-size)) batch-size)
            before-start (time.now)
            before (vev.clone-db store.conn.db)
            before-elapsed (bench.elapsed-us before-start)
            resolve-start (time.now)
            resolved (vev.resolve-tx-data-for-tx before (slice tx 0) store.conn.next-tx)
            resolve-elapsed (bench.elapsed-us resolve-start)]
        (arr.push! before-samples before-elapsed)
        (arr.push! resolve-samples resolve-elapsed)
        (when (not resolved.ok)
          (fmt.printf "engine=vev-sqlite workload=batch-resolve-tx ok=false error=%s\n" resolved.error)
          (vev.delete-owned-db before)
          (delete resolved.ops)
          (delete resolved.tx-meta)
          (delete resolved.tempids)
          (delete tx)
          (vev.close-sqlite-conn store)
          (return))
        (let [apply-start (time.now)
              report (vev.transact-ops-with-tempids-from-before (addr store.conn) before (slice resolved.ops 0) (slice resolved.tx-meta 0) resolved.tempids)
              apply-elapsed (bench.elapsed-us apply-start)]
          (arr.push! apply-samples apply-elapsed)
          (delete resolved.ops)
          (delete resolved.tx-meta)
          (when (not report.ok)
            (fmt.printf "engine=vev-sqlite workload=batch-apply-resolved ok=false error=%s\n" report.error)
            (vev.delete-tx-report-shallow report)
            (delete tx)
            (vev.close-sqlite-conn store)
            (return))
          (vev.delete-live-tx-report-shallow report))
        (delete tx)))
    (vev.close-sqlite-conn store)
    (print-timing "batch-before-snapshot" batch-size (slice before-samples 0))
    (print-timing "batch-resolve-tx" batch-size (slice resolve-samples 0))
    (print-timing "batch-apply-resolved" batch-size (slice apply-samples 0))))

(defn measure-append-only-core [base-people: int, batch-size: int, sample-count: int]
  (let [conn (vev.create-conn)
        seed-tx (batch-people-tx 1 base-people)
        seed-report (vev.transact-tx-data (addr conn) (slice seed-tx 0))
        log-samples (make [dynamic]f64 0 sample-count)
        index-samples (make [dynamic]f64 0 sample-count)]
    (defer (delete log-samples))
    (defer (delete index-samples))
    (when (not seed-report.ok)
      (fmt.printf "engine=vev-sqlite workload=append-only-core ok=false error=%s\n" seed-report.error)
      (vev.delete-tx-report-shallow seed-report)
      (delete-conn-shallow conn)
      (delete seed-tx)
      (return))
    (vev.delete-live-tx-report-shallow seed-report)
    (delete seed-tx)
    (for [sample-index (arr.range 0 sample-count)]
      (let [added (batch-people-datoms (+ base-people 1 (* sample-index batch-size)) batch-size (+ conn.next-tx (u64 sample-index)))]
        (let [log-start (time.now)
              after-log (clone-log-with-added (slice conn.db.datoms 0) (slice added 0))
              log-elapsed (bench.elapsed-us log-start)]
          (arr.push! log-samples log-elapsed)
          (delete after-log))
        (let [after-log (clone-log-with-added (slice conn.db.datoms 0) (slice added 0))
              index-start (time.now)
              after-db (vev.build-db-append-only conn.db after-log (count conn.db.datoms))
              index-elapsed (bench.elapsed-us index-start)]
          (arr.push! index-samples index-elapsed)
          (vev.delete-owned-db after-db))
        (delete added)))
    (delete-conn-shallow conn)
    (print-timing "append-log-copy" batch-size (slice log-samples 0))
    (print-timing "append-index-build" batch-size (slice index-samples 0))))

(defn seed-durable-db [path: string, people-count: int] -> bool
  (remove-sqlite-files path)
  (let [conn (vev.create-conn)
        tx (batch-people-tx 1 people-count)
        report (vev.transact-tx-data (addr conn) (slice tx 0))]
    (when (not report.ok)
      (fmt.printf "engine=vev-sqlite workload=seed ok=false error=%s\n" report.error)
      (vev.delete-tx-report-shallow report)
      (delete-conn-shallow conn)
      (delete tx)
      (return false))
    (let [[saved-ok saved-error] (vev.persist-conn-sqlite path conn)]
      (when (not saved-ok)
        (fmt.printf "engine=vev-sqlite workload=seed ok=false error=%s\n" saved-error)
        (vev.delete-live-tx-report-shallow report)
        (delete-conn-shallow conn)
        (delete tx)
        (return false)))
    (vev.delete-live-tx-report-shallow report)
    (delete-conn-shallow conn)
    (delete tx)
    true))

(defn measure-reopen [path: string, people-count: int, sample-count: int]
  (let [samples (make [dynamic]f64 0 sample-count)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [conn ok error] (vev.open-conn-sqlite path)
            elapsed (bench.elapsed-us start)]
        (when (not ok)
          (fmt.printf "engine=vev-sqlite workload=reopen ok=false error=%s\n" error)
          (return))
        (when (not (= (count conn.db.datoms) (* people-count 3)))
          (fmt.printf "engine=vev-sqlite workload=reopen ok=false error=unexpected-datom-count count=%d\n" (count conn.db.datoms))
          (delete-conn-shallow conn)
          (return))
        (delete-conn-shallow conn)
        (arr.push! samples elapsed)))
    (print-timing "reopen-rebuild" people-count (slice samples 0))))

(defn measure-persisted-index-load [path: string, people-count: int, sample-count: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        expected-datoms (* people-count 3)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [eavt eavt-ok eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
            [aevt aevt-ok aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
            [avet avet-ok avet-error] (vev.sqlite-latest-index-entries path ":avet")
            [vaet vaet-ok vaet-error] (vev.sqlite-latest-index-entries path ":vaet")
            elapsed (bench.elapsed-us start)]
        (when (not eavt-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-load ok=false error=%s\n" eavt-error)
          (return))
        (when (not aevt-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-load ok=false error=%s\n" aevt-error)
          (delete eavt)
          (return))
        (when (not avet-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-load ok=false error=%s\n" avet-error)
          (delete eavt)
          (delete aevt)
          (return))
        (when (not vaet-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-load ok=false error=%s\n" vaet-error)
          (delete eavt)
          (delete aevt)
          (delete avet)
          (return))
        (when (or (not (= (count eavt) expected-datoms))
                  (not (= (count aevt) expected-datoms))
                  (not (= (count avet) expected-datoms)))
          (fmt.printf "engine=vev-sqlite workload=persisted-index-load ok=false error=unexpected-index-count eavt=%d aevt=%d avet=%d vaet=%d\n" (count eavt) (count aevt) (count avet) (count vaet))
          (delete eavt)
          (delete aevt)
          (delete avet)
          (delete vaet)
          (return))
        (delete eavt)
        (delete aevt)
        (delete avet)
        (delete vaet)
        (arr.push! samples elapsed)))
    (print-timing "persisted-index-load" people-count (slice samples 0))))

(defn measure-persisted-index-page-load [path: string, people-count: int, sample-count: int, page-size: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        expected-datoms (* people-count 3)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [eavt-count eavt-ok eavt-error] (vev.sqlite-latest-index-entry-pages-count path ":eavt" page-size)
            [aevt-count aevt-ok aevt-error] (vev.sqlite-latest-index-entry-pages-count path ":aevt" page-size)
            [avet-count avet-ok avet-error] (vev.sqlite-latest-index-entry-pages-count path ":avet" page-size)
            [vaet-count vaet-ok vaet-error] (vev.sqlite-latest-index-entry-pages-count path ":vaet" page-size)
            elapsed (bench.elapsed-us start)]
        (when (not eavt-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-page-load ok=false error=%s\n" eavt-error)
          (return))
        (when (not aevt-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-page-load ok=false error=%s\n" aevt-error)
          (return))
        (when (not avet-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-page-load ok=false error=%s\n" avet-error)
          (return))
        (when (not vaet-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-page-load ok=false error=%s\n" vaet-error)
          (return))
        (when (or (not (= eavt-count expected-datoms))
                  (not (= aevt-count expected-datoms))
                  (not (= avet-count expected-datoms))
                  (not (= vaet-count expected-datoms)))
          (fmt.printf "engine=vev-sqlite workload=persisted-index-page-load ok=false error=unexpected-index-count eavt=%d aevt=%d avet=%d vaet=%d\n" eavt-count aevt-count avet-count vaet-count)
          (return))
        (arr.push! samples elapsed)))
    (print-timing "persisted-index-page-load" people-count (slice samples 0))))

(defn scan-index-cursor [cursor: ^vev.SQLite-Index-Cursor] -> [loaded-count: int, ok: bool, error: string]
  (let [total (vev.sqlite-index-cursor-count cursor^)
        i 0
        seen 0]
    (while (< i total)
      (let [[_ entry-ok entry-error] (vev.sqlite-index-cursor-at cursor i)]
        (when (not entry-ok)
          (return seen false entry-error))
        (set! seen (+ seen 1))
        (set! i (+ i 1))))
    (return seen true "")))

(defn measure-persisted-index-cursor-scan [path: string, people-count: int, sample-count: int, page-size: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        expected-datoms (* people-count 3)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [eavt-cursor eavt-cursor-ok eavt-cursor-error] (vev.sqlite-open-index-cursor path ":eavt" page-size)
            [aevt-cursor aevt-cursor-ok aevt-cursor-error] (vev.sqlite-open-index-cursor path ":aevt" page-size)
            [avet-cursor avet-cursor-ok avet-cursor-error] (vev.sqlite-open-index-cursor path ":avet" page-size)
            [vaet-cursor vaet-cursor-ok vaet-cursor-error] (vev.sqlite-open-index-cursor path ":vaet" page-size)]
        (when (not eavt-cursor-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" eavt-cursor-error)
          (return))
        (when (not aevt-cursor-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" aevt-cursor-error)
          (vev.close-sqlite-index-cursor eavt-cursor)
          (return))
        (when (not avet-cursor-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" avet-cursor-error)
          (vev.close-sqlite-index-cursor eavt-cursor)
          (vev.close-sqlite-index-cursor aevt-cursor)
          (return))
        (when (not vaet-cursor-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" vaet-cursor-error)
          (vev.close-sqlite-index-cursor eavt-cursor)
          (vev.close-sqlite-index-cursor aevt-cursor)
          (vev.close-sqlite-index-cursor avet-cursor)
          (return))
        (let [[eavt-count eavt-ok eavt-error] (scan-index-cursor (addr eavt-cursor))
              [aevt-count aevt-ok aevt-error] (scan-index-cursor (addr aevt-cursor))
              [avet-count avet-ok avet-error] (scan-index-cursor (addr avet-cursor))
              [vaet-count vaet-ok vaet-error] (scan-index-cursor (addr vaet-cursor))
              elapsed (bench.elapsed-us start)]
          (vev.close-sqlite-index-cursor eavt-cursor)
          (vev.close-sqlite-index-cursor aevt-cursor)
          (vev.close-sqlite-index-cursor avet-cursor)
          (vev.close-sqlite-index-cursor vaet-cursor)
          (when (not eavt-ok)
            (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" eavt-error)
            (return))
          (when (not aevt-ok)
            (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" aevt-error)
            (return))
          (when (not avet-ok)
            (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" avet-error)
            (return))
          (when (not vaet-ok)
            (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=%s\n" vaet-error)
            (return))
          (when (or (not (= eavt-count expected-datoms))
                    (not (= aevt-count expected-datoms))
                    (not (= avet-count expected-datoms))
                    (not (= vaet-count expected-datoms)))
            (fmt.printf "engine=vev-sqlite workload=persisted-index-cursor-scan ok=false error=unexpected-index-count eavt=%d aevt=%d avet=%d vaet=%d\n" eavt-count aevt-count avet-count vaet-count)
            (return))
          (arr.push! samples elapsed))))
    (print-timing "persisted-index-cursor-scan" people-count (slice samples 0))))

(defn measure-persisted-index-snapshot-open [path: string, people-count: int, sample-count: int, page-size: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        expected-datoms (* people-count 3)
        sample-log-index (/ expected-datoms 2)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-index-snapshot path page-size)]
        (when (not snapshot-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-index-snapshot-open ok=false error=%s\n" snapshot-error)
          (return))
        (let [view (vev.sqlite-index-snapshot-view (addr snapshot) (vev.public-index-order ":eavt"))
              count (vev.db-index-view-count view)
              first-entry (vev.db-index-view-at view 0)
              middle-entry (vev.db-index-view-at view sample-log-index)
              [datom datom-ok datom-error] (vev.sqlite-index-snapshot-datom-at-log-index (addr snapshot) sample-log-index)
              elapsed (bench.elapsed-us start)]
          (when (not (= count expected-datoms))
            (vev.close-sqlite-index-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-index-snapshot-open ok=false error=unexpected-index-count count=%d expected=%d\n" count expected-datoms)
            (return))
          (when (or (< first-entry 0) (< middle-entry 0))
            (vev.close-sqlite-index-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-index-snapshot-open ok=false error=invalid-index-entry first=%d middle=%d\n" first-entry middle-entry)
            (return))
          (when (not datom-ok)
            (vev.close-sqlite-index-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-index-snapshot-open ok=false error=%s\n" datom-error)
            (return))
          (when (= datom.a "")
            (vev.delete-owned-datom datom)
            (vev.close-sqlite-index-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-index-snapshot-open ok=false error=empty-datom-attr\n")
            (return))
          (vev.delete-owned-datom datom)
          (vev.close-sqlite-index-snapshot! (addr snapshot))
          (arr.push! samples elapsed))))
    (print-timing "persisted-index-snapshot-open" people-count (slice samples 0))))

(defn measure-persisted-db-snapshot-open [path: string, people-count: int, sample-count: int, page-size: int]
  (let [samples (make [dynamic]f64 0 sample-count)
        expected-datoms (* people-count 3)
        sample-log-index (/ expected-datoms 2)]
    (defer (delete samples))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-db-snapshot path page-size)]
        (when (not snapshot-ok)
          (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-open ok=false error=%s\n" snapshot-error)
          (return))
        (let [view (vev.sqlite-db-snapshot-index-view (addr snapshot) (vev.public-index-order ":eavt"))
              count (vev.db-index-view-count view)
              first-entry (vev.db-index-view-at view 0)
              middle-entry (vev.db-index-view-at view sample-log-index)
              [datom datom-ok datom-error] (vev.sqlite-db-snapshot-datom-at-log-index (addr snapshot) sample-log-index)
              elapsed (bench.elapsed-us start)]
