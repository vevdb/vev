(defn measure-sqlite-conn-source-prepared-query [path: string, people-count: int, sample-count: int]
  (let [[store ok error] (vev.open-sqlite-conn path)
        samples (make [dynamic]f64 0 sample-count)
        entity (/ people-count 2)
        query-text (vev.string-owned (fmt.tprintf "[:find ?name ?age :where [?e :user/email \"user-%d@example.com\"] [?e :user/name ?name] [?e :user/age ?age]]" entity))
        prepared (vev.prepare-query-text query-text)]
    (defer (delete samples))
    (defer (delete query-text))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=store-conn-source-prepared-query ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-sqlite-conn store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-sqlite workload=store-conn-source-prepared-query ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-sqlite-conn store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-result-sqlite-conn-prepared (addr store) prepared)
            elapsed (bench.elapsed-us start)]
        (when (or (not result.result.ok)
                  (not (= (count result.result.rows) 1))
                  (not (= (count result.result.rows[0].values) 2)))
          (fmt.printf "engine=vev-sqlite workload=store-conn-source-prepared-query ok=false error=unexpected-result\n")
          (vev.delete-query-result result)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-sqlite-conn store)
          (return))
        (vev.delete-query-result result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-sqlite-conn store)
    (print-timing "store-conn-source-prepared-query" people-count (slice samples 0))))

(defn measure-sqlite-source-conn-open [path: string, people-count: int, sample-count: int]
  (let [samples (make [dynamic]f64 0 sample-count)]
