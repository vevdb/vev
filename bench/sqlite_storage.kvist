(package main)

(import arr "kvist:arr")
(import bench "./support")
(import cli "../deps/cli")
(import fmt "core:fmt")
(import os "core:os")
(import time "core:time")
(import vev "../src/vev")

(defn remove-sqlite-files [path: string]
  (os.remove path)
  (os.remove (fmt.tprintf "%s-wal" path))
  (os.remove (fmt.tprintf "%s-shm" path)))

(defn delete-conn-shallow [conn: vev.Conn]
  (delete conn.listeners)
  (vev.delete-owned-db conn.db))

(defn one-person-tx [entity: int] -> [dynamic]vev.Tx-Data
  (let [tx (make [dynamic]vev.Tx-Data 0 3)]
    (arr.push! tx (vev.add (u64 entity) ":user/email" (vev.value-string (fmt.tprintf "user-%d@example.com" entity))))
    (arr.push! tx (vev.add (u64 entity) ":user/name" (vev.value-string (fmt.tprintf "User %d" entity))))
    (arr.push! tx (vev.add (u64 entity) ":user/age" (vev.value-int (i64 (% entity 100)))))
    tx))

(defn batch-people-tx [start-entity: int, n: int] -> [dynamic]vev.Tx-Data
  (let [tx (make [dynamic]vev.Tx-Data 0 (* n 3))]
    (for [offset (arr.range 0 n)]
      (let [entity (+ start-entity offset)]
        (arr.push! tx (vev.add (u64 entity) ":user/email" (vev.value-string (fmt.tprintf "user-%d@example.com" entity))))
        (arr.push! tx (vev.add (u64 entity) ":user/name" (vev.value-string (fmt.tprintf "User %d" entity))))
        (arr.push! tx (vev.add (u64 entity) ":user/age" (vev.value-int (i64 (% entity 100)))))))
    tx))

(defn batch-people-datoms [start-entity: int, n: int, tx: u64] -> [dynamic]vev.Datom
  (let [datoms (make [dynamic]vev.Datom 0 (* n 3))]
    (for [offset (arr.range 0 n)]
      (let [entity (+ start-entity offset)
            entity-id (u64 entity)]
        (arr.push! datoms (vev.Datom {e: entity-id
                                      a: ":user/email"
                                      v: (vev.value-string (fmt.tprintf "user-%d@example.com" entity))
                                      tx: tx
                                      added: true}))
        (arr.push! datoms (vev.Datom {e: entity-id
                                      a: ":user/name"
                                      v: (vev.value-string (fmt.tprintf "User %d" entity))
                                      tx: tx
                                      added: true}))
        (arr.push! datoms (vev.Datom {e: entity-id
                                      a: ":user/age"
                                      v: (vev.value-int (i64 (% entity 100)))
                                      tx: tx
                                      added: true}))))
    datoms))

(defn clone-log-with-added [base: []vev.Datom, added: []vev.Datom] -> [dynamic]vev.Datom
  (let [out (arr.into [dynamic]vev.Datom base)]
    (for [datom added]
      (arr.push! out datom))
    out))

(defn print-timing [workload: string, n: int, samples: []f64]
  (let [timing (bench.timing-from-samples samples)]
    (fmt.printf
      "engine=vev-sqlite workload=%s n=%d min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f samples=%d\n"
      workload
      n
      timing.min-us
      timing.median-us
      timing.p90-us
      timing.max-us
      (count samples))))

(defn print-store-timing [workload: string, n: int, samples: []f64]
  (let [timing (bench.timing-from-samples samples)]
    (fmt.printf
      "engine=vev-store workload=%s n=%d min_us=%.0f median_us=%.0f p90_us=%.0f max_us=%.0f samples=%d\n"
      workload
      n
      timing.min-us
      timing.median-us
      timing.p90-us
      timing.max-us
      (count samples))))

(defn profile-avg-us [value-us: f64, writes: u64] -> f64
  (if (> writes 0)
    (/ value-us (f64 writes))
    0.0))

(defn print-store-profile [workload: string, profile: vev.SQLite-Direct-Write-Profile]
  (fmt.printf
    "engine=vev-store-profile workload=%s writes=%d direct_call_us=%.0f open_before_us=%.0f read_source_us=%.0f resolve_us=%.0f overlay_us=%.0f append_us=%.0f report_open_us=%.0f auto_maintenance_us=%.0f listener_us=%.0f append_roots_us=%.0f append_root_build_us=%.0f append_root_sort_us=%.0f append_root_persist_us=%.0f append_root_publish_us=%.0f append_commit_us=%.0f\n"
    workload
    profile.writes
    (profile-avg-us profile.direct-call-us profile.writes)
    (profile-avg-us profile.open-before-us profile.writes)
    (profile-avg-us profile.read-source-us profile.writes)
    (profile-avg-us profile.resolve-us profile.writes)
    (profile-avg-us profile.overlay-us profile.writes)
    (profile-avg-us profile.append-us profile.writes)
    (profile-avg-us profile.report-open-us profile.writes)
    (profile-avg-us profile.auto-maintenance-us profile.writes)
    (profile-avg-us profile.listener-us profile.writes)
    (profile-avg-us profile.append-roots-us profile.writes)
    (profile-avg-us profile.append-root-build-us profile.writes)
    (profile-avg-us profile.append-root-sort-us profile.writes)
    (profile-avg-us profile.append-root-persist-us profile.writes)
    (profile-avg-us profile.append-root-publish-us profile.writes)
    (profile-avg-us profile.append-commit-us profile.writes)))

(defn run-workload? [selected: string, workload: string] -> bool
  (or (= selected "all")
      (= selected workload)))

(defn run-group? [selected: string, group: string] -> bool
  (or (= selected "all")
      (= selected group)))

(defn run-reopen-db-workloads? [selected: string] -> bool
  (or (run-group? selected "durable")
      (run-group? selected "source")
      (run-workload? selected "persisted-index-load")
      (run-workload? selected "persisted-index-page-load")
      (run-workload? selected "persisted-index-cursor-scan")
      (run-workload? selected "persisted-index-snapshot-open")
      (run-workload? selected "persisted-db-snapshot-open")
      (run-workload? selected "persisted-db-snapshot-entity-read")
      (run-workload? selected "persisted-db-snapshot-entity-attr-read")
      (run-workload? selected "persisted-db-snapshot-attr-read")
      (run-workload? selected "persisted-db-snapshot-source-query")
      (run-workload? selected "persisted-db-snapshot-source-join-query")
      (run-workload? selected "persisted-db-snapshot-source-two-attr-query")
      (run-workload? selected "store-conn-source-prepared-query")
      (run-workload? selected "store-read-only-open")
      (run-workload? selected "store-read-only-prepared-query")
      (run-workload? selected "store-db-prepared-query")
      (run-workload? selected "store-db-two-attr-prepared-query")
      (run-workload? selected "store-db-two-attr-typed-relation")
      (run-workload? selected "store-db-two-attr-column-operator")
      (run-workload? selected "reopen-rebuild")
      (run-workload? selected "reopened-query")))

(defn measure-single-append [path: string, sample-count: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        samples (make [dynamic]f64 0 sample-count)]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=single-append ok=false error=%s\n" open-error)
      (return))
    (for [i (arr.range 0 sample-count)]
      (let [tx (one-person-tx (+ i 1))
            start (time.now)
            report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))
            elapsed (bench.elapsed-us start)]
        (when (not report.ok)
          (fmt.printf "engine=vev-sqlite workload=single-append ok=false error=%s\n" report.error)
          (vev.delete-tx-report-shallow report)
          (delete tx)
          (vev.close-sqlite-conn store)
          (return))
        (vev.delete-live-tx-report-shallow report)
        (delete tx)
        (arr.push! samples elapsed)))
    (vev.close-sqlite-conn store)
    (print-timing "single-append" 1 (slice samples 0))))

(defn measure-batch-append [path: string, batch-size: int, sample-count: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-sqlite-conn path)
        samples (make [dynamic]f64 0 sample-count)]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-sqlite workload=batch-append ok=false error=%s\n" open-error)
      (return))
    (for [i (arr.range 0 sample-count)]
      (let [tx (batch-people-tx (+ 1 (* i batch-size)) batch-size)
            start (time.now)
            report (vev.transact-sqlite-tx-data (addr store) (slice tx 0))
            elapsed (bench.elapsed-us start)]
        (when (not report.ok)
          (fmt.printf "engine=vev-sqlite workload=batch-append ok=false error=%s\n" report.error)
          (vev.delete-tx-report-shallow report)
          (delete tx)
          (vev.close-sqlite-conn store)
          (return))
        (vev.delete-live-tx-report-shallow report)
        (delete tx)
        (arr.push! samples elapsed)))
    (vev.close-sqlite-conn store)
    (print-timing "batch-append" batch-size (slice samples 0))))

(defn measure-store-report-single-append [path: string, sample-count: int]
  (remove-sqlite-files path)
  (let [[store open-ok open-error] (vev.open-store path)
        samples (make [dynamic]f64 0 sample-count)]
    (defer (delete samples))
    (when (not open-ok)
      (fmt.printf "engine=vev-store workload=store-report-single-append ok=false error=%s\n" open-error)
      (return))
    (vev.reset-store-direct-write-profile! (addr store))
    (for [i (arr.range 0 sample-count)]
      (let [tx (one-person-tx (+ i 1))
            start (time.now)
            report (vev.transact-store-report-tx-data (addr store) (slice tx 0))
            elapsed (bench.elapsed-us start)]
        (when (not report.ok)
          (fmt.printf "engine=vev-store workload=store-report-single-append ok=false error=%s\n" report.error)
          (vev.delete-store-tx-report report)
          (delete tx)
          (vev.close-store store)
          (return))
        (vev.delete-store-tx-report report)
        (delete tx)
        (arr.push! samples elapsed)))
    (let [profile (vev.store-direct-write-profile (addr store))]
      (print-store-profile "store-report-single-append" profile))
    (vev.close-store store)
    (print-store-timing "store-report-single-append" 1 (slice samples 0))))

