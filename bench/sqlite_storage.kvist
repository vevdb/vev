                    (not (= snapshot.datom-count expected-datoms)))
            (vev.close-sqlite-db-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-open ok=false error=unexpected-count index=%d datoms=%d expected=%d\n" count snapshot.datom-count expected-datoms)
            (return))
          (when (or (< first-entry 0) (< middle-entry 0))
            (vev.close-sqlite-db-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-open ok=false error=invalid-index-entry first=%d middle=%d\n" first-entry middle-entry)
            (return))
          (when (not datom-ok)
            (vev.close-sqlite-db-snapshot! (addr snapshot))
            (fmt.printf "engine=vev-sqlite workload=persisted-db-snapshot-open ok=false error=%s\n" datom-error)
            (return))
          (vev.delete-owned-datom datom)
          (vev.close-sqlite-db-snapshot! (addr snapshot))
          (arr.push! samples elapsed))))
    (print-timing "persisted-db-snapshot-open" people-count (slice samples 0))))

