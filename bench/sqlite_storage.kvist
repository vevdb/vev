(defn measure-store-db-prepared-query [path: string, people-count: int, sample-count: int]
  (let [[store ok error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        entity (/ people-count 2)
        query-text (vev.string-owned (fmt.tprintf "[:find ?name ?age :where [?e :user/email \"user-%d@example.com\"] [?e :user/name ?name] [?e :user/age ?age]]" entity))
        prepared (vev.prepare-query-text query-text)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
    (defer (delete samples))
    (defer (delete query-text))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-prepared-query ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-prepared-query ok=false error=%s\n" snapshot-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-prepared-query ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-result-store-db-prepared (addr snapshot) prepared)
            elapsed (bench.elapsed-us start)]
        (when (or (not result.result.ok)
                  (not (= (count result.result.rows) 1))
                  (not (= (count result.result.rows[0].values) 2)))
          (fmt.printf "engine=vev-sqlite workload=store-db-prepared-query ok=false error=unexpected-result\n")
          (vev.delete-query-result result)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store-db! (addr snapshot))
          (vev.close-store store)
          (return))
        (vev.delete-query-result result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)
    (print-timing "store-db-prepared-query" people-count (slice samples 0))))

(defn measure-store-db-two-attr-prepared-query [path: string, people-count: int, sample-count: int]
  (let [[store ok error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        query-text "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]"
        prepared (vev.prepare-query-text query-text)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
    (defer (delete samples))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-prepared-query ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-prepared-query ok=false error=%s\n" snapshot-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-prepared-query ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-result-store-db-prepared (addr snapshot) prepared)
            elapsed (bench.elapsed-us start)]
        (when (or (not result.result.ok)
                  (not (= (count result.result.rows) people-count))
                  (not (= (count result.result.rows[0].values) 2)))
          (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-prepared-query ok=false error=unexpected-result rows=%d expected=%d\n" (count result.result.rows) people-count)
          (vev.delete-query-result result)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store-db! (addr snapshot))
          (vev.close-store store)
          (return))
        (vev.delete-query-result result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)
    (print-timing "store-db-two-attr-prepared-query" people-count (slice samples 0))))

(defn measure-store-db-two-attr-typed-relation [path: string, people-count: int, sample-count: int]
  (let [[store ok error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        query-text "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]"
        prepared (vev.prepare-query-text query-text)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        [source source-ok source-error] (vev.store-db-read-source (addr snapshot))]
    (defer (delete samples))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-typed-relation ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-typed-relation ok=false error=%s\n" snapshot-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not source-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-typed-relation ok=false error=%s\n" source-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-typed-relation ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [rel rel-stats used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) prepared.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            elapsed (bench.elapsed-us start)]
        (discard rel-stats)
        (when (or (not used)
                  (not rel.has-typed-columns)
                  (not (= (vev.query-relation-row-count rel) people-count)))
          (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-typed-relation ok=false error=unexpected-result rows=%d expected=%d\n" (vev.query-relation-row-count rel) people-count)
          (vev.delete-query-relation rel)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store-db! (addr snapshot))
          (vev.close-store store)
          (return))
        (vev.delete-query-relation rel)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)
    (print-timing "store-db-two-attr-typed-relation" people-count (slice samples 0))))

(defn measure-store-db-two-attr-column-operator [path: string, people-count: int, sample-count: int]
  (let [[store ok error] (vev.open-store-read-only path)
        samples (make [dynamic]f64 0 sample-count)
        query-text "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]"
        prepared (vev.prepare-query-text query-text)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        [source source-ok source-error] (vev.store-db-read-source (addr snapshot))]
    (defer (delete samples))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-column-operator ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not snapshot-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-column-operator ok=false error=%s\n" snapshot-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not source-ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-column-operator ok=false error=%s\n" source-error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (when (not prepared.ok)
      (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-column-operator ok=false error=%s\n" prepared.error)
      (vev.delete-prepared-query-shallow prepared)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store store)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            [columns columns-ok columns-error] (vev.q-db-read-source-string-int-pair-columns source prepared.query ([]vev.Query-Input []))
            elapsed (bench.elapsed-us start)]
        (when (or (not columns-ok)
                  (not (= (count columns.strings) people-count)))
          (fmt.printf "engine=vev-sqlite workload=store-db-two-attr-column-operator ok=false error=%s rows=%d expected=%d\n" columns-error (count columns.strings) people-count)
          (vev.delete-entity-string-int-triples columns)
          (vev.delete-prepared-query-shallow prepared)
          (vev.close-store-db! (addr snapshot))
          (vev.close-store store)
          (return))
        (vev.delete-entity-string-int-triples columns)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)
    (print-timing "store-db-two-attr-column-operator" people-count (slice samples 0))))

(defn measure-reopened-query [path: string, people-count: int, sample-count: int]
  (let [[conn ok error] (vev.open-conn-sqlite path)
        samples (make [dynamic]f64 0 sample-count)
        query (vev.prepare-query-text "[:find ?name ?age :in ?email :where [?e :user/email ?email] [?e :user/name ?name] [?e :user/age ?age]]")
        inputs (vev.string-owned (fmt.tprintf "[\"user-%d@example.com\"]" (/ people-count 2)))]
    (defer (delete samples))
    (defer (delete inputs))
    (when (not ok)
      (fmt.printf "engine=vev-sqlite workload=reopened-query ok=false error=%s\n" error)
      (vev.delete-prepared-query-shallow query)
      (delete-conn-shallow conn)
      (return))
    (for [sample-index (arr.range 0 sample-count)]
      (let [start (time.now)
            result (vev.q-prepared-with-input-text conn.db query inputs)
            elapsed (bench.elapsed-us start)]
        (when (not (= (count result.rows) 1))
          (fmt.printf "engine=vev-sqlite workload=reopened-query ok=false error=unexpected-row-count count=%d\n" (count result.rows))
          (vev.delete-result-set-shallow result)
          (delete-conn-shallow conn)
          (return))
        (vev.delete-result-set-shallow result)
        (arr.push! samples elapsed)))
    (vev.delete-prepared-query-shallow query)
    (delete-conn-shallow conn)
    (print-timing "reopened-query" people-count (slice samples 0))))

(defn main []
  (defer (free_all context.allocator))
  (let [selected (cli.option os.args "--workload" "all")
        single-path "tmp.vev.bench.single.sqlite"
        batch-path "tmp.vev.bench.batch.sqlite"
        split-path "tmp.vev.bench.split.sqlite"
        reopen-path "tmp.vev.bench.reopen.sqlite"
        single-samples 50
        batch-size 100
        batch-samples 20
        reopen-people 2000
        reopen-samples 30]
    (defer (remove-sqlite-files single-path))
    (defer (remove-sqlite-files batch-path))
    (defer (remove-sqlite-files split-path))
    (defer (remove-sqlite-files reopen-path))
    (when (or (run-group? selected "append") (run-workload? selected "single-append"))
      (measure-single-append single-path single-samples))
    (when (or (run-group? selected "append") (run-workload? selected "batch-append"))
      (measure-batch-append batch-path batch-size batch-samples))
    (when (or (run-group? selected "store-append") (run-workload? selected "store-report-single-append"))
      (measure-store-report-single-append single-path single-samples))
    (when (or (run-group? selected "store-append") (run-workload? selected "store-report-batch-append"))
      (measure-store-report-batch-append batch-path batch-size batch-samples))
    (when (or (run-group? selected "append") (run-workload? selected "batch-split"))
      (measure-batch-split split-path batch-size batch-samples))
    (when (or (run-group? selected "append") (run-workload? selected "batch-pipeline-split"))
      (measure-batch-pipeline-split split-path batch-size batch-samples))
    (when (or (run-group? selected "append") (run-workload? selected "append-only-core"))
      (measure-append-only-core reopen-people batch-size reopen-samples))
    (when (run-reopen-db-workloads? selected)
      (when (seed-durable-db reopen-path reopen-people)
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-index-load"))
          (measure-persisted-index-load reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-index-page-load"))
          (measure-persisted-index-page-load reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-index-cursor-scan"))
          (measure-persisted-index-cursor-scan reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-index-snapshot-open"))
          (measure-persisted-index-snapshot-open reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-db-snapshot-open"))
          (measure-persisted-db-snapshot-open reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-db-snapshot-entity-read"))
          (measure-persisted-db-snapshot-entity-read reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-db-snapshot-entity-attr-read"))
          (measure-persisted-db-snapshot-entity-attr-read reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-workload? selected "persisted-db-snapshot-attr-read"))
          (measure-persisted-db-snapshot-attr-read reopen-path reopen-people 5 128))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "persisted-db-snapshot-source-query"))
          (measure-persisted-db-snapshot-source-query reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "persisted-db-snapshot-source-join-query"))
          (measure-persisted-db-snapshot-source-join-query reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "persisted-db-snapshot-source-two-attr-query"))
          (measure-persisted-db-snapshot-source-two-attr-query reopen-path reopen-people reopen-samples 128))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-conn-source-prepared-query"))
          (measure-sqlite-conn-source-prepared-query reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-read-only-open"))
          (measure-sqlite-source-conn-open reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-read-only-prepared-query"))
          (measure-sqlite-source-conn-prepared-query reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-db-prepared-query"))
          (measure-store-db-prepared-query reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-db-two-attr-prepared-query"))
          (measure-store-db-two-attr-prepared-query reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-group? selected "source") (run-workload? selected "store-db-two-attr-typed-relation"))
          (measure-store-db-two-attr-typed-relation reopen-path reopen-people reopen-samples))
        (when (run-workload? selected "store-db-two-attr-column-operator")
          (measure-store-db-two-attr-column-operator reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-workload? selected "reopen-rebuild"))
          (measure-reopen reopen-path reopen-people reopen-samples))
        (when (or (run-group? selected "durable") (run-workload? selected "reopened-query"))
          (measure-reopened-query reopen-path reopen-people reopen-samples))))))
