@export
(defn vev_query_db_prepared_entity_column_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-U64-Array
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-U64-Array nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        db-ptr-value (db-ptr db)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (Vev-U64-Array nil)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (let [[entities entity-ok] (vev.q-query-entity-column db-ptr-value^ query-ptr-value^.query ([]vev.Query-Input []))]
        (when (not entity-ok)
          (delete entities)
          (return (Vev-U64-Array nil)))
        (return (Vev-U64-Array (abi-alloc-u64-array entities)))))
    (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (delete inputs)
        (return (Vev-U64-Array nil)))
      (let [[entities entity-ok] (vev.q-query-entity-column db-ptr-value^ query-ptr-value^.query (slice inputs 0))]
        (delete inputs)
        (when (not entity-ok)
          (delete entities)
          (return (Vev-U64-Array nil)))
        (Vev-U64-Array (abi-alloc-u64-array entities))))))

