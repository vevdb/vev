    case ABI_COLUMN_BATCH_ENTITY_STRING:
        abi_free_entity_string_int_triples(wrapper.handle)
    case ABI_COLUMN_BATCH_STRING_INT:
        abi_free_entity_string_int_triples(wrapper.handle)
    case ABI_COLUMN_BATCH_STRING_STRING:
        abi_free_string_string_pairs(wrapper.handle)
    }
    free(wrapper)
}

abi_column_batch_copy_u64_array :: proc(batch: rawptr, column: int) -> rawptr {
    count := abi_column_batch_count(batch)
    if column < 0 || column >= abi_column_batch_column_count(batch) || abi_column_batch_column_kind(batch, column) != ABI_COLUMN_KIND_ENTITY {
        return nil
    }
    data := abi_column_batch_column_entities_data(batch, column)
    if count > 0 && data == nil {
        return nil
    }
    values := make([dynamic]u64, 0, count)
    raw := ([^]u64)(data)
    for i in 0..<count {
        append(&values, raw[i])
    }
    return abi_alloc_u64_array(values)
}

abi_column_batch_copy_string_array :: proc(batch: rawptr, column: int) -> rawptr {
    count := abi_column_batch_count(batch)
    if column < 0 || column >= abi_column_batch_column_count(batch) || abi_column_batch_column_kind(batch, column) != ABI_COLUMN_KIND_STRING {
        return nil
    }
    data := abi_column_batch_column_string_data_array(batch, column)
    lengths := abi_column_batch_column_string_lengths_data(batch, column)
    if count > 0 && (data == nil || lengths == nil) {
        return nil
    }
    values := make([dynamic]string, 0, count)
    raw_data_values := ([^]rawptr)(data)
    raw_lengths := ([^]i32)(lengths)
    for i in 0..<count {
        owned, err := strings.clone_from_ptr((^byte)(raw_data_values[i]), int(raw_lengths[i]))
        if err != nil {
            for value in values {
                delete(value)
            }
            delete(values)
            return nil
        }
        append(&values, owned)
    }
    return abi_alloc_string_array(values)
}

abi_column_batch_copy_entity_int_pairs :: proc(batch: rawptr) -> rawptr {
    count := abi_column_batch_count(batch)
    if abi_column_batch_column_count(batch) != 2 ||
       abi_column_batch_column_kind(batch, 0) != ABI_COLUMN_KIND_ENTITY ||
       abi_column_batch_column_kind(batch, 1) != ABI_COLUMN_KIND_INT {
        return nil
    }
    entity_data := abi_column_batch_column_entities_data(batch, 0)
    int_data := abi_column_batch_column_ints_data(batch, 1)
    if count > 0 && (entity_data == nil || int_data == nil) {
        return nil
    }
    columns := vev__Entity_Int_Pair_Columns{
        entities = make([dynamic]u64, 0, count),
        values = make([dynamic]i64, 0, count),
    }
    raw_entities := ([^]u64)(entity_data)
    raw_ints := ([^]i64)(int_data)
    for i in 0..<count {
        append(&columns.entities, raw_entities[i])
        append(&columns.values, raw_ints[i])
    }
    return abi_alloc_entity_int_pairs(columns)
}

abi_column_batch_copy_entity_string_int_triples :: proc(batch: rawptr) -> rawptr {
    count := abi_column_batch_count(batch)
    if abi_column_batch_column_count(batch) != 3 ||
       abi_column_batch_column_kind(batch, 0) != ABI_COLUMN_KIND_ENTITY ||
       abi_column_batch_column_kind(batch, 1) != ABI_COLUMN_KIND_STRING ||
       abi_column_batch_column_kind(batch, 2) != ABI_COLUMN_KIND_INT {
        return nil
    }
    entity_data := abi_column_batch_column_entities_data(batch, 0)
    string_data := abi_column_batch_column_string_data_array(batch, 1)
    string_lengths := abi_column_batch_column_string_lengths_data(batch, 1)
    int_data := abi_column_batch_column_ints_data(batch, 2)
    if count > 0 && (entity_data == nil || string_data == nil || string_lengths == nil || int_data == nil) {
        return nil
    }
    columns := vev__Entity_String_Int_Triples{
        entities = make([dynamic]u64, 0, count),
        strings = make([dynamic]string, 0, count),
        ints = make([dynamic]i64, 0, count),
        owns_strings = true,
    }
    raw_entities := ([^]u64)(entity_data)
    raw_string_data := ([^]rawptr)(string_data)
    raw_string_lengths := ([^]i32)(string_lengths)
    raw_ints := ([^]i64)(int_data)
    for i in 0..<count {
        owned, err := strings.clone_from_ptr((^byte)(raw_string_data[i]), int(raw_string_lengths[i]))
        if err != nil {
            for value in columns.strings {
                delete(value)
            }
            delete(columns.entities)
            delete(columns.strings)
            delete(columns.ints)
            return nil
        }
        append(&columns.entities, raw_entities[i])
        append(&columns.strings, owned)
        append(&columns.ints, raw_ints[i])
    }
    return abi_alloc_entity_string_int_triples(columns)
}

abi_result_value_ptr :: proc(result: rawptr, row: int, column: int) -> rawptr {
    wrapper := (^ABI_Result)(result)
    if wrapper == nil || row < 0 || column < 0 || row >= len(wrapper.result.rows) || column >= len(wrapper.result.rows[row].values) {
        return nil
    }
    return rawptr(&wrapper.result.rows[row].values[column])
}

abi_result_pull_value_ptr :: proc(result: rawptr, row: int, pull: int) -> rawptr {
    wrapper := (^ABI_Result)(result)
    if wrapper == nil || row < 0 || pull < 0 || row >= len(wrapper.result.rows) || pull >= len(wrapper.result.rows[row].pulls) {
        return nil
    }
    if row >= len(wrapper.pull_offsets) {
        return nil
    }
    flat := wrapper.pull_offsets[row] + pull
    if flat < 0 || flat >= len(wrapper.pull_values) {
        return nil
    }
    return rawptr(&wrapper.pull_values[flat])
}

abi_value_item_ptr :: proc(value: rawptr, index: int) -> rawptr {
    if value == nil || index < 0 {
        return nil
    }
    v := (^vev__Value)(value)
    if (v.kind != .Vector && v.kind != .Set) || index >= len(v.items) {
        return nil
    }
    return rawptr(&v.items[index])
}

abi_value_map_key_ptr :: proc(value: rawptr, index: int) -> rawptr {
    if value == nil || index < 0 {
        return nil
    }
    v := (^vev__Value)(value)
    item_index := index * 2
    if v.kind != .Map || item_index >= len(v.items) {
        return nil
    }
    return rawptr(&v.items[item_index])
}

abi_value_map_value_ptr :: proc(value: rawptr, index: int) -> rawptr {
    if value == nil || index < 0 {
        return nil
    }
    v := (^vev__Value)(value)
    item_index := index * 2 + 1
    if v.kind != .Map || item_index >= len(v.items) {
        return nil
    }
    return rawptr(&v.items[item_index])
}

abi_value_text_data :: proc(value: rawptr) -> rawptr {
    if value == nil {
        return nil
    }
    v := (^vev__Value)(value)
    if v.kind != .String && v.kind != .Keyword && v.kind != .Symbol && v.kind != .Uuid {
        return nil
    }
    if len(v.text) == 0 {
        return nil
    }
    return raw_data(v.text)
}

abi_value_text_len :: proc(value: rawptr) -> int {
    if value == nil {
        return 0
    }
    v := (^vev__Value)(value)
    if v.kind != .String && v.kind != .Keyword && v.kind != .Symbol && v.kind != .Uuid {
        return 0
    }
    return len(v.text)
}

abi_value_visit_walk :: proc(value: ^vev__Value, visitor: ABI_Value_Visit_Fn, user: rawptr) -> bool {
    if value == nil || visitor == nil {
        return false
    }
    if !visitor(user, 1, rawptr(value)) {
        return false
    }
    if value.kind == .Vector || value.kind == .Set || value.kind == .Map {
        for i in 0..<len(value.items) {
            if !abi_value_visit_walk(&value.items[i], visitor, user) {
                return false
            }
        }
        if !visitor(user, 2, rawptr(value)) {
            return false
        }
    }
    return true
}

abi_value_visit :: proc(value: rawptr, visitor: rawptr, user: rawptr) -> bool {
    if value == nil || visitor == nil {
        return false
    }
    cb := transmute(ABI_Value_Visit_Fn)visitor
    return abi_value_visit_walk((^vev__Value)(value), cb, user)
}

abi_result_visit :: proc(result: rawptr, visitor: rawptr, user: rawptr) -> bool {
    wrapper := (^ABI_Result)(result)
    if wrapper == nil || visitor == nil {
        return false
    }
    cb := transmute(ABI_Result_Visit_Fn)visitor
    for row_index in 0..<len(wrapper.result.rows) {
        row := &wrapper.result.rows[row_index]
        if !cb(user, 1, row_index, -1, nil) {
            return false
        }
        for value_index in 0..<len(row.values) {
            if !cb(user, 2, row_index, value_index, rawptr(&row.values[value_index])) {
                return false
            }
        }
        for pull_index in 0..<len(row.pulls) {
            pull_value := abi_result_pull_value_ptr(result, row_index, pull_index)
            if !cb(user, 3, row_index, pull_index, pull_value) {
                return false
            }
        }
        if !cb(user, 4, row_index, -1, nil) {
            return false
        }
    }
    return true
}

abi_alloc_stmt :: proc(query: rawptr) -> rawptr {
    wrapper := new(ABI_Stmt)
    wrapper.query = query
    wrapper.inputs = make([dynamic]vev__Query_Input)
    wrapper.pull_pattern_sources = make([dynamic]string)
    wrapper.sources = make([dynamic]vev__DB_Read_Named_Source)
    wrapper.source_handles = make([dynamic]rawptr)
    return rawptr(wrapper)
}

abi_stmt_query :: proc(stmt: rawptr) -> rawptr {
    return (^ABI_Stmt)(stmt)^.query
}

abi_stmt_inputs_ptr :: proc(stmt: rawptr) -> ^[dynamic]vev__Query_Input {
    return &((^ABI_Stmt)(stmt))^.inputs
}

abi_stmt_pull_pattern_sources_ptr :: proc(stmt: rawptr) -> ^[dynamic]string {
    return &((^ABI_Stmt)(stmt))^.pull_pattern_sources
}

abi_stmt_sources_ptr :: proc(stmt: rawptr) -> ^[dynamic]vev__DB_Read_Named_Source {
    return &((^ABI_Stmt)(stmt))^.sources
}

abi_stmt_source_handles_ptr :: proc(stmt: rawptr) -> ^[dynamic]rawptr {
    return &((^ABI_Stmt)(stmt))^.source_handles
}

abi_stmt_error_ptr :: proc(stmt: rawptr) -> ^string {
    return &((^ABI_Stmt)(stmt))^.last_error
}

abi_stmt_push_input :: proc(stmt: rawptr, input: vev__Query_Input) {
    append(&((^ABI_Stmt)(stmt))^.inputs, input)
}

abi_stmt_push_source :: proc(stmt: rawptr, source: vev__DB_Read_Named_Source, handle: rawptr) {
    append(&((^ABI_Stmt)(stmt))^.sources, source)
    append(&((^ABI_Stmt)(stmt))^.source_handles, handle)
}

abi_cstring_at :: proc(values: rawptr, index: int) -> cstring {
    return ([^]cstring)(values)[index]
}

abi_u64_at :: proc(values: rawptr, index: int) -> u64 {
    return ([^]u64)(values)[index]
}

abi_i64_at :: proc(values: rawptr, index: int) -> i64 {
    return ([^]i64)(values)[index]
}

abi_bool_at :: proc(values: rawptr, index: int) -> bool {
    return ([^]bool)(values)[index]
}

abi_rawptr_at :: proc(values: rawptr, index: int) -> rawptr {
    return ([^]rawptr)(values)[index]
}

abi_free_stmt :: proc(stmt: rawptr) {
    wrapper := (^ABI_Stmt)(stmt)
    delete(wrapper.inputs)
    delete(wrapper.pull_pattern_sources)
    delete(wrapper.sources)
    delete(wrapper.source_handles)
    if len(wrapper.last_error) > 0 {
        delete(wrapper.last_error)
    }
    free(wrapper)
}
")

(def Vev-Conn (distinct rawptr))
(def Vev-Connection (distinct rawptr))
(def Vev-SQLite-Conn (distinct rawptr))
(def Vev-DB (distinct rawptr))
(def Vev-Entity (distinct rawptr))
(def Vev-Prepared-Query (distinct rawptr))
(def Vev-Prepared-Pull-Pattern (distinct rawptr))
(def Vev-Result (distinct rawptr))
(def Vev-U64-Array (distinct rawptr))
(def Vev-String-Array (distinct rawptr))
(def Vev-Entity-Int-Pairs (distinct rawptr))
(def Vev-Entity-String-Int-Triples (distinct rawptr))
(def Vev-Column-Batch (distinct rawptr))
(def Vev-Stmt (distinct rawptr))
(def Vev-Tx-Report (distinct rawptr))
(def Vev-Tx-Report-Array (distinct rawptr))
(def Vev-Tx-Builder (distinct rawptr))
(def Vev-Tx-Fn-Registry (distinct rawptr))
(def Vev-Query-Fn-Registry (distinct rawptr))
(def Vev-Tx-Fn-Args (distinct rawptr))
(def Vev-Value-Handle (distinct rawptr))
(def Vev-Value (distinct rawptr))

(defn- conn-ptr [conn: Vev-Conn] -> ^vev.Conn
  (abi-conn-ptr (rawptr conn)))

(defn- sqlite-conn-ptr [conn: Vev-SQLite-Conn] -> ^vev.SQLite-Conn
  (abi-sqlite-conn-ptr (rawptr conn)))

(defn- connection-as-sqlite [conn: Vev-Connection] -> Vev-SQLite-Conn
  (Vev-SQLite-Conn (rawptr conn)))

(defn- durable-path-from-uri [uri: string] -> string
  (if (strings.has_prefix uri "sqlite://")
    (string-owned (slice uri 9))
    (string-owned uri)))

(defn- connection-info-value [conn: Vev-Connection] -> vev.Value
  (let [[tx-count _ _] (vev.sqlite-conn-tx-count (sqlite-conn-ptr (connection-as-sqlite conn)))]
    (vev.value-map
      ([]vev.Value
        [(vev.value-keyword (string-owned ":backend"))
         (vev.value-keyword (string-owned ":sqlite"))
         (vev.value-keyword (string-owned ":path"))
         (vev.value-string (string-owned (abi-sqlite-conn-path (rawptr conn))))
         (vev.value-keyword (string-owned ":basis-t"))
         (vev.value-int (i64 (abi-sqlite-conn-basis-t (rawptr conn))))
         (vev.value-keyword (string-owned ":tx-count"))
         (vev.value-int (i64 tx-count))]))))

(defn- prepared-query-ptr [query: Vev-Prepared-Query] -> ^vev.Prepared-Query
  (abi-prepared-query-ptr (rawptr query)))

(defn- prepared-pull-pattern-ptr [pattern: Vev-Prepared-Pull-Pattern] -> ^vev.Prepared-Pull-Pattern
  (abi-prepared-pull-pattern-ptr (rawptr pattern)))

(defn- db-ptr [db: Vev-DB] -> ^vev.DB
  (abi-db-ptr (rawptr db)))

(defn- store-db-ptr [db: Vev-DB] -> ^vev.Store-DB
  (abi-store-db-ptr (rawptr db)))

(defn- entity-ptr [entity: Vev-Entity] -> ^vev.Store-Entity
  (abi-entity-ptr (rawptr entity)))

(defn- db-resident? [db: Vev-DB] -> bool
  (when (= (rawptr db) nil)
    (return false))
  (let [store (store-db-ptr db)]
    (= store^.kind .Resident)))

(defn- resident-db-ptr [db: Vev-DB] -> [ptr: ^vev.DB, ok: bool]
  (if (db-resident? db)
    (return (db-ptr db) true)
    (return (db-ptr db) false)))

(defn- result-ptr [result: Vev-Result] -> ^vev.Result-Set
  (abi-result-ptr (rawptr result)))

(defn- result-set-owns-values! [result: Vev-Result, owns-values: bool]
  (abi-result-set-owns-values (rawptr result) owns-values))

(defn- result-owns-values? [result: Vev-Result] -> bool
  (abi-result-owns-values (rawptr result)))

(defn- result-pull-values-ptr [result: Vev-Result] -> ^[dynamic]vev.Value
  (abi-result-pull-values-ptr (rawptr result)))

(defn- result-pull-offsets-ptr [result: Vev-Result] -> ^[dynamic]int
  (abi-result-pull-offsets-ptr (rawptr result)))

(defn- u64-array-count [array: Vev-U64-Array] -> int
  (abi-u64-array-count (rawptr array)))

(defn- u64-array-value [array: Vev-U64-Array, index: int] -> u64
  (abi-u64-array-value (rawptr array) index))

(defn- u64-array-data [array: Vev-U64-Array] -> rawptr
  (abi-u64-array-data (rawptr array)))

(defn- entity-int-pairs-count [array: Vev-Entity-Int-Pairs] -> int
  (abi-entity-int-pairs-count (rawptr array)))

(defn- entity-int-pairs-entity [array: Vev-Entity-Int-Pairs, index: int] -> u64
  (abi-entity-int-pairs-entity (rawptr array) index))

(defn- entity-int-pairs-value [array: Vev-Entity-Int-Pairs, index: int] -> i64
  (abi-entity-int-pairs-value (rawptr array) index))

(defn- entity-int-pairs-entities-data [array: Vev-Entity-Int-Pairs] -> rawptr
  (abi-entity-int-pairs-entities-data (rawptr array)))

(defn- entity-int-pairs-values-data [array: Vev-Entity-Int-Pairs] -> rawptr
  (abi-entity-int-pairs-values-data (rawptr array)))

(defn- u64-array-from-column-batch [batch: Vev-Column-Batch, column: int] -> Vev-U64-Array
  (Vev-U64-Array (abi-column-batch-copy-u64-array (rawptr batch) column)))

(defn- string-array-from-column-batch [batch: Vev-Column-Batch, column: int] -> Vev-String-Array
  (Vev-String-Array (abi-column-batch-copy-string-array (rawptr batch) column)))

(defn- entity-int-pairs-from-column-batch [batch: Vev-Column-Batch] -> Vev-Entity-Int-Pairs
  (Vev-Entity-Int-Pairs (abi-column-batch-copy-entity-int-pairs (rawptr batch))))

(defn- entity-string-int-triples-from-column-batch [batch: Vev-Column-Batch] -> Vev-Entity-String-Int-Triples
  (Vev-Entity-String-Int-Triples (abi-column-batch-copy-entity-string-int-triples (rawptr batch))))

(defn- column-batch-text-like-value? [value: vev.Value] -> bool
  (or (= value.kind .String)
      (= value.kind .Keyword)
      (= value.kind .Symbol)
      (= value.kind .Uuid)))

(defn- column-kind-for-relation-column-kind [kind: vev.Relation-Column-Kind] -> int
  (case kind
    .Entity 1
    .Int 3
    .Bool 5
    .Float 6
    .String 2
    .Keyword 2
    .Symbol 2
    .Uuid 2
    .Mixed 4
    0))

(defn- column-batch-legacy-kind-for-column-kinds [kinds: []int] -> int
  (case (count kinds)
    1
      (case kinds[0]
        1 1
        2 2
        3 5
        0)
    2
      (cond
        (and (= kinds[0] 1) (= kinds[1] 3)) 3
        (and (= kinds[0] 1) (= kinds[1] 2)) 6
        (and (= kinds[0] 2) (= kinds[1] 3)) 7
        (and (= kinds[0] 2) (= kinds[1] 2)) 8
        :else 0)
    3
      (if (and (= kinds[0] 1) (= kinds[1] 2) (= kinds[2] 3))
        4
        0)
    0))

(defn- column-batch-append-string-copy! [handle: rawptr, column: int, text: string] -> bool
  (let [owned (vev.string-owned text)]
    (abi-generic-column-batch-append-string-owned handle column owned)))

(defn- column-batch-append-mixed-string-copy! [handle: rawptr, column: int, kind: i32, text: string] -> bool
  (let [owned (vev.string-owned text)]
    (abi-generic-column-batch-append-mixed-string-owned handle column kind owned)))

(defn- column-batch-append-value-copy! [handle: rawptr, column: int, value: vev.Value] -> bool
  (let [owned (vev.value-owned value)]
    (abi-generic-column-batch-append-value-owned handle column owned)))

(defn- append-entity-string-int-triple-copy! [triples: ^vev.Entity-String-Int-Triples, entity: u64, text: string, value: i64]
  (let [owned (vev.string-owned text)]
    (vev.append-entity-string-int-triple! triples entity owned value)))

(defn- column-batch-append-generic-value! [handle: rawptr, column: int, kind: int, value: vev.Value] -> bool
  (case kind
    1
      (if (= value.kind .Entity)
        (abi-generic-column-batch-append-entity handle column value.entity)
        false)
    3
      (if (= value.kind .Int)
        (abi-generic-column-batch-append-int handle column value.int-value)
        false)
    5
      (if (= value.kind .Bool)
        (abi-generic-column-batch-append-bool handle column value.bool-value)
        false)
    6
      (if (= value.kind .Float)
        (abi-generic-column-batch-append-float handle column value.float-value)
        false)
    2
      (if (column-batch-text-like-value? value)
        (column-batch-append-string-copy! handle column value.text)
        false)
    4
      (case value.kind
        .Nil (abi-generic-column-batch-append-mixed-nil handle column)
        .Entity (abi-generic-column-batch-append-mixed-entity handle column value.entity)
        .Int (abi-generic-column-batch-append-mixed-int handle column value.int-value)
        .Float (abi-generic-column-batch-append-mixed-float handle column value.float-value)
        .Bool (abi-generic-column-batch-append-mixed-bool handle column value.bool-value)
        .String (column-batch-append-mixed-string-copy! handle column 2 value.text)
        .Keyword (column-batch-append-mixed-string-copy! handle column 6 value.text)
        .Symbol (column-batch-append-mixed-string-copy! handle column 7 value.text)
        .Uuid (column-batch-append-mixed-string-copy! handle column 10 value.text)
        false)
    7
      (column-batch-append-value-copy! handle column value)
    false))

(defn- column-batch-append-generic-relation-cell! [handle: rawptr, out-column: int, kind: int, relation-column: vev.Relation-Column, row: int] -> bool
  (case kind
    1
      (if (= relation-column.kind .Entity)
        (abi-generic-column-batch-append-entity handle out-column relation-column.entities[row])
        false)
    3
      (if (= relation-column.kind .Int)
        (abi-generic-column-batch-append-int handle out-column relation-column.ints[row])
        false)
    5
      (if (= relation-column.kind .Bool)
        (abi-generic-column-batch-append-bool handle out-column relation-column.bools[row])
        false)
    6
      (if (= relation-column.kind .Float)
        (abi-generic-column-batch-append-float handle out-column relation-column.floats[row])
        false)
    2
      (case relation-column.kind
        .String (column-batch-append-string-copy! handle out-column relation-column.texts[row])
        .Keyword (column-batch-append-string-copy! handle out-column relation-column.texts[row])
        .Symbol (column-batch-append-string-copy! handle out-column relation-column.texts[row])
        .Uuid (column-batch-append-string-copy! handle out-column relation-column.texts[row])
        false)
    4
      (let [[value value-ok] (vev.typed-relation-column-value relation-column row)]
        (and value-ok (column-batch-append-generic-value! handle out-column kind value)))
    7
      (let [[value value-ok] (vev.typed-relation-column-value relation-column row)]
        (and value-ok (column-batch-append-generic-value! handle out-column kind value)))
    false))

(defn- column-batch-from-typed-materialized-batch [batch: vev.Typed-Materialized-Batch] -> Vev-Column-Batch
  (let [column-count (count batch.columns)
        column-kinds (make [dynamic]int 0 column-count)]
    (when (not batch.ok)
      (delete column-kinds)
      (return (Vev-Column-Batch nil)))
    (for [output-column (arr.range 0 column-count)]
      (let [column batch.columns[output-column]
            column-kind (if batch.value-columns[output-column]
                          7
                          (if column.has-kind (column-kind-for-relation-column-kind column.kind) 0))]
        (when (= column-kind 0)
          (delete column-kinds)
          (return (Vev-Column-Batch nil)))
        (arr.push! column-kinds column-kind)))
    (let [legacy-kind (column-batch-legacy-kind-for-column-kinds (slice column-kinds 0))
          handle (abi-alloc-generic-column-batch column-kinds batch.rows)]
      (delete column-kinds)
      (when (= handle nil)
        (return (Vev-Column-Batch nil)))
      (for [row (arr.range 0 batch.rows)]
        (for [output-column (arr.range 0 column-count)]
          (let [column-kind (abi-generic-column-batch-column-kind handle output-column)]
            (when (not (column-batch-append-generic-relation-cell! handle output-column column-kind batch.columns[output-column] row))
              (abi-free-generic-column-batch handle)
              (return (Vev-Column-Batch nil))))))
      (Vev-Column-Batch (abi-alloc-column-batch-generic legacy-kind handle)))))

(defn- column-batch-kind-for-typed-flat-column-kind [kind: vev.Relation-Column-Kind] -> int
  (if (= kind .Mixed)
    7
    (column-kind-for-relation-column-kind kind)))

(defn- column-batch-from-typed-relation-generic [query: vev.Query, rel: vev.Query-Relation, resolved: vev.Resolved-Typed-Flat-Materialization] -> Vev-Column-Batch
  (discard query)
  (when (not resolved.ok)
    (return (Vev-Column-Batch nil)))
  (let [column-count (vev.resolved-typed-flat-materialization-column-count resolved)
        column-kinds (make [dynamic]int 0 column-count)]
    (for [output-column (arr.range 0 column-count)]
      (let [[kind kind-ok] (vev.resolved-typed-flat-materialization-output-column-kind rel resolved output-column)
            column-kind (if kind-ok (column-batch-kind-for-typed-flat-column-kind kind) 0)]
        (when (= column-kind 0)
          (delete column-kinds)
          (return (Vev-Column-Batch nil)))
        (arr.push! column-kinds column-kind)))
    (let [legacy-kind (column-batch-legacy-kind-for-column-kinds (slice column-kinds 0))
          capacity (vev.resolved-typed-flat-materialization-row-count resolved)
          handle (abi-alloc-generic-column-batch column-kinds capacity)
          cursor (vev.typed-flat-materialization-cursor resolved)
          rows 0]
      (delete column-kinds)
      (when (= handle nil)
        (vev.delete-typed-flat-materialization-cursor cursor)
        (return (Vev-Column-Batch nil)))
      (while true
        (let [[row found row-ok] (vev.typed-flat-materialization-cursor-next! (addr cursor) rel resolved)]
          (when (not row-ok)
            (vev.delete-typed-flat-materialization-cursor cursor)
            (abi-free-generic-column-batch handle)
            (return (Vev-Column-Batch nil)))
          (when (not found)
            (break))
          (for [output-column (arr.range 0 column-count)]
            (let [[source-column source-column-ok] (vev.resolved-typed-flat-materialization-output-column-index resolved output-column)]
              (when (or (not source-column-ok)
                        (not (column-batch-append-generic-relation-cell! handle output-column (abi-generic-column-batch-column-kind handle output-column) rel.typed-columns[source-column] row)))
                (vev.delete-typed-flat-materialization-cursor cursor)
                (abi-free-generic-column-batch handle)
                (return (Vev-Column-Batch nil)))))
          (set! rows (+ rows 1))))
      (vev.delete-typed-flat-materialization-cursor cursor)
      (abi-generic-column-batch-set-count handle rows)
      (Vev-Column-Batch (abi-alloc-column-batch-generic legacy-kind handle)))))

(defn- column-batch-from-typed-relation-with-materialization [query: vev.Query, rel: vev.Query-Relation, materialization: vev.Physical-Materialization-Plan] -> Vev-Column-Batch
  (let [resolved (vev.resolve-typed-flat-materialization rel materialization)]
    (when (not resolved.ok)
      (vev.delete-resolved-typed-flat-materialization resolved)
      (return (Vev-Column-Batch nil)))
    (defer (vev.delete-resolved-typed-flat-materialization resolved))
    (column-batch-from-typed-relation-generic query rel resolved)))

(defn- column-batch-from-typed-relation [query: vev.Query, rel: vev.Query-Relation] -> Vev-Column-Batch
  (let [materialization (vev.physical-materialization-plan-from-query query)]
    (defer (vev.delete-physical-materialization-plan materialization))
    (column-batch-from-typed-relation-with-materialization query rel materialization)))

(defn- column-batch-from-typed-aggregate-relation [query: vev.Query, rel: vev.Query-Relation] -> Vev-Column-Batch
  (when (= (count query.aggregates) 0)
    (return (Vev-Column-Batch nil)))
  (let [[aggregate-rel aggregate-ok] (vev.aggregate-query-relation-for-typed-relation query rel)]
    (when (not aggregate-ok)
      (vev.delete-query-relation aggregate-rel)
      (return (Vev-Column-Batch nil)))
    (let [plan (vev.typed-flat-result-plan-for-output-relation aggregate-rel)]
      (when (not plan.ok)
        (vev.delete-typed-flat-result-plan plan)
        (vev.delete-query-relation aggregate-rel)
        (return (Vev-Column-Batch nil)))
      (let [resolved (vev.Resolved-Typed-Flat-Materialization {ok: true
                                                               plan: plan
                                                               trust-unique-bindings: true})
            out (column-batch-from-typed-relation-generic query aggregate-rel resolved)]
        (vev.delete-resolved-typed-flat-materialization resolved)
        (vev.delete-query-relation aggregate-rel)
        out))))

(defn- column-batch-from-typed-aggregate-value-rows [query: vev.Query, rel: vev.Query-Relation] -> Vev-Column-Batch
  (when (= (count query.aggregates) 0)
    (return (Vev-Column-Batch nil)))
  (let [batch (vev.materialize-typed-aggregate-value-batch query rel)]
    (when (not batch.ok)
      (vev.delete-typed-materialized-batch batch)
      (return (Vev-Column-Batch nil)))
    (defer (vev.delete-typed-materialized-batch batch))
    (column-batch-from-typed-materialized-batch batch)))

(defn- column-batch-from-source-physical-materialize-op [source: vev.DB-Read-Source, sources: []vev.DB-Read-Named-Source, query: vev.Query, inputs: []vev.Query-Input, rel: vev.Query-Relation] -> Vev-Column-Batch
  (let [plan (vev.physical-plan-from-query query)]
    (defer (vev.delete-physical-plan plan))
    (when (not plan.has-materialize)
      (return (Vev-Column-Batch nil)))
    (let [[batch batch-ok _] (vev.db-read-source-apply-physical-materialize-op source sources query inputs rel plan.materialize-op plan.materialization ([]vev.Native-Query-Fn []))]
      (when (not batch-ok)
        (vev.delete-typed-materialized-batch batch)
        (return (Vev-Column-Batch nil)))
      (defer (vev.delete-typed-materialized-batch batch))
      (column-batch-from-typed-materialized-batch batch))))

(defn- column-batch-from-relation-engine [db: vev.DB, query: vev.Query, inputs: []vev.Query-Input] -> Vev-Column-Batch
  (when (not (vev.query-relation-engine-eligible? query ([]vev.DB-Source [])))
    (return (Vev-Column-Batch nil)))
  (let [stats (vev.query-stats-empty)
        rel (vev.relation-engine-relation-profiled db query inputs ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr stats))
        db-alias db
        source (vev.resident-db-read-source (addr db-alias))
        materialize-out (column-batch-from-source-physical-materialize-op source ([]vev.DB-Read-Named-Source []) query inputs rel)]
    (when (not (= (rawptr materialize-out) nil))
      (vev.delete-query-relation rel)
      (return materialize-out))
    (let [aggregate-out (column-batch-from-typed-aggregate-relation query rel)]
      (when (not (= (rawptr aggregate-out) nil))
        (vev.delete-query-relation rel)
        (return aggregate-out))
      (let [aggregate-value-out (column-batch-from-typed-aggregate-value-rows query rel)]
        (when (not (= (rawptr aggregate-value-out) nil))
          (vev.delete-query-relation rel)
          (return aggregate-value-out)))
      (let [out (column-batch-from-typed-relation query rel)]
        (vev.delete-query-relation rel)
        out))))

(defn- column-batch-from-source-relation-engine [source: vev.DB-Read-Source, sources: []vev.DB-Read-Named-Source, query: vev.Query, inputs: []vev.Query-Input] -> Vev-Column-Batch
  (let [[rel _ used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source sources query inputs ([]vev.Native-Query-Fn []))]
    (when (not used)
      (vev.delete-query-relation rel)
      (return (Vev-Column-Batch nil)))
    (let [materialize-out (column-batch-from-source-physical-materialize-op source sources query inputs rel)]
      (when (not (= (rawptr materialize-out) nil))
        (vev.delete-query-relation rel)
        (return materialize-out)))
    (let [aggregate-out (column-batch-from-typed-aggregate-relation query rel)]
      (when (not (= (rawptr aggregate-out) nil))
        (vev.delete-query-relation rel)
        (return aggregate-out))
      (let [aggregate-value-out (column-batch-from-typed-aggregate-value-rows query rel)]
        (when (not (= (rawptr aggregate-value-out) nil))
          (vev.delete-query-relation rel)
          (return aggregate-value-out)))
      (let [out (column-batch-from-typed-relation query rel)]
        (vev.delete-query-relation rel)
        out))))

(defn- column-batch-from-query-inputs [db: vev.DB, query: vev.Query, inputs: []vev.Query-Input] -> Vev-Column-Batch
  (let [relation-out (column-batch-from-relation-engine db query inputs)]
    (when (not (= (rawptr relation-out) nil))
      (return relation-out)))
  (let [[triples triple-ok] (vev.q-query-entity-string-int-triples db query inputs)]
    (if triple-ok
      (return (Vev-Column-Batch (abi-alloc-column-batch 4 (abi-alloc-entity-string-int-triples triples))))
      (vev.delete-entity-string-int-triples triples)))
  (let [[pairs pair-ok] (vev.q-query-entity-int-pair-columns db query inputs)]
    (if pair-ok
      (return (Vev-Column-Batch (abi-alloc-column-batch 3 (abi-alloc-entity-int-pairs pairs))))
      (vev.delete-entity-int-pair-columns pairs)))
  (let [[entities entity-ok] (vev.q-query-entity-column db query inputs)]
    (if entity-ok
      (return (Vev-Column-Batch (abi-alloc-column-batch 1 (abi-alloc-u64-array entities))))
      (delete entities)))
  (let [[strings string-ok] (vev.q-query-string-column db query inputs)]
    (if string-ok
      (return (Vev-Column-Batch (abi-alloc-column-batch 2 (abi-alloc-string-array strings))))
      (delete strings)))
  (let [db-alias db
        source (vev.resident-db-read-source (addr db-alias))
        result (vev.db-read-source-q-query-with-inputs source query inputs)
        out (column-batch-from-result result)]
    (vev.delete-result-set-shallow result)
    out))

(defn- column-batch-from-source-query-inputs [source: vev.DB-Read-Source, sources: []vev.DB-Read-Named-Source, query: vev.Query, inputs: []vev.Query-Input] -> Vev-Column-Batch
  (let [relation-out (column-batch-from-source-relation-engine source sources query inputs)]
    (when (not (= (rawptr relation-out) nil))
      (return relation-out)))
  (when (= (count sources) 0)
    (let [[triples triple-ok _] (vev.q-db-read-source-entity-string-int-triples source query inputs)]
      (if triple-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 4 (abi-alloc-entity-string-int-triples triples))))
        (vev.delete-entity-string-int-triples triples)))
    (let [[string-int-pairs string-int-ok _] (vev.q-db-read-source-string-int-pair-columns source query inputs)]
      (if string-int-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 7 (abi-alloc-entity-string-int-triples string-int-pairs))))
        (vev.delete-entity-string-int-triples string-int-pairs)))
    (let [[string-string-pairs string-string-ok _] (vev.q-db-read-source-string-string-pair-columns source query inputs)]
      (if string-string-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 8 (abi-alloc-string-string-pairs string-string-pairs))))
        (vev.delete-string-string-pair-columns string-string-pairs)))
    (let [[range-pairs range-pair-ok _] (vev.q-db-read-source-entity-int-range-pair-columns source query inputs)]
      (if range-pair-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 3 (abi-alloc-entity-int-pairs range-pairs))))
        (vev.delete-entity-int-pair-columns range-pairs)))
    (let [[string-pairs string-pair-ok _] (vev.q-db-read-source-entity-string-pair-columns source query inputs)]
      (if string-pair-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 6 (abi-alloc-entity-string-pairs string-pairs))))
        (vev.delete-entity-string-pair-columns string-pairs)))
    (let [[pairs pair-ok _] (vev.q-db-read-source-entity-int-pair-columns source query inputs)]
      (if pair-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 3 (abi-alloc-entity-int-pairs pairs))))
        (vev.delete-entity-int-pair-columns pairs)))
    (let [[entities entity-ok _] (vev.q-db-read-source-entity-column source query inputs)]
      (if entity-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 1 (abi-alloc-u64-array entities))))
        (delete entities)))
    (let [[ints int-ok _] (vev.q-db-read-source-int-column source query inputs)]
      (if int-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 5 (abi-alloc-i64-array ints))))
        (delete ints)))
    (let [[strings string-ok _] (vev.q-db-read-source-string-column source query inputs)]
      (if string-ok
        (return (Vev-Column-Batch (abi-alloc-column-batch 2 (abi-alloc-string-array strings))))
        (delete strings))))
  (Vev-Column-Batch nil))

(defn- column-batch-entity-id [value: vev.Value] -> [entity: u64, ok: bool]
  (case value.kind
    .Entity
      (return value.entity true)
    .Int
      (if (>= value.int-value 0)
        (return (u64 value.int-value) true)
        (return 0 false))
    (return 0 false)))

(defn- column-kind-for-result-value [value: vev.Value] -> int
  (case value.kind
    .Entity 1
    .Int 3
    .Bool 5
    .Float 6
    .String 2
    .Keyword 2
    .Symbol 2
    .Uuid 2
    .Vector 7
    .Map 7
    0))

(defn- column-kind-merge-result-value [current: int, value: vev.Value] -> int
  (let [next (column-kind-for-result-value value)]
    (when (= next 0)
      (if (= value.kind .Nil)
        (if (= current 0)
          (return 4)
          (return current))
        (return 0)))
    (when (= current 0)
      (return next))
    (when (= current next)
      (return current))
    (when (or (= current 7) (= next 7))
      (return 7))
    (return 4)))

(defn- column-kinds-for-result-rows [rows: []vev.Result-Row, width: int] -> [kinds: [dynamic]int, ok: bool]
  (let [column-kinds (make [dynamic]int 0 width)]
    (for [_ (arr.range 0 width)]
      (arr.push! column-kinds 0))
    (for [row rows]
      (when (or (not (= (count row.values) width))
                (> (count row.pulls) 0))
        (delete column-kinds)
        (return (make [dynamic]int) false))
      (for [value column row.values]
        (let [merged (column-kind-merge-result-value column-kinds[column] value)]
          (when (= merged 0)
            (delete column-kinds)
            (return (make [dynamic]int) false))
          (set! column-kinds[column] merged))))
    (for [kind index column-kinds]
      (when (= kind 0)
        (set! column-kinds[index] 4)))
    (return column-kinds true)))

(defn- column-batch-from-result-generic [result: vev.Result-Set, width: int] -> Vev-Column-Batch
  (when (<= width 0)
    (return (Vev-Column-Batch nil)))
  (let [[column-kinds kinds-ok] (column-kinds-for-result-rows (slice result.rows 0) width)]
    (when (not kinds-ok)
      (delete column-kinds)
      (return (Vev-Column-Batch nil)))
    (let [handle (abi-alloc-generic-column-batch column-kinds (count result.rows))]
      (delete column-kinds)
      (when (= handle nil)
        (return (Vev-Column-Batch nil)))
      (for [row result.rows]
        (for [value column row.values]
          (let [kind (abi-generic-column-batch-column-kind handle column)]
            (when (not (column-batch-append-generic-value! handle column kind value))
              (abi-free-generic-column-batch handle)
              (return (Vev-Column-Batch nil))))))
      (Vev-Column-Batch (abi-alloc-column-batch-generic 0 handle)))))

(defn- column-batch-from-result [result: vev.Result-Set] -> Vev-Column-Batch
  (when (not result.ok)
    (return (Vev-Column-Batch nil)))
  (when (= (count result.rows) 0)
    (return (Vev-Column-Batch nil)))
  (let [width (count result.rows[0].values)]
    (when (= width 1)
      (let [entity-values (make [dynamic]u64 0 (count result.rows))
            entity-ok true]
        (for [row result.rows]
          (let [entity: u64 0
                entity-value-ok false]
            (when (= (count row.values) 1)
              (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
                (set! entity resolved)
                (set! entity-value-ok resolved-ok)))
            (if (and entity-value-ok
                     (= (count row.pulls) 0))
              (arr.push! entity-values entity)
              (set! entity-ok false))))
        (when entity-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 1 (abi-alloc-u64-array entity-values)))))
        (delete entity-values))
      (let [string-values (make [dynamic]string 0 (count result.rows))
            string-ok true]
        (for [row result.rows]
          (if (and (= (count row.values) 1)
                   (= (count row.pulls) 0)
                   (or (= row.values[0].kind .String)
                       (= row.values[0].kind .Keyword)
                       (= row.values[0].kind .Symbol)
                       (= row.values[0].kind .Uuid)))
            (arr.push! string-values (string-owned row.values[0].text))
            (set! string-ok false)))
        (when string-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 2 (abi-alloc-string-array string-values)))))
        (for [text string-values]
          (delete text))
        (delete string-values)))
    (when (= width 2)
      (let [string-int-pairs (vev.empty-entity-string-int-triples)
            string-int-ok true]
        (for [row result.rows]
          (if (and (= (count row.values) 2)
                   (= (count row.pulls) 0)
                   (or (= row.values[0].kind .String)
                       (= row.values[0].kind .Keyword)
                       (= row.values[0].kind .Symbol)
                       (= row.values[0].kind .Uuid))
                   (= row.values[1].kind .Int))
            (vev.append-owned-entity-string-int-triple! (addr string-int-pairs) 0 row.values[0].text row.values[1].int-value)
            (set! string-int-ok false)))
        (if string-int-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 7 (abi-alloc-entity-string-int-triples string-int-pairs))))
          (vev.delete-entity-string-int-triples string-int-pairs))))
    (when (= width 2)
      (let [string-string-pairs (vev.empty-string-string-pair-columns)
            string-string-ok true]
        (for [row result.rows]
          (if (and (= (count row.values) 2)
                   (= (count row.pulls) 0)
                   (or (= row.values[0].kind .String)
                       (= row.values[0].kind .Keyword)
                       (= row.values[0].kind .Symbol)
                       (= row.values[0].kind .Uuid))
                   (or (= row.values[1].kind .String)
                       (= row.values[1].kind .Keyword)
                       (= row.values[1].kind .Symbol)
                       (= row.values[1].kind .Uuid)))
            (vev.append-owned-string-string-pair-column! (addr string-string-pairs) row.values[0].text row.values[1].text)
            (set! string-string-ok false)))
        (if string-string-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 8 (abi-alloc-string-string-pairs string-string-pairs))))
          (vev.delete-string-string-pair-columns string-string-pairs))))
    (when (= width 2)
      (let [pairs (vev.empty-entity-int-pair-columns)
            pair-ok true]
        (for [row result.rows]
          (let [entity: u64 0
                entity-ok false]
            (when (= (count row.values) 2)
              (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
                (set! entity resolved)
                (set! entity-ok resolved-ok)))
            (if (and entity-ok
                     (= (count row.pulls) 0)
                     (= row.values[1].kind .Int))
              (vev.append-entity-int-pair-column! (addr pairs) entity row.values[1].int-value)
              (set! pair-ok false))))
        (if pair-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 3 (abi-alloc-entity-int-pairs pairs))))
          (vev.delete-entity-int-pair-columns pairs))))
    (when (= width 2)
      (let [pairs (vev.empty-entity-string-pair-columns)
            pair-ok true]
        (for [row result.rows]
          (let [entity: u64 0
                entity-ok false]
            (when (= (count row.values) 2)
              (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
                (set! entity resolved)
                (set! entity-ok resolved-ok)))
            (if (and entity-ok
                     (= (count row.pulls) 0)
                     (or (= row.values[1].kind .String)
                         (= row.values[1].kind .Keyword)
                         (= row.values[1].kind .Symbol)
                         (= row.values[1].kind .Uuid)))
              (vev.append-owned-entity-string-pair-column! (addr pairs) entity row.values[1].text)
              (set! pair-ok false))))
        (if pair-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 6 (abi-alloc-entity-string-pairs pairs))))
          (vev.delete-entity-string-pair-columns pairs))))
    (when (= width 3)
      (let [triples (vev.empty-entity-string-int-triples)
            triple-ok true]
        (for [row result.rows]
          (let [entity: u64 0
                entity-ok false]
            (when (= (count row.values) 3)
              (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
                (set! entity resolved)
                (set! entity-ok resolved-ok)))
            (if (and entity-ok
                     (= (count row.pulls) 0)
                     (or (= row.values[1].kind .String)
                         (= row.values[1].kind .Keyword)
                         (= row.values[1].kind .Symbol)
                         (= row.values[1].kind .Uuid))
                     (= row.values[2].kind .Int))
              (append-entity-string-int-triple-copy! (addr triples) entity row.values[1].text row.values[2].int-value)
              (set! triple-ok false))))
        (if triple-ok
          (return (Vev-Column-Batch (abi-alloc-column-batch 4 (abi-alloc-entity-string-int-triples-with-ownership triples true))))
          (do
            (for [text triples.strings]
              (delete text))
            (vev.delete-entity-string-int-triples triples)))))
    (let [generic-out (column-batch-from-result-generic result width)]
      (when (not (= (rawptr generic-out) nil))
        (return generic-out))))
  (Vev-Column-Batch nil))

(defn- entity-array-from-result [result: vev.Result-Set] -> Vev-U64-Array
  (when (not result.ok)
    (return (Vev-U64-Array nil)))
  (let [entities (make [dynamic]u64 0 (count result.rows))
        ok true]
    (for [row result.rows]
      (let [entity: u64 0
            entity-ok false]
        (when (= (count row.values) 1)
          (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
            (set! entity resolved)
            (set! entity-ok resolved-ok)))
        (if (and entity-ok
                 (= (count row.pulls) 0))
          (arr.push! entities entity)
          (set! ok false))))
    (if ok
      (Vev-U64-Array (abi-alloc-u64-array entities))
      (do
        (delete entities)
        (Vev-U64-Array nil)))))

(defn- string-array-from-result [result: vev.Result-Set] -> Vev-String-Array
  (when (not result.ok)
    (return (Vev-String-Array nil)))
  (let [values (make [dynamic]string 0 (count result.rows))
        ok true]
    (for [row result.rows]
      (if (and (= (count row.values) 1)
               (= (count row.pulls) 0)
               (or (= row.values[0].kind .String)
                   (= row.values[0].kind .Keyword)
                   (= row.values[0].kind .Symbol)
                   (= row.values[0].kind .Uuid)))
        (arr.push! values (string-owned row.values[0].text))
        (set! ok false)))
    (if ok
      (Vev-String-Array (abi-alloc-string-array values))
      (do
        (for [text values]
          (delete text))
        (delete values)
        (Vev-String-Array nil)))))

(defn- entity-int-pairs-from-result [result: vev.Result-Set] -> Vev-Entity-Int-Pairs
  (when (not result.ok)
    (return (Vev-Entity-Int-Pairs nil)))
  (let [pairs (vev.empty-entity-int-pair-columns)
        ok true]
    (for [row result.rows]
      (let [entity: u64 0
            entity-ok false]
        (when (= (count row.values) 2)
          (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
            (set! entity resolved)
            (set! entity-ok resolved-ok)))
        (if (and entity-ok
                 (= (count row.pulls) 0)
                 (= row.values[1].kind .Int))
          (vev.append-entity-int-pair-column! (addr pairs) entity row.values[1].int-value)
          (set! ok false))))
    (if ok
      (Vev-Entity-Int-Pairs (abi-alloc-entity-int-pairs pairs))
      (do
        (vev.delete-entity-int-pair-columns pairs)
        (Vev-Entity-Int-Pairs nil)))))

(defn- entity-string-int-triples-from-result [result: vev.Result-Set] -> Vev-Entity-String-Int-Triples
  (when (not result.ok)
    (return (Vev-Entity-String-Int-Triples nil)))
  (let [triples (vev.empty-entity-string-int-triples)
        ok true]
    (for [row result.rows]
      (let [entity: u64 0
            entity-ok false]
        (when (= (count row.values) 3)
          (let [[resolved resolved-ok] (column-batch-entity-id row.values[0])]
            (set! entity resolved)
            (set! entity-ok resolved-ok)))
        (if (and entity-ok
                 (= (count row.pulls) 0)
                 (or (= row.values[1].kind .String)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].kind .Symbol)
                     (= row.values[1].kind .Uuid))
                 (= row.values[2].kind .Int))
          (vev.append-owned-entity-string-int-triple! (addr triples) entity row.values[1].text row.values[2].int-value)
          (set! ok false))))
    (if ok
      (Vev-Entity-String-Int-Triples (abi-alloc-entity-string-int-triples triples))
      (do
        (vev.delete-entity-string-int-triples triples)
        (Vev-Entity-String-Int-Triples nil)))))

(defn- value-ptr [value: Vev-Value] -> ^vev.Value
  (abi-value-ptr (rawptr value)))

(defn- tx-report-value-ptr [report: Vev-Tx-Report] -> ^vev.Value
  (abi-tx-report-value-ptr (rawptr report)))

(defn- tx-report-has-store-dbs? [report: Vev-Tx-Report] -> bool
  (abi-tx-report-has-store-dbs (rawptr report)))

(defn- tx-report-db-before-ptr [report: Vev-Tx-Report] -> ^vev.Store-DB
  (abi-tx-report-db-before-ptr (rawptr report)))

(defn- tx-report-db-after-ptr [report: Vev-Tx-Report] -> ^vev.Store-DB
  (abi-tx-report-db-after-ptr (rawptr report)))

(defn- tx-builder-data-ptr [builder: Vev-Tx-Builder] -> ^[dynamic]vev.Tx-Data
  (abi-tx-builder-data-ptr (rawptr builder)))

(defn- rawptr-at [values: rawptr, index: int] -> rawptr
  (abi-rawptr-at values index))

(defn- tx-fn-registry-entries-ptr [registry: Vev-Tx-Fn-Registry] -> ^[dynamic]vev.Tx-Fn-String
  (abi-tx-fn-registry-entries-ptr (rawptr registry)))

(defn- tx-fn-registry-source-entries-ptr [registry: Vev-Tx-Fn-Registry] -> ^[dynamic]vev.Tx-Fn-Source-String
  (abi-tx-fn-registry-source-entries-ptr (rawptr registry)))

(defn- tx-fn-registry-slots-ptr [registry: Vev-Tx-Fn-Registry] -> ^[dynamic]int
  (abi-tx-fn-registry-slots-ptr (rawptr registry)))

(defn- query-fn-registry-entries-ptr [registry: Vev-Query-Fn-Registry] -> ^[dynamic]vev.Native-Query-Fn
  (abi-query-fn-registry-entries-ptr (rawptr registry)))

(defn- query-fn-registry-predicate-slots-ptr [registry: Vev-Query-Fn-Registry] -> ^[dynamic]int
  (abi-query-fn-registry-predicate-slots-ptr (rawptr registry)))

(defn- query-fn-registry-aggregate-slots-ptr [registry: Vev-Query-Fn-Registry] -> ^[dynamic]int
  (abi-query-fn-registry-aggregate-slots-ptr (rawptr registry)))

(defn- value-handle-value-ptr [handle: Vev-Value-Handle] -> ^vev.Value
  (abi-value-handle-value-ptr (rawptr handle)))

(defn- stmt-query [stmt: Vev-Stmt] -> Vev-Prepared-Query
  (Vev-Prepared-Query (abi-stmt-query (rawptr stmt))))

(defn- stmt-inputs-ptr [stmt: Vev-Stmt] -> ^[dynamic]vev.Query-Input
  (abi-stmt-inputs-ptr (rawptr stmt)))

(defn- stmt-pull-pattern-sources-ptr [stmt: Vev-Stmt] -> ^[dynamic]string
  (abi-stmt-pull-pattern-sources-ptr (rawptr stmt)))

(defn- stmt-sources-ptr [stmt: Vev-Stmt] -> ^[dynamic]vev.DB-Read-Named-Source
  (abi-stmt-sources-ptr (rawptr stmt)))

(defn- stmt-source-handles-ptr [stmt: Vev-Stmt] -> ^[dynamic]rawptr
  (abi-stmt-source-handles-ptr (rawptr stmt)))

(defn- stmt-error-ptr [stmt: Vev-Stmt] -> ^string
  (abi-stmt-error-ptr (rawptr stmt)))

(defn- text-from-c [text: cstring] -> string
  (let [[out err] (strings.clone_from_cstring text)]
    (if (= err nil)
      out
      "")))

(defn- c-string-owned [text: string] -> cstring
  (let [[out err] (strings.clone_to_cstring text)]
    (if (= err nil)
      out
      (cstring ""))))

(defn- string-owned [text: string] -> string
  (let [[out err] (strings.clone text)]
    (if (= err nil)
      out
      "")))

(defn- alloc-sqlite-conn-copy [store: vev.SQLite-Conn, ok: bool, error: string] -> rawptr
  (let [owned-error (string-owned error)]
    (abi-alloc-sqlite-conn store ok owned-error)))

(defn- value-owned [value: vev.Value] -> vev.Value
  (case value.kind
    .String
      (vev.value-string (string-owned value.text))
    .Keyword
      (vev.value-keyword (string-owned value.text))
    .Symbol
      (vev.value-symbol (string-owned value.text))
    .Uuid
      (vev.value-uuid (string-owned value.text))
    .Vector
      (let [items (make [dynamic]vev.Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (vev.Value {kind: .Vector items: items}))
    .Map
      (let [items (make [dynamic]vev.Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (vev.Value {kind: .Map items: items}))
    value))

(defn- delete-pull-spec-containers [specs: []vev.Pull-Spec]
  (for [spec specs]
    (delete-pull-spec-containers (slice spec.pattern 0))
    (delete spec.pattern)))

(defn- tx-report-handle-from-value [value: vev.Value] -> Vev-Tx-Report
  (Vev-Tx-Report (abi-alloc-tx-report value)))

(defn- tx-report-handle-from-value-with-dbs [value: vev.Value, before: vev.Store-DB, after: vev.Store-DB] -> Vev-Tx-Report
  (Vev-Tx-Report (abi-alloc-tx-report-with-dbs value before after)))

(defn- tx-report-handle-from-report [report: vev.Tx-Report] -> Vev-Tx-Report
  (tx-report-handle-from-value-with-dbs
    (vev.tx-report-value report)
    (vev.Store-DB {kind: .Resident
                   resident: (vev.clone-db report.db-before)})
    (vev.Store-DB {kind: .Resident
                   resident: (vev.clone-db report.db-after)})))

(defn- tx-report-handle-from-store-report [report: vev.Store-Tx-Report] -> Vev-Tx-Report
  (tx-report-handle-from-value-with-dbs
    (vev.store-tx-report-value report)
    (vev.retain-store-db report.db-before)
    (vev.retain-store-db report.db-after)))

(defn- tx-report-handle-free [report: Vev-Tx-Report]
  (when (= (rawptr report) nil)
    (return))
  (let [ptr (tx-report-value-ptr report)]
    (vev.delete-owned-value ptr^)
    (when (tx-report-has-store-dbs? report)
      (vev.close-store-db! (tx-report-db-before-ptr report))
      (vev.close-store-db! (tx-report-db-after-ptr report)))
    (abi-free-tx-report (rawptr report))))

(defn- tx-report-array-reports-ptr [array: Vev-Tx-Report-Array] -> ^[dynamic]rawptr
  (abi-tx-report-array-reports-ptr (rawptr array)))

(defn- tx-report-array-handle-from-store-reports [reports: []vev.Store-Tx-Report] -> Vev-Tx-Report-Array
  (let [out (Vev-Tx-Report-Array (abi-alloc-tx-report-array (len reports)))
        handles (tx-report-array-reports-ptr out)]
    (for [report reports]
      (arr.push! handles^ (rawptr (tx-report-handle-from-store-report report))))
    out))

(defn- tx-report-array-handle-from-store-report [report: vev.Store-Tx-Report] -> Vev-Tx-Report-Array
  (let [out (Vev-Tx-Report-Array (abi-alloc-tx-report-array 1))
        handles (tx-report-array-reports-ptr out)]
    (arr.push! handles^ (rawptr (tx-report-handle-from-store-report report)))
    out))

(defn- tx-report-array-handle-free [array: Vev-Tx-Report-Array]
  (when (= (rawptr array) nil)
    (return))
  (let [count (abi-tx-report-array-count (rawptr array))]
    (for [index (arr.range 0 count)]
      (tx-report-handle-free (Vev-Tx-Report (abi-tx-report-array-value (rawptr array) index)))))
  (abi-free-tx-report-array (rawptr array)))

(defn- notify-abi-sqlite-tx-listeners! [conn: Vev-SQLite-Conn, report: vev.Store-Tx-Report]
  (when (not report.ok)
    (return))
  (let [handle (tx-report-handle-from-store-report report)]
    (abi-sqlite-conn-notify-tx-listeners (rawptr conn) (rawptr handle))
    (tx-report-handle-free handle)))

(defn- delete-tx-builder-entry-owned [data: vev.Tx-Data]
  (delete data.a)
  (vev.delete-owned-value data.v))

(defn- tx-builder-free [builder: Vev-Tx-Builder]
  (when (= (rawptr builder) nil)
    (return))
  (let [tx-data (tx-builder-data-ptr builder)]
    (for [data tx-data^]
      (delete-tx-builder-entry-owned data))
    (abi-free-tx-builder (rawptr builder))))

(defn- delete-store-tx-data-groups [groups: [dynamic]vev.Store-Tx-Data-Group]
  (for [group groups]
    (vev.delete-store-tx-data-group group))
  (delete groups))

(defn- store-tx-data-groups-from-builders [builders: rawptr, builder-count: int] -> [groups: [dynamic]vev.Store-Tx-Data-Group, ok: bool, error: string]
  (when (or (= builders nil) (< builder-count 0))
    (return (make [dynamic]vev.Store-Tx-Data-Group) false "transaction builder array was null or count was negative"))
  (let [out (make [dynamic]vev.Store-Tx-Data-Group 0 builder-count)]
    (for [index (arr.range 0 builder-count)]
      (let [builder (Vev-Tx-Builder (rawptr-at builders index))]
        (when (= (rawptr builder) nil)
          (delete-store-tx-data-groups out)
          (return (make [dynamic]vev.Store-Tx-Data-Group) false "transaction builder array contained a null builder"))
        (let [tx-data (tx-builder-data-ptr builder)]
          (arr.push! out (vev.store-tx-data-group (slice tx-data^ 0))))))
    (return out true "")))

(defn- delete-string-array [items: [dynamic]string]
  (for [item items]
    (delete item))
  (delete items))

(defn- strings-from-c-array [items: rawptr, item-count: int] -> [texts: [dynamic]string, ok: bool, error: string]
  (when (< item-count 0)
    (return (make [dynamic]string) false "string array count was negative"))
  (when (= item-count 0)
    (return (make [dynamic]string) true ""))
  (when (= items nil)
    (return (make [dynamic]string) false "string array was null"))
  (let [out (make [dynamic]string 0 item-count)]
    (for [index (arr.range 0 item-count)]
      (let [item (abi-cstring-at items index)]
        (when (= item nil)
          (delete-string-array out)
          (return (make [dynamic]string) false "string array contained a null string"))
        (arr.push! out (text-from-c item))))
    (return out true "")))

(defn- notify-abi-tx-listeners! [conn: Vev-Conn, report: vev.Tx-Report]
  (when (or (= (rawptr conn) nil) (not report.ok))
    (return))
  (let [handle (tx-report-handle-from-report report)]
    (abi-conn-notify-tx-listeners (rawptr conn) (rawptr handle))
    (tx-report-handle-free handle)))

(defn- value-handle-from-value [value: vev.Value] -> Vev-Value-Handle
  (let [owned (value-owned value)]
    (vev.delete-value-containers-shallow value)
    (Vev-Value-Handle (abi-alloc-value-handle owned))))

(defn- value-handle-from-owned-value [value: vev.Value] -> Vev-Value-Handle
  (Vev-Value-Handle (abi-alloc-value-handle value)))

(defn- value-from-edn-text [text: string] -> [value: vev.Value, ok: bool, error: string]
  (let [doc (vev.empty-edn-doc)
        [read-ok read-error] (vev.read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (vev.Value {}) false read-error))
    (let [[parsed parsed-ok parsed-error] (vev.edn-value-from-node doc doc.root)]
      (when (not parsed-ok)
        (delete doc.nodes)
        (return (vev.Value {}) false parsed-error))
      (let [owned (vev.value-owned parsed)]
        (vev.delete-value-containers-shallow parsed)
        (delete doc.nodes)
        (return owned true "")))))

(defn- entity-handle-from-owned-entity [entity: vev.Store-Entity] -> Vev-Entity
  (Vev-Entity (abi-alloc-entity entity)))

(defn- entity-handle-null [] -> Vev-Entity
  (Vev-Entity nil))

(defn- delete-query-input-owned [input: vev.Query-Input]
  (case input.kind
    .Scalar
      (do
        (vev.delete-owned-value input.value)
        (when input.has-lookup-ref
          (delete input.lookup-attr)
          (vev.delete-owned-value input.lookup-value)))
    .Collection
      (do
        (for [value input.values]
          (vev.delete-owned-value value))
        (delete input.values))
    .Relation
      (do
        (for [value input.values]
          (vev.delete-owned-value value))
        (delete input.values))
    .CollectionLookupRefs
      (do
        (for [attr input.lookup-attrs]
          (delete attr))
        (for [value input.lookup-values]
          (vev.delete-owned-value value))
        (delete input.lookup-attrs)
        (delete input.lookup-values))
    .PullPattern
      (do
        (delete-pull-spec-containers (slice input.pattern 0))
        (delete input.pattern))
    (do)))

(defn- stmt-clear-owned [stmt: Vev-Stmt]
  (let [inputs (stmt-inputs-ptr stmt)
        pattern-sources (stmt-pull-pattern-sources-ptr stmt)
        sources (stmt-sources-ptr stmt)
        source-handles (stmt-source-handles-ptr stmt)]
    (for [input inputs^]
      (delete-query-input-owned input))
    (resize inputs 0)
    (for [source pattern-sources^]
      (delete source))
    (resize pattern-sources 0)
    (for [source sources^]
      (delete source.name))
    (resize sources 0)
    (for [handle source-handles^]
      (let [storage (abi-release-db handle)]
        (when (not (= storage nil))
          (let [ptr (abi-store-db-storage-ptr storage)]
            (vev.close-store-db! ptr)
            (abi-free-db-storage storage)))))
    (resize source-handles 0)
    (stmt-clear-error! stmt)))

(defn- stmt-push-scalar! [stmt: Vev-Stmt, value: vev.Value]
  (abi-stmt-push-input (rawptr stmt) (vev.query-input-scalar value)))

(defn- stmt-push-collection! [stmt: Vev-Stmt, values: [dynamic]vev.Value]
  (abi-stmt-push-input (rawptr stmt) (vev.Query-Input {kind: .Collection values: values})))

(defn- stmt-push-relation! [stmt: Vev-Stmt, values: [dynamic]vev.Value, width: int]
  (abi-stmt-push-input (rawptr stmt) (vev.Query-Input {kind: .Relation values: values width: width})))

(defn- stmt-push-lookup-ref! [stmt: Vev-Stmt, attr: string, value: vev.Value]
  (abi-stmt-push-input (rawptr stmt) (vev.query-input-lookup-ref attr value)))

(defn- stmt-push-lookup-ref-collection! [stmt: Vev-Stmt, attrs: [dynamic]string, values: [dynamic]vev.Value]
  (abi-stmt-push-input (rawptr stmt) (vev.query-input-collection-lookup-refs (slice attrs 0) (slice values 0))))

(defn- stmt-push-pull-pattern! [stmt: Vev-Stmt, pattern: [dynamic]vev.Pull-Spec]
  (abi-stmt-push-input (rawptr stmt) (vev.query-input-pull-pattern-owned pattern)))

(defn- stmt-push-db-source! [stmt: Vev-Stmt, name: string, db: Vev-DB] -> bool
  (let [retained (abi-retain-db (rawptr db))
        retained-db (Vev-DB retained)
        store (store-db-ptr retained-db)
        [source source-ok _] (vev.store-db-read-source store)]
    (if source-ok
      (do
        (abi-stmt-push-source (rawptr stmt) (vev.db-read-named-source name source) retained)
        true)
      (do
        (release-db-handle-owned retained-db)
        (delete name)
        false))))

(defn- release-db-handle-owned [db: Vev-DB]
  (let [storage (abi-release-db (rawptr db))]
    (when (not (= storage nil))
      (let [ptr (abi-store-db-storage-ptr storage)]
        (vev.close-store-db! ptr)
        (abi-free-db-storage storage)))))

(defn- tx-fn-args-ptr [args: []vev.Value] -> rawptr
  (if (= (count args) 0)
    nil
    (rawptr (addr args[0]))))

(defn- abi-tx-fn-dispatch [slot: int, db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result
  (let [db-handle (Vev-DB (abi-alloc-db
                            (vev.Store-DB {kind: .Resident
                                           resident: (db-owned db)})))
        result-c (abi-tx-fn-call slot (rawptr db-handle) (count args) (tx-fn-args-ptr args))]
    (defer (release-db-handle-owned db-handle))
    (when (= result-c nil)
      (return (vev.tx-fn-error "transaction callback returned null")))
    (let [result-text (text-from-c result-c)
          tx-data (make [dynamic]vev.Tx-Data) :defer
          [ok error] (vev.parse-tx-text! (addr tx-data) result-text)]
      (when (not ok)
        (delete result-text)
        (return (vev.tx-fn-error error)))
      (let [out (vev.tx-fn-ok (slice tx-data 0))]
        (delete result-text)
        out))))

(defn- abi-tx-fn-slot-0 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 0 db args))
(defn- abi-tx-fn-slot-1 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 1 db args))
(defn- abi-tx-fn-slot-2 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 2 db args))
(defn- abi-tx-fn-slot-3 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 3 db args))
(defn- abi-tx-fn-slot-4 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 4 db args))
(defn- abi-tx-fn-slot-5 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 5 db args))
(defn- abi-tx-fn-slot-6 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 6 db args))
(defn- abi-tx-fn-slot-7 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 7 db args))
(defn- abi-tx-fn-slot-8 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 8 db args))
(defn- abi-tx-fn-slot-9 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 9 db args))
(defn- abi-tx-fn-slot-10 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 10 db args))
(defn- abi-tx-fn-slot-11 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 11 db args))
(defn- abi-tx-fn-slot-12 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 12 db args))
(defn- abi-tx-fn-slot-13 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 13 db args))
(defn- abi-tx-fn-slot-14 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 14 db args))
(defn- abi-tx-fn-slot-15 [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result (abi-tx-fn-dispatch 15 db args))

(defn- abi-tx-fn-source-dispatch [slot: int, source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result
  (let [[snapshot snapshot-ok _] (vev.store-db-from-read-source source)]
    (when snapshot-ok
      (let [db-handle (Vev-DB (abi-alloc-db snapshot))
            result-c (abi-tx-fn-call slot (rawptr db-handle) (count args) (tx-fn-args-ptr args))]
        (defer (release-db-handle-owned db-handle))
        (when (= result-c nil)
          (return (vev.tx-fn-source-error "transaction callback returned null")))
        (let [result-text (text-from-c result-c)
              tx-data (make [dynamic]vev.Tx-Data) :defer
              [ok error] (vev.parse-tx-text! (addr tx-data) result-text)]
          (when (not ok)
            (delete result-text)
            (return (vev.tx-fn-source-error error)))
          (let [out (vev.tx-fn-source-ok (slice tx-data 0))]
            (delete result-text)
            (return out))))))
  (vev.tx-fn-source-error "transaction callback DB source cannot be exposed as a retained Vev DB handle"))

(defn- abi-tx-fn-source-slot-0 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 0 source args))
(defn- abi-tx-fn-source-slot-1 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 1 source args))
(defn- abi-tx-fn-source-slot-2 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 2 source args))
(defn- abi-tx-fn-source-slot-3 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 3 source args))
(defn- abi-tx-fn-source-slot-4 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 4 source args))
(defn- abi-tx-fn-source-slot-5 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 5 source args))
(defn- abi-tx-fn-source-slot-6 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 6 source args))
(defn- abi-tx-fn-source-slot-7 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 7 source args))
(defn- abi-tx-fn-source-slot-8 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 8 source args))
(defn- abi-tx-fn-source-slot-9 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 9 source args))
(defn- abi-tx-fn-source-slot-10 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 10 source args))
(defn- abi-tx-fn-source-slot-11 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 11 source args))
(defn- abi-tx-fn-source-slot-12 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 12 source args))
(defn- abi-tx-fn-source-slot-13 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 13 source args))
(defn- abi-tx-fn-source-slot-14 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 14 source args))
(defn- abi-tx-fn-source-slot-15 [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result (abi-tx-fn-source-dispatch 15 source args))

(defn- tx-fn-slot-entry [ident: string, slot: int] -> vev.Tx-Fn-String
  (cond
    (= slot 0) (vev.tx-fn-values ident abi-tx-fn-slot-0)
    (= slot 1) (vev.tx-fn-values ident abi-tx-fn-slot-1)
    (= slot 2) (vev.tx-fn-values ident abi-tx-fn-slot-2)
    (= slot 3) (vev.tx-fn-values ident abi-tx-fn-slot-3)
    (= slot 4) (vev.tx-fn-values ident abi-tx-fn-slot-4)
    (= slot 5) (vev.tx-fn-values ident abi-tx-fn-slot-5)
    (= slot 6) (vev.tx-fn-values ident abi-tx-fn-slot-6)
    (= slot 7) (vev.tx-fn-values ident abi-tx-fn-slot-7)
    (= slot 8) (vev.tx-fn-values ident abi-tx-fn-slot-8)
    (= slot 9) (vev.tx-fn-values ident abi-tx-fn-slot-9)
    (= slot 10) (vev.tx-fn-values ident abi-tx-fn-slot-10)
    (= slot 11) (vev.tx-fn-values ident abi-tx-fn-slot-11)
    (= slot 12) (vev.tx-fn-values ident abi-tx-fn-slot-12)
    (= slot 13) (vev.tx-fn-values ident abi-tx-fn-slot-13)
    (= slot 14) (vev.tx-fn-values ident abi-tx-fn-slot-14)
    :else (vev.tx-fn-values ident abi-tx-fn-slot-15)))

(defn- tx-fn-source-slot-entry [ident: string, slot: int] -> vev.Tx-Fn-Source-String
  (cond
    (= slot 0) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-0)
    (= slot 1) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-1)
    (= slot 2) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-2)
    (= slot 3) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-3)
    (= slot 4) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-4)
    (= slot 5) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-5)
    (= slot 6) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-6)
    (= slot 7) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-7)
    (= slot 8) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-8)
    (= slot 9) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-9)
    (= slot 10) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-10)
    (= slot 11) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-11)
    (= slot 12) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-12)
    (= slot 13) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-13)
    (= slot 14) (vev.tx-fn-source-values ident abi-tx-fn-source-slot-14)
    :else (vev.tx-fn-source-values ident abi-tx-fn-source-slot-15)))

(defn- abi-query-predicate-dispatch [slot: int, args: []vev.Value] -> bool
  (abi-query-predicate-call slot (count args) (tx-fn-args-ptr args)))

(defn- abi-query-aggregate-dispatch [slot: int, values: []vev.Value] -> vev.Native-Query-Function-Result
  (let [result-c (abi-query-value-call slot (count values) (tx-fn-args-ptr values))]
    (when (= result-c nil)
      (return (vev.native-query-function-none)))
    (let [result-text (text-from-c result-c)
          [value value-ok _] (vev.value-from-owned-serial-text result-text)]
      (delete result-text)
      (if value-ok
        (vev.native-query-function-result value)
        (vev.native-query-function-none)))))

(defn- abi-query-predicate-slot-0 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 0 args))
(defn- abi-query-predicate-slot-1 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 1 args))
(defn- abi-query-predicate-slot-2 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 2 args))
(defn- abi-query-predicate-slot-3 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 3 args))
(defn- abi-query-predicate-slot-4 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 4 args))
(defn- abi-query-predicate-slot-5 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 5 args))
(defn- abi-query-predicate-slot-6 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 6 args))
(defn- abi-query-predicate-slot-7 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 7 args))
(defn- abi-query-predicate-slot-8 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 8 args))
(defn- abi-query-predicate-slot-9 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 9 args))
(defn- abi-query-predicate-slot-10 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 10 args))
(defn- abi-query-predicate-slot-11 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 11 args))
(defn- abi-query-predicate-slot-12 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 12 args))
(defn- abi-query-predicate-slot-13 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 13 args))
(defn- abi-query-predicate-slot-14 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 14 args))
(defn- abi-query-predicate-slot-15 [args: []vev.Value] -> bool (abi-query-predicate-dispatch 15 args))

(defn- abi-query-aggregate-slot-0 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 0 values))
(defn- abi-query-aggregate-slot-1 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 1 values))
(defn- abi-query-aggregate-slot-2 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 2 values))
(defn- abi-query-aggregate-slot-3 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 3 values))
(defn- abi-query-aggregate-slot-4 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 4 values))
(defn- abi-query-aggregate-slot-5 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 5 values))
(defn- abi-query-aggregate-slot-6 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 6 values))
(defn- abi-query-aggregate-slot-7 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 7 values))
(defn- abi-query-aggregate-slot-8 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 8 values))
(defn- abi-query-aggregate-slot-9 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 9 values))
(defn- abi-query-aggregate-slot-10 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 10 values))
(defn- abi-query-aggregate-slot-11 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 11 values))
(defn- abi-query-aggregate-slot-12 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 12 values))
(defn- abi-query-aggregate-slot-13 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 13 values))
(defn- abi-query-aggregate-slot-14 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 14 values))
(defn- abi-query-aggregate-slot-15 [values: []vev.Value] -> vev.Native-Query-Function-Result (abi-query-aggregate-dispatch 15 values))

(defn- query-predicate-slot-entry [ident: string, slot: int] -> vev.Native-Query-Fn
  (cond
    (= slot 0) (vev.query-predicate-fn ident abi-query-predicate-slot-0)
    (= slot 1) (vev.query-predicate-fn ident abi-query-predicate-slot-1)
    (= slot 2) (vev.query-predicate-fn ident abi-query-predicate-slot-2)
    (= slot 3) (vev.query-predicate-fn ident abi-query-predicate-slot-3)
    (= slot 4) (vev.query-predicate-fn ident abi-query-predicate-slot-4)
    (= slot 5) (vev.query-predicate-fn ident abi-query-predicate-slot-5)
    (= slot 6) (vev.query-predicate-fn ident abi-query-predicate-slot-6)
    (= slot 7) (vev.query-predicate-fn ident abi-query-predicate-slot-7)
    (= slot 8) (vev.query-predicate-fn ident abi-query-predicate-slot-8)
    (= slot 9) (vev.query-predicate-fn ident abi-query-predicate-slot-9)
    (= slot 10) (vev.query-predicate-fn ident abi-query-predicate-slot-10)
    (= slot 11) (vev.query-predicate-fn ident abi-query-predicate-slot-11)
    (= slot 12) (vev.query-predicate-fn ident abi-query-predicate-slot-12)
    (= slot 13) (vev.query-predicate-fn ident abi-query-predicate-slot-13)
    (= slot 14) (vev.query-predicate-fn ident abi-query-predicate-slot-14)
    :else (vev.query-predicate-fn ident abi-query-predicate-slot-15)))

(defn- query-aggregate-slot-entry [ident: string, slot: int] -> vev.Native-Query-Fn
  (cond
    (= slot 0) (vev.query-aggregate-fn ident abi-query-aggregate-slot-0)
    (= slot 1) (vev.query-aggregate-fn ident abi-query-aggregate-slot-1)
    (= slot 2) (vev.query-aggregate-fn ident abi-query-aggregate-slot-2)
    (= slot 3) (vev.query-aggregate-fn ident abi-query-aggregate-slot-3)
    (= slot 4) (vev.query-aggregate-fn ident abi-query-aggregate-slot-4)
    (= slot 5) (vev.query-aggregate-fn ident abi-query-aggregate-slot-5)
    (= slot 6) (vev.query-aggregate-fn ident abi-query-aggregate-slot-6)
    (= slot 7) (vev.query-aggregate-fn ident abi-query-aggregate-slot-7)
    (= slot 8) (vev.query-aggregate-fn ident abi-query-aggregate-slot-8)
    (= slot 9) (vev.query-aggregate-fn ident abi-query-aggregate-slot-9)
    (= slot 10) (vev.query-aggregate-fn ident abi-query-aggregate-slot-10)
    (= slot 11) (vev.query-aggregate-fn ident abi-query-aggregate-slot-11)
    (= slot 12) (vev.query-aggregate-fn ident abi-query-aggregate-slot-12)
    (= slot 13) (vev.query-aggregate-fn ident abi-query-aggregate-slot-13)
    (= slot 14) (vev.query-aggregate-fn ident abi-query-aggregate-slot-14)
    :else (vev.query-aggregate-fn ident abi-query-aggregate-slot-15)))

(defn- datom-owned [datom: vev.Datom] -> vev.Datom
  (vev.Datom {e: datom.e
              a: (string-owned datom.a)
              v: (value-owned datom.v)
              tx: datom.tx
              added: datom.added}))

(defn- db-owned [db: vev.DB] -> vev.DB
  (let [datoms (make [dynamic]vev.Datom 0 (count db.datoms))]
    (for [datom db.datoms]
      (arr.push! datoms (datom-owned datom)))
    (vev.build-db datoms)))

(defn- delete-db-owned [db: vev.DB]
  (for [datom db.datoms]
    (delete datom.a)
    (vev.delete-owned-value datom.v))
  (vev.delete-owned-db db))

(defn- delete-result-shallow [result: vev.Result-Set]
  (vev.delete-result-set-shallow result))

(defn- result-store-pull-values! [result: Vev-Result, db: vev.DB]
  (let [ptr (result-ptr result)
        pull-values (result-pull-values-ptr result)
        pull-offsets (result-pull-offsets-ptr result)]
    (for [row ptr^.rows]
      (arr.push! pull-offsets^ (count pull-values^))
      (for [pull row.pulls]
        (let [rendered (vev.pull-result-value db pull)]
          (arr.push! pull-values^ (value-owned rendered))
          (vev.delete-value-containers-shallow rendered))))))

(defn- result-finish [result: Vev-Result, db: vev.DB] -> Vev-Result
  (result-store-pull-values! result db)
  result)

(defn- result-store-pull-values-from-store-db! [result: Vev-Result, snapshot: ^vev.Store-DB] -> bool
  (let [ptr (result-ptr result)
        pull-values (result-pull-values-ptr result)
        pull-offsets (result-pull-offsets-ptr result)
        [source source-ok _] (vev.store-db-read-source snapshot)]
    (when (not source-ok)
      (return false))
    (for [row ptr^.rows]
      (arr.push! pull-offsets^ (count pull-values^))
      (for [pull row.pulls]
        (let [[rendered rendered-ok _] (vev.db-read-source-pull-result-value source pull)]
          (when (not rendered-ok)
            (return false))
          (arr.push! pull-values^ (value-owned rendered))
          (vev.delete-value-containers-shallow rendered))))
    true))

(defn- result-finish-store-db [result: Vev-Result, snapshot: ^vev.Store-DB] -> Vev-Result
  (when (not (result-store-pull-values-from-store-db! result snapshot))
    (let [ptr (result-ptr result)]
      (set! ptr^.ok false)
      (set! ptr^.error "failed to render pull results from DB snapshot")))
  result)

(defn- result-finish-query-result-store-db [result: Vev-Result, query-result: vev.Query-Result, snapshot: ^vev.Store-DB] -> Vev-Result
  (let [ptr (result-ptr result)]
    (set! ptr^ (vev.result-set-owned query-result.result))
    (vev.delete-query-result query-result)
    (result-set-owns-values! result true)
    (if ptr^.ok
      (result-finish-store-db result snapshot)
      result)))

(defn- result-finish-query-result [result: Vev-Result, query-result: vev.Query-Result, db: vev.DB] -> Vev-Result
  (let [ptr (result-ptr result)]
    (set! ptr^ query-result.result)
    (result-set-owns-values! result (vev.query-result-owns-values? query-result))
    (result-finish result db)))

(defn- result-delete-owned [result: Vev-Result]
  (let [ptr (result-ptr result)]
    (for [value (deref (result-pull-values-ptr result))]
      (vev.delete-owned-value value))
    (if (result-owns-values? result)
      (vev.delete-result-set-owned-values ptr^)
      (delete-result-shallow ptr^))
    (abi-free-result (rawptr result))))

(defn- stmt-clear-error! [stmt: Vev-Stmt]
  (let [error (stmt-error-ptr stmt)]
    (when (> (count error^) 0)
      (delete error^))
    (set! error^ "")))

(defn- stmt-set-error! [stmt: Vev-Stmt, message: string]
  (stmt-clear-error! stmt)
  (let [error (stmt-error-ptr stmt)]
    (set! error^ (string-owned message))))

(defn- result-finish-visit-delete [result: Vev-Result, db: vev.DB, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (result-finish result db)
  (let [ptr (result-ptr result)]
    (when (not ptr^.ok)
      (stmt-set-error! stmt ptr^.error)
      (result-delete-owned result)
      (return false))
    (when (not (abi-result-visit (rawptr result) visitor user))
      (stmt-set-error! stmt "result visitor cancelled")
      (result-delete-owned result)
      (return false))
    (stmt-clear-error! stmt)
    (result-delete-owned result)
    true))

(defn- result-finish-query-result-visit-delete [result: Vev-Result, query-result: vev.Query-Result, db: vev.DB, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (result-finish-query-result result query-result db)
  (let [ptr (result-ptr result)]
    (when (not ptr^.ok)
      (stmt-set-error! stmt ptr^.error)
      (result-delete-owned result)
      (return false))
    (when (not (abi-result-visit (rawptr result) visitor user))
      (stmt-set-error! stmt "result visitor cancelled")
      (result-delete-owned result)
      (return false))
    (stmt-clear-error! stmt)
    (result-delete-owned result)
    true))

(defn- result-finish-query-result-store-db-visit-delete [result: Vev-Result, query-result: vev.Query-Result, snapshot: ^vev.Store-DB, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (result-finish-query-result-store-db result query-result snapshot)
  (let [ptr (result-ptr result)]
    (when (not ptr^.ok)
      (stmt-set-error! stmt ptr^.error)
      (result-delete-owned result)
      (return false))
    (when (not (abi-result-visit (rawptr result) visitor user))
      (stmt-set-error! stmt "result visitor cancelled")
      (result-delete-owned result)
      (return false))
    (stmt-clear-error! stmt)
    (result-delete-owned result)
    true))

(defn- result-value [result: Vev-Result, row: int, column: int] -> vev.Value
  (let [ptr (result-ptr result)]
    (when (or (= (rawptr result) nil)
              (< row 0)
              (< column 0)
              (>= row (count ptr^.rows))
              (>= column (count ptr^.rows[row].values)))
      (return (vev.value-nil)))
    ptr^.rows[row].values[column]))

@export
(defn vev_version :abi "c" [] -> cstring
  (odin "context = runtime.default_context()")
  (cstring "vev-abi/0.1"))

@export
(defn vev_conn_open_memory :abi "c" [] -> Vev-Conn
  (odin "context = runtime.default_context()")
  (let [conn (abi-alloc-conn)
        ptr (conn-ptr (Vev-Conn conn))]
    (set! ptr^ (vev.create-conn))
    (Vev-Conn conn)))

@export
(defn vev_connect :abi "c" [uri: cstring] -> Vev-Connection
  (odin "context = runtime.default_context()")
  (when (= uri nil)
    (let [store (vev.create-sqlite-conn "")]
      (return (Vev-Connection (alloc-sqlite-conn-copy store false "null Vev connection URI")))))
  (let [uri-text (text-from-c uri)
        path (durable-path-from-uri uri-text)
        [store ok error] (vev.open-sqlite-conn path)
        out (Vev-Connection (alloc-sqlite-conn-copy store ok error))]
    (delete uri-text)
    (delete path)
    out))

@export
(defn vev_connection_ok :abi "c" [conn: Vev-Connection] -> bool
  (odin "context = runtime.default_context()")
  (abi-sqlite-conn-ok (rawptr conn)))

@export
(defn vev_connection_error :abi "c" [conn: Vev-Connection] -> cstring
  (odin "context = runtime.default_context()")
  (c-string-owned (abi-sqlite-conn-error (rawptr conn))))

@export
(defn vev_connection_backend :abi "c" [conn: Vev-Connection] -> cstring
  (odin "context = runtime.default_context()")
  (if (= (rawptr conn) nil)
    (c-string-owned "")
    (c-string-owned "sqlite")))

@export
(defn vev_connection_path :abi "c" [conn: Vev-Connection] -> cstring
  (odin "context = runtime.default_context()")
  (c-string-owned (abi-sqlite-conn-path (rawptr conn))))

@export
(defn vev_connection_basis_t :abi "c" [conn: Vev-Connection] -> u64
  (odin "context = runtime.default_context()")
  (abi-sqlite-conn-basis-t (rawptr conn)))

@export
(defn vev_connection_tx_count :abi "c" [conn: Vev-Connection] -> u64
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return 0))
  (let [[tx-count _ _] (vev.sqlite-conn-tx-count (sqlite-conn-ptr (connection-as-sqlite conn)))]
    tx-count))

@export
(defn vev_connection_tx_ids :abi "c" [conn: Vev-Connection] -> Vev-U64-Array
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return (Vev-U64-Array nil)))
  (let [[tx-ids tx-ok _] (vev.sqlite-conn-tx-ids (sqlite-conn-ptr (connection-as-sqlite conn)))]
    (when (not tx-ok)
      (delete tx-ids)
      (return (Vev-U64-Array nil)))
    (Vev-U64-Array (abi-alloc-u64-array tx-ids))))

@export
(defn vev_connection_tx_data_edn :abi "c" [conn: Vev-Connection, tx: u64] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return (c-string-owned "[]")))
  (let [[text ok _] (vev.sqlite-conn-tx-data-text (sqlite-conn-ptr (connection-as-sqlite conn)) tx)]
    (if ok
      (return (c-string-owned text))
      (return (c-string-owned "[]")))))

@export
(defn vev_connection_info_edn :abi "c" [conn: Vev-Connection] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return (c-string-owned "{:backend nil :path \"\" :basis-t 0 :tx-count 0}")))
  (let [value (connection-info-value conn)
        text (vev.value-serializable-text value)
        out (c-string-owned text)]
    (delete text)
    (vev.delete-owned-value value)
    out))

@export
(defn vev_connection_close :abi "c" [conn: Vev-Connection]
  (odin "context = runtime.default_context()")
  (vev_sqlite_conn_close (connection-as-sqlite conn)))

@export
(defn vev_connection_db :abi "c" [conn: Vev-Connection] -> Vev-DB
  (odin "context = runtime.default_context()")
  (vev_sqlite_conn_db (connection-as-sqlite conn)))

@export
