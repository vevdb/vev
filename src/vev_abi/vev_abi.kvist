@export
(defn vev_pull_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entity: u64] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= pattern-text nil))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        db-ptr-value (db-ptr db)
        value (vev.pull-text-value db-ptr-value^ pattern entity)
        out (value-handle-from-value value)]
    (delete pattern)
    out))

@export
(defn vev_pull_prepared :abi "c" [db: Vev-DB, pattern: Vev-Prepared-Pull-Pattern, entity: u64] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr pattern) nil))
    (return (Vev-Value-Handle nil)))
  (let [db-ptr-value (db-ptr db)
        pattern-ptr (prepared-pull-pattern-ptr pattern)
        value (vev.pull-prepared-value db-ptr-value^ pattern-ptr^ entity)]
    (value-handle-from-value value)))

