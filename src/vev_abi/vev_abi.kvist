abi_entity_string_int_triples_string_data_array :: proc(array: rawptr) -> rawptr {
    wrapper := (^ABI_Entity_String_Int_Triples)(array)
    if wrapper == nil || len(wrapper.string_data) == 0 {
        return nil
    }
    return rawptr(&wrapper.string_data[0])
