@export
(defn vev_tx_commit_report :abi "c" [conn: Vev-Conn, builder: Vev-Tx-Builder] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr builder) nil))
    (return (Vev-Tx-Report nil)))
  (let [tx-data (tx-builder-data-ptr builder)
        report (vev.transact-tx-data (conn-ptr conn) (slice tx-data^ 0))]
    (notify-abi-tx-listeners! conn report)
    (tx-report-handle-from-report report)))

@export
(defn vev_tx_db_with :abi "c" [db: Vev-DB, builder: Vev-Tx-Builder] -> Vev-DB
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr builder) nil))
    (return (Vev-DB nil)))
  (let [db-ptr-value (db-ptr db)
        tx-data (tx-builder-data-ptr builder)
        next-db (vev.db-with-tx-data db-ptr-value^ (slice tx-data^ 0))]
    (Vev-DB (abi-alloc-db (db-owned next-db)))))

@export
(defn vev_tx_fn_arg :abi "c" [args: Vev-Tx-Fn-Args, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
