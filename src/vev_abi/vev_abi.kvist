@export
(defn vev_sqlite_conn_open :abi "c" [path: cstring] -> Vev-SQLite-Conn
  (odin "context = runtime.default_context()")
  (when (= path nil)
    (let [store (vev.create-sqlite-conn "")]
      (return (Vev-SQLite-Conn (alloc-sqlite-conn-copy store false "null sqlite path")))))
  (let [path-text (text-from-c path)
        [store ok error] (vev.open-sqlite-conn path-text)
        out (Vev-SQLite-Conn (alloc-sqlite-conn-copy store ok error))]
    (delete path-text)
    out))

@export
(defn vev_sqlite_conn_ok :abi "c" [conn: Vev-SQLite-Conn] -> bool
  (odin "context = runtime.default_context()")
  (abi-sqlite-conn-ok (rawptr conn)))

@export
(defn vev_sqlite_conn_error :abi "c" [conn: Vev-SQLite-Conn] -> cstring
  (odin "context = runtime.default_context()")
  (c-string-owned (abi-sqlite-conn-error (rawptr conn))))

@export
(defn vev_sqlite_conn_close :abi "c" [conn: Vev-SQLite-Conn]
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return))
  (let [store (sqlite-conn-ptr conn)]
    (vev.close-sqlite-conn store^)
    (abi-free-sqlite-conn (rawptr conn))))

@export
(defn vev_sqlite_conn_db :abi "c" [conn: Vev-SQLite-Conn] -> Vev-DB
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-DB nil)))
  (let [store (sqlite-conn-ptr conn)]
    (let [[snapshot snapshot-ok _] (vev.sqlite-store-db store)]
      (if snapshot-ok
        (Vev-DB (abi-alloc-db snapshot))
        (Vev-DB nil)))))

@export
(defn vev_sqlite_conn_listen_tx_report :abi "c" [conn: Vev-SQLite-Conn, name: cstring, callback: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= name nil) (= callback nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return false))
  (let [name-text (text-from-c name)
        ok (abi-sqlite-conn-add-tx-listener (rawptr conn) name-text callback user)]
    (when (not ok)
      (delete name-text))
    ok))

@export
(defn vev_sqlite_conn_unlisten_tx_report :abi "c" [conn: Vev-SQLite-Conn, name: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= name nil))
    (return false))
  (let [name-text (text-from-c name)
        ok (abi-sqlite-conn-remove-tx-listener (rawptr conn) name-text)]
    (delete name-text)
    ok))

@export
(defn vev_conn_close :abi "c" [conn: Vev-Conn]
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return))
  (let [ptr (conn-ptr conn)]
    (vev.delete-owned-db ptr^.db)
    (delete ptr^.listeners)
    (abi-free-conn (rawptr conn))))

@export
(defn vev_conn_listen_tx_report :abi "c" [conn: Vev-Conn, name: cstring, callback: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= name nil) (= callback nil))
    (return false))
  (let [name-text (text-from-c name)
        ok (abi-conn-add-tx-listener (rawptr conn) name-text callback user)]
    (when (not ok)
      (delete name-text))
    ok))

@export
(defn vev_conn_unlisten_tx_report :abi "c" [conn: Vev-Conn, name: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= name nil))
    (return false))
  (let [name-text (text-from-c name)
        ok (abi-conn-remove-tx-listener (rawptr conn) name-text)]
    (delete name-text)
    ok))

@export
(defn vev_conn_db :abi "c" [conn: Vev-Conn] -> Vev-DB
  (odin "context = runtime.default_context()")
  (when (= (rawptr conn) nil)
    (return (Vev-DB nil)))
  (let [conn-ptr-value (conn-ptr conn)]
    (Vev-DB (abi-alloc-db
              (vev.Store-DB {kind: .Resident
                             resident: (db-owned conn-ptr-value^.db)})))))

@export
(defn vev_conn_from_db :abi "c" [db: Vev-DB] -> Vev-Conn
  (odin "context = runtime.default_context()")
  (when (= (rawptr db) nil)
    (return (Vev-Conn nil)))
  (let [[db-ptr-value db-ok] (resident-db-ptr db)]
    (when (not db-ok)
      (return (Vev-Conn nil)))
    (let [conn (abi-alloc-conn)
          ptr (conn-ptr (Vev-Conn conn))]
      (set! ptr^ (vev.conn-from-db db-ptr-value^))
      (Vev-Conn conn))))

@export
(defn vev_db_release :abi "c" [db: Vev-DB]
  (odin "context = runtime.default_context()")
  (when (= (rawptr db) nil)
    (return))
  (let [storage (abi-release-db (rawptr db))]
    (when (not (= storage nil))
      (let [ptr (abi-store-db-storage-ptr storage)]
        (vev.close-store-db! ptr)
        (abi-free-db-storage storage)))))

@export
(defn vev_db_retain :abi "c" [db: Vev-DB] -> Vev-DB
  (odin "context = runtime.default_context()")
  (when (= (rawptr db) nil)
    (return (Vev-DB nil)))
  (Vev-DB (abi-retain-db (rawptr db))))

@export
(defn vev_with_edn :abi "c" [db: Vev-DB, tx-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= tx-text nil))
    (return (c-string-owned "[:vev/error \"null db or tx\"]")))
  (let [tx (text-from-c tx-text)
        store-ptr-value (store-db-ptr db)]
    (let [report (vev.with-store-db-report-text store-ptr-value tx)
          value (vev.store-tx-report-value report)
          text (vev.value-serializable-text value)
          out (c-string-owned text)]
      (vev.delete-owned-value value)
      (vev.delete-store-tx-report report)
      (delete tx)
      out)))

@export
(defn vev_with_edn_report :abi "c" [db: Vev-DB, tx-text: cstring] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= tx-text nil))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        store-ptr-value (store-db-ptr db)]
    (let [report (vev.with-store-db-report-text store-ptr-value tx)
          out (tx-report-handle-from-store-report report)]
      (vev.delete-store-tx-report report)
      (delete tx)
      out)))

@export
(defn vev_db_with_edn :abi "c" [db: Vev-DB, tx-text: cstring] -> Vev-DB
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= tx-text nil))
    (return (Vev-DB nil)))
  (let [tx (text-from-c tx-text)
        store-ptr-value (store-db-ptr db)]
    (let [report (vev.with-store-db-report-text store-ptr-value tx)]
      (when (not report.ok)
        (vev.delete-store-tx-report report)
        (delete tx)
        (return (Vev-DB nil)))
      (let [next-db (vev.retain-store-db report.db-after)
            out (Vev-DB (abi-alloc-db next-db))]
        (vev.delete-store-tx-report report)
        (delete tx)
        out))))

@export
(defn vev_db_entity :abi "c" [db: Vev-DB, entity-id: u64] -> Vev-Entity
  (odin "context = runtime.default_context()")
  (when (= (rawptr db) nil)
    (return (entity-handle-null)))
  (let [store-ptr-value (store-db-ptr db)
        [entity entity-ok _] (vev.store-db-entity store-ptr-value entity-id)]
    (if entity-ok
      (entity-handle-from-owned-entity entity)
      (entity-handle-null))))

@export
(defn vev_db_entity_lookup_ref_string :abi "c" [db: Vev-DB, attr: cstring, value: cstring] -> Vev-Entity
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= attr nil) (= value nil))
    (return (entity-handle-null)))
  (let [attr-text (text-from-c attr)
        value-text (text-from-c value)
        lookup-value (vev.value-string value-text)
        store-ptr-value (store-db-ptr db)
        [entity entity-ok _] (vev.store-db-entity-lookup-ref store-ptr-value attr-text lookup-value)]
    (delete attr-text)
    (vev.delete-owned-value lookup-value)
    (if entity-ok
      (entity-handle-from-owned-entity entity)
      (entity-handle-null))))

@export
(defn vev_db_entity_ident :abi "c" [db: Vev-DB, ident: cstring] -> Vev-Entity
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= ident nil))
    (return (entity-handle-null)))
  (let [ident-text (text-from-c ident)
        store-ptr-value (store-db-ptr db)
        [entity entity-ok _] (vev.store-db-entity-ident store-ptr-value ident-text)]
    (delete ident-text)
    (if entity-ok
      (entity-handle-from-owned-entity entity)
      (entity-handle-null))))

@export
(defn vev_entity_free :abi "c" [entity: Vev-Entity]
  (odin "context = runtime.default_context()")
  (when (= (rawptr entity) nil)
    (return))
  (let [ptr (entity-ptr entity)]
    (vev.close-store-entity! ptr)
    (abi-free-entity (rawptr entity))))

@export
(defn vev_entity_found :abi "c" [entity: Vev-Entity] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr entity) nil)
    (return false))
  (let [ptr (entity-ptr entity)]
    ptr^.found))

@export
(defn vev_entity_id :abi "c" [entity: Vev-Entity] -> u64
  (odin "context = runtime.default_context()")
  (when (= (rawptr entity) nil)
    (return 0))
  (let [ptr (entity-ptr entity)]
    ptr^.e))

@export
(defn vev_entity_contains :abi "c" [entity: Vev-Entity, attr: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr entity) nil) (= attr nil))
    (return false))
  (let [attr-text (text-from-c attr)
        out (vev.store-entity-contains? (entity-ptr entity) attr-text)]
    (delete attr-text)
    out))

@export
(defn vev_entity_get :abi "c" [entity: Vev-Entity, attr: cstring] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr entity) nil) (= attr nil))
    (return (Vev-Value-Handle nil)))
  (let [attr-text (text-from-c attr)
        value (vev.store-entity-get (entity-ptr entity) attr-text)]
    (delete attr-text)
    (value-handle-from-owned-value value)))

@export
(defn vev_entity_values :abi "c" [entity: Vev-Entity, attr: cstring] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr entity) nil) (= attr nil))
    (return (Vev-Value-Handle nil)))
  (let [attr-text (text-from-c attr)
        [values values-ok _] (vev.store-entity-values (entity-ptr entity) attr-text)]
    (delete attr-text)
    (if values-ok
      (value-handle-from-owned-value (vev.value-vector-owned values))
      (do
        (vev.delete-owned-values-array values)
        (Vev-Value-Handle nil)))))

@export
(defn vev_entity_ref :abi "c" [entity: Vev-Entity, attr: cstring] -> Vev-Entity
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr entity) nil) (= attr nil))
    (return (entity-handle-null)))
  (let [attr-text (text-from-c attr)
        [ref ref-ok _] (vev.store-entity-ref (entity-ptr entity) attr-text)]
    (delete attr-text)
    (if ref-ok
      (entity-handle-from-owned-entity ref)
      (entity-handle-null))))

@export
(defn vev_entity_refs :abi "c" [entity: Vev-Entity, attr: cstring] -> Vev-U64-Array
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr entity) nil) (= attr nil))
    (return (Vev-U64-Array nil)))
  (let [attr-text (text-from-c attr)
        [refs refs-ok _] (vev.store-entity-refs (entity-ptr entity) attr-text)]
    (delete attr-text)
    (when (not refs-ok)
      (vev.close-store-entities refs)
      (return (Vev-U64-Array nil)))
    (let [ids (make [dynamic]u64 0 (count refs))]
      (for [ref refs]
        (arr.push! ids (vev.store-entity-id ref)))
      (vev.close-store-entities refs)
      (Vev-U64-Array (abi-alloc-u64-array ids)))))

@export
(defn vev_entity_touch :abi "c" [entity: Vev-Entity] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (= (rawptr entity) nil)
    (return (Vev-Value-Handle nil)))
  (let [[value value-ok _] (vev.touch-store-entity (entity-ptr entity))]
    (if value-ok
      (value-handle-from-owned-value value)
      (Vev-Value-Handle nil))))

@export
(defn vev_string_free :abi "c" [text: cstring]
  (odin "context = runtime.default_context()")
  (when (= text nil)
    (return))
  (delete text))

@export
(defn vev_transact_edn :abi "c" [conn: Vev-Conn, tx-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= tx-text nil))
    (return (c-string-owned "[:vev/error \"null conn or tx\"]")))
  (let [tx (text-from-c tx-text)
        report (vev.transact-text (conn-ptr conn) tx)]
    (notify-abi-tx-listeners! conn report)
    (let [value (vev.tx-report-value report)
          text (vev.value-serializable-text value)
          out (c-string-owned text)]
      (vev.delete-owned-value value)
      (abi-conn-store-tx-source (rawptr conn) tx)
      out)))

@export
(defn vev_transact_edn_report :abi "c" [conn: Vev-Conn, tx-text: cstring] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= tx-text nil))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        report (vev.transact-text (conn-ptr conn) tx)]
    (notify-abi-tx-listeners! conn report)
    (let [out (tx-report-handle-from-report report)]
    (abi-conn-store-tx-source (rawptr conn) tx)
    out)))

@export
(defn vev_sqlite_conn_transact_edn_report :abi "c" [conn: Vev-SQLite-Conn, tx-text: cstring] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= tx-text nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        report (vev.transact-sqlite-store-report-text (sqlite-conn-ptr conn) tx)
        out (tx-report-handle-from-store-report report)]
    (notify-abi-sqlite-tx-listeners! conn report)
    (delete tx)
    (vev.delete-store-tx-report report)
    out))

@export
(defn vev_connection_transact_edn_report_with_tx_fns :abi "c" [conn: Vev-Connection, tx-text: cstring, registry: Vev-Tx-Fn-Registry] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (vev_sqlite_conn_transact_edn_report_with_tx_fns (connection-as-sqlite conn) tx-text registry))

@export
(defn vev_sqlite_conn_transact_edn_report_with_tx_fns :abi "c" [conn: Vev-SQLite-Conn, tx-text: cstring, registry: Vev-Tx-Fn-Registry] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= tx-text nil) (= (rawptr registry) nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        entries (tx-fn-registry-source-entries-ptr registry)
        report (vev.transact-sqlite-store-report-text-with-source-string-fns (sqlite-conn-ptr conn) tx (slice entries^ 0))
        out (tx-report-handle-from-store-report report)]
    (notify-abi-sqlite-tx-listeners! conn report)
    (abi-sqlite-conn-store-tx-source (rawptr conn) tx)
    (vev.delete-store-tx-report report)
    out))

@export
(defn vev_sqlite_conn_tx_commit_report :abi "c" [conn: Vev-SQLite-Conn, builder: Vev-Tx-Builder] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr builder) nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report nil)))
  (let [tx-data (tx-builder-data-ptr builder)
        report (vev.transact-sqlite-store-report-tx-data (sqlite-conn-ptr conn) (slice tx-data^ 0))
        out (tx-report-handle-from-store-report report)]
    (notify-abi-sqlite-tx-listeners! conn report)
    (vev.delete-store-tx-report report)
    out))

@export
(defn vev_sqlite_conn_tx_commit_many_report :abi "c" [conn: Vev-SQLite-Conn, builders: rawptr, builder-count: int] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= builders nil) (<= builder-count 0) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report nil)))
  (let [[groups groups-ok groups-error] (store-tx-data-groups-from-builders builders builder-count)]
    (when (not groups-ok)
      (delete groups)
      (let [failed (vev.failed-store-tx-report (vev.Store-DB {}) groups-error)
            out (tx-report-handle-from-store-report failed)]
        (vev.delete-store-tx-report failed)
        (return out)))
    (let [report (vev.transact-sqlite-store-report-tx-data-groups (sqlite-conn-ptr conn) (slice groups 0))
          out (tx-report-handle-from-store-report report)]
      (notify-abi-sqlite-tx-listeners! conn report)
      (vev.delete-store-tx-report report)
      (delete-store-tx-data-groups groups)
      out)))

@export
(defn vev_sqlite_conn_tx_commit_logical_many_reports :abi "c" [conn: Vev-SQLite-Conn, builders: rawptr, builder-count: int] -> Vev-Tx-Report-Array
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (< builder-count 0) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report-Array nil)))
  (when (= builder-count 0)
    (return (Vev-Tx-Report-Array (abi-alloc-tx-report-array 0))))
  (let [[groups groups-ok groups-error] (store-tx-data-groups-from-builders builders builder-count)]
    (when (not groups-ok)
      (delete groups)
      (let [failed (vev.failed-store-tx-report (vev.Store-DB {}) groups-error)
            out (tx-report-array-handle-from-store-report failed)]
        (vev.delete-store-tx-report failed)
        (return out)))
    (let [[reports reports-ok reports-error] (vev.transact-sqlite-store-report-logical-tx-data-groups (sqlite-conn-ptr conn) (slice groups 0))]
      (when (not reports-ok)
        (vev.delete-store-tx-reports reports)
        (delete-store-tx-data-groups groups)
        (let [failed (vev.failed-sqlite-store-tx-report (sqlite-conn-ptr conn) reports-error)
              out (tx-report-array-handle-from-store-report failed)]
          (vev.delete-store-tx-report failed)
          (return out)))
      (let [out (tx-report-array-handle-from-store-reports (slice reports 0))]
        (for [report reports]
          (notify-abi-sqlite-tx-listeners! conn report))
        (vev.delete-store-tx-reports reports)
        (delete-store-tx-data-groups groups)
        out))))

@export
(defn vev_sqlite_conn_transact_many_edn_reports :abi "c" [conn: Vev-SQLite-Conn, tx-texts: rawptr, tx-count: int] -> Vev-Tx-Report-Array
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (< tx-count 0) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Tx-Report-Array nil)))
  (when (= tx-count 0)
    (return (Vev-Tx-Report-Array (abi-alloc-tx-report-array 0))))
  (let [[texts texts-ok texts-error] (strings-from-c-array tx-texts tx-count)]
    (when (not texts-ok)
      (delete texts)
      (let [failed (vev.failed-store-tx-report (vev.Store-DB {}) texts-error)
            out (tx-report-array-handle-from-store-report failed)]
        (vev.delete-store-tx-report failed)
        (return out)))
    (let [[reports reports-ok reports-error] (vev.transact-sqlite-store-report-logical-text-groups (sqlite-conn-ptr conn) (slice texts 0))]
      (delete-string-array texts)
      (when (not reports-ok)
        (vev.delete-store-tx-reports reports)
        (let [failed (vev.failed-sqlite-store-tx-report (sqlite-conn-ptr conn) reports-error)
              out (tx-report-array-handle-from-store-report failed)]
          (vev.delete-store-tx-report failed)
          (return out)))
      (let [out (tx-report-array-handle-from-store-reports (slice reports 0))]
        (for [report reports]
          (notify-abi-sqlite-tx-listeners! conn report))
        (vev.delete-store-tx-reports reports)
        out))))

@export
(defn vev_sqlite_conn_compact_indexes :abi "c" [conn: Vev-SQLite-Conn] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return false))
  (let [[_ compact-ok _] (vev.sqlite-conn-compact-indexes! (sqlite-conn-ptr conn))]
    compact-ok))

@export
(defn vev_tx_fn_registry_create :abi "c" [] -> Vev-Tx-Fn-Registry
  (odin "context = runtime.default_context()")
  (Vev-Tx-Fn-Registry (abi-alloc-tx-fn-registry)))

@export
(defn vev_tx_fn_registry_free :abi "c" [registry: Vev-Tx-Fn-Registry]
  (odin "context = runtime.default_context()")
  (when (= (rawptr registry) nil)
    (return))
  (let [entries (tx-fn-registry-entries-ptr registry)
        source-entries (tx-fn-registry-source-entries-ptr registry)]
    (for [entry entries^]
      (delete entry.ident))
    (for [entry source-entries^]
      (delete entry.ident))
    (abi-free-tx-fn-registry (rawptr registry))))

@export
(defn vev_tx_fn_registry_register_edn :abi "c" [registry: Vev-Tx-Fn-Registry, ident: cstring, callback: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr registry) nil) (= ident nil) (= callback nil))
    (return false))
  (let [ident-text (text-from-c ident)
        source-ident (text-from-c ident)
        entries (tx-fn-registry-entries-ptr registry)
        source-entries (tx-fn-registry-source-entries-ptr registry)]
    (for [entry entries^]
      (when (= entry.ident ident-text)
        (delete source-ident)
        (delete ident-text)
        (return false)))
    (let [slot (abi-tx-fn-alloc-slot callback user)]
      (when (< slot 0)
        (delete source-ident)
        (delete ident-text)
        (return false))
      (let [slots (tx-fn-registry-slots-ptr registry)]
      (arr.push! entries^ (tx-fn-slot-entry ident-text slot))
      (arr.push! source-entries^ (tx-fn-source-slot-entry source-ident slot))
      (arr.push! slots^ slot)
      true))))

@export
(defn vev_query_fn_registry_create :abi "c" [] -> Vev-Query-Fn-Registry
  (odin "context = runtime.default_context()")
  (Vev-Query-Fn-Registry (abi-alloc-query-fn-registry)))

@export
(defn vev_query_fn_registry_free :abi "c" [registry: Vev-Query-Fn-Registry]
  (odin "context = runtime.default_context()")
  (when (= (rawptr registry) nil)
    (return))
  (abi-free-query-fn-registry (rawptr registry)))

@export
(defn vev_query_fn_registry_register_predicate :abi "c" [registry: Vev-Query-Fn-Registry, ident: cstring, callback: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr registry) nil) (= ident nil) (= callback nil))
    (return false))
  (let [slot (abi-query-predicate-alloc-slot callback user)]
    (when (< slot 0)
      (return false))
    (let [ident-text (text-from-c ident)
          entries (query-fn-registry-entries-ptr registry)
          slots (query-fn-registry-predicate-slots-ptr registry)]
      (arr.push! entries^ (query-predicate-slot-entry ident-text slot))
      (arr.push! slots^ slot)
      true)))

@export
(defn vev_query_fn_registry_register_aggregate :abi "c" [registry: Vev-Query-Fn-Registry, ident: cstring, callback: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr registry) nil) (= ident nil) (= callback nil))
    (return false))
  (let [slot (abi-query-value-alloc-slot callback user)]
    (when (< slot 0)
      (return false))
    (let [ident-text (text-from-c ident)
          entries (query-fn-registry-entries-ptr registry)
          slots (query-fn-registry-aggregate-slots-ptr registry)]
      (arr.push! entries^ (query-aggregate-slot-entry ident-text slot))
      (arr.push! slots^ slot)
      true)))

@export
(defn vev_transact_edn_report_with_tx_fns :abi "c" [conn: Vev-Conn, tx-text: cstring, registry: Vev-Tx-Fn-Registry] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= tx-text nil) (= (rawptr registry) nil))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        entries (tx-fn-registry-entries-ptr registry)
        report (vev.transact-text-with-string-fns (conn-ptr conn) tx (slice entries^ 0))]
    (notify-abi-tx-listeners! conn report)
    (let [out (tx-report-handle-from-report report)]
      (abi-conn-store-tx-source (rawptr conn) tx)
      out)))

@export
(defn vev_with_edn_report_with_tx_fns :abi "c" [db: Vev-DB, tx-text: cstring, registry: Vev-Tx-Fn-Registry] -> Vev-Tx-Report
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= tx-text nil) (= (rawptr registry) nil))
    (return (Vev-Tx-Report nil)))
  (let [tx (text-from-c tx-text)
        store-ptr-value (store-db-ptr db)
        [db-ptr-value db-ok] (resident-db-ptr db)]
    (when db-ok
      (let [entries (tx-fn-registry-entries-ptr registry)
            report (vev.with-text-with-string-fns db-ptr-value^ tx (slice entries^ 0))
            out (tx-report-handle-from-report report)]
        (delete tx)
        (return out)))
    (let [entries (tx-fn-registry-source-entries-ptr registry)
          report (vev.with-store-db-report-text-with-source-string-fns store-ptr-value tx (slice entries^ 0))
          out (tx-report-handle-from-store-report report)]
      (vev.delete-store-tx-report report)
      (delete tx)
      out)))

@export
(defn vev_tx_report_free :abi "c" [report: Vev-Tx-Report]
  (odin "context = runtime.default_context()")
  (when (= (rawptr report) nil)
    (return))
  (tx-report-handle-free report))

@export
(defn vev_tx_report_array_free :abi "c" [array: Vev-Tx-Report-Array]
  (odin "context = runtime.default_context()")
