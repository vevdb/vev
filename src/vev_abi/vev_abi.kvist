abi_entity_string_int_triples_string_lengths_data :: proc(array: rawptr) -> rawptr {
    wrapper := (^ABI_Entity_String_Int_Triples)(array)
    if wrapper == nil || len(wrapper.string_lengths) == 0 {
        return nil
    }
