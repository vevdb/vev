@export
(defn vev_query_db_prepared_column_batch_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Column-Batch nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        db-ptr-value (db-ptr db)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (Vev-Column-Batch nil)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (return (column-batch-from-query-inputs db-ptr-value^ query-ptr-value^.query ([]vev.Query-Input []))))
    (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (delete inputs)
        (return (Vev-Column-Batch nil)))
      (let [out (column-batch-from-query-inputs db-ptr-value^ query-ptr-value^.query (slice inputs 0))]
        (delete inputs)
        out))))

