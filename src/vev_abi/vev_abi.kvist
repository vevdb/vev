    (set! result-ptr-value^ (vev.q-prepared-with-sources conn-ptr-value^.db query-ptr-value^ (slice inputs^ 0) (slice sources^ 0)))
    (result-finish-visit-delete (Vev-Result result) conn-ptr-value^.db stmt visitor user)))

