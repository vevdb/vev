    (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value)))

@export
(defn vev_query_db_prepared_result_with_inputs_and_fns :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring, registry: Vev-Query-Fn-Registry] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil) (= (rawptr registry) nil))
    (return (Vev-Result nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr query)
        entries (query-fn-registry-entries-ptr registry)
        result (abi-alloc-result)
        [source source-ok source-error] (vev.store-db-read-source store-ptr-value)]
    (if source-ok
      (if query-ptr-value^.ok
        (let [[inputs input-ok input-error] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
          (if input-ok
            (let [query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) query-ptr-value^ (slice inputs 0) (slice entries^ 0))]
              (vev.delete-owned-query-inputs inputs)
              (delete inputs-text-value)
              (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value))
            (let [query-result (vev.query-result-owned-values (vev.result-set-error input-error))]
              (vev.delete-owned-query-inputs inputs)
              (delete inputs-text-value)
              (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value))))
        (let [query-result (vev.query-result-owned-values (vev.result-set-error query-ptr-value^.error))]
          (delete inputs-text-value)
          (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value)))
      (let [query-result (vev.query-result-owned-values (vev.result-set-error source-error))]
        (delete inputs-text-value)
        (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value)))))

@export
(defn vev_query_relation_db_prepared_result_with_inputs :abi "c" [rows-text: cstring, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= rows-text nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Result nil)))
  (let [rows-source (text-from-c rows-text)
        inputs-source (text-from-c inputs-text)
        query-ptr-value (prepared-query-ptr query)
        result (abi-alloc-result)]
    (when (not query-ptr-value^.ok)
      (delete rows-source)
      (delete inputs-source)
      (let [query-result (vev.query-result-owned-values (vev.result-set-error query-ptr-value^.error))]
        (return (result-finish-query-result (Vev-Result result) query-result (vev.DB {})))))
    (let [[rows rows-ok rows-error] (value-from-edn-text rows-source)]
      (delete rows-source)
      (when (not rows-ok)
        (delete inputs-source)
        (let [query-result (vev.query-result-owned-values (vev.result-set-error rows-error))]
          (return (result-finish-query-result (Vev-Result result) query-result (vev.DB {})))))
      (let [[inputs input-ok input-error] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-source)]
        (delete inputs-source)
        (when (not input-ok)
          (vev.delete-owned-value rows)
          (vev.delete-owned-query-inputs inputs)
          (let [query-result (vev.query-result-owned-values (vev.result-set-error input-error))]
            (return (result-finish-query-result (Vev-Result result) query-result (vev.DB {})))))
        (let [relation-result (vev.q-query-relation-db rows query-ptr-value^.query (slice inputs 0))
              owned-result (vev.result-set-owned relation-result)]
          (vev.delete-result-set-shallow relation-result)
          (vev.delete-owned-value rows)
          (vev.delete-owned-query-inputs inputs)
          (let [ptr (result-ptr (Vev-Result result))]
            (set! ptr^ owned-result)
            (result-set-owns-values! (Vev-Result result) true)
            (Vev-Result result)))))))

@export
(defn vev_query_db_prepared_result_with_rules_text_and_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, rules-text: cstring, inputs-text: cstring] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= rules-text nil) (= inputs-text nil))
