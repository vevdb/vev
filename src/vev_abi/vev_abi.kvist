@export
(defn vev_sqlite_conn_prepared_column_batch_with_inputs :abi "c" [conn: Vev-SQLite-Conn, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil) (= inputs-text nil) (not (abi-sqlite-conn-ok (rawptr conn))))
    (return (Vev-Column-Batch nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        query-ptr-value (prepared-query-ptr query)
        store (sqlite-conn-ptr conn)
        [snapshot snapshot-ok _] (vev.sqlite-store-db-current-root-cached store)]
    (when (not snapshot-ok)
      (delete inputs-text-value)
      (return (Vev-Column-Batch nil)))
    (let [out (column-batch-from-store-db-query-inputs-text-owned (addr snapshot) query-ptr-value inputs-text-value)]
      (vev.close-store-db! (addr snapshot))
      out)))

@export
(defn vev_connection_prepared_column_batch_with_inputs :abi "c" [conn: Vev-Connection, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (vev_sqlite_conn_prepared_column_batch_with_inputs (connection-as-sqlite conn) query inputs-text))

