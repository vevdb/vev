        (delete rules-text-value)
        (delete inputs-text-value)
        (return out)))
    (let [[inputs input-ok error] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (when (not input-ok)
        (vev.delete-owned-query-inputs inputs)
        (vev.delete-prepared-rules-shallow rules)
        (delete rules-text-value)
        (delete inputs-text-value)
        (return (c-string-owned error)))
      (let [[source source-ok source-error] (vev.store-db-read-source store-ptr-value)]
        (when (not source-ok)
          (vev.delete-owned-query-inputs inputs)
          (vev.delete-prepared-rules-shallow rules)
          (delete rules-text-value)
          (delete inputs-text-value)
          (return (c-string-owned source-error)))
        (let [profiled (vev.q-prepared-db-read-source-profiled-with-rules source query-ptr-value^ rules (slice inputs 0))
              value (vev.query-stats-value profiled.stats)
              text (vev.value-serializable-text value)
              out (c-string-owned text)]
          (vev.delete-owned-query-inputs inputs)
          (vev.delete-prepared-rules-shallow rules)
          (delete rules-text-value)
          (delete inputs-text-value)
          (vev.delete-value-containers-shallow value)
          (vev.delete-profiled-result-set-shallow profiled)
          out)))))

