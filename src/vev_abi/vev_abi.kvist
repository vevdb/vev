@export
(defn vev_pull_many_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entities: rawptr, entity-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= pattern-text nil)
            (< entity-count 0)
            (and (> entity-count 0) (= entities nil)))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        ids (make [dynamic]u64 0 entity-count)
        db-ptr-value (db-ptr db)
        index 0]
    (while (< index entity-count)
      (arr.push! ids (abi-u64-at entities index))
      (set! index (+ index 1)))
    (let [pulled (vev.pull-many-text-value db-ptr-value^ pattern (slice ids 0))
          out (value-handle-from-value pulled)]
      (delete pattern)
      (delete ids)
      out)))

@export
(defn vev_pull_many_prepared :abi "c" [db: Vev-DB, pattern: Vev-Prepared-Pull-Pattern, entities: rawptr, entity-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= (rawptr pattern) nil)
            (< entity-count 0)
            (and (> entity-count 0) (= entities nil)))
    (return (Vev-Value-Handle nil)))
  (let [ids (make [dynamic]u64 0 entity-count)
        db-ptr-value (db-ptr db)
        pattern-ptr (prepared-pull-pattern-ptr pattern)
        index 0]
    (while (< index entity-count)
      (arr.push! ids (abi-u64-at entities index))
      (set! index (+ index 1)))
    (let [pulled (vev.pull-many-prepared-value db-ptr-value^ pattern-ptr^ (slice ids 0))
          out (value-handle-from-value pulled)]
      (delete ids)
      out)))

@export
(defn vev_pull_many_lookup_ref_uuid_prepared :abi "c" [db: Vev-DB, pattern: Vev-Prepared-Pull-Pattern, attr: cstring, values: rawptr, value-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= (rawptr pattern) nil)
            (= attr nil)
            (< value-count 0)
            (and (> value-count 0) (= values nil)))
    (return (Vev-Value-Handle nil)))
  (let [attr-text (text-from-c attr)
        attrs (make [dynamic]string 0 value-count)
        lookup-values (make [dynamic]vev.Value 0 value-count)
        db-ptr-value (db-ptr db)
        pattern-ptr (prepared-pull-pattern-ptr pattern)
        index 0]
    (while (< index value-count)
      (let [value-c (abi-cstring-at values index)]
        (when (= value-c nil)
          (delete attr-text)
          (delete attrs)
          (for [value lookup-values]
            (vev.delete-owned-value value))
          (delete lookup-values)
          (return (Vev-Value-Handle nil)))
        (let [value-text (text-from-c value-c)]
          (arr.push! attrs attr-text)
          (arr.push! lookup-values (vev.value-uuid value-text))))
      (set! index (+ index 1)))
    (let [pulled (vev.pull-many-prepared-lookup-refs-value db-ptr-value^ pattern-ptr^ (slice attrs 0) (slice lookup-values 0))
          out (value-handle-from-value pulled)]
      (delete attr-text)
      (delete attrs)
      (for [value lookup-values]
        (vev.delete-owned-value value))
      (delete lookup-values)
      out)))

@export
(defn vev_value_handle_free :abi "c" [handle: Vev-Value-Handle]
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return))
  (let [ptr (value-handle-value-ptr handle)]
    (vev.delete-owned-value ptr^)
    (abi-free-value-handle (rawptr handle))))

@export
(defn vev_value_handle_value :abi "c" [handle: Vev-Value-Handle] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return (Vev-Value nil)))
  (Vev-Value (rawptr (value-handle-value-ptr handle))))

@export
(defn vev_value_handle_edn :abi "c" [handle: Vev-Value-Handle] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return (c-string-owned "nil")))
  (let [ptr (value-handle-value-ptr handle)]
    (c-string-owned (vev.value-serializable-text ptr^))))

@export
(defn vev_result_free :abi "c" [result: Vev-Result]
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return))
  (result-delete-owned result))

@export
(defn vev_result_ok :abi "c" [result: Vev-Result] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return false))
  (let [ptr (result-ptr result)]
    ptr^.ok))

@export
(defn vev_result_error :abi "c" [result: Vev-Result] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (c-string-owned "null result")))
  (let [ptr (result-ptr result)]
    (c-string-owned ptr^.error)))

@export
(defn vev_result_row_count :abi "c" [result: Vev-Result] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (count ptr^.rows)))

@export
(defn vev_result_value_count :abi "c" [result: Vev-Result, row: int] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (when (or (< row 0) (>= row (count ptr^.rows)))
      (return 0))
    (count ptr^.rows[row].values)))

@export
(defn vev_result_value_kind :abi "c" [result: Vev-Result, row: int, column: int] -> int
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (int value.kind)))

@export
(defn vev_result_value :abi "c" [result: Vev-Result, row: int, column: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-result-value-ptr (rawptr result) row column)))

@export
(defn vev_result_pull_count :abi "c" [result: Vev-Result, row: int] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (when (or (< row 0) (>= row (count ptr^.rows)))
      (return 0))
    (count ptr^.rows[row].pulls)))

@export
(defn vev_result_pull :abi "c" [result: Vev-Result, row: int, pull: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-result-pull-value-ptr (rawptr result) row pull)))

@export
(defn vev_result_visit :abi "c" [result: Vev-Result, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr result) nil) (= visitor nil))
    (return false))
  (abi-result-visit (rawptr result) visitor user))

@export
(defn vev_result_value_entity :abi "c" [result: Vev-Result, row: int, column: int] -> u64
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Entity) value.entity 0)))

@export
(defn vev_result_value_int :abi "c" [result: Vev-Result, row: int, column: int] -> i64
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Int) value.int-value 0)))

@export
(defn vev_result_value_bool :abi "c" [result: Vev-Result, row: int, column: int] -> bool
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Bool) value.bool-value false)))

@export
(defn vev_result_value_text :abi "c" [result: Vev-Result, row: int, column: int] -> cstring
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (case value.kind
      .String (c-string-owned value.text)
      .Keyword (c-string-owned value.text)
      .Symbol (c-string-owned value.text)
      .Uuid (c-string-owned value.text)
      :else (c-string-owned ""))))

@export
(defn vev_result_value_text_data :abi "c" [result: Vev-Result, row: int, column: int] -> rawptr
  (odin "context = runtime.default_context()")
  (abi-value-text-data (abi-result-value-ptr (rawptr result) row column)))

@export
(defn vev_result_value_text_len :abi "c" [result: Vev-Result, row: int, column: int] -> int
  (odin "context = runtime.default_context()")
  (abi-value-text-len (abi-result-value-ptr (rawptr result) row column)))

@export
(defn vev_result_value_edn :abi "c" [result: Vev-Result, row: int, column: int] -> cstring
  (odin "context = runtime.default_context()")
  (c-string-owned (vev.value-serializable-text (result-value result row column))))

@export
(defn vev_value_kind :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (int ptr^.kind)))

@export
(defn vev_value_entity :abi "c" [value: Vev-Value] -> u64
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Entity) ptr^.entity 0)))

@export
(defn vev_value_int :abi "c" [value: Vev-Value] -> i64
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Int) ptr^.int-value 0)))

@export
(defn vev_value_float :abi "c" [value: Vev-Value] -> f64
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0.0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Float) ptr^.float-value 0.0)))

@export
(defn vev_value_bool :abi "c" [value: Vev-Value] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return false))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Bool) ptr^.bool-value false)))

@export
(defn vev_value_text :abi "c" [value: Vev-Value] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (c-string-owned "")))
  (let [ptr (value-ptr value)]
    (case ptr^.kind
      .String (c-string-owned ptr^.text)
      .Keyword (c-string-owned ptr^.text)
      .Symbol (c-string-owned ptr^.text)
      .Uuid (c-string-owned ptr^.text)
      :else (c-string-owned ""))))

@export
(defn vev_value_text_data :abi "c" [value: Vev-Value] -> rawptr
  (odin "context = runtime.default_context()")
  (abi-value-text-data (rawptr value)))

@export
(defn vev_value_text_len :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (abi-value-text-len (rawptr value)))

@export
(defn vev_value_edn :abi "c" [value: Vev-Value] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (c-string-owned "nil")))
  (let [ptr (value-ptr value)]
    (c-string-owned (vev.value-serializable-text ptr^))))

@export
(defn vev_value_item_count :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Vector) (count ptr^.items) 0)))

@export
(defn vev_value_item :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-item-ptr (rawptr value) index)))

@export
(defn vev_value_map_count :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Map) (/ (count ptr^.items) 2) 0)))

@export
(defn vev_value_map_key :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-map-key-ptr (rawptr value) index)))

@export
(defn vev_value_map_value :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-map-value-ptr (rawptr value) index)))

@export
(defn vev_value_text_equals :abi "c" [value: Vev-Value, expected: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= expected nil))
    (return false))
  (let [ptr (value-ptr value)
        expected-text (text-from-c expected)]
    (defer (delete expected-text))
    (case ptr^.kind
      .String (= ptr^.text expected-text)
      .Keyword (= ptr^.text expected-text)
      .Symbol (= ptr^.text expected-text)
      .Uuid (= ptr^.text expected-text)
      :else false)))

@export
(defn vev_value_map_get :abi "c" [value: Vev-Value, key: cstring] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= key nil))
    (return (Vev-Value nil)))
  (let [ptr (value-ptr value)
        key-text (text-from-c key)]
    (defer (delete key-text))
    (when (not (= ptr^.kind .Map))
      (return (Vev-Value nil)))
    (let [index 0]
      (while (< (+ index 1) (count ptr^.items))
        (let [item-key ptr^.items[index]]
          (when (and (or (= item-key.kind .String)
                         (= item-key.kind .Keyword)
                         (= item-key.kind .Symbol)
                         (= item-key.kind .Uuid))
                     (= item-key.text key-text))
            (return (Vev-Value (rawptr (addr ptr^.items[(+ index 1)]))))))
        (set! index (+ index 2))))
    (Vev-Value nil)))

@export
(defn vev_value_visit :abi "c" [value: Vev-Value, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= visitor nil))
    (return false))
  (abi-value-visit (rawptr value) visitor user))
