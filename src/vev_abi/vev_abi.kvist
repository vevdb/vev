@export
(defn vev_stmt_bind_string_relation :abi "c" [stmt: Vev-Stmt, values: rawptr, value-count: int, width: int] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr stmt) nil)
            (< value-count 0)
            (<= width 0)
            (not (= (% value-count width) 0))
            (and (> value-count 0) (= values nil)))
    (return false))
  (let [out (make [dynamic]vev.Value 0 value-count)
        index 0]
    (while (< index value-count)
      (let [value (abi-cstring-at values index)]
        (when (= value nil)
          (for [item out]
            (vev.delete-owned-value item))
          (delete out)
          (return false))
        (arr.push! out (vev.value-string (text-from-c value))))
      (set! index (+ index 1)))
    (stmt-push-relation! stmt out width)
    true))

