@export
(defn vev_pull_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entity: u64] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= pattern-text nil))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        db-ptr-value (db-ptr db)
        value (vev.pull-text-value db-ptr-value^ pattern entity)
        out (value-handle-from-value value)]
    (delete pattern)
    out))

@export
(defn vev_pull_lookup_ref_string_edn :abi "c" [db: Vev-DB, pattern-text: cstring, attr: cstring, value: cstring] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= pattern-text nil) (= attr nil) (= value nil))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        attr-text (text-from-c attr)
        value-text (text-from-c value)
        db-ptr-value (db-ptr db)
        pulled (vev.pull-text-lookup-ref-value db-ptr-value^ pattern attr-text (vev.value-string value-text))
        out (value-handle-from-value pulled)]
    (delete pattern)
    (delete attr-text)
    out))

@export
(defn vev_pull_many_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entities: rawptr, entity-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= pattern-text nil)
            (< entity-count 0)
            (and (> entity-count 0) (= entities nil)))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        ids (make [dynamic]u64 0 entity-count)
        db-ptr-value (db-ptr db)
        index 0]
    (while (< index entity-count)
      (arr.push! ids (abi-u64-at entities index))
      (set! index (+ index 1)))
    (let [pulled (vev.pull-many-text-value db-ptr-value^ pattern (slice ids 0))
          out (value-handle-from-value pulled)]
      (delete pattern)
      (delete ids)
      out)))

@export
(defn vev_value_handle_free :abi "c" [handle: Vev-Value-Handle]
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return))
  (let [ptr (value-handle-value-ptr handle)]
    (vev.delete-owned-value ptr^)
    (abi-free-value-handle (rawptr handle))))

@export
(defn vev_value_handle_value :abi "c" [handle: Vev-Value-Handle] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return (Vev-Value nil)))
  (Vev-Value (rawptr (value-handle-value-ptr handle))))

@export
(defn vev_value_handle_edn :abi "c" [handle: Vev-Value-Handle] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr handle) nil)
    (return (c-string-owned "nil")))
  (let [ptr (value-handle-value-ptr handle)]
    (c-string-owned (vev.value-serializable-text ptr^))))

@export
(defn vev_result_free :abi "c" [result: Vev-Result]
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return))
  (result-delete-owned result))

@export
(defn vev_result_ok :abi "c" [result: Vev-Result] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return false))
  (let [ptr (result-ptr result)]
    ptr^.ok))

@export
(defn vev_result_error :abi "c" [result: Vev-Result] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (c-string-owned "null result")))
  (let [ptr (result-ptr result)]
    (c-string-owned ptr^.error)))

@export
(defn vev_result_row_count :abi "c" [result: Vev-Result] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (count ptr^.rows)))

@export
(defn vev_result_value_count :abi "c" [result: Vev-Result, row: int] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (when (or (< row 0) (>= row (count ptr^.rows)))
      (return 0))
    (count ptr^.rows[row].values)))

@export
(defn vev_result_value_kind :abi "c" [result: Vev-Result, row: int, column: int] -> int
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (int value.kind)))

@export
(defn vev_result_value :abi "c" [result: Vev-Result, row: int, column: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-result-value-ptr (rawptr result) row column)))

@export
(defn vev_result_pull_count :abi "c" [result: Vev-Result, row: int] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return 0))
  (let [ptr (result-ptr result)]
    (when (or (< row 0) (>= row (count ptr^.rows)))
      (return 0))
    (count ptr^.rows[row].pulls)))

@export
(defn vev_result_pull :abi "c" [result: Vev-Result, row: int, pull: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr result) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-result-pull-value-ptr (rawptr result) row pull)))

@export
(defn vev_result_visit :abi "c" [result: Vev-Result, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr result) nil) (= visitor nil))
    (return false))
  (abi-result-visit (rawptr result) visitor user))

@export
(defn vev_result_value_entity :abi "c" [result: Vev-Result, row: int, column: int] -> u64
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Entity) value.entity 0)))

@export
(defn vev_result_value_int :abi "c" [result: Vev-Result, row: int, column: int] -> i64
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Int) value.int-value 0)))

@export
(defn vev_result_value_bool :abi "c" [result: Vev-Result, row: int, column: int] -> bool
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (if (= value.kind .Bool) value.bool-value false)))

@export
(defn vev_result_value_text :abi "c" [result: Vev-Result, row: int, column: int] -> cstring
  (odin "context = runtime.default_context()")
  (let [value (result-value result row column)]
    (case value.kind
      .String (c-string-owned value.text)
      .Keyword (c-string-owned value.text)
      .Symbol (c-string-owned value.text)
      :else (c-string-owned ""))))

@export
(defn vev_result_value_edn :abi "c" [result: Vev-Result, row: int, column: int] -> cstring
  (odin "context = runtime.default_context()")
  (c-string-owned (vev.value-serializable-text (result-value result row column))))

