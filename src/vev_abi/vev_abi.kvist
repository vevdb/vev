    (return false))
  (stmt-push-db-source! stmt (text-from-c name) db))

@export
(defn vev_query_stmt_result :abi "c" [conn: Vev-Conn, stmt: Vev-Stmt] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr stmt) nil))
    (return (Vev-Result nil)))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)]
    (if (> (count sources^) 0)
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))]
        (result-finish-query-result (Vev-Result result) query-result conn-ptr-value^.db))
      (let [result-ptr-value (result-ptr (Vev-Result result))]
        (set! result-ptr-value^ (vev.q-prepared-with-inputs conn-ptr-value^.db query-ptr-value^ (slice inputs^ 0)))
        (result-finish (Vev-Result result) conn-ptr-value^.db)))))

@export
(defn vev_query_db_stmt_result :abi "c" [db: Vev-DB, stmt: Vev-Stmt] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr stmt) nil))
    (return (Vev-Result nil)))
  (let [store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)
        [source source-ok source-error] (vev.store-db-read-source store-ptr-value)]
    (if source-ok
      (let [query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))]
        (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value))
      (let [query-result (vev.query-result-owned-values (vev.result-set-error source-error))]
        (result-finish-query-result-store-db (Vev-Result result) query-result store-ptr-value)))))

@export
(defn vev_query_stmt_column_batch :abi "c" [conn: Vev-Conn, stmt: Vev-Stmt] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr stmt) nil))
    (return (Vev-Column-Batch nil)))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)]
    (when (not query-ptr-value^.ok)
      (return (Vev-Column-Batch nil)))
    (when (> (count sources^) 0)
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            typed-out (column-batch-from-source-query-inputs source (slice sources^ 0) query-ptr-value^.query (slice inputs^ 0))]
        (when (not (= (rawptr typed-out) nil))
          (return typed-out)))
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))
            out (column-batch-from-result query-result.result)]
        (vev.delete-query-result query-result)
        (return out)))
    (column-batch-from-query-inputs conn-ptr-value^.db query-ptr-value^.query (slice inputs^ 0))))

@export
(defn vev_query_prepared_column_batch_with_inputs :abi "c" [conn: Vev-Conn, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Column-Batch nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (Vev-Column-Batch nil)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (let [typed-out (column-batch-from-query-inputs conn-ptr-value^.db query-ptr-value^.query ([]vev.Query-Input []))]
        (when (not (= (rawptr typed-out) nil))
          (return typed-out)))
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            query-result (vev.q-result-prepared-db-read-source source query-ptr-value^)
            out (column-batch-from-result query-result.result)]
        (vev.delete-query-result query-result)
        (return out)))
    (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (vev.delete-owned-query-inputs inputs)
        (return (Vev-Column-Batch nil)))
      (let [typed-out (column-batch-from-query-inputs conn-ptr-value^.db query-ptr-value^.query (slice inputs 0))]
        (when (not (= (rawptr typed-out) nil))
          (vev.delete-owned-query-inputs inputs)
          (return typed-out)))
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            query-result (vev.q-result-prepared-db-read-source-with-inputs source query-ptr-value^ (slice inputs 0))
            out (column-batch-from-result query-result.result)]
        (vev.delete-owned-query-inputs inputs)
        (vev.delete-query-result query-result)
        out))))

@export
(defn vev_query_db_stmt_column_batch :abi "c" [db: Vev-DB, stmt: Vev-Stmt] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr stmt) nil))
    (return (Vev-Column-Batch nil)))
  (let [store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)]
    (when (not query-ptr-value^.ok)
      (return (Vev-Column-Batch nil)))
    (let [[source source-ok _] (vev.store-db-read-source store-ptr-value)]
      (when (not source-ok)
        (return (Vev-Column-Batch nil)))
      (let [typed-out (column-batch-from-source-query-inputs source (slice sources^ 0) query-ptr-value^.query (slice inputs^ 0))]
        (when (not (= (rawptr typed-out) nil))
          (return typed-out)))
      (let [query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))
            out (column-batch-from-result query-result.result)]
        (vev.delete-query-result query-result)
        out))))

@export
(defn vev_query_stmt_visit :abi "c" [conn: Vev-Conn, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr stmt) nil) (= visitor nil))
    (return false))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)]
    (if (> (count sources^) 0)
      (let [source (vev.resident-db-read-source (addr conn-ptr-value^.db))
            query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))]
        (result-finish-query-result-visit-delete (Vev-Result result) query-result conn-ptr-value^.db stmt visitor user))
      (let [result-ptr-value (result-ptr (Vev-Result result))]
        (set! result-ptr-value^ (vev.q-prepared-with-inputs conn-ptr-value^.db query-ptr-value^ (slice inputs^ 0)))
        (result-finish-visit-delete (Vev-Result result) conn-ptr-value^.db stmt visitor user)))))

@export
(defn vev_query_db_stmt_visit :abi "c" [db: Vev-DB, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr stmt) nil) (= visitor nil))
    (return false))
  (let [store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)
        [source source-ok source-error] (vev.store-db-read-source store-ptr-value)]
    (if source-ok
      (let [query-result (vev.q-result-prepared-db-read-source-with-sources-inputs-and-fns source (slice sources^ 0) query-ptr-value^ (slice inputs^ 0) ([]vev.Native-Query-Fn []))]
        (result-finish-query-result-store-db-visit-delete (Vev-Result result) query-result store-ptr-value stmt visitor user))
      (let [query-result (vev.query-result-owned-values (vev.result-set-error source-error))]
        (result-finish-query-result-store-db-visit-delete (Vev-Result result) query-result store-ptr-value stmt visitor user)))))

@export
(defn vev_query_prepared :abi "c" [conn: Vev-Conn, query: Vev-Prepared-Query] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil))
    (return (c-string-owned "[:vev/error \"null conn or prepared query\"]")))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr query)
        value (vev.q-prepared-value conn-ptr-value^.db query-ptr-value^)
        text (vev.value-serializable-text value)
        out (c-string-owned text)]
    out))

@export
(defn vev_query_prepared_with_inputs :abi "c" [conn: Vev-Conn, query: Vev-Prepared-Query, inputs-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (c-string-owned "[:vev/error \"null conn, prepared query, or inputs\"]")))
  (let [inputs (text-from-c inputs-text)
        conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr query)
        value (vev.q-prepared-value-with-input-text conn-ptr-value^.db query-ptr-value^ inputs)
        text (vev.value-serializable-text value)
        out (c-string-owned text)]
    (delete inputs)
    out))

@export
(defn vev_query_prepared_result_with_inputs :abi "c" [conn: Vev-Conn, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Result nil)))
  (let [inputs (text-from-c inputs-text)
        conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr query)
        result (abi-alloc-result)
        result-ptr-value (result-ptr (Vev-Result result))]
    (set! result-ptr-value^ (vev.q-prepared-with-input-text conn-ptr-value^.db query-ptr-value^ inputs))
    (delete inputs)
    (result-finish (Vev-Result result) conn-ptr-value^.db)))

@export
(defn vev_query_prepared_result_with_rules_text_and_inputs :abi "c" [conn: Vev-Conn, query: Vev-Prepared-Query, rules-text: cstring, inputs-text: cstring] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr query) nil) (= rules-text nil) (= inputs-text nil))
    (return (Vev-Result nil)))
  (let [rules-text-value (text-from-c rules-text)
        inputs-text-value (text-from-c inputs-text)
        conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr query)
        rules (vev.parse-rules-text rules-text-value)
        result (abi-alloc-result)
        result-ptr-value (result-ptr (Vev-Result result))]
    (if query-ptr-value^.ok
      (let [[inputs input-ok input-error] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
        (if input-ok
          (set! result-ptr-value^ (vev.q-prepared-with-rules conn-ptr-value^.db query-ptr-value^ rules (slice inputs 0)))
          (set! result-ptr-value^ (vev.result-set-error input-error)))
        (vev.delete-owned-query-inputs inputs))
      (set! result-ptr-value^ (vev.result-set-error query-ptr-value^.error)))
    (vev.delete-prepared-rules-shallow rules)
    (delete rules-text-value)
    (delete inputs-text-value)
    (result-finish (Vev-Result result) conn-ptr-value^.db)))

@export
(defn vev_query_db_prepared_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (c-string-owned "[:vev/error \"null db, prepared query, or inputs\"]")))
  (let [inputs (text-from-c inputs-text)
        store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr query)
        query-result (vev.q-result-store-db-prepared-with-input-text store-ptr-value query-ptr-value^ inputs)]
    (delete inputs)
    (if query-result.result.ok
      (let [[value value-ok value-error] (vev.store-db-result-value store-ptr-value query-result.result)]
        (if value-ok
          (let [owned-value (vev.value-owned value)
                text (vev.value-serializable-text owned-value)
                out (c-string-owned text)]
            (delete text)
            (vev.delete-owned-value owned-value)
            (vev.delete-query-result query-result)
            out)
          (let [error-value (vev.value-map
                              ([]vev.Value [(vev.value-keyword (string-owned ":ok")) (vev.value-bool false)
                                            (vev.value-keyword (string-owned ":error")) (vev.value-string (string-owned value-error))]))
                text (vev.value-serializable-text error-value)
                out (c-string-owned text)]
            (delete text)
            (vev.delete-owned-value error-value)
            (vev.delete-query-result query-result)
            out)))
      (let [error-value (vev.value-map
                          ([]vev.Value [(vev.value-keyword (string-owned ":ok")) (vev.value-bool false)
                                        (vev.value-keyword (string-owned ":error")) (vev.value-string (string-owned query-result.result.error))]))
            text (vev.value-serializable-text error-value)
            out (c-string-owned text)]
        (delete text)
        (vev.delete-owned-value error-value)
        (vev.delete-query-result query-result)
        out))))

@export
(defn vev_query_db_prepared_result_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
