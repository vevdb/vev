@export
(defn vev_pull_many_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entities: rawptr, entity-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= pattern-text nil)
            (< entity-count 0)
            (and (> entity-count 0) (= entities nil)))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        ids (make [dynamic]u64 0 entity-count)
        store-ptr-value (store-db-ptr db)
        index 0]
    (while (< index entity-count)
      (arr.push! ids (abi-u64-at entities index))
      (set! index (+ index 1)))
    (let [[pulled pulled-ok _] (vev.pull-many-store-db-value-text store-ptr-value pattern (slice ids 0))
          out (if pulled-ok
                (value-handle-from-value pulled)
                (Vev-Value-Handle nil))]
      (delete pattern)
      (delete ids)
      out)))

