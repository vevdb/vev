@export
(defn vev_query_db_prepared_entity_int_pairs_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Entity-Int-Pairs
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Entity-Int-Pairs nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        db-ptr-value (db-ptr db)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (Vev-Entity-Int-Pairs nil)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (let [[columns pair-ok] (vev.q-query-entity-int-pair-columns db-ptr-value^ query-ptr-value^.query ([]vev.Query-Input []))]
        (when (not pair-ok)
          (vev.delete-entity-int-pair-columns columns)
          (return (Vev-Entity-Int-Pairs nil)))
        (return (Vev-Entity-Int-Pairs (abi-alloc-entity-int-pairs columns)))))
    (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (delete inputs)
        (return (Vev-Entity-Int-Pairs nil)))
      (let [[columns pair-ok] (vev.q-query-entity-int-pair-columns db-ptr-value^ query-ptr-value^.query (slice inputs 0))]
        (delete inputs)
        (when (not pair-ok)
          (vev.delete-entity-int-pair-columns columns)
          (return (Vev-Entity-Int-Pairs nil)))
        (Vev-Entity-Int-Pairs (abi-alloc-entity-int-pairs columns))))))

@export
(defn vev_query_db_prepared_profile_edn_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (c-string-owned "[:vev/error \"null db, query, or inputs\"]")))
  (let [inputs-text-value (text-from-c inputs-text)
        db-ptr-value (db-ptr db)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (c-string-owned query-ptr-value^.error)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (let [profiled (vev.q-prepared-profiled db-ptr-value^ query-ptr-value^)
            value (vev.query-stats-value profiled.stats)
            text (vev.value-serializable-text value)
            out (c-string-owned text)]
        (vev.delete-value-containers-shallow value)
        (vev.delete-profiled-result-set-shallow profiled)
        (return out)))
    (let [[inputs input-ok error] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (delete inputs)
        (return (c-string-owned error)))
      (let [profiled (vev.q-prepared-profiled-with-inputs db-ptr-value^ query-ptr-value^ (slice inputs 0))
            value (vev.query-stats-value profiled.stats)
            text (vev.value-serializable-text value)
            out (c-string-owned text)]
        (delete inputs)
        (vev.delete-value-containers-shallow value)
        (vev.delete-profiled-result-set-shallow profiled)
        out))))

