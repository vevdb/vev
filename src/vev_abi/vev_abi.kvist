@export
(defn vev_stmt_bind_lookup_ref_string_collection :abi "c" [stmt: Vev-Stmt, attr: cstring, values: rawptr, value-count: int] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr stmt) nil)
            (= attr nil)
            (< value-count 0)
            (and (> value-count 0) (= values nil)))
    (return false))
  (let [attrs (make [dynamic]string 0 value-count)
        out (make [dynamic]vev.Value 0 value-count)
        index 0]
    (while (< index value-count)
      (let [value (abi-cstring-at values index)]
        (when (= value nil)
          (for [item attrs]
            (delete item))
          (for [item out]
            (vev.delete-owned-value item))
          (delete attrs)
          (delete out)
          (return false))
        (arr.push! attrs (text-from-c attr))
        (arr.push! out (vev.value-string (text-from-c value))))
      (set! index (+ index 1)))
    (stmt-push-lookup-ref-collection! stmt attrs out)
    true))

@export
(defn vev_stmt_bind_pull_pattern_edn :abi "c" [stmt: Vev-Stmt, pattern-text: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr stmt) nil) (= pattern-text nil))
    (return false))
  (let [pattern-source (text-from-c pattern-text)
        [pattern ok _] (vev.parse-pull-pattern-text pattern-source)]
    (when (not ok)
      (delete-pull-spec-containers (slice pattern 0))
      (delete pattern)
      (delete pattern-source)
      (return false))
    (let [sources (stmt-pull-pattern-sources-ptr stmt)]
      (arr.push! sources^ pattern-source))
    (stmt-push-pull-pattern! stmt pattern)
    true))

@export
(defn vev_stmt_bind_db_source :abi "c" [stmt: Vev-Stmt, name: cstring, db: Vev-DB] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr stmt) nil) (= name nil) (= (rawptr db) nil))
    (return false))
  (stmt-push-db-source! stmt (text-from-c name) db)
  true)

@export
(defn vev_query_stmt_result :abi "c" [conn: Vev-Conn, stmt: Vev-Stmt] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr stmt) nil))
    (return (Vev-Result nil)))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)
        result-ptr-value (result-ptr (Vev-Result result))]
    (set! result-ptr-value^ (vev.q-prepared-with-sources conn-ptr-value^.db query-ptr-value^ (slice inputs^ 0) (slice sources^ 0)))
    (result-finish (Vev-Result result) conn-ptr-value^.db)))

@export
(defn vev_query_db_stmt_result :abi "c" [db: Vev-DB, stmt: Vev-Stmt] -> Vev-Result
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr stmt) nil))
    (return (Vev-Result nil)))
  (let [db-ptr-value (db-ptr db)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)
        result-ptr-value (result-ptr (Vev-Result result))]
    (set! result-ptr-value^ (vev.q-prepared-with-sources db-ptr-value^ query-ptr-value^ (slice inputs^ 0) (slice sources^ 0)))
    (result-finish (Vev-Result result) db-ptr-value^)))

@export
(defn vev_query_stmt_visit :abi "c" [conn: Vev-Conn, stmt: Vev-Stmt, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= (rawptr stmt) nil) (= visitor nil))
    (return false))
  (let [conn-ptr-value (conn-ptr conn)
        query-ptr-value (prepared-query-ptr (stmt-query stmt))
        inputs (stmt-inputs-ptr stmt)
        sources (stmt-sources-ptr stmt)
        result (abi-alloc-result)
        result-ptr-value (result-ptr (Vev-Result result))]
    (set! result-ptr-value^ (vev.q-prepared-with-sources conn-ptr-value^.db query-ptr-value^ (slice inputs^ 0) (slice sources^ 0)))
    (result-finish-visit-delete (Vev-Result result) conn-ptr-value^.db stmt visitor user)))

