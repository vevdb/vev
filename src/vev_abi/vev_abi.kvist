@export
(defn vev_pull_many_lookup_ref_string_edn :abi "c" [db: Vev-DB, pattern-text: cstring, attr: cstring, values: rawptr, value-count: int] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil)
            (= pattern-text nil)
            (= attr nil)
            (< value-count 0)
            (and (> value-count 0) (= values nil)))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        attr-text (text-from-c attr)
        attrs (make [dynamic]string 0 value-count)
        lookup-values (make [dynamic]vev.Value 0 value-count)
        store-ptr-value (store-db-ptr db)
        index 0]
    (while (< index value-count)
      (let [value-c (abi-cstring-at values index)]
        (when (= value-c nil)
          (delete pattern)
          (delete attr-text)
          (delete attrs)
          (for [value lookup-values]
            (vev.delete-owned-value value))
          (delete lookup-values)
          (return (Vev-Value-Handle nil)))
        (let [value-text (text-from-c value-c)]
          (arr.push! attrs attr-text)
          (arr.push! lookup-values (vev.value-string value-text))))
      (set! index (+ index 1)))
    (let [[pulled pulled-ok _] (vev.pull-many-store-db-lookup-refs-value-text store-ptr-value pattern (slice attrs 0) (slice lookup-values 0))
          out (if pulled-ok
                (value-handle-from-value pulled)
                (Vev-Value-Handle nil))]
      (delete pattern)
      (delete attr-text)
      (delete attrs)
      (for [value lookup-values]
        (vev.delete-owned-value value))
      (delete lookup-values)
      out)))

