(defn vev_query_db_prepared_profile_edn_with_rules_text_and_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, rules-text: cstring, inputs-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= rules-text nil) (= inputs-text nil))
    (return (c-string-owned "[:vev/error \"null db, query, rules, or inputs\"]")))
  (let [rules-text-value (text-from-c rules-text)
        inputs-text-value (text-from-c inputs-text)
        store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr query)
        rules (vev.parse-rules-text rules-text-value)]
    (when (not query-ptr-value^.ok)
      (vev.delete-prepared-rules-shallow rules)
      (delete rules-text-value)
      (delete inputs-text-value)
      (return (c-string-owned query-ptr-value^.error)))
    (when (not rules.ok)
      (let [out (c-string-owned rules.error)]
