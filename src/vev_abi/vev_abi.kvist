@export
(defn vev_query_edn :abi "c" [conn: Vev-Conn, query-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= query-text nil))
    (return (c-string-owned "[:vev/error \"null conn or query\"]")))
  (let [query (text-from-c query-text)
        ptr (conn-ptr conn)
        value (vev.q-text-value ptr^.db query)
        text (vev.value-serializable-text value)
        out (c-string-owned text)]
    (delete query)
    out))

@export
(defn vev_query_edn_with_inputs :abi "c" [conn: Vev-Conn, query-text: cstring, inputs-text: cstring] -> cstring
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr conn) nil) (= query-text nil) (= inputs-text nil))
    (return (c-string-owned "[:vev/error \"null conn, query, or inputs\"]")))
  (let [query (text-from-c query-text)
        inputs (text-from-c inputs-text)
        ptr (conn-ptr conn)
        value (vev.q-text-value-with-input-text ptr^.db query inputs)
        text (vev.value-serializable-text value)
        out (c-string-owned text)]
    (delete query)
    (delete inputs)
    out))

@export
(defn vev_prepare_query_edn :abi "c" [query-text: cstring] -> Vev-Prepared-Query
  (odin "context = runtime.default_context()")
  (when (= query-text nil)
    (return (Vev-Prepared-Query nil)))
  (let [query (text-from-c query-text)
        prepared (abi-alloc-prepared-query query)
        ptr (prepared-query-ptr (Vev-Prepared-Query prepared))]
    (set! ptr^ (vev.prepare-query-text query))
    (Vev-Prepared-Query prepared)))

@export
(defn vev_prepare_query_edn_with_sources :abi "c" [query-text: cstring, source-names: rawptr, source-count: int] -> Vev-Prepared-Query
  (odin "context = runtime.default_context()")
  (when (or (= query-text nil)
            (< source-count 0)
            (and (> source-count 0) (= source-names nil)))
    (return (Vev-Prepared-Query nil)))
  (let [query (text-from-c query-text)
        sources (make [dynamic]vev.DB-Source 0 source-count)
        index 0]
    (while (< index source-count)
      (let [name (abi-cstring-at source-names index)]
        (when (= name nil)
          (for [source sources]
            (delete source.name))
          (delete sources)
          (delete query)
          (return (Vev-Prepared-Query nil)))
        (arr.push! sources (vev.db-source (text-from-c name) (vev.DB {}))))
      (set! index (+ index 1)))
    (let [prepared (abi-alloc-prepared-query query)
          ptr (prepared-query-ptr (Vev-Prepared-Query prepared))]
      (set! ptr^ (vev.prepare-query-text-with-sources query (slice sources 0)))
      (for [source sources]
        (delete source.name))
      (delete sources)
      (Vev-Prepared-Query prepared))))

@export
(defn vev_prepared_query_free :abi "c" [query: Vev-Prepared-Query]
  (odin "context = runtime.default_context()")
  (when (= (rawptr query) nil)
    (return))
  (let [ptr (prepared-query-ptr query)]
    (vev.delete-prepared-query-shallow ptr^)
    (abi-free-prepared-query (rawptr query))))

@export
(defn vev_prepared_query_ok :abi "c" [query: Vev-Prepared-Query] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr query) nil)
    (return false))
  (let [ptr (prepared-query-ptr query)]
    ptr^.ok))

@export
(defn vev_prepared_query_error :abi "c" [query: Vev-Prepared-Query] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr query) nil)
    (return (c-string-owned "null prepared query")))
  (let [ptr (prepared-query-ptr query)]
    (c-string-owned ptr^.error)))

@export
(defn vev_prepare_pull_pattern_edn :abi "c" [pattern-text: cstring] -> Vev-Prepared-Pull-Pattern
  (odin "context = runtime.default_context()")
  (when (= pattern-text nil)
    (return (Vev-Prepared-Pull-Pattern nil)))
  (let [source (text-from-c pattern-text)
        prepared (abi-alloc-prepared-pull-pattern source)
        ptr (prepared-pull-pattern-ptr (Vev-Prepared-Pull-Pattern prepared))]
    (set! ptr^ (vev.prepare-pull-pattern-text source))
    (Vev-Prepared-Pull-Pattern prepared)))

@export
(defn vev_prepared_pull_pattern_free :abi "c" [pattern: Vev-Prepared-Pull-Pattern]
  (odin "context = runtime.default_context()")
  (when (= (rawptr pattern) nil)
    (return))
  (let [ptr (prepared-pull-pattern-ptr pattern)]
    (delete ptr^.pattern)
    (when (> (count ptr^.error) 0)
      (delete ptr^.error))
    (abi-free-prepared-pull-pattern (rawptr pattern))))

@export
(defn vev_prepared_pull_pattern_ok :abi "c" [pattern: Vev-Prepared-Pull-Pattern] -> bool
  (odin "context = runtime.default_context()")
  (when (= (rawptr pattern) nil)
    (return false))
  (let [ptr (prepared-pull-pattern-ptr pattern)]
    ptr^.ok))

@export
(defn vev_prepared_pull_pattern_error :abi "c" [pattern: Vev-Prepared-Pull-Pattern] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr pattern) nil)
    (return (c-string-owned "null prepared pull pattern")))
  (let [ptr (prepared-pull-pattern-ptr pattern)]
    (c-string-owned ptr^.error)))

