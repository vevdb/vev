@export
(defn vev_pull_edn :abi "c" [db: Vev-DB, pattern-text: cstring, entity: u64] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= pattern-text nil))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        store-ptr-value (store-db-ptr db)
        [value value-ok _] (vev.pull-store-db-value-text store-ptr-value pattern entity)
        out (if value-ok
              (value-handle-from-value value)
              (Vev-Value-Handle nil))]
    (delete pattern)
    out))

@export
(defn vev_pull_prepared :abi "c" [db: Vev-DB, pattern: Vev-Prepared-Pull-Pattern, entity: u64] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr pattern) nil))
    (return (Vev-Value-Handle nil)))
  (let [store-ptr-value (store-db-ptr db)
        pattern-ptr (prepared-pull-pattern-ptr pattern)
        [value value-ok _] (vev.pull-store-db-value-prepared store-ptr-value pattern-ptr^ entity)]
    (if value-ok
      (value-handle-from-value value)
      (Vev-Value-Handle nil))))

@export
(defn vev_pull_lookup_ref_string_edn :abi "c" [db: Vev-DB, pattern-text: cstring, attr: cstring, value: cstring] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= pattern-text nil) (= attr nil) (= value nil))
    (return (Vev-Value-Handle nil)))
  (let [pattern (text-from-c pattern-text)
        attr-text (text-from-c attr)
        value-text (text-from-c value)
        store-ptr-value (store-db-ptr db)
        [pulled pulled-ok _] (vev.pull-store-db-lookup-ref-value-text store-ptr-value pattern attr-text (vev.value-string value-text))
        out (if pulled-ok
              (value-handle-from-value pulled)
              (Vev-Value-Handle nil))]
    (delete pattern)
    (delete attr-text)
    (delete value-text)
    out))

@export
(defn vev_pull_lookup_ref_string_prepared :abi "c" [db: Vev-DB, pattern: Vev-Prepared-Pull-Pattern, attr: cstring, value: cstring] -> Vev-Value-Handle
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr pattern) nil) (= attr nil) (= value nil))
