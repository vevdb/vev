        result-ptr-value (result-ptr (Vev-Result result))]
    (set! result-ptr-value^ (vev.q-prepared-with-input-text conn-ptr-value^.db query-ptr-value^ inputs))
    (delete inputs)
    (result-finish (Vev-Result result) conn-ptr-value^.db)))

