@export
(defn vev_value_text_len :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (abi-value-text-len (rawptr value)))

@export
(defn vev_value_edn :abi "c" [value: Vev-Value] -> cstring
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (c-string-owned "nil")))
  (let [ptr (value-ptr value)]
    (c-string-owned (vev.value-serializable-text ptr^))))

@export
(defn vev_value_item_count :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (or (= ptr^.kind .Vector)
            (= ptr^.kind .Set))
      (count ptr^.items)
      0)))

@export
(defn vev_value_item :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-item-ptr (rawptr value) index)))

@export
(defn vev_value_map_count :abi "c" [value: Vev-Value] -> int
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return 0))
  (let [ptr (value-ptr value)]
    (if (= ptr^.kind .Map) (/ (count ptr^.items) 2) 0)))

@export
(defn vev_value_map_key :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-map-key-ptr (rawptr value) index)))

@export
(defn vev_value_map_value :abi "c" [value: Vev-Value, index: int] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (= (rawptr value) nil)
    (return (Vev-Value nil)))
  (Vev-Value (abi-value-map-value-ptr (rawptr value) index)))

@export
(defn vev_value_text_equals :abi "c" [value: Vev-Value, expected: cstring] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= expected nil))
    (return false))
  (let [ptr (value-ptr value)
        expected-text (text-from-c expected)]
    (defer (delete expected-text))
    (case ptr^.kind
      .String
        (= ptr^.text expected-text)
      .Keyword
        (= ptr^.text expected-text)
      .Symbol
        (= ptr^.text expected-text)
      .Uuid
        (= ptr^.text expected-text)
      false)))

@export
(defn vev_value_map_get :abi "c" [value: Vev-Value, key: cstring] -> Vev-Value
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= key nil))
    (return (Vev-Value nil)))
  (let [ptr (value-ptr value)
        key-text (text-from-c key)]
    (defer (delete key-text))
    (when (not (= ptr^.kind .Map))
      (return (Vev-Value nil)))
    (let [index 0]
      (while (< (+ index 1) (count ptr^.items))
        (let [item-key ptr^.items[index]]
          (when (and (or (= item-key.kind .String)
                         (= item-key.kind .Keyword)
                         (= item-key.kind .Symbol)
                         (= item-key.kind .Uuid))
                     (= item-key.text key-text))
            (return (Vev-Value (rawptr (addr ptr^.items[(+ index 1)]))))))
        (set! index (+ index 2))))
    (Vev-Value nil)))

@export
(defn vev_value_visit :abi "c" [value: Vev-Value, visitor: rawptr, user: rawptr] -> bool
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr value) nil) (= visitor nil))
    (return false))
  (abi-value-visit (rawptr value) visitor user))
