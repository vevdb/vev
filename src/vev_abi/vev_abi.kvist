@export
(defn vev_query_db_prepared_entity_string_int_triples_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Entity-String-Int-Triples
  (odin "context = runtime.default_context()")
  (when (or (= (rawptr db) nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Entity-String-Int-Triples nil)))
  (let [inputs-text-value (text-from-c inputs-text)
        store-ptr-value (store-db-ptr db)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete inputs-text-value)
      (return (Vev-Entity-String-Int-Triples nil)))
    (let [[source source-ok _] (vev.store-db-read-source store-ptr-value)]
      (when (not source-ok)
        (delete inputs-text-value)
        (return (Vev-Entity-String-Int-Triples nil)))
      (when (= inputs-text-value "[]")
        (delete inputs-text-value)
        (let [typed-out (column-batch-from-source-query-inputs source ([]vev.DB-Read-Named-Source []) query-ptr-value^.query ([]vev.Query-Input []))
              out (entity-string-int-triples-from-column-batch typed-out)]
          (abi-free-column-batch (rawptr typed-out))
          (when (not (= (rawptr out) nil))
            (return out)))
        (let [query-result (vev.q-result-prepared-db-read-source source query-ptr-value^)
              out (entity-string-int-triples-from-result query-result.result)]
          (vev.delete-query-result query-result)
          (return out)))
      (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
        (delete inputs-text-value)
        (when (not input-ok)
          (vev.delete-owned-query-inputs inputs)
          (return (Vev-Entity-String-Int-Triples nil)))
        (let [typed-out (column-batch-from-source-query-inputs source ([]vev.DB-Read-Named-Source []) query-ptr-value^.query (slice inputs 0))
              out (entity-string-int-triples-from-column-batch typed-out)]
          (abi-free-column-batch (rawptr typed-out))
          (when (not (= (rawptr out) nil))
            (vev.delete-owned-query-inputs inputs)
            (return out)))
        (let [query-result (vev.q-result-prepared-db-read-source-with-inputs source query-ptr-value^ (slice inputs 0))
              out (entity-string-int-triples-from-result query-result.result)]
      (vev.delete-owned-query-inputs inputs)
      (vev.delete-query-result query-result)
      out)))))

(defn- column-batch-from-store-db-query-inputs-text-owned [store-ptr-value: ^vev.Store-DB, query-ptr-value: ^vev.Prepared-Query, inputs-text-value: string] -> Vev-Column-Batch
  (when (not query-ptr-value^.ok)
    (delete inputs-text-value)
    (return (Vev-Column-Batch nil)))
  (let [[source source-ok _] (vev.store-db-read-source store-ptr-value)]
    (when (not source-ok)
      (delete inputs-text-value)
      (return (Vev-Column-Batch nil)))
    (when (= inputs-text-value "[]")
      (delete inputs-text-value)
      (let [typed-out (column-batch-from-source-query-inputs source ([]vev.DB-Read-Named-Source []) query-ptr-value^.query ([]vev.Query-Input []))]
        (when (not (= (rawptr typed-out) nil))
          (return typed-out)))
      (let [query-result (vev.q-result-prepared-db-read-source source query-ptr-value^)
            out (column-batch-from-result query-result.result)]
        (vev.delete-query-result query-result)
        (return out)))
    (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-text-value)]
      (delete inputs-text-value)
      (when (not input-ok)
        (vev.delete-owned-query-inputs inputs)
        (return (Vev-Column-Batch nil)))
      (let [typed-out (column-batch-from-source-query-inputs source ([]vev.DB-Read-Named-Source []) query-ptr-value^.query (slice inputs 0))]
        (when (not (= (rawptr typed-out) nil))
          (vev.delete-owned-query-inputs inputs)
          (return typed-out)))
      (let [query-result (vev.q-result-prepared-db-read-source-with-inputs source query-ptr-value^ (slice inputs 0))
            out (column-batch-from-result query-result.result)]
        (vev.delete-owned-query-inputs inputs)
        (vev.delete-query-result query-result)
        out))))

@export
(defn vev_query_relation_db_prepared_column_batch_with_inputs :abi "c" [rows-text: cstring, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
  (when (or (= rows-text nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (Vev-Column-Batch nil)))
  (let [rows-source (text-from-c rows-text)
        inputs-source (text-from-c inputs-text)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete rows-source)
      (delete inputs-source)
      (return (Vev-Column-Batch nil)))
    (let [[rows rows-ok _] (value-from-edn-text rows-source)]
      (delete rows-source)
      (when (not rows-ok)
        (delete inputs-source)
        (return (Vev-Column-Batch nil)))
      (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-source)]
        (delete inputs-source)
        (when (not input-ok)
          (vev.delete-owned-value rows)
          (vev.delete-owned-query-inputs inputs)
          (return (Vev-Column-Batch nil)))
        (let [relation-result (vev.q-query-relation-db rows query-ptr-value^.query (slice inputs 0))
              out (column-batch-from-result relation-result)]
          (vev.delete-result-set-shallow relation-result)
          (vev.delete-owned-value rows)
          (vev.delete-owned-query-inputs inputs)
          out)))))

@export
(defn vev_query_relation_db_prepared_row_count_with_inputs :abi "c" [rows-text: cstring, query: Vev-Prepared-Query, inputs-text: cstring] -> i64
  (odin "context = runtime.default_context()")
  (when (or (= rows-text nil) (= (rawptr query) nil) (= inputs-text nil))
    (return (i64 -1)))
  (let [rows-source (text-from-c rows-text)
        inputs-source (text-from-c inputs-text)
        query-ptr-value (prepared-query-ptr query)]
    (when (not query-ptr-value^.ok)
      (delete rows-source)
      (delete inputs-source)
      (return (i64 -1)))
    (let [[rows rows-ok _] (value-from-edn-text rows-source)]
      (delete rows-source)
      (when (not rows-ok)
        (delete inputs-source)
        (return (i64 -1)))
      (let [[inputs input-ok _] (vev.parse-query-inputs-text-for-query query-ptr-value^.query inputs-source)]
        (delete inputs-source)
        (when (not input-ok)
          (vev.delete-owned-value rows)
          (vev.delete-owned-query-inputs inputs)
          (return (i64 -1)))
        (let [source (vev.primary-relation-db-source-name)
              relation-query (vev.relation-db-query query-ptr-value^.query source)
              relation-inputs (arr.into [dynamic]vev.Query-Input (slice inputs 0)) :defer
              empty-datoms (make [dynamic]vev.Datom)
              empty (vev.build-db empty-datoms)
              stats (vev.Query-Stats {})]
          (if (= rows.kind .Map)
            (arr.push! relation-inputs (vev.query-input-map-relation rows))
            (arr.push! relation-inputs (vev.query-input-scalar rows)))
          (let [rel (vev.relation-engine-relation-profiled empty relation-query (slice relation-inputs 0) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr stats))
                [row-count count-ok] (vev.typed-flat-result-row-count relation-query rel)]
            (vev.delete-query-relation rel)
            (delete empty-datoms)
            (delete empty.current)
            (delete empty.eavt)
            (delete empty.aevt)
            (delete empty.avet)
            (delete empty.vaet)
            (vev.delete-owned-value rows)
            (vev.delete-owned-query-inputs inputs)
            (if count-ok
              (return (i64 row-count))
              (return (i64 -1)))))))))

@export
(defn vev_query_db_prepared_column_batch_with_inputs :abi "c" [db: Vev-DB, query: Vev-Prepared-Query, inputs-text: cstring] -> Vev-Column-Batch
  (odin "context = runtime.default_context()")
