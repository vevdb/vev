(package vev)

(import arr "kvist:arr")
(import math "core:math")
(import strings "core:strings")

(defenum Value-Kind [
  Nil
  Entity
  String
  Int
  Float
  Bool
  Keyword
  Vector
  Map
])

(defstruct Value {
  kind: Value-Kind
  entity: u64
  text: string
  int_value: i64
  float_value: f64
  bool_value: bool
  items: [dynamic]Value
})

(defenum Term-Kind [
  Value
  Var
  Wildcard
  LookupRef
])

(defstruct Term {
  kind: Term-Kind
  value: Value
  name: string
  lookup_attr: string
  lookup_value: Value
})

(defstruct Datom {
  e: u64
  a: string
  v: Value
  tx: u64
  added: bool
})

(defstruct Datom-Result {
  found: bool
  datom: Datom
})

(defstruct DB {
  datoms: [dynamic]Datom
  current: [dynamic]int
  eavt: [dynamic]int
  aevt: [dynamic]int
  avet: [dynamic]int
  vaet: [dynamic]int
})

(defstruct Conn {
  db: DB
  next_tx: u64
})

(defenum Tx-Op-Kind [
  Add
  Retract
])

(defstruct Tx-Op {
  kind: Tx-Op-Kind
  e: u64
  a: string
  v: Value
  derived: bool
})

(defstruct Tx-Data {
  op: string
  e: u64
  tempid: string
  has_tempid: bool
  lookup_attr: string
  lookup_value: Value
  has_lookup_ref: bool
  ident: string
  has_ident: bool
  a: string
  v: Value
  expected: Value
  expected_lookup_attr: string
  expected_lookup_value: Value
  has_expected_lookup_ref: bool
  value_tempid: string
  has_value_tempid: bool
  value_lookup_attr: string
  value_lookup_value: Value
  has_value_lookup_ref: bool
})

(defstruct Tempid {
  tempid: string
  e: u64
})

(defstruct Resolved-Tx {
  ok: bool
  error: string
  ops: [dynamic]Tx-Op
  tx_meta: [dynamic]Tx-Meta
  tempids: [dynamic]Tempid
})

(defstruct Tx-Meta {
  a: string
