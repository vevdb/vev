(defn retract-entity-ident [ident: string] -> Tx-Data
  (Tx-Data {op: ":db/retractEntity" ident: ident has_ident: true}))

(defn tempid-lookup [tempids: []Tempid, tempid: string] -> [e: u64, ok: bool]
  (for [item tempids]
    (when (= item.tempid tempid)
      (return item.e true)))
  (return 0 false))

(defn current-tx-tempid? [tempid: string] -> bool
  (or (= tempid ":db/current-tx")
      (= tempid "datomic.tx")
      (= tempid "datascript.tx")))

(defn current-tx-value? [value: Value] -> bool
  (and (or (= value.kind .Keyword)
           (= value.kind .String))
       (current-tx-tempid? value.text)))

(defn ensure-tempid! [tempids: ^[dynamic]Tempid, tempid: string, e: u64]
  (let [[_ ok] (tempid-lookup (slice tempids^ 0) tempid)]
    (when (not ok)
      (arr.push! tempids^ (Tempid {tempid: tempid e: e})))))

(defn next-entity-id [datoms: []Datom] -> u64
  (let [next: u64 1]
    (for [datom datoms]
      (when (>= datom.e next)
        (set! next (+ datom.e 1))))
    next))

(defn value-equal? [left: Value, right: Value] -> bool
  (if (not (= left.kind right.kind))
    false
    (case left.kind
      .Entity (= left.entity right.entity)
      .String (= left.text right.text)
      .Int (= left.int_value right.int_value)
      .Float (= left.float_value right.float_value)
      .Bool (= left.bool_value right.bool_value)
      .Keyword (= left.text right.text)
      .Vector (values-equal? (slice left.items 0) (slice right.items 0))
      .Map (do
        (when (not (= (count left.items) (count right.items)))
          (return false))
        (when (not (= (% (count left.items) 2) 0))
          (return false))
        (let [left-index 0]
          (while (< left-index (count left.items))
            (let [found false
                  right-index 0]
              (while (< right-index (count right.items))
                (when (and (value-equal? left.items[left-index] right.items[right-index])
                           (value-equal? left.items[(+ left-index 1)] right.items[(+ right-index 1)]))
                  (set! found true))
                (set! right-index (+ right-index 2)))
              (when (not found)
                (return false)))
            (set! left-index (+ left-index 2))))
        true)
      .Nil true
      :else false)))

(defn predicate-value-equal? [left: Value, right: Value] -> bool
  (if (and (= left.kind .Entity) (= right.kind .Int))
    (= left.entity (u64 right.int_value))
    (if (and (= left.kind .Int) (= right.kind .Entity))
      (= (u64 left.int_value) right.entity)
      (value-equal? left right))))

(defn values-equal? [left: []Value, right: []Value] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [value index left]
    (when (not (value-equal? value right[index]))
      (return false)))
  true)

(defn value-exists? [values: []Value, value: Value] -> bool
  (for [existing values]
    (when (value-equal? existing value)
      (return true)))
  false)

(defn row-values-exist? [rows: []Result-Row, values: []Value] -> bool
  (for [row rows]
    (when (values-equal? (slice row.values 0) values)
      (return true)))
  false)

(defn row-value-prefix-exists? [rows: []Result-Row, values: []Value] -> bool
  (for [row rows]
    (when (values-equal? (slice row.values 0 (count values)) values)
      (return true)))
  false)

(defn datom-less-eavt? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.e right.e))
      (< left.e right.e)
      (if (not (= left.a right.a))
        (string-less? left.a right.a)
        (if (not (value-equal? left.v right.v))
          (value-less? left.v right.v)
          (< left.tx right.tx))))))

(defn datom-less-aevt? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.a right.a))
      (string-less? left.a right.a)
      (if (not (= left.e right.e))
        (< left.e right.e)
        (if (not (value-equal? left.v right.v))
          (value-less? left.v right.v)
          (< left.tx right.tx))))))

(defn datom-less-avet? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.a right.a))
      (string-less? left.a right.a)
      (if (not (value-equal? left.v right.v))
        (value-less? left.v right.v)
        (if (not (= left.e right.e))
          (< left.e right.e)
          (< left.tx right.tx))))))

(defn datom-less-vaet? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (value-equal? left.v right.v))
      (value-less? left.v right.v)
      (if (not (= left.a right.a))
        (string-less? left.a right.a)
        (if (not (= left.e right.e))
          (< left.e right.e)
          (< left.tx right.tx))))))

(defn sort-datom-indexes! [indexes: ^[dynamic]int, datoms: []Datom, order: string]
  // ponytail: insertion sort is fine for the in-memory proof; replace when benchmarks say index build dominates.
  (for [i (arr.range 1 (count indexes^))]
    (let [current indexes^[i]
          j i]
      (while (> j 0)
        (let [previous indexes^[(- j 1)]
              less false]
          (if (= order "eavt")
            (set! less (datom-less-eavt? datoms current previous))
            (if (= order "aevt")
              (set! less (datom-less-aevt? datoms current previous))
              (if (= order "avet")
                (set! less (datom-less-avet? datoms current previous))
                (set! less (datom-less-vaet? datoms current previous)))))
          (if less
            (do
              (set! indexes^[j] previous)
              (set! j (- j 1)))
            (break))))
      (set! indexes^[j] current))))

(defn build-index [datoms: []Datom, order: string] -> [dynamic]int
  (let [indexes (make [dynamic]int 0 (count datoms))]
    (for [_ index datoms]
      (arr.push! indexes index))
    (sort-datom-indexes! (addr indexes) datoms order)
    indexes))

(defn same-fact? [left: Datom, right: Datom] -> bool
  (and (= left.e right.e)
       (= left.a right.a)
       (value-equal? left.v right.v)))

(defn current-fact-exists? [db: DB, target: Datom] -> bool
  (for [datom-index db.eavt]
    (when (datom-current-at? db datom-index)
      (when (same-fact? db.datoms[datom-index] target)
        (return true))))
  false)

(defn append-db-diff-side! [only-side: ^[dynamic]Datom, both: ^[dynamic]Datom, left: DB, right: DB]
  (for [datom-index left.eavt]
    (when (datom-current-at? left datom-index)
      (let [datom left.datoms[datom-index]]
        (if (current-fact-exists? right datom)
          (arr.push! both^ datom)
          (arr.push! only-side^ datom))))))

(defn db-diff [left: DB, right: DB] -> DB-Diff
  (let [only-left (make [dynamic]Datom)
        only-right (make [dynamic]Datom)
        both (make [dynamic]Datom)]
    (append-db-diff-side! (addr only-left) (addr both) left right)
    (for [datom-index right.eavt]
      (when (datom-current-at? right datom-index)
        (let [datom right.datoms[datom-index]]
          (when (not (current-fact-exists? left datom))
            (arr.push! only-right datom)))))
    (DB-Diff {only_left: only-left only_right: only-right both: both})))

(defn datom-current-in-log? [datoms: []Datom, index: int] -> bool
  (let [datom datoms[index]]
    (when (not datom.added)
      (return false))
    (for [later (slice datoms (+ index 1))]
      (when (same-fact? datom later)
        (return false)))
    true))

(defn build-current-index [datoms: []Datom] -> [dynamic]int
  // ponytail: O(n^2) snapshot build is fine until transact benchmarks say otherwise.
  (let [indexes (make [dynamic]int)]
    (for [_ index datoms]
      (when (datom-current-in-log? datoms index)
        (arr.push! indexes index)))
    indexes))

(defn int-lower-bound [xs: []int, value: int] -> int
  (let [low 0
        high (count xs)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)]
        (if (< xs[mid] value)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn build-db [datoms: [dynamic]Datom] -> DB
  (let [slice-datoms (slice datoms 0)]
    (DB {datoms: datoms
         current: (build-current-index slice-datoms)
         eavt: (build-index slice-datoms "eavt")
         aevt: (build-index slice-datoms "aevt")
         avet: (build-index slice-datoms "avet")
         vaet: (build-index slice-datoms "vaet")})))

(defn clone-datom-slice [datoms: []Datom] -> [dynamic]Datom
  (arr.into [dynamic]Datom datoms))

(defn make-datom [e: u64, a: string, v: Value] -> Datom
  (Datom {e: e a: a v: v tx: 0 added: true}))

(defn datom-tx [e: u64, a: string, v: Value, tx: u64, added: bool] -> Datom
  (Datom {e: e a: a v: v tx: tx added: added}))

(defn init-db [datoms: []Datom] -> DB
  (build-db (clone-datom-slice datoms)))

(defn filter-db [db: DB, pred: (fn [db: DB, datom: Datom] -> bool)] -> DB
  // ponytail: materialize filtered DBs for now; replace with predicate-wrapped indexes only if benchmarks require it.
  (let [datoms (make [dynamic]Datom)]
    (for [datom-index db.eavt]
      (when (datom-current-at? db datom-index)
        (let [datom db.datoms[datom-index]]
          (when (pred db datom)
            (arr.push! datoms datom)))))
    (build-db datoms)))

(defn max-tx [datoms: []Datom] -> u64
  (let [tx: u64 0]
    (for [datom datoms]
      (when (> datom.tx tx)
        (set! tx datom.tx)))
    tx))

(defn conn-from-db [db: DB] -> Conn
  (Conn {db: (build-db (clone-datom-slice (slice db.datoms 0)))
         next_tx: (+ (max-tx (slice db.datoms 0)) 1)}))

(defn conn-from-datoms [datoms: []Datom] -> Conn
  (conn-from-db (init-db datoms)))

(defn compare-eavt-prefix [datom: Datom, e: u64] -> int
  (if (< datom.e e)
    -1
    (if (> datom.e e) 1 0)))

(defn compare-eavt-entity-attr-prefix [datom: Datom, e: u64, a: string] -> int
  (let [e-compare (compare-eavt-prefix datom e)]
    (if (not (= e-compare 0))
      e-compare
      (strings.compare datom.a a))))

(defn compare-aevt-prefix [datom: Datom, a: string] -> int
  (strings.compare datom.a a))

(defn compare-avet-prefix [datom: Datom, a: string, v: Value] -> int
  (let [a-compare (strings.compare datom.a a)]
    (if (not (= a-compare 0))
      a-compare
      (value-compare datom.v v))))

(defn compare-vaet-prefix [datom: Datom, v: Value] -> int
  (value-compare datom.v v))

(defn datom-prefix-compare [db: DB, order: string, datom-index: int, e: u64, a: string, v: Value] -> int
  (let [datom db.datoms[datom-index]]
    (if (= order "eavt")
      (compare-eavt-prefix datom e)
      (if (= order "eavt-ea")
        (compare-eavt-entity-attr-prefix datom e a)
        (if (= order "aevt")
          (compare-aevt-prefix datom a)
          (if (= order "avet")
            (compare-avet-prefix datom a v)
            (compare-vaet-prefix datom v)))))))

(defn lower-bound-index [db: DB, indexes: []int, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (datom-prefix-compare db order indexes[mid] e a v)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn upper-bound-index [db: DB, indexes: []int, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (datom-prefix-compare db order indexes[mid] e a v)]
        (if (<= compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn create-conn [] -> Conn
  (Conn {db: (build-db (make [dynamic]Datom))
         next_tx: 1}))

(defmacro- emit-literal-value [form]
  (if (nil? form)
    (quasiquote (value-nil))
    (if (string? form)
    (quasiquote (value-string (unquote form)))
    (if (int? form)
      (quasiquote (value-int (unquote form)))
      (if (bool? form)
        (quasiquote (value-bool (unquote form)))
        (if (keyword? form)
          (quasiquote (value-keyword (unquote (source form))))
          (if (vector? form)
            (quasiquote (value-vector ([]Value [(splice (emit-literal-values form))])))
            (quasiquote (unquote form)))))))))

(defmacro- emit-literal-values [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-literal-value (first forms))
      (emit-literal-values (rest forms)))))

(defmacro- emit-attr [form]
  (if (keyword? form)
    (source form)
    (if (string? form)
      (text form)
      (error "tx-data attributes must be keywords or strings"))))

(defmacro- lookup-ref? [form]
  (cond
    (not (vector? form)) false
    (not (= (count form) 2)) false
    :else (keyword? (first form))))

(defmacro- query-input-lookup-ref? [form]
  (and (lookup-ref? form)
       (not (keyword? (nth form 1)))))

(defmacro- current-tx-form? [form]
  (cond
    (keyword? form) (= (source form) ":db/current-tx")
    (string? form) (or (= (text form) "datomic.tx")
                       (= (text form) "datascript.tx"))
    :else false))

(defmacro- emit-index-arg [form]
  (if (lookup-ref? form)
    (quasiquote
      (Index-Arg {has_lookup_ref: true
                  lookup_attr: (unquote (emit-attr (nth form 0)))
                  lookup_value: (unquote (emit-literal-value (nth form 1)))}))
    (quasiquote
      (Index-Arg {value: (unquote (emit-literal-value form))}))))

(defmacro- emit-index-args [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-index-arg (first forms))
      (emit-index-args (rest forms)))))

(defmacro- emit-tx-data-call [op e a v]
  (let [is-retract (= (source op) ":db/retract")]
    (if (lookup-ref? e)
      (quasiquote
        ((unquote (if is-retract (quasiquote retract-lookup-ref) (quasiquote add-lookup-ref)))
          (unquote (emit-attr (nth e 0)))
          (unquote (emit-literal-value (nth e 1)))
          (unquote (emit-attr a))
          (unquote (emit-literal-value v))))
      (if (string? e)
        (if (lookup-ref? v)
          (quasiquote
            (add-tempid-value-lookup-ref
              (unquote e)
              (unquote (emit-attr a))
              (unquote (emit-attr (nth v 0)))
              (unquote (emit-literal-value (nth v 1)))))
          (quasiquote
            ((unquote (if is-retract (quasiquote retract-tempid) (quasiquote add-tempid)))
              (unquote e)
              (unquote (emit-attr a))
              (unquote (emit-literal-value v)))))
	    (if (keyword? e)
        (if (current-tx-form? e)
          (quasiquote
            ((unquote (if is-retract (quasiquote retract-tempid) (quasiquote add-tempid)))
              (unquote (source e))
              (unquote (emit-attr a))
              (unquote (emit-literal-value v))))
	        (quasiquote
	          ((unquote (if is-retract (quasiquote retract-ident) (quasiquote add-ident)))
	            (unquote (source e))
	            (unquote (emit-attr a))
	            (unquote (emit-literal-value v)))))
	          (if (lookup-ref? v)
	            (quasiquote
	              ((unquote (if is-retract (quasiquote retract-value-lookup-ref) (quasiquote add-value-lookup-ref)))
	                (unquote e)
	                (unquote (emit-attr a))
	                (unquote (emit-attr (nth v 0)))
	                (unquote (emit-literal-value (nth v 1)))))
	            (quasiquote
	              ((unquote (if is-retract (quasiquote retract) (quasiquote add)))
	                (unquote e)
	                (unquote (emit-attr a))
	                (unquote (emit-literal-value v))))))))))

(defmacro- emit-cas-call [e a expected v]
  (if (lookup-ref? e)
    (quasiquote
      (cas-lookup-ref
        (unquote (emit-attr (nth e 0)))
        (unquote (emit-literal-value (nth e 1)))
        (unquote (emit-attr a))
        (unquote (emit-literal-value expected))
        (unquote (emit-literal-value v))))
    (if (string? e)
      (quasiquote
        (cas-tempid
          (unquote e)
          (unquote (emit-attr a))
          (unquote (emit-literal-value expected))
          (unquote (emit-literal-value v))))
      (if (and (keyword? e) (current-tx-form? e))
        (quasiquote
          (cas-tempid
            (unquote (source e))
            (unquote (emit-attr a))
            (unquote (emit-literal-value expected))
            (unquote (emit-literal-value v))))
    (if (lookup-ref? expected)
      (quasiquote
        (cas-expected-lookup-ref
          (unquote e)
          (unquote (emit-attr a))
          (unquote (emit-attr (nth expected 0)))
          (unquote (emit-literal-value (nth expected 1)))
          (unquote (emit-literal-value v))))
      (if (lookup-ref? v)
        (quasiquote
          (cas-value-lookup-ref
            (unquote e)
            (unquote (emit-attr a))
            (unquote (emit-literal-value expected))
            (unquote (emit-attr (nth v 0)))
            (unquote (emit-literal-value (nth v 1)))))
        (quasiquote
          (cas
            (unquote e)
            (unquote (emit-attr a))
            (unquote (emit-literal-value expected))
            (unquote (emit-literal-value v))))))))))

(defmacro- tx-map-id [items]
  (if (= (count items) 0)
    (error "tx map forms require :db/id")
    (if (= (count items) 1)
      (error "tx map forms require key/value pairs")
      (if (keyword? (nth items 0))
        (if (= (source (nth items 0)) ":db/id")
          (nth items 1)
          (tx-map-id (rest (rest items))))
        (tx-map-id (rest (rest items)))))))

(defmacro- tx-map-has-id? [items]
  (if (= (count items) 0)
    false
    (if (= (count items) 1)
      false
      (if (keyword? (nth items 0))
        (if (= (source (nth items 0)) ":db/id")
          true
          (tx-map-has-id? (rest (rest items))))
        (tx-map-has-id? (rest (rest items)))))))

(defmacro- tx-map-string-id [form]
  (if (brace? form)
    (let [id (tx-map-id form)]
      (if (string? id)
        (text id)
        (error "nested tx maps currently require string :db/id")))
    (error "nested tx map expected")))

(defmacro- tx-map-ref-tempid [form]
  (if (brace? form)
    (if (tx-map-has-id? form)
      (tx-map-string-id form)
      (source (gensym "vev_tx_map")))
    (error "nested tx map expected")))

(defmacro- tx-map-has-numeric-id? [form]
  (if (brace? form)
    (if (tx-map-has-id? form)
      (int? (tx-map-id form))
      false)
    false))

(defmacro- tx-map-has-keyword-id? [form]
  (if (brace? form)
    (if (tx-map-has-id? form)
      (keyword? (tx-map-id form))
      false)
    false))

(defmacro- tx-map-entity-id [form]
  (if (tx-map-has-id? form)
    (tx-map-id form)
    (source (gensym "vev_tx_map"))))

(defmacro- emit-tx-map-entity-ref-call [e a value-e]
  (if (lookup-ref? e)
    (quasiquote
      (add-lookup-ref
        (unquote (emit-attr (nth e 0)))
        (unquote (emit-literal-value (nth e 1)))
        (unquote (emit-attr a))
        (value-entity (unquote value-e))))
    (if (keyword? e)
      (quasiquote
        (add-ident
          (unquote (source e))
          (unquote (emit-attr a))
          (value-entity (unquote value-e))))
      (if (string? e)
        (quasiquote
          (add-tempid
            (unquote e)
            (unquote (emit-attr a))
            (value-entity (unquote value-e))))
        (if (int? e)
          (quasiquote
            (add
              (unquote e)
              (unquote (emit-attr a))
              (value-entity (unquote value-e))))
          (error "nested tx map parent currently supports numeric, string, lookup ref, or ident :db/id"))))))

(defmacro- emit-tx-map-ref-call [e a value-tempid]
  (if (lookup-ref? e)
    (quasiquote
      (add-lookup-ref-value-tempid
        (unquote (emit-attr (nth e 0)))
        (unquote (emit-literal-value (nth e 1)))
        (unquote (emit-attr a))
        (unquote value-tempid)))
    (if (keyword? e)
      (quasiquote
        (add-ident-value-tempid
          (unquote (source e))
          (unquote (emit-attr a))
          (unquote value-tempid)))
      (if (string? e)
        (quasiquote
          (add-tempid-value-tempid
            (unquote e)
            (unquote (emit-attr a))
            (unquote value-tempid)))
        (if (int? e)
          (quasiquote
            (add-value-tempid
              (unquote e)
              (unquote (emit-attr a))
              (unquote value-tempid)))
          (error "nested tx map parent currently supports numeric, string, lookup ref, or ident :db/id"))))))

(defmacro- reverse-attr-form? [form]
  (and (keyword? form)
       (starts-with? (source form) ":_")))

(defmacro- forward-attr-source [form]
  (let [attr (source form)]
    (str ":" (slice attr 2))))

(defmacro- emit-tx-map-reverse-attr [e a v]
  (if (int? e)
    (if (lookup-ref? v)
      (quasiquote
        (add-lookup-ref
          (unquote (emit-attr (nth v 0)))
          (unquote (emit-literal-value (nth v 1)))
          (unquote (forward-attr-source a))
          (value-entity (unquote e))))
      (if (int? v)
        (quasiquote
          (add
            (unquote v)
            (unquote (forward-attr-source a))
            (value-entity (unquote e))))
        (if (keyword? v)
          (quasiquote
            (add-ident
              (unquote (source v))
              (unquote (forward-attr-source a))
              (value-entity (unquote e))))
          (if (string? v)
            (quasiquote
              (add-tempid
                (unquote v)
                (unquote (forward-attr-source a))
                (value-entity (unquote e))))
            (error "reverse tx map attrs currently require id, tempid, ident, or lookup ref values")))))
    (error "reverse tx map attrs currently require numeric :db/id on the map entity")))

(defmacro- emit-tx-map-attr [e a v]
  (if (reverse-attr-form? a)
    (if (vector? v)
      (if (lookup-ref? v)
        (emit-tx-map-reverse-attr e a v)
        (emit-tx-map-vector-attr e a v))
      (emit-tx-map-reverse-attr e a v))
  (if (brace? v)
    (if (tx-map-has-numeric-id? v)
      (let [value-e (tx-map-id v)]
        (forms
          (emit-tx-map-entity-ref-call e a value-e)
          (emit-tx-map-attrs value-e v)))
      (if (tx-map-has-keyword-id? v)
        (let [value-ident (tx-map-id v)]
          (forms
            (emit-tx-data-call (keyword "db/add") e a value-ident)
            (emit-tx-map-attrs value-ident v)))
        (let [value-tempid (tx-map-ref-tempid v)]
          (forms
            (emit-tx-map-ref-call e a value-tempid)
            (emit-tx-map-attrs value-tempid v)))))
    (if (vector? v)
      (if (lookup-ref? v)
        (emit-tx-data-call (keyword "db/add") e a v)
        (emit-tx-map-vector-attr e a v))
      (forms
        (emit-tx-data-call (keyword "db/add") e a v))))))

(defmacro- emit-tx-map-vector-attr [e a values]
  (if (= (count values) 0)
    (forms)
    (concat
      (forms (emit-tx-map-attr e a (first values)))
      (emit-tx-map-vector-attr e a (rest values)))))

(defmacro- emit-retract-entity-call [e]
  (if (lookup-ref? e)
    (quasiquote
      (retract-entity-lookup-ref
        (unquote (emit-attr (nth e 0)))
        (unquote (emit-literal-value (nth e 1)))))
    (if (string? e)
      (quasiquote (retract-entity-tempid (unquote e)))
      (if (keyword? e)
        (quasiquote (retract-entity-ident (unquote (source e))))
        (quasiquote (retract-entity (unquote e)))))))

(defmacro- emit-retract-attr-call [e a]
  (if (lookup-ref? e)
    (quasiquote
      (retract-attr-lookup-ref
        (unquote (emit-attr (nth e 0)))
        (unquote (emit-literal-value (nth e 1)))
        (unquote (emit-attr a))))
    (if (string? e)
      (quasiquote
        (retract-attr-tempid
          (unquote e)
          (unquote (emit-attr a))))
      (if (keyword? e)
        (quasiquote
          (retract-attr-ident
            (unquote (source e))
            (unquote (emit-attr a))))
        (quasiquote
          (retract-attr
            (unquote e)
            (unquote (emit-attr a))))))))

(defmacro- emit-tx-map-attrs [e items]
  (if (= (count items) 0)
    (forms)
    (if (= (count items) 1)
      (error "tx map forms require key/value pairs")
      (if (keyword? (nth items 0))
        (if (= (source (nth items 0)) ":db/id")
          (emit-tx-map-attrs e (rest (rest items)))
          (concat
            (forms (emit-tx-map-attr e (nth items 0) (nth items 1)))
            (emit-tx-map-attrs e (rest (rest items)))))
        (concat
          (forms (emit-tx-map-attr e (nth items 0) (nth items 1)))
          (emit-tx-map-attrs e (rest (rest items))))))))

(defmacro- emit-tx-map-items [form]
  (let [e (tx-map-entity-id form)]
    (emit-tx-map-attrs e form)))

(defmacro- emit-tx-data-item [form]
  (if (nil? form)
    (forms)
    (if (vector? form)
    (if (= (count form) 5)
      (let [op (nth form 0)
            e (nth form 1)
            a (nth form 2)
            expected (nth form 3)
            v (nth form 4)]
        (if (keyword? op)
          (if (or (= (source op) ":db.fn/cas") (= (source op) ":db/cas"))
            (forms (emit-cas-call e a expected v))
            (error "five-item tx-data vectors currently support :db.fn/cas or :db/cas"))
          (error "five-item tx-data vectors currently support :db.fn/cas or :db/cas")))
      (if (= (count form) 4)
      (let [op (nth form 0)
            e (nth form 1)
            a (nth form 2)
            v (nth form 3)]
        (if (keyword? op)
          (if (= (source op) ":db/retract")
            (forms (emit-tx-data-call op e a v))
            (if (= (source op) ":db/add")
              (forms (emit-tx-data-call op e a v))
              (error "tx-data operation must be :db/add or :db/retract")))
          (error "tx-data operation must be :db/add or :db/retract")))
      (if (= (count form) 2)
        (let [op (nth form 0)
              e (nth form 1)]
          (if (keyword? op)
            (if (= (source op) ":db/retractEntity")
              (forms (emit-retract-entity-call e))
              (if (= (source op) ":db.fn/retractEntity")
                (forms (emit-retract-entity-call e))
                (error "tx-data operation must be :db/add, :db/retract, :db/retractEntity, or :db.fn/retractEntity")))
            (error "tx-data operation must be :db/add, :db/retract, or :db/retractEntity")))
        (if (= (count form) 3)
          (let [op (nth form 0)
                e (nth form 1)
                a (nth form 2)]
            (if (keyword? op)
              (if (= (source op) ":db/retract")
                (forms (emit-retract-attr-call e a))
                (if (= (source op) ":db.fn/retractAttribute")
                  (forms (emit-retract-attr-call e a))
                  (error "three-item tx-data vectors currently support :db/retract or :db.fn/retractAttribute")))
              (error "three-item tx-data vectors currently support :db/retract or :db.fn/retractAttribute")))
          (error "tx-data vectors must have shape [:db/add e :attr value], [:db/retract e :attr], [:db.fn/retractAttribute e :attr], or [:db/retractEntity e]")))))
    (if (brace? form)
      (emit-tx-map-items form)
      (error "tx-data expects vector forms like [:db/add e :attr value] or map forms")))))

(defmacro- emit-tx-data-items [forms]
  (if (= (count forms) 0)
    (forms)
    (concat
      (emit-tx-data-item (first forms))
      (emit-tx-data-items (rest forms)))))

(defmacro tx-data [& forms]
  (quasiquote ([]Tx-Data [(splice (emit-tx-data-items forms))])))

(defmacro- emit-find-var [form]
  (if (symbol? form)
    (quasiquote (unquote (source form)))
    (error (str ":find entries must be variables, got " (source form)))))

(defmacro- find-var? [form]
  (symbol? form))

(defmacro- aggregate-op? [op]
  (contains? ["count" "count-distinct" "min" "max" "sum" "avg" "median" "variance" "stddev"] op))

(defmacro- top-n-aggregate-op? [op]
  (contains? ["min" "max"] op))

(defmacro- find-scalar-marker? [form]
  (if (symbol? form)
    (= (source form) ".")
    false))

(defmacro- find-collection? [form]
  (if (vector? form)
    (if (= (count form) 2)
      (if (symbol? (nth form 1))
        (= (source (nth form 1)) "...")
        false)
      false)
    false))

(defmacro- find-tuple? [form]
  (if (vector? form)
    (if (= (count form) 1)
      (vector? (first form))
      false)
    false))

(defmacro- find-direct-tuple? [form]
  (if (vector? form)
    (if (find-collection? form)
      false
      (if (= (count form) 1)
        (not (vector? (first form)))
        true))
    false))

(defmacro- find-return-map-marker? [form]
  (if (keyword? form)
    (contains? [":keys" ":strs" ":syms"] (source form))
    false))

(defmacro- emit-find-tuple-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (if (aggregate-find? (first forms))
      (emit-find-tuple-vars (rest forms))
      (forms
        (emit-find-var (first forms))
        (emit-find-tuple-vars (rest forms))))))

(defmacro- pull-find? [form]
  (cond
    (not (list? form)) false
    (not (or (= (count form) 3) (= (count form) 4))) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "pull")))

(defmacro- aggregate-find? [form]
  (cond
    (not (list? form)) false
    (not (or (= (count form) 2) (= (count form) 3))) false
    (not (symbol? (first form))) false
    :else (let [op (source (first form))]
            (if (= (count form) 3)
              (and (top-n-aggregate-op? op)
                   (or (int? (nth form 1))
                       (find-var? (nth form 1)))
                   (find-var? (nth form 2)))
              (and (find-var? (nth form 1))
                   (aggregate-op? op))))))

(defmacro- emit-find-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (if (find-return-map-marker? (first forms))
      (forms)
      (if (pull-find? (first forms))
        (emit-find-vars (rest forms))
        (if (aggregate-find? (first forms))
          (emit-find-vars (rest forms))
          (if (find-scalar-marker? (first forms))
            (emit-find-vars (rest forms))
            (if (find-collection? (first forms))
              (if (aggregate-find? (nth (first forms) 0))
                (emit-find-vars (rest forms))
                (forms
                  (emit-find-var (nth (first forms) 0))
                  (emit-find-vars (rest forms))))
              (if (find-tuple? (first forms))
                (forms
                  (emit-find-tuple-vars (first (first forms)))
                  (emit-find-vars (rest forms)))
                (forms
                  (emit-find-var (first forms))
                  (emit-find-vars (rest forms)))))))))))

(defmacro- datalog-items-until-keyword [forms]
  (if (= (count forms) 0)
    (forms)
    (let [head (first forms)]
      (if (keyword? head)
        (forms)
        (forms
          head
          (datalog-items-until-keyword (rest forms)))))))

(defmacro- emit-result-key [form]
  (if (symbol? form)
    (quasiquote (unquote (source form)))
    (if (keyword? form)
      (quasiquote (unquote (source form)))
      (if (string? form)
        (quasiquote (unquote form))
        (error ":keys entries must be symbols, keywords, or strings")))))

(defmacro- emit-result-keys [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-result-key (first forms))
      (emit-result-keys (rest forms)))))

(defmacro- datalog-return-map-items [forms marker]
  (if (datalog-has-marker-before? forms marker ":where")
    (datalog-items-until-keyword (datalog-items-after forms marker))
    (error (str "query expects " marker))))

(defmacro- input-collection? [form]
  (cond
    (not (vector? form)) false
    (not (= (count form) 2)) false
    (not (symbol? (nth form 1))) false
    :else (= (source (nth form 1)) "...")))

(defmacro- input-relation? [form]
  (cond
    (not (vector? form)) false
    (not (= (count form) 1)) false
    :else (vector? (first form))))

(defmacro- input-tuple? [form]
  (cond
    (not (vector? form)) false
    (input-collection? form) false
    (input-relation? form) false
    :else true))

(defmacro- input-source? [form]
  (if (symbol? form)
    (contains? ["$" "%"] (source form))
    false))

(defmacro- input-db-source? [spec]
  // ponytail: $1..$9 covers DataScript tests; replace with digit parsing if users need more sources.
  (and (symbol? spec)
       (contains? ["$1" "$2" "$3" "$4" "$5" "$6" "$7" "$8" "$9"] (source spec))))

(defmacro- relation-source? [form]
  (and (symbol? form)
       (starts-with? (source form) "$")
       (not (= (source form) "$"))))

(defmacro- input-wildcard? [form]
  (and (symbol? form)
       (= (source form) "_")))

(defmacro- emit-input-var [form]
  (if (input-collection? form)
    (emit-find-var (nth form 0))
    (emit-find-var form)))

(defmacro- emit-input-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (if (or (input-source? (first forms)) (input-db-source? (first forms)))
      (emit-input-vars (rest forms))
      (if (input-collection? (first forms))
        (emit-input-vars (rest forms))
        (if (input-relation? (first forms))
          (emit-input-vars (rest forms))
          (if (input-tuple? (first forms))
            (emit-input-vars (rest forms))
            (forms
              (emit-input-var (first forms))
              (emit-input-vars (rest forms)))))))))

(defmacro- emit-collection-input-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (if (or (input-source? (first forms)) (input-db-source? (first forms)))
      (emit-collection-input-vars (rest forms))
      (if (input-collection? (first forms))
        (forms
          (emit-input-var (first forms))
          (emit-collection-input-vars (rest forms)))
        (emit-collection-input-vars (rest forms))))))

(defmacro- emit-tuple-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (if (input-wildcard? (first forms))
        (quasiquote "")
        (emit-find-var (first forms)))
      (emit-tuple-vars (rest forms)))))

(defmacro- emit-tuple-input [form]
  (if (input-tuple? form)
    (quasiquote
      (Tuple-Input {vars: ([]string [(splice (emit-tuple-vars form))])}))
    (error "tuple inputs must have shape [?a ?b]")))

(defmacro- emit-tuple-inputs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (or (input-source? (first forms)) (input-db-source? (first forms)))
      (emit-tuple-inputs (rest forms))
      (if (input-tuple? (first forms))
        (forms
          (emit-tuple-input (first forms))
          (emit-tuple-inputs (rest forms)))
        (emit-tuple-inputs (rest forms))))))

(defmacro- emit-relation-input [form]
  (if (input-relation? form)
    (quasiquote
      (Relation-Input {vars: ([]string [(splice (emit-tuple-vars (first form)))])}))
    (error "relation inputs must have shape [[?a ?b]]")))

(defmacro- emit-relation-inputs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (or (input-source? (first forms)) (input-db-source? (first forms)))
      (emit-relation-inputs (rest forms))
      (if (input-relation? (first forms))
        (forms
          (emit-relation-input (first forms))
          (emit-relation-inputs (rest forms)))
        (emit-relation-inputs (rest forms))))))

(defmacro- datalog-items-before [forms marker]
  (if (= (count forms) 0)
    (error (str "datalog query expects " marker))
    (let [head (first forms)]
      (if (keyword? head)
        (if (= (source head) marker)
          (forms)
          (error (str "datalog query expects " marker)))
        (forms
          head
          (datalog-items-before (rest forms) marker))))))

(defmacro- datalog-items-after [forms marker]
  (if (= (count forms) 0)
    (error (str "datalog query expects " marker))
    (let [head (first forms)]
      (if (keyword? head)
        (if (= (source head) marker)
          (rest forms)
        (datalog-items-after (rest forms) marker))
        (datalog-items-after (rest forms) marker)))))

(defmacro- datalog-has-marker-before? [forms marker stop]
  (if (= (count forms) 0)
    false
    (let [head (first forms)]
      (if (keyword? head)
        (if (= (source head) marker)
          true
          (if (= (source head) stop)
            false
            (datalog-has-marker-before? (rest forms) marker stop)))
        (datalog-has-marker-before? (rest forms) marker stop)))))

(defmacro- datalog-find-items [forms]
  (if (datalog-has-marker-before? forms ":keys" ":where")
    (datalog-items-before forms ":keys")
    (if (datalog-has-marker-before? forms ":strs" ":where")
      (datalog-items-before forms ":strs")
      (if (datalog-has-marker-before? forms ":syms" ":where")
        (datalog-items-before forms ":syms")
        (if (datalog-has-marker-before? forms ":with" ":where")
          (datalog-items-before forms ":with")
          (if (datalog-has-marker-before? forms ":in" ":where")
            (datalog-items-before forms ":in")
            (datalog-items-before forms ":where")))))))

(defmacro- datalog-with-items [forms]
  (if (datalog-has-marker-before? forms ":with" ":where")
    (let [after-with (datalog-items-after forms ":with")]
      (if (datalog-has-marker-before? after-with ":in" ":where")
        (datalog-items-before after-with ":in")
        (datalog-items-before after-with ":where")))
    (forms)))

(defmacro- datalog-input-items [forms]
  (if (datalog-has-marker-before? forms ":in" ":where")
    (let [after-in (datalog-items-after forms ":in")]
      (if (datalog-has-marker-before? after-in ":where" ":where")
        (datalog-items-before after-in ":where")
        after-in))
    (forms)))

(defmacro- datalog-where-items [forms]
  (if (datalog-has-marker-before? forms ":where" ":where")
    (datalog-items-after forms ":where")
    (forms)))

(defmacro- emit-entity-term [form]
  (if (symbol? form)
    (if (= (source form) "_")
      (quasiquote (term-wildcard))
      (quasiquote (term-var (unquote (source form)))))
    (if (lookup-ref? form)
      (quasiquote
        (term-lookup-ref
          (unquote (emit-attr (nth form 0)))
          (unquote (emit-literal-value (nth form 1)))))
      (if (int? form)
        (quasiquote (term-entity (unquote form)))
        (if (keyword? form)
          (quasiquote (term-keyword (unquote (source form))))
          (quasiquote (unquote form)))))))

(defmacro- emit-attr-term [form]
  (if (symbol? form)
    (if (= (source form) "_")
      (quasiquote (term-wildcard))
      (quasiquote (term-var (unquote (source form)))))
    (if (keyword? form)
      (quasiquote (term-keyword (unquote (source form))))
      (if (string? form)
        (quasiquote (term-keyword (unquote form)))
        (quasiquote (unquote form))))))

(defmacro- emit-value-term [form]
  (if (symbol? form)
    (if (= (source form) "_")
      (quasiquote (term-wildcard))
      (quasiquote (term-var (unquote (source form)))))
    (if (lookup-ref? form)
      (quasiquote
        (term-lookup-ref
          (unquote (emit-attr (nth form 0)))
          (unquote (emit-literal-value (nth form 1)))))
      (if (string? form)
        (quasiquote (term-string (unquote form)))
        (if (int? form)
          (quasiquote (term-int (unquote form)))
          (if (bool? form)
            (quasiquote (term-bool (unquote form)))
            (if (keyword? form)
              (quasiquote (term-keyword (unquote (source form))))
              (if (vector? form)
                (quasiquote (term-value (unquote (emit-literal-value form))))
                (quasiquote (unquote form))))))))))

(defmacro- emit-datalog-clause [form]
  (if (vector? form)
    (if (= (count form) 2)
      (quasiquote
        (Clause {e: (unquote (emit-entity-term (nth form 0)))
                 a: (unquote (emit-attr-term (nth form 1)))
                 v: (term-wildcard)}))
      (if (= (count form) 3)
        (if (relation-source? (nth form 0))
          (quasiquote
            (Clause {e: (unquote (emit-value-term (nth form 1)))
                     a: (unquote (emit-value-term (nth form 2)))
                     v: (term-wildcard)
                     tx_term: (term-wildcard)
                     op_term: (term-wildcard)
                     source: (unquote (source (nth form 0)))
                     has_source: true
                     source_width: 2}))
          (if (input-source? (nth form 0))
          (quasiquote
            (Clause {e: (unquote (emit-entity-term (nth form 1)))
                     a: (unquote (emit-attr-term (nth form 2)))
                     v: (term-wildcard)}))
          (quasiquote
            (Clause {e: (unquote (emit-entity-term (nth form 0)))
                     a: (unquote (emit-attr-term (nth form 1)))
                     v: (unquote (emit-value-term (nth form 2)))}))))
        (if (= (count form) 4)
          (if (input-source? (nth form 0))
            (quasiquote
              (Clause {e: (unquote (emit-entity-term (nth form 1)))
                       a: (unquote (emit-attr-term (nth form 2)))
                       v: (unquote (emit-value-term (nth form 3)))}))
            (quasiquote
              (Clause {e: (unquote (emit-value-term (nth form 1)))
                       a: (unquote (emit-value-term (nth form 2)))
                       v: (unquote (emit-value-term (nth form 3)))
                       tx_term: (term-wildcard)
                       op_term: (term-wildcard)
                       source: (unquote (source (nth form 0)))
                       has_source: true
                       source_width: 3})))
          (if (= (count form) 5)
            (if (relation-source? (nth form 0))
              (quasiquote
                (Clause {e: (unquote (emit-value-term (nth form 1)))
                         a: (unquote (emit-value-term (nth form 2)))
                         v: (unquote (emit-value-term (nth form 3)))
                         tx_term: (unquote (emit-value-term (nth form 4)))
                         op_term: (term-wildcard)
                         source: (unquote (source (nth form 0)))
                         has_source: true
                         source_width: 4}))
              (error "five-item datalog clauses require a relation source"))
            (if (= (count form) 6)
              (if (relation-source? (nth form 0))
                (quasiquote
                  (Clause {e: (unquote (emit-value-term (nth form 1)))
                           a: (unquote (emit-value-term (nth form 2)))
                           v: (unquote (emit-value-term (nth form 3)))
                           tx_term: (unquote (emit-value-term (nth form 4)))
                           op_term: (unquote (emit-value-term (nth form 5)))
                           source: (unquote (source (nth form 0)))
                           has_source: true
                           source_width: 5}))
                (error "six-item datalog clauses require a relation source"))
              (error "datalog clauses must have shape [e a], [e a v], [src e a], [src e a v], [src e a v tx], or [src e a v tx op]"))))))
    (error "datalog :where entries must be clauses")))

(defmacro- missing-clause? [form]
  (if (vector? form)
    (if (= (count form) 1)
      (let [expr (first form)]
        (if (list? expr)
          (if (= (count expr) 4)
            (let [head (first expr)]
              (if (symbol? head)
                (= (source head) "missing?")
                false))
            false)
          false))
      false)
    false))

(defmacro- predicate-clause? [form]
  (if (missing-clause? form)
    false
    (if (vector? form)
      (if (= (count form) 1)
        (list? (first form))
        false)
      false)))

(defmacro- function-clause? [form]
  (cond
    (not (vector? form)) false
    (not (= (count form) 2)) false
    (not (list? (first form))) false
    (not (>= (count (first form)) 2)) false
    (not (or (symbol? (nth form 1)) (vector? (nth form 1)))) false
    (not (symbol? (first (first form)))) false
    :else (let [op (source (first (first form)))]
            (contains? ["count" "+" "-" "*" "inc" "identity" "vector" "tuple" "untuple" "hash-map" "get" "first" "second"] op))))

(defmacro- get-else-clause? [form]
  (if (vector? form)
    (if (= (count form) 2)
      (let [expr (first form)]
        (if (list? expr)
          (if (= (count expr) 5)
            (let [head (first expr)]
              (if (symbol? head)
                (= (source head) "get-else")
                false))
            false)
          false))
      false)
    false))

(defmacro- get-some-clause? [form]
  (if (vector? form)
    (if (= (count form) 2)
      (let [expr (first form)
            out (nth form 1)]
        (if (list? expr)
          (if (>= (count expr) 4)
            (let [head (first expr)]
              (if (symbol? head)
                (if (= (source head) "get-some")
                  (if (vector? out)
                    (= (count out) 2)
                    false)
                  false)
                false))
            false)
          false))
      false)
    false))

(defmacro- ground-clause? [form]
  (if (vector? form)
    (if (= (count form) 2)
      (let [expr (first form)]
        (if (list? expr)
          (if (= (count expr) 2)
            (let [head (first expr)]
              (if (symbol? head)
                (= (source head) "ground")
                false))
            false)
          false))
      false)
    false))

(defmacro- not-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 1) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "not")))

(defmacro- sourced-not-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 2) false
    (not (relation-source? (first form))) false
    (not (symbol? (nth form 1))) false
    :else (= (source (nth form 1)) "not")))

(defmacro- not-join-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 2) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "not-join")))

(defmacro- or-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 1) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "or")))

(defmacro- sourced-or-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 2) false
    (not (relation-source? (first form))) false
    (not (symbol? (nth form 1))) false
    :else (= (source (nth form 1)) "or")))

(defmacro- or-join-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 2) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "or-join")))

(defmacro- and-clause? [form]
  (cond
    (not (list? form)) false
    (<= (count form) 1) false
    (not (symbol? (first form))) false
    :else (= (source (first form)) "and")))

(defmacro- rule-call? [form]
  (cond
    (not (list? form)) false
    (= (count form) 0) false
    (not (symbol? (first form))) false
    (relation-source? (first form)) (and (> (count form) 1)
                                         (symbol? (nth form 1))
                                         (not (contains? ["not" "or"] (source (nth form 1)))))
    :else (let [name (source (first form))]
            (not (contains? ["not" "not-join" "or" "or-join" "and"] name)))))

(defmacro- emit-not-join-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-find-var (first forms))
      (emit-not-join-vars (rest forms)))))

(defmacro- emit-datalog-source-clause [source-name form]
  (if (vector? form)
    (if (= (count form) 2)
      (quasiquote
        (Clause {e: (unquote (emit-value-term (nth form 0)))
                 a: (unquote (emit-value-term (nth form 1)))
                 v: (term-wildcard)
                 tx_term: (term-wildcard)
                 op_term: (term-wildcard)
                 source: (unquote source-name)
                 has_source: true
                 source_width: 2}))
      (if (= (count form) 3)
        (if (relation-source? (nth form 0))
          (emit-datalog-clause form)
          (quasiquote
            (Clause {e: (unquote (emit-value-term (nth form 0)))
                     a: (unquote (emit-value-term (nth form 1)))
                     v: (unquote (emit-value-term (nth form 2)))
                     tx_term: (term-wildcard)
                     op_term: (term-wildcard)
                     source: (unquote source-name)
                     has_source: true
                     source_width: 3})))
        (if (= (count form) 4)
          (if (or (input-source? (nth form 0))
                  (input-db-source? (nth form 0))
                  (relation-source? (nth form 0)))
            (emit-datalog-clause form)
            (quasiquote
              (Clause {e: (unquote (emit-value-term (nth form 0)))
                       a: (unquote (emit-value-term (nth form 1)))
                       v: (unquote (emit-value-term (nth form 2)))
                       tx_term: (unquote (emit-value-term (nth form 3)))
                       op_term: (term-wildcard)
                       source: (unquote source-name)
                       has_source: true
                       source_width: 4})))
          (if (= (count form) 5)
            (if (or (input-source? (nth form 0))
                    (input-db-source? (nth form 0))
                    (relation-source? (nth form 0)))
              (emit-datalog-clause form)
              (quasiquote
                (Clause {e: (unquote (emit-value-term (nth form 0)))
                         a: (unquote (emit-value-term (nth form 1)))
                         v: (unquote (emit-value-term (nth form 2)))
                         tx_term: (unquote (emit-value-term (nth form 3)))
                         op_term: (unquote (emit-value-term (nth form 4)))
                         source: (unquote source-name)
                         has_source: true
                         source_width: 5})))
            (emit-datalog-clause form)))))
    (error "source-prefixed clauses currently support data clauses")))

(defmacro- emit-datalog-source-clauses [source-name forms]
  (if (= (count forms) 0)
    (forms)
    (if (vector? (first forms))
      (forms
        (emit-datalog-source-clause source-name (first forms))
        (emit-datalog-source-clauses source-name (rest forms)))
      (emit-datalog-source-clauses source-name (rest forms)))))

(defmacro- emit-datalog-source-not-group [source-name form]
  (if (sourced-not-clause? form)
    (emit-datalog-not-group form)
    (if (not-clause? form)
      (quasiquote
        (not-group
          ([]Clause [(splice (emit-datalog-source-clauses source-name (rest form)))])
          ([]Not-Group [(splice (emit-datalog-source-not-groups source-name (rest form)))])))
      (error "source-prefixed nested not currently supports not data clauses"))))

(defmacro- emit-datalog-source-not-groups [source-name forms]
  (if (= (count forms) 0)
    (forms)
    (if (or (not-clause? (first forms))
            (sourced-not-clause? (first forms)))
      (forms
        (emit-datalog-source-not-group source-name (first forms))
        (emit-datalog-source-not-groups source-name (rest forms)))
      (emit-datalog-source-not-groups source-name (rest forms)))))

(defmacro- emit-datalog-not-group [form]
  (if (not-join-clause? form)
    (let [join-vars (nth form 1)]
      (if (vector? join-vars)
        (quasiquote
          (not-join-group
            ([]string [(splice (emit-not-join-vars join-vars))])
            ([]Clause [(splice (emit-datalog-clauses (slice form 2)))])
            ([]Not-Group [(splice (emit-datalog-not-groups (slice form 2)))])))
        (error "not-join expects a vector of join vars")))
    (if (not-clause? form)
      (quasiquote
        (not-group
          ([]Clause [(splice (emit-datalog-clauses (rest form)))])
          ([]Not-Group [(splice (emit-datalog-not-groups (rest form)))])))
      (if (sourced-not-clause? form)
        (quasiquote
          (not-group
            ([]Clause [(splice (emit-datalog-source-clauses (source (first form)) (slice form 2)))])
            ([]Not-Group [(splice (emit-datalog-source-not-groups (source (first form)) (slice form 2)))])))
        (error "not clauses must have shape (not [e a v] ...), ($src not [e a v] ...), or (not-join [?x] [e a v] ...)")))))

(defmacro- emit-datalog-missing-group [form]
  (if (missing-clause? form)
    (let [expr (first form)]
      (quasiquote
        (not-group
          ([]Clause
            [(Clause {e: (unquote (emit-entity-term (nth expr 2)))
                      a: (unquote (emit-attr-term (nth expr 3)))
                      v: (term-wildcard)})])
          ([]Not-Group []))))
    (error "missing? clauses must have shape [(missing? $ ?e :attr)]")))

(defmacro- emit-datalog-or-branch [form]
  (if (vector? form)
    (quasiquote
      (not-group-simple ([]Clause [(unquote (emit-datalog-clause form))])))
    (if (and-clause? form)
      (quasiquote
        (not-group-simple ([]Clause [(splice (emit-datalog-clauses (rest form)))])))
      (error "or branches currently support data clauses or (and [e a v] ...)"))))

(defmacro- emit-datalog-source-or-branch [source-name form]
  (if (vector? form)
    (quasiquote
      (not-group-simple ([]Clause [(unquote (emit-datalog-source-clause source-name form))])))
    (if (and-clause? form)
      (quasiquote
        (not-group-simple ([]Clause [(splice (emit-datalog-source-clauses source-name (rest form)))])))
      (error "source-prefixed or branches currently support data clauses or (and [e a v] ...)"))))

(defmacro- emit-datalog-or-branches [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-datalog-or-branch (first forms))
      (emit-datalog-or-branches (rest forms)))))

(defmacro- emit-datalog-source-or-branches [source-name forms]
  (if (= (count forms) 0)
    (forms)
    (let [head (first forms)]
      (if (sourced-or-clause? head)
        (forms
          (emit-datalog-source-or-branches (source (first head)) (slice head 2))
          (emit-datalog-source-or-branches source-name (rest forms)))
        (if (or-clause? head)
          (forms
            (emit-datalog-source-or-branches source-name (rest head))
            (emit-datalog-source-or-branches source-name (rest forms)))
          (forms
            (emit-datalog-source-or-branch source-name head)
            (emit-datalog-source-or-branches source-name (rest forms))))))))

(defmacro- emit-datalog-or-group [form]
  (if (or-join-clause? form)
    (let [join-vars (nth form 1)]
      (if (vector? join-vars)
        (quasiquote
          (or-join-group
            ([]string [(splice (emit-not-join-vars join-vars))])
            ([]Not-Group [(splice (emit-datalog-or-branches (slice form 2)))])))
        (error "or-join expects a vector of join vars")))
    (if (or-clause? form)
      (quasiquote
        (or-group ([]Not-Group [(splice (emit-datalog-or-branches (rest form)))])))
      (if (sourced-or-clause? form)
        (quasiquote
          (or-group ([]Not-Group [(splice (emit-datalog-source-or-branches (source (first form)) (slice form 2)))])))
        (error "or clauses must have shape (or [e a v] [e a v] ...), ($src or [e a v] ...), or (or-join [?x] ...)")))))

(defmacro- emit-predicate-terms [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-value-term (first forms))
      (emit-predicate-terms (rest forms)))))

(defmacro- emit-datalog-predicate [form]
  (if (predicate-clause? form)
    (let [expr (first form)]
      (if (>= (count expr) 2)
        (quasiquote
          (Predicate {op: (unquote (source (nth expr 0)))
                      terms: ([]Term [(splice (emit-predicate-terms (rest expr)))])}))
        (error "predicate clauses must have shape [(op arg arg ...)]")))
    (error "predicate clauses must have shape [(op arg arg ...)]")))

(defmacro- emit-datalog-function-clause [form]
  (if (function-clause? form)
    (let [expr (first form)
          out (nth form 1)]
      (if (vector? out)
        (quasiquote
          (Function-Clause {op: (unquote (source (nth expr 0)))
                            terms: ([]Term [(splice (emit-predicate-terms (rest expr)))])
                            out_vars: ([]string [(splice (emit-datalog-function-out-vars out))])
                            is_tuple: true}))
        (quasiquote
          (Function-Clause {op: (unquote (source (nth expr 0)))
                            terms: ([]Term [(splice (emit-predicate-terms (rest expr)))])
                            out: (unquote (emit-find-var out))}))))
    (error "function clauses must have shape [(op arg ...) ?out]")))

(defmacro- emit-datalog-function-out-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-find-var (first forms))
      (emit-datalog-function-out-vars (rest forms)))))

(defmacro- emit-datalog-get-else [form]
  (if (get-else-clause? form)
    (let [expr (first form)]
      (quasiquote
        (Get-Else {e: (unquote (emit-entity-term (nth expr 2)))
                   a: (unquote (emit-attr (nth expr 3)))
                   default_value: (unquote (emit-literal-value (nth expr 4)))
                   out: (unquote (emit-find-var (nth form 1)))})))
    (error "get-else clauses must have shape [(get-else $ ?e :attr default) ?out]")))

(defmacro- emit-get-some-attrs [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-attr (first forms))
      (emit-get-some-attrs (rest forms)))))

(defmacro- emit-datalog-get-some [form]
  (if (get-some-clause? form)
    (let [expr (first form)
          out (nth form 1)]
      (quasiquote
        (Get-Some {e: (unquote (emit-entity-term (nth expr 2)))
                   attrs: ([]string [(splice (emit-get-some-attrs (slice expr 3)))])
                   out_attr: (unquote (emit-find-var (nth out 0)))
                   out_value: (unquote (emit-find-var (nth out 1)))})))
    (error "get-some clauses must have shape [(get-some $ ?e :attr ...) [?a ?v]]")))

(defmacro- emit-ground-tuple-vars [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-input-var (first forms))
      (emit-ground-tuple-vars (rest forms)))))

(defmacro- ground-relation-output? [form]
  (cond
    (not (vector? form)) false
    (not (= (count form) 2)) false
    (not (vector? (nth form 0))) false
    (not (symbol? (nth form 1))) false
    :else (= (source (nth form 1)) "...")))

(defmacro- emit-datalog-ground [form]
  (if (ground-clause? form)
    (let [expr (first form)
          value (nth expr 1)
          out (nth form 1)]
      (if (ground-relation-output? out)
        (quasiquote
          (Ground {source: (unquote (emit-value-term value))
                   out: ""
                   tuple_vars: ([]string [(splice (emit-ground-tuple-vars (nth out 0)))])
                   is_collection: false
                   is_tuple: false
                   is_relation: true
                   width: (unquote (count (nth out 0)))}))
        (if (input-collection? out)
          (quasiquote
            (Ground {source: (unquote (emit-value-term value))
                     out: (unquote (emit-input-var out))
                     tuple_vars: ([]string [])
                     is_collection: true
                     is_tuple: false
                     is_relation: false}))
        (if (vector? out)
          (quasiquote
            (Ground {source: (unquote (emit-value-term value))
                     out: ""
                     tuple_vars: ([]string [(splice (emit-ground-tuple-vars out))])
                     is_collection: false
                     is_tuple: true
                     is_relation: false}))
          (quasiquote
            (Ground {source: (unquote (emit-value-term value))
                     out: (unquote (if (input-wildcard? out) (quasiquote "") (emit-find-var out)))
                     tuple_vars: ([]string [])
                     is_collection: false
                     is_tuple: false
                     is_relation: false}))))))
    (error "ground clauses must have shape [(ground value) ?out], [(ground [...]) [?out ...]], or [(ground [[...]]) [[?out ...]...]]")))

(defmacro- datalog-non-data-clause? [form]
  (cond
    (predicate-clause? form) true
    (function-clause? form) true
    (get-else-clause? form) true
    (get-some-clause? form) true
    (ground-clause? form) true
    (missing-clause? form) true
    (not-clause? form) true
    (sourced-not-clause? form) true
    (not-join-clause? form) true
    (or-clause? form) true
    (sourced-or-clause? form) true
    (or-join-clause? form) true
    :else (rule-call? form)))

(defmacro- emit-datalog-clauses [forms]
  (if (= (count forms) 0)
    (forms)
    (let [head (first forms)]
      (if (datalog-non-data-clause? head)
        (emit-datalog-clauses (rest forms))
        (if (and-clause? head)
          (forms
            (emit-datalog-clauses (rest head))
            (emit-datalog-clauses (rest forms)))
          (forms
            (emit-datalog-clause head)
            (emit-datalog-clauses (rest forms))))))))

(defmacro- emit-datalog-predicates [forms]
  (if (= (count forms) 0)
    (forms)
    (if (predicate-clause? (first forms))
      (forms
        (emit-datalog-predicate (first forms))
        (emit-datalog-predicates (rest forms)))
      (emit-datalog-predicates (rest forms)))))

(defmacro- emit-rule-call-args [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-value-term (first forms))
      (emit-rule-call-args (rest forms)))))

(defmacro- emit-datalog-rule-call [form]
  (if (rule-call? form)
    (if (relation-source? (first form))
      (quasiquote
        (Rule-Call {name: (unquote (source (nth form 1)))
                    source: (unquote (source (first form)))
                    has_source: true
                    args: ([dynamic]Term [(splice (emit-rule-call-args (slice form 2)))])}))
      (quasiquote
        (Rule-Call {name: (unquote (source (first form)))
                    args: ([dynamic]Term [(splice (emit-rule-call-args (rest form)))])})))
    (error "rule calls must have shape (rule ?arg ...)")))

(defmacro- emit-datalog-rule-calls [forms]
  (if (= (count forms) 0)
    (forms)
    (if (rule-call? (first forms))
      (forms
        (emit-datalog-rule-call (first forms))
        (emit-datalog-rule-calls (rest forms)))
      (emit-datalog-rule-calls (rest forms)))))

(defmacro- emit-datalog-function-clauses [forms]
  (if (= (count forms) 0)
    (forms)
    (if (function-clause? (first forms))
      (forms
        (emit-datalog-function-clause (first forms))
        (emit-datalog-function-clauses (rest forms)))
      (emit-datalog-function-clauses (rest forms)))))

(defmacro- emit-datalog-get-elses [forms]
  (if (= (count forms) 0)
    (forms)
    (if (get-else-clause? (first forms))
      (forms
        (emit-datalog-get-else (first forms))
        (emit-datalog-get-elses (rest forms)))
      (emit-datalog-get-elses (rest forms)))))

(defmacro- emit-datalog-get-somes [forms]
  (if (= (count forms) 0)
    (forms)
    (if (get-some-clause? (first forms))
      (forms
        (emit-datalog-get-some (first forms))
        (emit-datalog-get-somes (rest forms)))
      (emit-datalog-get-somes (rest forms)))))

(defmacro- emit-datalog-grounds [forms]
  (if (= (count forms) 0)
    (forms)
    (if (ground-clause? (first forms))
      (forms
        (emit-datalog-ground (first forms))
        (emit-datalog-grounds (rest forms)))
      (emit-datalog-grounds (rest forms)))))

(defmacro- emit-datalog-not-groups [forms]
  (if (= (count forms) 0)
    (forms)
    (if (not-clause? (first forms))
      (forms
        (emit-datalog-not-group (first forms))
        (emit-datalog-not-groups (rest forms)))
      (if (sourced-not-clause? (first forms))
        (forms
          (emit-datalog-not-group (first forms))
          (emit-datalog-not-groups (rest forms)))
        (if (not-join-clause? (first forms))
          (forms
            (emit-datalog-not-group (first forms))
            (emit-datalog-not-groups (rest forms)))
          (if (missing-clause? (first forms))
            (forms
              (emit-datalog-missing-group (first forms))
              (emit-datalog-not-groups (rest forms)))
            (emit-datalog-not-groups (rest forms))))))))

(defmacro- emit-datalog-or-groups [forms]
  (if (= (count forms) 0)
    (forms)
    (if (or-clause? (first forms))
      (forms
        (emit-datalog-or-group (first forms))
        (emit-datalog-or-groups (rest forms)))
      (if (sourced-or-clause? (first forms))
        (forms
          (emit-datalog-or-group (first forms))
          (emit-datalog-or-groups (rest forms)))
        (if (or-join-clause? (first forms))
          (forms
            (emit-datalog-or-group (first forms))
            (emit-datalog-or-groups (rest forms)))
          (emit-datalog-or-groups (rest forms)))))))

(defmacro- emit-pull-attrs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (brace? (first forms))
      (emit-pull-attrs (rest forms))
      (forms
        (if (keyword? (first forms))
          (source (first forms))
          (if (string? (first forms))
            (text (first forms))
            (if (vector? (first forms))
              (pull-attr-source (nth (first forms) 0))
              (if (and (symbol? (first forms))
                       (= (source (first forms)) "*"))
                "*"
                (error "pull patterns currently accept keyword, string, *, option vectors, or nested attrs")))))
        (emit-pull-attrs (rest forms))))))

(defmacro- pull-attr-source [form]
  (if (keyword? form)
    (source form)
    (if (string? form)
      (text form)
      (if (and (symbol? form)
               (= (source form) "*"))
        "*"
        (error "pull pattern attrs must be keywords, strings, or *")))))

(defmacro- pull-alias-source [form]
  (if (keyword? form)
    (source form)
    (if (string? form)
      (text form)
      (if (symbol? form)
        (source form)
        (error "pull :as expects keyword, string, or symbol alias")))))

(defmacro- pull-pattern-has-trailing-limit? [pattern]
  (if (= (count pattern) 3)
    (if (keyword? (nth pattern 1))
      (= (source (nth pattern 1)) ":limit")
      false)
    (if (= (count pattern) 4)
      (if (keyword? (nth pattern 2))
        (= (source (nth pattern 2)) ":limit")
        false)
      false)))

(defmacro- emit-pull-limit [form]
  (if (nil? form)
    (quasiquote -1)
    form))

(defmacro- recursion-ellipsis? [form]
  (if (symbol? form)
    (= (source form) "...")
    false))

(defmacro- emit-pull-nested-spec [attr pattern]
  (if (pull-pattern-has-trailing-limit? pattern)
    (if (= (count pattern) 3)
      (quasiquote
        (pull-spec-limit
          (unquote (pull-attr-source attr))
          ([]Pull-Spec [(splice (emit-pull-specs (slice pattern 0 1)))])
          (unquote (emit-pull-limit (nth pattern 2)))))
      (quasiquote
        (pull-spec-limit
          (unquote (pull-attr-source attr))
          ([]Pull-Spec [(splice (emit-pull-specs (slice pattern 0 2)))])
          (unquote (emit-pull-limit (nth pattern 3))))))
    (quasiquote
      (pull-spec
        (unquote (pull-attr-source attr))
        ([]Pull-Spec [(splice (emit-pull-specs pattern))])))))

(defmacro- emit-pull-spec [form]
  (if (vector? form)
    (if (keyword? (nth form 1))
      (if (= (count form) 3)
        (if (= (source (nth form 1)) ":default")
          (quasiquote
            (pull-spec-default
              (unquote (pull-attr-source (nth form 0)))
              (unquote (emit-literal-value (nth form 2)))))
          (if (= (source (nth form 1)) ":as")
            (quasiquote
              (pull-spec-as
                (unquote (pull-attr-source (nth form 0)))
                (unquote (pull-alias-source (nth form 2)))))
            (if (= (source (nth form 1)) ":limit")
              (quasiquote
                (pull-spec-limit
                  (unquote (pull-attr-source (nth form 0)))
                  ([]Pull-Spec [])
                  (unquote (emit-pull-limit (nth form 2)))))
              (error "pull option vectors currently support :default, :as, and :limit"))))
        (if (= (count form) 5)
          (if (keyword? (nth form 3))
            (if (= (source (nth form 1)) ":as")
              (if (= (source (nth form 3)) ":default")
                (quasiquote
                  (pull-spec-default-as
                    (unquote (pull-attr-source (nth form 0)))
                    (unquote (emit-literal-value (nth form 4)))
                    (unquote (pull-alias-source (nth form 2)))))
                (if (= (source (nth form 3)) ":limit")
                  (quasiquote
                    (pull-spec-limit-as
                      (unquote (pull-attr-source (nth form 0)))
                      ([]Pull-Spec [])
                      (unquote (emit-pull-limit (nth form 4)))
                      (unquote (pull-alias-source (nth form 2)))))
                  (error "combined pull option vectors currently support [:attr :default value :as alias], [:attr :as alias :default value], [:attr :limit n :as alias], or [:attr :as alias :limit n]")))
              (if (= (source (nth form 1)) ":default")
                (if (= (source (nth form 3)) ":as")
                  (quasiquote
                    (pull-spec-default-as
                      (unquote (pull-attr-source (nth form 0)))
                      (unquote (emit-literal-value (nth form 2)))
                      (unquote (pull-alias-source (nth form 4)))))
                  (error "combined pull option vectors currently support [:attr :default value :as alias] or [:attr :as alias :default value]"))
                (if (= (source (nth form 1)) ":limit")
                  (if (= (source (nth form 3)) ":as")
                    (quasiquote
                      (pull-spec-limit-as
                        (unquote (pull-attr-source (nth form 0)))
                        ([]Pull-Spec [])
                        (unquote (emit-pull-limit (nth form 2)))
                        (unquote (pull-alias-source (nth form 4)))))
                    (error "combined pull option vectors currently support [:attr :default value :as alias], [:attr :as alias :default value], [:attr :limit n :as alias], or [:attr :as alias :limit n]"))
                  (error "combined pull option vectors currently support [:attr :default value :as alias], [:attr :as alias :default value], [:attr :limit n :as alias], or [:attr :as alias :limit n]"))))
            (error "combined pull option vectors expect keyword options"))
          (error "pull option vectors currently have shape [:attr :default value], [:attr :as alias], [:attr :limit n], or [:attr :default value :as alias]")))
      (error "pull option vectors expect a keyword option"))
  (if (brace? form)
    (if (= (count form) 2)
      (let [attr (nth form 0)
            pattern (nth form 1)]
        (if (vector? pattern)
          (emit-pull-nested-spec attr pattern)
          (if (int? pattern)
            (quasiquote
              (pull-spec-recursion
                (unquote (pull-attr-source attr))
                (unquote pattern)))
            (if (recursion-ellipsis? pattern)
              (quasiquote
                (pull-spec-recursion
                  (unquote (pull-attr-source attr))
                  32))
              (error "nested pull attrs expect vector patterns or recursion depth")))))
      (error "nested pull maps currently support one attr"))
    (quasiquote
      (pull-spec
        (unquote (pull-attr-source form))
        ([]Pull-Spec []))))))

(defmacro- emit-pull-map-spec [attr pattern]
  (if (vector? pattern)
    (emit-pull-nested-spec attr pattern)
    (if (int? pattern)
      (quasiquote
        (pull-spec-recursion
          (unquote (pull-attr-source attr))
          (unquote pattern)))
      (if (recursion-ellipsis? pattern)
        (quasiquote
          (pull-spec-recursion
            (unquote (pull-attr-source attr))
            32))
        (error "nested pull attrs expect vector patterns or recursion depth")))))

(defmacro- emit-pull-map-specs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (> (count forms) 1)
      (forms
        (emit-pull-map-spec (nth forms 0) (nth forms 1))
        (emit-pull-map-specs (slice forms 2)))
      (error "nested pull maps expect attr/pattern pairs"))))

(defmacro- emit-pull-specs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (brace? (first forms))
      (concat
        (emit-pull-map-specs (first forms))
        (emit-pull-specs (rest forms)))
      (forms
        (emit-pull-spec (first forms))
        (emit-pull-specs (rest forms))))))

(defmacro- emit-pull-find [form]
  (if (pull-find? form)
    (let [source-name (if (= (count form) 4) (source (nth form 1)) "")
          var (if (= (count form) 4) (nth form 2) (nth form 1))
          pattern (if (= (count form) 4) (nth form 3) (nth form 2))]
      (if (vector? pattern)
        (quasiquote
          (Pull-Find {var: (unquote (emit-find-var var))
                      source: (unquote source-name)
                      has_source: (unquote (= (count form) 4))
                      has_pattern_var: false
                      pattern_var: ""
                      attrs: ([]string [(splice (emit-pull-attrs pattern))])
                      pattern: ([]Pull-Spec [(splice (emit-pull-specs pattern))])}))
        (if (symbol? pattern)
          (quasiquote
            (Pull-Find {var: (unquote (emit-find-var var))
                        source: (unquote source-name)
                        has_source: (unquote (= (count form) 4))
                        has_pattern_var: true
                        pattern_var: (unquote (emit-find-var pattern))
                        attrs: ([]string [])
                        pattern: ([]Pull-Spec [])}))
          (error "find pull expects a literal vector pattern or an input pattern var"))))
    (error ":find pull expressions must be (pull ?e pattern) or (pull $ ?e pattern)")))

(defmacro- emit-pull-finds [forms]
  (if (= (count forms) 0)
    (forms)
    (if (find-return-map-marker? (first forms))
      (forms)
      (if (pull-find? (first forms))
        (forms
          (emit-pull-find (first forms))
          (emit-pull-finds (rest forms)))
        (emit-pull-finds (rest forms))))))

(defmacro- emit-aggregate-find [form]
  (if (aggregate-find? form)
    (if (= (count form) 3)
      (if (int? (nth form 1))
        (quasiquote
          (Aggregate-Find {op: (unquote (source (first form)))
                           var: (unquote (emit-find-var (nth form 2)))
                           limit: (unquote (nth form 1))
                           has_limit: true}))
        (quasiquote
          (Aggregate-Find {op: (unquote (source (first form)))
                           var: (unquote (emit-find-var (nth form 2)))
                           limit_var: (unquote (emit-find-var (nth form 1)))
                           has_limit_var: true})))
      (quasiquote
        (Aggregate-Find {op: (unquote (source (first form)))
                         var: (unquote (emit-find-var (nth form 1)))})))
    (error "aggregate find expressions currently support count, count-distinct, min, max, sum, avg, median, variance, and stddev")))

(defmacro- emit-aggregate-finds [forms]
  (if (= (count forms) 0)
    (forms)
    (if (find-return-map-marker? (first forms))
      (forms)
      (if (aggregate-find? (first forms))
        (forms
          (emit-aggregate-find (first forms))
          (emit-aggregate-finds (rest forms)))
        (if (find-collection? (first forms))
          (if (aggregate-find? (nth (first forms) 0))
            (forms
              (emit-aggregate-find (nth (first forms) 0))
              (emit-aggregate-finds (rest forms)))
            (emit-aggregate-finds (rest forms)))
          (if (find-tuple? (first forms))
            (concat
              (emit-aggregate-finds (first (first forms)))
              (emit-aggregate-finds (rest forms)))
            (emit-aggregate-finds (rest forms))))))))

(defmacro datalog [form]
  (if (vector? form)
    (let [head (first form)]
      (if (keyword? head)
        (if (= (source head) ":find")
          (let [tail (rest form)
                find-items (datalog-find-items tail)
                with-items (datalog-with-items tail)
                input-items (datalog-input-items tail)
                where-items (datalog-where-items tail)]
            (if (find-direct-tuple? (first tail))
              (quasiquote
                (query
                  ([]string [(splice (emit-find-tuple-vars (first tail)))])
                  ([]string [(splice (emit-find-vars with-items))])
                  ([]string [(splice (emit-input-vars input-items))])
                  ([]string [(splice (emit-collection-input-vars input-items))])
                  ([]Tuple-Input [(splice (emit-tuple-inputs input-items))])
                  ([]Relation-Input [(splice (emit-relation-inputs input-items))])
                  ([]Clause [(splice (emit-datalog-clauses where-items))])
                  ([]Predicate [(splice (emit-datalog-predicates where-items))])
                  ([]Function-Clause [(splice (emit-datalog-function-clauses where-items))])
                  ([]Rule [])
                  ([]Rule-Call [(splice (emit-datalog-rule-calls where-items))])
                  ([]Get-Else [(splice (emit-datalog-get-elses where-items))])
                  ([]Get-Some [(splice (emit-datalog-get-somes where-items))])
                  ([]Ground [(splice (emit-datalog-grounds where-items))])
                  ([]Not-Group [(splice (emit-datalog-not-groups where-items))])
                  ([]Or-Group [(splice (emit-datalog-or-groups where-items))])
                  ([]Pull-Find [])
                  ([]Aggregate-Find [(splice (emit-aggregate-finds (first tail)))])))
              (quasiquote
                (query
                  ([]string [(splice (emit-find-vars find-items))])
                  ([]string [(splice (emit-find-vars with-items))])
                  ([]string [(splice (emit-input-vars input-items))])
                  ([]string [(splice (emit-collection-input-vars input-items))])
                  ([]Tuple-Input [(splice (emit-tuple-inputs input-items))])
                  ([]Relation-Input [(splice (emit-relation-inputs input-items))])
                  ([]Clause [(splice (emit-datalog-clauses where-items))])
                  ([]Predicate [(splice (emit-datalog-predicates where-items))])
                  ([]Function-Clause [(splice (emit-datalog-function-clauses where-items))])
                  ([]Rule [])
                  ([]Rule-Call [(splice (emit-datalog-rule-calls where-items))])
                  ([]Get-Else [(splice (emit-datalog-get-elses where-items))])
                  ([]Get-Some [(splice (emit-datalog-get-somes where-items))])
                  ([]Ground [(splice (emit-datalog-grounds where-items))])
                  ([]Not-Group [(splice (emit-datalog-not-groups where-items))])
                  ([]Or-Group [(splice (emit-datalog-or-groups where-items))])
                  ([]Pull-Find [(splice (emit-pull-finds find-items))])
                  ([]Aggregate-Find [(splice (emit-aggregate-finds find-items))])))))
          (error "datalog query must start with :find"))
        (error "datalog query must start with :find")))
    (error "datalog expects a vector query")))

(defmacro- emit-query-inputs [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (quasiquote
        (Query-Input {kind: .Scalar
                      value: (unquote (emit-literal-value (first forms)))}))
      (emit-query-inputs (rest forms)))))

(defmacro- emit-query-input-values [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-literal-value (first forms))
      (emit-query-input-values (rest forms)))))

(defmacro- emit-query-input-lookup-ref-values [forms]
  (if (= (count forms) 0)
    (forms)
    (if (lookup-ref? (first forms))
      (forms
        (emit-literal-value (nth (first forms) 1))
        (emit-query-input-lookup-ref-values (rest forms)))
      (error "lookup-ref collection inputs must contain lookup refs"))))

(defmacro- emit-query-input-lookup-ref-attrs [forms]
  (if (= (count forms) 0)
    (forms)
    (if (lookup-ref? (first forms))
      (if (keyword? (nth (first forms) 0))
        (forms
          (source (nth (first forms) 0))
          (emit-query-input-lookup-ref-attrs (rest forms)))
        (error "lookup-ref collection inputs require keyword attrs"))
      (error "lookup-ref collection inputs must contain lookup refs"))))

(defmacro- emit-query-relation-row-values [row]
  (if (= (count row) 0)
    (forms)
    (forms
      (emit-literal-value (first row))
      (emit-query-relation-row-values (rest row)))))

(defmacro- emit-query-relation-input-values [forms]
  (if (= (count forms) 0)
    (forms)
    (concat
      (emit-query-relation-row-values (first forms))
      (emit-query-relation-input-values (rest forms)))))

(defmacro- emit-query-input [form]
  (if (query-input-lookup-ref? form)
    (quasiquote
      (Query-Input {kind: .Scalar
                    has_lookup_ref: true
                    lookup_attr: (unquote (emit-attr (nth form 0)))
                    lookup_value: (unquote (emit-literal-value (nth form 1)))}))
    (if (vector? form)
      (if (> (count form) 0)
        (if (vector? (first form))
          (quasiquote
            (Query-Input {kind: .Relation
                          values: ([]Value [(splice (emit-query-relation-input-values form))])
                          width: (unquote (count (first form)))}))
          (quasiquote
            (Query-Input {kind: .Collection
                          values: ([]Value [(splice (emit-query-input-values form))])})))
        (quasiquote
          (Query-Input {kind: .Collection
                        values: ([]Value [])})))
      (quasiquote
        (Query-Input {kind: .Scalar
                      value: (unquote (emit-literal-value form))})))))

(defmacro- pull-find-pattern-var-name [form]
  (if (pull-find? form)
    (let [pattern (if (= (count form) 4) (nth form 3) (nth form 2))]
      (if (symbol? pattern)
        (emit-find-var pattern)
        ""))
    ""))

(defmacro- pull-pattern-var-in-finds? [forms name]
  (if (= (count forms) 0)
    false
    (if (= (pull-find-pattern-var-name (first forms)) name)
      true
      (pull-pattern-var-in-finds? (rest forms) name))))

(defmacro- input-spec-var-name [form]
  (if (or (input-source? form) (input-db-source? form))
    ""
    (if (input-collection? form)
      (emit-find-var (nth form 0))
      (if (input-relation? form)
        ""
        (if (input-tuple? form)
          ""
          (emit-find-var form))))))

(defmacro- pull-pattern-input? [find-items spec]
  (let [name (input-spec-var-name spec)]
    (if (= name "")
      false
      (pull-pattern-var-in-finds? find-items name))))

(defmacro- emit-query-collection-lookup-ref-input [value]
  (quasiquote
    (Query-Input {kind: .CollectionLookupRefs
                  lookup_attrs: ([]string [(splice (emit-query-input-lookup-ref-attrs value))])
                  lookup_values: ([]Value [(splice (emit-query-input-lookup-ref-values value))])})))

(defmacro- collection-lookup-ref-input? [spec value]
  (if (input-collection? spec)
    (if (vector? value)
      (if (> (count value) 0)
        (lookup-ref? (first value))
        false)
      false)
    false))

(defmacro- scalar-lookup-ref-input? [spec value]
  (if (or (input-source? spec) (input-db-source? spec))
    false
    (if (input-collection? spec)
      false
      (if (input-relation? spec)
        false
        (if (input-tuple? spec)
          false
          (lookup-ref? value))))))

(defmacro- emit-query-scalar-lookup-ref-input [value]
  (if (keyword? (nth value 0))
    (quasiquote
      (Query-Input {kind: .Scalar
                    has_lookup_ref: true
                    lookup_attr: (unquote (emit-attr (nth value 0)))
                    lookup_value: (unquote (emit-literal-value (nth value 1)))}))
    (error "lookup-ref scalar inputs require keyword attrs")))

(defmacro- emit-query-scalar-input [value]
  (quasiquote
    (Query-Input {kind: .Scalar
                  value: (unquote (emit-literal-value value))})))

(defmacro- scalar-input-spec? [spec]
  (not (or (input-source? spec)
           (input-db-source? spec)
           (input-collection? spec)
           (input-relation? spec)
           (input-tuple? spec))))

(defmacro- emit-query-input-for-spec [find-items spec value]
  (if (pull-pattern-input? find-items spec)
    (if (vector? value)
      (quasiquote
        (Query-Input {kind: .PullPattern
                      value: (unquote (emit-literal-value value))
                      pattern: ([]Pull-Spec [(splice (emit-pull-specs value))])}))
      (error "pull pattern inputs must be literal vectors"))
    (if (scalar-lookup-ref-input? spec value)
      (emit-query-scalar-lookup-ref-input value)
      (if (collection-lookup-ref-input? spec value)
        (emit-query-collection-lookup-ref-input value)
        (if (scalar-input-spec? spec)
          (emit-query-scalar-input value)
          (emit-query-input value))))))

(defmacro- input-kind? [spec kind]
  (cond
    (= kind "scalar") (scalar-input-spec? spec)
    (= kind "collection") (input-collection? spec)
    (= kind "tuple") (input-tuple? spec)
    :else (input-relation? spec)))

(defmacro- emit-query-input-list-for-kind [find-items specs values kind]
  (if (= (count values) 0)
    (forms)
    (if (= (count specs) 0)
      (forms)
      (let [spec (first specs)]
        (if (input-db-source? spec)
          (emit-query-input-list-for-kind find-items (rest specs) (rest values) kind)
          (if (input-source? spec)
          (if (= (source spec) "%")
            (if (rule-list? (first values))
              (emit-query-input-list-for-kind find-items (rest specs) (rest values) kind)
              (emit-query-input-list-for-kind find-items (rest specs) values kind))
            (if (= (source spec) "$")
              (emit-query-input-list-for-kind find-items (rest specs) values kind)
              (emit-query-input-list-for-kind find-items (rest specs) (rest values) kind)))
          (if (rule-list? (first values))
            (emit-query-input-list-for-kind find-items specs (rest values) kind)
            (if (input-kind? spec kind)
              (forms
                (emit-query-input-for-spec find-items spec (first values))
                (emit-query-input-list-for-kind find-items (rest specs) (rest values) kind))
              (emit-query-input-list-for-kind find-items (rest specs) (rest values) kind)))))))))

(defmacro- emit-query-input-list-for-query [find-items specs values]
  (if (= (count values) 0)
    (forms)
    (if (= (count specs) 0)
      (emit-query-input-list-without-rules values)
      (forms
        (emit-query-input-list-for-kind find-items specs values "scalar")
        (emit-query-input-list-for-kind find-items specs values "collection")
        (emit-query-input-list-for-kind find-items specs values "tuple")
        (emit-query-input-list-for-kind find-items specs values "relation")))))

(defmacro- emit-query-db-source-list [specs values]
  (if (or (= (count specs) 0) (= (count values) 0))
    (forms)
    (let [spec (first specs)]
      (if (input-db-source? spec)
        (forms
          (quasiquote (DB-Source {name: (unquote (source spec)) db: (unquote (first values))}))
          (emit-query-db-source-list (rest specs) (rest values)))
        (if (input-source? spec)
          (if (= (source spec) "%")
            (if (rule-list? (first values))
              (emit-query-db-source-list (rest specs) (rest values))
              (emit-query-db-source-list (rest specs) values))
            (emit-query-db-source-list (rest specs) values))
          (if (rule-list? (first values))
            (emit-query-db-source-list specs (rest values))
            (emit-query-db-source-list (rest specs) (rest values))))))))

(defmacro- emit-query-input-list [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-query-input (first forms))
      (emit-query-input-list (rest forms)))))

(defmacro- rule-list? [form]
  (if (vector? form)
    (if (> (count form) 0)
      (let [first-rule (first form)]
        (if (vector? first-rule)
          (if (> (count first-rule) 0)
            (list? (first first-rule))
            false)
          false))
      false)
    false))

(defmacro- emit-rule-params [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-find-var (first forms))
      (emit-rule-params (rest forms)))))

(defmacro- emit-rule [form]
  (if (vector? form)
    (let [head (first form)]
      (if (list? head)
        (quasiquote
          (Rule {name: (unquote (source (first head)))
                 params: ([dynamic]string [(splice (emit-rule-params (rest head)))])
                 clauses: ([dynamic]Clause [(splice (emit-datalog-clauses (rest form)))])
                 predicates: ([dynamic]Predicate [(splice (emit-datalog-predicates (rest form)))])
                 function_clauses: ([dynamic]Function-Clause [(splice (emit-datalog-function-clauses (rest form)))])
                 grounds: ([dynamic]Ground [(splice (emit-datalog-grounds (rest form)))])
                 rule_calls: ([dynamic]Rule-Call [(splice (emit-datalog-rule-calls (rest form)))])}))
        (error "rule definitions must start with a rule head")))
    (error "rule definitions must be vectors")))

(defmacro- emit-rules [forms]
  (if (= (count forms) 0)
    (forms)
    (forms
      (emit-rule (first forms))
      (emit-rules (rest forms)))))

(defmacro- emit-rule-input-rules [forms]
  (if (= (count forms) 0)
    (forms)
    (if (rule-list? (first forms))
      (forms
        (emit-rules (first forms))
        (emit-rule-input-rules (rest forms)))
      (emit-rule-input-rules (rest forms)))))

(defmacro- emit-query-input-list-without-rules [forms]
  (if (= (count forms) 0)
    (forms)
    (if (rule-list? (first forms))
      (emit-query-input-list-without-rules (rest forms))
      (forms
        (emit-query-input (first forms))
        (emit-query-input-list-without-rules (rest forms))))))

(defmacro q [db query-form & inputs]
  (if (vector? query-form)
    (let [tail (rest query-form)
          find-items (datalog-find-items tail)
          input-items (datalog-input-items tail)]
      (quasiquote
        (q-query-with-sources
          (unquote db)
          (query-with-rules
            (unquote (datalog query-form))
            ([]Rule [(splice (emit-rule-input-rules inputs))]))
          ([]Query-Input [(splice (emit-query-input-list-for-query find-items input-items inputs))])
          ([]DB-Source [(splice (emit-query-db-source-list input-items inputs))]))))
    (quasiquote
      (q-query-with-inputs
        (unquote db)
        (unquote query-form)
        ([]Query-Input [(splice (emit-query-input-list-without-rules inputs))])))))

(defmacro q-scalar [db query-form & inputs]
  (quasiquote
    (result-scalar (q (unquote db) (unquote query-form) (splice inputs)))))

(defmacro q-collection [db query-form & inputs]
  (quasiquote
    (result-collection (q (unquote db) (unquote query-form) (splice inputs)))))

(defmacro q-tuple [db query-form & inputs]
  (quasiquote
    (result-tuple (q (unquote db) (unquote query-form) (splice inputs)))))

(defmacro q-keys [db query-form & inputs]
  (if (vector? query-form)
    (quasiquote
      (result-keys
        (q (unquote db) (unquote query-form) (splice inputs))
        .Keyword
        ([]string [(splice (emit-result-keys (datalog-return-map-items (rest query-form) ":keys")))])))
    (error "q-keys expects a literal datalog query")))

(defmacro q-strs [db query-form & inputs]
  (if (vector? query-form)
    (quasiquote
      (result-keys
        (q (unquote db) (unquote query-form) (splice inputs))
        .String
        ([]string [(splice (emit-result-keys (datalog-return-map-items (rest query-form) ":strs")))])))
    (error "q-strs expects a literal datalog query")))

(defmacro q-syms [db query-form & inputs]
  (if (vector? query-form)
    (quasiquote
      (result-keys
        (q (unquote db) (unquote query-form) (splice inputs))
        .Symbol
        ([]string [(splice (emit-result-keys (datalog-return-map-items (rest query-form) ":syms")))])))
    (error "q-syms expects a literal datalog query")))

(defmacro datoms [db order & args]
  (if (keyword? order)
    (quasiquote
      (datoms-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "datoms index order must be a keyword")))

(defmacro datoms-checked [db order & args]
  (if (keyword? order)
    (quasiquote
      (datoms-checked-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "datoms-checked index order must be a keyword")))

(defmacro seek-datoms [db order & args]
  (if (keyword? order)
    (quasiquote
      (seek-datoms-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "seek-datoms index order must be a keyword")))

(defmacro seek-datoms-checked [db order & args]
  (if (keyword? order)
    (quasiquote
      (seek-datoms-checked-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "seek-datoms-checked index order must be a keyword")))

(defmacro rseek-datoms [db order & args]
  (if (keyword? order)
    (quasiquote
      (rseek-datoms-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "rseek-datoms index order must be a keyword")))

(defmacro rseek-datoms-checked [db order & args]
  (if (keyword? order)
    (quasiquote
      (rseek-datoms-checked-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "rseek-datoms-checked index order must be a keyword")))

(defmacro find-datom [db order & args]
  (if (keyword? order)
    (quasiquote
      (find-datom-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "find-datom index order must be a keyword")))

(defmacro index-range [db attr start end]
  (quasiquote
    (index-range-with-args
      (unquote db)
      (unquote (emit-attr attr))
      (unquote (emit-index-arg start))
      (unquote (if (nil? start) (quasiquote false) (quasiquote true)))
      (unquote (emit-index-arg end))
      (unquote (if (nil? end) (quasiquote false) (quasiquote true))))))

(defmacro index-range-checked [db attr start end]
  (quasiquote
    (index-range-checked-with-args
      (unquote db)
      (unquote (emit-attr attr))
      (unquote (emit-index-arg start))
      (unquote (if (nil? start) (quasiquote false) (quasiquote true)))
      (unquote (emit-index-arg end))
      (unquote (if (nil? end) (quasiquote false) (quasiquote true))))))

(defmacro transact [conn tx-form]
  (if (vector? tx-form)
    (quasiquote
      (transact-tx-data
        (unquote conn)
        ([]Tx-Data [(splice (emit-tx-data-items tx-form))])))
    (quasiquote (transact-tx-data (unquote conn) (unquote tx-form)))))

(defmacro pull [db pattern entity]
  (if (vector? pattern)
    (if (lookup-ref? entity)
      (quasiquote
        (pull-pattern-lookup-ref
          (unquote db)
          (unquote (emit-attr (nth entity 0)))
          (unquote (emit-literal-value (nth entity 1)))
          ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
      (if (keyword? entity)
        (quasiquote
          (pull-pattern-ident
            (unquote db)
            (unquote (source entity))
            ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
        (quasiquote
          (pull-pattern-spec
            (unquote db)
            (unquote entity)
            ([]Pull-Spec [(splice (emit-pull-specs pattern))])))))
    (quasiquote (pull-pattern (unquote db) (unquote entity) (unquote pattern)))))

(defmacro pull-many [db pattern entities]
  (if (vector? pattern)
    (if (and (vector? entities)
             (> (count entities) 0)
             (lookup-ref? (first entities)))
      (quasiquote
        (pull-many-pattern-lookup-refs
          (unquote db)
          ([]string [(splice (emit-query-input-lookup-ref-attrs entities))])
          ([]Value [(splice (emit-query-input-lookup-ref-values entities))])
          ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
      (quasiquote
        (pull-many-pattern-spec
          (unquote db)
          (unquote entities)
          ([]Pull-Spec [(splice (emit-pull-specs pattern))]))))
    (quasiquote (pull-many-pattern (unquote db) (unquote entities) (unquote pattern)))))

(defn not-group-simple [clauses: []Clause] -> Not-Group
  (let [owned-clauses (arr.into [dynamic]Clause clauses)
        owned-not-groups (make [dynamic]Not-Group)
        owned-join-vars (make [dynamic]string)]
    (Not-Group {clauses: owned-clauses
                not_groups: owned-not-groups
                has_join: false
                join_vars: owned-join-vars})))

(defn not-group [clauses: []Clause, not-groups: []Not-Group] -> Not-Group
  (let [owned-clauses (arr.into [dynamic]Clause clauses)
        owned-not-groups (arr.into [dynamic]Not-Group not-groups)
        owned-join-vars (make [dynamic]string)]
    (Not-Group {clauses: owned-clauses
                not_groups: owned-not-groups
                has_join: false
                join_vars: owned-join-vars})))

(defn not-join-group [join-vars: []string, clauses: []Clause, not-groups: []Not-Group] -> Not-Group
  (let [owned-clauses (arr.into [dynamic]Clause clauses)
        owned-not-groups (arr.into [dynamic]Not-Group not-groups)
        owned-join-vars (arr.into [dynamic]string join-vars)]
    (Not-Group {clauses: owned-clauses
                not_groups: owned-not-groups
                has_join: true
                join_vars: owned-join-vars})))

(defn or-group [branches: []Not-Group] -> Or-Group
  (let [owned-branches (arr.into [dynamic]Not-Group branches)
        owned-join-vars (make [dynamic]string)]
    (Or-Group {branches: owned-branches
               has_join: false
               join_vars: owned-join-vars})))

(defn or-join-group [join-vars: []string, branches: []Not-Group] -> Or-Group
  (let [owned-branches (arr.into [dynamic]Not-Group branches)
        owned-join-vars (arr.into [dynamic]string join-vars)]
    (Or-Group {branches: owned-branches
               has_join: true
               join_vars: owned-join-vars})))

(defn query [find: []string, with: []string, inputs: []string, collection-inputs: []string, tuple-inputs: []Tuple-Input, relation-inputs: []Relation-Input, clauses: []Clause, predicates: []Predicate, function-clauses: []Function-Clause, rules: []Rule, rule-calls: []Rule-Call, get-elses: []Get-Else, get-somes: []Get-Some, grounds: []Ground, not-groups: []Not-Group, or-groups: []Or-Group, pulls: []Pull-Find, aggregates: []Aggregate-Find] -> Query
  (let [owned-find (arr.into [dynamic]string find)
        owned-with (arr.into [dynamic]string with)
        owned-inputs (arr.into [dynamic]string inputs)
        owned-collection-inputs (arr.into [dynamic]string collection-inputs)
        owned-tuple-inputs (arr.into [dynamic]Tuple-Input tuple-inputs)
        owned-relation-inputs (arr.into [dynamic]Relation-Input relation-inputs)
        owned-clauses (arr.into [dynamic]Clause clauses)
        owned-predicates (arr.into [dynamic]Predicate predicates)
        owned-function-clauses (arr.into [dynamic]Function-Clause function-clauses)
        owned-rules (arr.into [dynamic]Rule rules)
        owned-rule-calls (arr.into [dynamic]Rule-Call rule-calls)
        owned-get-elses (arr.into [dynamic]Get-Else get-elses)
        owned-get-somes (arr.into [dynamic]Get-Some get-somes)
        owned-grounds (arr.into [dynamic]Ground grounds)
        owned-not-groups (arr.into [dynamic]Not-Group not-groups)
        owned-or-groups (arr.into [dynamic]Or-Group or-groups)
        owned-pulls (arr.into [dynamic]Pull-Find pulls)
        owned-aggregates (arr.into [dynamic]Aggregate-Find aggregates)]
    (Query {find: owned-find
            with: owned-with
            inputs: owned-inputs
            collection_inputs: owned-collection-inputs
            tuple_inputs: owned-tuple-inputs
            relation_inputs: owned-relation-inputs
            clauses: owned-clauses
            predicates: owned-predicates
            function_clauses: owned-function-clauses
            rules: owned-rules
            rule_calls: owned-rule-calls
            get_elses: owned-get-elses
            get_somes: owned-get-somes
            grounds: owned-grounds
            not_groups: owned-not-groups
            or_groups: owned-or-groups
            pulls: owned-pulls
            aggregates: owned-aggregates})))

(defn empty-query [] -> Query
  (query ([]string []) ([]string []) ([]string []) ([]string []) ([]Tuple-Input []) ([]Relation-Input []) ([]Clause []) ([]Predicate []) ([]Function-Clause []) ([]Rule []) ([]Rule-Call []) ([]Get-Else []) ([]Get-Some []) ([]Ground []) ([]Not-Group []) ([]Or-Group []) ([]Pull-Find []) ([]Aggregate-Find [])))

(defn empty-edn-doc [] -> EDN-Doc
  (EDN-Doc {nodes: (make [dynamic]EDN-Node) root: -1}))

(defn edn-node [kind: EDN-Kind, text: string] -> EDN-Node
  (EDN-Node {kind: kind text: text first_child: -1 next_sibling: -1 child_count: 0}))

(defn edn-add-node! [doc: ^EDN-Doc, node: EDN-Node] -> int
  (let [index (count doc^.nodes)]
    (arr.push! doc^.nodes node)
    index))

(defn edn-set-root! [doc: ^EDN-Doc, index: int]
  (set! doc^.root index))

(defn edn-set-first-child! [doc: ^EDN-Doc, index: int, child: int]
  (let [node doc^.nodes[index]]
    (set! node.first_child child)
    (set! doc^.nodes[index] node)))

(defn edn-set-next-sibling! [doc: ^EDN-Doc, index: int, sibling: int]
  (let [node doc^.nodes[index]]
    (set! node.next_sibling sibling)
    (set! doc^.nodes[index] node)))

(defn edn-inc-child-count! [doc: ^EDN-Doc, index: int]
  (let [node doc^.nodes[index]]
    (set! node.child_count (+ node.child_count 1))
    (set! doc^.nodes[index] node)))

(defn edn-whitespace? [ch: u8] -> bool
  (or (= ch 32)
      (= ch 10)
      (= ch 13)
      (= ch 9)
      (= ch 44)))

(defn edn-delimiter? [ch: u8] -> bool
  (or (edn-whitespace? ch)
      (= ch 40)
      (= ch 41)
      (= ch 91)
      (= ch 93)
      (= ch 123)
      (= ch 125)
      (= ch 34)))

(defn ascii-digit? [ch: u8] -> bool
  (and (>= ch 48) (<= ch 57)))

(defn edn-int-token? [token: string] -> bool
  (let [n (kstr.count token)]
    (when (= n 0)
      (return false))
    (if (= (kstr.get token 0) 45)
      (and (> n 1) (ascii-digit? (kstr.get token 1)))
      (ascii-digit? (kstr.get token 0)))))

(defn edn-skip-ws [text: string, i: int] -> int
  (let [out i
        n (kstr.count text)]
    (while (and (< out n) (edn-whitespace? (kstr.get text out)))
      (set! out (+ out 1)))
    out))

(defn read-edn-string! [doc: ^EDN-Doc, text: string, i: int] -> [next: int, node: int, ok: bool, error: string]
  (let [start (+ i 1)
        cursor start
        n (kstr.count text)]
    (while (and (< cursor n) (not (= (kstr.get text cursor) 34)))
      (if (= (kstr.get text cursor) 92)
        (set! cursor (+ cursor 2))
        (set! cursor (+ cursor 1))))
    (when (>= cursor n)
      (return cursor -1 false "unterminated EDN string"))
    (let [node-index (edn-add-node! doc (edn-node .String (kstr.slice text start cursor)))]
      (return (+ cursor 1) node-index true ""))))

(defn read-edn-atom! [doc: ^EDN-Doc, text: string, i: int] -> [next: int, node: int, ok: bool, error: string]
  (let [cursor i
        n (kstr.count text)]
    (while (and (< cursor n) (not (edn-delimiter? (kstr.get text cursor))))
      (set! cursor (+ cursor 1)))
    (when (= cursor i)
      (return cursor -1 false "expected EDN token"))
    (let [token (kstr.slice text i cursor)]
      (cond
        (= token "nil")
          (return cursor (edn-add-node! doc (edn-node .Nil token)) true "")
        (= token "true")
          (let [node (edn-node .Bool token)]
            (set! node.bool_value true)
            (return cursor (edn-add-node! doc node) true ""))
        (= token "false")
          (let [node (edn-node .Bool token)]
            (set! node.bool_value false)
            (return cursor (edn-add-node! doc node) true ""))
        (strings.has_prefix token ":")
          (return cursor (edn-add-node! doc (edn-node .Keyword token)) true "")
        (not (edn-int-token? token))
          (return cursor (edn-add-node! doc (edn-node .Symbol token)) true "")
        :else
          (let [[parsed parsed-ok] (strconv.parse_int token)]
            (if parsed-ok
              (let [node (edn-node .Int token)]
                (set! node.int_value (i64 parsed))
                (return cursor (edn-add-node! doc node) true ""))
              (return cursor (edn-add-node! doc (edn-node .Symbol token)) true "")))))))

(defn read-edn-form! [doc: ^EDN-Doc, text: string, i: int] -> [next: int, node: int, ok: bool, error: string]
  (let [cursor (edn-skip-ws text i)
        n (kstr.count text)]
    (when (>= cursor n)
      (return cursor -1 false "expected EDN form"))
    (let [ch (kstr.get text cursor)]
      (cond
        (= ch 91) (read-edn-container! doc text cursor .Vector 93)
        (= ch 40) (read-edn-container! doc text cursor .List 41)
        (= ch 123) (read-edn-container! doc text cursor .Map 125)
        (= ch 34) (read-edn-string! doc text cursor)
        (or (= ch 93) (= ch 41) (= ch 125))
          (return cursor -1 false "unexpected EDN closing delimiter")
        :else (read-edn-atom! doc text cursor)))))

(defn read-edn-container! [doc: ^EDN-Doc, text: string, i: int, kind: EDN-Kind, close: u8] -> [next: int, node: int, ok: bool, error: string]
  (let [container (edn-add-node! doc (edn-node kind ""))
        cursor (+ i 1)
        previous -1
        n (kstr.count text)]
    (while true
      (set! cursor (edn-skip-ws text cursor))
      (when (>= cursor n)
        (return cursor -1 false "unterminated EDN container"))
      (when (= (kstr.get text cursor) close)
        (return (+ cursor 1) container true ""))
      (let [[next child child-ok child-error] (read-edn-form! doc text cursor)]
        (when (not child-ok)
          (return next -1 false child-error))
        (if (= previous -1)
          (edn-set-first-child! doc container child)
          (edn-set-next-sibling! doc previous child))
        (edn-inc-child-count! doc container)
        (set! previous child)
        (set! cursor next)))
    (return cursor -1 false "unreachable EDN container state")))

(defn read-edn-text! [out: ^EDN-Doc, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [next root parsed-ok parsed-error] (read-edn-form! (addr doc) text 0)]
    (when (not parsed-ok)
      (delete doc.nodes)
      (return false parsed-error))
    (let [end (edn-skip-ws text next)]
      (when (not (= end (kstr.count text)))
        (delete doc.nodes)
        (return false "trailing EDN input")))
    (edn-set-root! (addr doc) root)
    (set! out^ doc)
    (return true "")))

(defn edn-child-at [doc: EDN-Doc, node-index: int, position: int] -> int
  (let [child doc.nodes[node-index].first_child
        current 0]
    (while (and (not (= child -1)) (< current position))
      (set! child doc.nodes[child].next_sibling)
      (set! current (+ current 1)))
    child))

(defn edn-symbol-text? [doc: EDN-Doc, node-index: int, text: string] -> bool
  (and (not (= node-index -1))
       (= doc.nodes[node-index].kind .Symbol)
       (= doc.nodes[node-index].text text)))

(defn edn-keyword-text? [doc: EDN-Doc, node-index: int, text: string] -> bool
  (and (not (= node-index -1))
       (= doc.nodes[node-index].kind .Keyword)
       (= doc.nodes[node-index].text text)))

(defn edn-source-var? [doc: EDN-Doc, node-index: int] -> bool
  (and (not (= node-index -1))
       (= doc.nodes[node-index].kind .Symbol)
       (strings.has_prefix doc.nodes[node-index].text "$")))

(defn edn-var? [doc: EDN-Doc, node-index: int] -> bool
  (and (not (= node-index -1))
       (= doc.nodes[node-index].kind .Symbol)
       (strings.has_prefix doc.nodes[node-index].text "?")))

(defn term-from-edn-node [doc: EDN-Doc, node-index: int, attr-position: bool] -> Term
  (let [node doc.nodes[node-index]]
    (cond
      (and (= node.kind .Symbol) (= node.text "_")) (term-wildcard)
      (and (= node.kind .Symbol) (strings.has_prefix node.text "?")) (term-var node.text)
      (= node.kind .String) (term-string node.text)
      (= node.kind .Keyword) (if attr-position (term-keyword node.text) (term-value (value-keyword node.text)))
      (= node.kind .Bool) (term-value (value-bool node.bool_value))
      (= node.kind .Int) (if attr-position (term-value (value-int node.int_value)) (term-entity (u64 node.int_value)))
      :else (term-string node.text))))

(defn value-term-from-edn-node [doc: EDN-Doc, node-index: int] -> Term
  (let [node doc.nodes[node-index]]
    (cond
      (and (= node.kind .Symbol) (= node.text "_")) (term-wildcard)
      (and (= node.kind .Symbol) (strings.has_prefix node.text "?")) (term-var node.text)
      (= node.kind .String) (term-string node.text)
      (= node.kind .Keyword) (term-value (value-keyword node.text))
      (= node.kind .Bool) (term-value (value-bool node.bool_value))
      (= node.kind .Int) (term-value (value-int node.int_value))
      (= node.kind .Nil) (term-value (value-nil))
      :else (term-string node.text))))

(defn edn-node-text [doc: EDN-Doc, node-index: int] -> string
  (if (= node-index -1)
    ""
    doc.nodes[node-index].text))

(defn edn-list-head-text [doc: EDN-Doc, node-index: int] -> string
  (if (or (= node-index -1)
          (not (= doc.nodes[node-index].kind .List)))
    ""
    (edn-node-text doc doc.nodes[node-index].first_child)))

(defn edn-terms-from-list-tail [doc: EDN-Doc, list-node: int] -> [dynamic]Term
  (let [out (make [dynamic]Term)
        child doc.nodes[doc.nodes[list-node].first_child].next_sibling]
    (while (not (= child -1))
      (arr.push! out (value-term-from-edn-node doc child))
      (set! child doc.nodes[child].next_sibling))
    out))

(defn edn-vars-from-vector [doc: EDN-Doc, vector-node: int] -> [dynamic]string
  (let [out (make [dynamic]string)
        child doc.nodes[vector-node].first_child]
    (while (not (= child -1))
      (if (edn-var? doc child)
        (arr.push! out doc.nodes[child].text)
        (arr.push! out ""))
      (set! child doc.nodes[child].next_sibling))
    out))

(defn query-input-scalar [value: Value] -> Query-Input
  (Query-Input {kind: .Scalar value: value}))

(defn query-input-collection [values: []Value] -> Query-Input
  (Query-Input {kind: .Collection values: values}))

(defn query-input-relation [values: []Value, width: int] -> Query-Input
  (Query-Input {kind: .Relation values: values width: width}))

(defn query-input-lookup-ref [attr: string, value: Value] -> Query-Input
  (Query-Input {kind: .Scalar has_lookup_ref: true lookup_attr: attr lookup_value: value}))

(defn query-input-collection-lookup-refs [attrs: []string, values: []Value] -> Query-Input
  (Query-Input {kind: .CollectionLookupRefs lookup_attrs: attrs lookup_values: values}))

(defn db-source [name: string, db: DB] -> DB-Source
  (DB-Source {name: name db: db}))

(defn query-from-text-parts [find: []string, with: []string, inputs: []string, collection-inputs: []string, tuple-inputs: []Tuple-Input, relation-inputs: []Relation-Input, clauses: []Clause, predicates: []Predicate, function-clauses: []Function-Clause, rule-calls: []Rule-Call, not-groups: []Not-Group, or-groups: []Or-Group, pulls: []Pull-Find, aggregates: []Aggregate-Find] -> Query
  (query find with inputs collection-inputs tuple-inputs relation-inputs clauses predicates function-clauses ([]Rule []) rule-calls ([]Get-Else []) ([]Get-Some []) ([]Ground []) not-groups or-groups pulls aggregates))

(defn db-source-name? [sources: []DB-Source, name: string] -> bool
  (when (= name "$")
    (return true))
  (for [source sources]
    (when (= source.name name)
      (return true)))
  false)

(defn append-edn-input-spec! [inputs: ^[dynamic]string, collection-inputs: ^[dynamic]string, tuple-inputs: ^[dynamic]Tuple-Input, relation-inputs: ^[dynamic]Relation-Input, doc: EDN-Doc, node-index: int, db-sources: []DB-Source] -> [ok: bool, error: string]
  (let [node doc.nodes[node-index]]
    (cond
      (and (= node.kind .Symbol) (db-source-name? db-sources node.text))
        (return true "")
      (and (= node.kind .Symbol) (= node.text "%"))
        (return true "")
      (and (= node.kind .Symbol) (strings.has_prefix node.text "$"))
        (do
          (arr.push! inputs^ node.text)
          (return true ""))
      (edn-var? doc node-index)
        (do
          (arr.push! inputs^ node.text)
          (return true ""))
      (= node.kind .Vector)
        (let [first-node node.first_child
              second-node (if (= first-node -1) -1 doc.nodes[first-node].next_sibling)]
          (cond
            (= first-node -1)
              (return false "empty :in vector spec")
            (= doc.nodes[first-node].kind .Vector)
              (do
                (let [vars (edn-vars-from-vector doc first-node)]
                  (arr.push! relation-inputs^ (Relation-Input {vars: (slice vars 0)})))
                (return true ""))
            (and (edn-var? doc first-node) (edn-symbol-text? doc second-node "..."))
              (do
                (arr.push! collection-inputs^ doc.nodes[first-node].text)
                (return true ""))
            :else
              (do
                (let [vars (edn-vars-from-vector doc node-index)]
                  (arr.push! tuple-inputs^ (Tuple-Input {vars: (slice vars 0)})))
                (return true ""))))
      :else (return false "query text :in currently supports vars, [?x ...], [?x ?y], and [[?x ?y]]"))))

(defn edn-pull-attr-source [doc: EDN-Doc, node-index: int] -> [attr: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Keyword) (return node.text true)
      (= node.kind .String) (return node.text true)
      (and (= node.kind .Symbol) (= node.text "*")) (return "*" true)
      :else (return "" false))))

(defn edn-pull-alias-source [doc: EDN-Doc, node-index: int] -> [alias: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Keyword (return node.text true)
      .String (return node.text true)
      .Symbol (return node.text true)
      :else (return "" false))))

(defn edn-pull-limit-value [doc: EDN-Doc, node-index: int] -> [limit: int, ok: bool]
  (when (= node-index -1)
    (return 0 false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Nil (return -1 true)
      .Int (return (int node.int_value) true)
      :else (return 0 false))))

(defn edn-pull-option-spec [doc: EDN-Doc, vector-node: int] -> [spec: Pull-Spec, ok: bool]
  (let [attr-node (edn-child-at doc vector-node 0)
        option-node (edn-child-at doc vector-node 1)
        value-node (edn-child-at doc vector-node 2)
        second-option-node (edn-child-at doc vector-node 3)
        second-value-node (edn-child-at doc vector-node 4)
        [attr attr-ok] (edn-pull-attr-source doc attr-node)]
    (when (not attr-ok)
      (return (Pull-Spec {}) false))
    (when (= doc.nodes[vector-node].child_count 3)
      (cond
        (edn-keyword-text? doc option-node ":default")
          (let [[value value-ok _] (edn-value-from-node doc value-node)]
            (return (pull-spec-default attr value) value-ok))
        (edn-keyword-text? doc option-node ":as")
          (let [[alias alias-ok] (edn-pull-alias-source doc value-node)]
            (return (pull-spec-as attr alias) alias-ok))
        (edn-keyword-text? doc option-node ":limit")
          (let [[limit limit-ok] (edn-pull-limit-value doc value-node)]
            (return (pull-spec-limit attr ([]Pull-Spec []) limit) limit-ok))
        :else (return (Pull-Spec {}) false)))
    (when (= doc.nodes[vector-node].child_count 5)
      (cond
        (and (edn-keyword-text? doc option-node ":default")
             (edn-keyword-text? doc second-option-node ":as"))
          (let [[value value-ok _] (edn-value-from-node doc value-node)
                [alias alias-ok] (edn-pull-alias-source doc second-value-node)]
            (return (pull-spec-default-as attr value alias) (and value-ok alias-ok)))
        (and (edn-keyword-text? doc option-node ":as")
             (edn-keyword-text? doc second-option-node ":default"))
          (let [[alias alias-ok] (edn-pull-alias-source doc value-node)
                [value value-ok _] (edn-value-from-node doc second-value-node)]
            (return (pull-spec-default-as attr value alias) (and value-ok alias-ok)))
        (and (edn-keyword-text? doc option-node ":limit")
             (edn-keyword-text? doc second-option-node ":as"))
          (let [[limit limit-ok] (edn-pull-limit-value doc value-node)
                [alias alias-ok] (edn-pull-alias-source doc second-value-node)]
            (return (pull-spec-limit-as attr ([]Pull-Spec []) limit alias) (and limit-ok alias-ok)))
        (and (edn-keyword-text? doc option-node ":as")
             (edn-keyword-text? doc second-option-node ":limit"))
          (let [[alias alias-ok] (edn-pull-alias-source doc value-node)
                [limit limit-ok] (edn-pull-limit-value doc second-value-node)]
            (return (pull-spec-limit-as attr ([]Pull-Spec []) limit alias) (and limit-ok alias-ok)))
        :else (return (Pull-Spec {}) false)))
    (return (Pull-Spec {}) false)))

(defn edn-pull-specs [doc: EDN-Doc, vector-node: int] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec)
        child doc.nodes[vector-node].first_child]
    (while (not (= child -1))
      (if (= doc.nodes[child].kind .Map)
        (let [entry doc.nodes[child].first_child]
          (while (not (= entry -1))
            (let [pattern-node doc.nodes[entry].next_sibling
                  [attr attr-ok] (edn-pull-attr-source doc entry)]
              (when (and attr-ok (not (= pattern-node -1)) (= doc.nodes[pattern-node].kind .Vector))
                (let [nested (edn-pull-specs doc pattern-node)]
                  (arr.push! out (pull-spec attr (slice nested 0)))))
              (if (= pattern-node -1)
                (set! entry -1)
                (set! entry doc.nodes[pattern-node].next_sibling)))))
        (if (= doc.nodes[child].kind .Vector)
          (let [[spec spec-ok] (edn-pull-option-spec doc child)]
            (when spec-ok
              (arr.push! out spec)))
          (let [[attr attr-ok] (edn-pull-attr-source doc child)]
            (when attr-ok
              (arr.push! out (pull-spec attr ([]Pull-Spec [])))))))
      (set! child doc.nodes[child].next_sibling))
    out))

(defn append-edn-pull-find! [out: ^[dynamic]Pull-Find, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [head doc.nodes[form].first_child
        first-arg doc.nodes[head].next_sibling]
    (when (= first-arg -1)
      (return false "pull find expects entity var and pattern"))
    (let [var-node first-arg
          pattern-node doc.nodes[var-node].next_sibling
          source ""
          has-source false]
      (when (edn-source-var? doc first-arg)
        (set! source doc.nodes[first-arg].text)
        (set! has-source true)
        (set! var-node doc.nodes[first-arg].next_sibling)
        (set! pattern-node doc.nodes[var-node].next_sibling))
      (when (or (= var-node -1) (not (edn-var? doc var-node)))
        (return false "pull find expects an entity variable"))
      (when (or (= pattern-node -1) (not (= doc.nodes[pattern-node].kind .Vector)))
        (return false "pull find currently expects a literal vector pattern"))
      (let [pattern (edn-pull-specs doc pattern-node)]
        (arr.push! out^
          (Pull-Find {var: doc.nodes[var-node].text
                      source: source
                      has_source: has-source
                      has_pattern_var: false
                      pattern_var: ""
                      attrs: ([]string [])
                      pattern: (slice pattern 0)}))
        (return true "")))))

(defn edn-aggregate-op? [op: string] -> bool
  (or (= op "count")
      (= op "count-distinct")
      (= op "min")
      (= op "max")
      (= op "sum")
      (= op "avg")
      (= op "median")
      (= op "variance")
      (= op "stddev")))

(defn edn-top-n-aggregate-op? [op: string] -> bool
  (or (= op "min") (= op "max")))

(defn append-edn-aggregate-find! [out: ^[dynamic]Aggregate-Find, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[form].first_child]
    (when (or (= op-node -1) (not (= doc.nodes[op-node].kind .Symbol)))
      (return false "aggregate find expressions must start with a symbol"))
    (let [op doc.nodes[op-node].text
          first-arg doc.nodes[op-node].next_sibling
          second-arg (if (= first-arg -1) -1 doc.nodes[first-arg].next_sibling)]
      (when (not (edn-aggregate-op? op))
        (return false "unsupported aggregate find expression"))
      (when (= first-arg -1)
        (return false "aggregate find expression missing variable"))
      (if (= second-arg -1)
        (do
          (when (not (edn-var? doc first-arg))
            (return false "aggregate find expression expects variable argument"))
          (arr.push! out^ (Aggregate-Find {op: op var: doc.nodes[first-arg].text}))
          (return true ""))
        (do
          (when (not (and (edn-top-n-aggregate-op? op)
                          (= doc.nodes[second-arg].next_sibling -1)
                          (edn-var? doc second-arg)))
            (return false "top-n aggregate find expressions expect (min n ?x), (max n ?x), (min ?n ?x), or (max ?n ?x)"))
          (if (= doc.nodes[first-arg].kind .Int)
            (arr.push! out^ (Aggregate-Find {op: op
                                             var: doc.nodes[second-arg].text
                                             limit: (int doc.nodes[first-arg].int_value)
                                             has_limit: true}))
            (if (edn-var? doc first-arg)
              (arr.push! out^ (Aggregate-Find {op: op
                                               var: doc.nodes[second-arg].text
                                               limit_var: doc.nodes[first-arg].text
                                               has_limit_var: true}))
              (return false "top-n aggregate limit must be an int or variable")))
          (return true ""))))))

(defn append-edn-find-item! [find: ^[dynamic]string, pulls: ^[dynamic]Pull-Find, aggregates: ^[dynamic]Aggregate-Find, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (cond
    (edn-var? doc item)
      (do
        (arr.push! find^ doc.nodes[item].text)
        (return true ""))
    (and (= doc.nodes[item].kind .Symbol) (= doc.nodes[item].text "."))
      (return true "")
    (= doc.nodes[item].kind .List)
      (let [head (edn-list-head-text doc item)]
        (if (= head "pull")
          (append-edn-pull-find! pulls doc item)
          (append-edn-aggregate-find! aggregates doc item)))
    :else (return false "query text :find currently supports vars, tuples, pull, and aggregates")))

(defn append-edn-find-vector! [find: ^[dynamic]string, pulls: ^[dynamic]Pull-Find, aggregates: ^[dynamic]Aggregate-Find, doc: EDN-Doc, vector-node: int] -> [ok: bool, error: string]
  (let [first-node doc.nodes[vector-node].first_child
        second-node (if (= first-node -1) -1 doc.nodes[first-node].next_sibling)]
    (when (and (not (= first-node -1))
               (edn-symbol-text? doc second-node "..."))
      (return (append-edn-find-item! find pulls aggregates doc first-node)))
    (let [cursor first-node]
      (while (not (= cursor -1))
        (let [[item-ok item-error] (append-edn-find-item! find pulls aggregates doc cursor)]
          (when (not item-ok)
            (return false item-error)))
        (set! cursor doc.nodes[cursor].next_sibling))
      (return true ""))))

(defn append-edn-data-clause! [out: ^[dynamic]Clause, doc: EDN-Doc, node-index: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[node-index].kind .Vector))
    (return false "query text where clauses must be vectors"))
  (let [source ""
        has-source false
        term-node (edn-child-at doc node-index 0)]
    (when (edn-source-var? doc term-node)
      (set! source doc.nodes[term-node].text)
      (set! has-source true)
      (set! term-node doc.nodes[term-node].next_sibling))
    (when (or (= term-node -1)
              (= doc.nodes[term-node].next_sibling -1))
      (return false "query text clause is incomplete"))
    (let [e-node term-node
          a-node doc.nodes[e-node].next_sibling
          v-node doc.nodes[a-node].next_sibling
          tx-node -1
          op-node -1]
      (when (= v-node -1)
        (arr.push! out^
          (Clause {e: (term-from-edn-node doc e-node false)
                   a: (term-from-edn-node doc a-node true)
                   v: (term-wildcard)
                   source: source
                   has_source: has-source
                   source_width: (if has-source 2 0)}))
        (return true ""))
      (set! tx-node doc.nodes[v-node].next_sibling)
      (when (not (= tx-node -1))
        (set! op-node doc.nodes[tx-node].next_sibling))
      (when (and (not has-source) (not (= tx-node -1)))
        (return false "query text clauses currently need two or three terms unless source-qualified"))
      (when (and has-source (not (= op-node -1)) (not (= doc.nodes[op-node].next_sibling -1)))
        (return false "source query text clauses currently need two to five terms"))
      (arr.push! out^
        (Clause {e: (term-from-edn-node doc e-node false)
                 a: (term-from-edn-node doc a-node true)
                 v: (value-term-from-edn-node doc v-node)
                 tx_term: (if (= tx-node -1) (term-wildcard) (value-term-from-edn-node doc tx-node))
                 op_term: (if (= op-node -1) (term-wildcard) (value-term-from-edn-node doc op-node))
                 source: source
                 has_source: has-source
                 source_width: (if has-source (if (= tx-node -1) 3 (if (= op-node -1) 4 5)) 0)}))
      (return true ""))))

(defn append-edn-predicate! [out: ^[dynamic]Predicate, doc: EDN-Doc, expr: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[expr].first_child]
    (when (or (= op-node -1) (= doc.nodes[op-node].next_sibling -1))
      (return false "predicate clauses must have shape [(op arg ...)]"))
    (let [terms (edn-terms-from-list-tail doc expr)]
      (arr.push! out^ (Predicate {op: (edn-node-text doc op-node)
                                  terms: (slice terms 0)}))
      (return true ""))))

(defn append-edn-function-clause! [out: ^[dynamic]Function-Clause, doc: EDN-Doc, expr: int, output: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[expr].first_child]
    (when (or (= op-node -1) (= doc.nodes[op-node].next_sibling -1))
      (return false "function clauses must have shape [(op arg ...) ?out]"))
    (let [terms (edn-terms-from-list-tail doc expr)]
      (if (= doc.nodes[output].kind .Vector)
        (let [out-vars (edn-vars-from-vector doc output)]
          (arr.push! out^
            (Function-Clause {op: (edn-node-text doc op-node)
                              terms: (slice terms 0)
                              out_vars: (slice out-vars 0)
                              is_tuple: true})))
        (if (edn-var? doc output)
          (arr.push! out^
            (Function-Clause {op: (edn-node-text doc op-node)
                              terms: (slice terms 0)
                              out: doc.nodes[output].text}))
          (return false "function output must be a variable or vector of variables")))
      (return true ""))))

(defn append-edn-missing-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, expr: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[expr].child_count 4))
    (return false "missing? clauses must have shape [(missing? $ ?e :attr)]"))
  (let [db-node doc.nodes[doc.nodes[expr].first_child].next_sibling
        entity-node doc.nodes[db-node].next_sibling
        attr-node doc.nodes[entity-node].next_sibling]
    (arr.push! out^
      (not-group-simple
        ([]Clause [(Clause {e: (term-from-edn-node doc entity-node false)
                            a: (term-from-edn-node doc attr-node true)
                            v: (term-wildcard)})])))
    (return true "")))

(defn append-edn-not-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [clauses (make [dynamic]Clause) :defer
        cursor doc.nodes[doc.nodes[form].first_child].next_sibling]
    (while (not (= cursor -1))
      (let [[ok error] (append-edn-data-clause! (addr clauses) doc cursor)]
        (when (not ok)
          (return false error)))
      (set! cursor doc.nodes[cursor].next_sibling))
    (arr.push! out^ (not-group-simple (slice clauses 0)))
    (return true "")))

(defn append-edn-not-join-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [join-node doc.nodes[doc.nodes[form].first_child].next_sibling]
    (when (or (= join-node -1) (not (= doc.nodes[join-node].kind .Vector)))
      (return false "not-join expects a vector of join vars"))
    (let [join-vars (edn-vars-from-vector doc join-node) :defer
          clauses (make [dynamic]Clause) :defer
          not-groups (make [dynamic]Not-Group) :defer
          cursor doc.nodes[join-node].next_sibling]
      (while (not (= cursor -1))
        (let [[ok error] (append-edn-data-clause! (addr clauses) doc cursor)]
          (when (not ok)
            (return false error)))
        (set! cursor doc.nodes[cursor].next_sibling))
      (arr.push! out^ (not-join-group (slice join-vars 0) (slice clauses 0) (slice not-groups 0)))
      (return true ""))))

(defn append-edn-or-branch! [out: ^[dynamic]Not-Group, doc: EDN-Doc, branch: int] -> [ok: bool, error: string]
  (let [clauses (make [dynamic]Clause) :defer]
    (if (= doc.nodes[branch].kind .List)
      (let [head (edn-list-head-text doc branch)]
        (when (not (= head "and"))
          (return false "query text or branches support data clauses or and"))
        (let [cursor doc.nodes[doc.nodes[branch].first_child].next_sibling]
          (while (not (= cursor -1))
            (let [[ok error] (append-edn-data-clause! (addr clauses) doc cursor)]
              (when (not ok)
                (return false error)))
            (set! cursor doc.nodes[cursor].next_sibling))))
      (let [[ok error] (append-edn-data-clause! (addr clauses) doc branch)]
        (when (not ok)
          (return false error))))
    (arr.push! out^ (not-group-simple (slice clauses 0)))
    (return true "")))

(defn append-edn-or-group! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [branches (make [dynamic]Not-Group) :defer
        cursor doc.nodes[doc.nodes[form].first_child].next_sibling]
    (while (not (= cursor -1))
      (let [[ok error] (append-edn-or-branch! (addr branches) doc cursor)]
        (when (not ok)
          (return false error)))
      (set! cursor doc.nodes[cursor].next_sibling))
    (arr.push! out^ (or-group (slice branches 0)))
    (return true "")))

(defn append-edn-or-join-group! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [join-node doc.nodes[doc.nodes[form].first_child].next_sibling]
    (when (or (= join-node -1) (not (= doc.nodes[join-node].kind .Vector)))
      (return false "or-join expects a vector of join vars"))
    (let [join-vars (edn-vars-from-vector doc join-node) :defer
          branches (make [dynamic]Not-Group) :defer
          cursor doc.nodes[join-node].next_sibling]
      (while (not (= cursor -1))
        (let [[ok error] (append-edn-or-branch! (addr branches) doc cursor)]
          (when (not ok)
            (return false error)))
        (set! cursor doc.nodes[cursor].next_sibling))
      (arr.push! out^ (or-join-group (slice join-vars 0) (slice branches 0)))
      (return true ""))))

(defn rule-call-from-text-parts [name: string, source: string, has-source: bool, args: []Term] -> Rule-Call
  (let [owned-args (arr.into [dynamic]Term args)]
    (Rule-Call {name: name source: source has_source: has-source args: owned-args})))

(defn append-edn-rule-call! [out: ^[dynamic]Rule-Call, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [head doc.nodes[form].first_child]
    (when (or (= head -1) (not (= doc.nodes[head].kind .Symbol)))
      (return false "rule calls must start with a symbol"))
    (let [name-node head
          source ""
          has-source false]
      (when (edn-source-var? doc head)
        (set! source doc.nodes[head].text)
        (set! has-source true)
        (set! name-node doc.nodes[head].next_sibling)
        (when (or (= name-node -1) (not (= doc.nodes[name-node].kind .Symbol)))
          (return false "source-qualified rule calls must name a rule")))
    (let [args (make [dynamic]Term) :defer
          cursor doc.nodes[name-node].next_sibling]
      (while (not (= cursor -1))
        (arr.push! args (value-term-from-edn-node doc cursor))
        (set! cursor doc.nodes[cursor].next_sibling))
      (arr.push! out^ (rule-call-from-text-parts doc.nodes[name-node].text source has-source (slice args 0)))
      (return true "")))))

(defn append-edn-where-item! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (if (= doc.nodes[item].kind .List)
    (let [head (edn-list-head-text doc item)]
      (cond
        (= head "not") (append-edn-not-group! not-groups doc item)
        (= head "not-join") (append-edn-not-join-group! not-groups doc item)
        (= head "or") (append-edn-or-group! or-groups doc item)
        (= head "or-join") (append-edn-or-join-group! or-groups doc item)
        :else (return false "query text list where clauses currently support not, or, and rules")))
    (if (= doc.nodes[item].kind .Vector)
      (let [first-item (edn-child-at doc item 0)]
        (if (and (not (= first-item -1)) (= doc.nodes[first-item].kind .List))
          (let [expr first-item
                output doc.nodes[expr].next_sibling
                op (edn-list-head-text doc expr)]
            (cond
              (= op "missing?") (append-edn-missing-group! not-groups doc expr)
              (not (= output -1)) (append-edn-function-clause! function-clauses doc expr output)
              :else (append-edn-predicate! predicates doc expr)))
          (append-edn-data-clause! clauses doc item)))
      (return false "query text where clauses must be vectors or lists"))))

(defn append-edn-where-or-rule-item! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, rule-calls: ^[dynamic]Rule-Call, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (if (= doc.nodes[item].kind .List)
    (let [head (edn-list-head-text doc item)]
      (cond
        (= head "not") (append-edn-not-group! not-groups doc item)
        (= head "not-join") (append-edn-not-join-group! not-groups doc item)
        (= head "or") (append-edn-or-group! or-groups doc item)
        (= head "or-join") (append-edn-or-join-group! or-groups doc item)
        :else (append-edn-rule-call! rule-calls doc item)))
    (append-edn-where-item! clauses predicates function-clauses not-groups or-groups doc item)))

(defn rule-from-text-parts [name: string, params: []string, clauses: []Clause, predicates: []Predicate, function-clauses: []Function-Clause, rule-calls: []Rule-Call] -> Rule
  (let [owned-params (arr.into [dynamic]string params)
        owned-clauses (arr.into [dynamic]Clause clauses)
        owned-predicates (arr.into [dynamic]Predicate predicates)
        owned-functions (arr.into [dynamic]Function-Clause function-clauses)
        owned-grounds (make [dynamic]Ground)
        owned-calls (arr.into [dynamic]Rule-Call rule-calls)]
    (Rule {name: name
           params: owned-params
           clauses: owned-clauses
           predicates: owned-predicates
           function_clauses: owned-functions
           grounds: owned-grounds
           rule_calls: owned-calls})))

(defn append-edn-rule! [out: ^[dynamic]Rule, doc: EDN-Doc, rule-node: int] -> [ok: bool, error: string]
  (when (or (= rule-node -1) (not (= doc.nodes[rule-node].kind .Vector)))
    (return false "rule definitions must be vectors"))
  (let [head doc.nodes[rule-node].first_child]
    (when (or (= head -1) (not (= doc.nodes[head].kind .List)))
      (return false "rule definitions must start with a rule head"))
    (let [name-node doc.nodes[head].first_child]
      (when (or (= name-node -1) (not (= doc.nodes[name-node].kind .Symbol)))
        (return false "rule head must start with a symbol"))
        (let [params (make [dynamic]string) :defer
            clauses (make [dynamic]Clause) :defer
            predicates (make [dynamic]Predicate) :defer
            function-clauses (make [dynamic]Function-Clause) :defer
            not-groups (make [dynamic]Not-Group) :defer
            or-groups (make [dynamic]Or-Group) :defer
            rule-calls (make [dynamic]Rule-Call) :defer
            param doc.nodes[name-node].next_sibling
            body doc.nodes[head].next_sibling]
        (while (not (= param -1))
          (when (not (edn-var? doc param))
            (return false "rule params must be variables"))
          (arr.push! params doc.nodes[param].text)
          (set! param doc.nodes[param].next_sibling))
        (while (not (= body -1))
          (let [[body-ok body-error] (append-edn-where-or-rule-item! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr or-groups) (addr rule-calls) doc body)]
            (when (not body-ok)
              (return false body-error)))
          (set! body doc.nodes[body].next_sibling))
        (arr.push! out^ (rule-from-text-parts doc.nodes[name-node].text (slice params 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice rule-calls 0)))
        (return true "")))))

(defn parse-rules-edn! [out: ^[dynamic]Rule, doc: EDN-Doc] -> [ok: bool, error: string]
  (when (or (= doc.root -1) (not (= doc.nodes[doc.root].kind .Vector)))
    (return false "rules text must be an EDN vector"))
  (let [cursor doc.nodes[doc.root].first_child]
    (while (not (= cursor -1))
      (let [[rule-ok rule-error] (append-edn-rule! out doc cursor)]
        (when (not rule-ok)
          (return false rule-error)))
      (set! cursor doc.nodes[cursor].next_sibling))
    (return true "")))

(defn parse-rules-text! [out: ^[dynamic]Rule, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-rules-edn! out doc)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn parse-query-edn-with-sources! [out: ^Query, doc: EDN-Doc, db-sources: []DB-Source] -> [ok: bool, error: string]
  (when (or (= doc.root -1)
            (not (= doc.nodes[doc.root].kind .Vector)))
    (return false "query text must be an EDN vector"))
  (let [head (edn-child-at doc doc.root 0)]
    (when (not (edn-keyword-text? doc head ":find"))
      (return false "query text must start with [:find")))
  (let [find (make [dynamic]string) :defer
        with (make [dynamic]string) :defer
        inputs (make [dynamic]string) :defer
        collection-inputs (make [dynamic]string) :defer
        tuple-inputs (make [dynamic]Tuple-Input) :defer
        relation-inputs (make [dynamic]Relation-Input) :defer
        clauses (make [dynamic]Clause) :defer
        predicates (make [dynamic]Predicate) :defer
        function-clauses (make [dynamic]Function-Clause) :defer
        rule-calls (make [dynamic]Rule-Call) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer
        pulls (make [dynamic]Pull-Find) :defer
        aggregates (make [dynamic]Aggregate-Find) :defer
        cursor (edn-child-at doc doc.root 1)]
    (while (and (not (= cursor -1))
                (not (edn-keyword-text? doc cursor ":in"))
                (not (edn-keyword-text? doc cursor ":where"))
                (not (edn-keyword-text? doc cursor ":with"))
                (not (edn-keyword-text? doc cursor ":keys"))
                (not (edn-keyword-text? doc cursor ":strs"))
                (not (edn-keyword-text? doc cursor ":syms")))
      (if (= doc.nodes[cursor].kind .Vector)
        (let [[find-ok find-error] (append-edn-find-vector! (addr find) (addr pulls) (addr aggregates) doc cursor)]
          (when (not find-ok)
            (return false find-error)))
        (let [[find-ok find-error] (append-edn-find-item! (addr find) (addr pulls) (addr aggregates) doc cursor)]
          (when (not find-ok)
            (return false find-error))))
      (set! cursor doc.nodes[cursor].next_sibling))
    (when (or (edn-keyword-text? doc cursor ":keys")
              (edn-keyword-text? doc cursor ":strs")
              (edn-keyword-text? doc cursor ":syms"))
      (set! cursor doc.nodes[cursor].next_sibling)
      (while (and (not (= cursor -1))
                  (not (edn-keyword-text? doc cursor ":in"))
                  (not (edn-keyword-text? doc cursor ":with"))
                  (not (edn-keyword-text? doc cursor ":where")))
        (set! cursor doc.nodes[cursor].next_sibling)
        (continue)))
    (when (edn-keyword-text? doc cursor ":with")
      (set! cursor doc.nodes[cursor].next_sibling)
      (while (and (not (= cursor -1))
                  (not (edn-keyword-text? doc cursor ":in"))
                  (not (edn-keyword-text? doc cursor ":where")))
        (when (not (edn-var? doc cursor))
          (return false "query text :with currently supports vars"))
        (arr.push! with doc.nodes[cursor].text)
        (set! cursor doc.nodes[cursor].next_sibling)))
    (when (edn-keyword-text? doc cursor ":in")
      (set! cursor doc.nodes[cursor].next_sibling)
      (while (and (not (= cursor -1)) (not (edn-keyword-text? doc cursor ":where")))
        (let [[input-ok input-error] (append-edn-input-spec! (addr inputs) (addr collection-inputs) (addr tuple-inputs) (addr relation-inputs) doc cursor db-sources)]
          (when (not input-ok)
            (return false input-error)))
        (set! cursor doc.nodes[cursor].next_sibling)))
    (when (edn-keyword-text? doc cursor ":where")
      (set! cursor doc.nodes[cursor].next_sibling))
    (while (not (= cursor -1))
      (let [[item-ok item-error] (append-edn-where-or-rule-item! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr or-groups) (addr rule-calls) doc cursor)]
        (when (not item-ok)
          (return false item-error)))
      (set! cursor doc.nodes[cursor].next_sibling))
    (let [query-value (query-from-text-parts (slice find 0) (slice with 0) (slice inputs 0) (slice collection-inputs 0) (slice tuple-inputs 0) (slice relation-inputs 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice rule-calls 0) (slice not-groups 0) (slice or-groups 0) (slice pulls 0) (slice aggregates 0))]
      (set! out^ query-value)
      (return true ""))))

(defn parse-query-edn! [out: ^Query, doc: EDN-Doc] -> [ok: bool, error: string]
  (parse-query-edn-with-sources! out doc ([]DB-Source [])))

(defn parse-query-text-with-sources! [out: ^Query, text: string, db-sources: []DB-Source] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-query-edn-with-sources! out doc db-sources)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn parse-query-text! [out: ^Query, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-query-edn! out doc)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn q-text [db: DB, text: string] -> Result-Set
  (let [query-value (empty-query)
        [ok _] (parse-query-text! (addr query-value) text)]
    (if ok
      (q-query db query-value)
      (Result-Set {rows: (make [dynamic]Result-Row)}))))

(defn q-text-with-inputs [db: DB, text: string, inputs: []Query-Input] -> Result-Set
  (let [query-value (empty-query)
        [ok _] (parse-query-text! (addr query-value) text)]
    (if ok
      (q-query-with-inputs db query-value inputs)
      (Result-Set {rows: (make [dynamic]Result-Row)}))))

(defn q-text-with-sources [db: DB, text: string, inputs: []Query-Input, sources: []DB-Source] -> Result-Set
  (let [query-value (empty-query)
        [ok _] (parse-query-text-with-sources! (addr query-value) text sources)]
    (if ok
      (q-query-with-sources db query-value inputs sources)
      (Result-Set {rows: (make [dynamic]Result-Row)}))))

(defn q-text-with-rules [db: DB, text: string, rules-text: string, inputs: []Query-Input] -> Result-Set
  (let [query-value (empty-query)
        rules (make [dynamic]Rule) :defer
        [query-ok _] (parse-query-text! (addr query-value) text)]
    (when (not query-ok)
      (return (Result-Set {rows: (make [dynamic]Result-Row)})))
    (let [[rules-ok _] (parse-rules-text! (addr rules) rules-text)]
      (when (not rules-ok)
        (return (Result-Set {rows: (make [dynamic]Result-Row)})))
      (q-query-with-inputs db (query-with-rules query-value (slice rules 0)) inputs))))

(defn q-text-scalar [db: DB, text: string] -> [value: Value, ok: bool]
  (result-scalar (q-text db text)))

(defn q-text-scalar-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [value: Value, ok: bool]
  (result-scalar (q-text-with-inputs db text inputs)))

(defn q-text-collection [db: DB, text: string] -> [dynamic]Value
  (result-collection (q-text db text)))

(defn q-text-collection-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [dynamic]Value
  (result-collection (q-text-with-inputs db text inputs)))

(defn q-text-tuple [db: DB, text: string] -> [dynamic]Value
  (result-tuple (q-text db text)))

(defn q-text-tuple-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [dynamic]Value
  (result-tuple (q-text-with-inputs db text inputs)))

(defn append-edn-return-keys! [out: ^[dynamic]string, doc: EDN-Doc, marker: string] -> bool
  (let [cursor (edn-child-at doc doc.root 1)]
    (while (not (= cursor -1))
      (when (edn-keyword-text? doc cursor marker)
        (set! cursor doc.nodes[cursor].next_sibling)
        (while (and (not (= cursor -1))
                    (not (edn-keyword-text? doc cursor ":in"))
                    (not (edn-keyword-text? doc cursor ":where")))
          (let [node doc.nodes[cursor]]
            (case node.kind
              .Symbol (arr.push! out^ node.text)
              .Keyword (arr.push! out^ node.text)
              .String (arr.push! out^ node.text)
              :else (return false)))
          (set! cursor doc.nodes[cursor].next_sibling))
        (return true))
      (set! cursor doc.nodes[cursor].next_sibling))
    false))

(defn query-text-return-keys [text: string, marker: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        doc (empty-edn-doc)
        keys-ok false
        [read-ok _] (read-edn-text! (addr doc) text)]
    (when read-ok
      (set! keys-ok (append-edn-return-keys! (addr out) doc marker)))
    (delete doc.nodes)
    out))

(defn q-text-keys [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":keys") :defer]
    (result-keys (q-text db text) .Keyword (slice keys 0))))

(defn q-text-strs [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":strs") :defer]
    (result-keys (q-text db text) .String (slice keys 0))))

(defn q-text-syms [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":syms") :defer]
    (result-keys (q-text db text) .Symbol (slice keys 0))))

(defn edn-attr-text [doc: EDN-Doc, node-index: int] -> [attr: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Keyword) (return node.text true)
      (= node.kind .String) (return node.text true)
      :else (return "" false))))

(defn edn-value-from-node [doc: EDN-Doc, node-index: int] -> [value: Value, ok: bool, error: string]
  (when (= node-index -1)
    (return (Value {}) false "expected EDN value"))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Nil (return (value-nil) true "")
      .Bool (return (value-bool node.bool_value) true "")
      .Int (return (value-int node.int_value) true "")
      .String (return (value-string node.text) true "")
      .Symbol (return (value-string node.text) true "")
      .Keyword (return (value-keyword node.text) true "")
      .Vector (let [items (make [dynamic]Value) :defer
                    child node.first_child]
                (while (not (= child -1))
                  (let [[item item-ok item-error] (edn-value-from-node doc child)]
                    (when (not item-ok)
                      (return (Value {}) false item-error))
                    (arr.push! items item))
                  (set! child doc.nodes[child].next_sibling))
                (return (value-vector (slice items 0)) true ""))
      .Map (let [items (make [dynamic]Value) :defer
                 child node.first_child]
             (while (not (= child -1))
               (let [value-node doc.nodes[child].next_sibling]
                 (when (= value-node -1)
                   (return (Value {}) false "EDN map value missing"))
                 (let [[key key-ok key-error] (edn-value-from-node doc child)
                       [value value-ok value-error] (edn-value-from-node doc value-node)]
                   (when (not key-ok)
                     (return (Value {}) false key-error))
                   (when (not value-ok)
                     (return (Value {}) false value-error))
                   (arr.push! items key)
                   (arr.push! items value)
                   (set! child doc.nodes[value-node].next_sibling))))
             (return (value-map (slice items 0)) true ""))
      :else (return (Value {}) false "unsupported EDN value"))))

(defn edn-lookup-ref-node? [doc: EDN-Doc, node-index: int] -> bool
  (when (or (= node-index -1)
            (not (= doc.nodes[node-index].kind .Vector))
            (not (= doc.nodes[node-index].child_count 2)))
    (return false))
  (let [attr-node (edn-child-at doc node-index 0)
        [attr attr-ok] (edn-attr-text doc attr-node)]
    (and attr-ok (strings.has_prefix attr ":"))))

(defn edn-entity-ref-from-node [doc: EDN-Doc, node-index: int] -> [ref: Tx-EDN-Entity, ok: bool, error: string]
  (when (= node-index -1)
    (return (Tx-EDN-Entity {}) false "expected entity id"))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Int)
        (return (Tx-EDN-Entity {kind: .Id e: (u64 node.int_value)}) true "")
      (= node.kind .String)
        (return (Tx-EDN-Entity {kind: .Tempid tempid: node.text}) true "")
      (= node.kind .Keyword)
        (if (current-tx-tempid? node.text)
          (return (Tx-EDN-Entity {kind: .Tempid tempid: node.text}) true "")
          (return (Tx-EDN-Entity {kind: .Ident ident: node.text}) true ""))
      (edn-lookup-ref-node? doc node-index)
        (let [attr-node (edn-child-at doc node-index 0)
              value-node (edn-child-at doc node-index 1)
              [attr attr-ok] (edn-attr-text doc attr-node)
              [value value-ok value-error] (edn-value-from-node doc value-node)]
          (when (not attr-ok)
            (return (Tx-EDN-Entity {}) false "lookup ref attribute must be keyword or string"))
          (when (not value-ok)
            (return (Tx-EDN-Entity {}) false value-error))
          (return (Tx-EDN-Entity {kind: .LookupRef lookup_attr: attr lookup_value: value}) true ""))
      :else (return (Tx-EDN-Entity {}) false "entity id must be int, tempid string, ident keyword, or lookup ref"))))

(defn tx-add-from-ref [ref: Tx-EDN-Entity, a: string, v: Value] -> Tx-Data
  (case ref.kind
    .Id (add ref.e a v)
    .Tempid (add-tempid ref.tempid a v)
    .LookupRef (add-lookup-ref ref.lookup_attr ref.lookup_value a v)
    .Ident (add-ident ref.ident a v)
    :else (Tx-Data {})))

(defn tx-add-value-tempid-from-ref [ref: Tx-EDN-Entity, a: string, value-tempid: string] -> Tx-Data
  (case ref.kind
    .Id (add-value-tempid ref.e a value-tempid)
    .Tempid (add-tempid-value-tempid ref.tempid a value-tempid)
    .LookupRef (add-lookup-ref-value-tempid ref.lookup_attr ref.lookup_value a value-tempid)
    .Ident (add-ident-value-tempid ref.ident a value-tempid)
    :else (Tx-Data {})))

(defn tx-add-value-lookup-ref-from-ref [ref: Tx-EDN-Entity, a: string, value-attr: string, value-value: Value] -> Tx-Data
  (case ref.kind
    .Id (add-value-lookup-ref ref.e a value-attr value-value)
    .Tempid (add-tempid-value-lookup-ref ref.tempid a value-attr value-value)
    .LookupRef (Tx-Data {op: ":db/add"
                         lookup_attr: ref.lookup_attr
                         lookup_value: ref.lookup_value
                         has_lookup_ref: true
                         a: a
                         value_lookup_attr: value-attr
                         value_lookup_value: value-value
                         has_value_lookup_ref: true})
    .Ident (Tx-Data {op: ":db/add"
                     ident: ref.ident
                     has_ident: true
                     a: a
                     value_lookup_attr: value-attr
                     value_lookup_value: value-value
                     has_value_lookup_ref: true})
    :else (Tx-Data {})))

(defn tx-add-ref-value-from-ref [ref: Tx-EDN-Entity, a: string, value-ref: Tx-EDN-Entity] -> Tx-Data
  (case value-ref.kind
    .Id (tx-add-from-ref ref a (value-entity value-ref.e))
    .Tempid (tx-add-value-tempid-from-ref ref a value-ref.tempid)
    .LookupRef (tx-add-value-lookup-ref-from-ref ref a value-ref.lookup_attr value-ref.lookup_value)
    .Ident (tx-add-from-ref ref a (value-keyword value-ref.ident))
    :else (Tx-Data {})))

(defn tx-retract-from-ref [ref: Tx-EDN-Entity, a: string, v: Value] -> Tx-Data
  (case ref.kind
    .Id (retract ref.e a v)
    .Tempid (retract-tempid ref.tempid a v)
    .LookupRef (retract-lookup-ref ref.lookup_attr ref.lookup_value a v)
    .Ident (retract-ident ref.ident a v)
    :else (Tx-Data {})))

(defn tx-retract-value-lookup-ref-from-ref [ref: Tx-EDN-Entity, a: string, value-attr: string, value-value: Value] -> Tx-Data
  (case ref.kind
    .Id (retract-value-lookup-ref ref.e a value-attr value-value)
    .Tempid (Tx-Data {op: ":db/retract"
                      tempid: ref.tempid
                      has_tempid: true
                      a: a
                      value_lookup_attr: value-attr
                      value_lookup_value: value-value
                      has_value_lookup_ref: true})
    .LookupRef (Tx-Data {op: ":db/retract"
                         lookup_attr: ref.lookup_attr
                         lookup_value: ref.lookup_value
                         has_lookup_ref: true
                         a: a
                         value_lookup_attr: value-attr
                         value_lookup_value: value-value
                         has_value_lookup_ref: true})
    .Ident (Tx-Data {op: ":db/retract"
                     ident: ref.ident
                     has_ident: true
                     a: a
                     value_lookup_attr: value-attr
                     value_lookup_value: value-value
                     has_value_lookup_ref: true})
    :else (Tx-Data {})))

(defn tx-retract-attr-from-ref [ref: Tx-EDN-Entity, a: string] -> Tx-Data
  (case ref.kind
    .Id (retract-attr ref.e a)
    .Tempid (retract-attr-tempid ref.tempid a)
    .LookupRef (retract-attr-lookup-ref ref.lookup_attr ref.lookup_value a)
    .Ident (retract-attr-ident ref.ident a)
    :else (Tx-Data {})))

(defn tx-retract-entity-from-ref [ref: Tx-EDN-Entity] -> Tx-Data
  (case ref.kind
    .Id (retract-entity ref.e)
    .Tempid (retract-entity-tempid ref.tempid)
    .LookupRef (retract-entity-lookup-ref ref.lookup_attr ref.lookup_value)
    .Ident (retract-entity-ident ref.ident)
    :else (Tx-Data {})))

(defn tx-cas-from-ref [ref: Tx-EDN-Entity, a: string, expected: Value, v: Value] -> Tx-Data
  (case ref.kind
    .Id (cas ref.e a expected v)
    .Tempid (cas-tempid ref.tempid a expected v)
    .LookupRef (cas-lookup-ref ref.lookup_attr ref.lookup_value a expected v)
    .Ident (Tx-Data {op: ":db.fn/cas" ident: ref.ident has_ident: true a: a expected: expected v: v})
    :else (Tx-Data {})))

(defn tx-cas-lookup-values-from-ref [ref: Tx-EDN-Entity, a: string, expected: Value, has-expected-lookup: bool, expected-attr: string, expected-value: Value, v: Value, has-value-lookup: bool, value-attr: string, value-value: Value] -> Tx-Data
  (let [data (tx-cas-from-ref ref a expected v)]
    (when has-expected-lookup
      (set! data.expected_lookup_attr expected-attr)
      (set! data.expected_lookup_value expected-value)
      (set! data.has_expected_lookup_ref true))
    (when has-value-lookup
      (set! data.value_lookup_attr value-attr)
      (set! data.value_lookup_value value-value)
      (set! data.has_value_lookup_ref true))
    data))

(defn edn-lookup-ref-parts [doc: EDN-Doc, node-index: int] -> [attr: string, value: Value, ok: bool, error: string]
  (when (not (edn-lookup-ref-node? doc node-index))
    (return "" (Value {}) false "expected lookup ref"))
  (let [attr-node (edn-child-at doc node-index 0)
        lookup-value-node (edn-child-at doc node-index 1)
        [lookup-attr attr-ok] (edn-attr-text doc attr-node)
        [lookup-value value-ok value-error] (edn-value-from-node doc lookup-value-node)]
    (when (not attr-ok)
      (return "" (Value {}) false "lookup ref attribute must be keyword or string"))
    (when (not value-ok)
      (return "" (Value {}) false value-error))
    (return lookup-attr lookup-value true "")))

(defn append-edn-tx-add-value! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, ref: Tx-EDN-Entity, a: string, value-node: int] -> [ok: bool, error: string]
  (if (and (= doc.nodes[value-node].kind .String)
           (not (edn-lookup-ref-node? doc value-node)))
    (do
      (arr.push! out^ (tx-add-from-ref ref a (value-string doc.nodes[value-node].text)))
      (return true ""))
    (if (edn-lookup-ref-node? doc value-node)
      (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc value-node)]
        (when (not lookup-ok)
          (return false lookup-error))
        (arr.push! out^ (tx-add-value-lookup-ref-from-ref ref a lookup-attr lookup-value))
        (return true ""))
      (let [[value value-ok value-error] (edn-value-from-node doc value-node)]
        (when (not value-ok)
          (return false value-error))
        (arr.push! out^ (tx-add-from-ref ref a value))
        (return true "")))))

(defn append-edn-tx-map-attr! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, ref: Tx-EDN-Entity, attr-node: int, value-node: int] -> [ok: bool, error: string]
  (let [[attr attr-ok] (edn-attr-text doc attr-node)]
    (when (not attr-ok)
      (return false "tx map attributes must be keywords or strings"))
    (when (= attr ":db/id")
      (return true ""))
    (if (= doc.nodes[value-node].kind .Vector)
      (do
        (if (edn-lookup-ref-node? doc value-node)
          (append-edn-tx-add-value! out doc ref attr value-node)
          (let [child doc.nodes[value-node].first_child]
            (while (not (= child -1))
              (let [[item-ok item-error] (append-edn-tx-add-value! out doc ref attr child)]
                (when (not item-ok)
                  (return false item-error)))
              (set! child doc.nodes[child].next_sibling))
            (return true ""))))
      (if (= doc.nodes[value-node].kind .Map)
        (let [nested-tempid (fmt.tprintf "__vev_tx_map_%d" value-node)
              [nested-id nested-has-id nested-id-error] (edn-tx-map-entity-ref doc value-node nested-tempid)]
          (when (not nested-has-id)
            (return false nested-id-error))
          (arr.push! out^ (tx-add-ref-value-from-ref ref attr nested-id))
          (append-edn-tx-map-items! out doc value-node nested-id))
        (append-edn-tx-add-value! out doc ref attr value-node)))))

(defn edn-tx-map-entity-ref [doc: EDN-Doc, map-node: int, generated-tempid: string] -> [ref: Tx-EDN-Entity, ok: bool, error: string]
  (let [child doc.nodes[map-node].first_child]
    (while (not (= child -1))
      (let [value-node doc.nodes[child].next_sibling]
        (when (= value-node -1)
          (return (Tx-EDN-Entity {}) false "tx map value missing"))
        (when (edn-keyword-text? doc child ":db/id")
          (return (edn-entity-ref-from-node doc value-node)))
        (set! child doc.nodes[value-node].next_sibling)))
    (return (Tx-EDN-Entity {kind: .Tempid tempid: generated-tempid}) true "")))

(defn append-edn-tx-map-items! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, map-node: int, ref: Tx-EDN-Entity] -> [ok: bool, error: string]
  (let [child doc.nodes[map-node].first_child]
    (while (not (= child -1))
      (let [value-node doc.nodes[child].next_sibling]
        (when (= value-node -1)
          (return false "tx map value missing"))
        (let [[item-ok item-error] (append-edn-tx-map-attr! out doc ref child value-node)]
          (when (not item-ok)
            (return false item-error)))
        (set! child doc.nodes[value-node].next_sibling)))
    (return true "")))

(defn append-edn-tx-map! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, map-node: int] -> [ok: bool, error: string]
  (let [generated-tempid (fmt.tprintf "__vev_tx_map_%d" map-node)
        [ref ref-ok ref-error] (edn-tx-map-entity-ref doc map-node generated-tempid)]
    (when (not ref-ok)
      (return false ref-error))
    (append-edn-tx-map-items! out doc map-node ref)))

(defn append-edn-tx-vector! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, vector-node: int] -> [ok: bool, error: string]
  (let [op-node (edn-child-at doc vector-node 0)]
    (when (= op-node -1)
      (return true ""))
    (when (not (= doc.nodes[op-node].kind .Keyword))
      (return false "tx-data operation must be a keyword"))
    (let [op doc.nodes[op-node].text]
      (cond
        (or (= op ":db/add") (= op ":db/retract"))
          (do
            (when (and (= op ":db/add") (not (= doc.nodes[vector-node].child_count 4)))
              (return false ":db/add expects [op e a v]"))
            (when (and (= op ":db/retract")
                       (not (= doc.nodes[vector-node].child_count 3))
                       (not (= doc.nodes[vector-node].child_count 4)))
              (return false ":db/retract expects [op e a] or [op e a v]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  v-node (edn-child-at doc vector-node 3)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (return false "tx-data attributes must be keywords or strings"))
              (if (= v-node -1)
                (do
                  (arr.push! out^ (tx-retract-attr-from-ref ref attr))
                  (return true ""))
                (if (= op ":db/add")
                  (append-edn-tx-add-value! out doc ref attr v-node)
                  (if (edn-lookup-ref-node? doc v-node)
                    (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc v-node)]
                      (when (not lookup-ok)
                        (return false lookup-error))
                      (arr.push! out^ (tx-retract-value-lookup-ref-from-ref ref attr lookup-attr lookup-value))
                      (return true ""))
                    (let [[value value-ok value-error] (edn-value-from-node doc v-node)]
                      (when (not value-ok)
                        (return false value-error))
                      (arr.push! out^ (tx-retract-from-ref ref attr value))
                      (return true "")))))))
        (or (= op ":db/retractEntity") (= op ":db.fn/retractEntity"))
          (do
            (when (not (= doc.nodes[vector-node].child_count 2))
              (return false ":db/retractEntity expects [op e]"))
            (let [[ref ref-ok ref-error] (edn-entity-ref-from-node doc (edn-child-at doc vector-node 1))]
              (when (not ref-ok)
                (return false ref-error))
              (arr.push! out^ (tx-retract-entity-from-ref ref))
              (return true "")))
        (= op ":db.fn/retractAttribute")
          (do
            (when (not (= doc.nodes[vector-node].child_count 3))
              (return false ":db.fn/retractAttribute expects [op e a]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (return false "tx-data attributes must be keywords or strings"))
              (arr.push! out^ (tx-retract-attr-from-ref ref attr))
              (return true "")))
        (or (= op ":db.fn/cas") (= op ":db/cas"))
          (do
            (when (not (= doc.nodes[vector-node].child_count 5))
              (return false ":db.fn/cas expects [op e a old new]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  old-node (edn-child-at doc vector-node 3)
                  new-node (edn-child-at doc vector-node 4)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)
                  expected (Value {})
                  expected-ok true
                  expected-error ""
                  expected-lookup-attr ""
                  expected-lookup-value (Value {})
                  has-expected-lookup false
                  value (Value {})
                  value-ok true
                  value-error ""
                  value-lookup-attr ""
                  value-lookup-value (Value {})
                  has-value-lookup false]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (return false "tx-data attributes must be keywords or strings"))
              (if (edn-lookup-ref-node? doc old-node)
                (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc old-node)]
                  (set! expected-lookup-attr lookup-attr)
                  (set! expected-lookup-value lookup-value)
                  (set! has-expected-lookup true)
                  (set! expected-ok lookup-ok)
                  (set! expected-error lookup-error))
                (let [[plain-value plain-ok plain-error] (edn-value-from-node doc old-node)]
                  (set! expected plain-value)
                  (set! expected-ok plain-ok)
                  (set! expected-error plain-error)))
              (if (edn-lookup-ref-node? doc new-node)
                (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc new-node)]
                  (set! value-lookup-attr lookup-attr)
                  (set! value-lookup-value lookup-value)
                  (set! has-value-lookup true)
                  (set! value-ok lookup-ok)
                  (set! value-error lookup-error))
                (let [[plain-value plain-ok plain-error] (edn-value-from-node doc new-node)]
                  (set! value plain-value)
                  (set! value-ok plain-ok)
                  (set! value-error plain-error)))
              (when (not expected-ok)
                (return false expected-error))
              (when (not value-ok)
                (return false value-error))
              (arr.push! out^ (tx-cas-lookup-values-from-ref ref attr expected has-expected-lookup expected-lookup-attr expected-lookup-value value has-value-lookup value-lookup-attr value-lookup-value))
              (return true "")))
        :else (return false "unknown tx-data operation")))))

(defn append-edn-tx-item! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, node-index: int] -> [ok: bool, error: string]
  (case doc.nodes[node-index].kind
    .Nil (return true "")
    .Vector (append-edn-tx-vector! out doc node-index)
    .Map (append-edn-tx-map! out doc node-index)
    :else (return false "tx-data expects vector or map items")))

(defn parse-tx-text! [out: ^[dynamic]Tx-Data, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (when (or (= doc.root -1) (not (= doc.nodes[doc.root].kind .Vector)))
      (delete doc.nodes)
      (return false "tx text must be an EDN vector"))
    (let [child doc.nodes[doc.root].first_child]
      (while (not (= child -1))
        (let [[item-ok item-error] (append-edn-tx-item! out doc child)]
          (when (not item-ok)
            (delete doc.nodes)
            (return false item-error)))
        (set! child doc.nodes[child].next_sibling)))
    (delete doc.nodes)
    (return true "")))

(defn transact-text [conn: ^Conn, text: string] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report conn^.db parse-error)))
    (transact-tx-data conn (slice tx-data 0))))

(defn query-with-rules [query: Query, rules: []Rule] -> Query
  (let [out query]
    (delete out.rules)
    (set! out.rules (arr.into [dynamic]Rule rules))
    (return out)))

(defn clone-datoms [datoms: [dynamic]Datom] -> [dynamic]Datom
  (arr.into [dynamic]Datom (slice datoms 0)))

(defn db [conn: ^Conn] -> DB
  (build-db (clone-datoms conn^.db.datoms)))

(defn clone-tx-meta [meta: []Tx-Meta] -> [dynamic]Tx-Meta
  (arr.into [dynamic]Tx-Meta meta))

(defn clone-binding [binding: Binding] -> Binding
  (let [items (arr.into [dynamic]Var-Binding (slice binding.items 0))]
    (Binding {items: items})))

(defn binding-lookup [binding: Binding, name: string] -> [value: Value, ok: bool]
  (for [item binding.items]
    (when (= item.name name)
      (return item.value true)))
  (return (Value {}) false))

(defn binding-store! [binding: ^Binding, name: string, value: Value]
  (arr.push! binding^.items (Var-Binding {name: name value: value})))

(defn query-input-scalar-value [db: DB, input: Query-Input] -> [value: Value, ok: bool]
  (when input.has_lookup_ref
    (let [[entity lookup-ok] (resolve-lookup-ref db input.lookup_attr input.lookup_value)]
      (when lookup-ok
        (return (value-entity entity) true))
      (return (Value {}) false)))
  (return input.value true))

(defn binding-from-inputs [db: DB, names: []string, values: []Query-Input] -> [bindings: [dynamic]Binding]
  (let [binding (Binding {})
        out (make [dynamic]Binding)]
    (for [name index names]
      (when (and (< index (count values))
                 (or (= values[index].kind .Scalar)
                     (= values[index].kind .PullPattern)))
        (let [[value ok] (query-input-scalar-value db values[index])]
          (if ok
            (binding-store! (addr binding) name value)
            (return out)))))
    (arr.push! out binding)
    out))

(defn expand-collection-input [bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .Collection)
      (for [binding bindings]
        (for [value input.values]
          (let [next (clone-binding binding)]
            (binding-store! (addr next) name value)
            (arr.push! out next)))))
    out))

(defn expand-collection-lookup-ref-input [db: DB, bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .CollectionLookupRefs)
      (for [binding bindings]
        (for [value index input.lookup_values]
          (let [[entity ok] (resolve-lookup-ref db input.lookup_attrs[index] value)]
            (when ok
              (let [next (clone-binding binding)]
                (binding-store! (addr next) name (value-entity entity))
                (arr.push! out next)))))))
    out))

(defn expand-tuple-input [bindings: []Binding, tuple: Tuple-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= (count tuple.vars) (count input.values))
      (for [binding bindings]
        (let [next (clone-binding binding)]
          (for [name index tuple.vars]
            (when (not (= name ""))
              (binding-store! (addr next) name input.values[index])))
          (arr.push! out next))))
    out))

(defn expand-relation-input [bindings: []Binding, relation: Relation-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        width (count relation.vars)]
    (when (and (= input.kind .Relation)
               (= input.width width))
      (let [row_count (/ (count input.values) width)]
        (for [binding bindings]
          (for [row 0..<row_count]
            (let [next (clone-binding binding)
                  offset (* row width)]
              (for [name index relation.vars]
                (when (not (= name ""))
                  (binding-store! (addr next) name input.values[(+ offset index)])))
              (arr.push! out next))))))
    out))

(defn bindings-from-inputs [db: DB, query: Query, inputs: []Query-Input] -> [dynamic]Binding
  (let [bindings (binding-from-inputs db (slice query.inputs 0) inputs)
        collection-offset (count query.inputs)
        tuple-offset (+ collection-offset (count query.collection_inputs))
        relation-offset (+ tuple-offset (count query.tuple_inputs))]
    (for [name index query.collection_inputs]
      (let [input-index (+ collection-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (make [dynamic]Binding)]
            (if (= inputs[input-index].kind .CollectionLookupRefs)
              (set! next-bindings (expand-collection-lookup-ref-input db (slice bindings 0) name inputs[input-index]))
              (set! next-bindings (expand-collection-input (slice bindings 0) name inputs[input-index])))
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [tuple index query.tuple_inputs]
      (let [input-index (+ tuple-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-tuple-input (slice bindings 0) tuple inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [relation index query.relation_inputs]
      (let [input-index (+ relation-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-relation-input (slice bindings 0) relation inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    bindings))

(defn match-term? [term: Term, actual: Value, binding: ^Binding] -> bool
  (case term.kind
    .Value (value-equal? term.value actual)
    .Wildcard true
    .Var (let [[existing ok] (binding-lookup binding^ term.name)]
           (if ok
             (predicate-value-equal? existing actual)
             (do
               (binding-store! binding term.name actual)
               true)))
    :else false))

(defn resolve-term [term: Term, binding: Binding] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (binding-lookup binding term.name))
    :else (return (Value {}) false)))

(defn resolve-entity-term [db: DB, term: Term, binding: Binding] -> [value: Value, ok: bool]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup_attr term.lookup_value)]
      (return (value-entity entity) lookup-ok)))
  (let [[resolved resolved-ok] (resolve-term term binding)]
    (when (not resolved-ok)
      (return resolved false))
    (when (= resolved.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db resolved.text)]
        (return (value-entity entity) ident-ok)))
    (when (= resolved.kind .Int)
      (return (value-entity (u64 resolved.int_value)) true))
    (return resolved true)))

(defn predicate-pair-matches? [op: string, left: Value, right: Value] -> bool
  (cond
    (= op "=") (predicate-value-equal? left right)
    (or (= op "!=") (= op "not=")) (not (predicate-value-equal? left right))
    (= op ">") (value-less? right left)
    (= op "<") (value-less? left right)
    (= op ">=") (not (value-less? left right))
    (= op "<=") (not (value-less? right left))
    :else false))

(defn predicate-matches? [predicate: Predicate, binding: Binding] -> bool
  (when (and (or (= predicate.op "even?")
                 (= predicate.op "odd?")
                 (= predicate.op "zero?")
                 (= predicate.op "pos?")
                 (= predicate.op "neg?"))
             (= (count predicate.terms) 1))
    (let [[value value-ok] (resolve-term predicate.terms[0] binding)]
      (when (not value-ok)
        (return false))
      (when (= value.kind .Int)
        (cond
          (= predicate.op "even?") (return (= (% value.int_value 2) 0))
          (= predicate.op "odd?") (return (not (= (% value.int_value 2) 0)))
          (= predicate.op "zero?") (return (= value.int_value 0))
          (= predicate.op "pos?") (return (> value.int_value 0))
          (= predicate.op "neg?") (return (< value.int_value 0))))
      (when (= value.kind .Entity)
        (cond
          (= predicate.op "even?") (return (= (% value.entity 2) 0))
          (= predicate.op "odd?") (return (not (= (% value.entity 2) 0)))
          (= predicate.op "zero?") (return (= value.entity 0))
          (= predicate.op "pos?") (return (> value.entity 0))
          (= predicate.op "neg?") (return false)))
      (return false)))
  (when (< (count predicate.terms) 2)
    (return false))
  (for [index (arr.range 0 (- (count predicate.terms) 1))]
    (let [[left left-ok] (resolve-term predicate.terms[index] binding)
          [right right-ok] (resolve-term predicate.terms[(+ index 1)] binding)]
      (when (not (and left-ok right-ok))
        (return false))
      (when (not (predicate-pair-matches? predicate.op left right))
        (return false))))
  true)

(defn map-get-value [map-value: Value, key: Value] -> [value: Value, ok: bool]
  (when (not (= map-value.kind .Map))
    (return (Value {}) false))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (when (value-equal? map-value.items[index] key)
        (return map-value.items[(+ index 1)] true))
      (set! index (+ index 2))))
  (return (Value {}) false))

(defn apply-function-op [function: Function-Clause, binding: Binding] -> [value: Value, ok: bool]
  (when (and (= function.op "count")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .String))
        (return (value-int (i64 (count input.text))) true))
      (return (Value {}) false)))
  (when (and (= function.op "identity")
             (= (count function.terms) 1))
    (return (resolve-term function.terms[0] binding)))
  (when (and (= function.op "inc")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Int))
        (return (value-int (+ input.int_value 1)) true))
      (return (Value {}) false)))
  (when (and (or (= function.op "first")
                 (= function.op "second"))
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)
          index (if (= function.op "first") 0 1)]
      (when (and input-ok
                 (= input.kind .Vector)
                 (< index (count input.items)))
        (return input.items[index] true))
      (return (Value {}) false)))
  (when (or (= function.op "vector")
            (= function.op "tuple"))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-vector (slice items 0)) true)))
  (when (and (= function.op "untuple")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Vector))
        (return input true))
      (return (Value {}) false)))
  (when (= function.op "hash-map")
    (when (not (= (% (count function.terms) 2) 0))
      (return (Value {}) false))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-map (slice items 0)) true)))
  (when (and (= function.op "get")
             (= (count function.terms) 2))
    (let [[map-value map-ok] (resolve-term function.terms[0] binding)
          [key key-ok] (resolve-term function.terms[1] binding)]
      (when (and map-ok key-ok)
        (return (map-get-value map-value key)))
      (return (Value {}) false)))
  (when (or (= function.op "+")
            (= function.op "-")
            (= function.op "*"))
    (when (= (count function.terms) 0)
      (return (Value {}) false))
    (let [[first-value first-ok] (resolve-term function.terms[0] binding)
          result first-value.int_value]
      (when (not (and first-ok (= first-value.kind .Int)))
        (return (Value {}) false))
      (for [term (slice function.terms 1)]
        (let [[next next-ok] (resolve-term term binding)]
          (when (not (and next-ok (= next.kind .Int)))
            (return (Value {}) false))
          (if (= function.op "+")
            (set! result (+ result next.int_value))
            (if (= function.op "-")
              (set! result (- result next.int_value))
              (set! result (* result next.int_value))))))
      (return (value-int result) true)))
  (return (Value {}) false))

(defn apply-function-clause [binding: Binding, function: Function-Clause] -> [out: Binding, ok: bool]
  (let [[value value-ok] (apply-function-op function binding)]
    (when (not value-ok)
      (return binding false))
    (when function.is_tuple
      (when (not (= value.kind .Vector))
        (return binding false))
      (when (not (= (count value.items) (count function.out_vars)))
        (return binding false))
      (let [next (clone-binding binding)]
        (for [name index function.out_vars]
          (when (not (= name "_"))
            (let [[bound bound-ok] (binding-with-value next name value.items[index])]
              (when (not bound-ok)
                (return binding false))
              (set! next bound))))
        (return next true)))
    (let [next (clone-binding binding)
          [existing exists] (binding-lookup next function.out)]
      (if exists
        (return next (predicate-value-equal? existing value))
        (do
          (binding-store! (addr next) function.out value)
          (return next true))))))

(defn datom-current-at? [db: DB, index: int] -> bool
  (let [current (slice db.current 0)
        found (int-lower-bound current index)]
    (and (< found (count current))
         (= current[found] index))))

(defn index-arg-value [db: DB, arg: Index-Arg] -> [value: Value, ok: bool]
  (when arg.has_lookup_ref
    (let [[entity found] (resolve-lookup-ref db arg.lookup_attr arg.lookup_value)]
      (when found
        (return (value-entity entity) true))
      (return (Value {}) false)))
  (return arg.value true))

(defn resolve-index-args [db: DB, args: []Index-Arg] -> [values: [dynamic]Value, ok: bool]
  (let [resolved (make [dynamic]Value)]
    (for [arg args]
      (let [[value ok] (index-arg-value db arg)]
        (when (not ok)
          (return resolved false))
        (arr.push! resolved value)))
    (return resolved true)))

(defn datom-index-position-value [datom: Datom, order: string, position: int] -> Value
  (if (= order ":eavt")
    (if (= position 0)
      (value-entity datom.e)
      (if (= position 1)
        (value-keyword datom.a)
        (if (= position 2)
          datom.v
          (Value {}))))
    (if (= order ":aevt")
      (if (= position 0)
        (value-keyword datom.a)
        (if (= position 1)
          (value-entity datom.e)
          (if (= position 2)
            datom.v
            (Value {}))))
      (if (= order ":avet")
        (if (= position 0)
          (value-keyword datom.a)
          (if (= position 1)
            datom.v
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))
        (if (= position 0)
          datom.v
          (if (= position 1)
            (value-keyword datom.a)
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))))))

(defn index-position-equal? [actual: Value, expected: Value] -> bool
  (predicate-value-equal? actual expected))

(defn index-position-compare [actual: Value, expected: Value] -> int
  (if (and (= actual.kind .Entity) (= expected.kind .Int))
    (let [right (u64 expected.int_value)]
      (if (< actual.entity right)
        -1
        (if (> actual.entity right) 1 0)))
    (if (and (= actual.kind .Keyword) (= expected.kind .String))
      (strings.compare actual.text expected.text)
      (value-compare actual expected))))

(defn datom-matches-index-values? [datom: Datom, order: string, values: []Value] -> bool
  (for [value position values]
    (when (not (index-position-equal? (datom-index-position-value datom order position) value))
      (return false)))
  true)

(defn datom-index-compare-values [datom: Datom, order: string, values: []Value] -> int
  (for [value position values]
    (let [compare (index-position-compare (datom-index-position-value datom order position) value)]
      (when (not (= compare 0))
        (return compare))))
  0)

(defn public-avet-attr? [db: DB, attr: string] -> bool
  (when (not (db-has-schema? db))
    (return true))
  (let [tuple-attrs (schema-tuple-attrs db attr)
        visible (or (schema-indexed? db attr)
                    (schema-unique? db attr)
                    (schema-ref? db attr)
                    (> (count tuple-attrs) 0))]
    (delete tuple-attrs)
    visible))

(defn public-index-datom-visible? [db: DB, order: string, datom: Datom] -> bool
  (if (= order ":avet")
    (public-avet-attr? db datom.a)
    true))

(defn index-arg-attr [db: DB, arg: Index-Arg] -> [attr: string, ok: bool]
  (let [[value value-ok] (index-arg-value db arg)]
    (when (not value-ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true))
    (return "" false)))

(defn validate-public-index-args [db: DB, order: string, args: []Index-Arg] -> [ok: bool, error: string]
  (when (not (= order ":avet"))
    (return true ""))
  (when (= (count args) 0)
    (return true ""))
  (let [[attr attr-ok] (index-arg-attr db args[0])]
    (when (not attr-ok)
      (return false "invalid index attr"))
    (when (not (public-avet-attr? db attr))
      (return false "attribute should be marked as :db/index true")))
  (return true ""))

(defn append-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (for [datom-index indexes]
    (when (datom-current-at? db datom-index)
      (let [datom db.datoms[datom-index]]
        (when (and (public-index-datom-visible? db order datom)
                   (datom-matches-index-values? datom order values))
          (arr.push! out^ datom))))))

(defn datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (datoms-with-args db order args)})))

(defn append-seek-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (for [datom-index indexes]
    (when (datom-current-at? db datom-index)
      (let [datom db.datoms[datom-index]]
        (when (and (public-index-datom-visible? db order datom)
                   (>= (datom-index-compare-values datom order values) 0))
          (arr.push! out^ datom))))))

(defn seek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-seek-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-seek-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-seek-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-seek-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn seek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (seek-datoms-with-args db order args)})))

(defn append-rseek-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (let [i (count indexes)]
    (while (> i 0)
      (set! i (- i 1))
      (let [datom-index indexes[i]]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (and (public-index-datom-visible? db order datom)
                       (<= (datom-index-compare-values datom order values) 0))
              (arr.push! out^ datom))))))))

(defn rseek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-rseek-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-rseek-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-rseek-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-rseek-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn rseek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (rseek-datoms-with-args db order args)})))

(defn find-datom-with-args [db: DB, order: string, args: []Index-Arg] -> Datom-Result
  (let [found (datoms-with-args db order args)]
    (defer (delete found))
    (when (> (count found) 0)
      (return (Datom-Result {found: true datom: found[0]})))
    (Datom-Result {})))

(defn index-range-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        start-value (Value {})
        end-value (Value {})]
    (when has-start
      (let [[value ok] (index-arg-value db start)]
        (when (not ok)
          (return out))
        (set! start-value value)))
    (when has-end
      (let [[value ok] (index-arg-value db end)]
        (when (not ok)
          (return out))
        (set! end-value value)))
    (for [datom-index db.avet]
      (when (datom-current-at? db datom-index)
        (let [datom db.datoms[datom-index]]
          (when (and (= datom.a attr)
                     (public-index-datom-visible? db ":avet" datom))
            (when (or (not has-start) (>= (index-position-compare datom.v start-value) 0))
              (when (or (not has-end) (<= (index-position-compare datom.v end-value) 0))
                (arr.push! out datom)))))))
    out))

(defn index-range-checked-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> Datoms-Result
  (when (not (public-avet-attr? db attr))
    (return (Datoms-Result {ok: false error: "attribute should be marked as :db/index true" datoms: (make [dynamic]Datom)})))
  (Datoms-Result {ok: true error: "" datoms: (index-range-with-args db attr start has-start end has-end)}))

(defn u64-contains? [items: []u64, value: u64] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn append-retract-entity-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, seen: ^[dynamic]u64]
  (when (u64-contains? (slice seen^ 0) entity)
    (return))
  (arr.push! seen^ entity)
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" entity "" (Value {}))
        high (upper-bound-index db indexes "eavt" entity "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db datom.a))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity datom.a datom.v))))))
  (let [ref-value (value-entity entity)
        indexes (slice db.vaet 0)
        low (lower-bound-index db indexes "vaet" 0 "" ref-value)
        high (upper-bound-index db indexes "vaet" 0 "" ref-value)]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (push-tx-op-once! ops (tx-retract datom.e datom.a datom.v)))))))

(defn append-retract-entity-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (append-retract-entity-ops-seen! ops db entity (addr seen))))

(defn append-retract-attr-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string, seen: ^[dynamic]u64]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db attr))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity attr datom.v)))))))

(defn append-retract-attr-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen entity)
    (append-retract-attr-ops-seen! ops db entity attr (addr seen))))

(defn schema-entity-for-attr [db: DB, attr: string] -> [e: u64, ok: bool]
  (let [value (value-keyword attr)
        indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 ":db/ident" value)
        high (upper-bound-index db indexes "avet" 0 ":db/ident" value)]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return db.datoms[datom-index].e true))))
  (return 0 false))

(defn db-has-schema? [db: DB] -> bool
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn schema-keyword [db: DB, attr: string, schema-attr: string] -> [value: string, ok: bool]
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return "" false))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Keyword))
            (return datom.v.text true))))))
  (return "" false))

(defn schema-bool? [db: DB, attr: string, schema-attr: string] -> bool
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return false))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Bool))
            (return datom.v.bool_value))))))
  false)

(defn schema-ident-for-entity [db: DB, entity: u64] -> [attr: string, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity ":db/ident" (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword))
          (return datom.v.text true)))))
  (return "" false))

(defn schema-tuple-attrs [db: DB, attr: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        [schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return out))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Vector))
            (for [item datom.v.items]
              (when (= item.kind .Keyword)
                (arr.push! out item.text)))))))
    out))

(defn tuple-schema-contains? [schema: Tuple-Schema, attr: string] -> bool
  (for [component schema.attrs]
    (when (= component attr)
      (return true)))
  false)

(defn tuple-schemas-containing [db: DB, attr: string] -> [dynamic]Tuple-Schema
  (let [out (make [dynamic]Tuple-Schema)
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[tuple-attr ident-ok] (schema-ident-for-entity db datom.e)]
            (when ident-ok
              (let [attrs (schema-tuple-attrs db tuple-attr)
                    schema (Tuple-Schema {attr: tuple-attr attrs: attrs})]
                (if (tuple-schema-contains? schema attr)
                  (arr.push! out schema)
                  (delete attrs))))))))
    out))

(defn schema-indexed? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/index"))

(defn schema-ref? [db: DB, attr: string] -> bool
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (and has-type (= schema-type ":db.type/ref"))))

(defn schema-component? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/isComponent"))

(defn value-matches-schema-type? [value: Value, schema-type: string] -> bool
  (cond
    (= schema-type ":db.type/string") (= value.kind .String)
    (= schema-type ":db.type/long") (= value.kind .Int)
    (= schema-type ":db.type/boolean") (= value.kind .Bool)
    (= schema-type ":db.type/ref") (= value.kind .Entity)
    (= schema-type ":db.type/keyword") (= value.kind .Keyword)
    :else true))

(defn valid-tuple-attrs-value? [db: DB, value: Value] -> bool
  (when (not (= value.kind .Vector))
    (return false))
  (when (= (count value.items) 0)
    (return false))
  (for [item value.items]
    (when (not (= item.kind .Keyword))
      (return false))
    (when (not (schema-cardinality-one? db item.text))
      (return false))
    (let [nested (schema-tuple-attrs db item.text)]
      (defer (delete nested))
      (when (> (count nested) 0)
        (return false))))
  true)

(defn valid-tuple-attr-target? [db: DB, schema-e: u64] -> bool
  (let [[attr attr-ok] (schema-ident-for-entity db schema-e)]
    (when (not attr-ok)
      (return true))
    (schema-cardinality-one? db attr)))

(defn unique-conflict? [db: DB, op: Tx-Op] -> bool
  (let [indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 op.a op.v)
        high (upper-bound-index db indexes "avet" 0 op.a op.v)]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.e op.e)))
          (return true)))))
  false)

(defn schema-unique? [db: DB, attr: string] -> bool
  (let [[unique has-unique] (schema-keyword db attr ":db/unique")]
    (and has-unique
         (or (= unique ":db.unique/identity")
             (= unique ":db.unique/value")))))

(defn schema-unique-identity? [db: DB, attr: string] -> bool
  (let [[unique has-unique] (schema-keyword db attr ":db/unique")]
    (and has-unique
         (= unique ":db.unique/identity"))))

(defn schema-cardinality-one? [db: DB, attr: string] -> bool
  (let [[cardinality has-cardinality] (schema-keyword db attr ":db/cardinality")]
    (if (and has-cardinality
             (= cardinality ":db.cardinality/many"))
      false
      true)))

(defn tx-op-cardinality-one? [db: DB, op: Tx-Op] -> bool
  (let [[cardinality has-cardinality] (schema-keyword db op.a ":db/cardinality")]
    (when (and has-cardinality
               (= cardinality ":db.cardinality/many"))
      (return false))
    true))

(defn resolve-lookup-ref [db: DB, attr: string, value: Value] -> [e: u64, ok: bool]
  (when (not (schema-unique? db attr))
    (return 0 false))
  (let [lookup-value value
        tuple-attrs (schema-tuple-attrs db attr)]
    (defer (delete tuple-attrs))
    (when (and (= value.kind .Vector)
               (= (count tuple-attrs) (count value.items)))
      (let [items (make [dynamic]Value 0 (count value.items))]
        (defer (delete items))
        (for [item index value.items]
          (let [component-attr tuple-attrs[index]]
            (if (schema-ref? db component-attr)
              (cond
                (= item.kind .Entity) (arr.push! items item)
                (= item.kind .Int) (arr.push! items (value-entity (u64 item.int_value)))
                (and (= item.kind .Vector)
                     (= (count item.items) 2)
                     (= item.items[0].kind .Keyword))
                  (let [[entity entity-ok] (resolve-lookup-ref db item.items[0].text item.items[1])]
                    (when (not entity-ok)
                      (return 0 false))
                    (arr.push! items (value-entity entity)))
                :else (arr.push! items item))
              (arr.push! items item))))
        (set! lookup-value (value-vector (slice items 0)))))
  (let [indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 attr lookup-value)
        high (upper-bound-index db indexes "avet" 0 attr lookup-value)]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return db.datoms[datom-index].e true))))
  (return 0 false)))

(defn current-value-exists? [db: DB, entity: u64, attr: string, value: Value] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v value))
          (return true)))))
  false)

(defn current-attr-exists? [db: DB, entity: u64, attr: string] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn cas-expected-matches? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (if (= expected.kind .Nil)
    (not (current-attr-exists? db entity attr))
    (current-value-exists? db entity attr expected)))

(defn resolve-tx-value [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (when (and has-type (= schema-type ":db.type/ref"))
      (when (= value.kind .Int)
        (return (value-entity (u64 value.int_value)) true ""))
      (when (= value.kind .Keyword)
        (let [[entity ident-ok] (schema-entity-for-attr db value.text)]
          (if ident-ok
            (return (value-entity entity) true "")
            (return value false "ident not found"))))))
  (return value true ""))

(defn resolve-cas-expected [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has_expected_lookup_ref
    (let [[lookup-e lookup-ok] (resolve-lookup-ref db data.expected_lookup_attr data.expected_lookup_value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.expected false "lookup ref not found"))))
  (resolve-tx-value db data.a data.expected))

(defn resolve-tx-data-value [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has_value_lookup_ref
    (let [[lookup-e lookup-ok] (resolve-lookup-ref db data.value_lookup_attr data.value_lookup_value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.v false "lookup ref not found"))))
  (resolve-tx-value db data.a data.v))

(defn tx-data-has-tempid? [tx-data: []Tx-Data, tempid: string] -> bool
  (for [data tx-data]
    (when (and data.has_tempid
               (= data.tempid tempid))
      (return true)))
  false)

(defn ref-string-value? [db: DB, attr: string, value: Value] -> bool
  (when (not (= value.kind .String))
    (return false))
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (and has-type
         (= schema-type ":db.type/ref"))))

(defn tempid-tuple-component-value [db: DB, tx-data: []Tx-Data, tempid: string, attr: string] -> [value: Value, ok: bool]
  (for [data tx-data]
    (when (and data.has_tempid
               (= data.tempid tempid)
               (= data.op ":db/add")
               (= data.a attr))
      (let [[value value-ok _] (resolve-tx-data-value db data)]
        (return value value-ok))))
  (return (Value {}) false))

(defn tuple-schema-already-seen? [schemas: []string, attr: string] -> bool
  (for [schema-attr schemas]
    (when (= schema-attr attr)
      (return true)))
  false)

(defn tempid-tuple-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false
        seen (make [dynamic]string)]
    (defer (delete seen))
    (for [data tx-data]
      (when (not (and data.has_tempid
                      (= data.tempid tempid)
                      (= data.op ":db/add")))
        (continue))
      (let [schemas (tuple-schemas-containing db data.a)]
        (defer (delete schemas))
        (for [schema schemas]
          (defer (delete schema.attrs))
          (when (not (schema-unique-identity? db schema.attr))
            (continue))
          (when (tuple-schema-already-seen? (slice seen 0) schema.attr)
            (continue))
          (arr.push! seen schema.attr)
          (let [items (make [dynamic]Value 0 (count schema.attrs))
                complete true]
            (for [component schema.attrs]
              (let [[value value-ok] (tempid-tuple-component-value db tx-data tempid component)]
                (if value-ok
                  (arr.push! items value)
                  (set! complete false))))
            (when complete
              (let [tuple-value (value-vector (slice items 0))
                    [entity entity-ok] (resolve-lookup-ref db schema.attr tuple-value)]
                (when entity-ok
                  (when (and has-found (not (= found entity)))
                    (delete items)
                    (return found false true))
                  (set! found entity)
                  (set! has-found true))))
            (delete items)))))
    (return found has-found false)))

(defn tempid-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false]
    (for [data tx-data]
      (when (and data.has_tempid
                 (= data.tempid tempid)
                 (= data.op ":db/add")
                 (schema-unique-identity? db data.a))
        (let [[value value-ok _] (resolve-tx-data-value db data)]
          (when value-ok
            (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
              (when entity-ok
                (when (and has-found (not (= found entity)))
                  (return found false true))
                (set! found entity)
                (set! has-found true)))))))
    (let [[tuple-e tuple-ok tuple-conflict] (tempid-tuple-upsert-entity db tx-data tempid)]
      (when tuple-conflict
        (return found false true))
      (when tuple-ok
        (when (and has-found (not (= found tuple-e)))
          (return found false true))
        (set! found tuple-e)
        (set! has-found true)))
    (return found has-found false)))

(defn current-tx-upsert-conflict? [db: DB, data: Tx-Data, current-tx-e: u64] -> bool
  (when (not (and (= data.op ":db/add")
                  (schema-unique-identity? db data.a)))
    (return false))
  (let [[value value-ok _] (resolve-tx-data-value db data)]
    (when (not value-ok)
      (return false))
    (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
      (and entity-ok (not (= entity current-tx-e))))))

(defn db-with-resolved-ops [db: DB, ops: []Tx-Op] -> DB
  (let [datoms (clone-datoms db.datoms)]
    (for [op ops]
      (arr.push! datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (build-db datoms)))

(defn latest-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))
        latest-index -1
        latest (Value {})]
    (for [datom-index (slice indexes low high)]
      (when (and (datom-current-at? db datom-index)
                 (> datom-index latest-index))
        (set! latest-index datom-index)
        (set! latest db.datoms[datom-index].v)))
    (return latest (>= latest-index 0))))

(defn tuple-value-for-entity [db: DB, entity: u64, attrs: []string] -> [value: Value, ok: bool]
  (let [items (make [dynamic]Value 0 (count attrs))
        any false]
    (for [attr attrs]
      (let [[value found] (latest-attr-value db entity attr)]
        (if found
          (do
            (set! any true)
            (arr.push! items value))
          (arr.push! items (value-nil)))))
    (when (not any)
      (delete items)
      (return (Value {}) false))
    (let [out (value-vector (slice items 0))]
      (delete items)
      (return out true))))

(defn remove-derived-tuple-adds! [ops: ^[dynamic]Tx-Op, entity: u64, attr: string]
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [op ops^[index]]
        (when (and op.derived
                   (= op.kind .Add)
                   (= op.e entity)
                   (= op.a attr))
          (arr.remove-ordered-at! ops^ index))
        (set! index (- index 1))))))

(defn append-tuple-maintenance-ops! [out: ^[dynamic]Tx-Op, db: DB, op: Tx-Op]
  (when (= op.a ":db/tupleAttrs")
    (return))
  (let [schemas (tuple-schemas-containing db op.a)]
    (defer (delete schemas))
    (for [schema schemas]
      (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice schema.attrs 0))]
        (if has-value
          (do
            (remove-derived-tuple-adds! out op.e schema.attr)
            (arr.push! out^ (tx-add-derived op.e schema.attr tuple-value)))
          (append-retract-attr-ops! out db op.e schema.attr)))
      (delete schema.attrs))))

(defn direct-tuple-add-matches? [db: DB, op: Tx-Op] -> bool
  (when (not (= op.kind .Add))
    (return false))
  (let [tuple-attrs (schema-tuple-attrs db op.a)]
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return false))
    (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice tuple-attrs 0))]
      (and has-value (value-equal? tuple-value op.v)))))

(defn expand-tuple-ops [db: DB, ops: []Tx-Op] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (let [scratch-before (db-with-resolved-ops db (slice out 0))]
        (when (direct-tuple-add-matches? scratch-before op)
          (continue)))
      (arr.push! out op)
      (let [scratch (db-with-resolved-ops db (slice out 0))]
        (append-tuple-maintenance-ops! (addr out) scratch op)))
    out))

(defn tx-data-op-known? [op: string] -> bool
  (or (= op ":db/add")
      (= op ":db/retract")
      (= op ":db/retractAttr")
      (= op ":db/retractEntity")
      (= op ":db.fn/cas")
      (= op ":db/cas")))

(defn tx-data-op-needs-attr? [op: string] -> bool
  (not (= op ":db/retractEntity")))

(defn attr-name-valid? [attr: string] -> bool
  (and (strings.has_prefix attr ":")
       (> (count attr) 1)))

(defn validate-tx-data-item [data: Tx-Data] -> [ok: bool, error: string]
  (when (not (tx-data-op-known? data.op))
    (return false "unknown tx op"))
  (when (and data.has_tempid
             (not (= data.op ":db/add")))
    (return false "tempids not allowed outside add"))
  (when (and (tx-data-op-needs-attr? data.op)
             (not (attr-name-valid? data.a)))
    (return false "bad entity attribute"))
  (when (and data.has_lookup_ref
             (not (attr-name-valid? data.lookup_attr)))
    (return false "bad lookup attribute"))
  (when (and data.has_expected_lookup_ref
             (not (attr-name-valid? data.expected_lookup_attr)))
    (return false "bad lookup attribute"))
  (when (and data.has_value_lookup_ref
             (not (attr-name-valid? data.value_lookup_attr)))
    (return false "bad lookup attribute"))
  (return true ""))

(defn resolve-tx-data [db: DB, tx-data: []Tx-Data] -> Resolved-Tx
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)
        next-e (next-entity-id (slice db.datoms 0))
        current-tx-e next-e
        current-tx-reserved false]
    (for [data tx-data]
      (when (and (not data.has_tempid)
                 (not data.has_lookup_ref)
                 (not data.has_ident)
                 (>= data.e next-e))
        (set! next-e (+ data.e 1))))
    (for [data tx-data]
      (let [e data.e
            current-db (db-with-resolved-ops db (slice resolved-ops 0))
            skip-data false]
        (let [[shape-ok shape-error] (validate-tx-data-item data)]
          (when (not shape-ok)
            (return (Resolved-Tx {ok: false
                                  error: shape-error
                                  ops: resolved-ops
                                  tx_meta: resolved-meta
                                  tempids: resolved-tempids}))))
        (when data.has_tempid
          (if (current-tx-tempid? data.tempid)
            (do
              (when (not current-tx-reserved)
                (set! current-tx-e next-e)
                (set! next-e (+ next-e 1))
                (set! current-tx-reserved true))
              (set! e current-tx-e)
              (ensure-tempid! (addr resolved-tempids) data.tempid current-tx-e)
              (when (current-tx-upsert-conflict? current-db data current-tx-e)
                (return (Resolved-Tx {ok: false
                                      error: "conflicting upsert"
                                      ops: resolved-ops
                                      tx_meta: resolved-meta
                                      tempids: resolved-tempids})))
              (when (= data.op ":db/add")
                (arr.push! resolved-meta (Tx-Meta {a: data.a v: data.v}))))
          (let [[existing ok] (tempid-lookup (slice resolved-tempids 0) data.tempid)]
            (if ok
              (set! e existing)
              (do
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db tx-data data.tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx_meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (set! e upsert-e)
                    (do
                      (set! e next-e)
                      (set! next-e (+ next-e 1)))))
                (arr.push! resolved-tempids (Tempid {tempid: data.tempid e: e})))))))
        (when data.has_lookup_ref
          (let [[lookup-e lookup-ok] (resolve-lookup-ref current-db data.lookup_attr data.lookup_value)]
            (if lookup-ok
              (set! e lookup-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: "lookup ref not found"
                                      ops: resolved-ops
                                      tx_meta: resolved-meta
                                      tempids: resolved-tempids}))
                (set! skip-data true)))))
        (when skip-data
          (continue))
        (when data.has_ident
          (let [[ident-e ident-ok] (schema-entity-for-attr current-db data.ident)]
            (if ident-ok
              (set! e ident-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: "ident not found"
                                      ops: resolved-ops
                                      tx_meta: resolved-meta
                                      tempids: resolved-tempids}))
                (set! skip-data true)))))
        (when skip-data
          (continue))
        (when (or (= data.op ":db/retract")
                  (= data.op ":db/retractAttr"))
          (let [tuple-attrs (schema-tuple-attrs current-db data.a) :defer]
            (when (> (count tuple-attrs) 0)
              (return (Resolved-Tx {ok: false
                                    error: "cannot modify tuple attrs directly"
                                    ops: resolved-ops
                                    tx_meta: resolved-meta
                                    tempids: resolved-tempids})))))
        (when (= data.op ":db/retractEntity")
          (append-retract-entity-ops! (addr resolved-ops) current-db e)
          (continue))
        (when (= data.op ":db/retractAttr")
          (append-retract-attr-ops! (addr resolved-ops) current-db e data.a)
          (continue))
        (when (= data.op ":db.fn/cas")
          (let [[expected expected-ok expected-error] (resolve-cas-expected current-db data)]
            (when (not expected-ok)
              (return (Resolved-Tx {ok: false
                                    error: expected-error
                                    ops: resolved-ops
                                    tx_meta: resolved-meta
                                    tempids: resolved-tempids})))
            (when (not (cas-expected-matches? current-db e data.a expected))
              (return (Resolved-Tx {ok: false
                                    error: "cas failed"
                                    ops: resolved-ops
                                    tx_meta: resolved-meta
                                    tempids: resolved-tempids})))))
	        (let [v data.v
                value-ok true
                value-error ""]
            (when (not (current-tx-value? v))
              (let [[resolved resolved-ok resolved-error] (resolve-tx-value current-db data.a data.v)]
                (set! v resolved)
                (set! value-ok resolved-ok)
                (set! value-error resolved-error)))
	          (when data.has_value_lookup_ref
	            (let [[lookup-e lookup-ok] (resolve-lookup-ref current-db data.value_lookup_attr data.value_lookup_value)]
	              (if lookup-ok
	                (set! v (value-entity lookup-e))
	                (if (= data.op ":db/retract")
	                  (set! skip-data true)
	                  (return (Resolved-Tx {ok: false
	                                        error: "lookup ref not found"
	                                        ops: resolved-ops
	                                        tx_meta: resolved-meta
	                                        tempids: resolved-tempids}))))))
	          (when skip-data
	            (continue))
            (when (current-tx-value? v)
              (when (not current-tx-reserved)
                (set! current-tx-e next-e)
                (set! next-e (+ next-e 1))
                (set! current-tx-reserved true))
              (set! v (value-entity current-tx-e))
              (ensure-tempid! (addr resolved-tempids) v.text current-tx-e))
	          (when (or data.has_value_tempid
                       (ref-string-value? current-db data.a v))
	            (let [value-tempid data.value_tempid]
              (when (not data.has_value_tempid)
                (set! value-tempid v.text))
              (if (current-tx-tempid? value-tempid)
                (do
                  (when (not current-tx-reserved)
                    (set! current-tx-e next-e)
                    (set! next-e (+ next-e 1))
                    (set! current-tx-reserved true))
                  (set! v (value-entity current-tx-e))
                  (ensure-tempid! (addr resolved-tempids) value-tempid current-tx-e))
              (if (not (tx-data-has-tempid? tx-data value-tempid))
                (return (Resolved-Tx {ok: false
                                      error: "tempid used only as value"
                                      ops: resolved-ops
                                      tx_meta: resolved-meta
                                      tempids: resolved-tempids}))
              (let [[existing ok] (tempid-lookup (slice resolved-tempids 0) value-tempid)]
              (if ok
                (set! v (value-entity existing))
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db tx-data value-tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx_meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (do
                      (set! v (value-entity upsert-e))
                      (arr.push! resolved-tempids (Tempid {tempid: value-tempid e: upsert-e})))
                    (do
                      (set! v (value-entity next-e))
                      (arr.push! resolved-tempids (Tempid {tempid: value-tempid e: next-e}))
                      (set! next-e (+ next-e 1)))))))))))
          (when (not value-ok)
            (return (Resolved-Tx {ok: false
                                  error: value-error
                                  ops: resolved-ops
                                  tx_meta: resolved-meta
                                  tempids: resolved-tempids})))
        (if (= data.op ":db/retract")
          (arr.push! resolved-ops (tx-retract e data.a v))
          (arr.push! resolved-ops (tx-add e data.a v))))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx_meta: resolved-meta tempids: resolved-tempids})))

(defn validate-add-op [db: DB, op: Tx-Op] -> [ok: bool, error: string]
  (when (= op.v.kind .Nil)
    (return false "cannot store nil"))
  (when (and (= op.a ":db/tupleAttrs")
             (not (and (valid-tuple-attr-target? db op.e)
                       (valid-tuple-attrs-value? db op.v))))
    (return false "invalid tuple schema"))
  (when (not op.derived)
    (let [tuple-attrs (schema-tuple-attrs db op.a)]
      (defer (delete tuple-attrs))
      (when (> (count tuple-attrs) 0)
        (return false "cannot modify tuple attrs directly"))))
  (let [[schema-type has-type] (schema-keyword db op.a ":db/valueType")]
    (when (and has-type (not (value-matches-schema-type? op.v schema-type)))
      (return false "schema value type mismatch")))
  (let [[unique has-unique] (schema-keyword db op.a ":db/unique")]
    (when (and has-unique
               (or (= unique ":db.unique/identity")
                   (= unique ":db.unique/value"))
               (unique-conflict? db op))
      (return false "schema unique conflict")))
  (return true ""))

(defn validate-tuple-type-schema [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (= datom.v.text ":db.type/tuple"))
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when attr-ok
              (let [tuple-attrs (schema-tuple-attrs db attr)]
                (defer (delete tuple-attrs))
                (when (= (count tuple-attrs) 0)
                  (return false "invalid tuple schema")))))))))
  (return true ""))

(defn validate-schema-bool-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Bool)))
          (return false "schema boolean value must be boolean")))))
  (return true ""))

(defn validate-ident-values [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Keyword)))
          (return false ":db/ident value must be keyword")))))
  (return true ""))

(defn valid-schema-keyword-value? [schema-attr: string, value: string] -> bool
  (cond
    (= schema-attr ":db/valueType")
      (or (= value ":db.type/string")
          (= value ":db.type/long")
          (= value ":db.type/boolean")
          (= value ":db.type/ref")
          (= value ":db.type/keyword")
          (= value ":db.type/tuple"))
    (= schema-attr ":db/cardinality")
      (or (= value ":db.cardinality/one")
          (= value ":db.cardinality/many"))
    (= schema-attr ":db/unique")
      (or (= value ":db.unique/identity")
          (= value ":db.unique/value"))
    :else true))

(defn validate-schema-keyword-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (or (not (= datom.v.kind .Keyword))
                       (not (valid-schema-keyword-value? schema-attr datom.v.text))))
          (return false "invalid schema keyword value")))))
  (return true ""))

(defn validate-component-schema [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/isComponent" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/isComponent" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Bool)
                   datom.v.bool_value)
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when (and attr-ok (not (schema-ref? db attr)))
              (return false "invalid component schema")))))))
  (return true ""))

(defn validate-ops [before: DB, ops: []Tx-Op] -> [ok: bool, error: string]
  (let [scratch-datoms (clone-datoms before.datoms)]
    (defer (delete scratch-datoms))
    (for [op ops]
      (when (= op.kind .Add)
        (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
              scratch (build-db scratch-owned)
              [ok error] (validate-add-op scratch op)]
          (when (not ok)
            (return false error))))
      (arr.push! scratch-datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-tuple-type-schema scratch)]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-ident-values scratch)]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-schema-keyword-values scratch ":db/valueType")]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-schema-keyword-values scratch ":db/cardinality")]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-schema-keyword-values scratch ":db/unique")]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-schema-bool-values scratch ":db/index")]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-schema-bool-values scratch ":db/isComponent")]
      (when (not ok)
        (return false error)))
    (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
          scratch (build-db scratch-owned)
          [ok error] (validate-component-schema scratch)]
      (when (not ok)
        (return false error)))
    (return true "")))

(defn failed-tx-report [db: DB, error: string] -> Tx-Report
  (Tx-Report {ok: false
              error: error
              db_before: db
              db_after: db
              tx_data: (make [dynamic]Datom)
              tx: 0
              tx_meta: (make [dynamic]Tx-Meta)
              tempids: (make [dynamic]Tempid)}))

(defn reset-conn-with-meta [conn: ^Conn, next-db: DB, tx-meta: []Tx-Meta] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        after (build-db (clone-datom-slice (slice next-db.datoms 0)))
        diff (db-diff before after)
        tx conn^.next_tx
        tx-data (make [dynamic]Datom 0 (+ (count diff.only_left) (count diff.only_right)))]
    (for [datom diff.only_left]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: false})))
    (for [datom diff.only_right]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: true})))
    (delete diff.only_left)
    (delete diff.only_right)
    (delete diff.both)
    (set! conn^.db after)
    (set! conn^.next_tx (+ conn^.next_tx 1))
    (Tx-Report {ok: true
                error: ""
                db_before: before
                db_after: after
                tx_data: tx-data
                tx: tx
                tx_meta: (clone-tx-meta tx-meta)
                tempids: (make [dynamic]Tempid)})))

(defn reset-conn [conn: ^Conn, next-db: DB] -> Tx-Report
  (reset-conn-with-meta conn next-db ([]Tx-Meta [])))

(defn tx-fn-ok [tx-data: []Tx-Data] -> Tx-Fn-Result
  (let [owned (arr.into [dynamic]Tx-Data tx-data)]
    (Tx-Fn-Result {ok: true
                   error: ""
                   tx_data: owned})))

(defn tx-fn-error [error: string] -> Tx-Fn-Result
  (let [empty (make [dynamic]Tx-Data)]
    (Tx-Fn-Result {ok: false
                   error: error
                   tx_data: empty})))

(defn append-cardinality-one-retractions! [after-datoms: ^[dynamic]Datom, tx-data: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (when (not (= op.kind .Add))
    (return))
  (let [current (build-db (clone-datoms after-datoms^))]
    (when (not (tx-op-cardinality-one? current op))
      (return))
    (let [indexes (slice current.eavt 0)
          low (lower-bound-index current indexes "eavt-ea" op.e op.a (Value {}))
          high (upper-bound-index current indexes "eavt-ea" op.e op.a (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom current.datoms[datom-index]]
          (when (and (datom-current-at? current datom-index)
                     (not (value-equal? datom.v op.v)))
            (let [retract (Datom {e: datom.e
                                  a: datom.a
                                  v: datom.v
                                  tx: tx
                                  added: false})]
              (arr.push! after-datoms^ retract)
              (arr.push! tx-data^ retract))))))))

(defn transact-ops-with-tempids [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta, tempids: [dynamic]Tempid] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        expanded-ops (expand-tuple-ops before ops)
        after-datoms (clone-datoms conn^.db.datoms)
        tx-data (make [dynamic]Datom 0 (count expanded-ops))
        tx conn^.next_tx]
    (let [[valid error] (validate-ops before (slice expanded-ops 0))]
      (when (not valid)
        (delete expanded-ops)
        (return (failed-tx-report before error))))
    (for [op expanded-ops]
      (append-cardinality-one-retractions! (addr after-datoms) (addr tx-data) op tx)
      (let [datom (Datom {e: op.e
                          a: op.a
                          v: op.v
                          tx: tx
                          added: (= op.kind .Add)})]
        (arr.push! after-datoms datom)
        (arr.push! tx-data datom)))
    (delete expanded-ops)
    (let [after (build-db after-datoms)]
      (set! conn^.db after)
      (set! conn^.next_tx (+ conn^.next_tx 1))
      (Tx-Report {db_before: before
                  db_after: after
                  ok: true
                  error: ""
                  tx_data: tx-data
                  tx: tx
                  tx_meta: (clone-tx-meta tx-meta)
                  tempids: tempids}))))

(defn transact-with-meta [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta] -> Tx-Report
  (transact-ops-with-tempids conn ops tx-meta (make [dynamic]Tempid)))

(defn transact-ops [conn: ^Conn, ops: []Tx-Op] -> Tx-Report
  (transact-with-meta conn ops ([]Tx-Meta [])))

(defn transact-tx-data [conn: ^Conn, tx-data: []Tx-Data] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        resolved (resolve-tx-data before tx-data)]
    (when (not resolved.ok)
      (delete resolved.ops)
      (delete resolved.tx_meta)
      (delete resolved.tempids)
      (return (failed-tx-report before resolved.error)))
    (let [report (transact-ops-with-tempids conn (slice resolved.ops 0) (slice resolved.tx_meta 0) resolved.tempids)]
      (delete resolved.ops)
      (delete resolved.tx_meta)
      report)))

(defn transact-fn [conn: ^Conn, f: (fn [db: DB] -> Tx-Fn-Result)] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        result (f before)]
    (defer (delete result.tx_data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (transact-tx-data conn (slice result.tx_data 0))))

(defn transact-fn-string [conn: ^Conn, f: (fn [db: DB, arg: string] -> Tx-Fn-Result), arg: string] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        result (f before arg)]
    (defer (delete result.tx_data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (transact-tx-data conn (slice result.tx_data 0))))

(defn match-entity-term? [db: DB, term: Term, actual: Value, binding: ^Binding] -> bool
  (let [[resolved resolved-ok] (resolve-entity-term db term binding^)]
    (when resolved-ok
      (return (value-equal? resolved actual))))
  (match-term? term actual binding))

(defn ref-entity-literal [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool]
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (when (and has-type (= schema-type ":db.type/ref"))
      (if (= value.kind .Int)
        (return (value-entity (u64 value.int_value)) true)
        (when (= value.kind .Keyword)
          (let [[entity ok] (schema-entity-for-attr db value.text)]
            (when ok
              (return (value-entity entity) true)))))))
  (return value false))

(defn match-clause-value-term? [db: DB, attr: string, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup_attr term.lookup_value)]
      (return (and lookup-ok (value-equal? (value-entity entity) actual)))))
  (when (= term.kind .Value)
    (let [[resolved ok] (ref-entity-literal db attr term.value)]
      (when ok
        (return (value-equal? resolved actual)))))
  (match-term? term actual binding))

(defn datom-clause-matches? [db: DB, datom: Datom, clause: Clause, binding: ^Binding] -> bool
  (when (and (= clause.a.kind .Value)
             (= clause.a.value.kind .Keyword)
             (reverse-attr? clause.a.value.text))
    (when (not (= datom.v.kind .Entity))
      (return false))
    (let [forward-attr (forward-attr-for-reverse clause.a.value.text) :defer]
      (return
        (and (= datom.a forward-attr)
             (match-entity-term? db clause.e (value-entity datom.v.entity) binding)
             (match-entity-term? db clause.v (value-entity datom.e) binding)))))
  (and (match-entity-term? db clause.e (value-entity datom.e) binding)
       (match-term? clause.a (value-keyword datom.a) binding)
       (match-clause-value-term? db datom.a clause.v datom.v binding)))

(defn candidate-index-matches? [datom: Datom,
                                e-value: Value, e-ok: bool,
                                a-value: Value, a-ok: bool,
                                v-value: Value, v-ok: bool] -> bool
  (when e-ok
    (when (not (and (= e-value.kind .Entity)
                    (= datom.e e-value.entity)))
      (return false)))
  (when a-ok
    (when (not (and (= a-value.kind .Keyword)
                    (= datom.a a-value.text)))
      (return false)))
  (when v-ok
    (when (not (value-equal? datom.v v-value))
      (return false)))
  true)

(defn clause-selectivity-score [clause: Clause, binding: Binding] -> int
  (let [[ignored-e e-bound] (resolve-term clause.e binding)
        e-ok (or (= clause.e.kind .LookupRef) e-bound)
        [a-value a-ok] (resolve-term clause.a binding)
        [_ v-ok] (resolve-term clause.v binding)]
    (when (and a-ok (not (= a-value.kind .Keyword)))
      (return 0))
    (if (and e-ok a-ok)
      1
      (if (and a-ok v-ok)
        2
        (if e-ok
          3
          (if a-ok
            4
            (if v-ok 5 6)))))))

(defn best-clause-index [clauses: []Clause, binding: Binding] -> int
  (let [best 0
        best-score (clause-selectivity-score clauses[0] binding)]
    (for [i (arr.range 1 (count clauses))]
      (let [score (clause-selectivity-score clauses[i] binding)]
        (when (< score best-score)
          (set! best i)
          (set! best-score score))))
    best))

(defn relation-source-row-matches? [clause: Clause, row: Value, binding: ^Binding] -> bool
  (when (not (= row.kind .Vector))
    (return false))
  (when (not (= (count row.items) clause.source_width))
    (return false))
  (when (= clause.source_width 2)
    (return
      (and (match-term? clause.e row.items[0] binding)
           (match-term? clause.a row.items[1] binding))))
  (when (not (and (match-term? clause.e row.items[0] binding)
                  (match-term? clause.a row.items[1] binding)
                  (match-term? clause.v row.items[2] binding)))
    (return false))
  (when (= clause.source_width 3)
    (return true))
  (when (not (match-term? clause.tx_term row.items[3] binding))
    (return false))
  (when (= clause.source_width 4)
    (return true))
  (match-term? clause.op_term row.items[4] binding))

(defn bindings-after-relation-source-clause [clause: Clause, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        [source source-ok] (binding-lookup binding clause.source)]
    (when (not (and source-ok (= source.kind .Vector)))
      (return out))
    (for [row source.items]
      (let [next (clone-binding binding)]
        (when (relation-source-row-matches? clause row (addr next))
          (arr.push! out next))))
    out))

(defn source-db-lookup [db: DB, sources: []DB-Source, name: string] -> [source-db: DB, ok: bool]
  (when (= name "$")
    (return db true))
  (for [source sources]
    (when (= source.name name)
      (return source.db true)))
  (return db false))

(defn unsourced-clause [clause: Clause] -> Clause
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           tx_term: (term-wildcard)
           op_term: (term-wildcard)
           source: ""
           has_source: false
           source_width: 0}))

(defn append-bindings-after-clause! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding]
  (when clause-value.has_source
    (let [source-bindings (bindings-after-relation-source-clause clause-value binding)]
      (defer (delete source-bindings))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (let [candidates (clause-candidate-indexes db clause-value binding)]
    (defer (delete candidates))
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [next (clone-binding binding)]
            (when (datom-clause-matches? db datom clause-value (addr next))
              (arr.push! out^ next))))))))

(defn append-bindings-after-clause-with-sources! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding]
  (when clause-value.has_source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause! out source-db (unsourced-clause clause-value) binding)
        (return))))
  (append-bindings-after-clause! out db clause-value binding))

(defn clause-candidate-indexes [db: DB, clause: Clause, binding: Binding] -> [dynamic]int
  (let [[e-value e-ok] (resolve-entity-term db clause.e binding)
        [a-value a-ok] (resolve-term clause.a binding)
        [v-value v-ok] (resolve-term clause.v binding)
        source: []int (slice db.eavt 0)
        out (make [dynamic]int)]
    (when (= clause.v.kind .LookupRef)
      (let [[lookup-entity lookup-ok] (resolve-lookup-ref db clause.v.lookup_attr clause.v.lookup_value)]
        (when lookup-ok
          (set! v-value (value-entity lookup-entity))
          (set! v-ok true))))
    (when (and a-ok v-ok (= a-value.kind .Keyword))
      (let [[resolved resolved-ok] (ref-entity-literal db a-value.text v-value)]
        (when resolved-ok
          (set! v-value resolved))))
    (when (and a-ok
               (= a-value.kind .Keyword)
               (reverse-attr? a-value.text))
      (let [forward-attr (forward-attr-for-reverse a-value.text) :defer]
        (let [[source-entity source-ok] (resolve-entity-term db clause.v binding)]
          (when source-ok
            (set! v-value source-entity)
            (set! v-ok true)))
        (when (and e-ok (not (= e-value.kind .Entity)))
          (return out))
        (when (and v-ok (not (= v-value.kind .Entity)))
          (return out))
        (if e-ok
          (let [indexes (slice db.vaet 0)
                ref-value (value-entity e-value.entity)
                low (lower-bound-index db indexes "vaet" 0 "" ref-value)
                high (upper-bound-index db indexes "vaet" 0 "" ref-value)]
            (set! source (slice indexes low high)))
          (if v-ok
            (let [indexes (slice db.eavt 0)
                  low (lower-bound-index db indexes "eavt-ea" v-value.entity forward-attr (Value {}))
                  high (upper-bound-index db indexes "eavt-ea" v-value.entity forward-attr (Value {}))]
              (set! source (slice indexes low high)))
            (let [indexes (slice db.aevt 0)
                  low (lower-bound-index db indexes "aevt" 0 forward-attr (Value {}))
                  high (upper-bound-index db indexes "aevt" 0 forward-attr (Value {}))]
              (set! source (slice indexes low high)))))
        (for [datom-index source]
          (let [datom db.datoms[datom-index]]
            (when (and (= datom.a forward-attr)
                       (= datom.v.kind .Entity))
              (arr.push! out datom-index))))
        (return out)))
    (if (and e-ok a-ok)
      (do
        (when (not (and (= e-value.kind .Entity)
                        (= a-value.kind .Keyword)))
          (return out))
        (let [indexes (slice db.eavt 0)
              low (lower-bound-index db indexes "eavt-ea" e-value.entity a-value.text (Value {}))
              high (upper-bound-index db indexes "eavt-ea" e-value.entity a-value.text (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (and a-ok v-ok))
      (do
        (when (not (= a-value.kind .Keyword))
          (return out))
        (let [indexes (slice db.avet 0)
              low (lower-bound-index db indexes "avet" 0 a-value.text v-value)
              high (upper-bound-index db indexes "avet" 0 a-value.text v-value)]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) e-ok)
      (do
        (when (not (= e-value.kind .Entity))
          (return out))
        (let [indexes (slice db.eavt 0)
              low (lower-bound-index db indexes "eavt" e-value.entity "" (Value {}))
              high (upper-bound-index db indexes "eavt" e-value.entity "" (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) (not e-ok) a-ok)
      (do
        (when (not (= a-value.kind .Keyword))
          (return out))
        (let [indexes (slice db.aevt 0)
              low (lower-bound-index db indexes "aevt" 0 a-value.text (Value {}))
              high (upper-bound-index db indexes "aevt" 0 a-value.text (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) (not e-ok) (not a-ok) v-ok)
      (let [indexes (slice db.vaet 0)
            low (lower-bound-index db indexes "vaet" 0 "" v-value)
            high (upper-bound-index db indexes "vaet" 0 "" v-value)]
        (set! source (slice indexes low high))))
    (for [datom-index source]
      (let [datom db.datoms[datom-index]]
        (when (candidate-index-matches? datom e-value e-ok a-value a-ok v-value v-ok)
          (arr.push! out datom-index))))
    out))

(defn binding-matches-clause? [db: DB, clause: Clause, binding: Binding] -> bool
  (when clause.has_source
    (let [source-bindings (bindings-after-relation-source-clause clause binding) :defer]
      (return (> (count source-bindings) 0))))
  (let [candidates (clause-candidate-indexes db clause binding) :defer]
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [candidate (clone-binding binding)]
            (when (datom-clause-matches? db datom clause (addr candidate))
              (return true)))))))
  false)

(defn bindings-after-clause-group-with-sources [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (let [bindings ([dynamic]Binding [binding])]
    (for [clause group.clauses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (append-bindings-after-clause-with-sources! (addr next-bindings) db sources clause candidate-binding))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    (for [not-group group.not_groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (when (not (binding-matches-not-group-with-sources? db sources not-group candidate-binding))
            (arr.push! next-bindings candidate-binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    bindings))

(defn bindings-after-clause-group [db: DB, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-clause-group-with-sources db ([]DB-Source []) group binding))

(defn project-binding [binding: Binding, names: []string] -> Binding
  (let [out (Binding {})]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (when ok
          (binding-store! (addr out) name value))))
    out))

(defn merge-binding [base: Binding, extra: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding base)]
    (for [item extra.items]
      (let [[existing exists] (binding-lookup out item.name)]
        (if exists
          (when (not (value-equal? existing item.value))
            (return out false))
          (binding-store! (addr out) item.name item.value))))
    (return out true)))

(defn binding-with-value [binding: Binding, name: string, value: Value] -> [next: Binding, ok: bool]
  (let [out (clone-binding binding)
        [existing exists] (binding-lookup out name)]
    (if exists
      (return out (value-equal? existing value))
      (do
        (binding-store! (addr out) name value)
        (return out true)))))

(defn apply-get-else [db: DB, binding: Binding, clause: Get-Else] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (let [[value value-ok] (pull-attr-value db entity.entity clause.a)]
      (if value-ok
        (binding-with-value binding clause.out value)
        (binding-with-value binding clause.out clause.default_value)))))

(defn apply-get-some [db: DB, binding: Binding, clause: Get-Some] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (for [attr clause.attrs]
      (let [[value value-ok] (pull-attr-value db entity.entity attr)]
        (when value-ok
          (let [[with-attr attr-ok] (binding-with-value binding clause.out_attr (value-keyword attr))]
            (when (not attr-ok)
              (return with-attr false))
            (return (binding-with-value with-attr clause.out_value value))))))
    (return binding false)))

(defn ground-bind-values [binding: Binding, vars: []string, values: []Value] -> [next: Binding, ok: bool]
  (when (not (= (count vars) (count values)))
    (return binding false))
  (let [bound-binding (clone-binding binding)]
    (for [name index vars]
      (when (not (= name ""))
        (let [[bound bound-ok] (binding-with-value bound-binding name values[index])]
          (when (not bound-ok)
            (return binding false))
          (set! bound-binding bound))))
    (return bound-binding true)))

(defn apply-ground [bindings: []Binding, ground: Ground] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[source source-ok] (resolve-term ground.source binding)]
        (when source-ok
          (if ground.is_tuple
            (when (= source.kind .Vector)
              (let [[next ok] (ground-bind-values binding ground.tuple_vars (slice source.items 0))]
                (when ok
                  (arr.push! out next))))
            (if ground.is_relation
              (when (= source.kind .Vector)
                (for [row source.items]
                  (when (and (= row.kind .Vector)
                             (= (count row.items) ground.width))
                    (let [[next ok] (ground-bind-values binding ground.tuple_vars (slice row.items 0))]
                      (when ok
                        (arr.push! out next))))))
              (if ground.is_collection
                (when (= source.kind .Vector)
                  (for [value source.items]
                    (let [[next ok] (binding-with-value binding ground.out value)]
                      (when ok
                        (arr.push! out next)))))
                (if (= ground.out "")
                  (arr.push! out binding)
                  (let [[next ok] (binding-with-value binding ground.out source)]
                    (when ok
                      (arr.push! out next))))))))))
    out))

(defn bindings-after-function [bindings: []Binding, function: Function-Clause] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[next ok] (apply-function-clause binding function)]
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-predicate [bindings: []Binding, predicate: Predicate] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (when (predicate-matches? predicate binding)
        (arr.push! out binding)))
    out))

(defn rule-clause-with-source [clause: Clause, source: string, has-source: bool] -> Clause
  (when (or (not has-source) clause.has_source)
    (return clause))
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           source: source
           has_source: true
           source_width: (if (= clause.v.kind .Wildcard) 2 3)}))

(defn rule-clauses-with-source [clauses: []Clause, source: string, has-source: bool] -> [dynamic]Clause
  (let [out (make [dynamic]Clause 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (rule-clause-with-source clause source has-source)))
    out))

(defn bind-rule-source [outer: Binding, initial: Binding, source: string, has-source: bool] -> [binding: Binding, ok: bool]
  (when (not has-source)
    (return initial true))
  (let [[source-value source-ok] (binding-lookup outer source)]
    (when (not source-ok)
      (return initial false))
    (let [next (clone-binding initial)]
      (binding-store! (addr next) source source-value)
      (return next true))))

(defn binding-equal? [left: Binding, right: Binding] -> bool
  (when (not (= (count left.items) (count right.items)))
    (return false))
  (for [item left.items]
    (let [[right-value right-ok] (binding-lookup right item.name)]
      (when (not (and right-ok (value-equal? item.value right-value)))
        (return false))))
  true)

(defn binding-exists? [bindings: []Binding, binding: Binding] -> bool
  (for [existing bindings]
    (when (binding-equal? existing binding)
      (return true)))
  false)

(defn bindings-after-rule-body-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (let [clauses (rule-clauses-with-source rule.clauses source has-source)
        group (not-group-simple (slice clauses 0))
        bindings (bindings-after-clause-group db group initial)]
    (delete clauses)
    (for [call rule.rule_calls]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [next-source (if call.has_source call.source source)
                next-has-source (or call.has_source has-source)
                rule-bindings (bindings-after-rule-call-depth db rules call binding (- depth 1) next-source next-has-source)]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [ground rule.grounds]
      (let [next (apply-ground (slice bindings 0) ground)]
        (delete bindings)
        (set! bindings next)))
    (for [function rule.function_clauses]
      (let [next (bindings-after-function (slice bindings 0) function)]
        (delete bindings)
        (set! bindings next)))
    (for [predicate rule.predicates]
      (let [next (bindings-after-predicate (slice bindings 0) predicate)]
        (delete bindings)
        (set! bindings next)))
    bindings))

(defn bind-rule-args [outer: Binding, call: Rule-Call, rule: Rule] -> [binding: Binding, ok: bool]
  (let [out (Binding {})]
    (when (not (= (count call.args) (count rule.params)))
      (return out false))
    (for [param index rule.params]
      (let [arg call.args[index]]
        (case arg.kind
          .Var (let [[value value-ok] (binding-lookup outer arg.name)]
                 (when value-ok
                   (let [[next bind-ok] (binding-with-value out param value)]
                     (when (not bind-ok)
                       (return next false))
                     (set! out next))))
          .Value (let [[next bind-ok] (binding-with-value out param arg.value)]
                   (when (not bind-ok)
                     (return next false))
                   (set! out next))
          :else (return out false))))
    (return out true)))

(defn merge-rule-output [outer: Binding, call: Rule-Call, rule: Rule, result: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding outer)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [[value value-ok] (binding-lookup result param)]
            (when value-ok
              (let [[next bind-ok] (binding-with-value out arg.name value)]
                (when (not bind-ok)
                  (return next false))
                (set! out next)))))))
    (return out true)))

(defn bindings-after-rule-call-depth [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (<= depth 0)
      (return out))
    (for [rule rules]
      (when (= rule.name call.name)
        (let [[initial ok] (bind-rule-args binding call rule)]
          (when ok
            (let [[source-initial source-ok] (bind-rule-source binding initial source has-source)]
              (when source-ok
                (let [results (bindings-after-rule-body-depth db rules rule source-initial depth source has-source)]
                  (for [result results]
                    (let [[merged merged-ok] (merge-rule-output binding call rule result)]
                      (when merged-ok
                        (arr.push! out merged))))
                  (delete results))))))))
    out))

(defn bindings-after-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        depth 1
        min-depth (+ (count rules) 1)
        changed true]
    (while (or changed (<= depth min-depth))
      (set! changed false)
      (let [candidates (bindings-after-rule-call-depth db rules call binding depth call.source call.has_source)]
        (defer (delete candidates))
        (for [candidate candidates]
          (when (not (binding-exists? (slice out 0) candidate))
            (arr.push! out candidate)
            (set! changed true))))
      (set! depth (+ depth 1)))
    out))

(defn bindings-after-or-branch-with-sources [db: DB, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (let [initial (clone-binding binding)]
    (when group.has_join
      (set! initial (project-binding binding group.join_vars))
      (for [branch-clause branch.clauses]
        (let [has-source branch-clause.has_source]
          (when has-source
          (let [[source source-ok] (binding-lookup binding branch-clause.source)]
            (when source-ok
              (binding-store! (addr initial) branch-clause.source source)))))))
  (let [branch-bindings (bindings-after-clause-group-with-sources db sources branch initial) :defer
        out (make [dynamic]Binding)]
    (for [branch-binding branch-bindings]
      (let [branch-output (if group.has_join (project-binding branch-binding group.join_vars) branch-binding)
            [merged ok] (merge-binding binding branch-output)]
        (when ok
          (arr.push! out merged))))
    out)))

(defn bindings-after-or-branch [db: DB, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-or-branch-with-sources db ([]DB-Source []) group branch binding))

(defn binding-matches-not-group-with-sources? [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> bool
  (let [initial (clone-binding binding)]
    (when group.has_join
      (delete initial.items)
      (set! initial (project-binding binding group.join_vars)))
  (let [bindings ([dynamic]Binding [initial])]
    (for [clause group.clauses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (append-bindings-after-clause-with-sources! (addr next-bindings) db sources clause candidate-binding))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (delete bindings)
          (return false))))
    (for [not-group group.not_groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (when (not (binding-matches-not-group-with-sources? db sources not-group candidate-binding))
            (arr.push! next-bindings candidate-binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (delete bindings)
          (return false))))
    (let [matched (> (count bindings) 0)]
      (delete bindings)
      (return matched)))))

(defn binding-matches-not-group? [db: DB, group: Not-Group, binding: Binding] -> bool
  (binding-matches-not-group-with-sources? db ([]DB-Source []) group binding))

(defn aggregate-initial-value [aggregate: Aggregate-Find] -> Value
  (if (or (= aggregate.op "count")
          (= aggregate.op "count-distinct")
          (= aggregate.op "sum")
          (= aggregate.op "avg")
          (= aggregate.op "median")
          (= aggregate.op "variance")
          (= aggregate.op "stddev"))
    (value-int 0)
    (Value {})))

(defn sort-i64! [values: ^[dynamic]i64]
  // ponytail: insertion sort is enough for current aggregate tests; replace if aggregate benches care.
  (for [i (arr.range 1 (count values^))]
    (let [current values^[i]
          j i]
      (while (and (> j 0)
                  (< current values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] current))))

(defn sort-values! [values: ^[dynamic]Value]
  (for [i (arr.range 1 (count values^))]
    (let [current values^[i]
          j i]
      (while (and (> j 0)
                  (value-less? current values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] current))))

(defn top-n-values [values: []Value, limit: int, max?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (let [take-count (min limit (count sorted))
          start (if max? (- (count sorted) take-count) 0)]
      (for [index (arr.range start (+ start take-count))]
        (arr.push! out sorted[index]))
      (Value {kind: .Vector items: out}))))

(defn median-int [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sorted (arr.into [dynamic]i64 values)]
    (defer (delete sorted))
    (sort-i64! (addr sorted))
    (let [mid (/ (count sorted) 2)]
      (if (= (% (count sorted) 2) 1)
        (value-int sorted[mid])
        (value-int (/ (+ sorted[(- mid 1)] sorted[mid]) 2))))))

(defn variance-int [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sum: i64 0]
    (for [value values]
      (set! sum (+ sum value)))
    (let [mean (/ sum (i64 (count values)))
          squared: i64 0]
      (for [value values]
        (let [diff (- value mean)]
          (set! squared (+ squared (* diff diff)))))
      (value-int (/ squared (i64 (count values)))))))

(defn stddev-float [values: []i64] -> Value
  (let [variance (variance-int values)]
    (value-float (math.sqrt (f64 variance.int_value)))))

(defn apply-aggregate-value [current: Value, aggregate: Aggregate-Find, value: Value] -> Value
  (when (or (= aggregate.op "count")
            (= aggregate.op "count-distinct"))
    (return (value-int (+ current.int_value 1))))
  (when (or (= aggregate.op "sum")
            (= aggregate.op "avg"))
    (when (not (= value.kind .Int))
      (return current))
    (return (value-int (+ current.int_value value.int_value))))
  (when (= current.kind .Nil)
    (return value))
  (if (= aggregate.op "min")
    (if (value-less? value current) value current)
    (if (= aggregate.op "max")
      (if (value-less? current value) value current)
      current)))

(defn binding-values-for-vars [binding: Binding, names: []string] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value 0 (count names))]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-key-values [binding: Binding, query: Query, aggregate: Aggregate-Find] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query.find]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (for [name query.with]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (let [[value ok] (binding-lookup binding aggregate.var)]
      (if ok
        (arr.push! out value)
        (return out false)))
    (return out true)))

(defn aggregate-key-row [values: []Value] -> Result-Row
  (let [stored (arr.into [dynamic]Value values)
        pulls (make [dynamic]Pull-Result)]
    (Result-Row {values: stored pulls: pulls})))

(defn aggregate-value-for-group [bindings: []Binding, query: Query, aggregate: Aggregate-Find, group-values: []Value] -> Value
  (let [current (aggregate-initial-value aggregate)
        avg-count: i64 0
        resolved-limit aggregate.limit
        aggregate-ints (make [dynamic]i64)
        aggregate-values (make [dynamic]Value)
        distinct-values (make [dynamic]Value)
        seen-keys (make [dynamic]Result-Row)]
    (defer (delete aggregate-ints))
    (defer (delete aggregate-values))
    (defer (delete distinct-values))
    (defer (delete seen-keys))
    (for [binding bindings]
      (let [[binding-group ok] (binding-values-for-vars binding (slice query.find 0))]
        (when (and ok (values-equal? (slice binding-group 0) group-values))
          (when aggregate.has_limit_var
            (let [[limit-value limit-ok] (binding-lookup binding aggregate.limit_var)]
              (when (and limit-ok (= limit-value.kind .Int))
                (set! resolved-limit (int limit-value.int_value)))))
          (let [[key key-ok] (aggregate-key-values binding query aggregate)]
            (when (and key-ok (not (row-values-exist? (slice seen-keys 0) (slice key 0))))
              (arr.push! seen-keys (aggregate-key-row (slice key 0)))
              (let [[value has-value] (binding-lookup binding aggregate.var)]
                (when has-value
                  (if (= aggregate.op "count")
                    (set! current.int_value (+ current.int_value 1))
                    (if (= aggregate.op "count-distinct")
                      (when (not (value-exists? (slice distinct-values 0) value))
                        (arr.push! distinct-values value))
                      (do
                        (when (and (or (= aggregate.op "median")
                                       (= aggregate.op "variance")
                                       (= aggregate.op "stddev"))
                                   (= value.kind .Int))
                          (arr.push! aggregate-ints value.int_value))
                        (when (and (or aggregate.has_limit aggregate.has_limit_var)
                                   (or (= aggregate.op "min")
                                       (= aggregate.op "max")))
                          (arr.push! aggregate-values value))
                        (when (and (= aggregate.op "avg")
                                   (= value.kind .Int))
                          (set! avg-count (+ avg-count 1)))
                        (set! current (apply-aggregate-value current aggregate value))))))))))))
    (when (= aggregate.op "count-distinct")
      (return (value-int (i64 (count distinct-values)))))
    (when (and (or aggregate.has_limit aggregate.has_limit_var)
               (or (= aggregate.op "min")
                   (= aggregate.op "max")))
      (return (top-n-values (slice aggregate-values 0) resolved-limit (= aggregate.op "max"))))
    (when (and (= aggregate.op "avg") (> avg-count 0))
      (set! current.int_value (/ current.int_value avg-count)))
    (when (= aggregate.op "median")
      (return (median-int (slice aggregate-ints 0))))
    (when (= aggregate.op "variance")
      (return (variance-int (slice aggregate-ints 0))))
    (when (= aggregate.op "stddev")
      (return (stddev-float (slice aggregate-ints 0))))
    current))

(defn pull-pattern-input [query: Query, inputs: []Query-Input, name: string] -> [pattern: []Pull-Spec, ok: bool]
  (for [input-name index query.inputs]
    (when (= input-name name)
      (when (and (< index (count inputs))
                 (= inputs[index].kind .PullPattern))
        (return inputs[index].pattern true))
      (return ([]Pull-Spec []) false)))
  (return ([]Pull-Spec []) false))

(defn pull-find-pattern [query: Query, inputs: []Query-Input, pull-find: Pull-Find] -> [pattern: []Pull-Spec, ok: bool]
  (if pull-find.has_pattern_var
    (pull-pattern-input query inputs pull-find.pattern_var)
    (return pull-find.pattern true)))

(defn pull-db-for-find [db: DB, sources: []DB-Source, pull-find: Pull-Find] -> [pull-db: DB, ok: bool]
  (if pull-find.has_source
    (source-db-lookup db sources pull-find.source)
    (return db true)))

(defn pulls-for-binding-with-sources [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (let [out (make [dynamic]Pull-Result 0 (count query.pulls))]
    (for [pull-find query.pulls]
      (let [[entity ok] (binding-lookup binding pull-find.var)]
        (if (and ok (= entity.kind .Entity))
          (let [[pattern pattern-ok] (pull-find-pattern query inputs pull-find)
                [pull-db pull-db-ok] (pull-db-for-find db sources pull-find)]
            (if (and pattern-ok pull-db-ok)
              (arr.push! out (pull-pattern-spec pull-db entity.entity pattern))
              (return out false)))
          (return out false))))
    (return out true)))

(defn pulls-for-binding [db: DB, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (pulls-for-binding-with-sources db ([]DB-Source []) query inputs binding))

(defn append-aggregate-rows-with-sources! [rows: ^[dynamic]Result-Row, db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding]
  (for [binding bindings]
    (let [[group-values ok] (binding-values-for-vars binding (slice query.find 0))]
      (when ok
        (when (not (row-value-prefix-exists? (slice rows^ 0) (slice group-values 0)))
            (let [values (arr.into [dynamic]Value (slice group-values 0))
                  [pulls pulls-ok] (pulls-for-binding-with-sources db sources query inputs binding)]
            (when (not pulls-ok)
              (delete pulls)
              (return))
            (for [aggregate query.aggregates]
              (arr.push! values (aggregate-initial-value aggregate)))
            (arr.push! rows^ (Result-Row {values: values pulls: pulls})))))))
  (for [row rows^]
    (for [aggregate index query.aggregates]
      (set! row.values[(+ (count query.find) index)]
        (aggregate-value-for-group bindings query aggregate (slice row.values 0 (count query.find)))))))

(defn append-aggregate-rows! [rows: ^[dynamic]Result-Row, db: DB, query: Query, inputs: []Query-Input, bindings: []Binding]
  (append-aggregate-rows-with-sources! rows db ([]DB-Source []) query inputs bindings))

(defn q-query-with-sources [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source] -> Result-Set
  (let [bindings (bindings-from-inputs db query inputs)
        remaining (arr.into [dynamic]Clause (slice query.clauses 0))]
    (defer (delete remaining))
    (while (and (> (count bindings) 0) (> (count remaining) 0))
      (let [clause-index (best-clause-index (slice remaining 0) bindings[0])
            clause remaining[clause-index]
            next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources! (addr next-bindings) db sources clause binding))
        (delete bindings)
        (set! bindings next-bindings)
        (arr.remove-ordered-at! remaining clause-index)))
    (for [call query.rule_calls]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call db (slice query.rules 0) call binding)]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [ground query.grounds]
      (let [next-bindings (apply-ground (slice bindings 0) ground)]
        (delete bindings)
        (set! bindings next-bindings)))
    (for [get-else query.get_elses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [[next ok] (apply-get-else db binding get-else)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [get-some query.get_somes]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [[next ok] (apply-get-some db binding get-some)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [function query.function_clauses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [[next ok] (apply-function-clause binding function)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [predicate query.predicates]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (when (predicate-matches? predicate binding)
            (arr.push! next-bindings binding)))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [group query.or_groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-sources db sources group branch binding)]
              (for [branch-binding branch-bindings]
                (arr.push! next-bindings branch-binding))
              (delete branch-bindings))))
        (delete bindings)
        (set! bindings next-bindings)))
    (for [not-group query.not_groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-sources? db sources not-group binding))
            (arr.push! next-bindings binding)))
        (delete bindings)
        (set! bindings next-bindings)))
    (when (> (count query.aggregates) 0)
      (let [rows (make [dynamic]Result-Row)]
        (if (= (count query.find) 0)
          (let [values (make [dynamic]Value 0 (count query.aggregates))
                pulls (make [dynamic]Pull-Result)]
            (for [aggregate query.aggregates]
              (arr.push! values (aggregate-value-for-group (slice bindings 0) query aggregate ([]Value []))))
            (arr.push! rows (Result-Row {values: values pulls: pulls})))
          (append-aggregate-rows-with-sources! (addr rows) db sources query inputs (slice bindings 0)))
        (delete bindings)
        (return (Result-Set {rows: rows}))))
    (let [rows (make [dynamic]Result-Row 0 (count bindings))]
      (for [binding bindings]
        (let [values (make [dynamic]Value 0 (count query.find))
              dedupe-values (make [dynamic]Value)
              [pulls pulls-ok] (pulls-for-binding-with-sources db sources query inputs binding)
              complete true]
          (when (not pulls-ok)
            (set! complete false))
          (for [name query.find]
            (let [[value ok] (binding-lookup binding name)]
              (if ok
                (do
                  (arr.push! values value)
                  (arr.push! dedupe-values value))
                (set! complete false))))
          (for [name query.with]
            (let [[value ok] (binding-lookup binding name)]
              (if ok
                (arr.push! dedupe-values value)
                (set! complete false))))
          (when complete
            (when (or (> (count pulls) 0)
                      (not (row-values-exist? (slice rows 0) (slice dedupe-values 0))))
              (arr.push! rows (Result-Row {values: values pulls: pulls}))))))
      (delete bindings)
      (Result-Set {rows: rows}))))

(defn q-query-with-inputs [db: DB, query: Query, inputs: []Query-Input] -> Result-Set
  (q-query-with-sources db query inputs ([]DB-Source [])))

(defn q-query [db: DB, query: Query] -> Result-Set
  (q-query-with-inputs db query ([]Query-Input [])))

(defn result-scalar [result: Result-Set] -> [value: Value, ok: bool]
  (when (= (count result.rows) 0)
    (return (Value {}) false))
  (when (not (= (count result.rows[0].values) 1))
    (return (Value {}) false))
  (return result.rows[0].values[0] true))

(defn result-collection [result: Result-Set] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) 1)
        (arr.push! out row.values[0])))
    out))

(defn result-tuple [result: Result-Set] -> [dynamic]Value
  (if (> (count result.rows) 0)
    (arr.into [dynamic]Value (slice result.rows[0].values 0))
    (make [dynamic]Value)))

(defn result-keys [result: Result-Set, kind: Key-Kind, keys: []string] -> [dynamic]Keyed-Row
  (let [out (make [dynamic]Keyed-Row 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) (count keys))
        (let [items (make [dynamic]Keyed-Value 0 (count keys))]
          (for [key index keys]
            (arr.push! items (Keyed-Value {kind: kind key: key value: row.values[index]})))
          (arr.push! out (Keyed-Row {items: items})))))
    out))

(defn q-strings [db: DB, query: Query] -> [dynamic]string
  (let [result (q-query db query)
        out (make [dynamic]string 0 (count result.rows))]
    (for [row result.rows]
      (when (and (= (count row.values) 1)
                 (= row.values[0].kind .String))
        (arr.push! out row.values[0].text)))
    out))

(defn reverse-attr? [attr: string] -> bool
  (strings.has_prefix attr ":_"))

(defn forward-attr-for-reverse [attr: string] -> string
  (strings.concatenate ([]string [":" (slice attr 2)])))

(defn pull-output-has-attr? [out: [dynamic]Pull-Attr, attr: string] -> bool
  (for [pulled out]
    (when (= pulled.a attr)
      (return true)))
  false)

(defn pull-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (return datom.v true)))))
  (return (Value {}) false))

(defn pull-limit [spec: Pull-Spec] -> int
  (if (= spec.limit -1)
    2147483647
    (if (> spec.limit 0) spec.limit 1000)))

(defn pull-id-attrs [entity: u64] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (arr.push! out (Pull-Attr {a: ":db/id"
                               v: (value-entity entity)
                               attrs: (make [dynamic]Pull-Attr)}))
    out))

(defn pull-child-pattern [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (let [child-seen (arr.into [dynamic]u64 seen)]
    (defer (delete child-seen))
    (arr.push! child-seen entity)
    (let [pulled (pull-pattern-spec-seen db entity pattern root (slice child-seen 0))]
      pulled.attrs)))

(defn pull-child-recursion [db: DB, entity: u64, pattern: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (if (u64-contains? seen entity)
    (pull-id-attrs entity)
    (pull-child-pattern db entity pattern pattern seen)))

(defn pull-include-ref-result? [spec: Pull-Spec, children: []Pull-Attr] -> bool
  (or (= (count spec.pattern) 0)
      (> (count children) 0)))

(defn pull-reverse-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [forward-attr (forward-attr-for-reverse spec.a) :defer
        ref-value (value-entity entity)
        indexes (slice db.vaet 0)
        low (lower-bound-index db indexes "vaet" 0 "" ref-value)
        high (upper-bound-index db indexes "vaet" 0 "" ref-value)
        limit (pull-limit spec)
        seen 0
        found false]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? db datom-index))
          (let [children (make [dynamic]Pull-Attr)]
            (when (> (count spec.pattern) 0)
              (set! children (pull-child-pattern db datom.e spec.pattern spec.pattern seen-entities)))
            (when (and (= (count spec.pattern) 0)
                       spec.has_recursion
                       (not (= spec.recursion_depth 0)))
              (let [pattern (pull-recursion-pattern root spec.a)]
                (defer (delete pattern))
                (set! children (pull-child-recursion db datom.e (slice pattern 0) seen-entities))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^ (Pull-Attr {a: (pull-output-attr spec)
                                            v: (value-entity datom.e)
                                            attrs: children}))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-wildcard-seen! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, seen: ^[dynamic]u64]
  (when (not (pull-output-has-attr? out^ ":db/id"))
    (arr.push! out^ (Pull-Attr {a: ":db/id"
                                v: (value-entity entity)
                                attrs: (make [dynamic]Pull-Attr)})))
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" entity "" (Value {}))
        high (upper-bound-index db indexes "eavt" entity "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (not (pull-output-has-attr? out^ datom.a))
            (let [children (make [dynamic]Pull-Attr)]
              (when (and (= datom.v.kind .Entity)
                         (schema-component? db datom.a))
                (set! children (pull-component-attrs db datom.v.entity seen)))
              (arr.push! out^ (Pull-Attr {a: datom.a
                                          v: datom.v
                                          attrs: children})))))))))

(defn pull-component-attrs [db: DB, entity: u64, seen: ^[dynamic]u64] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (if (u64-contains? (slice seen^ 0) entity)
      (arr.push! out (Pull-Attr {a: ":db/id"
                                 v: (value-entity entity)
                                 attrs: (make [dynamic]Pull-Attr)}))
      (do
        (arr.push! seen^ entity)
        (pull-wildcard-seen! (addr out) db entity seen)))
    out))

(defn pull-wildcard! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen entity)
    (pull-wildcard-seen! out db entity (addr seen))))

(defn pull-component-children [db: DB, parent: u64, child: u64] -> [dynamic]Pull-Attr
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen parent)
    (pull-component-attrs db child (addr seen))))

(defn pull-output-attr [spec: Pull-Spec] -> string
  (if spec.has_alias spec.alias spec.a))

(defn pull-next-recursion-depth [depth: int] -> int
  (- depth 1))

(defn pull-spec-decrement-recursion [spec: Pull-Spec, attr: string] -> Pull-Spec
  (if (and spec.has_recursion
           (= spec.a attr)
           (not (= spec.recursion_depth 0)))
    (Pull-Spec {a: spec.a
                pattern: spec.pattern
                limit: spec.limit
                has_default: spec.has_default
                default_value: spec.default_value
                has_alias: spec.has_alias
                alias: spec.alias
                has_recursion: true
                recursion_depth: (pull-next-recursion-depth spec.recursion_depth)})
    spec))

(defn pull-recursion-pattern [root: []Pull-Spec, attr: string] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec)]
    (for [spec root]
      (arr.push! out (pull-spec-decrement-recursion spec attr)))
    out))

(defn pull-forward-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        limit (pull-limit spec)
        seen 0
        found false]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [children (make [dynamic]Pull-Attr)]
            (when (= datom.v.kind .Entity)
              (if (> (count spec.pattern) 0)
                (set! children (pull-child-pattern db datom.v.entity spec.pattern spec.pattern seen-entities))
                (if (and spec.has_recursion (not (= spec.recursion_depth 0)))
                  (let [pattern (pull-recursion-pattern root spec.a)]
                    (defer (delete pattern))
                    (set! children (pull-child-recursion db datom.v.entity (slice pattern 0) seen-entities)))
                  (when (schema-component? db datom.a)
                    (set! children (pull-component-children db entity datom.v.entity))))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^ (Pull-Attr {a: (pull-output-attr spec)
                                            v: datom.v
                                            attrs: children}))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-spec-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (when (and spec.has_recursion (<= spec.recursion_depth 0))
    (return))
  (when (= spec.a "*")
    (pull-wildcard! out db entity)
    (return))
  (when (= spec.a ":db/id")
    (when (not (pull-output-has-attr? out^ (pull-output-attr spec)))
      (arr.push! out^ (Pull-Attr {a: (pull-output-attr spec)
                                  v: (value-entity entity)
                                  attrs: (make [dynamic]Pull-Attr)})))
    (return))
  (when (reverse-attr? spec.a)
    (let [found (pull-reverse-attr! out db entity spec root seen-entities)]
      (when (and (not found) spec.has_default)
        (arr.push! out^ (Pull-Attr {a: (pull-output-attr spec)
                                    v: spec.default_value
                                    attrs: (make [dynamic]Pull-Attr)}))))
    (return))
  (let [found (pull-forward-attr! out db entity spec root seen-entities)]
    (when (and (not found) spec.has_default)
      (arr.push! out^ (Pull-Attr {a: (pull-output-attr spec)
                                  v: spec.default_value
                                  attrs: (make [dynamic]Pull-Attr)})))))

(defn pull-pattern-spec-seen [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> Pull-Result
  (let [out (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (pull-spec-attr! (addr out) db entity spec root seen-entities))
    (Pull-Result {e: entity attrs: out})))

(defn pull-pattern-spec [db: DB, entity: u64, pattern: []Pull-Spec] -> Pull-Result
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen entity)
    (pull-pattern-spec-seen db entity pattern pattern (slice seen 0))))

(defn pull-pattern-lookup-ref [db: DB, attr: string, value: Value, pattern: []Pull-Spec] -> Pull-Result
  (let [[entity ok] (resolve-lookup-ref db attr value)]
    (if ok
      (pull-pattern-spec db entity pattern)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-pattern-ident [db: DB, ident: string, pattern: []Pull-Spec] -> Pull-Result
  (let [[entity ok] (schema-entity-for-attr db ident)]
    (if ok
      (pull-pattern-spec db entity pattern)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn entity-exists? [db: DB, e: u64] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" e "" (Value {}))
        high (upper-bound-index db indexes "eavt" e "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn db-entity [db: DB, e: u64] -> Entity
  (Entity {db: db e: e found: (entity-exists? db e)}))

(defn entity-lookup-ref [db: DB, attr: string, value: Value] -> Entity
  (let [[e ok] (resolve-lookup-ref db attr value)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-ident [db: DB, ident: string] -> Entity
  (let [[e ok] (schema-entity-for-attr db ident)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-id [entity: Entity] -> u64
  entity.e)

(defn entity-db [entity: Entity] -> DB
  entity.db)

(defn entity-forward-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [indexes (slice entity.db.eavt 0)
          low (lower-bound-index entity.db indexes "eavt-ea" entity.e attr (Value {}))
          high (upper-bound-index entity.db indexes "eavt-ea" entity.e attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom entity.db.datoms[datom-index]]
          (when (datom-current-at? entity.db datom-index)
            (arr.push! out datom.v)))))
    out))

(defn entity-reverse-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [forward-attr (forward-attr-for-reverse attr)
          ref-value (value-entity entity.e)
          indexes (slice entity.db.vaet 0)
          low (lower-bound-index entity.db indexes "vaet" 0 "" ref-value)
          high (upper-bound-index entity.db indexes "vaet" 0 "" ref-value)]
      (for [datom-index (slice indexes low high)]
        (let [datom entity.db.datoms[datom-index]]
          (when (and (= datom.a forward-attr)
                     (datom-current-at? entity.db datom-index))
            (arr.push! out (value-entity datom.e))))))
    out))

(defn entity-values [entity: Entity, attr: string] -> [dynamic]Value
  (if (reverse-attr? attr)
    (entity-reverse-values entity attr)
    (entity-forward-values entity attr)))

(defn entity-get [entity: Entity, attr: string] -> Value
  (when (= attr ":db/id")
    (when entity.found
      (return (value-entity entity.e)))
    (return (value-nil)))
  (let [values (entity-values entity attr)]
    (defer (delete values))
    (if (> (count values) 0)
      values[0]
      (value-nil))))

(defn entity-contains? [entity: Entity, attr: string] -> bool
  (when (= attr ":db/id")
    (return entity.found))
  (let [values (entity-values entity attr)]
    (defer (delete values))
    (> (count values) 0)))

(defn entity-refs [entity: Entity, attr: string] -> [dynamic]Entity
  (let [out (make [dynamic]Entity)
        values (entity-values entity attr)]
    (defer (delete values))
    (for [value values]
      (when (= value.kind .Entity)
        (let [ref (db-entity entity.db value.entity)]
          (when ref.found
            (arr.push! out ref)))))
    out))

(defn entity-ref [entity: Entity, attr: string] -> Entity
  (let [refs (entity-refs entity attr)]
    (defer (delete refs))
    (if (> (count refs) 0)
      refs[0]
      (Entity {db: entity.db e: 0 found: false}))))

(defn touch [entity: Entity] -> Pull-Result
  (if entity.found
    (pull-pattern-spec entity.db entity.e ([]Pull-Spec [(flat-pull-spec "*")]))
    (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))

(defn flat-pull-spec [attr: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: false
              default_value: (Value {})
              has_alias: false
              alias: ""
              pattern: ([]Pull-Spec [])}))

(defn pull-spec [attr: string, pattern: []Pull-Spec] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: false
              default_value: (Value {})
              has_alias: false
              alias: ""
              pattern: pattern}))

(defn pull-spec-recursion [attr: string, depth: int] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: false
              default_value: (Value {})
              has_alias: false
              alias: ""
              pattern: ([]Pull-Spec [])
              has_recursion: true
              recursion_depth: depth}))

(defn pull-spec-limit [attr: string, pattern: []Pull-Spec, limit: int] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: limit
              has_default: false
              default_value: (Value {})
              has_alias: false
              alias: ""
              pattern: pattern}))

(defn pull-spec-limit-as [attr: string, pattern: []Pull-Spec, limit: int, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: limit
              has_default: false
              default_value: (Value {})
              has_alias: true
              alias: alias
              pattern: pattern}))

(defn pull-spec-default [attr: string, default-value: Value] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: true
              default_value: default-value
              has_alias: false
              alias: ""
              pattern: ([]Pull-Spec [])}))

(defn pull-spec-as [attr: string, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: false
              default_value: (Value {})
              has_alias: true
              alias: alias
              pattern: ([]Pull-Spec [])}))

(defn pull-spec-default-as [attr: string, default-value: Value, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has_default: true
              default_value: default-value
              has_alias: true
              alias: alias
              pattern: ([]Pull-Spec [])}))

(defn pull-pattern [db: DB, entity: u64, attrs: []string] -> Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-pattern-spec db entity (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn pull-many-pattern-spec [db: DB, entities: []u64, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count entities))]
    (for [entity entities]
      (arr.push! out (pull-pattern-spec db entity pattern)))
    out))

(defn pull-many-pattern-lookup-refs [db: DB, attrs: []string, values: []Value, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count values))]
    (for [value index values]
      (let [[entity ok] (resolve-lookup-ref db attrs[index] value)]
        (if ok
          (arr.push! out (pull-pattern-spec db entity pattern))
          (arr.push! out (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))))
    out))

(defn pull-many-pattern [db: DB, entities: []u64, attrs: []string] -> [dynamic]Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-many-pattern-spec db entities (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn query-name-by-email [email: string] -> Query
  (query ([]string ["name"])
    ([]string [])
    ([]string [])
    ([]string [])
    ([]Tuple-Input [])
    ([]Relation-Input [])
    ([]Clause
      [(clause (term-var "e") ":user/email" (term-string email))
       (clause (term-var "e") ":user/name" (term-var "name"))])
    ([]Predicate [])
    ([]Function-Clause [])
    ([]Rule [])
    ([]Rule-Call [])
    ([]Get-Else [])
    ([]Get-Some [])
    ([]Ground [])
    ([]Not-Group [])
    ([]Or-Group [])
    ([]Pull-Find [])
    ([]Aggregate-Find [])))

(defn seed-people [conn: ^Conn] -> Tx-Report
  (transact conn
    [[:db/add 1 :user/email "ada@example.com"]
     [:db/add 1 :user/name "Ada"]
     [:db/add 1 :user/age 37]
     [:db/add 1 :user/active true]
     [:db/add 1 :user/friend (value-entity 2)]
     [:db/add 2 :user/email "grace@example.com"]
     [:db/add 2 :user/name "Grace"]
     [:db/add 2 :user/age 41]
     [:db/add 2 :user/active false]]))
