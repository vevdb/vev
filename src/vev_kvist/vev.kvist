})

(defstruct Keyed-Row {
  items: [dynamic]Keyed-Value
})

(defstruct Pull-Attr {
  a: string
  v: Value
  attrs: [dynamic]Pull-Attr
})

(defstruct Pull-Result {
  e: u64
