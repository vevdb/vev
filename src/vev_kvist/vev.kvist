})

(defstruct Not-Group {
  clauses: []Clause
  not_groups: []Not-Group
  has_join: bool
  join_vars: []string
})

(defstruct Or-Group {
  branches: []Not-Group
  has_join: bool
  join_vars: []string
})

(defstruct Pull-Find {
