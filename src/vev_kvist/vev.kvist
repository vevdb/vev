  out_value: string
})

(defstruct Ground {
  out: string
  tuple_vars: []string
  is_collection: bool
  is_tuple: bool
  value: Value
  values: []Value
})

(defstruct Query {
  find: [dynamic]string
  with: [dynamic]string
  inputs: [dynamic]string
  collection_inputs: [dynamic]string
  tuple_inputs: [dynamic]Tuple-Input
  relation_inputs: [dynamic]Relation-Input
  clauses: [dynamic]Clause
  predicates: [dynamic]Predicate
  function_clauses: [dynamic]Function-Clause
  rules: [dynamic]Rule
  rule_calls: [dynamic]Rule-Call
  get_elses: [dynamic]Get-Else
  get_somes: [dynamic]Get-Some
  grounds: [dynamic]Ground
  not_groups: [dynamic]Not-Group
  or_groups: [dynamic]Or-Group
  pulls: [dynamic]Pull-Find
  aggregates: [dynamic]Aggregate-Find
})

(defstruct Var-Binding {
  name: string
  value: Value
})

(defstruct Binding {
