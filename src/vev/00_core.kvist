})

(defn value-entity [id: u64] -> Value
  (Value {kind: .Entity entity: id}))

(defn value-string [text: string] -> Value
  (Value {kind: .String text: text}))

(defn value-int [value: i64] -> Value
  (Value {kind: .Int int_value: value}))

(defn value-float [value: f64] -> Value
  (Value {kind: .Float float_value: value}))

(defn value-bool [value: bool] -> Value
  (Value {kind: .Bool bool_value: value}))

(defn value-keyword [text: string] -> Value
  (Value {kind: .Keyword text: text}))

(defn value-nil [] -> Value
  (Value {kind: .Nil}))

(defn value-vector [items: []Value] -> Value
  (let [owned (arr.into [dynamic]Value items)]
    (Value {kind: .Vector items: owned})))

(defn value-map [items: []Value] -> Value
  (let [owned (arr.into [dynamic]Value items)]
    (Value {kind: .Map items: owned})))

(defn value-vector2 [a: Value, b: Value] -> Value
  (value-vector ([]Value [a b])))

(defn- value-keyword-vector2 [a: string, b: string] -> Value
  (value-vector2 (value-keyword a) (value-keyword b)))

(defn tuple-attrs-schema-tx [schema-e: u64, tuple-attr: string, a: string, b: string] -> [dynamic]Tx-Data
  (let [out (make [dynamic]Tx-Data)]
    (arr.push! out (add schema-e ":db/ident" (value-keyword tuple-attr)))
    (arr.push! out (add schema-e ":db/tupleAttrs" (value-keyword-vector2 a b)))
    out))

(defn string-less? [left: string, right: string] -> bool
  (< (strings.compare left right) 0))

(defn value-kind-rank [kind: Value-Kind] -> int
  (case kind
    .Nil 0
    .Entity 1
    .Int 2
    .Float 3
    .String 4
    .Bool 5
    .Keyword 6
    .Vector 7
    .Map 8
    :else 99))

(defn slash-index [text: string] -> int
  (for [_ index text]
    (when (= (slice text index (+ index 1)) "/")
      (return index)))
  -1)

(defn keyword-less? [left: string, right: string] -> bool
  (let [left-slash (slash-index left)
        right-slash (slash-index right)
        left-ns ""
        right-ns ""]
    (when (not (= left-slash -1))
      (set! left-ns (slice left 1 left-slash)))
    (when (not (= right-slash -1))
      (set! right-ns (slice right 1 right-slash)))
    (let [ns-compare (strings.compare left-ns right-ns)]
      (when (not (= ns-compare 0))
        (return (< ns-compare 0))))
    (let [left-name (slice left 1)
          right-name (slice right 1)]
      (when (not (= left-slash -1))
        (set! left-name (slice left (+ left-slash 1))))
      (when (not (= right-slash -1))
        (set! right-name (slice right (+ right-slash 1))))
      (string-less? left-name right-name))))

(defn value-less? [left: Value, right: Value] -> bool
  (if (not (= left.kind right.kind))
    (< (value-kind-rank left.kind) (value-kind-rank right.kind))
    (case left.kind
      .Entity (< left.entity right.entity)
      .String (string-less? left.text right.text)
      .Int (< left.int_value right.int_value)
      .Float (< left.float_value right.float_value)
      .Bool (and (not left.bool_value) right.bool_value)
      .Keyword (keyword-less? left.text right.text)
      .Vector (do
        (let [limit (min (count left.items) (count right.items))]
          (for [index 0..<limit]
            (when (value-less? left.items[index] right.items[index])
              (return true))
            (when (value-less? right.items[index] left.items[index])
              (return false)))
          (< (count left.items) (count right.items))))
      .Map (do
        (let [limit (min (count left.items) (count right.items))]
          (for [index 0..<limit]
            (when (value-less? left.items[index] right.items[index])
              (return true))
            (when (value-less? right.items[index] left.items[index])
              (return false)))
          (< (count left.items) (count right.items))))
      .Nil false
      :else false)))

(defn value-compare [left: Value, right: Value] -> int
  (if (value-less? left right)
    -1
    (if (value-less? right left)
      1
      0)))

(defn term-value [value: Value] -> Term
  (Term {kind: .Value value: value}))

(defn term-entity [id: u64] -> Term
  (term-value (value-entity id)))

(defn term-string [text: string] -> Term
  (term-value (value-string text)))

(defn term-int [value: i64] -> Term
  (term-value (value-int value)))

(defn term-bool [value: bool] -> Term
  (term-value (value-bool value)))

(defn term-keyword [text: string] -> Term
  (term-value (value-keyword text)))

(defn term-var [name: string] -> Term
  (Term {kind: .Var name: name}))

(defn term-wildcard [] -> Term
  (Term {kind: .Wildcard}))

(defn term-lookup-ref [attr: string, value: Value] -> Term
  (Term {kind: .LookupRef lookup_attr: attr lookup_value: value}))

(defn attr [name: string] -> Term
  (term-keyword name))

(defn clause [e: Term, a: string, v: Term] -> Clause
  (Clause {e: e
           a: (attr a)
           v: v
           tx_term: (term-wildcard)
           op_term: (term-wildcard)
           source: ""
           has_source: false
           source_width: 0}))

(defn tx-add [e: u64, a: string, v: Value] -> Tx-Op
  (Tx-Op {kind: .Add e: e a: a v: v}))

(defn tx-add-derived [e: u64, a: string, v: Value] -> Tx-Op
  (Tx-Op {kind: .Add e: e a: a v: v derived: true}))

(defn tx-retract [e: u64, a: string, v: Value] -> Tx-Op
  (Tx-Op {kind: .Retract e: e a: a v: v}))

(defn tx-op-equal? [left: Tx-Op, right: Tx-Op] -> bool
  (and (= left.kind right.kind)
       (= left.e right.e)
       (= left.a right.a)
       (value-equal? left.v right.v)))

(defn push-tx-op-once! [ops: ^[dynamic]Tx-Op, op: Tx-Op]
  (for [existing ops^]
    (when (tx-op-equal? existing op)
      (return)))
  (arr.push! ops^ op))

(defn add [e: u64, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" e: e a: a v: v}))

(defn retract [e: u64, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/retract" e: e a: a v: v}))

(defn cas [e: u64, a: string, expected: Value, v: Value] -> Tx-Data
  (Tx-Data {op: ":db.fn/cas" e: e a: a expected: expected v: v}))

(defn cas-tempid [tempid: string, a: string, expected: Value, v: Value] -> Tx-Data
  (Tx-Data {op: ":db.fn/cas" tempid: tempid has_tempid: true a: a expected: expected v: v}))

(defn cas-lookup-ref [lookup-attr: string, lookup-value: Value, a: string, expected: Value, v: Value] -> Tx-Data
  (Tx-Data {op: ":db.fn/cas" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true a: a expected: expected v: v}))

(defn cas-expected-lookup-ref [e: u64, a: string, expected-attr: string, expected-value: Value, v: Value] -> Tx-Data
  (Tx-Data {op: ":db.fn/cas" e: e a: a expected_lookup_attr: expected-attr expected_lookup_value: expected-value has_expected_lookup_ref: true v: v}))

(defn cas-value-lookup-ref [e: u64, a: string, expected: Value, value-attr: string, value-value: Value] -> Tx-Data
  (Tx-Data {op: ":db.fn/cas" e: e a: a expected: expected value_lookup_attr: value-attr value_lookup_value: value-value has_value_lookup_ref: true}))

(defn retract-attr [e: u64, a: string] -> Tx-Data
  (Tx-Data {op: ":db/retractAttr" e: e a: a}))

(defn retract-entity [e: u64] -> Tx-Data
  (Tx-Data {op: ":db/retractEntity" e: e}))

(defn add-tempid [tempid: string, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" tempid: tempid has_tempid: true a: a v: v}))

(defn add-value-tempid [e: u64, a: string, value-tempid: string] -> Tx-Data
  (Tx-Data {op: ":db/add" e: e a: a value_tempid: value-tempid has_value_tempid: true}))

(defn add-value-lookup-ref [e: u64, a: string, lookup-attr: string, lookup-value: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" e: e a: a value_lookup_attr: lookup-attr value_lookup_value: lookup-value has_value_lookup_ref: true}))

(defn add-tempid-value-lookup-ref [tempid: string, a: string, lookup-attr: string, lookup-value: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" tempid: tempid has_tempid: true a: a value_lookup_attr: lookup-attr value_lookup_value: lookup-value has_value_lookup_ref: true}))

(defn retract-value-lookup-ref [e: u64, a: string, lookup-attr: string, lookup-value: Value] -> Tx-Data
  (Tx-Data {op: ":db/retract" e: e a: a value_lookup_attr: lookup-attr value_lookup_value: lookup-value has_value_lookup_ref: true}))

(defn add-tempid-value-tempid [tempid: string, a: string, value-tempid: string] -> Tx-Data
  (Tx-Data {op: ":db/add" tempid: tempid has_tempid: true a: a value_tempid: value-tempid has_value_tempid: true}))

(defn retract-tempid [tempid: string, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/retract" tempid: tempid has_tempid: true a: a v: v}))

(defn retract-attr-tempid [tempid: string, a: string] -> Tx-Data
  (Tx-Data {op: ":db/retractAttr" tempid: tempid has_tempid: true a: a}))

(defn retract-entity-tempid [tempid: string] -> Tx-Data
  (Tx-Data {op: ":db/retractEntity" tempid: tempid has_tempid: true}))

(defn add-lookup-ref [lookup-attr: string, lookup-value: Value, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true a: a v: v}))

(defn add-lookup-ref-value-tempid [lookup-attr: string, lookup-value: Value, a: string, value-tempid: string] -> Tx-Data
  (Tx-Data {op: ":db/add" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true a: a value_tempid: value-tempid has_value_tempid: true}))

(defn retract-lookup-ref [lookup-attr: string, lookup-value: Value, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/retract" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true a: a v: v}))

(defn retract-attr-lookup-ref [lookup-attr: string, lookup-value: Value, a: string] -> Tx-Data
  (Tx-Data {op: ":db/retractAttr" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true a: a}))

(defn retract-entity-lookup-ref [lookup-attr: string, lookup-value: Value] -> Tx-Data
  (Tx-Data {op: ":db/retractEntity" lookup_attr: lookup-attr lookup_value: lookup-value has_lookup_ref: true}))

(defn add-ident [ident: string, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/add" ident: ident has_ident: true a: a v: v}))

(defn add-ident-value-tempid [ident: string, a: string, value-tempid: string] -> Tx-Data
  (Tx-Data {op: ":db/add" ident: ident has_ident: true a: a value_tempid: value-tempid has_value_tempid: true}))

(defn retract-ident [ident: string, a: string, v: Value] -> Tx-Data
  (Tx-Data {op: ":db/retract" ident: ident has_ident: true a: a v: v}))

(defn retract-attr-ident [ident: string, a: string] -> Tx-Data
