(defn retract-entity-ident [ident: string] -> Tx-Data
  (Tx-Data {op: ":db/retractEntity" ident: ident has_ident: true}))

(defn tempid-lookup [tempids: []Tempid, tempid: string] -> [e: u64, ok: bool]
  (for [item tempids]
    (when (= item.tempid tempid)
      (return item.e true)))
  (return 0 false))

(defn current-tx-tempid? [tempid: string] -> bool
  (or (= tempid ":db/current-tx")
      (= tempid "datomic.tx")
      (= tempid "datascript.tx")))

(defn current-tx-value? [value: Value] -> bool
  (and (or (= value.kind .Keyword)
           (= value.kind .String))
       (current-tx-tempid? value.text)))

(defn ensure-tempid! [tempids: ^[dynamic]Tempid, tempid: string, e: u64]
  (let [[_ ok] (tempid-lookup (slice tempids^ 0) tempid)]
    (when (not ok)
      (arr.push! tempids^ (Tempid {tempid: tempid e: e})))))

(defn next-entity-id [datoms: []Datom] -> u64
  (let [next: u64 1]
    (for [datom datoms]
      (when (>= datom.e next)
        (set! next (+ datom.e 1))))
    next))

(defn value-equal? [left: Value, right: Value] -> bool
  (if (not (= left.kind right.kind))
    false
    (case left.kind
      .Entity (= left.entity right.entity)
      .String (= left.text right.text)
      .Int (= left.int_value right.int_value)
      .Float (= left.float_value right.float_value)
      .Bool (= left.bool_value right.bool_value)
      .Keyword (= left.text right.text)
      .Vector (values-equal? (slice left.items 0) (slice right.items 0))
      .Map (do
        (when (not (= (count left.items) (count right.items)))
          (return false))
        (when (not (= (% (count left.items) 2) 0))
          (return false))
        (let [left-index 0]
          (while (< left-index (count left.items))
            (let [found false
                  right-index 0]
              (while (< right-index (count right.items))
                (when (and (value-equal? left.items[left-index] right.items[right-index])
                           (value-equal? left.items[(+ left-index 1)] right.items[(+ right-index 1)]))
                  (set! found true))
                (set! right-index (+ right-index 2)))
              (when (not found)
                (return false)))
            (set! left-index (+ left-index 2))))
        true)
      .Nil true
      :else false)))

(defn predicate-value-equal? [left: Value, right: Value] -> bool
  (if (and (= left.kind .Entity) (= right.kind .Int))
    (= left.entity (u64 right.int_value))
    (if (and (= left.kind .Int) (= right.kind .Entity))
      (= (u64 left.int_value) right.entity)
      (value-equal? left right))))

(defn values-equal? [left: []Value, right: []Value] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [value index left]
    (when (not (value-equal? value right[index]))
      (return false)))
  true)

(defn value-exists? [values: []Value, value: Value] -> bool
  (for [existing values]
    (when (value-equal? existing value)
      (return true)))
  false)

(defn row-values-exist? [rows: []Result-Row, values: []Value] -> bool
  (for [row rows]
    (when (values-equal? (slice row.values 0) values)
      (return true)))
  false)

(defn row-value-prefix-exists? [rows: []Result-Row, values: []Value] -> bool
  (for [row rows]
    (when (values-equal? (slice row.values 0 (count values)) values)
      (return true)))
  false)

(defn datom-less-eavt? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.e right.e))
      (< left.e right.e)
      (if (not (= left.a right.a))
        (string-less? left.a right.a)
        (if (not (value-equal? left.v right.v))
          (value-less? left.v right.v)
          (< left.tx right.tx))))))

(defn datom-less-aevt? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.a right.a))
      (string-less? left.a right.a)
      (if (not (= left.e right.e))
        (< left.e right.e)
        (if (not (value-equal? left.v right.v))
          (value-less? left.v right.v)
          (< left.tx right.tx))))))

(defn datom-less-avet? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (= left.a right.a))
      (string-less? left.a right.a)
      (if (not (value-equal? left.v right.v))
        (value-less? left.v right.v)
        (if (not (= left.e right.e))
          (< left.e right.e)
          (< left.tx right.tx))))))

(defn datom-less-vaet? [datoms: []Datom, left-index: int, right-index: int] -> bool
  (let [left datoms[left-index]
        right datoms[right-index]]
    (if (not (value-equal? left.v right.v))
      (value-less? left.v right.v)
      (if (not (= left.a right.a))
        (string-less? left.a right.a)
        (if (not (= left.e right.e))
          (< left.e right.e)
          (< left.tx right.tx))))))

(defn sort-datom-indexes! [indexes: ^[dynamic]int, datoms: []Datom, order: string]
  // ponytail: insertion sort is fine for the in-memory proof; replace when benchmarks say index build dominates.
  (for [i (arr.range 1 (count indexes^))]
    (let [current indexes^[i]
          j i]
      (while (> j 0)
        (let [previous indexes^[(- j 1)]
              less false]
          (if (= order "eavt")
            (set! less (datom-less-eavt? datoms current previous))
            (if (= order "aevt")
              (set! less (datom-less-aevt? datoms current previous))
              (if (= order "avet")
                (set! less (datom-less-avet? datoms current previous))
                (set! less (datom-less-vaet? datoms current previous)))))
          (if less
            (do
              (set! indexes^[j] previous)
              (set! j (- j 1)))
            (break))))
      (set! indexes^[j] current))))

(defn build-index [datoms: []Datom, order: string] -> [dynamic]int
  (let [indexes (make [dynamic]int 0 (count datoms))]
    (for [_ index datoms]
      (arr.push! indexes index))
    (sort-datom-indexes! (addr indexes) datoms order)
    indexes))

(defn same-fact? [left: Datom, right: Datom] -> bool
  (and (= left.e right.e)
       (= left.a right.a)
       (value-equal? left.v right.v)))

(defn current-fact-exists? [db: DB, target: Datom] -> bool
  (for [datom-index db.eavt]
    (when (datom-current-at? db datom-index)
      (when (same-fact? db.datoms[datom-index] target)
        (return true))))
  false)

(defn append-db-diff-side! [only-side: ^[dynamic]Datom, both: ^[dynamic]Datom, left: DB, right: DB]
  (for [datom-index left.eavt]
    (when (datom-current-at? left datom-index)
      (let [datom left.datoms[datom-index]]
        (if (current-fact-exists? right datom)
          (arr.push! both^ datom)
          (arr.push! only-side^ datom))))))

(defn db-diff [left: DB, right: DB] -> DB-Diff
  (let [only-left (make [dynamic]Datom)
        only-right (make [dynamic]Datom)
        both (make [dynamic]Datom)]
    (append-db-diff-side! (addr only-left) (addr both) left right)
    (for [datom-index right.eavt]
      (when (datom-current-at? right datom-index)
        (let [datom right.datoms[datom-index]]
          (when (not (current-fact-exists? left datom))
            (arr.push! only-right datom)))))
    (DB-Diff {only_left: only-left only_right: only-right both: both})))

(defn datom-current-in-log? [datoms: []Datom, index: int] -> bool
  (let [datom datoms[index]]
    (when (not datom.added)
      (return false))
    (for [later (slice datoms (+ index 1))]
      (when (same-fact? datom later)
        (return false)))
    true))

(defn build-current-index [datoms: []Datom] -> [dynamic]int
  // ponytail: O(n^2) snapshot build is fine until transact benchmarks say otherwise.
  (let [indexes (make [dynamic]int)]
    (for [_ index datoms]
      (when (datom-current-in-log? datoms index)
        (arr.push! indexes index)))
    indexes))

(defn int-lower-bound [xs: []int, value: int] -> int
  (let [low 0
        high (count xs)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)]
        (if (< xs[mid] value)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn build-db [datoms: [dynamic]Datom] -> DB
  (let [slice-datoms (slice datoms 0)]
    (DB {datoms: datoms
         current: (build-current-index slice-datoms)
         eavt: (build-index slice-datoms "eavt")
         aevt: (build-index slice-datoms "aevt")
         avet: (build-index slice-datoms "avet")
         vaet: (build-index slice-datoms "vaet")})))

(defn clone-datom-slice [datoms: []Datom] -> [dynamic]Datom
  (arr.into [dynamic]Datom datoms))

(defn make-datom [e: u64, a: string, v: Value] -> Datom
  (Datom {e: e a: a v: v tx: 0 added: true}))

(defn datom-tx [e: u64, a: string, v: Value, tx: u64, added: bool] -> Datom
  (Datom {e: e a: a v: v tx: tx added: added}))

(defn init-db [datoms: []Datom] -> DB
  (build-db (clone-datom-slice datoms)))

(defn filter-db [db: DB, pred: (fn [db: DB, datom: Datom] -> bool)] -> DB
  // ponytail: materialize filtered DBs for now; replace with predicate-wrapped indexes only if benchmarks require it.
  (let [datoms (make [dynamic]Datom)]
    (for [datom-index db.eavt]
      (when (datom-current-at? db datom-index)
        (let [datom db.datoms[datom-index]]
          (when (pred db datom)
            (arr.push! datoms datom)))))
    (build-db datoms)))

(defn max-tx [datoms: []Datom] -> u64
  (let [tx: u64 0]
    (for [datom datoms]
      (when (> datom.tx tx)
        (set! tx datom.tx)))
    tx))

(defn conn-from-db [db: DB] -> Conn
  (Conn {db: (build-db (clone-datom-slice (slice db.datoms 0)))
         next_tx: (+ (max-tx (slice db.datoms 0)) 1)}))

(defn conn-from-datoms [datoms: []Datom] -> Conn
  (conn-from-db (init-db datoms)))

(defn compare-eavt-prefix [datom: Datom, e: u64] -> int
  (if (< datom.e e)
    -1
    (if (> datom.e e) 1 0)))

(defn compare-eavt-entity-attr-prefix [datom: Datom, e: u64, a: string] -> int
  (let [e-compare (compare-eavt-prefix datom e)]
    (if (not (= e-compare 0))
      e-compare
      (strings.compare datom.a a))))

(defn compare-aevt-prefix [datom: Datom, a: string] -> int
  (strings.compare datom.a a))

(defn compare-avet-prefix [datom: Datom, a: string, v: Value] -> int
  (let [a-compare (strings.compare datom.a a)]
    (if (not (= a-compare 0))
      a-compare
      (value-compare datom.v v))))

(defn compare-vaet-prefix [datom: Datom, v: Value] -> int
  (value-compare datom.v v))

(defn datom-prefix-compare [db: DB, order: string, datom-index: int, e: u64, a: string, v: Value] -> int
  (let [datom db.datoms[datom-index]]
    (if (= order "eavt")
      (compare-eavt-prefix datom e)
      (if (= order "eavt-ea")
        (compare-eavt-entity-attr-prefix datom e a)
        (if (= order "aevt")
          (compare-aevt-prefix datom a)
          (if (= order "avet")
            (compare-avet-prefix datom a v)
            (compare-vaet-prefix datom v)))))))

(defn lower-bound-index [db: DB, indexes: []int, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (datom-prefix-compare db order indexes[mid] e a v)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn upper-bound-index [db: DB, indexes: []int, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (datom-prefix-compare db order indexes[mid] e a v)]
        (if (<= compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn create-conn [] -> Conn
  (Conn {db: (build-db (make [dynamic]Datom))
         next_tx: 1}))
