(package vev)

(defstruct Shared-Int-Chunk {
  values: [dynamic]int
  refs: [dynamic]int
})

(defstruct Shared-Int-Index {
  chunks: [dynamic]Shared-Int-Chunk
  count: int
  chunk-size: int
})

(defstruct Shared-Datom-Chunk {
  values: [dynamic]Datom
  refs: [dynamic]int
})

(defstruct Shared-Datom-Log {
  chunks: [dynamic]Shared-Datom-Chunk
  chunk-starts: [dynamic]int
  count: int
  chunk-size: int
})

(defstruct Shared-DB-Int-Indexes {
  current: Shared-Int-Index
  eavt: Shared-Int-Index
  aevt: Shared-Int-Index
  avet: Shared-Int-Index
  vaet: Shared-Int-Index
})

(defstruct Shared-DB-Snapshot {
  datoms: Shared-Datom-Log
  indexes: Shared-DB-Int-Indexes
})

(defstruct Shared-Write-State {
  conn: Conn
  has-tuple-schema: bool
  schema-ref: set[string]
  schema-unique: set[string]
  schema-unique-identity: set[string]
  next-entity-id: u64
  source-resolves: int
  resident-fallbacks: int
})

(defstruct Shared-Conn {
  write: Shared-Write-State
  snapshot: Shared-DB-Snapshot
  chunk-size: int
})

(defstruct Shared-Tx-Report {
  ok: bool
  error: string
  db-before: Shared-DB-Snapshot
  db-after: Shared-DB-Snapshot
  tx-data: [dynamic]Datom
  tx: u64
  tx-meta: [dynamic]Tx-Meta
  tempids: [dynamic]Tempid
  datom-start-index: int
  append-only: bool
  new-entities-after-existing: bool
})

(defstruct Tx-Fn-Source-Result {
  ok: bool
  error: string
  tx-data: [dynamic]Tx-Data
})

(defstruct Tx-Fn-Source-String {
  ident: string
  f: fn [source: DB-Read-Source, arg: string] -> Tx-Fn-Source-Result
  has-values-fn: bool
  values-f: fn [source: DB-Read-Source, args: []Value] -> Tx-Fn-Source-Result
})

(defn shared-int-chunk [values: []int] -> Shared-Int-Chunk
  (let [refs (make [dynamic]int 0 1)
        owned (arr.into [dynamic]int values)]
    (arr.push! refs 1)
    (Shared-Int-Chunk {values: owned refs: refs})))

(defn shared-int-chunk-from-range [start: int, end: int] -> Shared-Int-Chunk
  (let [refs (make [dynamic]int 0 1)
        owned (make [dynamic]int 0 (max 0 (- end start)))
        value start]
    (arr.push! refs 1)
    (while (< value end)
      (arr.push! owned value)
      (set! value (+ value 1)))
    (Shared-Int-Chunk {values: owned refs: refs})))

(defn retain-shared-int-chunk! [chunk: Shared-Int-Chunk]
  (set! chunk.refs[0] (+ chunk.refs[0] 1)))

(defn release-shared-int-chunk! [chunk: Shared-Int-Chunk]
  (set! chunk.refs[0] (- chunk.refs[0] 1))
  (when (= chunk.refs[0] 0)
    (delete chunk.values)
    (delete chunk.refs)))

(defn shared-int-index-empty [chunk-size: int] -> Shared-Int-Index
  (Shared-Int-Index {chunks: (make [dynamic]Shared-Int-Chunk)
                     count: 0
                     chunk-size: (max 1 chunk-size)}))

(defn shared-int-index-from-slice [values: []int, chunk-size: int] -> Shared-Int-Index
  (let [out (shared-int-index-empty chunk-size)
        size out.chunk-size
        start 0]
    (while (< start (count values))
      (let [end (min (+ start size) (count values))
            chunk (shared-int-chunk (slice values start end))]
        (arr.push! out.chunks chunk)
        (set! start end)))
    (set! out.count (count values))
    out))

(defn retain-shared-int-index [index: Shared-Int-Index] -> Shared-Int-Index
  (let [chunks (make [dynamic]Shared-Int-Chunk 0 (count index.chunks))]
    (for [chunk index.chunks]
      (retain-shared-int-chunk! chunk)
      (arr.push! chunks chunk))
    (Shared-Int-Index {chunks: chunks
                       count: index.count
                       chunk-size: index.chunk-size})))

(defn delete-shared-int-index [index: Shared-Int-Index]
  (for [chunk index.chunks]
    (release-shared-int-chunk! chunk))
  (delete index.chunks))

(defn shared-int-index-count [index: Shared-Int-Index] -> int
  index.count)

(defn shared-int-index-at [index: Shared-Int-Index, position: int] -> [value: int, ok: bool]
  (when (or (< position 0)
            (>= position index.count))
    (return 0 false))
  (let [remaining position]
    (for [chunk index.chunks]
      (let [chunk-count (count chunk.values)]
        (if (< remaining chunk-count)
          (return chunk.values[remaining] true)
          (set! remaining (- remaining chunk-count))))))
  (return 0 false))

(defn shared-int-index-ref-count-at [index: Shared-Int-Index, chunk-index: int] -> [refs: int, ok: bool]
  (when (or (< chunk-index 0)
            (>= chunk-index (count index.chunks)))
    (return 0 false))
  (return index.chunks[chunk-index].refs[0] true))

(defn shared-int-index-lower-bound [index: Shared-Int-Index, value: int] -> int
  (let [low 0
        high index.count]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            [candidate ok] (shared-int-index-at index mid)]
        (if (and ok (< candidate value))
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn shared-int-index-contains? [index: Shared-Int-Index, value: int] -> bool
  (let [position (shared-int-index-lower-bound index value)]
    (when (>= position index.count)
      (return false))
    (let [[candidate ok] (shared-int-index-at index position)]
      (and ok (= candidate value)))))

(defn shared-int-index-with-appended-slice [base: Shared-Int-Index, values: []int] -> Shared-Int-Index
  (let [out (retain-shared-int-index base)
        start 0]
    (while (< start (count values))
      (let [end (min (+ start out.chunk-size) (count values))
            chunk (shared-int-chunk (slice values start end))]
        (arr.push! out.chunks chunk)
        (set! start end)))
    (set! out.count (+ out.count (count values)))
    out))

(defn shared-int-index-with-appended-tail [base: Shared-Int-Index, values: []int] -> Shared-Int-Index
  (if (<= base.count (count values))
    (shared-int-index-with-appended-slice base (slice values base.count))
    (shared-int-index-from-slice values base.chunk-size)))

(defn shared-int-index-with-appended-range [base: Shared-Int-Index, start: int, end: int] -> Shared-Int-Index
  (let [out (retain-shared-int-index base)
        offset start]
    (while (< offset end)
      (let [chunk-end (min (+ offset out.chunk-size) end)
            chunk (shared-int-chunk-from-range offset chunk-end)]
        (arr.push! out.chunks chunk)
        (set! out.count (+ out.count (- chunk-end offset)))
        (set! offset chunk-end)))
    out))

(defn shared-int-index-with-appended-sorted-datoms [base: Shared-Int-Index, datoms: []Datom, start-index: int, order: string] -> Shared-Int-Index
  (let [added (sorted-new-datom-indexes datoms start-index order) :defer]
    (shared-int-index-with-appended-slice base (slice added 0))))

(defn shared-int-index-with-appended-sorted-datom-slice [base: Shared-Int-Index, datoms: []Datom, start-index: int, order: string] -> Shared-Int-Index
  (let [added (sorted-appended-datom-slice-indexes datoms start-index order) :defer]
    (shared-int-index-with-appended-slice base (slice added 0))))

(defn shared-datom-log-at-borrowed [log: Shared-Datom-Log, position: int] -> [datom: Datom, ok: bool]
  (when (or (< position 0)
            (>= position log.count)
            (= (count log.chunk-starts) 0))
    (return (Datom {}) false))
  (let [estimated (/ position log.chunk-size)]
    (when (and (>= estimated 0)
               (< estimated (count log.chunks)))
      (let [start log.chunk-starts[estimated]
            offset (- position start)
            chunk log.chunks[estimated]]
        (when (and (>= offset 0)
                   (< offset (count chunk.values)))
          (return chunk.values[offset] true)))))
  (let [low 0
        high (count log.chunk-starts)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)]
        (if (<= log.chunk-starts[mid] position)
          (set! low (+ mid 1))
          (set! high mid))))
    (let [found-index (- low 1)]
      (when (or (< found-index 0)
                (>= found-index (count log.chunks)))
        (return (Datom {}) false))
      (let [offset (- position log.chunk-starts[found-index])
            chunk log.chunks[found-index]]
        (when (or (< offset 0)
                  (>= offset (count chunk.values)))
          (return (Datom {}) false))
        (return chunk.values[offset] true)))))

(defn shared-int-chunk-matches-slice? [chunk: Shared-Int-Chunk, values: []int, start: int] -> bool
  (when (> (+ start (count chunk.values)) (count values))
    (return false))
  (for [value offset chunk.values]
    (when (not (= value values[(+ start offset)]))
      (return false)))
  true)

(defn shared-int-index-from-base-pages-or-slice [base: Shared-Int-Index, values: []int] -> Shared-Int-Index
  (let [out (shared-int-index-empty base.chunk-size)
        offset 0]
    (for [chunk base.chunks]
      (when (< offset (count values))
        (let [end (min (+ offset (count chunk.values)) (count values))]
          (if (shared-int-chunk-matches-slice? chunk values offset)
            (do
              (retain-shared-int-chunk! chunk)
              (arr.push! out.chunks chunk))
            (arr.push! out.chunks (shared-int-chunk (slice values offset end))))))
      (set! offset (+ offset (count chunk.values))))
    (while (< offset (count values))
      (let [end (min (+ offset out.chunk-size) (count values))]
        (arr.push! out.chunks (shared-int-chunk (slice values offset end)))
        (set! offset end)))
    (set! out.count (count values))
    out))

(defn shared-int-index-flush-pending! [out: ^Shared-Int-Index, pending: ^[dynamic]int]
  (when (> (count pending^) 0)
    (arr.push! out^.chunks (shared-int-chunk (slice pending^ 0)))
    (delete pending^)
    (set! pending^ (make [dynamic]int 0 out^.chunk-size))))

(defn shared-int-index-push-merged-value! [out: ^Shared-Int-Index, pending: ^[dynamic]int, value: int]
  (arr.push! pending^ value)
  (set! out^.count (+ out^.count 1))
  (when (>= (count pending^) out^.chunk-size)
    (shared-int-index-flush-pending! out pending)))

(defn shared-int-index-append-slice! [out: ^Shared-Int-Index, pending: ^[dynamic]int, values: []int]
  (let [offset 0]
    (while (< offset (count values))
      (if (and (= (count pending^) 0)
               (>= (- (count values) offset) out^.chunk-size))
        (let [end (+ offset out^.chunk-size)]
          (arr.push! out^.chunks (shared-int-chunk (slice values offset end)))
          (set! out^.count (+ out^.count out^.chunk-size))
          (set! offset end))
        (let [space (- out^.chunk-size (count pending^))
              take (min space (- (count values) offset))
              end (+ offset take)]
          (for [value (slice values offset end)]
            (arr.push! pending^ value))
          (set! out^.count (+ out^.count take))
          (set! offset end)
          (when (>= (count pending^) out^.chunk-size)
            (shared-int-index-flush-pending! out pending)))))))

(defn shared-int-chunk-before-or-at-added? [datoms: []Datom, order: string, chunk: Shared-Int-Chunk, added-index: int] -> bool
  (when (= (count chunk.values) 0)
    (return false))
  (not (datom-index-less? datoms order added-index chunk.values[(- (count chunk.values) 1)])))

(defn shared-datom-log-or-appended-at-borrowed [log: Shared-Datom-Log, appended: []Datom, start-index: int, index: int] -> [datom: Datom, ok: bool]
  (if (< index start-index)
    (shared-datom-log-at-borrowed log index)
    (let [appended-index (- index start-index)]
      (when (or (< appended-index 0)
                (>= appended-index (count appended)))
        (return (Datom {}) false))
      (return appended[appended-index] true))))

(defn shared-datom-index-less? [log: Shared-Datom-Log, appended: []Datom, start-index: int, order: string, left-index: int, right-index: int] -> bool
  (let [[left left-ok] (shared-datom-log-or-appended-at-borrowed log appended start-index left-index)
        [right right-ok] (shared-datom-log-or-appended-at-borrowed log appended start-index right-index)]
    (when (or (not left-ok)
              (not right-ok))
      (return false))
    (datom-less-order? left right order left-index right-index)))

(defn appended-datom-index-less-than-base? [base-datoms: []Datom, appended: []Datom, start-index: int, order: string, appended-index: int, base-index: int] -> bool
  (let [appended-offset (- appended-index start-index)]
    (when (or (< base-index 0)
              (>= base-index (count base-datoms))
              (< appended-offset 0)
              (>= appended-offset (count appended)))
      (return false))
    (datom-less-order? appended[appended-offset] base-datoms[base-index] order appended-index base-index)))

(defn shared-int-chunk-before-or-at-added-direct? [log: Shared-Datom-Log, appended: []Datom, start-index: int, order: string, chunk: Shared-Int-Chunk, added-index: int] -> bool
  (when (= (count chunk.values) 0)
    (return false))
  (not (shared-datom-index-less? log appended start-index order added-index chunk.values[(- (count chunk.values) 1)])))

(defn shared-int-chunk-before-or-at-added-across-append? [base-datoms: []Datom, appended: []Datom, start-index: int, order: string, chunk: Shared-Int-Chunk, added-index: int] -> bool
  (when (= (count chunk.values) 0)
    (return false))
  (not (appended-datom-index-less-than-base? base-datoms appended start-index order added-index chunk.values[(- (count chunk.values) 1)])))

(defn shared-int-index-with-merged-appended-datoms [base: Shared-Int-Index, datoms: []Datom, start-index: int, order: string] -> Shared-Int-Index
  (let [added (sorted-new-datom-indexes datoms start-index order) :defer]
    (shared-int-index-with-merged-appended-indexes base datoms order (slice added 0))))

(defn shared-int-index-with-merged-appended-indexes [base: Shared-Int-Index, datoms: []Datom, order: string, added: []int] -> Shared-Int-Index
  (let [out (shared-int-index-empty base.chunk-size)
        pending (make [dynamic]int 0 base.chunk-size)
        chunk-index 0
        chunk-offset 0
        added-index 0]
    (while (or (< chunk-index (count base.chunks))
               (< added-index (count added)))
      (cond
        (>= chunk-index (count base.chunks))
          (do
            (shared-int-index-append-slice! (addr out) (addr pending) (slice added added-index))
            (set! added-index (count added)))
        (>= added-index (count added))
          (if (= chunk-offset 0)
            (do
              (shared-int-index-flush-pending! (addr out) (addr pending))
              (retain-shared-int-chunk! base.chunks[chunk-index])
              (arr.push! out.chunks base.chunks[chunk-index])
              (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
              (set! chunk-index (+ chunk-index 1)))
            (do
              (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
              (set! chunk-offset (+ chunk-offset 1))
              (when (>= chunk-offset (count base.chunks[chunk-index].values))
                (set! chunk-index (+ chunk-index 1))
                (set! chunk-offset 0))))
        (and (= chunk-offset 0)
             (shared-int-chunk-before-or-at-added? datoms order base.chunks[chunk-index] added[added-index]))
          (do
            (shared-int-index-flush-pending! (addr out) (addr pending))
            (retain-shared-int-chunk! base.chunks[chunk-index])
            (arr.push! out.chunks base.chunks[chunk-index])
            (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
            (set! chunk-index (+ chunk-index 1)))
        (datom-index-less? datoms order added[added-index] base.chunks[chunk-index].values[chunk-offset])
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) added[added-index])
            (set! added-index (+ added-index 1)))
        :else
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
            (set! chunk-offset (+ chunk-offset 1))
            (when (>= chunk-offset (count base.chunks[chunk-index].values))
              (set! chunk-index (+ chunk-index 1))
              (set! chunk-offset 0)))))
    (shared-int-index-flush-pending! (addr out) (addr pending))
    (delete pending)
    out))

(defn shared-int-index-with-merged-appended-indexes-across-append [base: Shared-Int-Index, base-datoms: []Datom, appended: []Datom, start-index: int, order: string, added: []int] -> Shared-Int-Index
  (let [out (shared-int-index-empty base.chunk-size)
        pending (make [dynamic]int 0 base.chunk-size)
        chunk-index 0
        chunk-offset 0
        added-index 0]
    (while (or (< chunk-index (count base.chunks))
               (< added-index (count added)))
      (cond
        (>= chunk-index (count base.chunks))
          (do
            (shared-int-index-append-slice! (addr out) (addr pending) (slice added added-index))
            (set! added-index (count added)))
        (>= added-index (count added))
          (if (= chunk-offset 0)
            (do
              (shared-int-index-flush-pending! (addr out) (addr pending))
              (retain-shared-int-chunk! base.chunks[chunk-index])
              (arr.push! out.chunks base.chunks[chunk-index])
              (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
              (set! chunk-index (+ chunk-index 1)))
            (do
              (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
              (set! chunk-offset (+ chunk-offset 1))
              (when (>= chunk-offset (count base.chunks[chunk-index].values))
                (set! chunk-index (+ chunk-index 1))
                (set! chunk-offset 0))))
        (and (= chunk-offset 0)
             (shared-int-chunk-before-or-at-added-across-append? base-datoms appended start-index order base.chunks[chunk-index] added[added-index]))
          (do
            (shared-int-index-flush-pending! (addr out) (addr pending))
            (retain-shared-int-chunk! base.chunks[chunk-index])
            (arr.push! out.chunks base.chunks[chunk-index])
            (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
            (set! chunk-index (+ chunk-index 1)))
        (appended-datom-index-less-than-base? base-datoms appended start-index order added[added-index] base.chunks[chunk-index].values[chunk-offset])
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) added[added-index])
            (set! added-index (+ added-index 1)))
        :else
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
            (set! chunk-offset (+ chunk-offset 1))
            (when (>= chunk-offset (count base.chunks[chunk-index].values))
              (set! chunk-index (+ chunk-index 1))
              (set! chunk-offset 0)))))
    (shared-int-index-flush-pending! (addr out) (addr pending))
    (delete pending)
    out))

(defn shared-int-index-with-merged-appended-datom-slice-direct [base: Shared-Int-Index, log: Shared-Datom-Log, appended: []Datom, start-index: int, order: string] -> Shared-Int-Index
  (let [out (shared-int-index-empty base.chunk-size)
        pending (make [dynamic]int 0 base.chunk-size)
        added (sorted-appended-datom-slice-indexes appended start-index order) :defer
        chunk-index 0
        chunk-offset 0
        added-index 0]
    (while (or (< chunk-index (count base.chunks))
               (< added-index (count added)))
      (cond
        (>= chunk-index (count base.chunks))
          (do
            (shared-int-index-append-slice! (addr out) (addr pending) (slice added added-index))
            (set! added-index (count added)))
        (>= added-index (count added))
          (if (= chunk-offset 0)
            (do
              (shared-int-index-flush-pending! (addr out) (addr pending))
              (retain-shared-int-chunk! base.chunks[chunk-index])
              (arr.push! out.chunks base.chunks[chunk-index])
              (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
              (set! chunk-index (+ chunk-index 1)))
            (do
              (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
              (set! chunk-offset (+ chunk-offset 1))
              (when (>= chunk-offset (count base.chunks[chunk-index].values))
                (set! chunk-index (+ chunk-index 1))
                (set! chunk-offset 0))))
        (and (= chunk-offset 0)
             (shared-int-chunk-before-or-at-added-direct? log appended start-index order base.chunks[chunk-index] added[added-index]))
          (do
            (shared-int-index-flush-pending! (addr out) (addr pending))
            (retain-shared-int-chunk! base.chunks[chunk-index])
            (arr.push! out.chunks base.chunks[chunk-index])
            (set! out.count (+ out.count (count base.chunks[chunk-index].values)))
            (set! chunk-index (+ chunk-index 1)))
        (shared-datom-index-less? log appended start-index order added[added-index] base.chunks[chunk-index].values[chunk-offset])
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) added[added-index])
            (set! added-index (+ added-index 1)))
        :else
          (do
            (shared-int-index-push-merged-value! (addr out) (addr pending) base.chunks[chunk-index].values[chunk-offset])
            (set! chunk-offset (+ chunk-offset 1))
            (when (>= chunk-offset (count base.chunks[chunk-index].values))
              (set! chunk-index (+ chunk-index 1))
              (set! chunk-offset 0)))))
    (shared-int-index-flush-pending! (addr out) (addr pending))
    (delete pending)
    out))

(defn shared-int-index-prefix-matches-slice? [base: Shared-Int-Index, values: []int] -> bool
  (when (> base.count (count values))
    (return false))
  (let [index 0]
    (while (< index base.count)
      (let [[base-value ok] (shared-int-index-at base index)]
        (when (or (not ok)
                  (not (= base-value values[index])))
          (return false)))
      (set! index (+ index 1))))
  true)

(defn shared-int-index-from-base-prefix-or-slice [base: Shared-Int-Index, values: []int] -> Shared-Int-Index
  (if (shared-int-index-prefix-matches-slice? base values)
    (shared-int-index-with-appended-slice base (slice values base.count))
    (shared-int-index-from-slice values base.chunk-size)))

(defn shared-db-int-indexes-from-db [db: DB, chunk-size: int] -> Shared-DB-Int-Indexes
  (Shared-DB-Int-Indexes {current: (shared-int-index-from-slice (slice db.current 0) chunk-size)
                          eavt: (shared-int-index-from-slice (slice db.eavt 0) chunk-size)
                          aevt: (shared-int-index-from-slice (slice db.aevt 0) chunk-size)
                          avet: (shared-int-index-from-slice (slice db.avet 0) chunk-size)
                          vaet: (shared-int-index-from-slice (slice db.vaet 0) chunk-size)}))

(defn shared-db-int-indexes-with-appended-datom-slice-mode [base: Shared-DB-Int-Indexes, after: DB, appended: []Datom, start-index: int, append-only: bool, new-entities-after-existing: bool] -> Shared-DB-Int-Indexes
  (Shared-DB-Int-Indexes {current: (if append-only
                                     (shared-int-index-with-appended-range base.current start-index (+ start-index (count appended)))
                                     (shared-int-index-from-base-prefix-or-slice base.current (slice after.current 0)))
                          eavt: (cond
                                  new-entities-after-existing
                                    (shared-int-index-with-appended-sorted-datom-slice base.eavt appended start-index "eavt")
                                  append-only
                                    (shared-int-index-with-merged-appended-datoms base.eavt (slice after.datoms 0) start-index "eavt")
                                  :else
                                    (shared-int-index-from-base-prefix-or-slice base.eavt (slice after.eavt 0)))
                          aevt: (if append-only
                                  (shared-int-index-with-merged-appended-datoms base.aevt (slice after.datoms 0) start-index "aevt")
                                  (shared-int-index-from-base-prefix-or-slice base.aevt (slice after.aevt 0)))
                          avet: (if append-only
                                  (shared-int-index-with-merged-appended-datoms base.avet (slice after.datoms 0) start-index "avet")
                                  (shared-int-index-from-base-prefix-or-slice base.avet (slice after.avet 0)))
                          vaet: (if append-only
                                  (shared-int-index-with-merged-appended-datoms base.vaet (slice after.datoms 0) start-index "vaet")
                                  (shared-int-index-from-base-prefix-or-slice base.vaet (slice after.vaet 0)))}))

(defn shared-db-int-indexes-with-append-publish-plan [base: Shared-DB-Int-Indexes, before: DB, appended: []Datom, plan: Tx-Publish-Plan] -> Shared-DB-Int-Indexes
  (Shared-DB-Int-Indexes {current: (shared-int-index-with-appended-range base.current plan.start-index (+ plan.start-index plan.appended-count))
                          eavt: (if plan.new-entities-after-existing
                                  (shared-int-index-with-appended-slice base.eavt (slice plan.eavt 0))
                                  (shared-int-index-with-merged-appended-indexes-across-append base.eavt (slice before.datoms 0) appended plan.start-index "eavt" (slice plan.eavt 0)))
                          aevt: (shared-int-index-with-merged-appended-indexes-across-append base.aevt (slice before.datoms 0) appended plan.start-index "aevt" (slice plan.aevt 0))
                          avet: (shared-int-index-with-merged-appended-indexes-across-append base.avet (slice before.datoms 0) appended plan.start-index "avet" (slice plan.avet 0))
                          vaet: (shared-int-index-with-merged-appended-indexes-across-append base.vaet (slice before.datoms 0) appended plan.start-index "vaet" (slice plan.vaet 0))}))

(defn shared-db-int-indexes-with-appended-datom-slice-direct [base: Shared-DB-Int-Indexes, log: Shared-Datom-Log, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> Shared-DB-Int-Indexes
  (Shared-DB-Int-Indexes {current: (shared-int-index-with-appended-range base.current start-index (+ start-index (count appended)))
                          eavt: (if new-entities-after-existing
                                  (shared-int-index-with-appended-sorted-datom-slice base.eavt appended start-index "eavt")
                                  (shared-int-index-with-merged-appended-datom-slice-direct base.eavt log appended start-index "eavt"))
                          aevt: (shared-int-index-with-merged-appended-datom-slice-direct base.aevt log appended start-index "aevt")
                          avet: (shared-int-index-with-merged-appended-datom-slice-direct base.avet log appended start-index "avet")
                          vaet: (shared-int-index-with-merged-appended-datom-slice-direct base.vaet log appended start-index "vaet")}))

(defn retain-shared-db-int-indexes [indexes: Shared-DB-Int-Indexes] -> Shared-DB-Int-Indexes
  (Shared-DB-Int-Indexes {current: (retain-shared-int-index indexes.current)
                          eavt: (retain-shared-int-index indexes.eavt)
                          aevt: (retain-shared-int-index indexes.aevt)
                          avet: (retain-shared-int-index indexes.avet)
                          vaet: (retain-shared-int-index indexes.vaet)}))

(defn delete-shared-db-int-indexes [indexes: Shared-DB-Int-Indexes]
  (delete-shared-int-index indexes.current)
  (delete-shared-int-index indexes.eavt)
  (delete-shared-int-index indexes.aevt)
  (delete-shared-int-index indexes.avet)
  (delete-shared-int-index indexes.vaet))

(defn shared-datom-chunk [values: []Datom] -> Shared-Datom-Chunk
  (let [refs (make [dynamic]int 0 1)
        owned (make [dynamic]Datom 0 (count values))]
    (arr.push! refs 1)
    (for [datom values]
      (arr.push! owned (datom-owned datom)))
    (Shared-Datom-Chunk {values: owned refs: refs})))

(defn retain-shared-datom-chunk! [chunk: Shared-Datom-Chunk]
  (set! chunk.refs[0] (+ chunk.refs[0] 1)))

(defn release-shared-datom-chunk! [chunk: Shared-Datom-Chunk]
  (set! chunk.refs[0] (- chunk.refs[0] 1))
  (when (= chunk.refs[0] 0)
    (for [datom chunk.values]
      (delete-owned-datom datom))
    (delete chunk.values)
    (delete chunk.refs)))

(defn shared-datom-log-empty [chunk-size: int] -> Shared-Datom-Log
  (Shared-Datom-Log {chunks: (make [dynamic]Shared-Datom-Chunk)
                     chunk-starts: (make [dynamic]int)
                     count: 0
                     chunk-size: (max 1 chunk-size)}))

(defn shared-datom-log-from-slice [values: []Datom, chunk-size: int] -> Shared-Datom-Log
  (let [out (shared-datom-log-empty chunk-size)
        size out.chunk-size
        start 0]
    (while (< start (count values))
      (let [end (min (+ start size) (count values))
            chunk (shared-datom-chunk (slice values start end))]
        (arr.push! out.chunk-starts start)
        (arr.push! out.chunks chunk)
        (set! start end)))
    (set! out.count (count values))
    out))

(defn retain-shared-datom-log [log: Shared-Datom-Log] -> Shared-Datom-Log
  (let [chunks (make [dynamic]Shared-Datom-Chunk 0 (count log.chunks))
        chunk-starts (arr.into [dynamic]int (slice log.chunk-starts 0))]
    (for [chunk log.chunks]
      (retain-shared-datom-chunk! chunk)
      (arr.push! chunks chunk))
    (Shared-Datom-Log {chunks: chunks
                       chunk-starts: chunk-starts
                       count: log.count
                       chunk-size: log.chunk-size})))

(defn delete-shared-datom-log [log: Shared-Datom-Log]
  (for [chunk log.chunks]
    (release-shared-datom-chunk! chunk))
  (delete log.chunks)
  (delete log.chunk-starts))

(defn shared-datom-log-ref-count-at [log: Shared-Datom-Log, chunk-index: int] -> [refs: int, ok: bool]
  (when (or (< chunk-index 0)
            (>= chunk-index (count log.chunks)))
    (return 0 false))
  (return log.chunks[chunk-index].refs[0] true))

(defn shared-datom-log-with-appended-slice [base: Shared-Datom-Log, values: []Datom] -> Shared-Datom-Log
  (let [out (retain-shared-datom-log base)
        base-count out.count
        start 0]
    (while (< start (count values))
      (let [end (min (+ start out.chunk-size) (count values))
            chunk (shared-datom-chunk (slice values start end))]
        (arr.push! out.chunk-starts (+ base-count start))
        (arr.push! out.chunks chunk)
        (set! start end)))
    (set! out.count (+ out.count (count values)))
    out))

(defn shared-datom-log-chunk-index-at [log: Shared-Datom-Log, position: int] -> [chunk-index: int, ok: bool]
  (when (or (< position 0)
            (>= position log.count)
            (= (count log.chunk-starts) 0))
    (return 0 false))
  (let [low 0
        high (count log.chunk-starts)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)]
        (if (<= log.chunk-starts[mid] position)
          (set! low (+ mid 1))
          (set! high mid))))
    (let [found-index (- low 1)]
      (when (or (< found-index 0)
                (>= found-index (count log.chunks)))
        (return 0 false))
      (return found-index true))))

(defn shared-datom-log-at [log: Shared-Datom-Log, position: int] -> [datom: Datom, ok: bool]
  (when (or (< position 0)
            (>= position log.count))
    (return (Datom {}) false))
  (let [[chunk-index chunk-ok] (shared-datom-log-chunk-index-at log position)]
    (when (not chunk-ok)
      (return (Datom {}) false))
    (let [offset (- position log.chunk-starts[chunk-index])
          chunk log.chunks[chunk-index]]
      (when (or (< offset 0)
                (>= offset (count chunk.values)))
        (return (Datom {}) false))
      (return (datom-owned chunk.values[offset]) true))))

(defn shared-db-snapshot-from-db [db: DB, chunk-size: int] -> Shared-DB-Snapshot
  (Shared-DB-Snapshot {datoms: (shared-datom-log-from-slice (slice db.datoms 0) chunk-size)
                       indexes: (shared-db-int-indexes-from-db db chunk-size)}))

(defn shared-db-snapshot-with-appended-datoms-mode [base: Shared-DB-Snapshot, after: DB, appended: []Datom, start-index: int, append-only: bool, new-entities-after-existing: bool] -> Shared-DB-Snapshot
  (Shared-DB-Snapshot {datoms: (shared-datom-log-with-appended-slice base.datoms appended)
                       indexes: (shared-db-int-indexes-with-appended-datom-slice-mode base.indexes after appended start-index append-only new-entities-after-existing)}))

(defn shared-db-snapshot-with-appended-datoms-direct [base: Shared-DB-Snapshot, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> Shared-DB-Snapshot
  (Shared-DB-Snapshot {datoms: (shared-datom-log-with-appended-slice base.datoms appended)
                       indexes: (shared-db-int-indexes-with-appended-datom-slice-direct base.indexes base.datoms appended start-index new-entities-after-existing)}))

(defn shared-db-snapshot-with-append-tx-report [base: Shared-DB-Snapshot, report: Tx-Report] -> Shared-DB-Snapshot
  (let [indexes (shared-db-int-indexes-with-append-publish-plan base.indexes report.db-before (slice report.tx-data 0) report.publish-plan)]
    (Shared-DB-Snapshot {datoms: (shared-datom-log-with-appended-slice base.datoms (slice report.tx-data 0))
                         indexes: indexes})))

(defn shared-db-snapshot-with-append-apply-result [base: Shared-DB-Snapshot, before: DB, applied: Tx-Apply-Result] -> Shared-DB-Snapshot
  (let [indexes (shared-db-int-indexes-with-append-publish-plan base.indexes before (slice applied.tx-data 0) applied.publish-plan)]
    (Shared-DB-Snapshot {datoms: (shared-datom-log-with-appended-slice base.datoms (slice applied.tx-data 0))
                         indexes: indexes})))

(defn shared-db-snapshot-with-tx-report [base: Shared-DB-Snapshot, after: DB, report: Tx-Report] -> Shared-DB-Snapshot
  (if report.append-only
    (shared-db-snapshot-with-append-tx-report base report)
    (shared-db-snapshot-with-appended-datoms-mode base
                                                  after
                                                  (slice report.tx-data 0)
                                                  report.datom-start-index
                                                  false
                                                  false)))

(defn shared-db-snapshot-with-tx-report-direct [base: Shared-DB-Snapshot, after: DB, report: Tx-Report] -> Shared-DB-Snapshot
  (if report.append-only
    (shared-db-snapshot-with-appended-datoms-direct base
                                                    (slice report.tx-data 0)
                                                    report.datom-start-index
                                                    report.new-entities-after-existing)
    (shared-db-snapshot-with-tx-report base after report)))

(defn shared-write-state-clone-schema-unique-identity [db: DB] -> set[string]
  (let [out (set.empty string)]
    (for [attr db.schema-unique]
      (when (schema-unique-identity? db attr)
        (set.add! out attr)))
    out))

(defn retain-shared-db-snapshot [snapshot: Shared-DB-Snapshot] -> Shared-DB-Snapshot
  (Shared-DB-Snapshot {datoms: (retain-shared-datom-log snapshot.datoms)
                       indexes: (retain-shared-db-int-indexes snapshot.indexes)}))

(defn delete-shared-db-snapshot [snapshot: Shared-DB-Snapshot]
  (delete-shared-datom-log snapshot.datoms)
  (delete-shared-db-int-indexes snapshot.indexes))

(defn create-shared-conn [chunk-size: int] -> Shared-Conn
  (let [conn (create-conn)
        size (max 1 chunk-size)]
    (Shared-Conn {write: (Shared-Write-State {conn: conn
                                              has-tuple-schema: (db-has-tuple-schema? conn.db)
                                              schema-ref: (clone-schema-ref conn.db.schema-ref)
                                              schema-unique: (clone-schema-unique conn.db.schema-unique)
                                              schema-unique-identity: (shared-write-state-clone-schema-unique-identity conn.db)
                                              next-entity-id: (next-entity-id (slice conn.db.datoms 0))
                                              source-resolves: 0
                                              resident-fallbacks: 0})
                  snapshot: (shared-db-snapshot-from-db conn.db size)
                  chunk-size: size})))

(defn delete-shared-conn [conn: Shared-Conn]
  (delete-shared-db-snapshot conn.snapshot)
  (delete conn.write.schema-ref)
  (delete conn.write.schema-unique)
  (delete conn.write.schema-unique-identity)
  (delete conn.write.conn.listeners)
  (delete-owned-db conn.write.conn.db))

(defn delete-shared-tx-report-shallow [report: Shared-Tx-Report]
  (delete-shared-db-snapshot report.db-before)
  (delete-shared-db-snapshot report.db-after)
  (delete report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids))

(defn shared-write-state-before-db [state: ^Shared-Write-State] -> DB
  state^.conn.db)

(defn shared-write-state-next-tx [state: ^Shared-Write-State] -> u64
  state^.conn.next-tx)

(defn shared-write-state-advance! [state: ^Shared-Write-State, after: DB]
  (set! state^.conn.db after)
  (set! state^.conn.next-tx (+ state^.conn.next-tx 1))
  (shared-write-state-refresh-from-current! state))

(defn shared-write-state-refresh-from-current! [state: ^Shared-Write-State]
  (let [after state^.conn.db]
    (delete state^.schema-ref)
    (set! state^.schema-ref (clone-schema-ref after.schema-ref))
    (delete state^.schema-unique)
    (set! state^.schema-unique (clone-schema-unique after.schema-unique))
    (delete state^.schema-unique-identity)
    (set! state^.schema-unique-identity (shared-write-state-clone-schema-unique-identity after))
    (set! state^.has-tuple-schema (db-has-tuple-schema? after))
    (set! state^.next-entity-id (next-entity-id (slice after.datoms 0)))))

(defn shared-write-state-notify! [state: ^Shared-Write-State, report: Tx-Report]
  (notify-listeners! (addr state^.conn) report))

(defn shared-write-state-note-source-resolve! [state: ^Shared-Write-State]
  (set! state^.source-resolves (+ state^.source-resolves 1)))

(defn shared-write-state-note-resident-fallback! [state: ^Shared-Write-State]
  (set! state^.resident-fallbacks (+ state^.resident-fallbacks 1)))

(defn shared-write-state-schema-ref-target? [state: ^Shared-Write-State, attr: string] -> bool
  (if (reverse-attr? attr)
    (let [forward (forward-attr-for-reverse attr)]
      (defer (delete forward))
      (set.contains? state^.schema-ref forward))
    (set.contains? state^.schema-ref attr)))

(defn shared-write-state-schema-unique? [state: ^Shared-Write-State, attr: string] -> bool
  (set.contains? state^.schema-unique attr))

(defn shared-write-state-schema-unique-identity? [state: ^Shared-Write-State, attr: string] -> bool
  (set.contains? state^.schema-unique-identity attr))

(defn shared-write-state-ref-tempid-value? [state: ^Shared-Write-State, attr: string, value: Value] -> bool
  (when (not (shared-write-state-schema-ref-target? state attr))
    (return false))
  (or (= value.kind .String)
      (and (= value.kind .Int)
           (< value.int-value 0))))

(defn shared-write-state-retract-like-op? [op: string] -> bool
  (or (= op ":db/retract")
      (= op ":db/retractAttr")
      (= op ":db/retractEntity")))

(defn shared-write-state-direct-tx-data-item? [state: ^Shared-Write-State, data: Tx-Data] -> bool
  (when (not (or (= data.op ":db/add")
                 (= data.op ":db/retract")))
    (return false))
  (when (or data.has-tempid
            data.has-lookup-ref
            data.has-ident
            data.has-expected-lookup-ref
            data.has-value-tempid
            data.has-value-lookup-ref
            data.has-nested-map
            data.from-map-collection
            (tx-data-modifies-validation-schema? data)
            (current-tx-value? data.v)
            (reverse-attr? data.a))
    (return false))
  true)

(defn shared-write-state-direct-tx-data? [state: ^Shared-Write-State, tx-data: []Tx-Data] -> bool
  (when state^.has-tuple-schema
    (return false))
  (for [data tx-data]
    (when (not (shared-write-state-direct-tx-data-item? state data))
      (return false)))
  true)

(defn shared-write-state-resolve-direct-tx-data-value [state: ^Shared-Write-State, source: DB-Read-Source, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (if (shared-write-state-schema-ref-target? state data.a)
    (db-read-source-resolve-ref-component-value source data.v)
    (return data.v true "")))

(defn shared-write-state-resolve-direct-tx-data-for-tx [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data] -> Resolved-Tx
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)]
    (for [data tx-data]
      (let [[shape-ok shape-error] (validate-tx-data-item data)]
        (when (not shape-ok)
          (return (Resolved-Tx {ok: false
                                error: shape-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids}))))
      (let [[value value-ok value-error] (shared-write-state-resolve-direct-tx-data-value state source data)]
        (when (not value-ok)
          (return (Resolved-Tx {ok: false
                                error: value-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (if (= data.op ":db/retract")
          (arr.push! resolved-ops (tx-retract data.e data.a value))
          (arr.push! resolved-ops (tx-add data.e data.a value)))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn shared-write-state-source-simple-tx-data-item? [state: ^Shared-Write-State, data: Tx-Data] -> bool
  (when (not (or (= data.op ":db/add")
                 (= data.op ":db/retract")
                 (= data.op ":db/retractAttr")
                 (= data.op ":db/retractEntity")
                 (= data.op ":db.fn/cas")
                 (= data.op ":db/cas")))
    (return false))
  (when (or data.has-nested-map
            data.from-map-collection
            (tx-data-modifies-validation-schema? data)
            (reverse-attr? data.a))
    (return false))
  (when (and data.has-expected-lookup-ref
             (not (shared-write-state-source-cas-op? data)))
    (return false))
  (when (and data.has-tempid
             (not (= data.op ":db/add")))
    (return false))
  (when (and data.has-tempid
             (current-tx-tempid? data.tempid))
    (return false))
  (when (and data.has-tempid
             (shared-write-state-schema-unique-identity? state data.a)
             (or data.has-value-tempid
                 (current-tx-value? data.v)))
    (return false))
  (when (and data.has-value-tempid
             (not (shared-write-state-schema-ref-target? state data.a)))
    (return false))
  (let [ref-target (shared-write-state-schema-ref-target? state data.a)]
    (when (and ref-target
               (= data.v.kind .String))
      (return false))
    (when (and ref-target
               (= data.v.kind .Int)
               (< data.v.int-value 0))
      (return false)))
  true)

(defn shared-write-state-source-cas-op? [data: Tx-Data] -> bool
  (or (= data.op ":db.fn/cas")
      (= data.op ":db/cas")))

(defn shared-write-state-source-simple-schema-tx-data-item? [data: Tx-Data] -> bool
  (when (not (or (= data.op ":db/add")
                 (= data.op ":db/retract")))
    (return false))
  (when (not (tx-data-modifies-validation-schema? data))
    (return false))
  (when (or data.has-tempid
            data.has-lookup-ref
            data.has-ident
            data.has-expected-lookup-ref
            data.has-value-tempid
            data.has-value-lookup-ref
            data.has-nested-map
            data.from-map-collection
            (reverse-attr? data.a))
    (return false))
  true)

(defn shared-write-state-source-simple-schema-tx-data? [tx-data: []Tx-Data] -> bool
  (when (= (count tx-data) 0)
    (return false))
  (for [data tx-data]
    (when (not (shared-write-state-source-simple-schema-tx-data-item? data))
      (return false)))
  true)

(defn shared-write-state-declared-schema-attrs [tx-data: []Tx-Data] -> [dynamic]string
  (let [out (make [dynamic]string)]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.a ":db/ident")
                 (= data.v.kind .Keyword))
        (arr.push! out (string-owned data.v.text))))
    out))

(defn shared-write-state-attr-declared-in-tx? [declared: []string, attr: string] -> bool
  (for [item declared]
    (when (= item attr)
      (return true)))
  false)

(defn shared-write-state-declared-attr-has-schema-value? [tx-data: []Tx-Data, attr: string, schema-attr: string, value: string] -> bool
  (let [schema-e: u64 0
        found-entity false]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.a ":db/ident")
                 (= data.v.kind .Keyword)
                 (= data.v.text attr))
        (set! schema-e data.e)
        (set! found-entity true)))
    (when (not found-entity)
      (return false))
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.e schema-e)
                 (= data.a schema-attr)
                 (= data.v.kind .Keyword)
                 (= data.v.text value))
        (return true))))
  false)

(defn shared-write-state-declared-attr-has-schema-attr? [tx-data: []Tx-Data, attr: string, schema-attr: string] -> bool
  (let [schema-e: u64 0
        found-entity false]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.a ":db/ident")
                 (= data.v.kind .Keyword)
                 (= data.v.text attr))
        (set! schema-e data.e)
        (set! found-entity true)))
    (when (not found-entity)
      (return false))
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.e schema-e)
                 (= data.a schema-attr))
        (return true))))
  false)

(defn shared-write-state-declared-attr-ref? [tx-data: []Tx-Data, attr: string] -> bool
  (shared-write-state-declared-attr-has-schema-value? tx-data attr ":db/valueType" ":db.type/ref"))

(defn shared-write-state-schema-ref-target-for-tx? [state: ^Shared-Write-State, tx-data: []Tx-Data, attr: string] -> bool
  (if (reverse-attr? attr)
    (let [forward (forward-attr-for-reverse attr)]
      (defer (delete forward))
      (or (set.contains? state^.schema-ref forward)
          (shared-write-state-declared-attr-ref? tx-data forward)))
    (or (set.contains? state^.schema-ref attr)
        (shared-write-state-declared-attr-ref? tx-data attr))))

(defn shared-write-state-ref-tempid-value-for-tx? [state: ^Shared-Write-State, tx-data: []Tx-Data, attr: string, value: Value] -> bool
  (when (not (shared-write-state-schema-ref-target-for-tx? state tx-data attr))
    (return false))
  (or (= value.kind .String)
      (and (= value.kind .Int)
           (< value.int-value 0))))

(defn shared-write-state-declared-attr-source-simple? [tx-data: []Tx-Data, attr: string] -> bool
  (when (shared-write-state-declared-attr-has-schema-value? tx-data attr ":db/valueType" ":db.type/tuple")
    (return false))
  (when (shared-write-state-declared-attr-has-schema-attr? tx-data attr ":db/tupleAttrs")
    (return false))
  (when (shared-write-state-declared-attr-has-schema-attr? tx-data attr ":db/unique")
    (return false))
  true)

(defn shared-write-state-declared-attr-schema-entity [tx-data: []Tx-Data, attr: string] -> [entity: u64, ok: bool]
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (= data.a ":db/ident")
               (= data.v.kind .Keyword)
               (= data.v.text attr))
      (return data.e true)))
  (return 0 false))

(defn shared-write-state-schema-fact-before-index? [tx-data: []Tx-Data, attr: string, schema-attr: string, data-index: int] -> bool
  (let [[schema-e schema-ok] (shared-write-state-declared-attr-schema-entity tx-data attr)]
    (when (not schema-ok)
      (return false))
    (for [data index tx-data]
      (when (>= index data-index)
        (return false))
      (when (and (= data.op ":db/add")
                 (= data.e schema-e)
                 (= data.a schema-attr))
        (return true))))
  false)

(defn shared-write-state-declared-unique-attr-source-simple-use? [tx-data: []Tx-Data, data: Tx-Data, data-index: int] -> bool
  (and (shared-write-state-declared-attr-has-schema-attr? tx-data data.a ":db/unique")
       (shared-write-state-schema-fact-before-index? tx-data data.a ":db/unique" data-index)
       (not data.has-lookup-ref)
       (not data.has-value-tempid)
       (not data.has-value-lookup-ref)
       (not data.has-ident)
       (not data.has-expected-lookup-ref)))

(defn shared-write-state-data-depends-on-declared-schema? [declared: []string, data: Tx-Data] -> bool
  (or (shared-write-state-attr-declared-in-tx? declared data.a)
      (and data.has-lookup-ref
           (shared-write-state-attr-declared-in-tx? declared data.lookup-attr))
      (and data.has-value-lookup-ref
           (shared-write-state-attr-declared-in-tx? declared data.value-lookup-attr))
      (and data.has-ident
           (shared-write-state-attr-declared-in-tx? declared data.ident))))

(defn shared-write-state-source-simple-mixed-schema-tx-data? [state: ^Shared-Write-State, tx-data: []Tx-Data] -> bool
  (when (= (count tx-data) 0)
    (return false))
  (when (shared-write-state-source-simple-has-intermediate-lookup-target? state tx-data)
    (return false))
  (when (shared-write-state-source-simple-has-intermediate-ident-target? tx-data)
    (return false))
  (when (not (shared-write-state-source-simple-value-tempids-have-entities? tx-data))
    (return false))
  (when (not (shared-write-state-source-simple-ref-tempids-have-entities? state tx-data))
    (return false))
  (let [declared (shared-write-state-declared-schema-attrs tx-data)
        saw-schema false
        saw-data false]
    (defer
      (do
        (for [attr declared]
          (delete attr))
        (delete declared)))
    (for [data data-index tx-data]
      (if (tx-data-modifies-validation-schema? data)
        (do
          (when (not (shared-write-state-source-simple-schema-tx-data-item? data))
            (return false))
          (set! saw-schema true))
        (do
          (when (and (shared-write-state-data-depends-on-declared-schema? (slice declared 0) data)
                     (not (or
                            (and (shared-write-state-attr-declared-in-tx? (slice declared 0) data.a)
                                 (or (shared-write-state-declared-attr-source-simple? tx-data data.a)
                                     (shared-write-state-declared-unique-attr-source-simple-use? tx-data data data-index))
                                 (or (not data.has-lookup-ref)
                                     (shared-write-state-same-tx-lookup-ref-source-simple? state tx-data data.lookup-attr data.lookup-value data-index))
                                 (or (not data.has-value-lookup-ref)
                                     (not (shared-write-state-attr-declared-in-tx? (slice declared 0) data.value-lookup-attr))
                                     (shared-write-state-same-tx-lookup-ref-source-simple? state tx-data data.value-lookup-attr data.value-lookup-value data-index))
                                 (not data.has-ident)
                                 (not data.has-expected-lookup-ref))
                            (and data.has-lookup-ref
                                 (shared-write-state-same-tx-lookup-ref-source-simple? state tx-data data.lookup-attr data.lookup-value data-index)
                                 (not (shared-write-state-attr-declared-in-tx? (slice declared 0) data.a))
                                 (not data.has-value-lookup-ref)
                                 (not data.has-ident)
                                 (not data.has-expected-lookup-ref)))))
            (return false))
          (when (not (shared-write-state-source-simple-tx-data-item? state data))
            (return false))
          (set! saw-data true))))
    (and saw-schema saw-data)))

(defn shared-write-state-push-owned-retract-op-once! [ops: ^[dynamic]Tx-Op, entity: u64, attr: string, value: Value]
  (let [op (tx-retract entity (string-owned attr) (value-owned value))
        before-count (count ops^)]
    (set! op.owned-attr true)
    (set! op.owned-value true)
    (push-tx-op-once! ops op)
    (when (= (count ops^) before-count)
      (delete op.a)
      (delete-owned-value op.v))))

(defn shared-write-state-append-incoming-retract-ops! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, entity: u64] -> [ok: bool, error: string]
  (let [ref-value (value-entity entity)
        values ([]Value [ref-value])
        view (db-read-source-index-view source .VAET)
        [low low-ok low-error] (db-read-source-lower-bound-values source view values)]
    (when (not low-ok)
      (return false low-error))
    (let [[high high-ok high-error] (db-read-source-upper-bound-values source view values)]
      (when (not high-ok)
        (return false high-error))
      (for [pos (arr.range low high)]
        (let [entry (db-index-view-at view pos)
              [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
          (when (not current-ok)
            (return false current-error))
          (when current
            (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
              (when (not datom-ok)
                (return false datom-error))
              (shared-write-state-push-owned-retract-op-once! ops datom.e datom.a datom.v)
              (delete-owned-datom datom)))))))
  (return true ""))


(defn shared-write-state-append-retract-entity-ops-seen! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, entity: u64, seen: ^set[u64]] -> [ok: bool, error: string]
  (when (set.contains? seen^ entity)
    (return true ""))
  (set.add! seen^ entity)
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity source entity)]
    (when (not datoms-ok)
      (return false datoms-error))
    (for [datom datoms]
      (when (= datom.v.kind .Entity)
        (let [[component component-ok component-error] (db-read-source-schema-component? source datom.a)]
          (when (not component-ok)
            (delete-owned-datoms datoms)
            (return false component-error))
          (when component
            (let [[child-ok child-error] (shared-write-state-append-retract-entity-ops-seen! ops source datom.v.entity seen)]
              (when (not child-ok)
                (delete-owned-datoms datoms)
                (return false child-error))))))
      (shared-write-state-push-owned-retract-op-once! ops datom.e datom.a datom.v))
    (delete-owned-datoms datoms))
  (let [[incoming-ok incoming-error] (shared-write-state-append-incoming-retract-ops! ops source entity)]
    (when (not incoming-ok)
      (return false incoming-error)))
  (return true ""))

(defn shared-write-state-append-retract-entity-ops! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, entity: u64] -> [ok: bool, error: string]
  (let [seen (set.empty u64)]
    (defer (delete seen))
    (shared-write-state-append-retract-entity-ops-seen! ops source entity (addr seen))))

(defn shared-write-state-append-retract-attr-ops! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, entity: u64, attr: string] -> [ok: bool, error: string]
  (let [seen (set.empty u64)]
    (defer (delete seen))
    (set.add! seen entity)
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
      (when (not datoms-ok)
        (return false datoms-error))
      (for [datom datoms]
        (when (= datom.v.kind .Entity)
          (let [[component component-ok component-error] (db-read-source-schema-component? source attr)]
            (when (not component-ok)
              (delete-owned-datoms datoms)
              (return false component-error))
            (when component
              (let [[child-ok child-error] (shared-write-state-append-retract-entity-ops-seen! ops source datom.v.entity (addr seen))]
                (when (not child-ok)
                  (delete-owned-datoms datoms)
                  (return false child-error))))))
        (shared-write-state-push-owned-retract-op-once! ops entity attr datom.v))
      (delete-owned-datoms datoms))
  (return true "")))

(defn shared-write-state-tx-adds-attr? [tx-data: []Tx-Data, attr: string] -> bool
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (= data.a attr))
      (return true)))
  false)

(defn shared-write-state-tx-has-local-lookup-add? [tx-data: []Tx-Data, attr: string, value: Value] -> bool
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (not data.has-lookup-ref)
               (not data.has-ident)
               (= data.a attr)
               (value-equal? data.v value))
      (return true)))
  false)

(defn shared-write-state-same-tx-lookup-ref-source-simple? [state: ^Shared-Write-State, tx-data: []Tx-Data, attr: string, value: Value, data-index: int] -> bool
  (and (shared-write-state-tx-adds-attr? tx-data attr)
       (or (shared-write-state-schema-unique? state attr)
           (shared-write-state-schema-fact-before-index? tx-data attr ":db/unique" data-index))
       (shared-write-state-tx-has-local-lookup-add? tx-data attr value)))

(defn shared-write-state-source-simple-has-intermediate-lookup-target? [state: ^Shared-Write-State, tx-data: []Tx-Data] -> bool
  (for [data index tx-data]
    (when (and data.has-lookup-ref
               (shared-write-state-tx-adds-attr? tx-data data.lookup-attr)
               (not (shared-write-state-same-tx-lookup-ref-source-simple? state tx-data data.lookup-attr data.lookup-value index)))
      (return true))
    (when (and data.has-value-lookup-ref
               (shared-write-state-tx-adds-attr? tx-data data.value-lookup-attr)
               (not (shared-write-state-same-tx-lookup-ref-source-simple? state tx-data data.value-lookup-attr data.value-lookup-value index)))
      (return true)))
  false)

(defn shared-write-state-tx-adds-ident? [tx-data: []Tx-Data, ident: string] -> bool
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (= data.a ":db/ident")
               (= data.v.kind .Keyword)
               (= data.v.text ident))
      (return true)))
  false)

(defn shared-write-state-source-simple-has-intermediate-ident-target? [tx-data: []Tx-Data] -> bool
  (for [data tx-data]
    (when (and data.has-ident
               (shared-write-state-tx-adds-ident? tx-data data.ident))
      (return true)))
  false)

(defn shared-write-state-source-simple-tx-has-tempid? [tx-data: []Tx-Data, tempid: string] -> bool
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid))
      (return true)))
  false)

(defn shared-write-state-source-simple-value-tempids-have-entities? [tx-data: []Tx-Data] -> bool
  (for [data tx-data]
    (when (and data.has-value-tempid
               (not (current-tx-tempid? data.value-tempid))
               (not (shared-write-state-source-simple-tx-has-tempid? tx-data data.value-tempid)))
      (return false)))
  true)

(defn shared-write-state-source-simple-ref-tempids-have-entities? [state: ^Shared-Write-State, tx-data: []Tx-Data] -> bool
  (for [data tx-data]
    (when (and (shared-write-state-ref-tempid-value-for-tx? state tx-data data.a data.v)
               (not (current-tx-value? data.v)))
      (let [value-tempid (ref-tempid-value-text data.v)]
        (when (not (shared-write-state-source-simple-tx-has-tempid? tx-data value-tempid))
          (return false)))))
  true)

(defn shared-write-state-source-simple-next-entity-id [state: ^Shared-Write-State, tx-data: []Tx-Data] -> u64
  (let [next state^.next-entity-id]
    (for [data tx-data]
      (when (and (not data.has-tempid)
                 (not data.has-lookup-ref)
                 (not data.has-ident)
                 (>= data.e next))
        (set! next (+ data.e 1))))
    next))

(defn shared-write-state-source-simple-tx-data? [state: ^Shared-Write-State, tx-data: []Tx-Data] -> bool
  (when (shared-write-state-source-simple-has-intermediate-lookup-target? state tx-data)
    (return false))
  (when (shared-write-state-source-simple-has-intermediate-ident-target? tx-data)
    (return false))
  (when (not (shared-write-state-source-simple-value-tempids-have-entities? tx-data))
    (return false))
  (when (not (shared-write-state-source-simple-ref-tempids-have-entities? state tx-data))
    (return false))
  (for [data tx-data]
    (when (not (shared-write-state-source-simple-tx-data-item? state data))
      (return false)))
  true)

(defn shared-write-state-resolve-source-simple-tempid [tempid: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> u64
  (let [[existing existing-ok] (resolved-tempid-lookup tempid-index tempid)]
    (when existing-ok
      (return existing))
    (let [assigned next-e^]
      (set! next-e^ (+ next-e^ 1))
      (push-resolved-tempid! tempids tempid-index tempid assigned)
      assigned)))

(defn shared-write-state-source-simple-tempid-upsert-entity [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, tempid: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [e: u64, ok: bool, conflict: bool, error: string]
  (let [found: u64 0
        has-found false]
    (for [data tx-data]
      (when (and data.has-tempid
                 (= data.tempid tempid)
                 (= data.op ":db/add")
                 (shared-write-state-schema-unique-identity? state data.a))
        (let [[value value-ok value-error] (shared-write-state-resolve-direct-tx-data-value state source data)]
          (when (not value-ok)
            (return 0 false false value-error))
          (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source data.a value)]
            (when (not (= lookup-error ""))
              (return 0 false false lookup-error))
            (when entity-ok
              (when (and has-found
                         (not (= found entity)))
                (return found false true ""))
              (set! found entity)
              (set! has-found true))))))
    (let [[tuple-e tuple-ok tuple-conflict tuple-error] (shared-write-state-source-simple-tempid-tuple-upsert-entity state source tx-data tempid tempid-index tempids next-e)]
      (when tuple-conflict
        (return found false true ""))
      (when (not (= tuple-error ""))
        (return found false false tuple-error))
      (when tuple-ok
        (when (and has-found
                   (not (= found tuple-e)))
          (return found false true ""))
        (set! found tuple-e)
        (set! has-found true)))
    (return found has-found false "")))

(defn shared-write-state-source-simple-tempid-component-value [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, tempid: string, attr: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [value: Value, ok: bool, error: string]
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid)
               (= data.op ":db/add")
               (= data.a attr))
      (let [empty-ops ([]Tx-Op [])
            [value value-ok value-skip value-error] (shared-write-state-resolve-source-simple-value state source tx-data empty-ops data tempid-index tempids next-e)]
        (if value-skip
          (return (Value {}) false "")
          (return value value-ok value-error)))))
  (return (Value {}) false ""))

(defn shared-write-state-source-simple-tempid-tuple-upsert-entity [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, tempid: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [e: u64, ok: bool, conflict: bool, error: string]
  (let [found: u64 0
        has-found false
        seen (make [dynamic]string)]
    (defer (delete seen))
    (for [data tx-data]
      (when (not (and data.has-tempid
                      (= data.tempid tempid)
                      (= data.op ":db/add")))
        (continue))
      (let [[schemas schemas-ok schemas-error] (db-read-source-tuple-schemas-containing source data.a)]
        (when (not schemas-ok)
          (return found false false schemas-error))
        (for [schema schemas]
          (when (not (shared-write-state-schema-unique-identity? state schema.attr))
            (continue))
          (when (tuple-schema-already-seen? (slice seen 0) schema.attr)
            (continue))
          (arr.push! seen schema.attr)
          (let [items (make [dynamic]Value 0 (count schema.attrs))
                complete true]
            (for [component schema.attrs]
              (let [[value value-ok value-error] (shared-write-state-source-simple-tempid-component-value state source tx-data tempid component tempid-index tempids next-e)]
                (when (not (= value-error ""))
                  (shared-write-state-delete-source-tuple-schemas schemas)
                  (delete items)
                  (return found false false value-error))
                (if value-ok
                  (arr.push! items value)
                  (set! complete false))))
            (when complete
              (let [tuple-value (value-vector (slice items 0))
                    [entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source schema.attr tuple-value)]
                (when (not (= lookup-error ""))
                  (shared-write-state-delete-source-tuple-schemas schemas)
                  (delete items)
                  (return found false false lookup-error))
                (when entity-ok
                  (when (and has-found
                             (not (= found entity)))
                    (shared-write-state-delete-source-tuple-schemas schemas)
                    (delete items)
                    (return found false true ""))
                  (set! found entity)
                  (set! has-found true))))
            (delete items)))
        (shared-write-state-delete-source-tuple-schemas schemas)))
    (return found has-found false "")))

(defn shared-write-state-resolve-source-simple-tempid-with-upsert [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, tempid: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [entity: u64, ok: bool, error: string]
  (let [[existing existing-ok] (resolved-tempid-lookup tempid-index tempid)]
    (when existing-ok
      (return existing true "")))
  (when (not (shared-write-state-source-simple-tx-has-tempid? tx-data tempid))
    (return 0 false "tempid used only as value"))
  (let [[upsert-e upsert-ok upsert-conflict upsert-error] (shared-write-state-source-simple-tempid-upsert-entity state source tx-data tempid tempid-index tempids next-e)]
    (when upsert-conflict
      (return 0 false "conflicting upsert"))
    (when (not (= upsert-error ""))
      (return 0 false upsert-error))
    (if upsert-ok
      (do
        (push-resolved-tempid! tempids tempid-index tempid upsert-e)
        (return upsert-e true ""))
      (let [assigned next-e^]
        (set! next-e^ (+ next-e^ 1))
        (push-resolved-tempid! tempids tempid-index tempid assigned)
        (return assigned true "")))))

(defn shared-write-state-prepare-source-simple-tempids! [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [ok: bool, error: string]
  (for [data tx-data]
    (when data.has-tempid
      (let [[_ existing-ok] (resolved-tempid-lookup tempid-index data.tempid)]
        (when (not existing-ok)
          (let [[upsert-e upsert-ok upsert-conflict upsert-error] (shared-write-state-source-simple-tempid-upsert-entity state source tx-data data.tempid tempid-index tempids next-e)]
            (when upsert-conflict
              (return false "conflicting upsert"))
            (when (not (= upsert-error ""))
              (return false upsert-error))
            (if upsert-ok
              (push-resolved-tempid! tempids tempid-index data.tempid upsert-e)
              (let [assigned next-e^]
                (set! next-e^ (+ next-e^ 1))
                (push-resolved-tempid! tempids tempid-index data.tempid assigned))))))))
  (return true ""))

(defn shared-write-state-latest-op-value [ops: []Tx-Op, entity: u64, attr: string] -> [value: Value, found: bool, retracted: bool]
  (let [index (- (count ops) 1)]
    (while (>= index 0)
      (let [op ops[index]]
        (when (and (not op.derived)
                   (= op.e entity)
                   (= op.a attr))
          (if (= op.kind .Add)
            (return (value-owned op.v) true false)
            (return (Value {}) true true))))
      (set! index (- index 1))))
  (return (Value {}) false false))

(defn shared-write-state-source-tuple-value-for-entity [source: DB-Read-Source, ops: []Tx-Op, entity: u64, attrs: []string] -> [value: Value, ok: bool, has-value: bool, error: string]
  (let [items (make [dynamic]Value 0 (count attrs))
        any false]
    (for [attr attrs]
      (let [[op-value op-found op-retracted] (shared-write-state-latest-op-value ops entity attr)]
        (cond
          op-retracted
            (arr.push! items (value-nil))
          op-found
            (do
              (set! any true)
              (arr.push! items op-value))
          :else
            (let [[source-value source-ok source-error] (db-read-source-cardinality-one-value-fast-all-current source entity attr)]
              (when (and (not source-ok)
                         (not (= source-error "")))
                (for [item items]
                  (delete-owned-value item))
                (delete items)
                (return (Value {}) false false source-error))
              (if source-ok
                (do
                  (set! any true)
                  (arr.push! items source-value))
                (arr.push! items (value-nil)))))))
    (when (not any)
      (delete items)
      (return (Value {}) true false ""))
    (let [out (value-vector (slice items 0))]
      (delete items)
      (return out true true ""))))

(defn shared-write-state-remove-source-derived-tuple-adds! [ops: ^[dynamic]Tx-Op, entity: u64, attr: string, map-group: string]
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [op ops^[index]]
        (when (and op.derived
                   (= op.kind .Add)
                   (= op.e entity)
                   (= op.a attr)
                   (= op.map-group map-group))
          (when op.owned-attr
            (delete op.a))
          (when op.owned-value
            (delete-owned-value op.v))
          (arr.remove-ordered-at! ops^ index)))
      (set! index (- index 1)))))

(defn shared-write-state-delete-source-tuple-schemas [schemas: [dynamic]Tuple-Schema]
  (for [schema schemas]
    (delete schema.attr)
    (delete schema.attrs))
  (delete schemas))

(defn shared-write-state-declared-tuple-schema-attrs-for-entity [tx-data: []Tx-Data, entity: u64] -> [dynamic]string
  (let [out (make [dynamic]string)]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.e entity)
                 (= data.a ":db/tupleAttrs")
                 (= data.v.kind .Vector))
        (for [item data.v.items]
          (when (= item.kind .Keyword)
            (arr.push! out (string-owned item.text))))))
    out))

(defn shared-write-state-declared-tuple-schemas-containing [tx-data: []Tx-Data, attr: string] -> [dynamic]Tuple-Schema
  (let [out (make [dynamic]Tuple-Schema)]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (= data.a ":db/ident")
                 (= data.v.kind .Keyword))
        (let [attrs (shared-write-state-declared-tuple-schema-attrs-for-entity tx-data data.e)]
          (if (= (count attrs) 0)
            (delete attrs)
            (let [schema (Tuple-Schema {attr: (string-owned data.v.text) attrs: attrs})]
              (if (tuple-schema-contains? schema attr)
                (arr.push! out schema)
                (do
                  (delete schema.attr)
                  (delete schema.attrs))))))))
    out))

(defn shared-write-state-declares-tuple-schema? [tx-data: []Tx-Data] -> bool
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (= data.a ":db/tupleAttrs"))
      (return true)))
  false)

(defn shared-write-state-apply-source-tuple-schema-maintenance! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op, schema: Tuple-Schema] -> [ok: bool, error: string]
  (let [[tuple-value tuple-ok has-tuple-value tuple-error] (shared-write-state-source-tuple-value-for-entity source (slice ops^ 0) op.e (slice schema.attrs 0))]
    (when (not tuple-ok)
      (return false tuple-error))
    (if has-tuple-value
      (do
        (shared-write-state-remove-source-derived-tuple-adds! ops op.e schema.attr op.map-group)
        (let [derived (tx-add-derived op.e (string-owned schema.attr) tuple-value)]
          (set! derived.map-group op.map-group)
          (set! derived.owned-attr true)
          (set! derived.owned-value true)
          (arr.push! ops^ derived)))
      (let [[retract-ok retract-error] (shared-write-state-append-retract-attr-ops! ops source op.e schema.attr)]
        (when (not retract-ok)
          (return false retract-error)))))
  (return true ""))

(defn shared-write-state-append-source-tuple-maintenance-op! [ops: ^[dynamic]Tx-Op, source: DB-Read-Source, tx-data: []Tx-Data, op: Tx-Op] -> [ok: bool, error: string]
  (when (or op.derived
            (= op.a ":db/tupleAttrs"))
    (return true ""))
  (let [[schemas schemas-ok schemas-error] (db-read-source-tuple-schemas-containing source op.a)]
    (when (not schemas-ok)
      (return false schemas-error))
    (for [schema schemas]
      (let [[ok error] (shared-write-state-apply-source-tuple-schema-maintenance! ops source op schema)]
        (when (not ok)
          (shared-write-state-delete-source-tuple-schemas schemas)
          (return false error))))
    (shared-write-state-delete-source-tuple-schemas schemas)
    (let [declared (shared-write-state-declared-tuple-schemas-containing tx-data op.a)]
      (for [schema declared]
        (let [[ok error] (shared-write-state-apply-source-tuple-schema-maintenance! ops source op schema)]
          (when (not ok)
            (shared-write-state-delete-source-tuple-schemas declared)
            (return false error))))
      (shared-write-state-delete-source-tuple-schemas declared))
    (return true "")))

(defn shared-write-state-append-source-tuple-maintenance-for-new-ops! [state: ^Shared-Write-State, ops: ^[dynamic]Tx-Op, source: DB-Read-Source, tx-data: []Tx-Data, start-index: int] -> [ok: bool, error: string]
  (when (and (not state^.has-tuple-schema)
             (not (shared-write-state-declares-tuple-schema? tx-data)))
    (return true ""))
  (let [end-index (count ops^)
        index start-index]
    (while (< index end-index)
      (let [[ok error] (shared-write-state-append-source-tuple-maintenance-op! ops source tx-data ops^[index])]
        (when (not ok)
          (return false error)))
      (set! index (+ index 1))))
  (return true ""))

(defn shared-write-state-resolve-tx-local-lookup-ref [ops: []Tx-Op, attr: string, value: Value] -> [entity: u64, ok: bool, error: string]
  (let [found: u64 0
        has-found false]
    (for [op ops]
      (when (and (= op.kind .Add)
                 (= op.a attr)
                 (value-equal? op.v value))
        (when (and has-found
                   (not (= found op.e)))
          (return 0 false "schema unique conflict"))
        (set! found op.e)
        (set! has-found true)))
    (if has-found
      (return found true "")
      (return 0 false ""))))

(defn shared-write-state-resolve-tx-data-lookup-ref [tx-data: []Tx-Data, tempid-index: (ptr (map string u64)), attr: string, value: Value] -> [entity: u64, ok: bool, error: string]
  (let [found: u64 0
        has-found false]
    (for [data tx-data]
      (when (and (= data.op ":db/add")
                 (not data.has-lookup-ref)
                 (not data.has-ident)
                 (= data.a attr)
                 (value-equal? data.v value))
        (let [candidate: u64 0]
          (if data.has-tempid
            (let [[tempid-e tempid-ok] (resolved-tempid-lookup tempid-index data.tempid)]
              (when (not tempid-ok)
                (return 0 false "tempid not resolved"))
              (set! candidate tempid-e))
            (set! candidate data.e))
          (when (and has-found
                     (not (= found candidate)))
            (return 0 false "schema unique conflict"))
          (set! found candidate)
          (set! has-found true))))
    (if has-found
      (return found true "")
      (return 0 false ""))))

(defn shared-write-state-tuple-attrs-contains? [attrs: []string, attr: string] -> bool
  (for [item attrs]
    (when (= item attr)
      (return true)))
  false)

(defn shared-write-state-tx-data-same-entity? [candidate: Tx-Data, data: Tx-Data] -> bool
  (if candidate.has-tempid
    (and data.has-tempid
         (= data.tempid candidate.tempid))
    (and (not data.has-tempid)
         (not data.has-lookup-ref)
         (not data.has-ident)
         (= data.e candidate.e))))

(defn shared-write-state-tx-local-tuple-component-value [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, ops: []Tx-Op, candidate: Tx-Data, attr: string, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [value: Value, ok: bool, error: string]
  (for [data tx-data]
    (when (and (= data.op ":db/add")
               (= data.a attr)
               (shared-write-state-tx-data-same-entity? candidate data))
      (let [[value value-ok value-skip value-error] (shared-write-state-resolve-source-simple-value state source tx-data ops data tempid-index tempids next-e)]
        (if value-skip
          (return (Value {}) false "")
          (return value value-ok value-error)))))
  (return (Value {}) false ""))

(defn shared-write-state-resolved-candidate-entity [candidate: Tx-Data, tempid-index: (ptr (map string u64))] -> [entity: u64, ok: bool]
  (if candidate.has-tempid
    (resolved-tempid-lookup tempid-index candidate.tempid)
    (return candidate.e true)))

(defn shared-write-state-resolve-tx-local-tuple-lookup-ref [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, ops: []Tx-Op, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64, attr: string, value: Value] -> [entity: u64, ok: bool, error: string]
  (when (not (= value.kind .Vector))
    (return 0 false ""))
  (let [[attrs attrs-ok attrs-error] (db-read-source-schema-tuple-attrs source attr)]
    (when (not attrs-ok)
      (return 0 false attrs-error))
    (defer (delete attrs))
    (when (not (= (count attrs) (count value.items)))
      (return 0 false ""))
    (let [found: u64 0
          has-found false]
      (for [candidate tx-data]
        (when (not (and (= candidate.op ":db/add")
                        (not candidate.has-lookup-ref)
                        (not candidate.has-ident)
                        (shared-write-state-tuple-attrs-contains? (slice attrs 0) candidate.a)))
          (continue))
        (let [matches true]
          (for [component index attrs]
            (let [[component-value component-ok component-error] (shared-write-state-tx-local-tuple-component-value state source tx-data ops candidate component tempid-index tempids next-e)
                  [expected-value expected-ok expected-error] (shared-write-state-resolve-source-tx-value state source component value.items[index])]
              (when (not (= component-error ""))
                (return 0 false component-error))
              (when (not expected-ok)
                (return 0 false expected-error))
              (when (or (not component-ok)
                        (not (value-equal? component-value expected-value)))
                (set! matches false))))
          (when matches
            (let [[candidate-e candidate-ok] (shared-write-state-resolved-candidate-entity candidate tempid-index)]
              (when (not candidate-ok)
                (return 0 false "tempid not resolved"))
              (when (and has-found
                         (not (= found candidate-e)))
                (return 0 false "schema unique conflict"))
              (set! found candidate-e)
              (set! has-found true)))))
      (if has-found
        (return found true "")
        (return 0 false "")))))

(defn shared-write-state-resolve-lookup-ref-for-tx [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, ops: []Tx-Op, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64, attr: string, value: Value] -> [entity: u64, ok: bool, error: string]
  (when (shared-write-state-tx-adds-attr? tx-data attr)
    (let [[local-e local-ok local-error] (shared-write-state-resolve-tx-local-lookup-ref ops attr value)]
      (when (or local-ok
                (not (= local-error "")))
        (return local-e local-ok local-error)))
    (let [[tx-data-e tx-data-ok tx-data-error] (shared-write-state-resolve-tx-data-lookup-ref tx-data tempid-index attr value)]
      (when (or tx-data-ok
                (not (= tx-data-error "")))
        (return tx-data-e tx-data-ok tx-data-error))))
  (let [[tuple-e tuple-ok tuple-error] (shared-write-state-resolve-tx-local-tuple-lookup-ref state source tx-data ops tempid-index tempids next-e attr value)]
    (when (or tuple-ok
              (not (= tuple-error "")))
      (return tuple-e tuple-ok tuple-error)))
  (db-read-source-resolve-lookup-ref source attr value))

(defn shared-write-state-resolve-source-simple-entity [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, ops: []Tx-Op, data: Tx-Data, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [entity: u64, ok: bool, skip: bool, error: string]
  (when data.has-tempid
    (return (shared-write-state-resolve-source-simple-tempid data.tempid tempid-index tempids next-e) true false ""))
  (when data.has-ident
    (let [[ident-e ident-ok ident-error] (db-read-source-schema-entity-for-attr source data.ident)]
      (when ident-ok
        (return ident-e true false ""))
      (if (and (shared-write-state-retract-like-op? data.op)
               (= ident-error ""))
        (return 0 true true "")
      (if (= ident-error "")
        (return 0 false false "ident not found")
        (return 0 false false ident-error)))))
  (when data.has-lookup-ref
    (let [[lookup-e lookup-ok lookup-error] (shared-write-state-resolve-lookup-ref-for-tx state source tx-data ops tempid-index tempids next-e data.lookup-attr data.lookup-value)]
      (when lookup-ok
        (return lookup-e true false ""))
      (if (and (shared-write-state-retract-like-op? data.op)
               (= lookup-error ""))
        (return 0 true true "")
        (if (= lookup-error "")
          (return 0 false false "lookup ref not found")
          (return 0 false false lookup-error)))))
  (return data.e true false ""))

(defn shared-write-state-resolve-source-simple-value [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data, ops: []Tx-Op, data: Tx-Data, tempid-index: (ptr (map string u64)), tempids: ^[dynamic]Tempid, next-e: ^u64] -> [resolved: Value, ok: bool, skip: bool, error: string]
  (when (current-tx-value? data.v)
    (return (value-entity (shared-write-state-next-tx state)) true false ""))
  (when data.has-value-tempid
    (when (current-tx-tempid? data.value-tempid)
      (let [tx (shared-write-state-next-tx state)]
        (ensure-resolved-tempid! tempids tempid-index data.value-tempid tx)
        (return (value-entity tx) true false "")))
    (let [[entity entity-ok entity-error] (shared-write-state-resolve-source-simple-tempid-with-upsert state source tx-data data.value-tempid tempid-index tempids next-e)]
      (return (value-entity entity) entity-ok false entity-error)))
  (when (shared-write-state-ref-tempid-value-for-tx? state tx-data data.a data.v)
    (let [value-tempid (ref-tempid-value-text data.v)]
      (when (current-tx-tempid? value-tempid)
        (let [tx (shared-write-state-next-tx state)]
          (ensure-resolved-tempid! tempids tempid-index value-tempid tx)
          (return (value-entity tx) true false "")))
      (let [[entity entity-ok entity-error] (shared-write-state-resolve-source-simple-tempid-with-upsert state source tx-data value-tempid tempid-index tempids next-e)]
        (return (value-entity entity) entity-ok false entity-error))))
  (when data.has-value-lookup-ref
    (when (not (shared-write-state-schema-ref-target-for-tx? state tx-data data.a))
      (return (value-lookup-ref-vector data.value-lookup-attr data.value-lookup-value) true false ""))
    (let [[lookup-e lookup-ok lookup-error] (shared-write-state-resolve-lookup-ref-for-tx state source tx-data ops tempid-index tempids next-e data.value-lookup-attr data.value-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true false "")
        (if (and (= data.op ":db/retract")
                 (= lookup-error ""))
          (return data.v true true "")
          (if (= lookup-error "")
            (return data.v false false "lookup ref not found")
            (return data.v false false lookup-error))))))
  (let [[value value-ok value-error] (shared-write-state-resolve-direct-tx-data-value state source data)]
    (return value value-ok false value-error)))

(defn shared-write-state-resolve-source-tx-value [state: ^Shared-Write-State, source: DB-Read-Source, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (if (shared-write-state-schema-ref-target? state attr)
    (db-read-source-resolve-ref-component-value source value)
    (db-read-source-resolve-tuple-value source attr value)))

(defn shared-write-state-resolve-source-cas-expected [state: ^Shared-Write-State, source: DB-Read-Source, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has-expected-lookup-ref
    (when (not (shared-write-state-schema-ref-target? state data.a))
      (return (value-lookup-ref-vector data.expected-lookup-attr data.expected-lookup-value) true ""))
    (let [[lookup-e lookup-ok lookup-error] (db-read-source-resolve-lookup-ref source data.expected-lookup-attr data.expected-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.expected false lookup-error))))
  (shared-write-state-resolve-source-tx-value state source data.a data.expected))

(defn shared-write-state-source-current-value-exists? [source: DB-Read-Source, entity: u64, attr: string, value: Value] -> [exists: bool, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
    (when (not datoms-ok)
      (return false false datoms-error))
    (for [datom datoms]
      (when (value-equal? datom.v value)
        (delete-owned-datoms datoms)
        (return true true "")))
    (delete-owned-datoms datoms)
    (return false true "")))

(defn shared-write-state-source-current-attr-exists? [source: DB-Read-Source, entity: u64, attr: string] -> [exists: bool, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
    (when (not datoms-ok)
      (return false false datoms-error))
    (let [out (> (count datoms) 0)]
      (delete-owned-datoms datoms)
      (return out true ""))))

(defn shared-write-state-source-cas-expected-matches? [source: DB-Read-Source, entity: u64, attr: string, expected: Value] -> [matches: bool, ok: bool, error: string]
  (if (= expected.kind .Nil)
    (let [[exists exists-ok exists-error] (shared-write-state-source-current-attr-exists? source entity attr)]
      (return (not exists) exists-ok exists-error))
    (shared-write-state-source-current-value-exists? source entity attr expected)))

(defn shared-write-state-source-current-cas-value-str [source: DB-Read-Source, entity: u64, attr: string] -> [text: string, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
    (when (not datoms-ok)
      (return "" false datoms-error))
    (let [parts (make [dynamic]string)]
      (for [datom datoms]
        (arr.push! parts (value-debug-str datom.v)))
      (delete-owned-datoms datoms)
      (when (= (count parts) 0)
        (delete parts)
        (return "nil" true ""))
      (when (= (count parts) 1)
        (let [out (string-owned parts[0])]
          (delete parts)
          (return out true "")))
      (let [[joined _] (core-strings.join (slice parts 0) " ")
            out (core-strings.concatenate ([]string ["(" joined ")"]))]
        (delete parts)
        (return out true "")))))

(defn shared-write-state-source-cas-failed-error [source: DB-Read-Source, entity: u64, attr: string, expected: Value] -> [error-text: string, ok: bool, error: string]
  (let [[current current-ok current-error] (shared-write-state-source-current-cas-value-str source entity attr)]
    (when (not current-ok)
      (return "" false current-error))
    (let [out (fmt.tprintf ":db.fn/cas failed on datom [%d %s %s], expected %s"
                           entity
                           attr
                           current
                           (value-debug-str expected))]
      (return out true ""))))

(defn shared-write-state-resolve-source-simple-tx-data-for-tx [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data] -> Resolved-Tx
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)
        tempid-index (make (map string u64))
        next-e (shared-write-state-source-simple-next-entity-id state tx-data)]
    (defer (delete tempid-index))
    (let [[prepared-ok prepared-error] (shared-write-state-prepare-source-simple-tempids! state source tx-data (addr tempid-index) (addr resolved-tempids) (addr next-e))]
      (when (not prepared-ok)
        (return (Resolved-Tx {ok: false
                              error: prepared-error
                              ops: resolved-ops
                              tx-meta: resolved-meta
                              tempids: resolved-tempids}))))
    (for [data tx-data]
      (let [[shape-ok shape-error] (validate-tx-data-item data)]
        (when (not shape-ok)
          (return (Resolved-Tx {ok: false
                                error: shape-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids}))))
      (let [[e e-ok skip-data e-error] (shared-write-state-resolve-source-simple-entity state source tx-data (slice resolved-ops 0) data (addr tempid-index) (addr resolved-tempids) (addr next-e))]
        (when (not e-ok)
          (return (Resolved-Tx {ok: false
                                error: e-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (when skip-data
          (continue))
        (when (= data.op ":db/retractEntity")
          (let [start-index (count resolved-ops)
                [expanded-ok expanded-error] (shared-write-state-append-retract-entity-ops! (addr resolved-ops) source e)]
            (when (not expanded-ok)
              (return (Resolved-Tx {ok: false
                                    error: expanded-error
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))
            (let [[tuple-ok tuple-error] (shared-write-state-append-source-tuple-maintenance-for-new-ops! state (addr resolved-ops) source tx-data start-index)]
              (when (not tuple-ok)
                (return (Resolved-Tx {ok: false
                                      error: tuple-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))))
          (continue))
        (when (= data.op ":db/retractAttr")
          (let [start-index (count resolved-ops)
                [expanded-ok expanded-error] (shared-write-state-append-retract-attr-ops! (addr resolved-ops) source e data.a)]
            (when (not expanded-ok)
              (return (Resolved-Tx {ok: false
                                    error: expanded-error
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))
            (let [[tuple-ok tuple-error] (shared-write-state-append-source-tuple-maintenance-for-new-ops! state (addr resolved-ops) source tx-data start-index)]
              (when (not tuple-ok)
                (return (Resolved-Tx {ok: false
                                      error: tuple-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))))
          (continue))
        (when (shared-write-state-source-cas-op? data)
          (let [[expected expected-ok expected-error] (shared-write-state-resolve-source-cas-expected state source data)]
            (when (not expected-ok)
              (return (Resolved-Tx {ok: false
                                    error: expected-error
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))
            (let [[matches matches-ok matches-error] (shared-write-state-source-cas-expected-matches? source e data.a expected)]
              (when (not matches-ok)
                (return (Resolved-Tx {ok: false
                                      error: matches-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))
              (when (not matches)
                (let [[cas-error cas-error-ok cas-error-fallback] (shared-write-state-source-cas-failed-error source e data.a expected)]
                  (return (Resolved-Tx {ok: false
                                        error: (if cas-error-ok cas-error cas-error-fallback)
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids})))))))
        (let [[value value-ok skip-value value-error] (shared-write-state-resolve-source-simple-value state source tx-data (slice resolved-ops 0) data (addr tempid-index) (addr resolved-tempids) (addr next-e))]
          (when (not value-ok)
            (return (Resolved-Tx {ok: false
                                  error: value-error
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids})))
          (when skip-value
            (continue))
          (let [start-index (count resolved-ops)]
            (if (= data.op ":db/retract")
              (arr.push! resolved-ops (tx-op-with-map-group (tx-retract e data.a value) data.map-group))
              (arr.push! resolved-ops (tx-op-with-map-group (tx-add e data.a value) data.map-group)))
            (let [[tuple-ok tuple-error] (shared-write-state-append-source-tuple-maintenance-for-new-ops! state (addr resolved-ops) source tx-data start-index)]
              (when (not tuple-ok)
                (return (Resolved-Tx {ok: false
                                      error: tuple-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))))))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn shared-write-state-resolve-tx-data [state: ^Shared-Write-State, source: DB-Read-Source, tx-data: []Tx-Data] -> Resolved-Tx
  (when (shared-write-state-direct-tx-data? state tx-data)
    (shared-write-state-note-source-resolve! state)
    (return (shared-write-state-resolve-direct-tx-data-for-tx state source tx-data)))
  (when (shared-write-state-source-simple-schema-tx-data? tx-data)
    (shared-write-state-note-source-resolve! state)
    (return (shared-write-state-resolve-source-simple-tx-data-for-tx state source tx-data)))
  (when (shared-write-state-source-simple-mixed-schema-tx-data? state tx-data)
    (shared-write-state-note-source-resolve! state)
    (return (shared-write-state-resolve-source-simple-tx-data-for-tx state source tx-data)))
  (when (shared-write-state-source-simple-tx-data? state tx-data)
    (shared-write-state-note-source-resolve! state)
    (return (shared-write-state-resolve-source-simple-tx-data-for-tx state source tx-data)))
  (shared-write-state-note-resident-fallback! state)
  (resolve-tx-data-for-tx state^.conn.db tx-data state^.conn.next-tx))

(defn tx-fn-source-ok [tx-data: []Tx-Data] -> Tx-Fn-Source-Result
  (let [out (arr.into [dynamic]Tx-Data tx-data)]
    (Tx-Fn-Source-Result {ok: true
                          error: ""
                          tx-data: out})))

(defn tx-fn-source-error [error: string] -> Tx-Fn-Source-Result
  (Tx-Fn-Source-Result {ok: false
                        error: error
                        tx-data: (make [dynamic]Tx-Data)}))

(defn tx-fn-source-string [ident: string, f: fn [source: DB-Read-Source, arg: string] -> Tx-Fn-Source-Result] -> Tx-Fn-Source-String
  (Tx-Fn-Source-String {ident: ident f: f}))

(defn tx-fn-source-values [ident: string, f: fn [source: DB-Read-Source, args: []Value] -> Tx-Fn-Source-Result] -> Tx-Fn-Source-String
  (Tx-Fn-Source-String {ident: ident has-values-fn: true values-f: f}))

(defn tx-fn-source-string-index [registry: []Tx-Fn-Source-String, ident: string] -> [index: int, ok: bool]
  (let [i 0]
    (while (< i (count registry))
      (when (= registry[i].ident ident)
        (return i true))
      (set! i (+ i 1)))
    (return 0 false)))

(defn tx-fn-source-string-duplicate-ident [registry: []Tx-Fn-Source-String] -> [ident: string, found: bool]
  (let [i 0]
    (while (< i (count registry))
      (let [j (+ i 1)]
        (while (< j (count registry))
          (when (= registry[i].ident registry[j].ident)
            (return registry[i].ident true))
          (set! j (+ j 1))))
      (set! i (+ i 1)))
    (return "" false)))

(defn call-source-registered-tx-fn [entry: Tx-Fn-Source-String, source: DB-Read-Source, data: Tx-Data] -> Tx-Fn-Source-Result
  (when (= data.v.kind .Vector)
    (when entry.has-values-fn
      (return (entry.values-f source (slice data.v.items 0))))
    (when (and (= (count data.v.items) 1)
               (= data.v.items[0].kind .String))
      (return (entry.f source data.v.items[0].text)))
    (return (tx-fn-source-error "transaction fn expects one string argument")))
  (when entry.has-values-fn
    (return (entry.values-f source ([]Value [data.v]))))
  (when (= data.v.kind .String)
    (return (entry.f source data.v.text)))
  (tx-fn-source-error "transaction fn expects one string argument"))

(defn failed-source-registered-tx [before: DB, ops: [dynamic]Tx-Op, tx-meta: [dynamic]Tx-Meta, tempids: [dynamic]Tempid, segment: [dynamic]Tx-Data, error: string] -> Tx-Report
  (delete ops)
  (delete tx-meta)
  (delete tempids)
  (delete segment)
  (failed-tx-report before error))

(defn append-source-resolved-tx! [ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, resolved: Resolved-Tx]
  (for [op resolved.ops]
    (arr.push! ops^ op))
  (for [meta resolved.tx-meta]
    (arr.push! tx-meta^ meta))
  (for [tempid resolved.tempids]
    (arr.push! tempids^ tempid)))

(defn resolve-shared-source-tx-segment! [state: ^Shared-Write-State, source: DB-Read-Source, ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, segment: ^[dynamic]Tx-Data] -> [ok: bool, error: string]
  (when (= (count segment^) 0)
    (return true ""))
  (let [resolved (shared-write-state-resolve-tx-data state source (slice segment^ 0))]
    (when (not resolved.ok)
      (let [error resolved.error]
        (delete-resolved-tx resolved)
        (return false error)))
    (append-source-resolved-tx! ops tx-meta tempids resolved)
    (delete resolved.ops)
    (delete resolved.tx-meta)
    (delete resolved.tempids)
    (delete segment^)
    (set! segment^ (make [dynamic]Tx-Data))
    (return true "")))

(defn failed-shared-tx-report [before-snapshot: Shared-DB-Snapshot, error: string] -> Shared-Tx-Report
  (Shared-Tx-Report {ok: false
                     error: error
                     db-before: before-snapshot
                     db-after: (retain-shared-db-snapshot before-snapshot)
                     tx-data: (make [dynamic]Datom)
                     tx: 0
                     tx-meta: (make [dynamic]Tx-Meta)
                     tempids: (make [dynamic]Tempid)
                     datom-start-index: 0
                     append-only: false
                     new-entities-after-existing: false}))

(defn shared-conn-read-source [conn: ^Shared-Conn] -> DB-Read-Source
  (shared-db-snapshot-read-source (addr conn^.snapshot)))

(defn shared-conn-transact [conn: ^Shared-Conn, tx-data: []Tx-Data] -> Tx-Report
  (let [before (shared-write-state-before-db (addr conn^.write))
        tx (shared-write-state-next-tx (addr conn^.write))
        source (shared-conn-read-source conn)
        resolved (shared-write-state-resolve-tx-data (addr conn^.write) source tx-data)]
    (when (not resolved.ok)
      (delete-resolved-tx resolved)
      (return (failed-tx-report before resolved.error)))
    (let [applied (apply-resolved-ops-to-datoms before (slice resolved.ops 0) tx)]
      (when (not applied.ok)
        (delete-resolved-tx resolved)
        (delete-tx-apply-result applied)
        (return (failed-tx-report before applied.error)))
      (let [append-snapshot (if applied.append-only
                              (shared-db-snapshot-with-append-apply-result conn^.snapshot before applied)
                              (retain-shared-db-snapshot conn^.snapshot))
            after (if applied.append-only
                    (build-db-append-only-with-publish-plan before applied.after-datoms applied.publish-plan)
                    (build-db applied.after-datoms))
            report (tx-report-from-apply-result before after applied (slice resolved.tx-meta 0) resolved.tempids)]
        (let [next-snapshot (if report.append-only
                              append-snapshot
                              (shared-db-snapshot-with-tx-report conn^.snapshot after report))]
          (delete-resolved-tx-after-tempids-moved resolved)
          (when (not report.append-only)
            (delete-shared-db-snapshot append-snapshot))
          (shared-write-state-advance! (addr conn^.write) after)
          (delete-shared-db-snapshot conn^.snapshot)
          (set! conn^.snapshot next-snapshot)
          (shared-write-state-notify! (addr conn^.write) report)
          report)))))

(defn shared-conn-transact-direct [conn: ^Shared-Conn, tx-data: []Tx-Data] -> Tx-Report
  (let [report (transact-tx-data (addr conn^.write.conn) tx-data)]
    (when (not report.ok)
      (return report))
    (let [next-snapshot (shared-db-snapshot-with-tx-report-direct conn^.snapshot conn^.write.conn.db report)]
      (delete-shared-db-snapshot conn^.snapshot)
      (set! conn^.snapshot next-snapshot))
    (shared-write-state-refresh-from-current! (addr conn^.write))
    report))

(defn shared-conn-transact-with-string-fns [conn: ^Shared-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-String] -> Tx-Report
  (let [report (transact-tx-data-with-string-fns (addr conn^.write.conn) tx-data registry)]
    (when (not report.ok)
      (return report))
    (let [next-snapshot (shared-db-snapshot-with-tx-report-direct conn^.snapshot conn^.write.conn.db report)]
      (delete-shared-db-snapshot conn^.snapshot)
      (set! conn^.snapshot next-snapshot))
    (shared-write-state-refresh-from-current! (addr conn^.write))
    report))

(defn shared-conn-transact-with-source-string-fns [conn: ^Shared-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Tx-Report
  (let [before (shared-write-state-before-db (addr conn^.write))
        tx (shared-write-state-next-tx (addr conn^.write))
        [duplicate-ident has-duplicate] (tx-fn-source-string-duplicate-ident registry)
        ops (make [dynamic]Tx-Op)
        tx-meta (make [dynamic]Tx-Meta)
        tempids (make [dynamic]Tempid)
        segment (make [dynamic]Tx-Data)]
    (when has-duplicate
      (return (failed-source-registered-tx before ops tx-meta tempids segment (fmt.tprintf "duplicate transaction fn registration: %s" duplicate-ident))))
    (for [data tx-data]
      (when (= data.op ":db.fn/call-ident")
        (let [base-source (shared-conn-read-source conn)
              [segment-ok segment-error] (resolve-shared-source-tx-segment! (addr conn^.write) base-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
          (when (not segment-ok)
            (return (failed-source-registered-tx before ops tx-meta tempids segment segment-error)))
          (let [current-source (tx-ops-overlay-db-read-source (addr base-source) (addr ops) tx)
                [fn-index fn-ok] (tx-fn-source-string-index registry data.ident)]
            (when (not fn-ok)
              (return (failed-source-registered-tx before ops tx-meta tempids segment "transaction fn not registered")))
            (let [result (call-source-registered-tx-fn registry[fn-index] current-source data)]
              (when (not result.ok)
                (delete result.tx-data)
                (return (failed-source-registered-tx before ops tx-meta tempids segment result.error)))
              (let [[result-ok result-error] (resolve-shared-source-tx-segment! (addr conn^.write) current-source (addr ops) (addr tx-meta) (addr tempids) (addr result.tx-data))]
                (delete result.tx-data)
                (when (not result-ok)
                  (return (failed-source-registered-tx before ops tx-meta tempids segment result-error)))))))
        (continue))
      (arr.push! segment data))
    (let [tail-source (shared-conn-read-source conn)
          [tail-ok tail-error] (resolve-shared-source-tx-segment! (addr conn^.write) tail-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
      (when (not tail-ok)
        (return (failed-source-registered-tx before ops tx-meta tempids segment tail-error))))
    (delete segment)
    (let [applied (apply-resolved-ops-to-datoms before (slice ops 0) tx)]
      (when (not applied.ok)
        (delete ops)
        (delete tx-meta)
        (delete tempids)
        (delete-tx-apply-result applied)
        (return (failed-tx-report before applied.error)))
      (let [append-snapshot (if applied.append-only
                              (shared-db-snapshot-with-append-apply-result conn^.snapshot before applied)
                              (retain-shared-db-snapshot conn^.snapshot))
            after (if applied.append-only
                    (build-db-append-only-with-publish-plan before applied.after-datoms applied.publish-plan)
                    (build-db applied.after-datoms))
            report (tx-report-from-apply-result before after applied (slice tx-meta 0) tempids)]
        (let [next-snapshot (if report.append-only
                              append-snapshot
                              (shared-db-snapshot-with-tx-report conn^.snapshot after report))]
          (delete ops)
          (delete tx-meta)
          (when (not report.append-only)
            (delete-shared-db-snapshot append-snapshot))
          (shared-write-state-advance! (addr conn^.write) after)
          (delete-shared-db-snapshot conn^.snapshot)
          (set! conn^.snapshot next-snapshot)
          (shared-write-state-notify! (addr conn^.write) report)
          (return report))))
    (failed-tx-report (shared-write-state-before-db (addr conn^.write)) "unreachable source transaction function path")))

(defn shared-conn-transact-report [conn: ^Shared-Conn, tx-data: []Tx-Data] -> Shared-Tx-Report
  (let [before-snapshot (retain-shared-db-snapshot conn^.snapshot)
        before (shared-write-state-before-db (addr conn^.write))
        tx (shared-write-state-next-tx (addr conn^.write))
        source (shared-conn-read-source conn)
        resolved (shared-write-state-resolve-tx-data (addr conn^.write) source tx-data)]
    (when (not resolved.ok)
      (delete-resolved-tx resolved)
      (return (failed-shared-tx-report before-snapshot resolved.error)))
    (let [applied (apply-resolved-ops-to-datoms before (slice resolved.ops 0) tx)]
      (when (not applied.ok)
        (delete-resolved-tx resolved)
        (delete-tx-apply-result applied)
        (return (failed-shared-tx-report before-snapshot applied.error)))
      (let [append-snapshot (if applied.append-only
                              (shared-db-snapshot-with-append-apply-result conn^.snapshot before applied)
                              (retain-shared-db-snapshot conn^.snapshot))
            after (if applied.append-only
                    (build-db-append-only-with-publish-plan before applied.after-datoms applied.publish-plan)
                    (build-db applied.after-datoms))
            live-report (tx-report-from-apply-result before after applied (slice resolved.tx-meta 0) resolved.tempids)]
        (let [next-snapshot (if live-report.append-only
                              append-snapshot
                              (shared-db-snapshot-with-tx-report conn^.snapshot after live-report))]
          (delete-resolved-tx-after-tempids-moved resolved)
          (when (not live-report.append-only)
            (delete-shared-db-snapshot append-snapshot))
          (shared-write-state-advance! (addr conn^.write) after)
          (delete-shared-db-snapshot conn^.snapshot)
          (set! conn^.snapshot next-snapshot)
          (shared-write-state-notify! (addr conn^.write) live-report)
          (let [owned-tx-data (arr.into [dynamic]Datom (slice live-report.tx-data 0))
                owned-tx-meta (clone-tx-meta (slice live-report.tx-meta 0))
                owned-tempids (arr.into [dynamic]Tempid (slice live-report.tempids 0))
                shared-report (Shared-Tx-Report {ok: true
                                                 error: ""
                                                 db-before: before-snapshot
                                                 db-after: (retain-shared-db-snapshot conn^.snapshot)
                                                 tx-data: owned-tx-data
                                                 tx: live-report.tx
                                                 tx-meta: owned-tx-meta
                                                 tempids: owned-tempids
                                                 datom-start-index: live-report.datom-start-index
                                                 append-only: live-report.append-only
                                                 new-entities-after-existing: live-report.new-entities-after-existing})]
            (delete-live-tx-report-shallow live-report)
            shared-report))))))
