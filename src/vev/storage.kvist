        return \"\", false, sqlite_error_text(db, \"sqlite prepare datom log-index read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite3_bind_int64(stmt, 1, log_index) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite bind datom log-index read failed\")
    }
    rc := sqlite3_step(stmt)
    if rc == SQLITE_ROW {
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            return \"\", false, \"sqlite datom row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            return \"\", false, \"failed to clone sqlite datom attr\"
        }
        defer delete(a_text)
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            return \"\", false, \"failed to clone sqlite datom value\"
        }
        defer delete(value_text)
        formatted := fmt.tprintf(\"[%d %s %s %d %v]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text,
            sqlite3_column_int64(stmt, 3),
            sqlite3_column_int(stmt, 4) != 0)
        out, out_err := strings.clone(formatted)
        if out_err != nil {
            return \"\", false, \"failed to clone sqlite datom log-index text\"
        }
        return out, true, \"\"
    }
    if rc == SQLITE_DONE {
        return \"\", false, \"sqlite datom log-index not found\"
    }
    return \"\", false, sqlite_error_text(db, \"sqlite datom log-index read failed\")
}

sqlite_load_tx_meta_rows_text_raw :: proc(path: string) -> (string, bool, string) {
    db, open_ok, open_error := sqlite_open_initialized(path)
    if !open_ok {
        return \"\", false, open_error
    }
    defer _ = sqlite3_close(db)
    stmt: ^SQLite3_Stmt
    sql := \"SELECT tx, a, value_text FROM vev_tx_meta ORDER BY id\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare tx metadata read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    parts := make([dynamic]string)
    append(&parts, \"[\")
    first := true
    for {
        rc := sqlite3_step(stmt)
        if rc == SQLITE_DONE {
            break
        }
        if rc != SQLITE_ROW {
            delete(parts)
            return \"\", false, sqlite_error_text(db, \"sqlite tx metadata read failed\")
        }
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            delete(parts)
            return \"\", false, \"sqlite tx metadata row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            delete(parts)
            return \"\", false, \"failed to clone sqlite tx metadata attr\"
        }
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            delete(a_text)
            delete(parts)
            return \"\", false, \"failed to clone sqlite tx metadata value\"
        }
        if !first {
            append(&parts, \" \")
        }
        first = false
        append(&parts, fmt.tprintf(\"[%d %s %s]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text))
        delete(a_text)
        delete(value_text)
    }
    append(&parts, \"]\")
    out := strings.concatenate(parts[:])
    delete(parts)
    return out, true, \"\"
}
")

(defn save-db-snapshot-text [path: string, db: DB] -> [ok: bool, error: string]
  (let [text (serializable-text db) :defer
        err (os.write_entire_file path text)]
    (if (= err nil)
      (return true "")
      (return false "failed to write DB snapshot"))))

(defn load-db-snapshot-text [path: string] -> [db: DB, ok: bool, error: string]
  (let [[data err] (os.read_entire_file path context.allocator)]
    (when (!= err nil)
      (return (build-db (make [dynamic]Datom)) false "failed to read DB snapshot"))
    (defer (delete data))
    (from-serializable-text (string data))))

(defn open-conn-snapshot-text [path: string] -> [conn: Conn, ok: bool, error: string]
  (let [[db loaded-ok load-error] (load-db-snapshot-text path)]
    (if loaded-ok
      (do
        (let [conn (conn-from-db db)]
          (delete-owned-db db)
          (return conn true "")))
      (do
        (delete-owned-db db)
        (return (create-conn) false load-error)))))

(defn persist-conn-snapshot-text [path: string, conn: Conn] -> [ok: bool, error: string]
  (save-db-snapshot-text path conn.db))

(defn db-basis-tx [db: DB] -> u64
  (let [basis: u64 0]
    (for [datom db.datoms]
      (when (> datom.tx basis)
        (set! basis datom.tx)))
    basis))

(def sqlite-index-leaf-chunk-size 128)

(defn index-int-slice-text [items: []int] -> string
  (let [builder (kstr.builder)]
    (defer (kstr.destroy! (addr builder)))
    (kstr.write! (addr builder) "[")
    (let [i 0]
      (while (< i (count items))
      (when (> i 0)
        (kstr.write! (addr builder) " "))
      (let [part (fmt.tprintf "%d" items[i])]
        (kstr.write! (addr builder) part))
      (set! i (+ i 1))))
    (kstr.write! (addr builder) "]")
    (kstr.finish (addr builder))))

(defn index-bound-text [items: []int, first?: bool] -> string
  (if (= (count items) 0)
    (string-owned ":empty")
    (if first?
      (string-owned (fmt.tprintf "%d" items[0]))
      (string-owned (fmt.tprintf "%d" items[(- (count items) 1)])))))

(defn storage-index-entry-delimiter? [ch: u8] -> bool
  (or (= ch 32)
      (= ch 9)
      (= ch 10)
      (= ch 13)
      (= ch 91)
      (= ch 93)))

(defn parse-index-entries-text [text: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [out (make [dynamic]int)
        cursor 0
        n (kstr.count text)]
    (while (< cursor n)
      (while (and (< cursor n)
                  (storage-index-entry-delimiter? (kstr.get text cursor)))
        (set! cursor (+ cursor 1)))
      (when (< cursor n)
        (let [start cursor]
          (while (and (< cursor n)
                      (not (storage-index-entry-delimiter? (kstr.get text cursor))))
            (set! cursor (+ cursor 1)))
          (let [token (kstr.slice text start cursor)
            [parsed parsed-ok] (strconv.parse_int token)]
            (when (not parsed-ok)
              (delete out)
              (return (make [dynamic]int) false "invalid persisted index entry"))
            (arr.push! out (int parsed))))))
    (return out true "")))

(defn persist-one-index-chunk-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [first-key (index-bound-text items true)
        last-key (index-bound-text items false)
        payload (index-int-slice-text items)
        [inserted-id inserted-ok inserted-error] (sqlite-insert-index-chunk-raw handle index-name 0 first-key last-key (i64 (count items)) payload basis-tx)]
    (delete first-key)
    (delete last-key)
    (delete payload)
    (return inserted-id inserted-ok inserted-error)))

(defn persist-bounded-index-chunks-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (<= (count items) sqlite-index-leaf-chunk-size)
    (return (persist-one-index-chunk-sqlite-handle handle basis-tx index-name items)))
  (let [leaf-ids (make [dynamic]u64) :defer
        start 0]
    (while (< start (count items))
      (let [end (min (+ start sqlite-index-leaf-chunk-size) (count items))
            [leaf-id leaf-ok leaf-error] (persist-one-index-chunk-sqlite-handle handle basis-tx index-name (slice items start end))]
        (when (not leaf-ok)
          (return 0 false leaf-error))
        (arr.push! leaf-ids leaf-id)
        (set! start end)))
    (let [first-key (index-bound-text items true)
          last-key (index-bound-text items false)
          payload (string-owned "[]")
          [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-raw handle index-name 1 first-key last-key (i64 (count items)) payload basis-tx)]
      (delete first-key)
      (delete last-key)
      (delete payload)
      (when (not parent-ok)
        (return 0 false parent-error))
      (for [ordinal (arr.range 0 (count leaf-ids))]
        (let [[edge-ok edge-error] (sqlite-insert-index-chunk-edge-raw handle parent-id leaf-ids[ordinal] (i64 ordinal))]
          (when (not edge-ok)
            (return 0 false edge-error))))
      (return parent-id true ""))))

(defn persist-index-root-sqlite-handle [handle: rawptr, db: DB] -> [ok: bool, error: string]
  (let [basis-tx (db-basis-tx db)
        [eavt-id eavt-ok eavt-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":eavt" (slice db.eavt 0))]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":aevt" (slice db.aevt 0))]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":avet" (slice db.avet 0))]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":vaet" (slice db.vaet 0))]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [[_ root-ok root-error] (sqlite-insert-index-root-raw handle basis-tx eavt-id aevt-id avet-id vaet-id)]
            (return root-ok root-error)))))))

(defn persist-index-root-sqlite-handle-from-indexes [handle: rawptr, basis-tx: u64, eavt: []int, aevt: []int, avet: []int, vaet: []int] -> [ok: bool, error: string]
  (let [[eavt-id eavt-ok eavt-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":eavt" eavt)]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":aevt" aevt)]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":avet" avet)]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx ":vaet" vaet)]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [[_ root-ok root-error] (sqlite-insert-index-root-raw handle basis-tx eavt-id aevt-id avet-id vaet-id)]
            (return root-ok root-error)))))))

(defn persist-appended-index-root-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[_ old-count old-root old-ok old-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not old-ok)
      (return 0 false old-error))
    (let [[added-root added-ok added-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx index-name appended)]
      (when (not added-ok)
        (return 0 false added-error))
      (let [payload (string-owned "[]")
            [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-raw handle index-name 1 ":shared-root" ":shared-root" (i64 (+ (int old-count) (count appended))) payload basis-tx)]
        (delete payload)
        (when (not parent-ok)
          (return 0 false parent-error))
        (let [[old-edge-ok old-edge-error] (sqlite-insert-index-chunk-edge-raw handle parent-id old-root 0)]
          (when (not old-edge-ok)
            (return 0 false old-edge-error))
          (let [[new-edge-ok new-edge-error] (sqlite-insert-index-chunk-edge-raw handle parent-id added-root 1)]
            (if new-edge-ok
              (return parent-id true "")
              (return 0 false new-edge-error))))))))

(defn persist-index-root-sqlite-handle-index-mode [handle: rawptr, basis-tx: u64, index-name: string, indexes: []int, appended-only: bool] -> [chunk-id: u64, ok: bool, error: string]
  (if appended-only
    (persist-appended-index-root-sqlite-handle handle basis-tx index-name indexes)
    (persist-bounded-index-chunks-sqlite-handle handle basis-tx index-name indexes)))

(defn persist-index-root-sqlite-handle-from-indexes-mode [handle: rawptr, basis-tx: u64, eavt: []int, eavt-appended-only: bool, aevt: []int, aevt-appended-only: bool, avet: []int, avet-appended-only: bool, vaet: []int, vaet-appended-only: bool] -> [ok: bool, error: string]
  (let [[eavt-id eavt-ok eavt-error] (persist-index-root-sqlite-handle-index-mode handle basis-tx ":eavt" eavt eavt-appended-only)]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-index-root-sqlite-handle-index-mode handle basis-tx ":aevt" aevt aevt-appended-only)]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-index-root-sqlite-handle-index-mode handle basis-tx ":avet" avet avet-appended-only)]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-index-root-sqlite-handle-index-mode handle basis-tx ":vaet" vaet vaet-appended-only)]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [[_ root-ok root-error] (sqlite-insert-index-root-raw handle basis-tx eavt-id aevt-id avet-id vaet-id)]
            (return root-ok root-error)))))))

(defn storage-int-slices-equal? [left: []int, right: []int] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn copy-index-entry-window [items: []int, offset-within-items: int, limit: int] -> [dynamic]int
  (let [out (make [dynamic]int)]
    (when (<= limit 0)
      (return out))
    (let [start (min (max offset-within-items 0) (count items))
          end (min (+ start limit) (count items))]
      (for [i (arr.range start end)]
        (arr.push! out items[i]))
      (return out))))

(defn validate-sqlite-index [path: string, db-index: []int, index-name: string] -> [ok: bool, error: string]
  (let [[loaded loaded-ok loaded-error] (sqlite-latest-index-entries path index-name)]
    (when (not loaded-ok)
      (return false loaded-error))
    (defer (delete loaded))
    (if (storage-int-slices-equal? (slice loaded 0) db-index)
      (return true "")
      (return false (fmt.tprintf "persisted %s index did not match rebuilt DB index" index-name)))))

(defn validate-sqlite-indexes-for-db [path: string, db: DB, expected-basis: u64, has-root: bool] -> [ok: bool, error: string]
  (when (not has-root)
    (return true ""))
  (let [basis (db-basis-tx db)]
    (when (not (= basis expected-basis))
      (return false (fmt.tprintf "persisted index basis %d did not match rebuilt DB basis %d" expected-basis basis)))
    (let [[eavt-ok eavt-error] (validate-sqlite-index path (slice db.eavt 0) ":eavt")]
      (when (not eavt-ok)
        (return false eavt-error)))
    (let [[aevt-ok aevt-error] (validate-sqlite-index path (slice db.aevt 0) ":aevt")]
      (when (not aevt-ok)
        (return false aevt-error)))
    (let [[avet-ok avet-error] (validate-sqlite-index path (slice db.avet 0) ":avet")]
      (when (not avet-ok)
        (return false avet-error)))
    (let [[vaet-ok vaet-error] (validate-sqlite-index path (slice db.vaet 0) ":vaet")]
      (when (not vaet-ok)
        (return false vaet-error)))
    (return true "")))

(defn save-db-sqlite [path: string, db: DB] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-replace-datoms-raw path)]
    (when (not open-ok)
      (return false open-error))
    (for [datom index db.datoms]
      (let [value-text (value-serializable-text datom.v)
            [insert-ok insert-error] (sqlite-insert-datom-raw handle (i64 index) datom.e datom.a value-text datom.tx datom.added)]
        (delete value-text)
        (when (not insert-ok)
          (sqlite-rollback-close-raw handle)
          (return false insert-error))))
    (let [[clear-ok clear-error] (sqlite-clear-index-storage-raw handle)]
      (when (not clear-ok)
        (sqlite-rollback-close-raw handle)
        (return false clear-error)))
    (let [[root-ok root-error] (persist-index-root-sqlite-handle handle db)]
      (when (not root-ok)
        (sqlite-rollback-close-raw handle)
        (return false root-error)))
    (sqlite-commit-close-raw handle)))

(defn load-db-sqlite [path: string] -> [db: DB, ok: bool, error: string]
  (let [[root-basis root-ok root-error] (sqlite-latest-index-root-basis path)
        has-root root-ok
        [row-text row-ok row-error] (sqlite-load-datom-rows-text-raw path)]
    (when row-ok
      (defer (delete row-text))
      (let [[db parsed-ok parsed-error] (from-serializable-text row-text)]
        (when (not parsed-ok)
          (return db false parsed-error))
        (let [[valid-ok valid-error] (validate-sqlite-indexes-for-db path db root-basis has-root)]
          (when (not valid-ok)
            (delete-owned-db db)
            (return (build-db (make [dynamic]Datom)) false valid-error)))
        (return db true "")))
    (let [[snapshot-text snapshot-ok snapshot-error] (sqlite-load-snapshot-text-raw path)]
      (when (not snapshot-ok)
        (return (build-db (make [dynamic]Datom)) false row-error))
      (defer (delete snapshot-text))
      (let [[db parsed-ok parsed-error] (from-serializable-text snapshot-text)]
        (when (not parsed-ok)
          (return db false parsed-error))
        (let [[valid-ok valid-error] (validate-sqlite-indexes-for-db path db root-basis has-root)]
          (when (not valid-ok)
            (delete-owned-db db)
            (return (build-db (make [dynamic]Datom)) false valid-error)))
        (return db true "")))))

(defn open-conn-sqlite [path: string] -> [conn: Conn, ok: bool, error: string]
  (let [[db loaded-ok load-error] (load-db-sqlite path)]
    (if loaded-ok
      (do
        (let [conn (conn-from-db db)]
          (delete-owned-db db)
          (return conn true "")))
      (do
        (delete-owned-db db)
        (return (create-conn) false load-error)))))

(defn persist-conn-sqlite [path: string, conn: Conn] -> [ok: bool, error: string]
  (save-db-sqlite path conn.db))

(defstruct SQLite-Tx-Meta-Row {
  tx: u64
  a: string
  v: Value
})

(defstruct SQLite-Conn {
  path: string
  conn: Conn
  handle: rawptr
  source-only: bool
  resident-loaded: bool
})

(defstruct SQLite-Index-Cursor {
  handle: rawptr
  owns-handle: bool
  index-name: string
  basis-tx: u64
  page-size: int
  row-count: int
  page: [dynamic]int
  page-start: int
  page-end: int
})

(defstruct SQLite-Index-Snapshot {
  handle: rawptr
  owns-handle: bool
  page-size: int
  eavt: SQLite-Index-Cursor
  aevt: SQLite-Index-Cursor
  avet: SQLite-Index-Cursor
  vaet: SQLite-Index-Cursor
})

(defstruct SQLite-DB-Snapshot {
  indexes: SQLite-Index-Snapshot
  datom-stmt: rawptr
  basis-tx: u64
  datom-count: int
  path: string
})

(defenum Store-Conn-Kind [
  Empty
  SQLite
  Shared
])

(defstruct Store-Conn {
  kind: Store-Conn-Kind
  sqlite: SQLite-Conn
  shared: Shared-Conn
})

(defenum Store-DB-Kind [
  Empty
  Resident
  SQLite-Snapshot
  SQLite-Tx-Ops-Overlay
  SQLite-Datom-Overlay
  Shared-Snapshot
  Shared-Tx-Ops-Overlay
  Shared-Datom-Overlay
])

(defstruct Store-DB {
  kind: Store-DB-Kind
  resident: DB
  sqlite-snapshot: SQLite-DB-Snapshot
  shared-snapshot: Shared-DB-Snapshot
  overlay-ops: [dynamic]Tx-Op
  overlay-datoms: [dynamic]Datom
  overlay-tx: u64
})

(defn insert-sqlite-tx-meta! [handle: rawptr, tx: u64, meta: []Tx-Meta] -> [ok: bool, error: string]
  (for [entry meta]
    (let [value-text (value-serializable-text entry.v)
          [insert-ok insert-error] (sqlite-insert-tx-meta-raw handle tx entry.a value-text)]
      (delete value-text)
      (when (not insert-ok)
        (return false insert-error))))
  (return true ""))

(defn append-datoms-sqlite [path: string, datoms: []Datom] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-append-datoms-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[base-count count-ok count-error] (sqlite-datom-count-raw handle)]
      (when (not count-ok)
        (sqlite-rollback-close-raw handle)
        (return false count-error))
      (for [datom index datoms]
        (let [value-text (value-serializable-text datom.v)
              [insert-ok insert-error] (sqlite-insert-datom-raw handle (i64 (+ (int base-count) index)) datom.e datom.a value-text datom.tx datom.added)]
          (delete value-text)
          (when (not insert-ok)
            (sqlite-rollback-close-raw handle)
            (return false insert-error)))))
    (sqlite-commit-close-raw handle)))

(defn append-tx-report-sqlite-handle [handle: rawptr, report: Tx-Report] -> [ok: bool, error: string]
  (let [[begin-ok begin-error] (sqlite-begin-immediate-raw handle)]
    (when (not begin-ok)
      (return false begin-error))
    (let [[tx-stmt tx-stmt-ok tx-stmt-error] (sqlite-prepare-insert-tx-raw handle)]
      (when (not tx-stmt-ok)
        (sqlite-rollback-raw handle)
        (return false tx-stmt-error))
      (let [[tx-ok tx-error] (sqlite-step-tx-stmt-raw handle tx-stmt report.tx)]
        (sqlite-finalize-stmt-raw tx-stmt)
        (when (not tx-ok)
          (sqlite-rollback-raw handle)
          (return false tx-error))))
    (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-insert-datom-raw handle)]
      (when (not datom-stmt-ok)
        (sqlite-rollback-raw handle)
        (return false datom-stmt-error))
      (let [base-index (count report.db-before.datoms)]
        (for [datom index report.tx-data]
          (let [value-text (value-serializable-text datom.v)
                [insert-ok insert-error] (sqlite-step-datom-stmt-raw handle datom-stmt (i64 (+ base-index index)) datom.e datom.a value-text datom.tx datom.added)]
            (delete value-text)
            (when (not insert-ok)
              (sqlite-finalize-stmt-raw datom-stmt)
              (sqlite-rollback-raw handle)
              (return false insert-error)))))
      (sqlite-finalize-stmt-raw datom-stmt))
    (let [[meta-ok meta-error] (insert-sqlite-tx-meta! handle report.tx (slice report.tx-meta 0))]
      (when (not meta-ok)
        (sqlite-rollback-raw handle)
        (return false meta-error)))
    (let [[root-ok root-error] (persist-index-root-sqlite-handle handle report.db-after)]
      (when (not root-ok)
        (sqlite-rollback-raw handle)
        (return false root-error)))
    (sqlite-commit-raw handle)))

(defn db-index-view-entries [view: DB-Index-View] -> [dynamic]int
  (let [out (make [dynamic]int 0 (db-index-view-count view))
        index 0]
    (while (< index (db-index-view-count view))
      (arr.push! out (db-index-view-at view index))
      (set! index (+ index 1)))
    out))

(defn source-appended-datom-at-entry [source: DB-Read-Source, appended: []Datom, start-index: int, entry: int] -> [datom: Datom, ok: bool, error: string]
  (if (< entry start-index)
    (db-read-source-datom-at-entry source entry)
    (let [offset (- entry start-index)]
      (when (or (< offset 0)
                (>= offset (count appended)))
        (return (Datom {}) false "appended datom index out of range"))
      (return (datom-owned appended[offset]) true ""))))

(defn source-appended-datom-index-less? [source: DB-Read-Source, appended: []Datom, start-index: int, order: string, left: int, right: int] -> [less: bool, ok: bool, error: string]
  (let [[left-datom left-ok left-error] (source-appended-datom-at-entry source appended start-index left)]
    (when (not left-ok)
      (return false false left-error))
    (let [[right-datom right-ok right-error] (source-appended-datom-at-entry source appended start-index right)]
      (when (not right-ok)
        (delete-owned-datom left-datom)
        (return false false right-error))
      (let [less-value (datom-less-order? left-datom right-datom order left right)]
        (delete-owned-datom left-datom)
        (delete-owned-datom right-datom)
        (return less-value true "")))))

(defn source-append-merge-index [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, order: string] -> [out: [dynamic]int, ok: bool, error: string]
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)
        merged (make [dynamic]int 0 (+ (count existing) (count added)))
        left 0
        right 0]
    (while (and (< left (count existing))
                (< right (count added)))
      (let [[added-less less-ok less-error] (source-appended-datom-index-less? source appended start-index order added[right] existing[left])]
        (when (not less-ok)
          (delete merged)
          (delete added)
          (return (make [dynamic]int) false less-error))
        (if added-less
          (do
            (arr.push! merged added[right])
            (set! right (+ right 1)))
          (do
            (arr.push! merged existing[left])
            (set! left (+ left 1))))))
    (while (< left (count existing))
      (arr.push! merged existing[left])
      (set! left (+ left 1)))
    (while (< right (count added))
      (arr.push! merged added[right])
      (set! right (+ right 1)))
    (delete added)
    (return merged true "")))

(defn source-append-eavt-index [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [out: [dynamic]int, ok: bool, error: string]
  (if new-entities-after-existing
    (let [added (sorted-appended-datom-slice-indexes appended start-index "eavt")
          out (arr.into [dynamic]int existing)]
      (for [entry added]
        (arr.push! out entry))
      (delete added)
      (return out true ""))
    (source-append-merge-index source existing appended start-index "eavt")))

(defn source-append-index-can-append? [source: DB-Read-Source, existing: []int, added: []int, appended: []Datom, start-index: int, order: string] -> [appendable: bool, ok: bool, error: string]
  (when (= (count added) 0)
    (return true true ""))
  (when (= (count existing) 0)
    (return true true ""))
  (let [last-existing existing[(- (count existing) 1)]
        first-added added[0]
        [existing-less less-ok less-error] (source-appended-datom-index-less? source appended start-index order last-existing first-added)]
    (if less-ok
      (return existing-less true "")
      (return false false less-error))))

(defn source-append-index-for-persist [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, order: string, force-append: bool] -> [out: [dynamic]int, append-mode: bool, ok: bool, error: string]
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)]
    (when force-append
      (return added true true ""))
    (let [[appendable appendable-ok appendable-error] (source-append-index-can-append? source existing (slice added 0) appended start-index order)]
      (when (not appendable-ok)
        (delete added)
        (return (make [dynamic]int) false false appendable-error))
      (when appendable
        (return added true true ""))
      (delete added)
      (let [[merged merged-ok merged-error] (source-append-merge-index source existing appended start-index order)]
        (return merged false merged-ok merged-error)))))

(defn source-append-index-for-persist-mode [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, order: string, append-mode: bool] -> [out: [dynamic]int, ok: bool, error: string]
  (if append-mode
    (return (sorted-appended-datom-slice-indexes appended start-index order) true "")
    (source-append-merge-index source existing appended start-index order)))

(defn source-append-index-mode-for-persist [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, order: string, force-append: bool] -> [append-mode: bool, ok: bool, error: string]
  (when force-append
    (return true true ""))
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)]
    (defer (delete added))
    (source-append-index-can-append? source existing (slice added 0) appended start-index order)))

(defn source-append-index-modes-for-persist [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [eavt-append-mode: bool, aevt-append-mode: bool, avet-append-mode: bool, vaet-append-mode: bool, ok: bool, error: string]
  (let [eavt-base (db-index-view-entries (db-read-source-index-view source .EAVT))
        aevt-base (db-index-view-entries (db-read-source-index-view source .AEVT))
        avet-base (db-index-view-entries (db-read-source-index-view source .AVET))
        vaet-base (db-index-view-entries (db-read-source-index-view source .VAET))]
    (defer (delete eavt-base))
    (defer (delete aevt-base))
    (defer (delete avet-base))
    (defer (delete vaet-base))
      (let [[eavt-mode-value eavt-ok eavt-error] (source-append-index-mode-for-persist source (slice eavt-base 0) appended start-index "eavt" new-entities-after-existing)]
      (when (not eavt-ok)
        (return false false false false false eavt-error))
      (let [[aevt-mode-value aevt-ok aevt-error] (source-append-index-mode-for-persist source (slice aevt-base 0) appended start-index "aevt" false)]
        (when (not aevt-ok)
          (return false false false false false aevt-error))
        (let [[avet-mode-value avet-ok avet-error] (source-append-index-mode-for-persist source (slice avet-base 0) appended start-index "avet" false)]
          (when (not avet-ok)
            (return false false false false false avet-error))
          (let [[vaet-mode-value vaet-ok vaet-error] (source-append-index-mode-for-persist source (slice vaet-base 0) appended start-index "vaet" false)]
            (if vaet-ok
              (return eavt-mode-value aevt-mode-value avet-mode-value vaet-mode-value true "")
              (return false false false false false vaet-error))))))))

(defn source-append-build-indexes [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int, ok: bool, error: string]
  (let [eavt-base (db-index-view-entries (db-read-source-index-view source .EAVT))
        aevt-base (db-index-view-entries (db-read-source-index-view source .AEVT))
        avet-base (db-index-view-entries (db-read-source-index-view source .AVET))
        vaet-base (db-index-view-entries (db-read-source-index-view source .VAET))
        [eavt-index eavt-ok eavt-error] (source-append-eavt-index source (slice eavt-base 0) appended start-index new-entities-after-existing)]
    (when (not eavt-ok)
      (delete eavt-base)
      (delete aevt-base)
      (delete avet-base)
      (delete vaet-base)
      (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false eavt-error))
    (let [[aevt-index aevt-ok aevt-error] (source-append-merge-index source (slice aevt-base 0) appended start-index "aevt")]
      (when (not aevt-ok)
        (delete eavt-index)
        (delete eavt-base)
        (delete aevt-base)
        (delete avet-base)
        (delete vaet-base)
        (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false aevt-error))
      (let [[avet-index avet-ok avet-error] (source-append-merge-index source (slice avet-base 0) appended start-index "avet")]
        (when (not avet-ok)
          (delete eavt-index)
          (delete aevt-index)
          (delete eavt-base)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false avet-error))
        (let [[vaet-index vaet-ok vaet-error] (source-append-merge-index source (slice vaet-base 0) appended start-index "vaet")]
          (when (not vaet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (delete avet-index)
            (delete eavt-base)
            (delete aevt-base)
            (delete avet-base)
            (delete vaet-base)
            (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false vaet-error))
          (delete eavt-base)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return eavt-index aevt-index avet-index vaet-index true ""))))))

(defn source-append-build-indexes-for-persist-with-eavt [source: DB-Read-Source, appended: []Datom, start-index: int, eavt-index: [dynamic]int, eavt-appended-only: bool] -> [eavt: [dynamic]int, eavt-append-mode: bool, aevt: [dynamic]int, aevt-append-mode: bool, avet: [dynamic]int, avet-append-mode: bool, vaet: [dynamic]int, vaet-append-mode: bool, ok: bool, error: string]
  (let [aevt-base (db-index-view-entries (db-read-source-index-view source .AEVT))
        avet-base (db-index-view-entries (db-read-source-index-view source .AVET))
        vaet-base (db-index-view-entries (db-read-source-index-view source .VAET))]
    (let [[aevt-index aevt-appended-only aevt-ok aevt-error] (source-append-index-for-persist source (slice aevt-base 0) appended start-index "aevt" false)]
      (when (not aevt-ok)
        (delete eavt-index)
        (delete aevt-base)
        (delete avet-base)
        (delete vaet-base)
        (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false aevt-error))
      (let [[avet-index avet-appended-only avet-ok avet-error] (source-append-index-for-persist source (slice avet-base 0) appended start-index "avet" false)]
        (when (not avet-ok)
          (delete eavt-index)
          (delete aevt-index)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false avet-error))
        (let [[vaet-index vaet-appended-only vaet-ok vaet-error] (source-append-index-for-persist source (slice vaet-base 0) appended start-index "vaet" false)]
          (when (not vaet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (delete avet-index)
            (delete aevt-base)
            (delete avet-base)
            (delete vaet-base)
            (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false vaet-error))
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return eavt-index eavt-appended-only aevt-index aevt-appended-only avet-index avet-appended-only vaet-index vaet-appended-only true ""))))))

(defn source-append-build-indexes-for-persist [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [eavt: [dynamic]int, eavt-append-mode: bool, aevt: [dynamic]int, aevt-append-mode: bool, avet: [dynamic]int, avet-append-mode: bool, vaet: [dynamic]int, vaet-append-mode: bool, ok: bool, error: string]
  (if new-entities-after-existing
    (let [eavt-index (sorted-appended-datom-slice-indexes appended start-index "eavt")]
      (source-append-build-indexes-for-persist-with-eavt source appended start-index eavt-index true))
    (let [eavt-base (db-index-view-entries (db-read-source-index-view source .EAVT))
          [eavt-index eavt-appended-only eavt-ok eavt-error] (source-append-index-for-persist source (slice eavt-base 0) appended start-index "eavt" false)]
      (delete eavt-base)
      (when (not eavt-ok)
        (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false eavt-error))
      (source-append-build-indexes-for-persist-with-eavt source appended start-index eavt-index eavt-appended-only))))

(defn source-append-build-indexes-for-persist-modes [source: DB-Read-Source, appended: []Datom, start-index: int, eavt-append-mode: bool, aevt-append-mode: bool, avet-append-mode: bool, vaet-append-mode: bool] -> [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int, ok: bool, error: string]
  (let [eavt-base (db-index-view-entries (db-read-source-index-view source .EAVT))
        aevt-base (db-index-view-entries (db-read-source-index-view source .AEVT))
        avet-base (db-index-view-entries (db-read-source-index-view source .AVET))
        vaet-base (db-index-view-entries (db-read-source-index-view source .VAET))]
    (let [[eavt-index eavt-ok eavt-error] (source-append-index-for-persist-mode source (slice eavt-base 0) appended start-index "eavt" eavt-append-mode)]
      (when (not eavt-ok)
        (delete eavt-base)
        (delete aevt-base)
        (delete avet-base)
        (delete vaet-base)
        (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false eavt-error))
      (let [[aevt-index aevt-ok aevt-error] (source-append-index-for-persist-mode source (slice aevt-base 0) appended start-index "aevt" aevt-append-mode)]
        (when (not aevt-ok)
          (delete eavt-index)
          (delete eavt-base)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false aevt-error))
        (let [[avet-index avet-ok avet-error] (source-append-index-for-persist-mode source (slice avet-base 0) appended start-index "avet" avet-append-mode)]
          (when (not avet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (delete eavt-base)
            (delete aevt-base)
            (delete avet-base)
            (delete vaet-base)
            (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false avet-error))
          (let [[vaet-index vaet-ok vaet-error] (source-append-index-for-persist-mode source (slice vaet-base 0) appended start-index "vaet" vaet-append-mode)]
            (when (not vaet-ok)
              (delete eavt-index)
              (delete aevt-index)
              (delete avet-index)
              (delete eavt-base)
              (delete aevt-base)
              (delete avet-base)
              (delete vaet-base)
              (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false vaet-error))
            (delete eavt-base)
            (delete aevt-base)
            (delete avet-base)
            (delete vaet-base)
            (return eavt-index aevt-index avet-index vaet-index true "")))))))

(defn source-append-datoms-all-new-entities? [next-entity: u64, datoms: []Datom] -> bool
  (for [datom datoms]
    (when (< datom.e next-entity)
      (return false)))
  true)

(defn append-source-direct-sqlite-handle [handle: rawptr, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, eavt: []int, eavt-appended-only: bool, aevt: []int, aevt-appended-only: bool, avet: []int, avet-appended-only: bool, vaet: []int, vaet-appended-only: bool] -> [ok: bool, error: string]
  (let [[begin-ok begin-error] (sqlite-begin-immediate-raw handle)]
    (when (not begin-ok)
      (return false begin-error))
    (let [[tx-stmt tx-stmt-ok tx-stmt-error] (sqlite-prepare-insert-tx-raw handle)]
      (when (not tx-stmt-ok)
        (sqlite-rollback-raw handle)
        (return false tx-stmt-error))
      (let [[tx-ok tx-error] (sqlite-step-tx-stmt-raw handle tx-stmt tx)]
        (sqlite-finalize-stmt-raw tx-stmt)
        (when (not tx-ok)
          (sqlite-rollback-raw handle)
          (return false tx-error))))
    (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-insert-datom-raw handle)]
      (when (not datom-stmt-ok)
        (sqlite-rollback-raw handle)
        (return false datom-stmt-error))
      (for [datom index tx-data]
        (let [value-text (value-serializable-text datom.v)
              [insert-ok insert-error] (sqlite-step-datom-stmt-raw handle datom-stmt (i64 (+ base-count index)) datom.e datom.a value-text datom.tx datom.added)]
          (delete value-text)
          (when (not insert-ok)
            (sqlite-finalize-stmt-raw datom-stmt)
            (sqlite-rollback-raw handle)
            (return false insert-error))))
      (sqlite-finalize-stmt-raw datom-stmt))
    (let [[meta-ok meta-error] (insert-sqlite-tx-meta! handle tx tx-meta)]
      (when (not meta-ok)
        (sqlite-rollback-raw handle)
        (return false meta-error)))
    (let [[root-ok root-error] (persist-index-root-sqlite-handle-from-indexes-mode handle tx eavt eavt-appended-only aevt aevt-appended-only avet avet-appended-only vaet vaet-appended-only)]
      (when (not root-ok)
        (sqlite-rollback-raw handle)
        (return false root-error)))
    (sqlite-commit-raw handle)))

(defn append-tx-report-sqlite [path: string, report: Tx-Report] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[append-ok append-error] (append-tx-report-sqlite-handle handle report)]
      (sqlite-close-live-raw handle)
      (return append-ok append-error))))

(defn sqlite-tx-meta-row-from-edn-node [doc: EDN-Doc, node-index: int] -> [row: SQLite-Tx-Meta-Row, ok: bool, error: string]
  (when (or (= node-index -1)
            (not (= doc.nodes[node-index].kind .Vector))
            (not (= doc.nodes[node-index].child-count 3)))
    (return (SQLite-Tx-Meta-Row {}) false "expected serialized tx metadata vector [tx a v]"))
  (let [tx-node (edn-child-at doc node-index 0)
        a-node (edn-child-at doc node-index 1)
        v-node (edn-child-at doc node-index 2)
        [tx tx-ok tx-error] (edn-int-u64 doc tx-node "tx")
        [attr attr-ok] (edn-attr-text doc a-node)]
    (when (not tx-ok)
      (return (SQLite-Tx-Meta-Row {}) false tx-error))
    (when (not attr-ok)
      (return (SQLite-Tx-Meta-Row {}) false "expected tx metadata attribute keyword or string"))
    (let [[value value-ok value-error] (serial-value-from-edn-node doc v-node)]
      (when (not value-ok)
        (return (SQLite-Tx-Meta-Row {}) false value-error))
      (let [owned (value-owned value)]
        (delete-value-containers-shallow value)
        (return (SQLite-Tx-Meta-Row {tx: tx a: (string-owned attr) v: owned}) true "")))))

(defn delete-sqlite-tx-meta-rows [rows: [dynamic]SQLite-Tx-Meta-Row]
  (for [row rows]
    (delete row.a)
    (delete-owned-value row.v))
  (delete rows))

(defn load-sqlite-tx-meta-rows [path: string] -> [rows: [dynamic]SQLite-Tx-Meta-Row, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-tx-meta-rows-text-raw path)]
    (when (not loaded-ok)
      (return (make [dynamic]SQLite-Tx-Meta-Row) false loaded-error))
    (defer (delete text))
    (let [doc (empty-edn-doc)
          [read-ok read-error] (read-edn-text! (addr doc) text)]
      (when (not read-ok)
        (delete doc.nodes)
        (return (make [dynamic]SQLite-Tx-Meta-Row) false read-error))
      (when (not (= doc.nodes[doc.root].kind .Vector))
        (delete doc.nodes)
        (return (make [dynamic]SQLite-Tx-Meta-Row) false "expected serialized tx metadata vector"))
      (let [out (make [dynamic]SQLite-Tx-Meta-Row)
            child doc.nodes[doc.root].first-child]
        (while (not (= child -1))
          (let [[row row-ok row-error] (sqlite-tx-meta-row-from-edn-node doc child)]
            (when (not row-ok)
              (delete-sqlite-tx-meta-rows out)
              (delete doc.nodes)
              (return (make [dynamic]SQLite-Tx-Meta-Row) false row-error))
            (arr.push! out row)
            (set! child doc.nodes[child].next-sibling)))
        (delete doc.nodes)
        (return out true "")))))

(defn create-sqlite-conn [path: string] -> SQLite-Conn
  (SQLite-Conn {path: (string-owned path)
                conn: (create-conn)
                resident-loaded: true}))

(defn open-sqlite-conn [path: string] -> [store: SQLite-Conn, ok: bool, error: string]
  (let [[handle handle-ok handle-error] (sqlite-open-live-raw path)]
    (if handle-ok
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            handle: handle
                            source-only: false
                            resident-loaded: false})
              true
              "")
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            resident-loaded: true})
              false
              handle-error))))

(defn open-sqlite-source-conn [path: string] -> [store: SQLite-Conn, ok: bool, error: string]
  (let [[handle handle-ok handle-error] (sqlite-open-live-raw path)]
    (if handle-ok
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            handle: handle
                            source-only: true
                            resident-loaded: false})
              true
              "")
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            source-only: true
                            resident-loaded: false})
              false
              handle-error))))

(defn sqlite-conn-ensure-resident! [store: ^SQLite-Conn] -> [ok: bool, error: string]
  (when store^.resident-loaded
    (return true ""))
  (let [[conn opened-ok opened-error] (open-conn-sqlite store^.path)]
    (when (and (not opened-ok)
               (not (= opened-error "sqlite DB has no Vev datom rows")))
      (delete-owned-db conn.db)
      (delete conn.listeners)
      (return false opened-error))
    (delete-owned-db store^.conn.db)
    (delete store^.conn.listeners)
    (set! store^.conn conn)
    (set! store^.resident-loaded true)
    (return true "")))

(defn sqlite-conn-basis-t [store: ^SQLite-Conn] -> [basis-t: u64, ok: bool, error: string]
  (when store^.resident-loaded
    (let [next-tx store^.conn.next-tx]
      (return (if (= next-tx 0) 0 (- next-tx 1)) true "")))
  (sqlite-latest-index-root-basis-raw store^.handle))

(defn sqlite-conn-tx-count [store: ^SQLite-Conn] -> [tx-count: u64, ok: bool, error: string]
  (sqlite-tx-count-raw store^.handle))

(defn sqlite-conn-datom-count [store: ^SQLite-Conn] -> [datom-count: u64, ok: bool, error: string]
  (sqlite-datom-count-raw store^.handle))

(defn sqlite-conn-tx-ids [store: ^SQLite-Conn] -> [tx-ids: [dynamic]u64, ok: bool, error: string]
  (sqlite-tx-ids-raw store^.handle))

(defn sqlite-conn-storage-architecture [store: ^SQLite-Conn] -> [architecture: string, ok: bool, error: string]
  (sqlite-meta-value-raw store^.handle "storage-architecture"))

(defn sqlite-conn-index-root-count [store: ^SQLite-Conn] -> [root-count: u64, ok: bool, error: string]
  (sqlite-index-root-count-raw store^.handle))

(defn sqlite-conn-index-chunk-count [store: ^SQLite-Conn] -> [chunk-count: u64, ok: bool, error: string]
  (sqlite-index-chunk-count-raw store^.handle))

(defn sqlite-conn-latest-index-root-basis [store: ^SQLite-Conn] -> [basis-tx: u64, ok: bool, error: string]
  (sqlite-latest-index-root-basis-raw store^.handle))

(defn sqlite-conn-latest-index-chunk-row-count [store: ^SQLite-Conn, index-name: string] -> [basis-tx: u64, row-count: u64, ok: bool, error: string]
  (sqlite-latest-index-chunk-row-count-raw store^.handle index-name))

(defn sqlite-conn-latest-index-entries [store: ^SQLite-Conn, index-name: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-latest-index-entries-text-raw store^.handle index-name)]
    (when (not loaded-ok)
      (return (make [dynamic]int) false loaded-error))
    (defer (delete text))
    (parse-index-entries-text text)))

(defn sqlite-conn-latest-index-entry-page [store: ^SQLite-Conn, index-name: string, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (when (< offset 0)
    (return (make [dynamic]int) false "sqlite index page offset was negative"))
  (when (<= limit 0)
    (return (make [dynamic]int) true ""))
  (let [[text base-offset loaded-ok loaded-error] (sqlite-latest-index-entries-page-text-raw store^.handle index-name (i64 offset) (i64 limit))]
    (when (not loaded-ok)
      (return (make [dynamic]int) false loaded-error))
    (defer (delete text))
    (let [[parsed parsed-ok parsed-error] (parse-index-entries-text text)]
      (when (not parsed-ok)
        (return (make [dynamic]int) false parsed-error))
      (defer (delete parsed))
      (let [window (copy-index-entry-window (slice parsed 0) (- offset (int base-offset)) limit)]
        (return window true "")))))

(defn sqlite-conn-datom-at-log-index [store: ^SQLite-Conn, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw store^.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
    (let [doc (empty-edn-doc)
          [read-ok read-error] (read-edn-text! (addr doc) text)]
      (when (not read-ok)
        (delete doc.nodes)
        (return (Datom {}) false read-error))
      (let [[parsed-datom parsed-ok parsed-error] (datom-from-edn-node doc doc.root)]
        (delete doc.nodes)
        (return parsed-datom parsed-ok parsed-error)))))

(defn sqlite-latest-index-entry-pages-count-handle [handle: rawptr, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (when (<= page-size 0)
    (return 0 false "sqlite index page size must be positive"))
  (let [[_ row-count rows-ok rows-error] (sqlite-latest-index-chunk-row-count-raw handle index-name)]
    (when (not rows-ok)
      (return 0 false rows-error))
    (let [total 0
          offset 0
          expected (int row-count)]
      (while (< offset expected)
        (let [[text base-offset page-ok page-error] (sqlite-latest-index-entries-page-text-raw handle index-name (i64 offset) (i64 page-size))]
          (when (not page-ok)
            (return total false page-error))
          (let [[parsed parsed-ok parsed-error] (parse-index-entries-text text)]
            (when (not parsed-ok)
              (delete text)
              (return total false parsed-error))
            (let [window (copy-index-entry-window (slice parsed 0) (- offset (int base-offset)) page-size)]
              (set! total (+ total (count window)))
              (delete window))
            (delete parsed))
          (delete text))
        (set! offset (+ offset page-size)))
      (return total true ""))))

(defn sqlite-conn-latest-index-entry-pages-count [store: ^SQLite-Conn, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (sqlite-latest-index-entry-pages-count-handle store^.handle index-name page-size))

(defn sqlite-storage-architecture [path: string] -> [architecture: string, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return "" false open-error))
    (let [[value value-ok value-error] (sqlite-meta-value-raw handle "storage-architecture")]
      (sqlite-close-live-raw handle)
      (return value value-ok value-error))))

(defn sqlite-index-root-count [path: string] -> [root-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-root-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-chunk-count [path: string] -> [chunk-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-chunk-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-latest-index-root-basis [path: string] -> [basis-tx: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
      (sqlite-close-live-raw handle)
      (return basis basis-ok basis-error))))

(defn sqlite-latest-index-chunk-row-count [path: string, index-name: string] -> [basis-tx: u64, row-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 0 false open-error))
    (let [[basis rows row-ok row-error] (sqlite-latest-index-chunk-row-count-raw handle index-name)]
      (sqlite-close-live-raw handle)
      (return basis rows row-ok row-error))))

(defn sqlite-latest-index-entries [path: string, index-name: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (make [dynamic]int) false open-error))
    (let [[text loaded-ok loaded-error] (sqlite-latest-index-entries-text-raw handle index-name)]
      (sqlite-close-live-raw handle)
      (when (not loaded-ok)
        (return (make [dynamic]int) false loaded-error))
      (defer (delete text))
      (parse-index-entries-text text))))

(defn sqlite-latest-index-entry-page [path: string, index-name: string, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (when (< offset 0)
    (return (make [dynamic]int) false "sqlite index page offset was negative"))
  (when (<= limit 0)
    (return (make [dynamic]int) true ""))
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (make [dynamic]int) false open-error))
    (let [[text base-offset loaded-ok loaded-error] (sqlite-latest-index-entries-page-text-raw handle index-name (i64 offset) (i64 limit))]
      (sqlite-close-live-raw handle)
      (when (not loaded-ok)
        (return (make [dynamic]int) false loaded-error))
      (defer (delete text))
      (let [[parsed parsed-ok parsed-error] (parse-index-entries-text text)]
        (when (not parsed-ok)
          (return (make [dynamic]int) false parsed-error))
        (defer (delete parsed))
        (let [window (copy-index-entry-window (slice parsed 0) (- offset (int base-offset)) limit)]
          (return window true ""))))))

(defn sqlite-latest-index-entry-pages-count [path: string, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[total total-ok total-error] (sqlite-latest-index-entry-pages-count-handle handle index-name page-size)]
      (sqlite-close-live-raw handle)
      (return total total-ok total-error))))

(defn sqlite-open-index-cursor-handle [handle: rawptr, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Cursor {}) false "sqlite index page size must be positive"))
  (let [[basis rows rows-ok rows-error] (sqlite-latest-index-chunk-row-count-raw handle index-name)]
    (when (not rows-ok)
      (return (SQLite-Index-Cursor {}) false rows-error))
    (return (SQLite-Index-Cursor {handle: handle
                                  owns-handle: false
                                  index-name: (string-owned index-name)
                                  basis-tx: basis
                                  page-size: page-size
                                  row-count: (int rows)
                                  page: (make [dynamic]int)
                                  page-start: 0
                                  page-end: 0})
            true
            "")))

(defn sqlite-open-index-cursor-handle-at-basis [handle: rawptr, index-name: string, basis-tx: u64, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Cursor {}) false "sqlite index page size must be positive"))
  (let [[rows rows-ok rows-error] (sqlite-index-chunk-row-count-at-basis-raw handle index-name basis-tx)]
    (when (not rows-ok)
      (return (SQLite-Index-Cursor {}) false rows-error))
    (return (SQLite-Index-Cursor {handle: handle
                                  owns-handle: false
                                  index-name: (string-owned index-name)
                                  basis-tx: basis-tx
                                  page-size: page-size
                                  row-count: (int rows)
                                  page: (make [dynamic]int)
                                  page-start: 0
                                  page-end: 0})
            true
            "")))

(defn sqlite-conn-open-index-cursor [store: ^SQLite-Conn, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (sqlite-open-index-cursor-handle store^.handle index-name page-size))

(defn sqlite-open-index-cursor [path: string, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-Index-Cursor {}) false open-error))
    (let [[cursor cursor-ok cursor-error] (sqlite-open-index-cursor-handle handle index-name page-size)]
      (when (not cursor-ok)
        (sqlite-close-live-raw handle)
        (return cursor false cursor-error))
      (set! cursor.owns-handle true)
      (return cursor true ""))))

(defn sqlite-index-cursor-count [cursor: SQLite-Index-Cursor] -> int
  cursor.row-count)

(defn sqlite-index-cursor-load-page! [cursor: ^SQLite-Index-Cursor, offset: int] -> [ok: bool, error: string]
  (when (< offset 0)
    (return false "sqlite index cursor offset was negative"))
  (when (>= offset cursor^.row-count)
    (set! cursor^.page-start cursor^.row-count)
    (set! cursor^.page-end cursor^.row-count)
    (delete cursor^.page)
    (set! cursor^.page (make [dynamic]int))
    (return true ""))
  (when (and (>= offset cursor^.page-start)
             (< offset cursor^.page-end))
    (return true ""))
  (let [page-start (* (/ offset cursor^.page-size) cursor^.page-size)
        [text base-offset loaded-ok loaded-error] (sqlite-index-entries-page-text-at-basis-raw cursor^.handle cursor^.index-name cursor^.basis-tx (i64 page-start) (i64 cursor^.page-size))]
    (when (not loaded-ok)
      (return false loaded-error))
    (let [[parsed parsed-ok parsed-error] (parse-index-entries-text text)]
      (delete text)
      (when (not parsed-ok)
        (return false parsed-error))
      (let [window (copy-index-entry-window (slice parsed 0) (- page-start (int base-offset)) cursor^.page-size)]
        (delete parsed)
        (delete cursor^.page)
        (set! cursor^.page window)
        (set! cursor^.page-start page-start)
        (set! cursor^.page-end (min (+ page-start (count window)) cursor^.row-count))
        (return true "")))))

(defn sqlite-index-cursor-at [cursor: ^SQLite-Index-Cursor, index: int] -> [entry: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index cursor^.row-count))
    (return 0 false "sqlite index cursor position out of range"))
  (let [[page-ok page-error] (sqlite-index-cursor-load-page! cursor index)]
    (when (not page-ok)
      (return 0 false page-error))
    (return cursor^.page[(- index cursor^.page-start)] true "")))

(defn close-sqlite-index-cursor! [cursor: ^SQLite-Index-Cursor]
  (when cursor^.owns-handle
    (sqlite-close-live-raw cursor^.handle))
  (delete cursor^.index-name)
  (delete cursor^.page)
  (set! cursor^ (SQLite-Index-Cursor {})))

(defn close-sqlite-index-cursor [cursor: SQLite-Index-Cursor]
  (let [owned cursor]
    (close-sqlite-index-cursor! (addr owned))))

(defn sqlite-index-snapshot-cursor [snapshot: ^SQLite-Index-Snapshot, order: Public-Index-Order] -> ^SQLite-Index-Cursor
  (cond
    (= order .EAVT) (addr snapshot^.eavt)
    (= order .AEVT) (addr snapshot^.aevt)
    (= order .AVET) (addr snapshot^.avet)
    :else (addr snapshot^.vaet)))

(defn sqlite-index-snapshot-view [snapshot: ^SQLite-Index-Snapshot, order: Public-Index-Order] -> DB-Index-View
  (db-index-view-from-sqlite-cursor order (sqlite-index-snapshot-cursor snapshot order)))

(defn sqlite-index-snapshot-datom-at-log-index [snapshot: ^SQLite-Index-Snapshot, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw snapshot^.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
    (let [doc (empty-edn-doc)
          [read-ok read-error] (read-edn-text! (addr doc) text)]
      (when (not read-ok)
        (delete doc.nodes)
        (return (Datom {}) false read-error))
      (let [[parsed-datom parsed-ok parsed-error] (datom-from-edn-node doc doc.root)]
        (delete doc.nodes)
        (return parsed-datom parsed-ok parsed-error)))))

(defn sqlite-open-index-snapshot-handle [handle: rawptr, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Snapshot {}) false "sqlite index snapshot page size must be positive"))
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return (SQLite-Index-Snapshot {}) false basis-error))
    (sqlite-open-index-snapshot-handle-at-basis handle basis page-size)))

(defn sqlite-open-index-snapshot-handle-at-basis [handle: rawptr, basis-tx: u64, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Snapshot {}) false "sqlite index snapshot page size must be positive"))
  (let [[eavt eavt-ok eavt-error] (sqlite-open-index-cursor-handle-at-basis handle ":eavt" basis-tx page-size)]
    (when (not eavt-ok)
      (return (SQLite-Index-Snapshot {}) false eavt-error))
    (let [[aevt aevt-ok aevt-error] (sqlite-open-index-cursor-handle-at-basis handle ":aevt" basis-tx page-size)]
      (when (not aevt-ok)
        (close-sqlite-index-cursor eavt)
        (return (SQLite-Index-Snapshot {}) false aevt-error))
      (let [[avet avet-ok avet-error] (sqlite-open-index-cursor-handle-at-basis handle ":avet" basis-tx page-size)]
        (when (not avet-ok)
          (close-sqlite-index-cursor eavt)
          (close-sqlite-index-cursor aevt)
          (return (SQLite-Index-Snapshot {}) false avet-error))
        (let [[vaet vaet-ok vaet-error] (sqlite-open-index-cursor-handle-at-basis handle ":vaet" basis-tx page-size)]
          (when (not vaet-ok)
            (close-sqlite-index-cursor eavt)
            (close-sqlite-index-cursor aevt)
            (close-sqlite-index-cursor avet)
            (return (SQLite-Index-Snapshot {}) false vaet-error))
          (return (SQLite-Index-Snapshot {handle: handle
                                          owns-handle: false
                                          page-size: page-size
                                          eavt: eavt
                                          aevt: aevt
                                          avet: avet
                                          vaet: vaet})
                  true
                  ""))))))

(defn sqlite-conn-open-index-snapshot [store: ^SQLite-Conn, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (sqlite-open-index-snapshot-handle store^.handle page-size))

(defn sqlite-open-index-snapshot [path: string, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-Index-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-index-snapshot-handle handle page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.owns-handle true)
      (return opened-snapshot true ""))))

(defn close-sqlite-index-snapshot! [snapshot: ^SQLite-Index-Snapshot]
  (close-sqlite-index-cursor! (addr snapshot^.eavt))
  (close-sqlite-index-cursor! (addr snapshot^.aevt))
  (close-sqlite-index-cursor! (addr snapshot^.avet))
  (close-sqlite-index-cursor! (addr snapshot^.vaet))
  (when snapshot^.owns-handle
    (sqlite-close-live-raw snapshot^.handle))
  (set! snapshot^ (SQLite-Index-Snapshot {})))

(defn close-sqlite-index-snapshot [snapshot: SQLite-Index-Snapshot]
  (let [owned snapshot]
    (close-sqlite-index-snapshot! (addr owned))))

(defn sqlite-db-snapshot-index-view [snapshot: ^SQLite-DB-Snapshot, order: Public-Index-Order] -> DB-Index-View
  (sqlite-index-snapshot-view (addr snapshot^.indexes) order))

(defn datom-from-owned-serial-text [text: string] -> [datom: Datom, ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (Datom {}) false read-error))
    (let [[parsed-datom parsed-ok parsed-error] (datom-from-edn-node doc doc.root)]
      (delete doc.nodes)
      (return parsed-datom parsed-ok parsed-error))))

(defn sqlite-db-snapshot-datom-at-log-index [snapshot: ^SQLite-DB-Snapshot, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (if (not (= snapshot^.datom-stmt nil))
    (let [[text loaded-ok loaded-error] (sqlite-step-prepared-datom-by-log-index-text-raw snapshot^.indexes.handle snapshot^.datom-stmt (i64 log-index))]
      (when (not loaded-ok)
        (return (Datom {}) false loaded-error))
      (defer (delete text))
      (datom-from-owned-serial-text text))
    (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw snapshot^.indexes.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
      (datom-from-owned-serial-text text))))

(defn sqlite-db-snapshot-eavt-entity-bound [snapshot: ^SQLite-DB-Snapshot, entity: u64, upper: bool] -> [position: int, ok: bool, error: string]
  (let [view (sqlite-db-snapshot-index-view snapshot .EAVT)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            log-index (db-index-view-at view mid)
            [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
        (when (not datom-ok)
          (return low false datom-error))
        (let [datom-entity datom.e]
          (delete-owned-datom datom)
          (if (if upper (<= datom-entity entity) (< datom-entity entity))
            (set! low (+ mid 1))
            (set! high mid)))))
    (return low true "")))

(defn sqlite-db-snapshot-eavt-entity-range [snapshot: ^SQLite-DB-Snapshot, entity: u64] -> [low: int, high: int, ok: bool, error: string]
  (let [[range-low low-ok low-error] (sqlite-db-snapshot-eavt-entity-bound snapshot entity false)]
    (when (not low-ok)
      (return range-low range-low false low-error))
    (let [[range-high high-ok high-error] (sqlite-db-snapshot-eavt-entity-bound snapshot entity true)]
      (return range-low range-high high-ok high-error))))

(defn sqlite-db-snapshot-entity-datoms [snapshot: ^SQLite-DB-Snapshot, entity: u64] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-eavt-entity-range snapshot entity)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom 0 (- high low))
          view (sqlite-db-snapshot-index-view snapshot .EAVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (arr.push! out datom)))
      (return out true ""))))

(defn sqlite-db-snapshot-aevt-attr-bound [snapshot: ^SQLite-DB-Snapshot, attr: string, upper: bool] -> [position: int, ok: bool, error: string]
  (let [view (sqlite-db-snapshot-index-view snapshot .AEVT)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            log-index (db-index-view-at view mid)
            [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
        (when (not datom-ok)
          (return low false datom-error))
        (let [compare (strings.compare datom.a attr)]
          (delete-owned-datom datom)
          (if (if upper (<= compare 0) (< compare 0))
            (set! low (+ mid 1))
            (set! high mid)))))
    (return low true "")))

(defn sqlite-db-snapshot-aevt-attr-range [snapshot: ^SQLite-DB-Snapshot, attr: string] -> [low: int, high: int, ok: bool, error: string]
  (let [[range-low low-ok low-error] (sqlite-db-snapshot-aevt-attr-bound snapshot attr false)]
    (when (not low-ok)
      (return range-low range-low false low-error))
    (let [[range-high high-ok high-error] (sqlite-db-snapshot-aevt-attr-bound snapshot attr true)]
      (return range-low range-high high-ok high-error))))

(defn sqlite-db-snapshot-attr-datoms [snapshot: ^SQLite-DB-Snapshot, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-aevt-attr-range snapshot attr)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom 0 (- high low))
          view (sqlite-db-snapshot-index-view snapshot .AEVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (arr.push! out datom)))
      (return out true ""))))

(defn sqlite-db-snapshot-entity-attr-datoms [snapshot: ^SQLite-DB-Snapshot, entity: u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-eavt-entity-range snapshot entity)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom)
          view (sqlite-db-snapshot-index-view snapshot .EAVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (if (= datom.a attr)
            (arr.push! out datom)
            (delete-owned-datom datom))))
      (return out true ""))))

(defn sqlite-open-db-snapshot-handle [handle: rawptr, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return (SQLite-DB-Snapshot {}) false basis-error))
    (sqlite-open-db-snapshot-handle-at-basis handle basis page-size)))

(defn sqlite-open-db-snapshot-handle-at-basis [handle: rawptr, basis-tx: u64, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
    (let [[datom-count datom-count-ok datom-count-error] (sqlite-datom-count-raw handle)]
      (when (not datom-count-ok)
        (return (SQLite-DB-Snapshot {}) false datom-count-error))
      (let [[indexes indexes-ok indexes-error] (sqlite-open-index-snapshot-handle-at-basis handle basis-tx page-size)]
        (when (not indexes-ok)
          (return (SQLite-DB-Snapshot {}) false indexes-error))
        (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
          (when (not datom-stmt-ok)
            (close-sqlite-index-snapshot indexes)
            (return (SQLite-DB-Snapshot {}) false datom-stmt-error))
        (return (SQLite-DB-Snapshot {indexes: indexes
                                     datom-stmt: datom-stmt
                                     basis-tx: basis-tx
                                     datom-count: (int datom-count)})
                true
                  "")))))

(defn sqlite-conn-open-db-snapshot [store: ^SQLite-Conn, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle store^.handle page-size)]
    (when snapshot-ok
      (set! opened-snapshot.path (string-owned store^.path)))
    (return opened-snapshot snapshot-ok snapshot-error)))

(def sqlite-db-source-default-page-size 128)

(defn q-result-sqlite-conn-text [store: ^SQLite-Conn, text: string] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-text (addr snapshot) text)]
      (close-store-db! (addr snapshot))
      result)))

(defn q-result-sqlite-conn-text-with-input-text [store: ^SQLite-Conn, text: string, inputs-text: string] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-text-with-input-text (addr snapshot) text inputs-text)]
      (close-store-db! (addr snapshot))
      result)))

(defn q-result-sqlite-conn-prepared [store: ^SQLite-Conn, prepared: Prepared-Query] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-prepared (addr snapshot) prepared)]
      (close-store-db! (addr snapshot))
      result)))

(defn sqlite-store-db [store: ^SQLite-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [[sqlite-snapshot snapshot-ok snapshot-error] (sqlite-conn-open-db-snapshot store sqlite-db-source-default-page-size)]
    (if snapshot-ok
      (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: sqlite-snapshot}) true "")
      (return (Store-DB {}) false snapshot-error))))

(defn retain-sqlite-db-snapshot [snapshot: SQLite-DB-Snapshot] -> SQLite-DB-Snapshot
  (when (= snapshot.path "")
    (return (SQLite-DB-Snapshot {})))
  (let [[retained retained-ok _] (sqlite-open-db-snapshot-at-basis snapshot.path snapshot.basis-tx sqlite-db-source-default-page-size)]
    (if retained-ok
      retained
      (SQLite-DB-Snapshot {}))))

(defn shared-store-db [conn: ^Shared-Conn] -> Store-DB
  (Store-DB {kind: .Shared-Snapshot
             shared-snapshot: (retain-shared-db-snapshot conn^.snapshot)}))

(defn tx-op-owned [op: Tx-Op] -> Tx-Op
  (Tx-Op {kind: op.kind
          e: op.e
          a: (string-owned op.a)
          owned-attr: true
          v: (value-owned op.v)
          owned-value: true
          derived: op.derived
          tuple-identity: op.tuple-identity
          map-group: (string-owned op.map-group)}))

(defn tx-op-from-datom-owned [datom: Datom] -> Tx-Op
  (Tx-Op {kind: (if datom.added .Add .Retract)
          e: datom.e
          a: (string-owned datom.a)
          owned-attr: true
          v: (value-owned datom.v)
          owned-value: true}))

(defn tx-ops-from-datoms-owned [datoms: []Datom] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count datoms))]
    (for [datom datoms]
      (arr.push! out (tx-op-from-datom-owned datom)))
    out))

(defn clone-tx-ops-owned [ops: []Tx-Op] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (arr.push! out (tx-op-owned op)))
    out))

(defn delete-owned-tx-ops [ops: [dynamic]Tx-Op]
  (for [op ops]
    (when op.owned-attr
      (delete op.a))
    (when op.owned-value
      (delete-owned-value op.v))
    (when (not (= op.map-group ""))
      (delete op.map-group)))
  (delete ops))

(defn append-overlay-cardinality-one-retractions! [out: ^[dynamic]Tx-Op, op: Tx-Op]
  (let [index 0]
    (while (< index (count out^))
      (let [existing out^[index]]
        (if (and (= existing.kind .Add)
                 (= existing.e op.e)
                 (= existing.a op.a)
                 (not (value-equal? existing.v op.v)))
          (do
            (when existing.owned-attr
              (delete existing.a))
            (when existing.owned-value
              (delete-owned-value existing.v))
            (when (not (= existing.map-group ""))
              (delete existing.map-group))
            (arr.remove-ordered-at! out^ index))
          (set! index (+ index 1)))))))

(defn append-source-cardinality-one-retractions! [out: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (let [[existing existing-ok existing-error] (db-read-source-datoms-by-entity-attr source op.e op.a)]
    (when (not existing-ok)
      (return false existing-error))
    (for [datom existing]
      (when (not (value-equal? datom.v op.v))
        (arr.push! out^ (Tx-Op {kind: .Retract
                                e: datom.e
                                a: (string-owned datom.a)
                                owned-attr: true
                                v: (value-owned datom.v)
                                owned-value: true}))))
    (delete-owned-datoms existing)
    (return true "")))

(defn overlay-ops-declare-cardinality-many? [ops: []Tx-Op, attr: string] -> bool
  (let [schema-e: u64 0
        found-schema false]
    (for [op ops]
      (when (and (= op.kind .Add)
                 (= op.a ":db/ident")
                 (= op.v.kind .Keyword)
                 (= op.v.text attr))
        (set! schema-e op.e)
        (set! found-schema true)))
    (when (not found-schema)
      (return false))
    (for [op ops]
      (when (and (= op.kind .Add)
                 (= op.e schema-e)
                 (= op.a ":db/cardinality")
                 (= op.v.kind .Keyword)
                 (= op.v.text ":db.cardinality/many"))
        (return true))))
  false)

(defn overlay-ops-schema-entity-for-attr [ops: []Tx-Op, attr: string] -> [entity: u64, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.a ":db/ident")
               (= op.v.kind .Keyword)
               (= op.v.text attr))
      (return op.e true)))
  (return 0 false))

(defn overlay-ops-schema-ident-for-entity [ops: []Tx-Op, entity: u64] -> [attr: string, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.e entity)
               (= op.a ":db/ident")
               (= op.v.kind .Keyword))
      (return (string-owned op.v.text) true)))
  (return "" false))

(defn overlay-ops-schema-keyword-property [ops: []Tx-Op, entity: u64, schema-attr: string] -> [value: string, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.e entity)
               (= op.a schema-attr)
               (= op.v.kind .Keyword))
      (return (string-owned op.v.text) true)))
  (return "" false))

(defn overlay-ops-schema-keyword [ops: []Tx-Op, attr: string, schema-attr: string] -> [value: string, ok: bool]
  (let [[schema-e schema-ok] (overlay-ops-schema-entity-for-attr ops attr)]
    (when (not schema-ok)
      (return "" false))
    (overlay-ops-schema-keyword-property ops schema-e schema-attr)))

(defn shared-store-db-with-overlay [base: Shared-DB-Snapshot, ops: []Tx-Op, tx: u64] -> Store-DB
  (Store-DB {kind: .Shared-Tx-Ops-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-ops: (clone-tx-ops-owned ops)
             overlay-tx: tx}))

(defn sqlite-store-db-with-overlay [base: SQLite-DB-Snapshot, ops: []Tx-Op, tx: u64] -> Store-DB
  (Store-DB {kind: .SQLite-Tx-Ops-Overlay
             sqlite-snapshot: (retain-sqlite-db-snapshot base)
             overlay-ops: (clone-tx-ops-owned ops)
             overlay-tx: tx}))

(defn shared-store-db-with-datom-overlay [base: Shared-DB-Snapshot, datoms: []Datom] -> Store-DB
  (Store-DB {kind: .Shared-Datom-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-datoms: (clone-owned-datom-slice datoms)}))

(defn sqlite-store-db-with-datom-overlay [base: SQLite-DB-Snapshot, datoms: []Datom] -> Store-DB
  (Store-DB {kind: .SQLite-Datom-Overlay
             sqlite-snapshot: (retain-sqlite-db-snapshot base)
             overlay-datoms: (clone-owned-datom-slice datoms)}))

(defn shared-store-db-with-report-overlay [base: Shared-DB-Snapshot, report: Tx-Report] -> Store-DB
  (Store-DB {kind: .Shared-Tx-Ops-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-ops: (tx-ops-from-datoms-owned (slice report.tx-data 0))
             overlay-tx: report.tx}))

(defn sqlite-store-db-with-report-overlay [base: SQLite-DB-Snapshot, report: Tx-Report] -> Store-DB
  (Store-DB {kind: .SQLite-Tx-Ops-Overlay
             sqlite-snapshot: (retain-sqlite-db-snapshot base)
             overlay-ops: (tx-ops-from-datoms-owned (slice report.tx-data 0))
             overlay-tx: report.tx}))

(defn source-overlay-schema-unique-kind [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [unique-kind: string, unique: bool, ok: bool, error: string]
  (let [[unique-kind unique-ok unique-error] (db-read-source-schema-keyword source attr ":db/unique")]
    (when unique-ok
      (return unique-kind true true ""))
    (when (not (= unique-error ""))
      (return "" false false unique-error)))
  (let [[overlay-kind overlay-ok] (overlay-ops-schema-keyword ops attr ":db/unique")]
    (if overlay-ok
      (return overlay-kind true true "")
      (return "" false true ""))))

(defn source-overlay-schema-unique-identity? [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [identity: bool, ok: bool, error: string]
  (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source ops attr)]
    (when (not unique-ok)
      (return false false unique-error))
    (when (not unique)
      (return false true ""))
    (let [is-identity (= unique-kind ":db.unique/identity")]
      (delete unique-kind)
      (return is-identity true ""))))

(defn source-overlay-unique-error [source: DB-Read-Source, ops: []Tx-Op, op: Tx-Op] -> [error-text: string, ok: bool]
  (let [[identity identity-ok identity-error] (source-overlay-schema-unique-identity? source ops op.a)]
    (when (not identity-ok)
      (return identity-error false))
    (if (and identity (not op.tuple-identity))
      (return "conflicting upsert" true)
      (return "schema unique conflict" true))))

(defn source-overlay-existing-unique-conflict? [source: DB-Read-Source, op: Tx-Op] -> [conflict: bool, ok: bool, error: string]
  (let [out (make [dynamic]Datom)
        values ([]Value [(value-keyword op.a) op.v])
        [scan-ok scan-error] (db-read-source-append-index-datoms! (addr out) source .AVET values)]
    (when (not scan-ok)
      (delete-owned-datoms out)
      (return false false scan-error))
    (for [datom out]
      (when (not (= datom.e op.e))
        (delete-owned-datoms out)
        (return true true "")))
    (delete-owned-datoms out)
    (return false true "")))

(defn source-overlay-prior-unique-conflict? [ops: []Tx-Op, op: Tx-Op] -> bool
  (for [prior ops]
    (when (and (= prior.kind .Add)
               (= prior.a op.a)
               (value-equal? prior.v op.v)
               (not (= prior.e op.e)))
      (return true)))
  false)

(defn source-overlay-fact-matches? [fact: Tx-Op, op: Tx-Op] -> bool
  (and (= fact.e op.e)
       (= fact.a op.a)
       (value-equal? fact.v op.v)))

(defn source-overlay-prior-fact-state [ops: []Tx-Op, op: Tx-Op] -> [touched: bool, current: bool]
  (let [index (- (count ops) 1)]
    (while (>= index 0)
      (let [prior ops[index]]
        (when (source-overlay-fact-matches? prior op)
          (return true (= prior.kind .Add))))
      (set! index (- index 1))))
  (return false false))

(defn source-overlay-existing-current-fact? [source: DB-Read-Source, op: Tx-Op] -> [exists: bool, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source op.e op.a)]
    (when (not datoms-ok)
      (return false false datoms-error))
    (for [datom datoms]
      (when (value-equal? datom.v op.v)
        (delete-owned-datoms datoms)
        (return true true "")))
    (delete-owned-datoms datoms)
    (return false true "")))

(defn remove-source-overlay-prior-fact-retractions! [ops: ^[dynamic]Tx-Op, op: Tx-Op]
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [prior ops^[index]]
        (when (and (= prior.kind .Retract)
                   (source-overlay-fact-matches? prior op))
          (when prior.owned-attr
            (delete prior.a))
          (when prior.owned-value
            (delete-owned-value prior.v))
          (when (not (= prior.map-group ""))
            (delete prior.map-group))
          (arr.remove-ordered-at! ops^ index)))
      (set! index (- index 1)))))

(defn remove-source-overlay-current-fact! [facts: ^[dynamic]Tx-Op, op: Tx-Op]
  (let [out (make [dynamic]Tx-Op 0 (count facts^))]
    (for [fact facts^]
      (if (source-overlay-fact-matches? fact op)
        (do
          (when fact.owned-attr
            (delete fact.a))
          (when fact.owned-value
            (delete-owned-value fact.v))
          (when (not (= fact.map-group ""))
            (delete fact.map-group)))
        (arr.push! out fact)))
    (delete facts^)
    (set! facts^ out)))

(defn source-overlay-current-attr-facts [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [facts: [dynamic]Tx-Op, ok: bool, error: string]
  (let [current-facts (make [dynamic]Tx-Op)
        [source-datoms source-ok source-error] (db-read-source-datoms-by-attr source attr)]
    (when (not source-ok)
      (return current-facts false source-error))
    (for [datom source-datoms]
      (arr.push! current-facts (tx-op-from-datom-owned datom)))
    (delete-owned-datoms source-datoms)
    (for [op ops]
      (when (not (= op.a attr))
        (continue))
      (if (= op.kind .Retract)
        (remove-source-overlay-current-fact! (addr current-facts) op)
        (when (= op.kind .Add)
          (arr.push! current-facts (tx-op-owned op)))))
    (return current-facts true "")))

(defn validate-source-overlay-unique-attr [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [ok: bool, error: string]
  (let [[facts facts-ok facts-error] (source-overlay-current-attr-facts source ops attr)]
    (when (not facts-ok)
      (delete-owned-tx-ops facts)
      (return false facts-error))
    (let [seen (mmap.empty string u64)]
      (defer (delete seen))
      (for [fact facts]
        (let [[key key-ok] (unique-op-value-key fact)]
          (when (not key-ok)
            (delete-owned-tx-ops facts)
            (return false "schema unique value unsupported"))
          (let [[existing existing-ok] (mmap.get seen key)]
            (when (and existing-ok (not (= existing fact.e)))
              (delete key)
              (delete-owned-tx-ops facts)
              (return false "schema unique conflict")))
          (mmap.assoc! seen key fact.e))))
    (delete-owned-tx-ops facts)
    (return true "")))

(defn validate-source-overlay-new-unique-schemas [source: DB-Read-Source, ops: []Tx-Op] -> [ok: bool, error: string]
  (let [checked (mmap.empty string bool)]
    (defer (delete checked))
    (for [op ops]
      (when (not (and (= op.kind .Add)
                      (= op.a ":db/unique")
                      (= op.v.kind .Keyword)))
        (continue))
      (let [[attr attr-ok] (overlay-ops-schema-ident-for-entity ops op.e)]
        (when (not attr-ok)
          (let [[source-attr source-attr-ok source-attr-error] (db-read-source-schema-ident-for-entity source op.e)]
            (when (not source-attr-ok)
              (when (not (= source-attr-error ""))
                (return false source-attr-error))
              (continue))
            (let [[already _] (mmap.get checked source-attr)]
              (when already
                (delete source-attr)
                (continue))
                (let [[attr-ok attr-error] (validate-source-overlay-unique-attr source ops source-attr)]
                  (when (not attr-ok)
                    (delete source-attr)
                    (return false attr-error)))
                (mmap.assoc! checked source-attr true))
            (continue)))
        (let [[already _] (mmap.get checked attr)]
          (when already
            (delete attr)
            (continue))
            (let [[attr-ok attr-error] (validate-source-overlay-unique-attr source ops attr)]
              (when (not attr-ok)
                (delete attr)
                (return false attr-error)))
            (mmap.assoc! checked attr true)))))
  (return true ""))

(defn append-source-overlay-op! [out: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (when (= op.kind .Add)
    (let [[touched current] (source-overlay-prior-fact-state (slice out^ 0) op)]
      (when current
        (return true ""))
      (when touched
        (remove-source-overlay-prior-fact-retractions! out op))
      (let [[exists exists-ok exists-error] (source-overlay-existing-current-fact? source op)]
        (when (not exists-ok)
          (return false exists-error))
        (when exists
          (return true ""))))
    (let [[schema-type has-type type-ok type-error] (db-read-source-schema-value-type source op.a)]
      (when (not type-ok)
        (return false type-error))
      (when has-type
        (let [matches (value-matches-schema-type? op.v schema-type)]
          (delete schema-type)
          (when (not matches)
            (return false "schema value type mismatch")))))
    (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source (slice out^ 0) op.a)]
      (when (not unique-ok)
        (return false unique-error))
      (when unique
        (delete unique-kind)
        (when (source-overlay-prior-unique-conflict? (slice out^ 0) op)
          (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
            (return false (if error-ok error-text "schema unique conflict"))))
        (let [[conflict conflict-ok conflict-error] (source-overlay-existing-unique-conflict? source op)]
          (when (not conflict-ok)
            (return false conflict-error))
          (when conflict
            (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
              (return false (if error-ok error-text "schema unique conflict")))))))
    (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source op.a)]
      (when (not many-ok)
        (return false many-error))
      (when (and (not many)
                 (not (overlay-ops-declare-cardinality-many? (slice out^ 0) op.a)))
        (let [[source-ok source-error] (append-source-cardinality-one-retractions! out source op)]
          (when (not source-ok)
            (return false source-error)))
        (append-overlay-cardinality-one-retractions! out op))))
  (arr.push! out^ (tx-op-owned op))
  (return true ""))

(defn source-overlay-ops-from-resolved [source: DB-Read-Source, resolved: Resolved-Tx] -> [ops: [dynamic]Tx-Op, ok: bool, error: string]
  (source-overlay-ops-from-ops source (slice resolved.ops 0)))

(defn source-overlay-ops-from-ops [source: DB-Read-Source, ops: []Tx-Op] -> [out-ops: [dynamic]Tx-Op, ok: bool, error: string]
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (let [[append-ok append-error] (append-source-overlay-op! (addr out) source op)]
        (when (not append-ok)
          (delete-owned-tx-ops out)
          (return (make [dynamic]Tx-Op) false append-error))))
    (let [[unique-ok unique-error] (validate-source-overlay-new-unique-schemas source (slice out 0))]
      (when (not unique-ok)
        (delete-owned-tx-ops out)
        (return (make [dynamic]Tx-Op) false unique-error)))
    (return out true "")))

(defn shared-store-db-with-source-overlay-tx-data [snapshot: Shared-DB-Snapshot, tx-data: []Tx-Data] -> [next: Store-DB, used: bool, ok: bool, error: string]
  (let [base snapshot
        source (shared-db-snapshot-read-source (addr base))
        [state state-ok state-error] (shared-write-state-from-shared-snapshot-metadata base)]
    (when (not state-ok)
      (return (Store-DB {}) false false state-error))
    (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
      (when (not resolved.ok)
        (delete-resolved-tx resolved)
        (delete-shared-write-state-metadata state)
        (return (Store-DB {}) false true ""))
      (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
        (when (not overlay-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-DB {}) false false overlay-error))
        (let [out (shared-store-db-with-overlay base (slice overlay-ops 0) state.conn.next-tx)]
          (delete-owned-tx-ops overlay-ops)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return out true true ""))))))

(defn store-db-source-overlay-from-resolved [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64] -> Store-DB
  (case snapshot.kind
    .SQLite-Snapshot (sqlite-store-db-with-overlay snapshot.sqlite-snapshot overlay-ops tx)
    .Shared-Snapshot (shared-store-db-with-overlay snapshot.shared-snapshot overlay-ops tx)
    .SQLite-Tx-Ops-Overlay
      (let [datoms (make [dynamic]Datom)]
        (append-overlay-datoms-from-ops! (addr datoms) (slice snapshot.overlay-ops 0) snapshot.overlay-tx)
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (sqlite-store-db-with-datom-overlay snapshot.sqlite-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
    .SQLite-Datom-Overlay
      (let [datoms (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))]
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (sqlite-store-db-with-datom-overlay snapshot.sqlite-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
    .Shared-Tx-Ops-Overlay
      (let [datoms (make [dynamic]Datom)]
        (append-overlay-datoms-from-ops! (addr datoms) (slice snapshot.overlay-ops 0) snapshot.overlay-tx)
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (shared-store-db-with-datom-overlay snapshot.shared-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
    .Shared-Datom-Overlay
      (let [datoms (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))]
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (shared-store-db-with-datom-overlay snapshot.shared-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
     (Store-DB {})))

(defn store-db-with-source-overlay-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [next: Store-DB, used: bool, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-DB {}) false false source-error))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
      (when (not state-ok)
        (return (Store-DB {}) false false state-error))
      (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
        (when (not resolved.ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-DB {}) false true ""))
        (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
          (when (not overlay-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-DB {}) false false overlay-error))
          (let [out (store-db-source-overlay-from-resolved snapshot^ (slice overlay-ops 0) state.conn.next-tx)]
            (delete-owned-tx-ops overlay-ops)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return out true true "")))))))

(defstruct Store-Tx-Report {
  ok: bool
  error: string
  db-before: Store-DB
  db-after: Store-DB
  tx-data: [dynamic]Datom
  tx: u64
  tx-meta: [dynamic]Tx-Meta
  tempids: [dynamic]Tempid
  source-append-metadata-known: bool
  source-new-entities-after-existing: bool
  source-eavt-append-mode: bool
  source-aevt-append-mode: bool
  source-avet-append-mode: bool
  source-vaet-append-mode: bool
})

(defn store-tx-report-value [report: Store-Tx-Report] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool report.ok)
              (value-keyword ":error") (value-string report.error)
              (value-keyword ":tx") (if report.ok (value-entity report.tx) (value-nil))
              (value-keyword ":tx-data") (datoms-value (slice report.tx-data 0))
              (value-keyword ":tempids") (tempids-value (slice report.tempids 0))
              (value-keyword ":tx-meta") (tx-metas-value (slice report.tx-meta 0))])))

(defn delete-store-tx-report [report: Store-Tx-Report]
  (close-store-db report.db-before)
  (close-store-db report.db-after)
  (delete-owned-datoms report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids))

(defn failed-store-tx-report [snapshot: Store-DB, error: string] -> Store-Tx-Report
  (let [before (retain-store-db snapshot)]
    (Store-Tx-Report {ok: false
                      error: error
                      db-before: before
                      db-after: (retain-store-db before)
                      tx-data: (make [dynamic]Datom)
                      tx: 0
                      tx-meta: (make [dynamic]Tx-Meta)
                      tempids: (make [dynamic]Tempid)
                      source-append-metadata-known: false
                      source-new-entities-after-existing: false
                      source-eavt-append-mode: false
                      source-aevt-append-mode: false
                      source-avet-append-mode: false
                      source-vaet-append-mode: false})))

(defn failed-owned-store-tx-report [snapshot: Store-DB, error: string] -> Store-Tx-Report
  (let [out (failed-store-tx-report snapshot error)]
    (close-store-db snapshot)
    out))

(defn store-report-tempids-with-current-tx [tempids: []Tempid, tx: u64] -> [dynamic]Tempid
  (let [out (arr.into [dynamic]Tempid tempids)
        [_ has-current-tx] (tempid-lookup (slice out 0) ":db/current-tx")]
    (when (not has-current-tx)
      (arr.push! out (Tempid {tempid: ":db/current-tx" e: tx})))
    out))

(defn store-tx-report-from-resident-report [report: Tx-Report] -> Store-Tx-Report
  (let [before (Store-DB {kind: .Resident resident: (clone-db report.db-before)})
        after (Store-DB {kind: .Resident resident: (clone-db report.db-after)})
        tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Store-Tx-Report {ok: report.ok
                      error: report.error
                      db-before: before
                      db-after: after
                      tx-data: (clone-datoms report.tx-data)
                      tx: report.tx
                      tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                      tempids: tempids
                      source-append-metadata-known: false
                      source-new-entities-after-existing: false
                      source-eavt-append-mode: false
                      source-aevt-append-mode: false
                      source-avet-append-mode: false
                      source-vaet-append-mode: false})))

(defn delete-temp-resident-store-report-source [report: Tx-Report]
  (if report.ok
    (delete-live-tx-report-shallow report)
    (do
      (delete report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))))

(defn store-tx-report-from-temp-resident-report [report: Tx-Report] -> Store-Tx-Report
  (let [out (store-tx-report-from-resident-report report)]
    (delete-temp-resident-store-report-source report)
    out))

(defn failed-sqlite-store-tx-report [store: ^SQLite-Conn, error: string] -> Store-Tx-Report
  (let [[snapshot snapshot-ok _] (sqlite-store-db store)]
    (if snapshot-ok
      (failed-owned-store-tx-report snapshot error)
      (failed-store-tx-report (Store-DB {}) error))))

(defn transact-sqlite-store-report-direct-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (when store^.resident-loaded
    (return (Store-Tx-Report {}) false true ""))
  (let [[before before-ok before-error] (sqlite-store-db store)]
    (when (not before-ok)
      (if (= before-error "sqlite DB has no Vev index roots")
        (return (Store-Tx-Report {}) false true "")
        (return (Store-Tx-Report {}) false false before-error)))
    (let [[source source-ok source-error] (store-db-read-source (addr before))]
      (when (not source-ok)
        (close-store-db before)
        (return (Store-Tx-Report {}) false false source-error))
      (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
        (when (not state-ok)
          (close-store-db before)
          (return (Store-Tx-Report {}) false false state-error))
        (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
          (when (not resolved.ok)
            (let [failed (failed-store-tx-report before resolved.error)]
              (delete-resolved-tx resolved)
              (delete-shared-write-state-metadata state)
              (close-store-db before)
              (return failed true true "")))
          (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
            (when (not overlay-ok)
              (delete-resolved-tx resolved)
              (delete-shared-write-state-metadata state)
              (close-store-db before)
              (return (Store-Tx-Report {}) false false overlay-error))
            (let [tx state.conn.next-tx
                  start-index before.sqlite-snapshot.datom-count
                  new-entities-after-existing (source-append-ops-all-new-entities? state.next-entity-id (slice overlay-ops 0))
                  appended (source-overlay-datoms-from-ops (slice overlay-ops 0) tx)]
              (let [[eavt eavt-appended-only aevt aevt-appended-only avet avet-appended-only vaet vaet-appended-only indexes-ok indexes-error] (source-append-build-indexes-for-persist source (slice appended 0) start-index new-entities-after-existing)]
                (when (not indexes-ok)
                  (delete-owned-datoms appended)
                  (delete-owned-tx-ops overlay-ops)
                  (delete-resolved-tx resolved)
                  (delete-shared-write-state-metadata state)
                  (close-store-db before)
                  (return (Store-Tx-Report {}) false false indexes-error))
                (close-store-db before)
                (let [[append-ok append-error] (append-source-direct-sqlite-handle store^.handle start-index tx (slice appended 0) (slice resolved.tx-meta 0) (slice eavt 0) eavt-appended-only (slice aevt 0) aevt-appended-only (slice avet 0) avet-appended-only (slice vaet 0) vaet-appended-only)]
                  (delete eavt)
                  (delete aevt)
                  (delete avet)
                  (delete vaet)
                  (when (not append-ok)
                    (delete-owned-datoms appended)
                    (delete-owned-tx-ops overlay-ops)
                    (delete-resolved-tx resolved)
                    (delete-shared-write-state-metadata state)
                    (let [[failed-before failed-before-ok _] (sqlite-store-db store)]
                      (if failed-before-ok
                        (return (failed-store-tx-report failed-before append-error) true true "")
                        (return (Store-Tx-Report {}) false false append-error))))
                  (let [[report-before report-before-ok report-before-error] (sqlite-open-db-snapshot-at-basis store^.path (- tx 1) sqlite-db-source-default-page-size)]
                    (when (not report-before-ok)
                      (delete-owned-datoms appended)
                      (delete-owned-tx-ops overlay-ops)
                      (delete-resolved-tx resolved)
                      (delete-shared-write-state-metadata state)
                      (return (Store-Tx-Report {}) false false report-before-error))
                    (let [[report-after report-after-ok report-after-error] (sqlite-open-db-snapshot-at-basis store^.path tx sqlite-db-source-default-page-size)]
                      (when (not report-after-ok)
                        (close-sqlite-db-snapshot report-before)
                        (delete-owned-datoms appended)
                        (delete-owned-tx-ops overlay-ops)
                        (delete-resolved-tx resolved)
                        (delete-shared-write-state-metadata state)
                        (return (Store-Tx-Report {}) false false report-after-error))
                      (let [report-tempids (store-report-tempids-with-current-tx (slice resolved.tempids 0) tx)
                            out-report (Store-Tx-Report {ok: true
                                                         error: ""
                                                         db-before: (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: report-before})
                                                         db-after: (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: report-after})
                                                         tx-data: (clone-owned-datom-slice (slice appended 0))
                                                         tx: tx
                                                         tx-meta: (clone-tx-meta (slice resolved.tx-meta 0))
                                                         tempids: report-tempids
                                                         source-append-metadata-known: true
                                                         source-new-entities-after-existing: new-entities-after-existing
                                                         source-eavt-append-mode: eavt-appended-only
                                                         source-aevt-append-mode: aevt-appended-only
                                                         source-avet-append-mode: avet-appended-only
                                                         source-vaet-append-mode: vaet-appended-only})]
                        (delete-owned-datoms appended)
                        (delete-owned-tx-ops overlay-ops)
                        (delete-resolved-tx resolved)
                        (delete-shared-write-state-metadata state)
                        (return out-report true true "")))))))))))))

(defn source-overlay-datoms-from-ops [ops: []Tx-Op, tx: u64] -> [dynamic]Datom
  (let [out (make [dynamic]Datom 0 (count ops))]
    (for [op ops]
      (let [datom (Datom {e: op.e
                          a: op.a
                          v: op.v
                          tx: tx
                          added: (= op.kind .Add)})]
        (arr.push! out (datom-owned datom))))
    out))

(defn clone-owned-datom-slice [datoms: []Datom] -> [dynamic]Datom
  (let [out (make [dynamic]Datom 0 (count datoms))]
    (for [datom datoms]
      (arr.push! out (datom-owned datom)))
    out))

(defn append-overlay-datoms-from-ops! [out: ^[dynamic]Datom, ops: []Tx-Op, tx: u64]
  (for [op ops]
    (let [datom (Datom {e: op.e
                        a: op.a
                        v: op.v
                        tx: tx
                        added: (= op.kind .Add)})]
      (arr.push! out^ (datom-owned datom)))))

(defn store-source-append-modes-for-report [snapshot: Store-DB, datoms: []Datom, new-entities-after-existing: bool] -> [known: bool, eavt-mode: bool, aevt-mode: bool, avet-mode: bool, vaet-mode: bool]
  (let [snapshot-value snapshot
        [source source-ok _] (store-db-read-source (addr snapshot-value))]
    (when (not source-ok)
      (return false false false false false))
    (let [view (db-read-source-index-view source .EAVT)
          start-index (db-index-view-count view)
          [eavt-mode-value aevt-mode-value avet-mode-value vaet-mode-value modes-ok _] (source-append-index-modes-for-persist source datoms start-index new-entities-after-existing)]
      (if modes-ok
        (return true eavt-mode-value aevt-mode-value avet-mode-value vaet-mode-value)
        (return false false false false false)))))

(defn store-tx-report-from-source-overlay-parts [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64, tx-meta: []Tx-Meta, tempids: []Tempid, next-entity: u64] -> Store-Tx-Report
  (let [tx-data (source-overlay-datoms-from-ops overlay-ops tx)
        cloned-tempids (store-report-tempids-with-current-tx tempids tx)
        new-entities-after-existing (source-append-ops-all-new-entities? next-entity overlay-ops)
        [modes-known eavt-mode aevt-mode avet-mode vaet-mode] (store-source-append-modes-for-report snapshot (slice tx-data 0) new-entities-after-existing)]
    (Store-Tx-Report {ok: true
                      error: ""
                      db-before: (retain-store-db snapshot)
                      db-after: (store-db-source-overlay-from-resolved snapshot overlay-ops tx)
                      tx-data: tx-data
                      tx: tx
                      tx-meta: (clone-tx-meta tx-meta)
                      tempids: cloned-tempids
                      source-append-metadata-known: modes-known
                      source-new-entities-after-existing: new-entities-after-existing
                      source-eavt-append-mode: (and modes-known eavt-mode)
                      source-aevt-append-mode: (and modes-known aevt-mode)
                      source-avet-append-mode: (and modes-known avet-mode)
                      source-vaet-append-mode: (and modes-known vaet-mode)})))

(defn store-tx-report-from-source-overlay [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64, resolved: Resolved-Tx, next-entity: u64] -> Store-Tx-Report
  (store-tx-report-from-source-overlay-parts snapshot overlay-ops tx (slice resolved.tx-meta 0) (slice resolved.tempids 0) next-entity))

(defn with-shared-store-db-source-overlay-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (let [base snapshot^.shared-snapshot
        source (shared-db-snapshot-read-source (addr base))
        [state state-ok state-error] (shared-write-state-from-shared-snapshot-metadata base)]
    (when (not state-ok)
      (return (Store-Tx-Report {}) false false state-error))
    (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
      (when (not resolved.ok)
        (delete-resolved-tx resolved)
        (delete-shared-write-state-metadata state)
        (return (Store-Tx-Report {}) false true ""))
      (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
        (when (not overlay-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-Tx-Report {}) false false overlay-error))
        (let [out-report (store-tx-report-from-source-overlay snapshot^ (slice overlay-ops 0) state.conn.next-tx resolved state.next-entity-id)]
          (delete-owned-tx-ops overlay-ops)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return out-report true true ""))))))

(defn with-store-db-source-overlay-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-Tx-Report {}) false false source-error))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
      (when (not state-ok)
        (return (Store-Tx-Report {}) false false state-error))
      (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
        (when (not resolved.ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-Tx-Report {}) false true ""))
        (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
          (when (not overlay-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-Tx-Report {}) false false overlay-error))
          (let [out-report (store-tx-report-from-source-overlay snapshot^ (slice overlay-ops 0) state.conn.next-tx resolved state.next-entity-id)]
            (delete-owned-tx-ops overlay-ops)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return out-report true true "")))))))

(defn failed-store-source-registered-tx [snapshot: Store-DB, ops: [dynamic]Tx-Op, tx-meta: [dynamic]Tx-Meta, tempids: [dynamic]Tempid, segment: [dynamic]Tx-Data, error: string] -> Store-Tx-Report
  (delete ops)
  (delete tx-meta)
  (delete tempids)
  (delete segment)
  (failed-store-tx-report snapshot error))

(defn with-store-db-report-tx-data-with-source-string-fns [snapshot: ^Store-DB, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (when (not (source-backed-store-db? snapshot))
    (return (failed-store-tx-report snapshot^ "source transaction functions require a source-backed Store-DB")))
  (let [[base-source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (failed-store-tx-report snapshot^ source-error)))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata base-source)]
      (when (not state-ok)
        (return (failed-store-tx-report snapshot^ state-error)))
      (let [[duplicate-ident has-duplicate] (tx-fn-source-string-duplicate-ident registry)
            tx state.conn.next-tx
            ops (make [dynamic]Tx-Op)
            tx-meta (make [dynamic]Tx-Meta)
            tempids (make [dynamic]Tempid)
            segment (make [dynamic]Tx-Data)]
        (when has-duplicate
          (delete-shared-write-state-metadata state)
          (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment (fmt.tprintf "duplicate transaction fn registration: %s" duplicate-ident))))
        (for [data tx-data]
          (when (= data.op ":db.fn/call-ident")
            (let [current-source (tx-ops-overlay-db-read-source (addr base-source) (addr ops) tx)
                  [segment-ok segment-error] (resolve-shared-source-tx-segment! (addr state) current-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
              (when (not segment-ok)
                (delete-shared-write-state-metadata state)
                (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment segment-error)))
              (let [call-source (tx-ops-overlay-db-read-source (addr base-source) (addr ops) tx)
                    [fn-index fn-ok] (tx-fn-source-string-index registry data.ident)]
                (when (not fn-ok)
                  (delete-shared-write-state-metadata state)
                  (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment "transaction fn not registered")))
                (let [result (call-source-registered-tx-fn registry[fn-index] call-source data)]
                  (when (not result.ok)
                    (delete result.tx-data)
                    (delete-shared-write-state-metadata state)
                    (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment result.error)))
                  (let [result-source (tx-ops-overlay-db-read-source (addr base-source) (addr ops) tx)
                        [result-ok result-error] (resolve-shared-source-tx-segment! (addr state) result-source (addr ops) (addr tx-meta) (addr tempids) (addr result.tx-data))]
                    (delete result.tx-data)
                    (when (not result-ok)
                      (delete-shared-write-state-metadata state)
                      (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment result-error)))))))
            (continue))
          (arr.push! segment data))
        (let [tail-source (tx-ops-overlay-db-read-source (addr base-source) (addr ops) tx)
              [tail-ok tail-error] (resolve-shared-source-tx-segment! (addr state) tail-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
          (when (not tail-ok)
            (delete-shared-write-state-metadata state)
            (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment tail-error))))
        (delete segment)
        (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-ops base-source (slice ops 0))]
          (when (not overlay-ok)
            (delete ops)
            (delete tx-meta)
            (delete tempids)
            (delete-shared-write-state-metadata state)
            (return (failed-store-tx-report snapshot^ overlay-error)))
          (let [report (store-tx-report-from-source-overlay-parts snapshot^ (slice overlay-ops 0) tx (slice tx-meta 0) (slice tempids 0) state.next-entity-id)]
            (delete-owned-tx-ops overlay-ops)
            (delete ops)
            (delete tx-meta)
            (delete tempids)
            (delete-shared-write-state-metadata state)
            report))))))

(defn retain-store-db [snapshot: Store-DB] -> Store-DB
  (case snapshot.kind
    .Resident (Store-DB {kind: .Resident
                         resident: (clone-db snapshot.resident)})
    .SQLite-Snapshot (Store-DB {kind: .SQLite-Snapshot
                                sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)})
    .SQLite-Tx-Ops-Overlay
      (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)
                 overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                 overlay-tx: snapshot.overlay-tx})
    .SQLite-Datom-Overlay
      (Store-DB {kind: .SQLite-Datom-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)
                 overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))})
    .Shared-Snapshot (Store-DB {kind: .Shared-Snapshot
                                shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)})
    .Shared-Tx-Ops-Overlay (Store-DB {kind: .Shared-Tx-Ops-Overlay
                                      shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)
                                      overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                                      overlay-tx: snapshot.overlay-tx})
    .Shared-Datom-Overlay (Store-DB {kind: .Shared-Datom-Overlay
                                     shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)
                                     overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))})
     (Store-DB {})))

(defn store-db-from-read-source [source: DB-Read-Source] -> [snapshot: Store-DB, ok: bool, error: string]
  (case source.kind
    .Resident
      (return (Store-DB {kind: .Resident
                         resident: (clone-db source.db^)})
              true
              "")
    .Shared-Resident-Indexes
      (return (Store-DB {kind: .Resident
                         resident: (clone-db source.db^)})
              true
              "")
    .Shared-Resident-Datoms-And-Indexes
      (return (Store-DB {kind: .Shared-Snapshot
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})})
              true
              "")
    .Shared-Tx-Ops-Overlay
      (return (Store-DB {kind: .Shared-Tx-Ops-Overlay
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})
                         overlay-ops: (clone-tx-ops-owned (slice source.overlay-ops^ 0))
                         overlay-tx: source.overlay-tx})
              true
              "")
    .Shared-Datom-Overlay
      (return (Store-DB {kind: .Shared-Datom-Overlay
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})
                         overlay-datoms: (clone-owned-datom-slice (slice source.overlay-datoms^ 0))})
              true
              "")
    .SQLite-Snapshot
      (return (Store-DB {kind: .SQLite-Snapshot
                         sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)})
              true
              "")
    .SQLite-Tx-Ops-Overlay
      (return (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                         sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)
                         overlay-ops: (clone-tx-ops-owned (slice source.overlay-ops^ 0))
                         overlay-tx: source.overlay-tx})
              true
              "")
    .SQLite-Datom-Overlay
      (return (Store-DB {kind: .SQLite-Datom-Overlay
                         sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)
                         overlay-datoms: (clone-owned-datom-slice (slice source.overlay-datoms^ 0))})
              true
              "")
    .Tx-Ops-Overlay
      (let [[base base-ok base-error] (store-db-from-read-source source.overlay-base^)]
        (when (not base-ok)
          (return (Store-DB {}) false base-error))
        (let [out (store-db-source-overlay-from-resolved base (slice source.overlay-ops^ 0) source.overlay-tx)]
          (close-store-db base)
          (return out true "")))
    .Relation-Value
      (return (Store-DB {}) false "relation-value source cannot be exposed as a DB handle")
     (return (Store-DB {}) false "unsupported read source for DB handle")))

(defn store-db-read-source [snapshot: ^Store-DB] -> [source: DB-Read-Source, ok: bool, error: string]
  (case snapshot^.kind
    .Resident (return (resident-db-read-source (addr snapshot^.resident)) true "")
    .SQLite-Snapshot (return (sqlite-db-read-source (addr snapshot^.sqlite-snapshot)) true "")
    .SQLite-Tx-Ops-Overlay (return (sqlite-tx-ops-overlay-db-read-source (addr snapshot^.sqlite-snapshot) (addr snapshot^.overlay-ops) snapshot^.overlay-tx) true "")
    .SQLite-Datom-Overlay (return (sqlite-datom-overlay-db-read-source (addr snapshot^.sqlite-snapshot) (addr snapshot^.overlay-datoms)) true "")
    .Shared-Snapshot (return (shared-db-snapshot-read-source (addr snapshot^.shared-snapshot)) true "")
    .Shared-Tx-Ops-Overlay (return (shared-tx-ops-overlay-db-read-source (addr snapshot^.shared-snapshot.datoms) (addr snapshot^.shared-snapshot.indexes) (addr snapshot^.overlay-ops) snapshot^.overlay-tx) true "")
    .Shared-Datom-Overlay (return (shared-datom-overlay-db-read-source (addr snapshot^.shared-snapshot.datoms) (addr snapshot^.shared-snapshot.indexes) (addr snapshot^.overlay-datoms)) true "")
     (return (DB-Read-Source {}) false "store DB snapshot is not open")))

(defn q-result-store-db-text [snapshot: ^Store-DB, text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source source text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-text [snapshot: ^Store-DB, text: string] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-text-db-read-source-profiled source text)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source-with-input-text source text inputs-text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-text-db-read-source-profiled-with-input-text source text inputs-text)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-prepared [snapshot: ^Store-DB, prepared: Prepared-Query] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source source prepared)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-prepared [snapshot: ^Store-DB, prepared: Prepared-Query] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-prepared-db-read-source-profiled source prepared)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-prepared-with-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, inputs-text: string] -> Query-Result
  (when (not prepared.ok)
    (return (query-result-owned-values (result-set-error prepared.error))))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (query-result-owned-values (result-set-error source-error))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
      (when (not input-ok)
        (delete inputs)
        (return (query-result-owned-values (result-set-error input-error))))
      (let [result (db-read-source-q-query-with-inputs source prepared.query (slice inputs 0))]
        (delete inputs)
        (query-result-owned-values result)))))

(defn q-profiled-store-db-prepared-with-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, inputs-text: string] -> Profiled-Result-Set
  (when (not prepared.ok)
    (return (profiled-result-set (result-set-error prepared.error) (query-stats-empty))))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (profiled-result-set (result-set-error source-error) (query-stats-empty))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
      (when (not input-ok)
        (delete inputs)
        (return (profiled-result-set (result-set-error input-error) (query-stats-empty))))
      (let [profiled (q-prepared-db-read-source-profiled-with-inputs source prepared (slice inputs 0))]
        (delete inputs)
        profiled))))

(defn store-db-result-value [snapshot: ^Store-DB, result: Result-Set] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (db-read-source-result-set-value source result)
      (return (Value {}) false source-error))))

(defn store-db-materialize-db [snapshot: ^Store-DB] -> [db: DB, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (build-db (make [dynamic]Datom)) false source-error))
    (db-read-source-materialize-db source)))

(defn with-store-db-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Tx-Report
  (when (source-backed-store-db? snapshot)
    (return (failed-tx-report
              (build-db (make [dynamic]Datom))
              "with-store-db-tx-data is resident-only; use with-store-db-report-tx-data for source-backed Store-DB values")))
  (let [[db db-ok db-error] (store-db-materialize-db snapshot)]
    (when (not db-ok)
      (return (failed-tx-report db db-error)))
    (with-tx-data db tx-data)))

(defn with-store-db-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Store-Tx-Report
  (when (source-backed-store-db? snapshot)
    (let [[report used ok error] (with-store-db-source-overlay-report-tx-data snapshot tx-data)]
      (when ok
        (when used
          (return report)))
      (when (not ok)
        (return (failed-store-tx-report snapshot^ error)))))
  (when (source-backed-store-db? snapshot)
    (return (failed-store-tx-report snapshot^ "transaction shape requires resident materialization for source-backed Store-DB")))
  (let [resident-report (with-store-db-tx-data snapshot tx-data)
        before (Store-DB {kind: .Resident resident: (clone-db resident-report.db-before)})
        after (Store-DB {kind: .Resident resident: (clone-db resident-report.db-after)})
        tempids (arr.into [dynamic]Tempid (slice resident-report.tempids 0))
        report (Store-Tx-Report {ok: resident-report.ok
                                 error: resident-report.error
                                 db-before: before
                                 db-after: after
                                 tx-data: (clone-datoms resident-report.tx-data)
                                 tx: resident-report.tx
                                 tx-meta: (clone-tx-meta (slice resident-report.tx-meta 0))
                                 tempids: tempids
                                 source-append-metadata-known: false
                                 source-new-entities-after-existing: false
                                 source-eavt-append-mode: false
                                 source-aevt-append-mode: false
                                 source-avet-append-mode: false
                                 source-vaet-append-mode: false})]
    (delete-store-db-temp-tx-report resident-report)
    report))

(defn delete-store-db-temp-tx-report [report: Tx-Report]
  (if report.ok
    (delete-tx-report-shallow report)
    (do
      (delete-owned-db report.db-before)
      (delete report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))))

(defn db-with-store-db-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Store-DB
  (when (= snapshot^.kind .Shared-Snapshot)
    (let [[source-snapshot source-used source-ok _] (shared-db-snapshot-db-with-source-append-tx-data snapshot^.shared-snapshot tx-data)]
      (when source-ok
        (when source-used
          (return (Store-DB {kind: .Shared-Snapshot
                             shared-snapshot: source-snapshot}))))
      (let [[overlay-snapshot overlay-used overlay-ok _] (shared-store-db-with-source-overlay-tx-data snapshot^.shared-snapshot tx-data)]
        (when overlay-ok
          (when overlay-used
            (return overlay-snapshot))))))
  (when (= snapshot^.kind .SQLite-Snapshot)
    (let [[overlay-snapshot overlay-used overlay-ok _] (store-db-with-source-overlay-tx-data snapshot tx-data)]
      (when overlay-ok
        (when overlay-used
          (return overlay-snapshot)))))
  (when (or (= snapshot^.kind .Shared-Tx-Ops-Overlay)
            (= snapshot^.kind .SQLite-Tx-Ops-Overlay)
            (= snapshot^.kind .Shared-Datom-Overlay)
            (= snapshot^.kind .SQLite-Datom-Overlay))
    (let [[overlay-snapshot overlay-used overlay-ok _] (store-db-with-source-overlay-tx-data snapshot tx-data)]
      (when overlay-ok
        (when overlay-used
          (return overlay-snapshot)))))
  (when (source-backed-store-db? snapshot)
    (let [report (with-store-db-report-tx-data snapshot tx-data)
          out (if report.ok
                (retain-store-db report.db-after)
                (retain-store-db report.db-before))]
      (delete-store-tx-report report)
      (return out)))
  (let [report (with-store-db-tx-data snapshot tx-data)]
    (case snapshot^.kind
      .SQLite-Snapshot
        (if report.ok
          (let [out (sqlite-store-db-with-report-overlay snapshot^.sqlite-snapshot report)]
            (delete-store-db-temp-tx-report report)
            out)
          (let [out (retain-store-db snapshot^)]
            (delete-store-db-temp-tx-report report)
            out))
      .Shared-Snapshot
        (if report.ok
          (let [out (shared-store-db-with-report-overlay snapshot^.shared-snapshot report)]
            (delete-store-db-temp-tx-report report)
            out)
          (let [out (retain-store-db snapshot^)]
            (delete-store-db-temp-tx-report report)
            out))
      (if report.ok
        (let [out (Store-DB {kind: .Resident
                             resident: (clone-db report.db-after)})]
          (delete-store-db-temp-tx-report report)
          out)
        (let [out (Store-DB {kind: .Resident
                             resident: (clone-db report.db-before)})]
          (delete-store-db-temp-tx-report report)
          out)))))

(defn source-backed-store-db? [snapshot: ^Store-DB] -> bool
  (or (= snapshot^.kind .Shared-Snapshot)
      (= snapshot^.kind .SQLite-Snapshot)
      (= snapshot^.kind .Shared-Tx-Ops-Overlay)
      (= snapshot^.kind .SQLite-Tx-Ops-Overlay)
      (= snapshot^.kind .Shared-Datom-Overlay)
      (= snapshot^.kind .SQLite-Datom-Overlay)))

(defn with-store-db-text [snapshot: ^Store-DB, text: string] -> Tx-Report
  (when (source-backed-store-db? snapshot)
    (return (failed-tx-report
              (build-db (make [dynamic]Datom))
              "with-store-db-text is resident-only; use with-store-db-report-text for source-backed Store-DB values")))
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (let [[db db-ok _] (store-db-materialize-db snapshot)]
        (return (failed-tx-report db parse-error))))
    (with-store-db-tx-data snapshot (slice tx-data 0))))

(defn with-store-db-report-text [snapshot: ^Store-DB, text: string] -> Store-Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (if parse-ok
      (with-store-db-report-tx-data snapshot (slice tx-data 0))
      (failed-store-tx-report snapshot^ parse-error))))

(defn with-store-db-report-text-with-source-string-fns [snapshot: ^Store-DB, text: string, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (if parse-ok
      (with-store-db-report-tx-data-with-source-string-fns snapshot (slice tx-data 0) registry)
      (failed-store-tx-report snapshot^ parse-error))))

(defn db-with-store-db-tx-data-with-source-string-fns [snapshot: ^Store-DB, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-DB
  (let [report (with-store-db-report-tx-data-with-source-string-fns snapshot tx-data registry)
        out (if report.ok
              (retain-store-db report.db-after)
              (retain-store-db report.db-before))]
    (delete-store-tx-report report)
    out))

(defn db-with-store-db-text-with-source-string-fns [snapshot: ^Store-DB, text: string, registry: []Tx-Fn-Source-String] -> Store-DB
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok _] (parse-tx-text! (addr tx-data) text)]
    (if parse-ok
      (db-with-store-db-tx-data-with-source-string-fns snapshot (slice tx-data 0) registry)
      (retain-store-db snapshot^))))

(defn source-append-build-indexes-for-store-report [source: DB-Read-Source, report: Store-Tx-Report, start-index: int] -> [eavt: [dynamic]int, eavt-append-mode: bool, aevt: [dynamic]int, aevt-append-mode: bool, avet: [dynamic]int, avet-append-mode: bool, vaet: [dynamic]int, vaet-append-mode: bool, ok: bool, error: string]
  (if report.source-append-metadata-known
    (let [[eavt aevt avet vaet indexes-ok indexes-error] (source-append-build-indexes-for-persist-modes source
                                                                                                       (slice report.tx-data 0)
                                                                                                       start-index
                                                                                                       report.source-eavt-append-mode
                                                                                                       report.source-aevt-append-mode
                                                                                                       report.source-avet-append-mode
                                                                                                       report.source-vaet-append-mode)]
      (return eavt
              report.source-eavt-append-mode
              aevt
              report.source-aevt-append-mode
              avet
              report.source-avet-append-mode
              vaet
              report.source-vaet-append-mode
              indexes-ok
              indexes-error))
    (source-append-build-indexes-for-persist source
                                             (slice report.tx-data 0)
                                             start-index
                                             report.source-new-entities-after-existing)))

(defn sqlite-commit-source-overlay-report [store: ^SQLite-Conn, overlay-report: Store-Tx-Report] -> Store-Tx-Report
  (when (not overlay-report.ok)
    (return overlay-report))
  (when (not (= overlay-report.db-before.kind .SQLite-Snapshot))
    (let [failed (failed-store-tx-report overlay-report.db-before "source transaction functions require a SQLite-backed Store-DB")]
      (delete-store-tx-report overlay-report)
      (return failed)))
  (let [before-snapshot overlay-report.db-before.sqlite-snapshot
        source (sqlite-db-read-source (addr before-snapshot))
        start-index before-snapshot.datom-count]
    (let [[eavt eavt-appended-only aevt aevt-appended-only avet avet-appended-only vaet vaet-appended-only indexes-ok indexes-error] (source-append-build-indexes-for-store-report source overlay-report start-index)]
    (when (not indexes-ok)
      (let [failed (failed-store-tx-report overlay-report.db-before indexes-error)]
        (delete-store-tx-report overlay-report)
        (return failed)))
    (let [[append-ok append-error] (append-source-direct-sqlite-handle store^.handle start-index overlay-report.tx (slice overlay-report.tx-data 0) (slice overlay-report.tx-meta 0) (slice eavt 0) eavt-appended-only (slice aevt 0) aevt-appended-only (slice avet 0) avet-appended-only (slice vaet 0) vaet-appended-only)]
      (delete eavt)
      (delete aevt)
      (delete avet)
      (delete vaet)
      (when (not append-ok)
        (let [failed (failed-store-tx-report overlay-report.db-before append-error)]
          (delete-store-tx-report overlay-report)
          (return failed)))
      (let [[report-before report-before-ok report-before-error] (sqlite-open-db-snapshot-at-basis store^.path (- overlay-report.tx 1) sqlite-db-source-default-page-size)]
        (when (not report-before-ok)
          (let [failed (failed-store-tx-report overlay-report.db-after report-before-error)]
            (delete-store-tx-report overlay-report)
            (return failed)))
        (let [[report-after report-after-ok report-after-error] (sqlite-open-db-snapshot-at-basis store^.path overlay-report.tx sqlite-db-source-default-page-size)]
          (when (not report-after-ok)
            (close-sqlite-db-snapshot report-before)
            (let [failed (failed-store-tx-report overlay-report.db-after report-after-error)]
              (delete-store-tx-report overlay-report)
              (return failed)))
          (let [out (Store-Tx-Report {ok: true
                                      error: ""
                                      db-before: (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: report-before})
                                      db-after: (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: report-after})
                                      tx-data: (clone-owned-datom-slice (slice overlay-report.tx-data 0))
                                      tx: overlay-report.tx
                                      tx-meta: (clone-tx-meta (slice overlay-report.tx-meta 0))
                                      tempids: (store-report-tempids-with-current-tx (slice overlay-report.tempids 0) overlay-report.tx)
                                      source-append-metadata-known: overlay-report.source-append-metadata-known
                                      source-new-entities-after-existing: overlay-report.source-new-entities-after-existing
                                      source-eavt-append-mode: overlay-report.source-eavt-append-mode
                                      source-aevt-append-mode: overlay-report.source-aevt-append-mode
                                      source-avet-append-mode: overlay-report.source-avet-append-mode
                                      source-vaet-append-mode: overlay-report.source-vaet-append-mode})]
            (delete-store-tx-report overlay-report)
            out)))))))

(defn db-with-store-db-text [snapshot: ^Store-DB, text: string] -> Store-DB
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok _] (parse-tx-text! (addr tx-data) text)]
    (if parse-ok
      (db-with-store-db-tx-data snapshot (slice tx-data 0))
      (retain-store-db snapshot^))))

(defn q-store-db-value-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> [value: Value, ok: bool, error: string]
  (let [result (q-result-store-db-text-with-input-text snapshot text inputs-text)]
    (defer (delete-query-result result))
    (if result.result.ok
      (store-db-result-value snapshot result.result)
      (return (value-map
                ([]Value [(value-keyword ":ok") (value-bool false)
                          (value-keyword ":error") (value-string result.result.error)
                          (value-keyword ":rows") (value-vector ([]Value []))]))
              true
              ""))))

(defn pull-store-db-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, entity: u64] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity pattern)]
      (when (not pull-ok)
        (return (Value {}) false pull-error))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-result-value source pull)]
        (delete-pull-result-owned-values pull)
        (return rendered rendered-ok rendered-error)))))

(defn pull-store-db-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, entity: u64] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-store-db-value-pattern snapshot (slice prepared.pattern 0) entity))

(defn pull-store-db-value-text [snapshot: ^Store-DB, pattern-text: string, entity: u64] -> [value: Value, ok: bool, error: string]
    (let [[pattern pattern-ok pattern-error] (parse-pull-pattern-text pattern-text)]
      (when (not pattern-ok)
        (delete pattern)
        (return (Value {}) false pattern-error))
    (let [[out out-ok out-error] (pull-store-db-value-pattern snapshot (slice pattern 0) entity)]
      (delete pattern)
      (return out out-ok out-error))))

(defn pull-store-db-lookup-ref-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attr lookup-value)]
      (when (not entity-ok)
        (if (= lookup-error "")
          (return (value-nil) true "")
          (return (Value {}) false lookup-error)))
      (pull-store-db-value-pattern snapshot pattern entity))))

(defn pull-store-db-lookup-ref-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-store-db-lookup-ref-value-pattern snapshot (slice prepared.pattern 0) attr lookup-value))

(defn pull-store-db-lookup-ref-value-text [snapshot: ^Store-DB, pattern-text: string, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (let [[pattern pattern-ok pattern-error] (parse-pull-pattern-text pattern-text)]
    (when (not pattern-ok)
      (delete pattern)
      (return (Value {}) false pattern-error))
    (let [[out out-ok out-error] (pull-store-db-lookup-ref-value-pattern snapshot (slice pattern 0) attr lookup-value)]
      (delete pattern)
      (return out out-ok out-error))))

(defn pull-many-store-db-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, entities: []u64] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [pulls (make [dynamic]Pull-Result 0 (count entities))]
      (for [entity entities]
        (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity pattern)]
          (when (not pull-ok)
            (for [existing pulls]
              (delete-pull-result-owned-values existing))
            (delete pulls)
            (return (Value {}) false pull-error))
          (arr.push! pulls pull)))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-many-results-value source (slice pulls 0))]
        (for [pull pulls]
          (delete-pull-result-owned-values pull))
        (delete pulls)
        (return rendered rendered-ok rendered-error)))))

(defn pull-many-store-db-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, entities: []u64] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-many-store-db-value-pattern snapshot (slice prepared.pattern 0) entities))

(defn pull-many-store-db-value-text [snapshot: ^Store-DB, pattern-text: string, entities: []u64] -> [value: Value, ok: bool, error: string]
  (let [[pattern pattern-ok pattern-error] (parse-pull-pattern-text pattern-text)]
    (when (not pattern-ok)
      (delete pattern)
      (return (Value {}) false pattern-error))
    (let [[out out-ok out-error] (pull-many-store-db-value-pattern snapshot (slice pattern 0) entities)]
      (delete pattern)
      (return out out-ok out-error))))

(defn pull-many-store-db-lookup-refs-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, attrs: []string, lookup-values: []Value] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [pulls (make [dynamic]Pull-Result 0 (count lookup-values))]
      (for [lookup-value index lookup-values]
        (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attrs[index] lookup-value)]
          (if entity-ok
            (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity (slice prepared.pattern 0))]
              (when (not pull-ok)
                (for [existing pulls]
                  (delete-pull-result-owned-values existing))
                (delete pulls)
                (return (Value {}) false pull-error))
              (arr.push! pulls pull))
            (if (= lookup-error "")
              (arr.push! pulls (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))
              (do
                (for [existing pulls]
                  (delete-pull-result-owned-values existing))
                (delete pulls)
                (return (Value {}) false lookup-error))))))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-many-results-value source (slice pulls 0))]
        (for [pull pulls]
          (delete-pull-result-owned-values pull))
        (delete pulls)
        (return rendered rendered-ok rendered-error)))))

(defn sqlite-open-db-snapshot [path: string, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-DB-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle handle page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.indexes.owns-handle true)
      (set! opened-snapshot.path (string-owned path))
      (return opened-snapshot true ""))))

(defn sqlite-open-db-snapshot-at-basis [path: string, basis-tx: u64, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-DB-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-basis handle basis-tx page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.indexes.owns-handle true)
      (set! opened-snapshot.path (string-owned path))
      (return opened-snapshot true ""))))

(defn close-sqlite-db-snapshot! [snapshot: ^SQLite-DB-Snapshot]
  (sqlite-finalize-stmt-raw snapshot^.datom-stmt)
  (close-sqlite-index-snapshot! (addr snapshot^.indexes))
  (delete snapshot^.path)
  (set! snapshot^ (SQLite-DB-Snapshot {})))

(defn close-sqlite-db-snapshot [snapshot: SQLite-DB-Snapshot]
  (let [owned snapshot]
    (close-sqlite-db-snapshot! (addr owned))))

(defn close-store-db! [snapshot: ^Store-DB]
  (case snapshot^.kind
    .Resident (delete-owned-db snapshot^.resident)
    .SQLite-Snapshot (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot))
    .SQLite-Tx-Ops-Overlay
      (do
        (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot))
        (delete-owned-tx-ops snapshot^.overlay-ops))
    .SQLite-Datom-Overlay
      (do
        (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot))
        (delete-owned-datoms snapshot^.overlay-datoms))
    .Shared-Snapshot (delete-shared-db-snapshot snapshot^.shared-snapshot)
    .Shared-Tx-Ops-Overlay
      (do
        (delete-shared-db-snapshot snapshot^.shared-snapshot)
        (delete-owned-tx-ops snapshot^.overlay-ops))
    .Shared-Datom-Overlay
      (do
        (delete-shared-db-snapshot snapshot^.shared-snapshot)
        (delete-owned-datoms snapshot^.overlay-datoms))
     (do))
  (set! snapshot^ (Store-DB {})))

(defn close-store-db [snapshot: Store-DB]
  (let [owned snapshot]
    (close-store-db! (addr owned))))

(defn close-sqlite-conn [store: SQLite-Conn]
  (sqlite-close-live-raw store.handle)
  (delete store.path)
  (delete store.conn.listeners)
  (delete-owned-db store.conn.db))

(defn rollback-sqlite-conn! [store: ^SQLite-Conn, before: DB]
  (let [restored (conn-from-db before)]
    (delete-owned-db store^.conn.db)
    (set! store^.conn.db restored.db)
    (set! store^.conn.next-tx restored.next-tx)
    (delete restored.listeners)))

(defn transact-sqlite-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> Tx-Report
  (when store^.source-only
    (return (failed-tx-report store^.conn.db "SQLite source connection is read-only; open a writable SQLite connection to transact")))
  (let [[resident-ok resident-error] (sqlite-conn-ensure-resident! store)]
    (when (not resident-ok)
      (return (failed-tx-report store^.conn.db resident-error))))
  (let [report (transact-tx-data (addr store^.conn) tx-data)]
    (when (not report.ok)
      (return report))
    (let [[saved-ok save-error] (append-tx-report-sqlite-handle store^.handle report)]
      (when (not saved-ok)
        (rollback-sqlite-conn! store report.db-before)
        (delete-live-tx-report-shallow report)
        (return (failed-tx-report store^.conn.db save-error))))
    report))

(defn transact-sqlite-text [store: ^SQLite-Conn, text: string] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report store^.conn.db parse-error)))
    (transact-sqlite-tx-data store (slice tx-data 0))))

(defn transact-sqlite-store-report-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> Store-Tx-Report
  (when store^.source-only
    (return (failed-sqlite-store-tx-report store "SQLite source connection is read-only; open a writable SQLite connection to transact")))
  (let [[direct-report direct-used direct-ok direct-error] (transact-sqlite-store-report-direct-tx-data store tx-data)]
    (when direct-ok
      (when direct-used
        (return direct-report)))
    (when (not direct-ok)
      (return (failed-sqlite-store-tx-report store direct-error))))
  (let [report (transact-sqlite-tx-data store tx-data)
        out (store-tx-report-from-temp-resident-report report)]
    out))

(defn transact-sqlite-store-report-text [store: ^SQLite-Conn, text: string] -> Store-Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-sqlite-store-tx-report store parse-error)))
    (transact-sqlite-store-report-tx-data store (slice tx-data 0))))

(defn transact-sqlite-store-report-tx-data-with-source-string-fns [store: ^SQLite-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (when store^.source-only
    (return (failed-sqlite-store-tx-report store "SQLite source connection is read-only; open a writable SQLite connection to transact")))
  (when store^.resident-loaded
    (return (store-tx-report-from-temp-resident-report (transact-sqlite-tx-data store tx-data))))
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db store)]
    (when (not snapshot-ok)
      (return (failed-sqlite-store-tx-report store snapshot-error)))
    (let [overlay-report (with-store-db-report-tx-data-with-source-string-fns (addr snapshot) tx-data registry)]
      (close-store-db snapshot)
      (sqlite-commit-source-overlay-report store overlay-report))))

(defn transact-sqlite-store-report-text-with-source-string-fns [store: ^SQLite-Conn, text: string, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-sqlite-store-tx-report store parse-error)))
    (transact-sqlite-store-report-tx-data-with-source-string-fns store (slice tx-data 0) registry)))

(defn store-from-sqlite-conn [store: SQLite-Conn] -> Store-Conn
  (Store-Conn {kind: .SQLite sqlite: store}))

(defn create-shared-store [chunk-size: int] -> Store-Conn
  (Store-Conn {kind: .Shared shared: (create-shared-conn chunk-size)}))

(defn open-store [uri: string] -> [store: Store-Conn, ok: bool, error: string]
  (let [[sqlite sqlite-ok sqlite-error] (open-sqlite-conn uri)]
    (return (store-from-sqlite-conn sqlite) sqlite-ok sqlite-error)))

(defn open-store-read-only [uri: string] -> [store: Store-Conn, ok: bool, error: string]
  (let [[sqlite sqlite-ok sqlite-error] (open-sqlite-source-conn uri)]
    (return (store-from-sqlite-conn sqlite) sqlite-ok sqlite-error)))

(defn close-store [store: Store-Conn]
  (case store.kind
    .SQLite (close-sqlite-conn store.sqlite)
    .Shared (delete-shared-conn store.shared)
     (do)))

(defn store-read-only? [store: ^Store-Conn] -> bool
  (case store^.kind
    .SQLite store^.sqlite.source-only
     false))

(defn store-resident-db-available? [store: ^Store-Conn] -> bool
  (case store^.kind
    .SQLite store^.sqlite.resident-loaded
    .Shared true
     false))

(defn store-db [store: ^Store-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-store-db (addr store^.sqlite))
    .Shared (return (shared-store-db (addr store^.shared)) true "")
     (return (Store-DB {}) false "store is not open")))

(defn store-tx-count [store: ^Store-Conn] -> [tx-count: u64, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-conn-tx-count (addr store^.sqlite))
    .Shared (return (shared-write-state-next-tx (addr store^.shared.write)) true "")
     (return 0 false "store is not open")))

(defn q-result-store-text [store: ^Store-Conn, text: string] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-text (addr store^.sqlite) text)
    .Shared (q-result-text-db-read-source (shared-conn-read-source (addr store^.shared)) text)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn q-result-store-text-with-input-text [store: ^Store-Conn, text: string, inputs-text: string] -> Query-Result
  (case store^.kind
    .SQLite
      (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db (addr store^.sqlite))]
        (when (not snapshot-ok)
          (return (query-result-owned-values (result-set-error snapshot-error))))
        (let [result (q-result-store-db-text-with-input-text (addr snapshot) text inputs-text)]
          (close-store-db! (addr snapshot))
          result))
    .Shared (q-result-text-db-read-source-with-input-text (shared-conn-read-source (addr store^.shared)) text inputs-text)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn q-result-store-prepared [store: ^Store-Conn, prepared: Prepared-Query] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-prepared (addr store^.sqlite) prepared)
    .Shared (q-result-prepared-db-read-source (shared-conn-read-source (addr store^.shared)) prepared)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn transact-store-tx-data [store: ^Store-Conn, tx-data: []Tx-Data] -> Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-tx-data (addr store^.sqlite) tx-data)
    .Shared (shared-conn-transact (addr store^.shared) tx-data)
     (failed-tx-report (build-db (make [dynamic]Datom)) "store is not open")))

(defn transact-store-text [store: ^Store-Conn, text: string] -> Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-text (addr store^.sqlite) text)
    .Shared
      (let [tx-data (make [dynamic]Tx-Data) :defer
            [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
        (when (not parse-ok)
          (return (failed-tx-report (shared-write-state-before-db (addr store^.shared.write)) parse-error)))
        (shared-conn-transact (addr store^.shared) (slice tx-data 0)))
     (failed-tx-report (build-db (make [dynamic]Datom)) "store is not open")))

(defn transact-store-report-tx-data [store: ^Store-Conn, tx-data: []Tx-Data] -> Store-Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-store-report-tx-data (addr store^.sqlite) tx-data)
    .Shared
      (let [report (shared-conn-transact-report (addr store^.shared) tx-data)]
        (if report.ok
          (let [tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
            (Store-Tx-Report {ok: true
                              error: ""
                              db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-before})
                              db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-after})
                              tx-data: (clone-owned-datom-slice (slice report.tx-data 0))
                              tx: report.tx
                              tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                              tempids: tempids
                              source-append-metadata-known: false
                              source-new-entities-after-existing: false
                              source-eavt-append-mode: false
                              source-aevt-append-mode: false
                              source-avet-append-mode: false
                              source-vaet-append-mode: false}))
          (Store-Tx-Report {ok: false
                            error: report.error
                            db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-before})
                            db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-after})
                            tx-data: (make [dynamic]Datom)
                            tx: 0
                            tx-meta: (make [dynamic]Tx-Meta)
                            tempids: (make [dynamic]Tempid)
                            source-append-metadata-known: false
                            source-new-entities-after-existing: false
                            source-eavt-append-mode: false
                            source-aevt-append-mode: false
                            source-avet-append-mode: false
                            source-vaet-append-mode: false})))
     (failed-store-tx-report (Store-DB {}) "store is not open")))

(defn delete-shared-store-source-temp-report [report: Tx-Report]
  (if report.ok
    (delete-live-tx-report-shallow report)
    (do
      (delete report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))))

(defn shared-store-report-tx-data-with-source-string-fns [store: ^Store-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [before-snapshot (retain-shared-db-snapshot store^.shared.snapshot)
        report (shared-conn-transact-with-source-string-fns (addr store^.shared) tx-data registry)]
    (if report.ok
      (let [after-snapshot (retain-shared-db-snapshot store^.shared.snapshot)
            tempids (arr.into [dynamic]Tempid (slice report.tempids 0))
            out (Store-Tx-Report {ok: true
                                  error: ""
                                  db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: before-snapshot})
                                  db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: after-snapshot})
                                  tx-data: (clone-owned-datom-slice (slice report.tx-data 0))
                                  tx: report.tx
                                  tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                                  tempids: tempids
                                  source-append-metadata-known: false
                                  source-new-entities-after-existing: false
                                  source-eavt-append-mode: false
                                  source-aevt-append-mode: false
                                  source-avet-append-mode: false
                                  source-vaet-append-mode: false})]
        (delete-shared-store-source-temp-report report)
        out)
      (let [out (Store-Tx-Report {ok: false
                                  error: report.error
                                  db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: before-snapshot})
                                  db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: (retain-shared-db-snapshot before-snapshot)})
                                  tx-data: (make [dynamic]Datom)
                                  tx: 0
                                  tx-meta: (make [dynamic]Tx-Meta)
                                  tempids: (make [dynamic]Tempid)
                                  source-append-metadata-known: false
                                  source-new-entities-after-existing: false
                                  source-eavt-append-mode: false
                                  source-aevt-append-mode: false
                                  source-avet-append-mode: false
                                  source-vaet-append-mode: false})]
        (delete-shared-store-source-temp-report report)
        out))))

(defn transact-store-report-tx-data-with-source-string-fns [store: ^Store-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-store-report-tx-data-with-source-string-fns (addr store^.sqlite) tx-data registry)
    .Shared (shared-store-report-tx-data-with-source-string-fns store tx-data registry)
     (failed-store-tx-report (Store-DB {}) "store is not open")))

(defn transact-store-report-text [store: ^Store-Conn, text: string] -> Store-Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-store-report-text (addr store^.sqlite) text)
    .Shared
      (let [tx-data (make [dynamic]Tx-Data) :defer
            [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
        (when (not parse-ok)
          (return (failed-store-tx-report (shared-store-db (addr store^.shared)) parse-error)))
        (transact-store-report-tx-data store (slice tx-data 0)))
     (failed-store-tx-report (Store-DB {}) "store is not open")))

(defn transact-store-report-text-with-source-string-fns [store: ^Store-Conn, text: string, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-store-report-text-with-source-string-fns (addr store^.sqlite) text registry)
    .Shared
      (let [tx-data (make [dynamic]Tx-Data) :defer
            [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
        (when (not parse-ok)
          (return (failed-store-tx-report (shared-store-db (addr store^.shared)) parse-error)))
        (transact-store-report-tx-data-with-source-string-fns store (slice tx-data 0) registry))
     (failed-store-tx-report (Store-DB {}) "store is not open")))
