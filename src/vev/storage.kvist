(defn transact-store-report-logical-text-groups-with-source-string-fns [store: ^Store-Conn, texts: []string, registry: []Tx-Fn-Source-String] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (case store^.kind
    .SQLite
