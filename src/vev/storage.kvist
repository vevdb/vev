        return 0, false, sqlite_error_text(db, \"sqlite prepare basis index root row id failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite3_bind_int64(stmt, 1, i64(basis_tx)) != SQLITE_OK {
