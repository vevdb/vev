sqlite_latest_index_entries_text_raw :: proc(handle: rawptr, index_name: string) -> (string, bool, string) {
    if handle == nil {
        return \"\", false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"\"
    switch index_name {
    case \":eavt\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.eavt_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":aevt\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.aevt_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":avet\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.avet_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":vaet\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.vaet_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case:
        return \"\", false, \"unknown Vev index name\"
    }
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare latest index entries failed\")
    }
    rc := sqlite3_step(stmt)
    if rc == SQLITE_DONE {
        _ = sqlite3_finalize(stmt)
        return \"\", false, \"sqlite DB has no Vev index roots\"
    }
    if rc != SQLITE_ROW {
        _ = sqlite3_finalize(stmt)
        return \"\", false, sqlite_error_text(db, \"sqlite latest index entries read failed\")
    }
    root_id := sqlite3_column_int64(stmt, 0)
    level := sqlite3_column_int64(stmt, 1)
    if level == 0 {
        raw := sqlite3_column_text(stmt, 2)
        if raw == nil {
            _ = sqlite3_finalize(stmt)
            return \"\", false, \"sqlite index chunk payload was null\"
        }
        out, err := strings.clone_from_cstring(raw)
        _ = sqlite3_finalize(stmt)
        if err != nil {
            return \"\", false, \"failed to clone sqlite index chunk payload\"
        }
        return out, true, \"\"
    }
    _ = sqlite3_finalize(stmt)

    child_stmt: ^SQLite3_Stmt
    child_sql := \"WITH RECURSIVE tree(chunk_id, level, path, payload_text) AS (SELECT c.chunk_id, c.level, printf('%012d', 0), c.payload_text FROM vev_index_chunks c WHERE c.chunk_id = ? UNION ALL SELECT child.chunk_id, child.level, tree.path || '.' || printf('%012d', edge.ordinal), child.payload_text FROM tree JOIN vev_index_chunk_edges edge ON edge.parent_chunk_id = tree.chunk_id JOIN vev_index_chunks child ON child.chunk_id = edge.child_chunk_id) SELECT '[' || COALESCE(group_concat(payload, ' '), '') || ']' FROM (SELECT substr(payload_text, 2, length(payload_text) - 2) AS payload FROM tree WHERE level = 0 ORDER BY path)\"
    child_sql_c, child_sql_c_ok := sqlite_cstring(child_sql)
    if !child_sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(child_sql_c)
    if sqlite3_prepare_v2(db, child_sql_c, -1, &child_stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare child index entries failed\")
    }
    defer _ = sqlite3_finalize(child_stmt)
    if sqlite3_bind_int64(child_stmt, 1, root_id) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite bind child index root failed\")
    }
    child_rc := sqlite3_step(child_stmt)
    if child_rc != SQLITE_ROW {
        return \"\", false, sqlite_error_text(db, \"sqlite child index entries read failed\")
    }
    raw := sqlite3_column_text(child_stmt, 0)
    if raw == nil {
        return \"\", false, \"sqlite child index entries were null\"
    }
    out, err := strings.clone_from_cstring(raw)
    if err != nil {
        return \"\", false, \"failed to clone sqlite child index entries\"
    }
    return out, true, \"\"
}

sqlite_latest_index_entries_page_text_raw :: proc(handle: rawptr, index_name: string, offset: i64, limit: i64) -> (string, i64, bool, string) {
    if handle == nil {
        return \"\", 0, false, \"sqlite handle was nil\"
    }
    if offset < 0 {
        return \"\", 0, false, \"sqlite index page offset was negative\"
    }
    if limit <= 0 {
        return \"[]\", offset, true, \"\"
    }
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"\"
    switch index_name {
    case \":eavt\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.eavt_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":aevt\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.aevt_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":avet\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.avet_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case \":vaet\":
        sql = \"SELECT c.chunk_id, c.level, c.payload_text FROM vev_index_roots r JOIN vev_index_chunks c ON c.chunk_id = r.vaet_chunk_id ORDER BY r.root_id DESC LIMIT 1\"
    case:
        return \"\", 0, false, \"unknown Vev index name\"
    }
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", 0, false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite prepare latest index page failed\")
    }
    rc := sqlite3_step(stmt)
    if rc == SQLITE_DONE {
        _ = sqlite3_finalize(stmt)
        return \"\", 0, false, \"sqlite DB has no Vev index roots\"
    }
    if rc != SQLITE_ROW {
        _ = sqlite3_finalize(stmt)
        return \"\", 0, false, sqlite_error_text(db, \"sqlite latest index page read failed\")
    }
    root_id := sqlite3_column_int64(stmt, 0)
    level := sqlite3_column_int64(stmt, 1)
    if level == 0 {
        raw := sqlite3_column_text(stmt, 2)
        if raw == nil {
            _ = sqlite3_finalize(stmt)
            return \"\", 0, false, \"sqlite index chunk payload was null\"
        }
        out, err := strings.clone_from_cstring(raw)
        _ = sqlite3_finalize(stmt)
        if err != nil {
            return \"\", 0, false, \"failed to clone sqlite index chunk payload\"
        }
        return out, 0, true, \"\"
    }
    _ = sqlite3_finalize(stmt)

    child_stmt: ^SQLite3_Stmt
    child_sql := \"WITH RECURSIVE tree(chunk_id, level, path, payload_text, row_count) AS (SELECT c.chunk_id, c.level, printf('%012d', 0), c.payload_text, c.row_count FROM vev_index_chunks c WHERE c.chunk_id = ? UNION ALL SELECT child.chunk_id, child.level, tree.path || '.' || printf('%012d', edge.ordinal), child.payload_text, child.row_count FROM tree JOIN vev_index_chunk_edges edge ON edge.parent_chunk_id = tree.chunk_id JOIN vev_index_chunks child ON child.chunk_id = edge.child_chunk_id), leaves AS (SELECT path, payload_text, row_count, COALESCE(SUM(row_count) OVER (ORDER BY path ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING), 0) AS base FROM tree WHERE level = 0) SELECT '[' || COALESCE(group_concat(payload, ' '), '') || ']', COALESCE(MIN(base), ?) FROM (SELECT base, substr(payload_text, 2, length(payload_text) - 2) AS payload FROM leaves WHERE base + row_count > ? AND base < ? ORDER BY path)\"
    child_sql_c, child_sql_c_ok := sqlite_cstring(child_sql)
    if !child_sql_c_ok {
        return \"\", 0, false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(child_sql_c)
    if sqlite3_prepare_v2(db, child_sql_c, -1, &child_stmt, nil) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite prepare child index page failed\")
    }
    defer _ = sqlite3_finalize(child_stmt)
    if sqlite3_bind_int64(child_stmt, 1, root_id) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite bind child index root failed\")
    }
    if sqlite3_bind_int64(child_stmt, 2, offset) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite bind child index page base failed\")
    }
    if sqlite3_bind_int64(child_stmt, 3, offset) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite bind child index page offset failed\")
    }
    if sqlite3_bind_int64(child_stmt, 4, offset + limit) != SQLITE_OK {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite bind child index page limit failed\")
    }
    child_rc := sqlite3_step(child_stmt)
    if child_rc != SQLITE_ROW {
        return \"\", 0, false, sqlite_error_text(db, \"sqlite child index page read failed\")
    }
    raw := sqlite3_column_text(child_stmt, 0)
    if raw == nil {
        return \"\", 0, false, \"sqlite child index page was null\"
    }
    out, err := strings.clone_from_cstring(raw)
    if err != nil {
        return \"\", 0, false, \"failed to clone sqlite child index page\"
    }
    return out, sqlite3_column_int64(child_stmt, 1), true, \"\"
}

