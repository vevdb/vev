        append(&entities_out, u64(sqlite3_column_int64(stmt, 0)))
        append(&attrs, a_text)
        append(&values, value_text)
        append(&txs, u64(sqlite3_column_int64(stmt, 3)))
        append(&added, sqlite3_column_int(stmt, 4) != 0)
    }
    return entities_out, attrs, values, txs, added, true, \"\"
}

sqlite_attr_string_term_datom_parts_raw :: proc(handle: rawptr, attr: string, search: string) -> ([dynamic]u64, [dynamic]string, [dynamic]string, [dynamic]u64, [dynamic]bool, bool, string) {
    entities_out := make([dynamic]u64, 0)
    attrs := make([dynamic]string, 0)
    values := make([dynamic]string, 0)
    txs := make([dynamic]u64, 0)
    added := make([dynamic]bool, 0)
    if handle == nil {
        return entities_out, attrs, values, txs, added, false, \"sqlite handle was nil\"
    }
    term_buf := make([dynamic]u8, 0, len(search))
    defer delete(term_buf)
    for i := 0; i < len(search); i += 1 {
        ch := search[i]
        if !sqlite_text_term_char_ok(ch) {
            return entities_out, attrs, values, txs, added, false, \"search text was not a simple indexed term\"
        }
        append(&term_buf, sqlite_text_term_lower(ch))
    }
    if len(term_buf) == 0 {
        return entities_out, attrs, values, txs, added, false, \"search text was empty\"
    }
    term := string(term_buf[:])
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"SELECT d.e, d.a, d.value_text, d.tx, d.added FROM vev_text_terms t JOIN vev_datoms d ON d.log_index = t.log_index WHERE t.attr = ? AND t.term = ? AND d.added = 1 ORDER BY t.log_index\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return entities_out, attrs, values, txs, added, false, \"failed to allocate sqlite attr string term SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return entities_out, attrs, values, txs, added, false, sqlite_error_text(db, \"sqlite prepare attr string term read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite_bind_text_borrowed(stmt, 1, attr) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 2, term) != SQLITE_OK {
        return entities_out, attrs, values, txs, added, false, sqlite_error_text(db, \"sqlite bind attr string term read failed\")
    }
    for {
        rc := sqlite3_step(stmt)
        if rc == SQLITE_DONE {
            break
        }
        if rc != SQLITE_ROW {
            return entities_out, attrs, values, txs, added, false, sqlite_error_text(db, \"sqlite attr string term read failed\")
        }
        a_text, a_ok := sqlite_column_text_owned(stmt, 1)
        if !a_ok {
            return entities_out, attrs, values, txs, added, false, \"sqlite attr string term row had null attr text\"
        }
        value_text, value_ok := sqlite_column_text_owned(stmt, 2)
        if !value_ok {
            delete(a_text)
            return entities_out, attrs, values, txs, added, false, \"sqlite attr string term row had null value text\"
        }
        append(&entities_out, u64(sqlite3_column_int64(stmt, 0)))
        append(&attrs, a_text)
        append(&values, value_text)
        append(&txs, u64(sqlite3_column_int64(stmt, 3)))
        append(&added, sqlite3_column_int(stmt, 4) != 0)
    }
    return entities_out, attrs, values, txs, added, true, \"\"
}

sqlite_step_datom_stmt_raw :: proc(handle: rawptr, stmt_handle: rawptr, log_index: i64, e: u64, a: string, value_text: string, value_entity: i64, tx: u64, added: bool) -> (bool, string) {
    if handle == nil || stmt_handle == nil {
        return false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt := (^SQLite3_Stmt)(stmt_handle)
    _ = sqlite3_reset(stmt)
    _ = sqlite3_clear_bindings(stmt)
    if sqlite3_bind_int64(stmt, 1, log_index) != SQLITE_OK ||
       sqlite3_bind_int64(stmt, 2, i64(e)) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 3, a) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 4, value_text) != SQLITE_OK ||
       sqlite3_bind_int64(stmt, 5, value_entity) != SQLITE_OK ||
       sqlite3_bind_int64(stmt, 6, i64(tx)) != SQLITE_OK ||
       sqlite3_bind_int(stmt, 7, c.int(added ? 1 : 0)) != SQLITE_OK {
        return false, sqlite_error_text(db, \"sqlite bind datom failed\")
    }
    if sqlite3_step(stmt) != SQLITE_DONE {
        return false, sqlite_error_text(db, \"sqlite insert datom failed\")
    }
    _ = sqlite3_clear_bindings(stmt)
    _, _ = sqlite_insert_fulltext_datom_raw(handle, log_index, a, value_text, added)
    terms_ok, terms_error := sqlite_insert_text_terms_for_datom_raw(handle, log_index, a, value_text, added)
    if !terms_ok {
        return false, terms_error
    }
    return true, \"\"
}

sqlite_insert_tx_meta_raw :: proc(handle: rawptr, tx: u64, a: string, value_text: string) -> (bool, string) {
    if handle == nil {
        return false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    tx_ok, tx_error := sqlite_insert_tx_raw(handle, tx)
    if !tx_ok {
        return false, tx_error
    }
    stmt: ^SQLite3_Stmt
    sql := \"INSERT INTO vev_tx_meta (tx, a, value_text) VALUES (?, ?, ?)\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return false, sqlite_error_text(db, \"sqlite prepare tx metadata failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite3_bind_int64(stmt, 1, i64(tx)) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 2, a) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 3, value_text) != SQLITE_OK {
        return false, sqlite_error_text(db, \"sqlite bind tx metadata failed\")
    }
    if sqlite3_step(stmt) != SQLITE_DONE {
        return false, sqlite_error_text(db, \"sqlite insert tx metadata failed\")
    }
    return true, \"\"
}

sqlite_prepare_insert_tx_meta_raw :: proc(handle: rawptr) -> (rawptr, bool, string) {
    if handle == nil {
        return nil, false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"INSERT INTO vev_tx_meta (tx, a, value_text) VALUES (?, ?, ?)\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return nil, false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return nil, false, sqlite_error_text(db, \"sqlite prepare tx metadata failed\")
    }
    return rawptr(stmt), true, \"\"
}

sqlite_step_tx_meta_stmt_raw :: proc(handle: rawptr, stmt_handle: rawptr, tx: u64, a: string, value_text: string) -> (bool, string) {
    if handle == nil || stmt_handle == nil {
        return false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt := (^SQLite3_Stmt)(stmt_handle)
    _ = sqlite3_reset(stmt)
    _ = sqlite3_clear_bindings(stmt)
    if sqlite3_bind_int64(stmt, 1, i64(tx)) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 2, a) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 3, value_text) != SQLITE_OK {
        return false, sqlite_error_text(db, \"sqlite bind tx metadata failed\")
    }
    if sqlite3_step(stmt) != SQLITE_DONE {
        return false, sqlite_error_text(db, \"sqlite insert tx metadata failed\")
    }
    _ = sqlite3_clear_bindings(stmt)
    return true, \"\"
}

sqlite_rows_exist_raw :: proc(db: ^SQLite3) -> (bool, bool, string) {
    stmt: ^SQLite3_Stmt
    sql := \"SELECT 1 FROM vev_datoms LIMIT 1\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return false, false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return false, false, sqlite_error_text(db, \"sqlite prepare exists failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    rc := sqlite3_step(stmt)
    if rc == SQLITE_ROW {
        return true, true, \"\"
    }
    if rc == SQLITE_DONE {
        return false, true, \"\"
    }
    return false, false, sqlite_error_text(db, \"sqlite exists failed\")
}

sqlite_load_datom_rows_text_raw :: proc(path: string) -> (string, bool, string) {
    db, open_ok, open_error := sqlite_open_initialized(path)
    if !open_ok {
        return \"\", false, open_error
    }
    defer _ = sqlite3_close(db)
    any_rows, exists_ok, exists_error := sqlite_rows_exist_raw(db)
    if !exists_ok {
        return \"\", false, exists_error
    }
    if !any_rows {
        return \"\", false, \"sqlite DB has no Vev datom rows\"
    }
    stmt: ^SQLite3_Stmt
    sql := \"SELECT e, a, value_text, tx, added FROM vev_datoms ORDER BY log_index, id\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare datom read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    parts := make([dynamic]string)
    append(&parts, \"[\")
    first := true
    for {
        rc := sqlite3_step(stmt)
        if rc == SQLITE_DONE {
            break
        }
        if rc != SQLITE_ROW {
            delete(parts)
            return \"\", false, sqlite_error_text(db, \"sqlite datom read failed\")
        }
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            delete(parts)
            return \"\", false, \"sqlite datom row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            delete(parts)
            return \"\", false, \"failed to clone sqlite datom attr\"
        }
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            delete(a_text)
            delete(parts)
            return \"\", false, \"failed to clone sqlite datom value\"
        }
        if !first {
            append(&parts, \" \")
        }
        first = false
        append(&parts, fmt.tprintf(\"[%d %s %s %d %v]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text,
            sqlite3_column_int64(stmt, 3),
            sqlite3_column_int(stmt, 4) != 0))
        delete(a_text)
        delete(value_text)
    }
    append(&parts, \"]\")
    out := strings.concatenate(parts[:])
    delete(parts)
    return out, true, \"\"
}

sqlite_load_datom_by_log_index_text_raw :: proc(handle: rawptr, log_index: i64) -> (string, bool, string) {
    if handle == nil {
        return \"\", false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"SELECT e, a, value_text, tx, added FROM vev_datoms WHERE log_index = ? ORDER BY id LIMIT 1\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare datom log-index read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite3_bind_int64(stmt, 1, log_index) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite bind datom log-index read failed\")
    }
    rc := sqlite3_step(stmt)
    if rc == SQLITE_ROW {
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            return \"\", false, \"sqlite datom row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            return \"\", false, \"failed to clone sqlite datom attr\"
        }
        defer delete(a_text)
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            return \"\", false, \"failed to clone sqlite datom value\"
        }
        defer delete(value_text)
        formatted := fmt.tprintf(\"[%d %s %s %d %v]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text,
            sqlite3_column_int64(stmt, 3),
            sqlite3_column_int(stmt, 4) != 0)
        out, out_err := strings.clone(formatted)
        if out_err != nil {
            return \"\", false, \"failed to clone sqlite datom log-index text\"
        }
        return out, true, \"\"
    }
    if rc == SQLITE_DONE {
        return \"\", false, \"sqlite datom log-index not found\"
    }
    return \"\", false, sqlite_error_text(db, \"sqlite datom log-index read failed\")
}

sqlite_load_attr_string_contains_rows_text_raw :: proc(handle: rawptr, attr: string, search: string) -> (string, bool, string) {
    if handle == nil {
        return \"\", false, \"sqlite handle was nil\"
    }
    db := (^SQLite3)(handle)
    stmt: ^SQLite3_Stmt
    sql := \"SELECT e, a, value_text, tx, added FROM vev_datoms WHERE a = ? AND added = 1 AND instr(lower(value_text), lower(?)) > 0 ORDER BY log_index, id\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare attr string contains read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    if sqlite_bind_text_borrowed(stmt, 1, attr) != SQLITE_OK ||
       sqlite_bind_text_borrowed(stmt, 2, search) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite bind attr string contains read failed\")
    }
    parts := make([dynamic]string)
    append(&parts, \"[\")
    first := true
    for {
        rc := sqlite3_step(stmt)
        if rc == SQLITE_DONE {
            break
        }
        if rc != SQLITE_ROW {
            delete(parts)
            return \"\", false, sqlite_error_text(db, \"sqlite attr string contains read failed\")
        }
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            delete(parts)
            return \"\", false, \"sqlite attr string contains row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            delete(parts)
            return \"\", false, \"failed to clone sqlite attr string contains attr\"
        }
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            delete(a_text)
            delete(parts)
            return \"\", false, \"failed to clone sqlite attr string contains value\"
        }
        if !first {
            append(&parts, \" \")
        }
        first = false
        append(&parts, fmt.tprintf(\"[%d %s %s %d %v]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text,
            sqlite3_column_int64(stmt, 3),
            sqlite3_column_int(stmt, 4) != 0))
        delete(a_text)
        delete(value_text)
    }
    append(&parts, \"]\")
    out := strings.concatenate(parts[:])
    delete(parts)
    return out, true, \"\"
}

sqlite_load_tx_meta_rows_text_raw :: proc(path: string) -> (string, bool, string) {
    db, open_ok, open_error := sqlite_open_initialized(path)
    if !open_ok {
        return \"\", false, open_error
    }
    defer _ = sqlite3_close(db)
    stmt: ^SQLite3_Stmt
    sql := \"SELECT tx, a, value_text FROM vev_tx_meta ORDER BY id\"
    sql_c, sql_c_ok := sqlite_cstring(sql)
    if !sql_c_ok {
        return \"\", false, \"failed to allocate sqlite SQL text\"
    }
    defer delete(sql_c)
    if sqlite3_prepare_v2(db, sql_c, -1, &stmt, nil) != SQLITE_OK {
        return \"\", false, sqlite_error_text(db, \"sqlite prepare tx metadata read failed\")
    }
    defer _ = sqlite3_finalize(stmt)
    parts := make([dynamic]string)
    append(&parts, \"[\")
    first := true
    for {
        rc := sqlite3_step(stmt)
        if rc == SQLITE_DONE {
            break
        }
        if rc != SQLITE_ROW {
            delete(parts)
            return \"\", false, sqlite_error_text(db, \"sqlite tx metadata read failed\")
        }
        a_raw := sqlite3_column_text(stmt, 1)
        value_raw := sqlite3_column_text(stmt, 2)
        if a_raw == nil || value_raw == nil {
            delete(parts)
            return \"\", false, \"sqlite tx metadata row had null text\"
        }
        a_text, a_err := strings.clone_from_cstring(a_raw)
        if a_err != nil {
            delete(parts)
            return \"\", false, \"failed to clone sqlite tx metadata attr\"
        }
        value_text, value_err := strings.clone_from_cstring(value_raw)
        if value_err != nil {
            delete(a_text)
            delete(parts)
            return \"\", false, \"failed to clone sqlite tx metadata value\"
        }
        if !first {
            append(&parts, \" \")
        }
        first = false
        append(&parts, fmt.tprintf(\"[%d %s %s]\",
            sqlite3_column_int64(stmt, 0),
            vev__attr_serializable_text(a_text),
            value_text))
        delete(a_text)
        delete(value_text)
    }
    append(&parts, \"]\")
    out := strings.concatenate(parts[:])
    delete(parts)
    return out, true, \"\"
}
")

(defn save-db-snapshot-text [path: string, db: DB] -> [ok: bool, error: string]
  (let [text (serializable-text db) :defer
        err (os.write_entire_file path text)]
    (if (= err nil)
      (return true "")
      (return false "failed to write DB snapshot"))))

(defn load-db-snapshot-text [path: string] -> [db: DB, ok: bool, error: string]
  (let [[data err] (os.read_entire_file path context.allocator)]
    (when (!= err nil)
      (return (build-db (make [dynamic]Datom)) false "failed to read DB snapshot"))
    (defer (delete data))
    (from-serializable-text (string data))))

(defn open-conn-snapshot-text [path: string] -> [conn: Conn, ok: bool, error: string]
  (let [[db loaded-ok load-error] (load-db-snapshot-text path)]
    (if loaded-ok
      (do
        (let [conn (conn-from-db db)]
          (delete-owned-db db)
          (return conn true "")))
      (do
        (delete-owned-db db)
        (return (create-conn) false load-error)))))

(defn persist-conn-snapshot-text [path: string, conn: Conn] -> [ok: bool, error: string]
  (save-db-snapshot-text path conn.db))

(defn db-basis-tx [db: DB] -> u64
  (let [basis: u64 0]
    (for [datom db.datoms]
      (when (> datom.tx basis)
        (set! basis datom.tx)))
    basis))

(def sqlite-index-leaf-chunk-size 128)
(def sqlite-index-parent-fanout 64)
(def sqlite-index-merge-root-fanout 4)
(def sqlite-index-merge-root-max-direct-runs 5)
(def sqlite-index-foreground-merge-row-budget 512)
(def sqlite-index-auto-maintenance-row-budget 512)

(defn index-int-slice-text [items: []int] -> string
  (let [builder (kstr.builder)]
    (defer (kstr.destroy! (addr builder)))
    (kstr.write! (addr builder) "[")
    (let [i 0]
      (while (< i (count items))
      (when (> i 0)
        (kstr.write! (addr builder) " "))
      (let [part (fmt.tprintf "%d" items[i])]
        (kstr.write! (addr builder) part))
      (set! i (+ i 1))))
    (kstr.write! (addr builder) "]")
    (kstr.finish (addr builder))))

(defn index-int-payload-text-append [payload: string, appended: []int] -> [text: string, ok: bool, error: string]
  (let [n (kstr.count payload)]
    (when (< n 2)
      (return "" false "invalid persisted index payload"))
    (when (or (not (= (kstr.get payload 0) 91))
              (not (= (kstr.get payload (- n 1)) 93)))
      (return "" false "invalid persisted index payload"))
    (let [builder (kstr.builder)]
      (defer (kstr.destroy! (addr builder)))
      (kstr.write! (addr builder) (kstr.slice payload 0 (- n 1)))
      (let [needs-space (> n 2)
            i 0]
        (while (< i (count appended))
          (when (or needs-space (> i 0))
            (kstr.write! (addr builder) " "))
          (let [part (fmt.tprintf "%d" appended[i])]
            (kstr.write! (addr builder) part))
          (set! i (+ i 1))))
      (kstr.write! (addr builder) "]")
      (return (kstr.finish (addr builder)) true ""))))

(defn index-bound-text [items: []int, first?: bool] -> string
  (if (= (count items) 0)
    (string-owned ":empty")
    (if first?
      (string-owned (fmt.tprintf "%d" items[0]))
      (string-owned (fmt.tprintf "%d" items[(- (count items) 1)])))))

(defn index-entry-bound-text [entry: int] -> string
  (string-owned (fmt.tprintf "%d" entry)))

(defn storage-string-starts-with? [text: string, prefix: string] -> bool
  (let [text-count (kstr.count text)
        prefix-count (kstr.count prefix)]
    (when (< text-count prefix-count)
      (return false))
    (for [index (arr.range 0 prefix-count)]
      (when (not (= (kstr.get text index) (kstr.get prefix index)))
        (return false)))
    true))

(defn sqlite-index-merge-root-key? [text: string] -> bool
  (or (= text ":merge-root")
      (storage-string-starts-with? text ":merge-root:")))

(defn parse-index-bound-entry [text: string] -> [entry: int, ok: bool]
  (let [value-text (if (storage-string-starts-with? text ":merge-root:")
                     (kstr.slice text 12 (kstr.count text))
                     text)
        [parsed parsed-ok] (strconv.parse_int value-text)]
    (if parsed-ok
      (return (int parsed) true)
      (return 0 false))))

(defn storage-index-entry-delimiter? [ch: u8] -> bool
  (or (= ch 32)
      (= ch 9)
      (= ch 10)
      (= ch 13)
      (= ch 91)
      (= ch 93)))

(defn parse-index-entries-text [text: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [out (make [dynamic]int)
        cursor 0
        n (kstr.count text)]
    (while (< cursor n)
      (while (and (< cursor n)
                  (storage-index-entry-delimiter? (kstr.get text cursor)))
        (set! cursor (+ cursor 1)))
      (when (< cursor n)
        (let [start cursor]
          (while (and (< cursor n)
                      (not (storage-index-entry-delimiter? (kstr.get text cursor))))
            (set! cursor (+ cursor 1)))
          (let [token (kstr.slice text start cursor)
            [parsed parsed-ok] (strconv.parse_int token)]
            (when (not parsed-ok)
              (delete out)
              (return (make [dynamic]int) false "invalid persisted index entry"))
            (arr.push! out (int parsed))))))
    (return out true "")))

(defn parse-index-entries-text-window [text: string, offset-within-items: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [out (make [dynamic]int)]
    (when (<= limit 0)
      (return out true ""))
    (let [cursor 0
          n (kstr.count text)
          seen 0
          start-index (max offset-within-items 0)
          end-index (+ start-index limit)]
      (while (< cursor n)
        (while (and (< cursor n)
                    (storage-index-entry-delimiter? (kstr.get text cursor)))
          (set! cursor (+ cursor 1)))
        (when (< cursor n)
          (let [start cursor]
            (while (and (< cursor n)
                        (not (storage-index-entry-delimiter? (kstr.get text cursor))))
              (set! cursor (+ cursor 1)))
            (let [token (kstr.slice text start cursor)
              [parsed parsed-ok] (strconv.parse_int token)]
              (when (not parsed-ok)
                (delete out)
                (return (make [dynamic]int) false "invalid persisted index entry"))
              (when (and (>= seen start-index)
                         (< seen end-index))
                (arr.push! out (int parsed)))
              (set! seen (+ seen 1))
              (when (>= seen end-index)
                (return out true ""))))))
      (return out true ""))))

(defn parse-index-entries-page-text-window [text: string, base-offset: i64, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (parse-index-entries-text-window text (- offset (int base-offset)) limit))

(defstruct SQLite-Index-Write-Stmts {
  chunk-stmt: rawptr
  chunk-entry-stmt: rawptr
  edge-stmt: rawptr
  copy-edges-stmt: rawptr
  copy-edges-before-stmt: rawptr
  root-stmt: rawptr
  root-copy-stmt: rawptr
  root-page-stmt: rawptr
  manifest-stmt: rawptr
  manifest-run-stmt: rawptr
  manifest-run-bounds-stmt: rawptr
  manifest-attr-range-stmt: rawptr
})

(defn sqlite-index-write-stmts-open [handle: rawptr] -> [stmts: SQLite-Index-Write-Stmts, ok: bool, error: string]
  (let [[chunk-stmt chunk-ok chunk-error] (sqlite-prepare-insert-index-chunk-raw handle)]
    (when (not chunk-ok)
      (return (SQLite-Index-Write-Stmts {}) false chunk-error))
    (let [[chunk-entry-stmt chunk-entry-ok chunk-entry-error] (sqlite-prepare-insert-index-chunk-entry-raw handle)]
      (when (not chunk-entry-ok)
        (sqlite-finalize-stmt-raw chunk-stmt)
        (return (SQLite-Index-Write-Stmts {}) false chunk-entry-error))
    (let [[edge-stmt edge-ok edge-error] (sqlite-prepare-insert-index-chunk-edge-raw handle)]
      (when (not edge-ok)
        (sqlite-finalize-stmt-raw chunk-stmt)
        (sqlite-finalize-stmt-raw chunk-entry-stmt)
        (return (SQLite-Index-Write-Stmts {}) false edge-error))
      (let [[copy-edges-stmt copy-edges-ok copy-edges-error] (sqlite-prepare-copy-index-chunk-edges-raw handle)]
        (when (not copy-edges-ok)
          (sqlite-finalize-stmt-raw chunk-stmt)
          (sqlite-finalize-stmt-raw chunk-entry-stmt)
          (sqlite-finalize-stmt-raw edge-stmt)
          (return (SQLite-Index-Write-Stmts {}) false copy-edges-error))
        (let [[copy-before-stmt copy-before-ok copy-before-error] (sqlite-prepare-copy-index-chunk-edges-before-ordinal-raw handle)]
          (when (not copy-before-ok)
            (sqlite-finalize-stmt-raw chunk-stmt)
            (sqlite-finalize-stmt-raw chunk-entry-stmt)
            (sqlite-finalize-stmt-raw edge-stmt)
            (sqlite-finalize-stmt-raw copy-edges-stmt)
            (return (SQLite-Index-Write-Stmts {}) false copy-before-error))
          (let [[root-stmt root-ok root-error] (sqlite-prepare-insert-index-root-with-manifests-raw handle)]
            (when (not root-ok)
              (sqlite-finalize-stmt-raw chunk-stmt)
              (sqlite-finalize-stmt-raw chunk-entry-stmt)
              (sqlite-finalize-stmt-raw edge-stmt)
              (sqlite-finalize-stmt-raw copy-edges-stmt)
              (sqlite-finalize-stmt-raw copy-before-stmt)
              (return (SQLite-Index-Write-Stmts {}) false root-error))
            (let [[root-copy-stmt root-copy-ok root-copy-error] (sqlite-prepare-insert-index-root-copy-latest-raw handle)]
              (when (not root-copy-ok)
                (sqlite-finalize-stmt-raw chunk-stmt)
                (sqlite-finalize-stmt-raw chunk-entry-stmt)
                (sqlite-finalize-stmt-raw edge-stmt)
                (sqlite-finalize-stmt-raw copy-edges-stmt)
                (sqlite-finalize-stmt-raw copy-before-stmt)
                (sqlite-finalize-stmt-raw root-stmt)
                (return (SQLite-Index-Write-Stmts {}) false root-copy-error))
            (let [[root-page-stmt root-page-ok root-page-error] (sqlite-prepare-insert-index-root-page-raw handle)]
              (when (not root-page-ok)
                (sqlite-finalize-stmt-raw chunk-stmt)
                (sqlite-finalize-stmt-raw chunk-entry-stmt)
                (sqlite-finalize-stmt-raw edge-stmt)
                (sqlite-finalize-stmt-raw copy-edges-stmt)
                (sqlite-finalize-stmt-raw copy-before-stmt)
                (sqlite-finalize-stmt-raw root-stmt)
                (sqlite-finalize-stmt-raw root-copy-stmt)
                (return (SQLite-Index-Write-Stmts {}) false root-page-error))
            (let [[manifest-stmt manifest-ok manifest-error] (sqlite-prepare-insert-index-run-manifest-with-parent-raw handle)]
              (when (not manifest-ok)
                (sqlite-finalize-stmt-raw chunk-stmt)
                (sqlite-finalize-stmt-raw chunk-entry-stmt)
                (sqlite-finalize-stmt-raw edge-stmt)
                (sqlite-finalize-stmt-raw copy-edges-stmt)
                (sqlite-finalize-stmt-raw copy-before-stmt)
                (sqlite-finalize-stmt-raw root-stmt)
                (sqlite-finalize-stmt-raw root-copy-stmt)
                (sqlite-finalize-stmt-raw root-page-stmt)
                (return (SQLite-Index-Write-Stmts {}) false manifest-error))
              (let [[manifest-run-stmt manifest-run-ok manifest-run-error] (sqlite-prepare-insert-index-run-manifest-run-raw handle)]
                (when (not manifest-run-ok)
                  (sqlite-finalize-stmt-raw chunk-stmt)
                  (sqlite-finalize-stmt-raw chunk-entry-stmt)
                  (sqlite-finalize-stmt-raw edge-stmt)
                  (sqlite-finalize-stmt-raw copy-edges-stmt)
                  (sqlite-finalize-stmt-raw copy-before-stmt)
                  (sqlite-finalize-stmt-raw root-stmt)
                  (sqlite-finalize-stmt-raw root-copy-stmt)
                  (sqlite-finalize-stmt-raw root-page-stmt)
                  (sqlite-finalize-stmt-raw manifest-stmt)
                  (return (SQLite-Index-Write-Stmts {}) false manifest-run-error))
                (let [[manifest-run-bounds-stmt manifest-run-bounds-ok manifest-run-bounds-error] (sqlite-prepare-insert-index-run-manifest-run-bounds-raw handle)]
                  (when (not manifest-run-bounds-ok)
                    (sqlite-finalize-stmt-raw chunk-stmt)
                    (sqlite-finalize-stmt-raw chunk-entry-stmt)
                    (sqlite-finalize-stmt-raw edge-stmt)
                    (sqlite-finalize-stmt-raw copy-edges-stmt)
                    (sqlite-finalize-stmt-raw copy-before-stmt)
                    (sqlite-finalize-stmt-raw root-stmt)
                    (sqlite-finalize-stmt-raw root-copy-stmt)
                    (sqlite-finalize-stmt-raw root-page-stmt)
                    (sqlite-finalize-stmt-raw manifest-stmt)
                    (sqlite-finalize-stmt-raw manifest-run-stmt)
                    (return (SQLite-Index-Write-Stmts {}) false manifest-run-bounds-error))
                (let [[attr-range-stmt attr-range-ok attr-range-error] (sqlite-prepare-insert-index-run-manifest-attr-range-raw handle)]
                  (when (not attr-range-ok)
                    (sqlite-finalize-stmt-raw chunk-stmt)
                    (sqlite-finalize-stmt-raw chunk-entry-stmt)
                    (sqlite-finalize-stmt-raw edge-stmt)
                    (sqlite-finalize-stmt-raw copy-edges-stmt)
                    (sqlite-finalize-stmt-raw copy-before-stmt)
                    (sqlite-finalize-stmt-raw root-stmt)
                    (sqlite-finalize-stmt-raw root-copy-stmt)
                    (sqlite-finalize-stmt-raw root-page-stmt)
                    (sqlite-finalize-stmt-raw manifest-stmt)
                    (sqlite-finalize-stmt-raw manifest-run-stmt)
                    (sqlite-finalize-stmt-raw manifest-run-bounds-stmt)
                    (return (SQLite-Index-Write-Stmts {}) false attr-range-error))
                  (return (SQLite-Index-Write-Stmts {chunk-stmt: chunk-stmt
                                                     chunk-entry-stmt: chunk-entry-stmt
                                                     edge-stmt: edge-stmt
                                                     copy-edges-stmt: copy-edges-stmt
                                                     copy-edges-before-stmt: copy-before-stmt
                                                     root-stmt: root-stmt
                                                     root-copy-stmt: root-copy-stmt
                                                     root-page-stmt: root-page-stmt
                                                     manifest-stmt: manifest-stmt
                                                     manifest-run-stmt: manifest-run-stmt
                                                     manifest-run-bounds-stmt: manifest-run-bounds-stmt
                                                     manifest-attr-range-stmt: attr-range-stmt})
                          true
                          ""))))))))))))))

(defn sqlite-index-write-stmts-close [stmts: SQLite-Index-Write-Stmts]
  (sqlite-finalize-stmt-raw stmts.chunk-stmt)
  (sqlite-finalize-stmt-raw stmts.chunk-entry-stmt)
  (sqlite-finalize-stmt-raw stmts.edge-stmt)
  (sqlite-finalize-stmt-raw stmts.copy-edges-stmt)
  (sqlite-finalize-stmt-raw stmts.copy-edges-before-stmt)
  (sqlite-finalize-stmt-raw stmts.root-stmt)
  (sqlite-finalize-stmt-raw stmts.root-copy-stmt)
  (sqlite-finalize-stmt-raw stmts.root-page-stmt)
  (sqlite-finalize-stmt-raw stmts.manifest-stmt)
  (sqlite-finalize-stmt-raw stmts.manifest-run-stmt)
  (sqlite-finalize-stmt-raw stmts.manifest-run-bounds-stmt)
  (sqlite-finalize-stmt-raw stmts.manifest-attr-range-stmt))

(defstruct SQLite-Direct-Write-Stmts {
  tx-stmt: rawptr
  datom-stmt: rawptr
  tx-meta-stmt: rawptr
})

(defn sqlite-direct-write-stmts-open [handle: rawptr] -> [stmts: SQLite-Direct-Write-Stmts, ok: bool, error: string]
  (let [[tx-stmt tx-ok tx-error] (sqlite-prepare-insert-tx-raw handle)]
    (when (not tx-ok)
      (return (SQLite-Direct-Write-Stmts {}) false tx-error))
    (let [[datom-stmt datom-ok datom-error] (sqlite-prepare-insert-datom-raw handle)]
      (when (not datom-ok)
        (sqlite-finalize-stmt-raw tx-stmt)
        (return (SQLite-Direct-Write-Stmts {}) false datom-error))
      (let [[tx-meta-stmt tx-meta-ok tx-meta-error] (sqlite-prepare-insert-tx-meta-raw handle)]
        (when (not tx-meta-ok)
          (sqlite-finalize-stmt-raw tx-stmt)
          (sqlite-finalize-stmt-raw datom-stmt)
          (return (SQLite-Direct-Write-Stmts {}) false tx-meta-error))
        (return (SQLite-Direct-Write-Stmts {tx-stmt: tx-stmt
                                            datom-stmt: datom-stmt
                                            tx-meta-stmt: tx-meta-stmt})
                true
                "")))))

(defn sqlite-direct-write-stmts-close [stmts: SQLite-Direct-Write-Stmts]
  (sqlite-finalize-stmt-raw stmts.tx-stmt)
  (sqlite-finalize-stmt-raw stmts.datom-stmt)
  (sqlite-finalize-stmt-raw stmts.tx-meta-stmt))

(defn sqlite-insert-index-chunk-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, index-name: string, level: i64, first-key: string, last-key: string, row-count: i64, child-count: i64, payload-text: string, checksum-text: string, created-tx: u64] -> [chunk-id: u64, ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-chunk-raw handle index-name level first-key last-key row-count child-count payload-text checksum-text created-tx)
    (sqlite-step-index-chunk-stmt-raw handle stmts^.chunk-stmt index-name level first-key last-key row-count child-count payload-text checksum-text created-tx)))

(defn sqlite-insert-index-chunk-entries-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, chunk-id: u64, items: []int] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-chunk-entries-raw handle chunk-id items)
    (do
      (for [ordinal (arr.range 0 (count items))]
        (let [[entry-ok entry-error] (sqlite-step-index-chunk-entry-stmt-raw handle stmts^.chunk-entry-stmt chunk-id (i64 ordinal) (i64 items[ordinal]))]
          (when (not entry-ok)
            (return false entry-error))))
      (return true ""))))

(defn sqlite-insert-index-chunk-edge-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, parent-chunk-id: u64, child-chunk-id: u64, ordinal: i64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-chunk-edge-raw handle parent-chunk-id child-chunk-id ordinal)
    (sqlite-step-index-chunk-edge-stmt-raw handle stmts^.edge-stmt parent-chunk-id child-chunk-id ordinal)))

(defn sqlite-copy-index-chunk-edges-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, parent-chunk-id: u64, source-parent-chunk-id: u64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-copy-index-chunk-edges-raw handle parent-chunk-id source-parent-chunk-id)
    (sqlite-step-copy-index-chunk-edges-stmt-raw handle stmts^.copy-edges-stmt parent-chunk-id source-parent-chunk-id)))

(defn sqlite-copy-index-chunk-edges-before-ordinal-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, parent-chunk-id: u64, source-parent-chunk-id: u64, before-ordinal: i64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-copy-index-chunk-edges-before-ordinal-raw handle parent-chunk-id source-parent-chunk-id before-ordinal)
    (sqlite-step-copy-index-chunk-edges-before-ordinal-stmt-raw handle stmts^.copy-edges-before-stmt parent-chunk-id source-parent-chunk-id before-ordinal)))

(defn sqlite-insert-index-chunk-edges-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, parent-chunk-id: u64, child-chunk-ids: []u64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-chunk-edges-raw handle parent-chunk-id child-chunk-ids)
    (do
      (for [ordinal (arr.range 0 (count child-chunk-ids))]
        (let [[edge-ok edge-error] (sqlite-step-index-chunk-edge-stmt-raw handle stmts^.edge-stmt parent-chunk-id child-chunk-ids[ordinal] (i64 ordinal))]
          (when (not edge-ok)
            (return false edge-error))))
      (return true ""))))

(defn sqlite-insert-index-root-with-manifests-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, eavt-id: u64, aevt-id: u64, avet-id: u64, vaet-id: u64, eavt-manifest-id: u64, aevt-manifest-id: u64, avet-manifest-id: u64, vaet-manifest-id: u64] -> [root-id: u64, ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-root-with-manifests-raw handle basis-tx eavt-id aevt-id avet-id vaet-id eavt-manifest-id aevt-manifest-id avet-manifest-id vaet-manifest-id)
    (sqlite-step-index-root-with-manifests-stmt-raw handle stmts^.root-stmt basis-tx eavt-id aevt-id avet-id vaet-id eavt-manifest-id aevt-manifest-id avet-manifest-id vaet-manifest-id)))

(defn sqlite-insert-index-run-manifest-with-parent-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, index-name: string, basis-tx: u64, parent-manifest-id: u64, base-chunk-id: u64, row-count: u64, run-count: u64, created-tx: u64] -> [manifest-id: u64, ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-run-manifest-with-parent-raw handle index-name basis-tx parent-manifest-id base-chunk-id row-count run-count created-tx)
    (sqlite-step-index-run-manifest-with-parent-stmt-raw handle stmts^.manifest-stmt index-name basis-tx parent-manifest-id base-chunk-id row-count run-count created-tx)))

(defn sqlite-insert-index-run-manifest-run-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, run-chunk-id: u64, row-count: u64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-run-manifest-run-raw handle manifest-id ordinal run-chunk-id row-count)
    (sqlite-step-index-run-manifest-run-stmt-raw handle stmts^.manifest-run-stmt manifest-id ordinal run-chunk-id row-count)))

(defn sqlite-insert-index-run-manifest-run-bounds-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, run-chunk-id: u64, row-count: u64, first-datom: Datom, last-datom: Datom] -> [ok: bool, error: string]
  (let [first-value-text (value-serializable-text first-datom.v)
        last-value-text (value-serializable-text last-datom.v)]
    (if (= stmts nil)
      (let [[stmt stmt-ok stmt-error] (sqlite-prepare-insert-index-run-manifest-run-bounds-raw handle)]
        (when (not stmt-ok)
          (delete first-value-text)
          (delete last-value-text)
          (return false stmt-error))
        (let [[ok error] (sqlite-step-index-run-manifest-run-bounds-stmt-raw handle stmt manifest-id ordinal run-chunk-id row-count first-datom.e first-datom.a first-value-text first-datom.tx first-datom.added last-datom.e last-datom.a last-value-text last-datom.tx last-datom.added)]
          (sqlite-finalize-stmt-raw stmt)
          (delete first-value-text)
          (delete last-value-text)
          (return ok error)))
      (let [[ok error] (sqlite-step-index-run-manifest-run-bounds-stmt-raw handle stmts^.manifest-run-bounds-stmt manifest-id ordinal run-chunk-id row-count first-datom.e first-datom.a first-value-text first-datom.tx first-datom.added last-datom.e last-datom.a last-value-text last-datom.tx last-datom.added)]
        (delete first-value-text)
        (delete last-value-text)
        (return ok error)))))

(defn sqlite-insert-index-run-manifest-attr-range-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, attr: string, first-ordinal: i64, first-e: u64, first-value-text: string, first-tx: u64, first-added: bool, last-ordinal: i64, last-e: u64, last-value-text: string, last-tx: u64, last-added: bool] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-run-manifest-attr-range-raw handle manifest-id ordinal attr first-ordinal first-e first-value-text first-tx first-added last-ordinal last-e last-value-text last-tx last-added)
    (sqlite-step-index-run-manifest-attr-range-stmt-raw handle stmts^.manifest-attr-range-stmt manifest-id ordinal attr first-ordinal first-e first-value-text first-tx first-added last-ordinal last-e last-value-text last-tx last-added)))

(defn persist-one-index-chunk-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [first-key (index-bound-text items true)
        last-key (index-bound-text items false)
        payload (index-int-slice-text items)
        [inserted-id inserted-ok inserted-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name 0 first-key last-key (i64 (count items)) 0 payload "" basis-tx)]
    (delete first-key)
    (delete last-key)
    (delete payload)
    (when (not inserted-ok)
      (return inserted-id false inserted-error))
    (return inserted-id true "")))

(defn persist-one-index-chunk-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-one-index-chunk-sqlite-handle-with-stmts handle nil basis-tx index-name items))

(defn persist-entry-backed-index-leaf-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [first-key (index-bound-text items true)
        last-key (index-bound-text items false)
        [inserted-id inserted-ok inserted-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name 0 first-key last-key (i64 (count items)) 0 ":entries" "" basis-tx)]
    (delete first-key)
    (delete last-key)
    (when (not inserted-ok)
      (return inserted-id false inserted-error))
    (let [[entries-ok entries-error] (sqlite-insert-index-chunk-entries-with-stmts handle stmts inserted-id items)]
      (return inserted-id entries-ok entries-error))))

(defstruct Persist-Index-Merge-State {
  total: int
  has-entry: bool
  first-entry: int
  last-entry: int
})

(defn persist-small-delta-index-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (<= (count items) sqlite-index-leaf-chunk-size)
    (return (persist-entry-backed-index-leaf-sqlite-handle-with-stmts handle stmts basis-tx index-name items)))
  (let [leaf-ids (make [dynamic]u64) :defer
        state (Persist-Index-Merge-State {})
        start 0]
    (while (< start (count items))
      (let [end (min (+ start sqlite-index-leaf-chunk-size) (count items))
            leaf-items (slice items start end)
            [leaf-id leaf-ok leaf-error] (persist-entry-backed-index-leaf-sqlite-handle-with-stmts handle stmts basis-tx index-name leaf-items)]
        (when (not leaf-ok)
          (return 0 false leaf-error))
        (when (not state.has-entry)
          (set! state.first-entry leaf-items[0])
          (set! state.has-entry true))
        (set! state.last-entry leaf-items[(- (count leaf-items) 1)])
        (set! state.total (+ state.total (count leaf-items)))
        (arr.push! leaf-ids leaf-id)
        (set! start end)))
    (persist-index-root-from-leaf-ids-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice leaf-ids 0) state)))

(defn persist-index-root-from-leaf-ids-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, leaf-ids: []u64, state: Persist-Index-Merge-State] -> [chunk-id: u64, ok: bool, error: string]
  (when (= state.total 0)
    (return (persist-one-index-chunk-sqlite-handle-with-stmts handle stmts basis-tx index-name ([]int []))))
  (when (= (count leaf-ids) 1)
    (return leaf-ids[0] true ""))
  (let [first-key (index-entry-bound-text state.first-entry)
        last-key (index-entry-bound-text state.last-entry)
        payload (string-owned "[]")
        [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name 1 first-key last-key (i64 state.total) (i64 (count leaf-ids)) payload "" basis-tx)]
    (delete first-key)
    (delete last-key)
    (delete payload)
    (when (not parent-ok)
      (return 0 false parent-error))
    (let [[edges-ok edges-error] (sqlite-insert-index-chunk-edges-with-stmts handle stmts parent-id leaf-ids)]
      (if edges-ok
        (return parent-id true "")
        (return 0 false edges-error)))))

(defn persist-index-root-from-leaf-ids-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, leaf-ids: []u64, state: Persist-Index-Merge-State] -> [chunk-id: u64, ok: bool, error: string]
  (persist-index-root-from-leaf-ids-sqlite-handle-with-stmts handle nil basis-tx index-name leaf-ids state))

(defn persist-index-merge-flush-pending-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, pending: ^[dynamic]int, leaf-ids: ^[dynamic]u64] -> [ok: bool, error: string]
  (when (= (count pending^) 0)
    (return true ""))
  (let [[leaf-id leaf-ok leaf-error] (persist-one-index-chunk-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice pending^ 0))]
    (when (not leaf-ok)
      (return false leaf-error))
    (arr.push! leaf-ids^ leaf-id)
    (delete pending^)
    (set! pending^ (make [dynamic]int))
    (return true "")))

(defn persist-index-merge-flush-pending! [handle: rawptr, basis-tx: u64, index-name: string, pending: ^[dynamic]int, leaf-ids: ^[dynamic]u64] -> [ok: bool, error: string]
  (persist-index-merge-flush-pending-with-stmts! handle nil basis-tx index-name pending leaf-ids))

(defn persist-index-merge-push-entry-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, pending: ^[dynamic]int, leaf-ids: ^[dynamic]u64, state: ^Persist-Index-Merge-State, entry: int] -> [ok: bool, error: string]
  (when (not state^.has-entry)
    (set! state^.first-entry entry)
    (set! state^.has-entry true))
  (set! state^.last-entry entry)
  (set! state^.total (+ state^.total 1))
  (arr.push! pending^ entry)
  (if (>= (count pending^) sqlite-index-leaf-chunk-size)
    (persist-index-merge-flush-pending-with-stmts! handle stmts basis-tx index-name pending leaf-ids)
    (return true "")))

(defn persist-index-merge-push-entry! [handle: rawptr, basis-tx: u64, index-name: string, pending: ^[dynamic]int, leaf-ids: ^[dynamic]u64, state: ^Persist-Index-Merge-State, entry: int] -> [ok: bool, error: string]
  (persist-index-merge-push-entry-with-stmts! handle nil basis-tx index-name pending leaf-ids state entry))

(defn persist-bounded-index-chunks-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (<= (count items) sqlite-index-leaf-chunk-size)
    (return (persist-one-index-chunk-sqlite-handle-with-stmts handle stmts basis-tx index-name items)))
  (let [leaf-ids (make [dynamic]u64) :defer
        start 0]
    (while (< start (count items))
      (let [end (min (+ start sqlite-index-leaf-chunk-size) (count items))
            [leaf-id leaf-ok leaf-error] (persist-one-index-chunk-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice items start end))]
        (when (not leaf-ok)
          (return 0 false leaf-error))
        (arr.push! leaf-ids leaf-id)
        (set! start end)))
    (let [first-key (index-bound-text items true)
          last-key (index-bound-text items false)
          payload (string-owned "[]")
          [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name 1 first-key last-key (i64 (count items)) (i64 (count leaf-ids)) payload "" basis-tx)]
      (delete first-key)
      (delete last-key)
      (delete payload)
      (when (not parent-ok)
        (return 0 false parent-error))
      (let [[edges-ok edges-error] (sqlite-insert-index-chunk-edges-with-stmts handle stmts parent-id (slice leaf-ids 0))]
        (if edges-ok
          (return parent-id true "")
          (return 0 false edges-error))))))

(defn persist-bounded-index-chunks-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, items: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-bounded-index-chunks-sqlite-handle-with-stmts handle nil basis-tx index-name items))

(defn persist-index-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, db: DB] -> [ok: bool, error: string]
  (let [basis-tx (db-basis-tx db)
        [eavt-id eavt-ok eavt-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":eavt" (slice db.eavt 0))]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":aevt" (slice db.aevt 0))]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":avet" (slice db.avet 0))]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":vaet" (slice db.vaet 0))]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [roots (sqlite-index-root-set (sqlite-index-root-page eavt-id 0)
                                             (sqlite-index-root-page aevt-id 0)
                                             (sqlite-index-root-page avet-id 0)
                                             (sqlite-index-root-page vaet-id 0))]
            (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! handle stmts basis-tx roots)))))))

(defn persist-index-root-sqlite-handle [handle: rawptr, db: DB] -> [ok: bool, error: string]
  (persist-index-root-sqlite-handle-with-stmts handle nil db))

(defn persist-index-root-sqlite-handle-from-indexes-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, eavt: []int, aevt: []int, avet: []int, vaet: []int] -> [ok: bool, error: string]
  (let [[eavt-id eavt-ok eavt-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":eavt" eavt)]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":aevt" aevt)]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":avet" avet)]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx ":vaet" vaet)]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [roots (sqlite-index-root-set (sqlite-index-root-page eavt-id 0)
                                             (sqlite-index-root-page aevt-id 0)
                                             (sqlite-index-root-page avet-id 0)
                                             (sqlite-index-root-page vaet-id 0))]
            (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! handle stmts basis-tx roots)))))))

(defn persist-index-root-sqlite-handle-from-indexes [handle: rawptr, basis-tx: u64, eavt: []int, aevt: []int, avet: []int, vaet: []int] -> [ok: bool, error: string]
  (persist-index-root-sqlite-handle-from-indexes-with-stmts handle nil basis-tx eavt aevt avet vaet))

(defn persist-appended-index-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[_ old-count old-root old-ok old-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not old-ok)
      (if (= old-error "sqlite DB has no Vev index roots")
        (return (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name appended))
        (return 0 false old-error)))
    (let [[added-root added-ok added-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name appended)]
      (when (not added-ok)
        (return 0 false added-error))
      (let [[old-level old-level-ok old-level-error] (sqlite-index-chunk-level-raw handle old-root)]
        (when (not old-level-ok)
          (return 0 false old-level-error))
        (let [[added-level added-level-ok added-level-error] (sqlite-index-chunk-level-raw handle added-root)]
          (when (not added-level-ok)
            (return 0 false added-level-error))
          (let [[old-child-count old-child-count-ok old-child-count-error] (sqlite-index-chunk-child-count-raw handle old-root)]
            (when (not old-child-count-ok)
              (return 0 false old-child-count-error))
            (let [flatten-parent (and (> old-level 0)
                                      (< added-level old-level)
                                      (< old-child-count (i64 sqlite-index-parent-fanout)))
                  parent-level (if flatten-parent
	                                 old-level
	                                 (+ (max old-level added-level) 1))
	                  payload (string-owned "[]")
	                  [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name parent-level ":shared-root" ":shared-root" (i64 (+ (int old-count) (count appended))) (if flatten-parent (+ old-child-count 1) 2) payload "" basis-tx)]
	        (delete payload)
	        (when (not parent-ok)
	          (return 0 false parent-error))
	              (if flatten-parent
	                (let [[copy-ok copy-error] (sqlite-copy-index-chunk-edges-with-stmts handle stmts parent-id old-root)]
	                  (when (not copy-ok)
	                    (return 0 false copy-error))
	                  (let [[new-edge-ok new-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id added-root old-child-count)]
	                    (if new-edge-ok
	                      (return parent-id true "")
	                      (return 0 false new-edge-error))))
	                (let [children ([]u64 [old-root added-root])
	                      [edges-ok edges-error] (sqlite-insert-index-chunk-edges-with-stmts handle stmts parent-id children)]
	                  (if edges-ok
	                    (return parent-id true "")
	                    (return 0 false edges-error)))))))))))

(defn persist-appended-index-root-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-appended-index-root-sqlite-handle-with-stmts handle nil basis-tx index-name appended))

(defn persist-appended-index-root-segmented-level1-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[appended-root appended-root-ok appended-root-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name appended)]
    (when (not appended-root-ok)
      (return 0 false appended-root-error))
    (let [payload (string-owned "[]")
          [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (i64 1) ":shared-root" ":shared-root" (i64 (+ old-count (count appended))) (i64 2) payload "" basis-tx)]
      (delete payload)
      (when (not parent-ok)
        (return 0 false parent-error))
      (let [[old-edge-ok old-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id old-root (i64 0))]
        (when (not old-edge-ok)
          (return 0 false old-edge-error))
        (let [[append-edge-ok append-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id appended-root (i64 1))]
          (if append-edge-ok
            (return parent-id true "")
            (return 0 false append-edge-error)))))))

(defn persist-appended-index-root-rollover-payload-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, base-root: u64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[old-payload old-payload-ok old-payload-error] (sqlite-index-chunk-payload-text-raw handle old-root)]
    (when (not old-payload-ok)
      (return 0 false old-payload-error))
    (defer (delete old-payload))
    (let [[old-local old-local-ok old-local-error] (parse-index-entries-text old-payload)]
      (when (not old-local-ok)
        (delete old-local)
        (return 0 false old-local-error))
      (defer (delete old-local))
      (when (= (count old-local) 0)
        (return 0 false "sqlite append root rollover requires a local payload"))
      (let [[old-local-root old-local-root-ok old-local-root-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice old-local 0))]
        (when (not old-local-root-ok)
          (return 0 false old-local-root-error))
        (let [[appended-root appended-root-ok appended-root-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name appended)]
          (when (not appended-root-ok)
            (return 0 false appended-root-error))
          (let [payload (string-owned "[]")
                [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (i64 1) ":shared-root" ":shared-root" (i64 (+ old-count (count appended))) (i64 3) payload "" basis-tx)]
            (delete payload)
            (when (not parent-ok)
              (return 0 false parent-error))
            (let [[base-edge-ok base-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id base-root (i64 0))]
              (when (not base-edge-ok)
                (return 0 false base-edge-error))
              (let [[local-edge-ok local-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id old-local-root (i64 1))]
                (when (not local-edge-ok)
                  (return 0 false local-edge-error))
                (let [[append-edge-ok append-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id appended-root (i64 2))]
                  (if append-edge-ok
                    (return parent-id true "")
                    (return 0 false append-edge-error)))))))))))

(defn persist-appended-index-root-fallback-payload-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [payload (index-int-slice-text appended)
        [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (+ old-level (i64 1)) ":shared-root" ":shared-root" (i64 (+ old-count (count appended))) (i64 1) payload "" basis-tx)]
    (delete payload)
    (when (not parent-ok)
      (return 0 false parent-error))
    (let [[edge-ok edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id old-root (i64 0))]
      (if edge-ok
        (return parent-id true "")
        (return 0 false edge-error)))))

(defn persist-appended-index-root-inline-payload-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, old-child-count: i64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (or (= (count appended) 0)
            (> (count appended) sqlite-index-leaf-chunk-size))
    (return 0 false "sqlite inline append payload requires a non-empty small append segment"))
  (when (and (> old-level 0)
             (= old-child-count (i64 1)))
    (let [[base-root base-root-ok base-root-error] (sqlite-index-child-chunk-id-raw handle old-root (i64 0))]
      (when (not base-root-ok)
        (return 0 false base-root-error))
      (let [[base-count base-count-ok base-count-error] (sqlite-index-chunk-row-count-by-id-raw handle base-root)]
        (when (not base-count-ok)
          (return 0 false base-count-error))
        (when (> (int base-count) old-count)
          (return 0 false "sqlite append root base child row count exceeded parent row count"))
        (let [old-local-count (- old-count (int base-count))]
          (when (= old-level (i64 1))
            (return (persist-appended-index-root-rollover-payload-with-stmts handle stmts basis-tx index-name old-count old-root base-root appended)))))))
  (persist-appended-index-root-fallback-payload-with-stmts handle stmts basis-tx index-name old-count old-root old-level appended))

(defn persist-single-index-subtree-at-level-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, target-level: i64, leaf-root: u64, row-count: int] -> [chunk-id: u64, ok: bool, error: string]
  (when (< target-level (i64 0))
    (return 0 false "sqlite append subtree target level was negative"))
  (when (= target-level (i64 0))
    (return leaf-root true ""))
  (let [current-root leaf-root
        current-level (i64 0)]
    (while (< current-level target-level)
      (let [payload (string-owned "[]")
            [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (+ current-level (i64 1)) ":shared-root" ":shared-root" (i64 row-count) (i64 1) payload "" basis-tx)]
        (delete payload)
        (when (not parent-ok)
          (return 0 false parent-error))
        (let [[edge-ok edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id current-root (i64 0))]
          (when (not edge-ok)
            (return 0 false edge-error)))
        (set! current-root parent-id)
        (set! current-level (+ current-level (i64 1)))))
    (return current-root true "")))

(defn sqlite-index-subtree-has-append-capacity [handle: rawptr, root: u64, level: i64] -> [has-capacity: bool, ok: bool, error: string]
  (when (= level (i64 0))
    (return false true ""))
  (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root)]
    (when (not child-count-ok)
      (return false false child-count-error))
    (when (< child-count (i64 sqlite-index-parent-fanout))
      (return true true ""))
    (let [[last-child last-child-ok last-child-error] (sqlite-index-child-chunk-id-raw handle root (- child-count (i64 1)))]
      (when (not last-child-ok)
        (return false false last-child-error))
      (let [[last-level last-level-ok last-level-error] (sqlite-index-chunk-level-raw handle last-child)]
        (when (not last-level-ok)
          (return false false last-level-error))
        (sqlite-index-subtree-has-append-capacity handle last-child last-level)))))

(defn persist-parent-with-replaced-last-child-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, level: i64, row-count: int, old-root: u64, child-count: i64, replacement-child: u64] -> [chunk-id: u64, ok: bool, error: string]
  (when (<= child-count (i64 0))
    (return 0 false "sqlite append parent replacement had no children"))
  (let [payload (string-owned "[]")
        [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name level ":shared-root" ":shared-root" (i64 row-count) child-count payload "" basis-tx)]
    (delete payload)
    (when (not parent-ok)
      (return 0 false parent-error))
    (let [[copy-ok copy-error] (sqlite-copy-index-chunk-edges-before-ordinal-with-stmts handle stmts parent-id old-root (- child-count (i64 1)))]
      (when (not copy-ok)
        (return 0 false copy-error))
      (let [[edge-ok edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id replacement-child (- child-count (i64 1)))]
        (if edge-ok
          (return parent-id true "")
          (return 0 false edge-error))))))

(defn persist-parent-with-appended-child-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, level: i64, row-count: int, old-root: u64, child-count: i64, appended-child: u64] -> [chunk-id: u64, ok: bool, error: string]
  (when (>= child-count (i64 sqlite-index-parent-fanout))
    (return 0 false "sqlite append parent was full"))
  (let [payload (string-owned "[]")
        [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name level ":shared-root" ":shared-root" (i64 row-count) (+ child-count (i64 1)) payload "" basis-tx)]
    (delete payload)
    (when (not parent-ok)
      (return 0 false parent-error))
    (let [[copy-ok copy-error] (sqlite-copy-index-chunk-edges-with-stmts handle stmts parent-id old-root)]
      (when (not copy-ok)
        (return 0 false copy-error))
      (let [[append-edge-ok append-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id appended-child child-count)]
        (if append-edge-ok
          (return parent-id true "")
          (return 0 false append-edge-error))))))

(defn persist-appended-index-root-fill-rightmost-leaf-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, appended: []int] -> [chunk-id: u64, filled: bool, ok: bool, error: string]
  (when (or (= (count appended) 0)
            (> (count appended) sqlite-index-leaf-chunk-size))
    (return 0 false true ""))
  (when (= old-level (i64 0))
    (when (> (+ old-count (count appended)) sqlite-index-leaf-chunk-size)
      (return 0 false true ""))
    (let [[old-payload old-payload-ok old-payload-error] (sqlite-index-chunk-payload-text-raw handle old-root)]
      (when (not old-payload-ok)
        (return 0 false false old-payload-error))
      (defer (delete old-payload))
      (let [[first-bound old-last-bound bounds-ok bounds-error] (sqlite-index-chunk-bounds-by-id-raw handle old-root)]
        (when (not bounds-ok)
          (return 0 false false bounds-error))
        (defer (delete first-bound))
        (defer (delete old-last-bound))
        (let [[payload payload-ok payload-error] (index-int-payload-text-append old-payload appended)]
          (when (not payload-ok)
            (return 0 false false payload-error))
          (defer (delete payload))
          (let [last-bound (index-entry-bound-text appended[(- (count appended) 1)]) :defer
                [leaf-id leaf-ok leaf-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (i64 0) first-bound last-bound (i64 (+ old-count (count appended))) (i64 0) payload "" basis-tx)]
            (return leaf-id leaf-ok leaf-ok leaf-error))))))
  (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle old-root)]
    (when (not child-count-ok)
      (return 0 false false child-count-error))
    (when (<= child-count (i64 0))
      (return 0 false false "sqlite append fill root had no child edges"))
    (let [[last-child last-child-ok last-child-error] (sqlite-index-child-chunk-id-raw handle old-root (- child-count (i64 1)))]
      (when (not last-child-ok)
        (return 0 false false last-child-error))
      (let [[last-level last-level-ok last-level-error] (sqlite-index-chunk-level-raw handle last-child)]
        (when (not last-level-ok)
          (return 0 false false last-level-error))
        (let [[last-count last-count-ok last-count-error] (sqlite-index-chunk-row-count-by-id-raw handle last-child)]
          (when (not last-count-ok)
            (return 0 false false last-count-error))
          (let [[new-last new-last-filled new-last-ok new-last-error] (persist-appended-index-root-fill-rightmost-leaf-with-stmts handle stmts basis-tx index-name (int last-count) last-child last-level appended)]
            (when (not new-last-ok)
              (return 0 false false new-last-error))
            (when (not new-last-filled)
              (return 0 false true ""))
            (let [[parent-id parent-ok parent-error] (persist-parent-with-replaced-last-child-with-stmts handle stmts basis-tx index-name old-level (+ old-count (count appended)) old-root child-count new-last)]
              (return parent-id true parent-ok parent-error))))))))

(defn persist-appended-index-root-same-level-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, appended-root: u64, appended-count: int] -> [chunk-id: u64, appended: bool, ok: bool, error: string]
  (when (= old-level (i64 0))
    (return 0 false true ""))
  (let [[old-child-count old-child-count-ok old-child-count-error] (sqlite-index-chunk-child-count-raw handle old-root)]
    (when (not old-child-count-ok)
      (return 0 false false old-child-count-error))
    (when (<= old-child-count (i64 0))
      (return 0 false false "sqlite append root had no child edges"))
    (let [[last-child last-child-ok last-child-error] (sqlite-index-child-chunk-id-raw handle old-root (- old-child-count (i64 1)))]
      (when (not last-child-ok)
        (return 0 false false last-child-error))
      (let [[last-level last-level-ok last-level-error] (sqlite-index-chunk-level-raw handle last-child)]
        (when (not last-level-ok)
          (return 0 false false last-level-error))
        (let [[last-capacity last-capacity-ok last-capacity-error] (sqlite-index-subtree-has-append-capacity handle last-child last-level)]
          (when (not last-capacity-ok)
            (return 0 false false last-capacity-error))
          (when last-capacity
            (let [[last-count last-count-ok last-count-error] (sqlite-index-chunk-row-count-by-id-raw handle last-child)]
              (when (not last-count-ok)
                (return 0 false false last-count-error))
              (let [[new-last new-last-appended new-last-ok new-last-error] (persist-appended-index-root-same-level-with-stmts handle stmts basis-tx index-name (int last-count) last-child last-level appended-root appended-count)]
                (when (not new-last-ok)
                  (return 0 false false new-last-error))
                (when new-last-appended
                  (let [[parent-id parent-ok parent-error] (persist-parent-with-replaced-last-child-with-stmts handle stmts basis-tx index-name old-level (+ old-count appended-count) old-root old-child-count new-last)]
                    (return parent-id true parent-ok parent-error)))))))
        (when (< old-child-count (i64 sqlite-index-parent-fanout))
          (let [[padded padded-ok padded-error] (persist-single-index-subtree-at-level-with-stmts handle stmts basis-tx index-name (- old-level (i64 1)) appended-root appended-count)]
            (when (not padded-ok)
              (return 0 false false padded-error))
            (let [[parent-id parent-ok parent-error] (persist-parent-with-appended-child-with-stmts handle stmts basis-tx index-name old-level (+ old-count appended-count) old-root old-child-count padded)]
              (return parent-id true parent-ok parent-error))))
        (return 0 false true "")))))

(defn persist-appended-index-root-sqlite-handle-known-root-and-child-count-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, old-child-count: i64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (= (count appended) 0)
    (return old-root true ""))
  (when (and (> (count appended) 0)
             (<= (count appended) sqlite-index-leaf-chunk-size))
    (let [[filled-root filled filled-ok filled-error] (persist-appended-index-root-fill-rightmost-leaf-with-stmts handle stmts basis-tx index-name old-count old-root old-level appended)]
      (when (not filled-ok)
        (return 0 false filled-error))
      (when filled
        (return filled-root true ""))))
  (when (and (> (count appended) 0)
             (<= (count appended) sqlite-index-leaf-chunk-size)
             (or (= old-level (i64 0))
                 (= old-child-count (i64 1))))
    (when (= old-level (i64 0))
      (return (persist-appended-index-root-segmented-level1-with-stmts handle stmts basis-tx index-name old-count old-root appended)))
    (return (persist-appended-index-root-inline-payload-with-stmts handle stmts basis-tx index-name old-count old-root old-level old-child-count appended)))
  (let [[added-root added-ok added-error] (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name appended)]
    (when (not added-ok)
      (return 0 false added-error))
    (when (and (> (count appended) 0)
               (<= (count appended) sqlite-index-leaf-chunk-size)
               (> old-level (i64 0)))
      (let [[same-root same-appended same-ok same-error] (persist-appended-index-root-same-level-with-stmts handle stmts basis-tx index-name old-count old-root old-level added-root (count appended))]
        (when (not same-ok)
          (return 0 false same-error))
        (when same-appended
          (return same-root true ""))))
    (let [added-level: i64 0]
      (when (> (count appended) sqlite-index-leaf-chunk-size)
        (let [[level level-ok level-error] (sqlite-index-chunk-level-raw handle added-root)]
          (when (not level-ok)
            (return 0 false level-error))
          (set! added-level level)))
      (when (and (> (count appended) 0)
                 (<= (count appended) sqlite-index-leaf-chunk-size)
                 (> old-level (i64 0)))
        (let [[padded padded-ok padded-error] (persist-single-index-subtree-at-level-with-stmts handle stmts basis-tx index-name old-level added-root (count appended))]
          (when (not padded-ok)
            (return 0 false padded-error))
          (let [payload (string-owned "[]")
                [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (+ old-level (i64 1)) ":shared-root" ":shared-root" (i64 (+ old-count (count appended))) (i64 2) payload "" basis-tx)]
            (delete payload)
            (when (not parent-ok)
              (return 0 false parent-error))
            (let [[old-edge-ok old-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id old-root (i64 0))]
              (when (not old-edge-ok)
                (return 0 false old-edge-error))
              (let [[padded-edge-ok padded-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id padded (i64 1))]
                (if padded-edge-ok
                  (return parent-id true "")
                  (return 0 false padded-edge-error)))))))
      (let [flatten-parent false
            known-child-count old-child-count]
        (when (and (> old-level 0)
                   (< added-level old-level))
          (set! flatten-parent (< known-child-count (i64 sqlite-index-parent-fanout))))
        (let [parent-level (if flatten-parent
                             old-level
                             (+ (max old-level added-level) 1))
              payload (string-owned "[]")
              [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name parent-level ":shared-root" ":shared-root" (i64 (+ old-count (count appended))) (if flatten-parent (+ known-child-count 1) 2) payload "" basis-tx)]
          (delete payload)
          (when (not parent-ok)
            (return 0 false parent-error))
          (if flatten-parent
            (let [[copy-ok copy-error] (sqlite-copy-index-chunk-edges-raw handle parent-id old-root)]
              (when (not copy-ok)
                (return 0 false copy-error))
              (let [[new-edge-ok new-edge-error] (sqlite-insert-index-chunk-edge-with-stmts handle stmts parent-id added-root known-child-count)]
                (if new-edge-ok
                  (return parent-id true "")
                  (return 0 false new-edge-error))))
            (let [children ([]u64 [old-root added-root])
                  [edges-ok edges-error] (sqlite-insert-index-chunk-edges-with-stmts handle stmts parent-id children)]
              (if edges-ok
                (return parent-id true "")
                (return 0 false edges-error)))))))))

(defn persist-appended-index-root-sqlite-handle-known-root-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [old-child-count: i64 0]
    (when (> old-level 0)
      (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle old-root)]
        (when (not child-count-ok)
          (return 0 false child-count-error))
        (set! old-child-count child-count)))
    (persist-appended-index-root-sqlite-handle-known-root-and-child-count-with-stmts handle stmts basis-tx index-name old-count old-root old-level old-child-count appended)))

(defn persist-appended-index-root-sqlite-handle-known-root [handle: rawptr, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-level: i64, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-appended-index-root-sqlite-handle-known-root-with-stmts handle nil basis-tx index-name old-count old-root old-level appended))

(defn persist-appended-index-root-sqlite-handle-for-view-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (= view.kind .SQLite-Cursor)
    (let [[known-id known-ok known-error] (persist-appended-index-root-sqlite-handle-known-root-and-child-count-with-stmts handle stmts basis-tx index-name view.sqlite-cursor^.row-count view.sqlite-cursor^.root-id view.sqlite-cursor^.root-level view.sqlite-cursor^.root-child-count appended)]
      (return known-id known-ok known-error)))
  (persist-appended-index-root-sqlite-handle handle basis-tx index-name appended))

(defn persist-appended-index-root-sqlite-handle-for-view [handle: rawptr, basis-tx: u64, index-name: string, view: DB-Index-View, appended: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-appended-index-root-sqlite-handle-for-view-with-stmts handle nil basis-tx index-name view appended))

(defn sqlite-index-root-level [handle: rawptr, root-id: u64] -> [level: i64, ok: bool, error: string]
  (sqlite-index-chunk-level-raw handle root-id))

(defn persist-merge-root-from-run-roots-and-metadata-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, roots: []u64, counts: []int, metadata-counts: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (= (count roots) 0)
    (return (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name ([]int []))))
  (when (= (count roots) 1)
    (return roots[0] true ""))
  (let [total 0
        max-level: i64 0
        first-bound 0
        last-bound 0
        has-bound false]
    (for [index (arr.range 0 (count roots))]
      (set! total (+ total counts[index]))
      (let [[level level-ok level-error] (sqlite-index-root-level handle roots[index])]
        (when (not level-ok)
          (return 0 false level-error))
        (when (> level max-level)
          (set! max-level level)))
      (let [[child-first child-last child-bounds-ok child-bounds-error] (sqlite-index-chunk-bounds-by-id-raw handle roots[index])]
        (when (not child-bounds-ok)
          (return 0 false child-bounds-error))
        (let [[child-first-entry child-first-ok] (parse-index-bound-entry child-first)
              [child-last-entry child-last-ok] (parse-index-bound-entry child-last)]
          (delete child-first)
          (delete child-last)
          (when (and child-first-ok child-last-ok)
            (if (not has-bound)
              (do
                (set! first-bound child-first-entry)
                (set! last-bound child-last-entry)
                (set! has-bound true))
              (do
                (let [[child-first-less first-less-ok first-less-error] (sqlite-index-root-entry-less? handle (sqlite-index-name-order index-name) child-first-entry first-bound)]
                  (when (not first-less-ok)
                    (return 0 false first-less-error))
                  (when child-first-less
                    (set! first-bound child-first-entry)))
                (let [[last-less-child last-less-ok last-less-error] (sqlite-index-root-entry-less? handle (sqlite-index-name-order index-name) last-bound child-last-entry)]
                  (when (not last-less-ok)
                    (return 0 false last-less-error))
                  (when last-less-child
                    (set! last-bound child-last-entry)))))))))
    (let [first-key (if has-bound (string-owned (fmt.tprintf ":merge-root:%d" first-bound)) (string-owned ":merge-root"))
          last-key (if has-bound (index-entry-bound-text last-bound) (string-owned ":merge-root"))
          payload (string-owned "[]")
          metadata (index-int-slice-text metadata-counts)
          [parent-id parent-ok parent-error] (sqlite-insert-index-chunk-with-stmts handle stmts index-name (+ max-level 1) first-key last-key (i64 total) (i64 (count roots)) payload metadata basis-tx)]
      (delete first-key)
      (delete last-key)
      (delete payload)
      (delete metadata)
      (when (not parent-ok)
        (return 0 false parent-error))
      (let [[edges-ok edges-error] (sqlite-insert-index-chunk-edges-with-stmts handle stmts parent-id roots)]
        (if edges-ok
          (return parent-id true "")
          (return 0 false edges-error))))))

(defn persist-merge-root-from-run-roots-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, roots: []u64, counts: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-merge-root-from-run-roots-and-metadata-sqlite-handle-with-stmts handle stmts basis-tx index-name roots counts counts))

(defn persist-merge-root-from-run-roots-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, roots: []u64, counts: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-merge-root-from-run-roots-sqlite-handle-with-stmts handle nil basis-tx index-name roots counts))

(defn persist-merge-root-appending-run-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, added-root: u64, added-count: int] -> [chunk-id: u64, ok: bool, error: string]
  (let [roots ([]u64 [old-root added-root])
        counts ([]int [old-count added-count])]
    (persist-merge-root-from-run-roots-sqlite-handle-with-stmts handle stmts basis-tx index-name roots counts)))

(defn persist-merge-root-appending-run [handle: rawptr, basis-tx: u64, index-name: string, old-count: int, old-root: u64, added-root: u64, added-count: int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-merge-root-appending-run-with-stmts handle nil basis-tx index-name old-count old-root added-root added-count))

(defn persist-merge-root-appending-run-with-counts-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, added-root: u64, added-count: int, counts: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [roots ([]u64 [old-root added-root])
        root-counts ([]int [old-count added-count])]
    (persist-merge-root-from-run-roots-and-metadata-sqlite-handle-with-stmts handle stmts basis-tx index-name roots root-counts counts)))

(defn sqlite-index-merge-root-count-metadata [handle: rawptr, root-id: u64] -> [counts: [dynamic]int, has?: bool, ok: bool, error: string]
  (let [[text text-ok text-error] (sqlite-index-chunk-checksum-text-raw handle root-id)]
    (when (not text-ok)
      (return (make [dynamic]int) false false text-error))
    (defer (delete text))
    (when (= text "")
      (return (make [dynamic]int) false true ""))
    (let [[parsed-counts parsed-ok _counts-error] (parse-index-entries-text text)]
      (when (not parsed-ok)
        (delete parsed-counts)
        (return (make [dynamic]int) false true ""))
      (if (= (count parsed-counts) 0)
        (do
          (delete parsed-counts)
          (return (make [dynamic]int) false true ""))
        (return parsed-counts true true "")))))

(defn sqlite-merge-counts-with-added [handle: rawptr, old-root: u64, added-count: int] -> [counts: [dynamic]int, has?: bool, ok: bool, error: string]
  (let [[metadata-counts metadata-has metadata-ok metadata-error] (sqlite-index-merge-root-count-metadata handle old-root)]
    (when (not metadata-ok)
      (delete metadata-counts)
      (return (make [dynamic]int) false false metadata-error))
    (when (not metadata-has)
      (delete metadata-counts)
      (return (make [dynamic]int) false true ""))
    (arr.push! metadata-counts added-count)
    (return metadata-counts true true "")))

(defn sqlite-tiered-merge-compaction-range [counts: []int] -> [start: int, end: int, compact?: bool]
  (let [run-count (count counts)]
    (when (<= run-count sqlite-index-merge-root-fanout)
      (return 0 0 false))
    (let [last-size counts[(- run-count 1)]
          trailing-start (- run-count 1)]
      (while (and (> trailing-start 0)
                  (= counts[(- trailing-start 1)] last-size))
        (set! trailing-start (- trailing-start 1)))
      (let [trailing-count (- run-count trailing-start)]
        (when (>= trailing-count sqlite-index-merge-root-fanout)
          (return (- run-count sqlite-index-merge-root-fanout) run-count true))
        (when (> run-count sqlite-index-merge-root-max-direct-runs)
        (return (- run-count sqlite-index-merge-root-fanout) run-count true))
        (return 0 0 false)))))

(defn sqlite-maintenance-merge-compaction-range [counts: []int] -> [start: int, end: int, compact?: bool]
  (let [[tier-start tier-end tier-compact] (sqlite-tiered-merge-compaction-range counts)]
    (when tier-compact
      (return tier-start tier-end true))
    (let [run-count (count counts)]
      (if (> run-count sqlite-index-merge-root-fanout)
        (return (- run-count sqlite-index-merge-root-fanout) run-count true)
        (return 0 0 false)))))

(defn sqlite-index-run-count-total [counts: []int, start: int, end: int] -> int
  (let [total 0]
    (for [index (arr.range start end)]
      (set! total (+ total counts[index])))
    total))

(defn sqlite-merge-counts-maintenance-row-count [counts: []int] -> [row-count: int, needed: bool]
  (let [[compact-start compact-end should-compact] (sqlite-maintenance-merge-compaction-range counts)]
    (if should-compact
      (return (sqlite-index-run-count-total counts compact-start compact-end) true)
      (return 0 false))))

(defn sqlite-foreground-merge-compaction-inline? [counts: []int, start: int, end: int] -> bool
  (<= (sqlite-index-run-count-total counts start end) sqlite-index-foreground-merge-row-budget))

(defn persist-merge-run-index-root-from-counts-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, added-root: u64, added-count: int, run-counts: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[compact-start compact-end should-compact] (sqlite-tiered-merge-compaction-range run-counts)]
    (if should-compact
      (if (sqlite-foreground-merge-compaction-inline? run-counts compact-start compact-end)
        (let [[run-roots fallback-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle old-root)]
          (when (not runs-ok)
            (delete run-roots)
            (delete fallback-counts)
            (return 0 false runs-error))
          (defer (delete run-roots))
          (defer (delete fallback-counts))
          (arr.push! run-roots added-root)
          (arr.push! fallback-counts added-count)
          (let [order (sqlite-index-name-order index-name)
                [compacted-root compacted-count compacted-ok compacted-error] (sqlite-merge-run-roots-into-ordered-root handle basis-tx index-name order (slice run-roots 0) (slice fallback-counts 0) compact-start compact-end)]
            (when (not compacted-ok)
              (return 0 false compacted-error))
            (let [next-roots (make [dynamic]u64) :defer
                  next-counts (make [dynamic]int) :defer]
              (for [index (arr.range 0 compact-start)]
                (arr.push! next-roots run-roots[index])
                (arr.push! next-counts fallback-counts[index]))
              (arr.push! next-roots compacted-root)
              (arr.push! next-counts compacted-count)
              (for [index (arr.range compact-end (count run-roots))]
                (arr.push! next-roots run-roots[index])
                (arr.push! next-counts fallback-counts[index]))
              (persist-merge-root-from-run-roots-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice next-roots 0) (slice next-counts 0)))))
        (persist-merge-root-appending-run-with-counts-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count run-counts))
      (persist-merge-root-appending-run-with-counts-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count run-counts))))

(defn sqlite-latest-index-root-next-compaction-row-count [handle: rawptr, index-name: string] -> [row-count: int, needed: bool, ok: bool, error: string]
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (if (= basis-error "sqlite DB has no Vev index roots")
        (return 0 false true "")
        (return 0 false false basis-error)))
    (let [[manifest-id manifest-row-count manifest-run-count has-manifest manifest-ok manifest-error] (sqlite-latest-index-root-manifest-info handle basis index-name)]
      (discard manifest-row-count)
      (when (not manifest-ok)
        (return 0 false false manifest-error))
      (when has-manifest
        (when (<= manifest-run-count sqlite-index-merge-root-fanout)
          (return 0 false true ""))
        (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-run-manifest-child-runs handle manifest-id)]
          (discard run-roots)
          (when (not runs-ok)
            (delete run-roots)
            (delete run-counts)
            (return 0 false false runs-error))
          (defer (delete run-roots))
          (defer (delete run-counts))
          (let [[manifest-maintenance-row-count manifest-needed] (sqlite-merge-counts-maintenance-row-count (slice run-counts 0))]
            (return manifest-maintenance-row-count manifest-needed true ""))))))
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not root-ok)
      (if (= root-error "sqlite DB has no Vev index roots")
        (return 0 false true "")
        (return 0 false false root-error)))
    (let [[_ first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root)]
      (when (not info-ok)
        (return 0 false false info-error))
      (defer (delete first-key))
      (when (not (sqlite-index-merge-root-key? first-key))
        (return 0 false true ""))
      (let [[metadata-counts metadata-has metadata-ok metadata-error] (sqlite-index-merge-root-count-metadata handle root)]
        (when (not metadata-ok)
          (delete metadata-counts)
          (return 0 false false metadata-error))
        (when metadata-has
          (defer (delete metadata-counts))
          (let [[metadata-row-count metadata-needed] (sqlite-merge-counts-maintenance-row-count (slice metadata-counts 0))]
            (return metadata-row-count metadata-needed true "")))
        (delete metadata-counts))
      (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle root)]
        (discard run-roots)
        (when (not runs-ok)
          (delete run-roots)
          (delete run-counts)
          (return 0 false false runs-error))
        (defer (delete run-roots))
        (defer (delete run-counts))
        (let [[compact-start compact-end should-compact] (sqlite-maintenance-merge-compaction-range (slice run-counts 0))]
          (if should-compact
            (return (sqlite-index-run-count-total (slice run-counts 0) compact-start compact-end) true true "")
            (return 0 false true "")))))))

(defn sqlite-index-name-order [index-name: string] -> string
  (if (= index-name ":eavt")
    "eavt"
    (if (= index-name ":aevt")
      "aevt"
      (if (= index-name ":avet")
        "avet"
        "vaet"))))

(defn sqlite-merge-run-roots-into-ordered-root [handle: rawptr, basis-tx: u64, index-name: string, order: string, roots: []u64, counts: []int, start: int, end: int] -> [chunk-id: u64, row-count: int, ok: bool, error: string]
  (when (or (< start 0)
            (> end (count roots))
            (>= start end))
    (return 0 0 false "invalid sqlite merge-run compaction range"))
  (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
    (when (not datom-stmt-ok)
      (return 0 0 false datom-stmt-error))
    (defer (sqlite-finalize-stmt-raw datom-stmt))
    (let [selected-roots (make [dynamic]u64)
          selected-counts (make [dynamic]int)]
      (for [index (arr.range start end)]
        (arr.push! selected-roots roots[index])
        (arr.push! selected-counts counts[index]))
      (let [pending (make [dynamic]int)
        leaf-ids (make [dynamic]u64)
            positions (make [dynamic]int 0 (count selected-roots))
            current-entries (make [dynamic]int 0 (count selected-roots))
            current-datoms (make [dynamic]Datom 0 (count selected-roots))
            has-current (make [dynamic]bool 0 (count selected-roots))
            page0 (make [dynamic]int)
            page1 (make [dynamic]int)
            page2 (make [dynamic]int)
            page3 (make [dynamic]int)
            page-start0 -1
            page-end0 -1
            page-start1 -1
            page-end1 -1
            page-start2 -1
            page-end2 -1
            page-start3 -1
            page-end3 -1
            state (Persist-Index-Merge-State {})]
        (for [local (arr.range 0 (count selected-roots))]
          (arr.push! positions 0)
          (if (> selected-counts[local] 0)
            (let [[entry entry-ok entry-error] (sqlite-index-merge-child-entry-at-cached handle (slice selected-roots 0) (slice selected-counts 0) local 0 sqlite-index-leaf-chunk-size (addr page0) (addr page-start0) (addr page-end0) (addr page1) (addr page-start1) (addr page-end1) (addr page2) (addr page-start2) (addr page-end2) (addr page3) (addr page-start3) (addr page-end3))]
              (when (not entry-ok)
                (delete pending)
                (delete leaf-ids)
                (delete positions)
                (delete current-entries)
                (delete current-datoms)
                (delete has-current)
                (delete page0)
                (delete page1)
                (delete page2)
                (delete page3)
                (delete selected-roots)
                (delete selected-counts)
                (return 0 state.total false entry-error))
              (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt entry)]
                (when (not datom-ok)
                  (delete pending)
                  (delete leaf-ids)
                  (delete positions)
                  (delete current-entries)
                  (delete current-datoms)
                  (delete has-current)
                  (delete page0)
                  (delete page1)
                  (delete page2)
                  (delete page3)
                  (delete selected-roots)
                  (delete selected-counts)
                  (return 0 state.total false datom-error))
                (arr.push! current-datoms datom))
              (arr.push! current-entries entry)
              (arr.push! has-current true))
            (do
              (arr.push! current-datoms (Datom {}))
              (arr.push! current-entries 0)
              (arr.push! has-current false))))
        (while true
          (let [best-local -1
                best-entry 0]
            (for [local (arr.range 0 (count selected-roots))]
              (when has-current[local]
                (if (= best-local -1)
                  (do
                    (set! best-local local)
                    (set! best-entry current-entries[local]))
                  (let [candidate-less (datom-less-order? current-datoms[local] current-datoms[best-local] order current-entries[local] best-entry)]
                    (when candidate-less
                      (set! best-local local)
                      (set! best-entry current-entries[local]))))))
            (when (= best-local -1)
              (let [[flush-ok flush-error] (persist-index-merge-flush-pending! handle basis-tx index-name (addr pending) (addr leaf-ids))]
                (when (not flush-ok)
                  (delete-active-datoms! (addr current-datoms) (addr has-current))
                  (delete pending)
                  (delete leaf-ids)
                  (delete positions)
                  (delete current-entries)
                  (delete current-datoms)
                  (delete has-current)
                  (delete page0)
                  (delete page1)
                  (delete page2)
                  (delete page3)
                  (delete selected-roots)
                  (delete selected-counts)
                  (return 0 state.total false flush-error))
                (let [[root root-ok root-error] (persist-index-root-from-leaf-ids-sqlite-handle handle basis-tx index-name (slice leaf-ids 0) state)]
                  (delete-active-datoms! (addr current-datoms) (addr has-current))
                  (delete pending)
                  (delete leaf-ids)
                  (delete positions)
                  (delete current-entries)
                  (delete current-datoms)
                  (delete has-current)
                  (delete page0)
                  (delete page1)
                  (delete page2)
                  (delete page3)
                  (delete selected-roots)
                  (delete selected-counts)
                  (return root state.total root-ok root-error))))
            (let [[push-ok push-error] (persist-index-merge-push-entry! handle basis-tx index-name (addr pending) (addr leaf-ids) (addr state) best-entry)]
              (when (not push-ok)
                (delete-active-datoms! (addr current-datoms) (addr has-current))
                (delete pending)
                (delete leaf-ids)
                (delete positions)
                (delete current-entries)
                (delete current-datoms)
                (delete has-current)
                (delete page0)
                (delete page1)
                (delete page2)
                (delete page3)
                (delete selected-roots)
                (delete selected-counts)
                (return 0 state.total false push-error)))
            (set! positions[best-local] (+ positions[best-local] 1))
            (delete-owned-datom current-datoms[best-local])
            (set! has-current[best-local] false)
            (if (< positions[best-local] selected-counts[best-local])
              (let [[next-entry next-ok next-error] (sqlite-index-merge-child-entry-at-cached handle (slice selected-roots 0) (slice selected-counts 0) best-local positions[best-local] sqlite-index-leaf-chunk-size (addr page0) (addr page-start0) (addr page-end0) (addr page1) (addr page-start1) (addr page-end1) (addr page2) (addr page-start2) (addr page-end2) (addr page3) (addr page-start3) (addr page-end3))]
                (when (not next-ok)
                  (delete-active-datoms! (addr current-datoms) (addr has-current))
                  (delete pending)
                  (delete leaf-ids)
                  (delete positions)
                  (delete current-entries)
                  (delete current-datoms)
                  (delete has-current)
                  (delete page0)
                  (delete page1)
                  (delete page2)
                  (delete page3)
                  (delete selected-roots)
                  (delete selected-counts)
                  (return 0 state.total false next-error))
                (let [[next-datom next-datom-ok next-datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt next-entry)]
                  (when (not next-datom-ok)
                    (delete-active-datoms! (addr current-datoms) (addr has-current))
                    (delete pending)
                    (delete leaf-ids)
                    (delete positions)
                    (delete current-entries)
                    (delete current-datoms)
                    (delete has-current)
                    (delete page0)
                    (delete page1)
                    (delete page2)
                    (delete page3)
                    (delete selected-roots)
                    (delete selected-counts)
                    (return 0 state.total false next-datom-error))
                  (set! current-datoms[best-local] next-datom))
                (set! current-entries[best-local] next-entry)
                (set! has-current[best-local] true))
              (set! has-current[best-local] false))))
        (delete-active-datoms! (addr current-datoms) (addr has-current))
        (delete pending)
        (delete leaf-ids)
        (delete positions)
        (delete current-entries)
        (delete current-datoms)
        (delete has-current)
        (delete page0)
        (delete page1)
        (delete page2)
        (delete page3)
        (delete selected-roots)
        (delete selected-counts)
        (return 0 state.total false "sqlite merge-run compaction exited unexpectedly")))))

(defn persist-merge-run-index-root-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, added: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[_ old-count old-root old-ok old-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not old-ok)
      (if (= old-error "sqlite DB has no Vev index roots")
        (return (persist-bounded-index-chunks-sqlite-handle handle basis-tx index-name added))
        (return 0 false old-error)))
    (let [[added-root added-ok added-error] (persist-bounded-index-chunks-sqlite-handle handle basis-tx index-name added)]
      (when (not added-ok)
        (return 0 false added-error))
      (let [[_ old-first-key _old-level old-info-ok old-info-error] (sqlite-index-chunk-info-by-id-raw handle old-root)]
        (when (not old-info-ok)
          (return 0 false old-info-error))
        (if (sqlite-index-merge-root-key? old-first-key)
          (let [[metadata-counts metadata-has metadata-ok metadata-error] (sqlite-merge-counts-with-added handle old-root (count added))]
            (delete old-first-key)
            (when (not metadata-ok)
              (delete metadata-counts)
              (return 0 false metadata-error))
            (when metadata-has
              (defer (delete metadata-counts))
              (return (persist-merge-run-index-root-from-counts-with-stmts handle nil basis-tx index-name (int old-count) old-root added-root (count added) (slice metadata-counts 0))))
            (delete metadata-counts)
            (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle old-root)]
            (when (not runs-ok)
              (delete run-roots)
              (delete run-counts)
              (return 0 false runs-error))
            (defer (delete run-roots))
            (defer (delete run-counts))
            (arr.push! run-roots added-root)
            (arr.push! run-counts (count added))
            (let [[compact-start compact-end should-compact] (sqlite-tiered-merge-compaction-range (slice run-counts 0))]
              (if should-compact
                (if (sqlite-foreground-merge-compaction-inline? (slice run-counts 0) compact-start compact-end)
                  (let [order (sqlite-index-name-order index-name)
                        [compacted-root compacted-count compacted-ok compacted-error] (sqlite-merge-run-roots-into-ordered-root handle basis-tx index-name order (slice run-roots 0) (slice run-counts 0) compact-start compact-end)]
                    (when (not compacted-ok)
                      (return 0 false compacted-error))
                    (let [next-roots (make [dynamic]u64) :defer
                          next-counts (make [dynamic]int) :defer]
                      (for [index (arr.range 0 compact-start)]
                        (arr.push! next-roots run-roots[index])
                        (arr.push! next-counts run-counts[index]))
                      (arr.push! next-roots compacted-root)
                      (arr.push! next-counts compacted-count)
                      (for [index (arr.range compact-end (count run-roots))]
                        (arr.push! next-roots run-roots[index])
                        (arr.push! next-counts run-counts[index]))
                      (persist-merge-root-from-run-roots-sqlite-handle handle basis-tx index-name (slice next-roots 0) (slice next-counts 0))))
                (persist-merge-root-appending-run handle basis-tx index-name (int old-count) old-root added-root (count added)))
                (persist-merge-root-appending-run handle basis-tx index-name (int old-count) old-root added-root (count added)))))
            )
          (do
            (delete old-first-key)
            (persist-merge-root-appending-run handle basis-tx index-name (int old-count) old-root added-root (count added))))))))

(defn persist-merge-run-index-root-sqlite-handle-known-root-and-added-root-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-first-key: string, added-root: u64, added-count: int] -> [chunk-id: u64, ok: bool, error: string]
    (if (sqlite-index-merge-root-key? old-first-key)
      (let [[metadata-counts metadata-has metadata-ok metadata-error] (sqlite-merge-counts-with-added handle old-root added-count)]
        (when (not metadata-ok)
          (delete metadata-counts)
          (return 0 false metadata-error))
        (when metadata-has
          (defer (delete metadata-counts))
          (return (persist-merge-run-index-root-from-counts-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count (slice metadata-counts 0))))
        (delete metadata-counts)
        (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle old-root)]
        (when (not runs-ok)
          (delete run-roots)
          (delete run-counts)
          (return 0 false runs-error))
        (defer (delete run-roots))
        (defer (delete run-counts))
        (arr.push! run-roots added-root)
        (arr.push! run-counts added-count)
        (let [[compact-start compact-end should-compact] (sqlite-tiered-merge-compaction-range (slice run-counts 0))]
          (if should-compact
            (if (sqlite-foreground-merge-compaction-inline? (slice run-counts 0) compact-start compact-end)
              (let [order (sqlite-index-name-order index-name)
                    [compacted-root compacted-count compacted-ok compacted-error] (sqlite-merge-run-roots-into-ordered-root handle basis-tx index-name order (slice run-roots 0) (slice run-counts 0) compact-start compact-end)]
                (when (not compacted-ok)
                  (return 0 false compacted-error))
                (let [next-roots (make [dynamic]u64) :defer
                      next-counts (make [dynamic]int) :defer]
                  (for [index (arr.range 0 compact-start)]
                    (arr.push! next-roots run-roots[index])
                    (arr.push! next-counts run-counts[index]))
                  (arr.push! next-roots compacted-root)
                  (arr.push! next-counts compacted-count)
                  (for [index (arr.range compact-end (count run-roots))]
                    (arr.push! next-roots run-roots[index])
                    (arr.push! next-counts run-counts[index]))
                  (persist-merge-root-from-run-roots-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice next-roots 0) (slice next-counts 0))))
              (persist-merge-root-appending-run-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count))
            (persist-merge-root-appending-run-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count)))))
      (persist-merge-root-appending-run-with-stmts handle stmts basis-tx index-name old-count old-root added-root added-count)))

(defn persist-merge-run-index-root-sqlite-handle-known-root-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-first-key: string, added: []int] -> [chunk-id: u64, ok: bool, error: string]
  (let [[added-root added-ok added-error] (persist-small-delta-index-root-sqlite-handle-with-stmts handle stmts basis-tx index-name added)]
    (when (not added-ok)
      (return 0 false added-error))
    (persist-merge-run-index-root-sqlite-handle-known-root-and-added-root-with-stmts handle stmts basis-tx index-name old-count old-root old-first-key added-root (count added))))

(defn persist-merge-run-index-root-sqlite-handle-known-root [handle: rawptr, basis-tx: u64, index-name: string, old-count: int, old-root: u64, old-first-key: string, added: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-merge-run-index-root-sqlite-handle-known-root-with-stmts handle nil basis-tx index-name old-count old-root old-first-key added))

(defn persist-merge-run-index-root-sqlite-handle-for-view-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int] -> [chunk-id: u64, ok: bool, error: string]
  (when (= view.kind .SQLite-Cursor)
    (return (persist-merge-run-index-root-sqlite-handle-known-root-with-stmts handle stmts basis-tx index-name view.sqlite-cursor^.row-count view.sqlite-cursor^.root-id view.sqlite-cursor^.root-first-key added)))
  (persist-merge-run-index-root-sqlite-handle handle basis-tx index-name added))

(defn persist-merge-run-index-root-sqlite-handle-for-view [handle: rawptr, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int] -> [chunk-id: u64, ok: bool, error: string]
  (persist-merge-run-index-root-sqlite-handle-for-view-with-stmts handle nil basis-tx index-name view added))

(defn persist-run-manifest-index-root-sqlite-handle-for-view-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int] -> [chunk-id: u64, manifest-id: u64, ok: bool, error: string]
  (persist-run-manifest-index-root-sqlite-handle-for-view-and-appended-with-stmts handle stmts basis-tx index-name view added ([]Datom []) 0 false))

(defn persist-run-manifest-index-root-sqlite-handle-for-view-and-appended-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int, appended: []Datom, start-index: int, has-appended?: bool] -> [chunk-id: u64, manifest-id: u64, ok: bool, error: string]
  (when (not (= view.kind .SQLite-Cursor))
    (let [[chunk-id chunk-ok chunk-error] (persist-merge-run-index-root-sqlite-handle-for-view-with-stmts handle stmts basis-tx index-name view added)]
      (return chunk-id 0 chunk-ok chunk-error)))
  (let [[added-root added-ok added-error] (persist-small-delta-index-root-sqlite-handle-with-stmts handle stmts basis-tx index-name added)]
    (when (not added-ok)
      (return 0 0 false added-error))
    (let [old-run-count: u64 0
          parent-manifest-id: u64 0]
      (when view.sqlite-cursor^.root-is-manifest
        (set! parent-manifest-id view.sqlite-cursor^.manifest-id)
        (set! old-run-count view.sqlite-cursor^.manifest-run-count))
    (let [
          next-run-count (+ old-run-count 1)
          [next-manifest-id manifest-ok manifest-error] (sqlite-insert-index-run-manifest-with-parent-with-stmts handle stmts index-name basis-tx parent-manifest-id view.sqlite-cursor^.root-id (u64 (+ view.sqlite-cursor^.row-count (count added))) next-run-count basis-tx)]
      (when (not manifest-ok)
        (return 0 0 false manifest-error))
      (let [added-run-ok false
            added-run-error ""]
        (if has-appended?
          (let [first-local (- added[0] start-index)
                last-local (- added[(- (count added) 1)] start-index)]
            (when (or (< first-local 0)
                      (>= first-local (count appended))
                      (< last-local 0)
                      (>= last-local (count appended)))
              (return 0 0 false "manifest run bound entry was outside appended datoms"))
            (let [[bounded-ok bounded-error] (sqlite-insert-index-run-manifest-run-bounds-with-stmts handle stmts next-manifest-id 0 added-root (u64 (count added)) appended[first-local] appended[last-local])]
              (set! added-run-ok bounded-ok)
              (set! added-run-error bounded-error)))
          (let [[run-ok run-error] (sqlite-insert-index-run-manifest-run-with-stmts handle stmts next-manifest-id 0 added-root (u64 (count added)))]
            (set! added-run-ok run-ok)
            (set! added-run-error run-error)))
        (when (not added-run-ok)
          (return 0 0 false added-run-error))
        (let [[entity-range-ok entity-range-error] (sqlite-insert-index-run-manifest-entity-attr-ranges-from-root! handle next-manifest-id 0 index-name added-root)]
          (when (not entity-range-ok)
            (return 0 0 false entity-range-error)))
        (if (sqlite-index-name-has-contiguous-attrs? index-name)
          (if has-appended?
            (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-ranges-from-appended-entries-with-stmts! handle stmts next-manifest-id 0 added appended start-index)]
              (return view.sqlite-cursor^.root-id next-manifest-id range-ok range-error))
            (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-ranges-from-entries-with-stmts! handle stmts next-manifest-id 0 added)]
              (return view.sqlite-cursor^.root-id next-manifest-id range-ok range-error)))
          (return view.sqlite-cursor^.root-id next-manifest-id true "")))))))

(defn sqlite-republish-latest-index-root-with [handle: rawptr, basis-tx: u64, index-name: string, new-root: u64] -> [ok: bool, error: string]
  (let [[_ eavt-count eavt-root eavt-ok eavt-error] (sqlite-latest-index-root-chunk-info-raw handle ":eavt")]
    (discard eavt-count)
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[_ aevt-count aevt-root aevt-ok aevt-error] (sqlite-latest-index-root-chunk-info-raw handle ":aevt")]
      (discard aevt-count)
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[_ avet-count avet-root avet-ok avet-error] (sqlite-latest-index-root-chunk-info-raw handle ":avet")]
        (discard avet-count)
        (when (not avet-ok)
          (return false avet-error))
        (let [[_ vaet-count vaet-root vaet-ok vaet-error] (sqlite-latest-index-root-chunk-info-raw handle ":vaet")]
          (discard vaet-count)
          (when (not vaet-ok)
            (return false vaet-error))
          (let [next-eavt (if (= index-name ":eavt") new-root eavt-root)
                next-aevt (if (= index-name ":aevt") new-root aevt-root)
                next-avet (if (= index-name ":avet") new-root avet-root)
                next-vaet (if (= index-name ":vaet") new-root vaet-root)
                [_ root-ok root-error] (sqlite-insert-index-root-raw handle basis-tx next-eavt next-aevt next-avet next-vaet)]
            (return root-ok root-error)))))))

(defn sqlite-latest-index-root-and-manifest-at-basis [handle: rawptr, basis-tx: u64, index-name: string] -> [root-id: u64, manifest-id: u64, ok: bool, error: string]
  (let [[_rows root manifest _manifest-runs first-key _level _children info-ok info-error] (sqlite-index-root-chunk-info-at-basis-raw handle index-name basis-tx)]
    (discard _rows)
    (discard _manifest-runs)
    (discard _level)
    (discard _children)
    (when (not info-ok)
      (return 0 0 false info-error))
    (delete first-key)
    (return root manifest true "")))

(defn sqlite-index-root-page [root-id: u64, manifest-id: u64] -> SQLite-Index-Root-Page
  (SQLite-Index-Root-Page {root-id: root-id manifest-id: manifest-id}))

(defn sqlite-index-root-set [eavt: SQLite-Index-Root-Page, aevt: SQLite-Index-Root-Page, avet: SQLite-Index-Root-Page, vaet: SQLite-Index-Root-Page] -> SQLite-Index-Root-Set
  (SQLite-Index-Root-Set {eavt: eavt
                          aevt: aevt
                          avet: avet
                          vaet: vaet}))

(defn sqlite-index-root-set-at-basis [handle: rawptr, basis-tx: u64] -> [roots: SQLite-Index-Root-Set, ok: bool, error: string]
  (let [[page-eavt-root page-aevt-root page-avet-root page-vaet-root page-eavt-manifest page-aevt-manifest page-avet-manifest page-vaet-manifest page-ok page-error] (sqlite-index-root-page-set-at-basis-raw handle basis-tx)]
    (when page-ok
      (return (sqlite-index-root-set (sqlite-index-root-page page-eavt-root page-eavt-manifest)
                                     (sqlite-index-root-page page-aevt-root page-aevt-manifest)
                                     (sqlite-index-root-page page-avet-root page-avet-manifest)
                                     (sqlite-index-root-page page-vaet-root page-vaet-manifest))
              true
              ""))
    (when (not (= page-error "sqlite DB has no normalized Vev index root pages for basis"))
      (return (SQLite-Index-Root-Set {}) false page-error)))
  (let [[eavt-root aevt-root avet-root vaet-root eavt-manifest aevt-manifest avet-manifest vaet-manifest roots-ok roots-error] (sqlite-index-root-set-at-basis-wide-raw handle basis-tx)]
    (when (not roots-ok)
      (return (SQLite-Index-Root-Set {}) false roots-error))
    (return (sqlite-index-root-set (sqlite-index-root-page eavt-root eavt-manifest)
                                   (sqlite-index-root-page aevt-root aevt-manifest)
                                   (sqlite-index-root-page avet-root avet-manifest)
                                   (sqlite-index-root-page vaet-root vaet-manifest))
            true
            "")))

(defn sqlite-index-root-row-id-at-basis [handle: rawptr, basis-tx: u64] -> [root-row-id: u64, ok: bool, error: string]
  (sqlite-index-root-row-id-at-basis-raw handle basis-tx))

(defn sqlite-index-root-set-with-index [roots: SQLite-Index-Root-Set, index-name: string, new-root: u64, new-manifest-id: u64] -> SQLite-Index-Root-Set
  (let [new-page (sqlite-index-root-page new-root new-manifest-id)]
    (sqlite-index-root-set (if (= index-name ":eavt") new-page roots.eavt)
                           (if (= index-name ":aevt") new-page roots.aevt)
                           (if (= index-name ":avet") new-page roots.avet)
                           (if (= index-name ":vaet") new-page roots.vaet))))

(defn sqlite-index-root-set-from-publishes [eavt: SQLite-Index-Root-Publish, aevt: SQLite-Index-Root-Publish, avet: SQLite-Index-Root-Publish, vaet: SQLite-Index-Root-Publish] -> SQLite-Index-Root-Set
  (sqlite-index-root-set (sqlite-index-root-page eavt.root-id eavt.manifest-id)
                         (sqlite-index-root-page aevt.root-id aevt.manifest-id)
                         (sqlite-index-root-page avet.root-id avet.manifest-id)
                         (sqlite-index-root-page vaet.root-id vaet.manifest-id)))

(defn sqlite-index-append-modes-from-publishes [eavt: SQLite-Index-Root-Publish, aevt: SQLite-Index-Root-Publish, avet: SQLite-Index-Root-Publish, vaet: SQLite-Index-Root-Publish] -> SQLite-Index-Append-Modes
  (SQLite-Index-Append-Modes {eavt: eavt.append-mode
                              aevt: aevt.append-mode
                              avet: avet.append-mode
                              vaet: vaet.append-mode}))

(defn sqlite-index-root-publish-set [eavt: SQLite-Index-Root-Publish, aevt: SQLite-Index-Root-Publish, avet: SQLite-Index-Root-Publish, vaet: SQLite-Index-Root-Publish] -> SQLite-Index-Root-Publish-Set
  (SQLite-Index-Root-Publish-Set {eavt: eavt
                                  aevt: aevt
                                  avet: avet
                                  vaet: vaet}))

(defn sqlite-index-root-set-from-publish-set [publishes: SQLite-Index-Root-Publish-Set] -> SQLite-Index-Root-Set
  (sqlite-index-root-set-from-publishes publishes.eavt publishes.aevt publishes.avet publishes.vaet))

(defn sqlite-index-append-modes-from-publish-set [publishes: SQLite-Index-Root-Publish-Set] -> SQLite-Index-Append-Modes
  (sqlite-index-append-modes-from-publishes publishes.eavt publishes.aevt publishes.avet publishes.vaet))

(defn sqlite-publish-index-root-set-from-publishes-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, publishes: SQLite-Index-Root-Publish-Set, enqueue-maintenance: bool] -> [modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (let [roots (sqlite-index-root-set-from-publish-set publishes)
        append-modes (sqlite-index-append-modes-from-publish-set publishes)
        [root-ok root-error] (sqlite-insert-index-root-set-with-maintenance-mode-with-stmts! handle stmts basis-tx roots enqueue-maintenance)]
    (return append-modes root-ok root-error)))

(defn sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts-id! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, roots: SQLite-Index-Root-Set] -> [root-row-id: u64, ok: bool, error: string]
  (let [[inserted-root-row-id root-ok root-error] (sqlite-insert-index-root-set-with-stmts! handle stmts basis-tx roots)]
    (when (not root-ok)
      (return inserted-root-row-id false root-error))
    (let [[eavt-ok eavt-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":eavt" roots.eavt.root-id roots.eavt.manifest-id)]
      (when (not eavt-ok)
        (return inserted-root-row-id false eavt-error))
      (let [[aevt-ok aevt-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":aevt" roots.aevt.root-id roots.aevt.manifest-id)]
        (when (not aevt-ok)
          (return inserted-root-row-id false aevt-error))
        (let [[avet-ok avet-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":avet" roots.avet.root-id roots.avet.manifest-id)]
          (when (not avet-ok)
            (return inserted-root-row-id false avet-error))
          (let [[vaet-ok vaet-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":vaet" roots.vaet.root-id roots.vaet.manifest-id)]
            (return inserted-root-row-id vaet-ok vaet-error)))))))

(defn sqlite-publish-durable-append-publication-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, publication: SQLite-Durable-Append-Publication, enqueue-maintenance: bool] -> [published: SQLite-Durable-Published-Root, ok: bool, error: string]
  (if enqueue-maintenance
    (let [[root-row-id root-ok root-error] (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts-id! handle stmts basis-tx publication.roots)]
      (return (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                              basis-tx: basis-tx
                                              roots: publication.roots
                                              modes: publication.modes})
              root-ok
              root-error))
    (let [[root-row-id root-ok root-error] (sqlite-insert-index-root-set-with-stmts! handle stmts basis-tx publication.roots)]
      (return (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                              basis-tx: basis-tx
                                              roots: publication.roots
                                              modes: publication.modes})
              root-ok
              root-error))))

(defn sqlite-republish-latest-index-root-with-manifest [handle: rawptr, basis-tx: u64, index-name: string, new-root: u64, new-manifest-id: u64] -> [ok: bool, error: string]
  (let [[old-roots old-roots-ok old-roots-error] (sqlite-index-root-set-at-basis handle basis-tx)]
    (when (not old-roots-ok)
      (return false old-roots-error))
    (let [next-roots (sqlite-index-root-set-with-index old-roots index-name new-root new-manifest-id)]
      (sqlite-insert-index-root-set-and-enqueue-maintenance! handle basis-tx next-roots))))

(defn sqlite-persist-run-manifest-from-run-roots [handle: rawptr, basis-tx: u64, index-name: string, roots: []u64, counts: []int] -> [manifest-id: u64, ok: bool, error: string]
  (when (not (= (count roots) (count counts)))
    (return 0 false "sqlite run manifest root/count length mismatch"))
  (when (= (count roots) 0)
    (return 0 false "sqlite run manifest requires at least one root"))
  (let [total 0]
    (for [index (arr.range 0 (count counts))]
      (set! total (+ total counts[index])))
    (let [[created-manifest-id manifest-ok manifest-error] (sqlite-insert-index-run-manifest-raw handle index-name basis-tx roots[0] (u64 total) (u64 (count roots)) basis-tx)]
      (when (not manifest-ok)
        (return 0 false manifest-error))
      (for [index (arr.range 1 (count roots))]
        (let [[run-ok run-error] (sqlite-insert-index-run-manifest-run-raw handle created-manifest-id (u64 (- index 1)) roots[index] (u64 counts[index]))]
          (when (not run-ok)
            (return 0 false run-error))
          (let [[entity-range-ok entity-range-error] (sqlite-insert-index-run-manifest-entity-attr-ranges-from-root! handle created-manifest-id (u64 (- index 1)) index-name roots[index])]
            (when (not entity-range-ok)
              (return 0 false entity-range-error)))
          (when (sqlite-index-name-has-contiguous-attrs? index-name)
            (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-ranges-from-root! handle created-manifest-id (u64 (- index 1)) roots[index] counts[index])]
              (when (not range-ok)
                (return 0 false range-error))))))
      (return created-manifest-id true ""))))

(defn sqlite-latest-index-root-manifest-info [handle: rawptr, basis-tx: u64, index-name: string] -> [manifest-id: u64, row-count: int, run-count: int, has-manifest: bool, ok: bool, error: string]
  (let [[rows _root manifest manifest-runs first-key _level _children info-ok info-error] (sqlite-index-root-chunk-info-at-basis-raw handle index-name basis-tx)]
    (discard _root)
    (discard _level)
    (discard _children)
    (when (not info-ok)
      (return 0 0 0 false false info-error))
    (delete first-key)
    (when (= manifest 0)
      (return 0 0 0 false true ""))
    (return manifest (int rows) (int manifest-runs) true true "")))

(defn sqlite-maintain-latest-manifest-root-step! [handle: rawptr, basis-tx: u64, index-name: string] -> [compacted: bool, ok: bool, error: string]
  (let [[manifest-id _row-count run-count has-manifest manifest-ok manifest-error] (sqlite-latest-index-root-manifest-info handle basis-tx index-name)]
    (discard _row-count)
    (when (not manifest-ok)
      (return false false manifest-error))
    (when (not has-manifest)
      (return false true ""))
    (when (<= run-count sqlite-index-merge-root-fanout)
      (return false true ""))
    (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-run-manifest-child-runs handle manifest-id)]
      (when (not runs-ok)
        (delete run-roots)
        (delete run-counts)
        (return false false runs-error))
      (defer (delete run-roots))
      (defer (delete run-counts))
      (let [[compact-start compact-end should-compact] (sqlite-maintenance-merge-compaction-range (slice run-counts 0))]
        (when (not should-compact)
          (return false true ""))
        (let [[compacted-root compacted-count compacted-ok compacted-error] (sqlite-merge-run-roots-into-ordered-root handle basis-tx index-name (sqlite-index-name-order index-name) (slice run-roots 0) (slice run-counts 0) compact-start compact-end)]
          (when (not compacted-ok)
            (return false false compacted-error))
          (let [next-roots (make [dynamic]u64) :defer
                next-counts (make [dynamic]int) :defer]
            (for [index (arr.range 0 compact-start)]
              (arr.push! next-roots run-roots[index])
              (arr.push! next-counts run-counts[index]))
            (arr.push! next-roots compacted-root)
            (arr.push! next-counts compacted-count)
            (for [index (arr.range compact-end (count run-roots))]
              (arr.push! next-roots run-roots[index])
              (arr.push! next-counts run-counts[index]))
            (if (= (count next-roots) 1)
              (let [[publish-ok publish-error] (sqlite-republish-latest-index-root-with-manifest handle basis-tx index-name next-roots[0] 0)]
                (return true publish-ok publish-error))
              (let [[next-manifest-id next-manifest-ok next-manifest-error] (sqlite-persist-run-manifest-from-run-roots handle basis-tx index-name (slice next-roots 0) (slice next-counts 0))]
                (when (not next-manifest-ok)
                  (return false false next-manifest-error))
                (let [[publish-ok publish-error] (sqlite-republish-latest-index-root-with-manifest handle basis-tx index-name next-roots[0] next-manifest-id)]
                  (return true publish-ok publish-error))))))))))

(defn sqlite-index-root-needs-maintenance? [handle: rawptr, root-id: u64] -> [needed: bool, ok: bool, error: string]
  (let [[_ first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root-id)]
    (when (not info-ok)
      (return false false info-error))
    (defer (delete first-key))
    (when (not (sqlite-index-merge-root-key? first-key))
      (return false true ""))
    (let [[metadata-counts metadata-has metadata-ok metadata-error] (sqlite-index-merge-root-count-metadata handle root-id)]
      (when (not metadata-ok)
        (delete metadata-counts)
        (return false false metadata-error))
      (when metadata-has
        (defer (delete metadata-counts))
        (let [[_ metadata-needed] (sqlite-merge-counts-maintenance-row-count (slice metadata-counts 0))]
          (return metadata-needed true "")))
      (delete metadata-counts))
    (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle root-id)]
      (when (not runs-ok)
        (delete run-roots)
        (delete run-counts)
        (return false false runs-error))
      (defer (delete run-roots))
      (defer (delete run-counts))
      (let [[_ _ should-compact] (sqlite-maintenance-merge-compaction-range (slice run-counts 0))]
        (return should-compact true "")))))

(defn sqlite-enqueue-index-maintenance-if-needed! [handle: rawptr, basis-tx: u64, index-name: string, root-id: u64] -> [ok: bool, error: string]
  (let [[needed needed-ok needed-error] (sqlite-index-root-needs-maintenance? handle root-id)]
    (when (not needed-ok)
      (return false needed-error))
    (let [[clear-ok clear-error] (sqlite_delete_index_maintenance_for_index_raw handle index-name)]
      (when (not clear-ok)
        (return false clear-error))
      (if needed
        (sqlite_enqueue_index_maintenance_raw handle index-name basis-tx root-id)
        (return true "")))))

(defn sqlite-enqueue-latest-index-maintenance-if-needed! [handle: rawptr, basis-tx: u64, index-name: string] -> [ok: bool, error: string]
  (let [[latest-basis _ latest-root latest-ok latest-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not latest-ok)
      (if (= latest-error "sqlite DB has no Vev index roots")
        (return true "")
        (return false latest-error)))
    (when (not (= latest-basis basis-tx))
      (return true ""))
    (sqlite-enqueue-index-maintenance-if-needed! handle basis-tx index-name latest-root)))

(defn sqlite-enqueue-latest-index-maintenance-unless-manifest! [handle: rawptr, basis-tx: u64, index-name: string] -> [ok: bool, error: string]
  (let [[root-id manifest-id root-ok root-error] (sqlite-latest-index-root-and-manifest-at-basis handle basis-tx index-name)]
    (when (not root-ok)
      (if (= root-error "sqlite DB has no Vev index roots")
        (return true "")
        (return false root-error)))
    (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx index-name root-id manifest-id)))

(defn sqlite-enqueue-latest-root-set-maintenance-unless-manifest! [handle: rawptr, basis-tx: u64] -> [ok: bool, error: string]
  (let [[eavt-ok eavt-error] (sqlite-enqueue-latest-index-maintenance-unless-manifest! handle basis-tx ":eavt")]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-ok aevt-error] (sqlite-enqueue-latest-index-maintenance-unless-manifest! handle basis-tx ":aevt")]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-ok avet-error] (sqlite-enqueue-latest-index-maintenance-unless-manifest! handle basis-tx ":avet")]
        (when (not avet-ok)
          (return false avet-error))
        (sqlite-enqueue-latest-index-maintenance-unless-manifest! handle basis-tx ":vaet")))))

(defn sqlite-enqueue-index-maintenance-unless-manifest! [handle: rawptr, basis-tx: u64, index-name: string, root-id: u64, manifest-id: u64] -> [ok: bool, error: string]
  (if (> manifest-id 0)
    (return true "")
    (sqlite-enqueue-index-maintenance-if-needed! handle basis-tx index-name root-id)))

(defn sqlite-insert-index-root-and-enqueue-maintenance! [handle: rawptr, basis-tx: u64, eavt-id: u64, aevt-id: u64, avet-id: u64, vaet-id: u64] -> [ok: bool, error: string]
  (sqlite-insert-index-root-set-and-enqueue-maintenance! handle basis-tx
    (sqlite-index-root-set (sqlite-index-root-page eavt-id 0)
                           (sqlite-index-root-page aevt-id 0)
                           (sqlite-index-root-page avet-id 0)
                           (sqlite-index-root-page vaet-id 0))))

(defn sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, roots: SQLite-Index-Root-Set] -> [ok: bool, error: string]
  (let [[_ root-ok root-error] (sqlite-insert-index-root-set-with-stmts! handle stmts basis-tx roots)]
    (when (not root-ok)
      (return false root-error))
    (let [[eavt-ok eavt-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":eavt" roots.eavt.root-id roots.eavt.manifest-id)]
      (when (not eavt-ok)
        (return false eavt-error))
      (let [[aevt-ok aevt-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":aevt" roots.aevt.root-id roots.aevt.manifest-id)]
        (when (not aevt-ok)
          (return false aevt-error))
        (let [[avet-ok avet-error] (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":avet" roots.avet.root-id roots.avet.manifest-id)]
          (when (not avet-ok)
            (return false avet-error))
          (sqlite-enqueue-index-maintenance-unless-manifest! handle basis-tx ":vaet" roots.vaet.root-id roots.vaet.manifest-id))))))

(defn sqlite-insert-index-root-page! [handle: rawptr, root-id: u64, index-name: string, page: SQLite-Index-Root-Page, ordinal: i64] -> [ok: bool, error: string]
  (sqlite-insert-index-root-page-raw handle root-id index-name page.root-id page.manifest-id ordinal))

(defn sqlite-insert-index-root-page-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, root-id: u64, index-name: string, page: SQLite-Index-Root-Page, ordinal: i64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-index-root-page! handle root-id index-name page ordinal)
    (sqlite-step-index-root-page-stmt-raw handle stmts^.root-page-stmt root-id index-name page.root-id page.manifest-id ordinal)))

(defn sqlite-insert-index-root-pages-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, root-id: u64, roots: SQLite-Index-Root-Set] -> [ok: bool, error: string]
  (let [[eavt-ok eavt-error] (sqlite-insert-index-root-page-with-stmts! handle stmts root-id ":eavt" roots.eavt 0)]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-ok aevt-error] (sqlite-insert-index-root-page-with-stmts! handle stmts root-id ":aevt" roots.aevt 1)]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-ok avet-error] (sqlite-insert-index-root-page-with-stmts! handle stmts root-id ":avet" roots.avet 2)]
        (when (not avet-ok)
          (return false avet-error))
        (sqlite-insert-index-root-page-with-stmts! handle stmts root-id ":vaet" roots.vaet 3)))))

(defn sqlite-insert-index-root-pages! [handle: rawptr, root-id: u64, roots: SQLite-Index-Root-Set] -> [ok: bool, error: string]
  (sqlite-insert-index-root-pages-with-stmts! handle nil root-id roots))

(defn sqlite-insert-index-root-set-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, roots: SQLite-Index-Root-Set] -> [root-id: u64, ok: bool, error: string]
  (let [[published-root-id root-ok root-error] (sqlite-insert-index-root-with-manifests-with-stmts
                                                handle
                                                stmts
                                                basis-tx
                                                roots.eavt.root-id
                                                roots.aevt.root-id
                                                roots.avet.root-id
                                                roots.vaet.root-id
                                                roots.eavt.manifest-id
                                                roots.aevt.manifest-id
                                                roots.avet.manifest-id
                                                roots.vaet.manifest-id)]
    (when (not root-ok)
      (return published-root-id false root-error))
    (let [[pages-ok pages-error] (sqlite-insert-index-root-pages-with-stmts! handle stmts published-root-id roots)]
      (return published-root-id pages-ok pages-error))))

(defn sqlite-insert-index-root-set! [handle: rawptr, basis-tx: u64, roots: SQLite-Index-Root-Set] -> [root-id: u64, ok: bool, error: string]
  (sqlite-insert-index-root-set-with-stmts! handle nil basis-tx roots))

(defn sqlite-copy-latest-index-root-set-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64] -> [root-id: u64, ok: bool, error: string]
  (let [[latest-basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return 0 false basis-error))
    (let [[latest-roots roots-ok roots-error] (sqlite-index-root-set-at-basis handle latest-basis)]
      (when (not roots-ok)
        (return 0 false roots-error))
      (if (= stmts nil)
        (let [[copied-root-id root-ok root-error] (sqlite-insert-index-root-copy-latest-raw handle basis-tx)]
          (when (not root-ok)
            (return copied-root-id false root-error))
          (let [[pages-ok pages-error] (sqlite-insert-index-root-pages-with-stmts! handle nil copied-root-id latest-roots)]
            (return copied-root-id pages-ok pages-error)))
        (let [[copied-root-id root-ok root-error] (sqlite-step-index-root-copy-latest-stmt-raw handle stmts^.root-copy-stmt basis-tx)]
          (when (not root-ok)
            (return copied-root-id false root-error))
          (let [[pages-ok pages-error] (sqlite-insert-index-root-pages-with-stmts! handle stmts copied-root-id latest-roots)]
            (return copied-root-id pages-ok pages-error)))))))

(defn sqlite-republish-latest-index-root-set-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64] -> [root-id: u64, ok: bool, error: string]
  (sqlite-copy-latest-index-root-set-with-stmts! handle stmts basis-tx))

(defn sqlite-republish-latest-index-root-set! [handle: rawptr, basis-tx: u64] -> [root-id: u64, ok: bool, error: string]
  (sqlite-republish-latest-index-root-set-with-stmts! handle nil basis-tx))

(defn sqlite-insert-index-root-set-and-enqueue-maintenance! [handle: rawptr, basis-tx: u64, roots: SQLite-Index-Root-Set] -> [ok: bool, error: string]
  (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! handle nil basis-tx roots))

(defn sqlite-insert-index-root-set-with-maintenance-mode-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, roots: SQLite-Index-Root-Set, enqueue-maintenance: bool] -> [ok: bool, error: string]
  (if enqueue-maintenance
    (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! handle stmts basis-tx roots)
    (let [[_root-id root-ok root-error] (sqlite-insert-index-root-set-with-stmts! handle stmts basis-tx roots)]
      (discard _root-id)
      (return root-ok root-error))))

(defn sqlite-maintain-latest-index-root-step! [handle: rawptr, basis-tx: u64, index-name: string] -> [compacted: bool, ok: bool, error: string]
  (let [[manifest-compacted manifest-ok manifest-error] (sqlite-maintain-latest-manifest-root-step! handle basis-tx index-name)]
    (when (or manifest-compacted (not manifest-ok))
      (return manifest-compacted manifest-ok manifest-error)))
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not root-ok)
      (if (= root-error "sqlite DB has no Vev index roots")
        (return false true "")
        (return false false root-error)))
    (let [[_ first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root)]
      (when (not info-ok)
        (return false false info-error))
      (defer (delete first-key))
      (when (not (sqlite-index-merge-root-key? first-key))
        (return false true ""))
      (let [[run-roots run-counts runs-ok runs-error] (sqlite-index-merge-root-child-runs handle root)]
        (when (not runs-ok)
          (delete run-roots)
          (delete run-counts)
          (return false false runs-error))
        (defer (delete run-roots))
        (defer (delete run-counts))
        (let [[compact-start compact-end should-compact] (sqlite-maintenance-merge-compaction-range (slice run-counts 0))]
          (when (not should-compact)
            (return false true ""))
          (let [[compacted-root compacted-count compacted-ok compacted-error] (sqlite-merge-run-roots-into-ordered-root handle basis-tx index-name (sqlite-index-name-order index-name) (slice run-roots 0) (slice run-counts 0) compact-start compact-end)]
            (when (not compacted-ok)
              (return false false compacted-error))
            (let [next-roots (make [dynamic]u64) :defer
                  next-counts (make [dynamic]int) :defer]
              (for [index (arr.range 0 compact-start)]
                (arr.push! next-roots run-roots[index])
                (arr.push! next-counts run-counts[index]))
              (arr.push! next-roots compacted-root)
              (arr.push! next-counts compacted-count)
              (for [index (arr.range compact-end (count run-roots))]
                (arr.push! next-roots run-roots[index])
                (arr.push! next-counts run-counts[index]))
              (let [[new-root new-root-ok new-root-error] (persist-merge-root-from-run-roots-sqlite-handle handle basis-tx index-name (slice next-roots 0) (slice next-counts 0))]
                (when (not new-root-ok)
                  (return false false new-root-error))
                (let [[publish-ok publish-error] (sqlite-republish-latest-index-root-with handle basis-tx index-name new-root)]
                  (when (not publish-ok)
                    (return false false publish-error))
                  (let [[enqueue-ok enqueue-error] (sqlite-enqueue-index-maintenance-if-needed! handle basis-tx index-name new-root)]
                    (return true enqueue-ok enqueue-error)))))))))))

(defn sqlite-latest-index-root-merge-child-count [handle: rawptr, index-name: string] -> [child-count: int, is-merge: bool, ok: bool, error: string]
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not root-ok)
      (if (= root-error "sqlite DB has no Vev index roots")
        (return 0 false true "")
        (return 0 false false root-error)))
    (let [[_ first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root)]
      (when (not info-ok)
        (return 0 false false info-error))
      (defer (delete first-key))
      (when (not (sqlite-index-merge-root-key? first-key))
        (return 0 false true ""))
      (let [[children children-ok children-error] (sqlite-index-chunk-child-count-raw handle root)]
        (if children-ok
          (return (int children) true true "")
          (return 0 true false children-error))))))

(defn sqlite-index-merge-root-run-count-into [handle: rawptr, root-id: u64, total: int] -> [run-count: int, ok: bool, error: string]
  (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root-id)]
    (when (not child-count-ok)
      (return total false child-count-error))
    (let [out total]
      (for [ordinal (arr.range 0 (int child-count))]
        (let [[child-root child-ok child-error] (sqlite-index-child-chunk-id-raw handle root-id (i64 ordinal))]
          (when (not child-ok)
            (return out false child-error))
          (let [[_ child-key _child-level child-info-ok child-info-error] (sqlite-index-chunk-info-by-id-raw handle child-root)]
            (when (not child-info-ok)
              (return out false child-info-error))
            (if (sqlite-index-merge-root-key? child-key)
              (do
                (delete child-key)
                (let [[nested-count nested-ok nested-error] (sqlite-index-merge-root-run-count-into handle child-root out)]
                  (when (not nested-ok)
                    (return nested-count false nested-error))
                  (set! out nested-count)))
              (do
                (delete child-key)
                (set! out (+ out 1)))))))
      (return out true ""))))

(defn sqlite-latest-index-root-merge-run-count [handle: rawptr, index-name: string] -> [run-count: int, is-merge: bool, ok: bool, error: string]
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (if (= basis-error "sqlite DB has no Vev index roots")
        (return 0 false true "")
        (return 0 false false basis-error)))
    (let [[_manifest-id _row-count manifest-run-count has-manifest manifest-ok manifest-error] (sqlite-latest-index-root-manifest-info handle basis index-name)]
      (discard _manifest-id)
      (discard _row-count)
      (when (not manifest-ok)
        (return 0 false false manifest-error))
      (when has-manifest
        (return manifest-run-count true true ""))))
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
    (when (not root-ok)
      (if (= root-error "sqlite DB has no Vev index roots")
        (return 0 false true "")
        (return 0 false false root-error)))
    (let [[_ first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root)]
      (when (not info-ok)
        (return 0 false false info-error))
      (defer (delete first-key))
      (when (not (sqlite-index-merge-root-key? first-key))
        (return 0 false true ""))
      (let [[flattened-count flattened-ok flattened-error] (sqlite-index-merge-root-run-count-into handle root 0)]
        (return flattened-count true flattened-ok flattened-error)))))

(defn persist-index-root-sqlite-handle-index-mode-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, indexes: []int, appended-only: bool] -> [chunk-id: u64, ok: bool, error: string]
  (if appended-only
    (persist-appended-index-root-sqlite-handle-with-stmts handle stmts basis-tx index-name indexes)
    (persist-bounded-index-chunks-sqlite-handle-with-stmts handle stmts basis-tx index-name indexes)))

(defn persist-index-root-sqlite-handle-index-mode [handle: rawptr, basis-tx: u64, index-name: string, indexes: []int, appended-only: bool] -> [chunk-id: u64, ok: bool, error: string]
  (persist-index-root-sqlite-handle-index-mode-with-stmts handle nil basis-tx index-name indexes appended-only))

(defn persist-index-root-sqlite-handle-from-indexes-mode-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, eavt: []int, aevt: []int, avet: []int, vaet: []int, modes: SQLite-Index-Append-Modes] -> [ok: bool, error: string]
  (let [[eavt-id eavt-ok eavt-error] (persist-index-root-sqlite-handle-index-mode-with-stmts handle stmts basis-tx ":eavt" eavt modes.eavt)]
    (when (not eavt-ok)
      (return false eavt-error))
    (let [[aevt-id aevt-ok aevt-error] (persist-index-root-sqlite-handle-index-mode-with-stmts handle stmts basis-tx ":aevt" aevt modes.aevt)]
      (when (not aevt-ok)
        (return false aevt-error))
      (let [[avet-id avet-ok avet-error] (persist-index-root-sqlite-handle-index-mode-with-stmts handle stmts basis-tx ":avet" avet modes.avet)]
        (when (not avet-ok)
          (return false avet-error))
        (let [[vaet-id vaet-ok vaet-error] (persist-index-root-sqlite-handle-index-mode-with-stmts handle stmts basis-tx ":vaet" vaet modes.vaet)]
          (when (not vaet-ok)
            (return false vaet-error))
          (let [roots (sqlite-index-root-set (sqlite-index-root-page eavt-id 0)
                                             (sqlite-index-root-page aevt-id 0)
                                             (sqlite-index-root-page avet-id 0)
                                             (sqlite-index-root-page vaet-id 0))]
            (sqlite-insert-index-root-set-and-enqueue-maintenance-with-stmts! handle stmts basis-tx roots)))))))

(defn persist-index-root-sqlite-handle-from-indexes-mode [handle: rawptr, basis-tx: u64, eavt: []int, aevt: []int, avet: []int, vaet: []int, modes: SQLite-Index-Append-Modes] -> [ok: bool, error: string]
  (persist-index-root-sqlite-handle-from-indexes-mode-with-stmts handle nil basis-tx eavt aevt avet vaet modes))

(defn storage-int-slices-equal? [left: []int, right: []int] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn validate-sqlite-index [path: string, db-index: []int, index-name: string] -> [ok: bool, error: string]
  (let [[loaded loaded-ok loaded-error] (sqlite-latest-index-entries path index-name)]
    (when (not loaded-ok)
      (return false loaded-error))
    (defer (delete loaded))
    (if (storage-int-slices-equal? (slice loaded 0) db-index)
      (return true "")
      (return false (fmt.tprintf "persisted %s index did not match rebuilt DB index" index-name)))))

(defn validate-sqlite-indexes-for-db [path: string, db: DB, expected-basis: u64, has-root: bool] -> [ok: bool, error: string]
  (when (not has-root)
    (return true ""))
  (let [basis (db-basis-tx db)]
    (when (not (= basis expected-basis))
      (return false (fmt.tprintf "persisted index basis %d did not match rebuilt DB basis %d" expected-basis basis)))
    (let [[eavt-ok eavt-error] (validate-sqlite-index path (slice db.eavt 0) ":eavt")]
      (when (not eavt-ok)
        (return false eavt-error)))
    (let [[aevt-ok aevt-error] (validate-sqlite-index path (slice db.aevt 0) ":aevt")]
      (when (not aevt-ok)
        (return false aevt-error)))
    (let [[avet-ok avet-error] (validate-sqlite-index path (slice db.avet 0) ":avet")]
      (when (not avet-ok)
        (return false avet-error)))
    (let [[vaet-ok vaet-error] (validate-sqlite-index path (slice db.vaet 0) ":vaet")]
      (when (not vaet-ok)
        (return false vaet-error)))
    (return true "")))

(defn save-db-sqlite [path: string, db: DB] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-replace-datoms-raw path)]
    (when (not open-ok)
      (return false open-error))
    (for [datom index db.datoms]
      (let [value-text (value-serializable-text datom.v)
            value-entity (sqlite-datom-value-entity-index datom)
            [insert-ok insert-error] (sqlite-insert-datom-raw handle (i64 index) datom.e datom.a value-text value-entity datom.tx datom.added)]
        (delete value-text)
        (when (not insert-ok)
          (sqlite-rollback-close-raw handle)
          (return false insert-error))))
    (let [[clear-ok clear-error] (sqlite-clear-index-storage-raw handle)]
      (when (not clear-ok)
        (sqlite-rollback-close-raw handle)
        (return false clear-error)))
    (let [[root-ok root-error] (persist-index-root-sqlite-handle handle db)]
      (when (not root-ok)
        (sqlite-rollback-close-raw handle)
        (return false root-error)))
    (sqlite-commit-close-raw handle)))

(defn load-db-sqlite-resident [path: string] -> [db: DB, ok: bool, error: string]
  (let [[root-basis root-ok root-error] (sqlite-latest-index-root-basis path)
        has-root root-ok
        [row-text row-ok row-error] (sqlite-load-datom-rows-text-raw path)]
    (when row-ok
      (defer (delete row-text))
      (let [[db parsed-ok parsed-error] (from-serializable-text row-text)]
        (when (not parsed-ok)
          (return db false parsed-error))
        (let [[valid-ok valid-error] (validate-sqlite-indexes-for-db path db root-basis has-root)]
          (when (not valid-ok)
            (delete-owned-db db)
            (return (build-db (make [dynamic]Datom)) false valid-error)))
        (return db true "")))
    (let [[snapshot-text snapshot-ok snapshot-error] (sqlite-load-snapshot-text-raw path)]
      (when (not snapshot-ok)
        (return (build-db (make [dynamic]Datom)) false row-error))
      (defer (delete snapshot-text))
      (let [[db parsed-ok parsed-error] (from-serializable-text snapshot-text)]
        (when (not parsed-ok)
          (return db false parsed-error))
        (let [[valid-ok valid-error] (validate-sqlite-indexes-for-db path db root-basis has-root)]
          (when (not valid-ok)
            (delete-owned-db db)
            (return (build-db (make [dynamic]Datom)) false valid-error)))
        (return db true "")))))

(defn load-db-sqlite [path: string] -> [db: DB, ok: bool, error: string]
  (load-db-sqlite-resident path))

(defn open-conn-sqlite-resident [path: string] -> [conn: Conn, ok: bool, error: string]
  (let [[db loaded-ok load-error] (load-db-sqlite-resident path)]
    (if loaded-ok
      (do
        (let [conn (conn-from-db db)]
          (delete-owned-db db)
          (return conn true "")))
      (do
        (delete-owned-db db)
        (return (create-conn) false load-error)))))

(defn open-conn-sqlite [path: string] -> [conn: Conn, ok: bool, error: string]
  (open-conn-sqlite-resident path))

(defn persist-conn-sqlite-resident [path: string, conn: Conn] -> [ok: bool, error: string]
  (save-db-sqlite path conn.db))

(defn persist-conn-sqlite [path: string, conn: Conn] -> [ok: bool, error: string]
  (persist-conn-sqlite-resident path conn))

(defstruct SQLite-Tx-Meta-Row {
  tx: u64
  a: string
  v: Value
})

(defstruct SQLite-Direct-Write-Profile {
  writes: u64
  direct-call-us: f64
  open-before-us: f64
  read-source-us: f64
  resolve-us: f64
  overlay-us: f64
  append-us: f64
  append-begin-us: f64
  append-tx-us: f64
  append-datoms-us: f64
  append-meta-us: f64
  append-roots-us: f64
  append-root-build-us: f64
  append-root-sort-us: f64
  append-root-check-us: f64
  append-root-persist-us: f64
  append-eavt-root-build-us: f64
  append-aevt-root-build-us: f64
  append-avet-root-build-us: f64
  append-vaet-root-build-us: f64
  append-root-publish-us: f64
  append-commit-us: f64
  report-open-us: f64
  auto-maintenance-us: f64
  listener-us: f64
})

(defstruct SQLite-Direct-Attr-Info {
  attr: string
  has-type: bool
  schema-type: string
  unique: bool
  unique-kind: string
  cardinality-many: bool
})

(defstruct SQLite-Index-Root-Page {
  root-id: u64
  manifest-id: u64
})

(defstruct SQLite-Index-Root-Set {
  eavt: SQLite-Index-Root-Page
  aevt: SQLite-Index-Root-Page
  avet: SQLite-Index-Root-Page
  vaet: SQLite-Index-Root-Page
})

(defstruct SQLite-Index-Root-Publish {
  root-id: u64
  manifest-id: u64
  append-mode: bool
})

(defstruct SQLite-Index-Root-Publish-Set {
  eavt: SQLite-Index-Root-Publish
  aevt: SQLite-Index-Root-Publish
  avet: SQLite-Index-Root-Publish
  vaet: SQLite-Index-Root-Publish
})

(defstruct SQLite-Index-Append-Modes {
  eavt: bool
  aevt: bool
  avet: bool
  vaet: bool
})

(defstruct SQLite-Index-Append-Page {
  index-name: string
  entries: [dynamic]int
  append-mode: bool
})

(defstruct SQLite-Index-Append-Delta {
  pages: [dynamic]SQLite-Index-Append-Page
})

(defstruct SQLite-Prepared-Index-Append {
  delta: SQLite-Index-Append-Delta
  modes: SQLite-Index-Append-Modes
})

(defstruct SQLite-Durable-Append-Plan {
  start-index: int
  prepared: SQLite-Prepared-Index-Append
})

(defstruct SQLite-Durable-Append-Publication {
  publishes: SQLite-Index-Root-Publish-Set
  roots: SQLite-Index-Root-Set
  modes: SQLite-Index-Append-Modes
})

(defstruct SQLite-Durable-Published-Root {
  root-row-id: u64
  basis-tx: u64
  roots: SQLite-Index-Root-Set
  modes: SQLite-Index-Append-Modes
})

(defn sqlite-index-append-page [index-name: string, entries: [dynamic]int, append-mode: bool] -> SQLite-Index-Append-Page
  (SQLite-Index-Append-Page {index-name: index-name
                             entries: entries
                             append-mode: append-mode}))

(defn sqlite-index-append-delta [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int, modes: SQLite-Index-Append-Modes] -> SQLite-Index-Append-Delta
  (let [pages (make [dynamic]SQLite-Index-Append-Page 0 4)]
    (arr.push! pages (sqlite-index-append-page ":eavt" eavt modes.eavt))
    (arr.push! pages (sqlite-index-append-page ":aevt" aevt modes.aevt))
    (arr.push! pages (sqlite-index-append-page ":avet" avet modes.avet))
    (arr.push! pages (sqlite-index-append-page ":vaet" vaet modes.vaet))
    (SQLite-Index-Append-Delta {pages: pages})))

(defn delete-sqlite-index-append-delta [delta: SQLite-Index-Append-Delta]
  (for [page delta.pages]
    (delete page.entries))
  (delete delta.pages))

(defn sqlite-index-append-delta-page [delta: SQLite-Index-Append-Delta, offset: int] -> SQLite-Index-Append-Page
  delta.pages[offset])

(defn sqlite-index-append-delta-modes [delta: SQLite-Index-Append-Delta] -> SQLite-Index-Append-Modes
  (SQLite-Index-Append-Modes {eavt: delta.pages[0].append-mode
                              aevt: delta.pages[1].append-mode
                              avet: delta.pages[2].append-mode
                              vaet: delta.pages[3].append-mode}))

(defn sqlite-prepared-index-append-from-modes [appended: []Datom, start-index: int, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> SQLite-Prepared-Index-Append
  (let [delta (sqlite-index-append-delta-from-appended appended start-index modes profile)]
    (SQLite-Prepared-Index-Append {delta: delta
                                   modes: modes})))

(defn delete-sqlite-prepared-index-append [prepared: SQLite-Prepared-Index-Append]
  (delete-sqlite-index-append-delta prepared.delta))

(defn sqlite-durable-append-plan-from-modes [appended: []Datom, start-index: int, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> SQLite-Durable-Append-Plan
  (SQLite-Durable-Append-Plan {start-index: start-index
                               prepared: (sqlite-prepared-index-append-from-modes appended start-index modes profile)}))

(defn delete-sqlite-durable-append-plan [plan: SQLite-Durable-Append-Plan]
  (delete-sqlite-prepared-index-append plan.prepared))

(defn sqlite-durable-append-plan-from-delta [start-index: int, delta: SQLite-Index-Append-Delta] -> SQLite-Durable-Append-Plan
  (SQLite-Durable-Append-Plan {start-index: start-index
                               prepared: (SQLite-Prepared-Index-Append {delta: delta
                                                                         modes: (sqlite-index-append-delta-modes delta)})}))

(defstruct SQLite-Conn {
  path: string
  conn: Conn
  handle: rawptr
  source-only: bool
  resident-loaded: bool
  direct-write-stmts-valid: bool
  direct-write-stmts: SQLite-Direct-Write-Stmts
  index-write-stmts-valid: bool
  index-write-stmts: SQLite-Index-Write-Stmts
  write-state-cache-valid: bool
  write-state-cache: Shared-Write-State
  datom-count-cache-valid: bool
  datom-count-cache: u64
  has-retractions-cache-valid: bool
  has-retractions-cache: bool
  current-root-cache-valid: bool
  current-root-cache-basis: u64
  current-root-cache-published: SQLite-Durable-Published-Root
  current-root-cache-page-cache: SQLite-Index-Page-Cache
  direct-write-profile: SQLite-Direct-Write-Profile
  direct-attr-cache: [dynamic]SQLite-Direct-Attr-Info
})

(defn sqlite-conn-direct-write-stmts [store: ^SQLite-Conn] -> [stmts: ^SQLite-Direct-Write-Stmts, ok: bool, error: string]
  (when store^.direct-write-stmts-valid
    (return (addr store^.direct-write-stmts) true ""))
  (let [[opened-stmts stmts-ok stmts-error] (sqlite-direct-write-stmts-open store^.handle)]
    (when (not stmts-ok)
      (return nil false stmts-error))
    (set! store^.direct-write-stmts opened-stmts)
    (set! store^.direct-write-stmts-valid true)
    (return (addr store^.direct-write-stmts) true "")))

(defn sqlite-conn-close-direct-write-stmts! [store: ^SQLite-Conn]
  (when store^.direct-write-stmts-valid
    (sqlite-direct-write-stmts-close store^.direct-write-stmts)
    (set! store^.direct-write-stmts-valid false)))

(defn sqlite-conn-index-write-stmts [store: ^SQLite-Conn] -> [stmts: ^SQLite-Index-Write-Stmts, ok: bool, error: string]
  (when store^.index-write-stmts-valid
    (return (addr store^.index-write-stmts) true ""))
  (let [[opened-stmts stmts-ok stmts-error] (sqlite-index-write-stmts-open store^.handle)]
    (when (not stmts-ok)
      (return nil false stmts-error))
    (set! store^.index-write-stmts opened-stmts)
    (set! store^.index-write-stmts-valid true)
    (return (addr store^.index-write-stmts) true "")))

(defn sqlite-conn-close-index-write-stmts! [store: ^SQLite-Conn]
  (when store^.index-write-stmts-valid
    (sqlite-index-write-stmts-close store^.index-write-stmts)
    (set! store^.index-write-stmts-valid false)))

(defstruct SQLite-Index-Cursor {
  handle: rawptr
  owns-handle: bool
  index-name: string
  basis-tx: u64
  root-id: u64
  manifest-id: u64
  manifest-run-count: u64
  root-first-key: string
  root-is-merge: bool
  root-is-manifest: bool
  root-level: i64
  root-child-count: i64
  order-text: string
  datom-stmt: rawptr
  entry-page-stmt: rawptr
  page-size: int
  row-count: int
  page: SQLite-Loaded-Index-Page
  page-cache: SQLite-Index-Page-Cache
  merge-ready: bool
  merge-next-output: int
  merge-roots: [dynamic]u64
  merge-counts: [dynamic]int
  merge-positions: [dynamic]int
  merge-current-entries: [dynamic]int
  merge-current-datoms: [dynamic]Datom
  merge-has-current: [dynamic]bool
  merge-loaded-pages: [dynamic]SQLite-Loaded-Index-Page
  merge-loaded-page-valid: [dynamic]bool
  merge-page0: [dynamic]int
  merge-page-start0: int
  merge-page-end0: int
  merge-page1: [dynamic]int
  merge-page-start1: int
  merge-page-end1: int
  merge-page2: [dynamic]int
  merge-page-start2: int
  merge-page-end2: int
  merge-page3: [dynamic]int
  merge-page-start3: int
  merge-page-end3: int
  direct-children-ready: bool
  direct-child-roots: [dynamic]u64
  direct-child-counts: [dynamic]int
  entry-runs-ready: bool
  entry-run-roots: [dynamic]u64
  entry-run-bases: [dynamic]int
  entry-run-counts: [dynamic]int
  entry-run-entry-payloads: [dynamic]bool
})

(defstruct SQLite-Loaded-Index-Page {
  entries: [dynamic]int
  datoms: [dynamic]Datom
  has-datoms: bool
  start: int
  end: int
  refs: [dynamic]int
})

(defn sqlite-loaded-index-page-empty [start: int] -> SQLite-Loaded-Index-Page
  (let [refs (make [dynamic]int 0 1)]
    (arr.push! refs 1)
    (SQLite-Loaded-Index-Page {entries: (make [dynamic]int)
                               datoms: (make [dynamic]Datom)
                               has-datoms: false
                               start: start
                               end: start
                               refs: refs})))

(defn sqlite-loaded-index-page-from-entries [entries: [dynamic]int, start: int, end: int] -> SQLite-Loaded-Index-Page
  (let [refs (make [dynamic]int 0 1)]
    (arr.push! refs 1)
    (SQLite-Loaded-Index-Page {entries: entries
                               datoms: (make [dynamic]Datom)
                               has-datoms: false
                               start: start
                               end: end
                               refs: refs})))

(defn sqlite-loaded-index-page-from-entries-and-datoms [entries: [dynamic]int, datoms: [dynamic]Datom, start: int, end: int] -> SQLite-Loaded-Index-Page
  (let [refs (make [dynamic]int 0 1)]
    (arr.push! refs 1)
    (SQLite-Loaded-Index-Page {entries: entries
                               datoms: datoms
                               has-datoms: true
                               start: start
                               end: end
                               refs: refs})))

(defn retain-sqlite-loaded-index-page! [page: SQLite-Loaded-Index-Page]
  (when (> (count page.refs) 0)
    (set! page.refs[0] (+ page.refs[0] 1))))

(defn retain-sqlite-loaded-index-page [page: SQLite-Loaded-Index-Page] -> SQLite-Loaded-Index-Page
  (retain-sqlite-loaded-index-page! page)
  page)

(defn release-sqlite-loaded-index-page! [page: SQLite-Loaded-Index-Page]
  (when (= (count page.refs) 0)
    (return))
  (set! page.refs[0] (- page.refs[0] 1))
  (when (= page.refs[0] 0)
    (delete page.entries)
    (if page.has-datoms
      (delete-owned-datoms page.datoms)
      (delete page.datoms))
    (delete page.refs)))

(defn sqlite-loaded-index-page-ref-count [page: SQLite-Loaded-Index-Page] -> int
  (if (> (count page.refs) 0)
    page.refs[0]
    0))

(defstruct SQLite-Index-Page-Cache-State {
  root-ids: [dynamic]u64
  manifest-ids: [dynamic]u64
  starts: [dynamic]int
  pages: [dynamic]SQLite-Loaded-Index-Page
  refs: [dynamic]int
  hits: int
  misses: int
  last-index: int
  last-valid: bool
  previous-index: int
  previous-valid: bool
})

(defstruct SQLite-Index-Page-Cache {
  state: ^SQLite-Index-Page-Cache-State
})

(defn sqlite-index-page-cache-empty [] -> SQLite-Index-Page-Cache
  (let [state (alloc SQLite-Index-Page-Cache-State context.allocator)]
    (set! state^ (SQLite-Index-Page-Cache-State {root-ids: (make [dynamic]u64)
                                                 manifest-ids: (make [dynamic]u64)
                                                 starts: (make [dynamic]int)
                                                 pages: (make [dynamic]SQLite-Loaded-Index-Page)
                                                 refs: (make [dynamic]int 0 1)}))
    (arr.push! state^.refs 1)
    (SQLite-Index-Page-Cache {state: state})))

(defn retain-sqlite-index-page-cache! [cache: SQLite-Index-Page-Cache]
  (when (or (= cache.state nil)
            (= (count cache.state^.refs) 0))
    (return))
  (set! cache.state^.refs[0] (+ cache.state^.refs[0] 1)))

(defn retain-sqlite-index-page-cache [cache: SQLite-Index-Page-Cache] -> SQLite-Index-Page-Cache
  (retain-sqlite-index-page-cache! cache)
  cache)

(defn release-sqlite-index-page-cache! [cache: SQLite-Index-Page-Cache]
  (when (or (= cache.state nil)
            (= (count cache.state^.refs) 0))
    (return))
  (set! cache.state^.refs[0] (- cache.state^.refs[0] 1))
  (when (= cache.state^.refs[0] 0)
    (for [page cache.state^.pages]
      (release-sqlite-loaded-index-page! page))
    (delete cache.state^.root-ids)
    (delete cache.state^.manifest-ids)
    (delete cache.state^.starts)
    (delete cache.state^.pages)
    (delete cache.state^.refs)
    (free cache.state)))

(defn sqlite-index-page-cache-ref-count [cache: SQLite-Index-Page-Cache] -> int
  (if (and (not (= cache.state nil))
           (> (count cache.state^.refs) 0))
    cache.state^.refs[0]
    0))

(defn sqlite-index-page-cache-count [cache: SQLite-Index-Page-Cache] -> int
  (if (= cache.state nil)
    0
    (count cache.state^.pages)))

(defn sqlite-index-page-cache-hit-count [cache: SQLite-Index-Page-Cache] -> int
  (if (= cache.state nil)
    0
    cache.state^.hits))

(defn sqlite-index-page-cache-miss-count [cache: SQLite-Index-Page-Cache] -> int
  (if (= cache.state nil)
    0
    cache.state^.misses))

(defn sqlite-index-page-cache-remember-hit! [cache: SQLite-Index-Page-Cache, index: int]
  (when (= cache.state nil)
    (return))
  (when (or (not cache.state^.last-valid)
            (not (= cache.state^.last-index index)))
    (set! cache.state^.previous-index cache.state^.last-index)
    (set! cache.state^.previous-valid cache.state^.last-valid)
    (set! cache.state^.last-index index)
    (set! cache.state^.last-valid true)))

(defn sqlite-index-page-cache-find-retained [cache: SQLite-Index-Page-Cache, root-id: u64, manifest-id: u64, start: int] -> [page: SQLite-Loaded-Index-Page, found: bool]
  (when (= cache.state nil)
    (return (SQLite-Loaded-Index-Page {}) false))
  (when (and cache.state^.last-valid
             (>= cache.state^.last-index 0)
             (< cache.state^.last-index (count cache.state^.pages))
             (= cache.state^.root-ids[cache.state^.last-index] root-id)
             (= cache.state^.manifest-ids[cache.state^.last-index] manifest-id)
             (= cache.state^.starts[cache.state^.last-index] start))
    (mut! cache.state^.hits += 1)
    (return (retain-sqlite-loaded-index-page cache.state^.pages[cache.state^.last-index]) true))
  (when (and cache.state^.previous-valid
             (>= cache.state^.previous-index 0)
             (< cache.state^.previous-index (count cache.state^.pages))
             (= cache.state^.root-ids[cache.state^.previous-index] root-id)
             (= cache.state^.manifest-ids[cache.state^.previous-index] manifest-id)
             (= cache.state^.starts[cache.state^.previous-index] start))
    (sqlite-index-page-cache-remember-hit! cache cache.state^.previous-index)
    (mut! cache.state^.hits += 1)
    (return (retain-sqlite-loaded-index-page cache.state^.pages[cache.state^.last-index]) true))
  (for [candidate index cache.state^.pages]
    (when (and (= cache.state^.root-ids[index] root-id)
               (= cache.state^.manifest-ids[index] manifest-id)
               (= cache.state^.starts[index] start))
      (sqlite-index-page-cache-remember-hit! cache index)
      (mut! cache.state^.hits += 1)
      (return (retain-sqlite-loaded-index-page candidate) true)))
  (mut! cache.state^.misses += 1)
  (return (SQLite-Loaded-Index-Page {}) false))

(defn sqlite-index-page-cache-store! [cache: ^SQLite-Index-Page-Cache, root-id: u64, manifest-id: u64, start: int, page: SQLite-Loaded-Index-Page]
  (when (= cache^.state nil)
    (return))
  (for [_candidate index cache^.state^.pages]
    (when (and (= cache^.state^.root-ids[index] root-id)
               (= cache^.state^.manifest-ids[index] manifest-id)
               (= cache^.state^.starts[index] start))
      (release-sqlite-loaded-index-page! cache^.state^.pages[index])
      (set! cache^.state^.pages[index] (retain-sqlite-loaded-index-page page))
      (sqlite-index-page-cache-remember-hit! cache^ index)
      (return)))
  (arr.push! cache^.state^.root-ids root-id)
  (arr.push! cache^.state^.manifest-ids manifest-id)
  (arr.push! cache^.state^.starts start)
  (arr.push! cache^.state^.pages (retain-sqlite-loaded-index-page page))
  (sqlite-index-page-cache-remember-hit! cache^ (- (count cache^.state^.pages) 1)))

(defstruct SQLite-Index-Snapshot {
  handle: rawptr
  owns-handle: bool
  page-size: int
  eavt: SQLite-Index-Cursor
  aevt: SQLite-Index-Cursor
  avet: SQLite-Index-Cursor
  vaet: SQLite-Index-Cursor
})

(defstruct SQLite-DB-Snapshot {
  indexes: SQLite-Index-Snapshot
  datom-stmt: rawptr
  datom-cache-log-indexes: [dynamic]int
  datom-cache-valids: [dynamic]bool
  datom-cache-datoms: [dynamic]Datom
  basis-tx: u64
  root-row-id: u64
  datom-count: int
  has-retractions: bool
  path: string
})

(def sqlite-db-snapshot-datom-cache-capacity 512)

(defn sqlite-db-snapshot-empty-datom-cache-log-indexes [] -> [dynamic]int
  (arr.repeat sqlite-db-snapshot-datom-cache-capacity -1))

(defn sqlite-db-snapshot-empty-datom-cache-valids [] -> [dynamic]bool
  (arr.repeat sqlite-db-snapshot-datom-cache-capacity false))

(defn sqlite-db-snapshot-empty-datom-cache-datoms [] -> [dynamic]Datom
  (arr.repeat sqlite-db-snapshot-datom-cache-capacity (Datom {})))

(defn sqlite-db-snapshot-datom-cache-slot [log-index: int] -> int
  (let [slot (% log-index sqlite-db-snapshot-datom-cache-capacity)]
    (if (< slot 0)
      (+ slot sqlite-db-snapshot-datom-cache-capacity)
      slot)))

(defn sqlite-db-snapshot-cache-find-datom [snapshot: ^SQLite-DB-Snapshot, log-index: int] -> [datom: Datom, found: bool]
  (let [slot (sqlite-db-snapshot-datom-cache-slot log-index)]
    (when (and (< slot (count snapshot^.datom-cache-valids))
               snapshot^.datom-cache-valids[slot]
               (= snapshot^.datom-cache-log-indexes[slot] log-index))
      (return (datom-owned snapshot^.datom-cache-datoms[slot]) true)))
  (return (Datom {}) false))

(defn sqlite-db-snapshot-cache-store-datom! [snapshot: ^SQLite-DB-Snapshot, log-index: int, datom: Datom]
  (let [slot (sqlite-db-snapshot-datom-cache-slot log-index)]
    (when (and (< slot (count snapshot^.datom-cache-valids))
               snapshot^.datom-cache-valids[slot])
      (delete-owned-datom snapshot^.datom-cache-datoms[slot]))
    (set! snapshot^.datom-cache-log-indexes[slot] log-index)
    (set! snapshot^.datom-cache-valids[slot] true)
    (set! snapshot^.datom-cache-datoms[slot] (datom-owned datom))))

(defn delete-sqlite-db-snapshot-datom-cache! [snapshot: ^SQLite-DB-Snapshot]
  (for [valid index snapshot^.datom-cache-valids]
    (when valid
      (delete-owned-datom snapshot^.datom-cache-datoms[index])))
  (delete snapshot^.datom-cache-log-indexes)
  (delete snapshot^.datom-cache-valids)
  (delete snapshot^.datom-cache-datoms)
  (set! snapshot^.datom-cache-log-indexes (make [dynamic]int))
  (set! snapshot^.datom-cache-valids (make [dynamic]bool))
  (set! snapshot^.datom-cache-datoms (make [dynamic]Datom)))

(defenum Store-Conn-Kind [
  Empty
  SQLite
  Shared
])

(defstruct Store-Conn {
  kind: Store-Conn-Kind
  sqlite: SQLite-Conn
  shared: Shared-Conn
  listeners: [dynamic]Store-Tx-Listener
  auto-maintenance-enabled: bool
  auto-maintenance-steps: int
  auto-maintenance-target: u64
  auto-maintenance-trigger: u64
})

(defn sqlite-direct-frontier-log-indexes-for-test [store: ^Store-Conn, order-text: string, entities: []u64, attr: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (when (not (= store^.kind .SQLite))
    (return (make [dynamic]int) false "direct frontier test lookup requires a SQLite store"))
  (sqlite-direct-frontier-log-indexes-raw store^.sqlite.handle order-text entities attr))

(defn sqlite-direct-frontier-datoms-for-test [store: ^Store-Conn, order-text: string, entities: []u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (when (not (= store^.kind .SQLite))
    (return (make [dynamic]Datom) false "direct frontier datom test lookup requires a SQLite store"))
  (sqlite-direct-frontier-datoms store^.sqlite.handle order-text entities attr))

(defn sqlite-load-datoms-by-log-indexes-parts-for-test [store: ^Store-Conn, entries: []int] -> [ordinals: [dynamic]int, entities: [dynamic]u64, attrs: [dynamic]string, value-texts: [dynamic]string, txs: [dynamic]u64, added: [dynamic]bool, ok: bool, error: string]
  (when (not (= store^.kind .SQLite))
    (return (make [dynamic]int) (make [dynamic]u64) (make [dynamic]string) (make [dynamic]string) (make [dynamic]u64) (make [dynamic]bool) false "batch datom test lookup requires a SQLite store"))
  (sqlite-load-datoms-by-log-indexes-parts-raw store^.sqlite.handle entries))

(defstruct Store-Tx-Listener {
  name: string
  reports: ^[dynamic]Store-Tx-Report
})

(defenum Store-DB-Kind [
  Empty
  Resident
  SQLite-Snapshot
  SQLite-Lazy-Snapshot
  SQLite-Root-Snapshot
  SQLite-Tx-Ops-Overlay
  SQLite-Datom-Overlay
  SQLite-Datom-Log-Overlay
  Shared-Snapshot
  Shared-Tx-Ops-Overlay
  Shared-Datom-Overlay
  Shared-Datom-Log-Overlay
])

(defstruct Store-DB {
  kind: Store-DB-Kind
  resident: DB
  sqlite-snapshot: SQLite-DB-Snapshot
  sqlite-lazy-path: string
  sqlite-lazy-basis-tx: u64
  sqlite-root-path: string
  sqlite-root-published: SQLite-Durable-Published-Root
  sqlite-root-page-cache: SQLite-Index-Page-Cache
  shared-snapshot: Shared-DB-Snapshot
  overlay-ops: [dynamic]Tx-Op
  overlay-datoms: [dynamic]Datom
  overlay-log: Shared-Datom-Log
  overlay-tx: u64
})

(defstruct Store-Entity {
  db: Store-DB
  e: u64
  found: bool
})

(defn insert-sqlite-tx-meta! [handle: rawptr, tx: u64, meta: []Tx-Meta] -> [ok: bool, error: string]
  (for [entry meta]
    (let [value-text (value-serializable-text entry.v)
          [insert-ok insert-error] (sqlite-insert-tx-meta-raw handle tx entry.a value-text)]
      (delete value-text)
      (when (not insert-ok)
        (return false insert-error))))
  (return true ""))

(defn insert-sqlite-tx-meta-with-stmts! [handle: rawptr, stmts: ^SQLite-Direct-Write-Stmts, tx: u64, meta: []Tx-Meta] -> [ok: bool, error: string]
  (if (= stmts nil)
    (insert-sqlite-tx-meta! handle tx meta)
    (do
      (for [entry meta]
        (let [value-text (value-serializable-text entry.v)
              [insert-ok insert-error] (sqlite-step-tx-meta-stmt-raw handle stmts^.tx-meta-stmt tx entry.a value-text)]
          (delete value-text)
          (when (not insert-ok)
            (return false insert-error))))
      (return true ""))))

(defn sqlite-datom-value-entity-index [datom: Datom] -> i64
  (if (= datom.v.kind .Entity)
    (i64 datom.v.entity)
    -1))

(defn insert-sqlite-tx-with-stmts! [handle: rawptr, stmts: ^SQLite-Direct-Write-Stmts, tx: u64] -> [ok: bool, error: string]
  (if (= stmts nil)
    (sqlite-insert-tx-raw handle tx)
    (sqlite-step-tx-stmt-raw handle stmts^.tx-stmt tx)))

(defn append-sqlite-datoms-with-stmts! [handle: rawptr, stmts: ^SQLite-Direct-Write-Stmts, base-count: int, datoms: []Datom] -> [ok: bool, error: string]
  (for [datom index datoms]
    (let [value-text (value-serializable-text datom.v)
          value-entity (sqlite-datom-value-entity-index datom)]
      (if (= stmts nil)
        (let [[insert-ok insert-error] (sqlite-insert-datom-raw handle (i64 (+ base-count index)) datom.e datom.a value-text value-entity datom.tx datom.added)]
          (delete value-text)
          (when (not insert-ok)
            (return false insert-error)))
        (let [[insert-ok insert-error] (sqlite-step-datom-stmt-raw handle stmts^.datom-stmt (i64 (+ base-count index)) datom.e datom.a value-text value-entity datom.tx datom.added)]
          (delete value-text)
          (when (not insert-ok)
            (return false insert-error))))))
  (return true ""))

(defn append-datoms-sqlite [path: string, datoms: []Datom] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-append-datoms-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[base-count count-ok count-error] (sqlite-datom-count-raw handle)]
      (when (not count-ok)
        (sqlite-rollback-close-raw handle)
        (return false count-error))
      (for [datom index datoms]
        (let [value-text (value-serializable-text datom.v)
              value-entity (sqlite-datom-value-entity-index datom)
              [insert-ok insert-error] (sqlite-insert-datom-raw handle (i64 (+ (int base-count) index)) datom.e datom.a value-text value-entity datom.tx datom.added)]
          (delete value-text)
          (when (not insert-ok)
            (sqlite-rollback-close-raw handle)
            (return false insert-error)))))
    (sqlite-commit-close-raw handle)))

(defn append-tx-report-sqlite-handle [handle: rawptr, report: Tx-Report] -> [ok: bool, error: string]
  (let [[begin-ok begin-error] (sqlite-begin-immediate-raw handle)]
    (when (not begin-ok)
      (return false begin-error))
    (let [[write-stmts write-stmts-ok write-stmts-error] (sqlite-direct-write-stmts-open handle)]
      (when (not write-stmts-ok)
        (sqlite-rollback-raw handle)
        (return false write-stmts-error))
      (defer (sqlite-direct-write-stmts-close write-stmts))
      (let [[tx-ok tx-error] (insert-sqlite-tx-with-stmts! handle (addr write-stmts) report.tx)]
        (when (not tx-ok)
          (sqlite-rollback-raw handle)
          (return false tx-error)))
      (let [base-index (count report.db-before.datoms)]
        (let [[datoms-ok datoms-error] (append-sqlite-datoms-with-stmts! handle (addr write-stmts) base-index (slice report.tx-data 0))]
          (when (not datoms-ok)
            (sqlite-rollback-raw handle)
            (return false datoms-error))))
      (let [[meta-ok meta-error] (insert-sqlite-tx-meta-with-stmts! handle (addr write-stmts) report.tx (slice report.tx-meta 0))]
        (when (not meta-ok)
          (sqlite-rollback-raw handle)
          (return false meta-error))))
    (let [[index-stmts index-stmts-ok index-stmts-error] (sqlite-index-write-stmts-open handle)]
      (when (not index-stmts-ok)
        (sqlite-rollback-raw handle)
        (return false index-stmts-error))
      (defer (sqlite-index-write-stmts-close index-stmts))
      (let [[root-ok root-error] (persist-index-root-sqlite-handle-with-stmts handle (addr index-stmts) report.db-after)]
        (when (not root-ok)
          (sqlite-rollback-raw handle)
          (return false root-error))))
    (sqlite-commit-raw handle)))

(defn db-index-view-entries [view: DB-Index-View] -> [dynamic]int
  (let [out (make [dynamic]int 0 (db-index-view-count view))
        index 0]
    (while (< index (db-index-view-count view))
      (arr.push! out (db-index-view-at view index))
      (set! index (+ index 1)))
    out))

(defn source-appended-datom-at-entry [source: DB-Read-Source, appended: []Datom, start-index: int, entry: int] -> [datom: Datom, ok: bool, error: string]
  (if (< entry start-index)
    (db-read-source-datom-at-entry source entry)
    (let [offset (- entry start-index)]
      (when (or (< offset 0)
                (>= offset (count appended)))
        (return (Datom {}) false "appended datom index out of range"))
      (return (datom-owned appended[offset]) true ""))))

(defn source-appended-datom-index-less? [source: DB-Read-Source, appended: []Datom, start-index: int, order: string, left: int, right: int] -> [less: bool, ok: bool, error: string]
  (let [[left-datom left-ok left-error] (source-appended-datom-at-entry source appended start-index left)]
    (when (not left-ok)
      (return false false left-error))
    (let [[right-datom right-ok right-error] (source-appended-datom-at-entry source appended start-index right)]
      (when (not right-ok)
        (delete-owned-datom left-datom)
        (return false false right-error))
      (let [less-value (datom-less-order? left-datom right-datom order left right)]
        (delete-owned-datom left-datom)
        (delete-owned-datom right-datom)
        (return less-value true "")))))

(defn source-append-merge-index [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, order: string] -> [out: [dynamic]int, ok: bool, error: string]
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)
        merged (make [dynamic]int 0 (+ (count existing) (count added)))
        left 0
        right 0]
    (while (and (< left (count existing))
                (< right (count added)))
      (let [[added-less less-ok less-error] (source-appended-datom-index-less? source appended start-index order added[right] existing[left])]
        (when (not less-ok)
          (delete merged)
          (delete added)
          (return (make [dynamic]int) false less-error))
        (if added-less
          (do
            (arr.push! merged added[right])
            (set! right (+ right 1)))
          (do
            (arr.push! merged existing[left])
            (set! left (+ left 1))))))
    (while (< left (count existing))
      (arr.push! merged existing[left])
      (set! left (+ left 1)))
    (while (< right (count added))
      (arr.push! merged added[right])
      (set! right (+ right 1)))
    (delete added)
    (return merged true "")))

(defn source-append-eavt-index [source: DB-Read-Source, existing: []int, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [out: [dynamic]int, ok: bool, error: string]
  (if new-entities-after-existing
    (let [added (sorted-appended-datom-slice-indexes appended start-index "eavt")
          out (arr.into [dynamic]int existing)]
      (for [entry added]
        (arr.push! out entry))
      (delete added)
      (return out true ""))
    (source-append-merge-index source existing appended start-index "eavt")))

(defn source-append-index-view-last-entry [view: DB-Index-View] -> [entry: int, ok: bool, error: string]
  (when (= (db-index-view-count view) 0)
    (return 0 false "empty index view has no last entry"))
  (case view.kind
    .SQLite-Cursor (sqlite-index-cursor-boundary-entry view.sqlite-cursor true)
     (return (db-index-view-at view (- (db-index-view-count view) 1)) true "")))

(defn source-append-index-view-can-append? [source: DB-Read-Source, view: DB-Index-View, added: []int, appended: []Datom, start-index: int, order: string] -> [appendable: bool, ok: bool, error: string]
  (when (= (count added) 0)
    (return true true ""))
  (when (= (db-index-view-count view) 0)
    (return true true ""))
  (let [[last-existing last-ok last-error] (source-append-index-view-last-entry view)]
    (when (not last-ok)
      (return false false last-error))
  (let [
        first-added added[0]
        [existing-less less-ok less-error] (source-appended-datom-index-less? source appended start-index order last-existing first-added)]
    (if less-ok
      (return existing-less true "")
      (return false false less-error)))))

(defn source-append-index-for-persist-view [source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string, force-append: bool] -> [out: [dynamic]int, append-mode: bool, ok: bool, error: string]
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)]
    (when force-append
      (return added true true ""))
    (let [[appendable appendable-ok appendable-error] (source-append-index-view-can-append? source view (slice added 0) appended start-index order)]
      (when (not appendable-ok)
        (delete added)
        (return (make [dynamic]int) false false appendable-error))
      (when appendable
        (return added true true ""))
      (delete added)
      (let [existing (db-index-view-entries view) :defer
            [merged merged-ok merged-error] (source-append-merge-index source (slice existing 0) appended start-index order)]
        (return merged false merged-ok merged-error)))))

(defn source-append-index-for-persist-mode-view [source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string, append-mode: bool] -> [out: [dynamic]int, ok: bool, error: string]
  (if append-mode
    (return (sorted-appended-datom-slice-indexes appended start-index order) true "")
    (let [existing (db-index-view-entries view) :defer]
      (source-append-merge-index source (slice existing 0) appended start-index order))))

(defn source-append-index-mode-for-persist-view [source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string, force-append: bool] -> [append-mode: bool, ok: bool, error: string]
  (when force-append
    (return true true ""))
  (let [added (sorted-appended-datom-slice-indexes appended start-index order)]
    (defer (delete added))
    (source-append-index-view-can-append? source view (slice added 0) appended start-index order)))

(defn persist-source-append-merged-index-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string] -> [chunk-id: u64, ok: bool, error: string]
  (let [added (sorted-appended-datom-slice-indexes appended start-index order) :defer
        pending (make [dynamic]int) :defer
        leaf-ids (make [dynamic]u64) :defer
        state (Persist-Index-Merge-State {})
        left 0
        right 0]
    (while (and (< left (db-index-view-count view))
                (< right (count added)))
      (let [[added-less less-ok less-error] (source-appended-datom-index-less? source appended start-index order added[right] (db-index-view-at view left))]
        (when (not less-ok)
          (return 0 false less-error))
        (if added-less
          (do
            (let [[push-ok push-error] (persist-index-merge-push-entry-with-stmts! handle stmts basis-tx index-name (addr pending) (addr leaf-ids) (addr state) added[right])]
              (when (not push-ok)
                (return 0 false push-error)))
            (set! right (+ right 1)))
          (do
            (let [[push-ok push-error] (persist-index-merge-push-entry-with-stmts! handle stmts basis-tx index-name (addr pending) (addr leaf-ids) (addr state) (db-index-view-at view left))]
              (when (not push-ok)
                (return 0 false push-error)))
            (set! left (+ left 1))))))
    (while (< left (db-index-view-count view))
      (let [[push-ok push-error] (persist-index-merge-push-entry-with-stmts! handle stmts basis-tx index-name (addr pending) (addr leaf-ids) (addr state) (db-index-view-at view left))]
        (when (not push-ok)
          (return 0 false push-error)))
      (set! left (+ left 1)))
    (while (< right (count added))
      (let [[push-ok push-error] (persist-index-merge-push-entry-with-stmts! handle stmts basis-tx index-name (addr pending) (addr leaf-ids) (addr state) added[right])]
        (when (not push-ok)
          (return 0 false push-error)))
      (set! right (+ right 1)))
    (let [[flush-ok flush-error] (persist-index-merge-flush-pending-with-stmts! handle stmts basis-tx index-name (addr pending) (addr leaf-ids))]
      (when (not flush-ok)
        (return 0 false flush-error)))
    (persist-index-root-from-leaf-ids-sqlite-handle-with-stmts handle stmts basis-tx index-name (slice leaf-ids 0) state)))

(defn persist-source-append-merged-index-root-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string] -> [chunk-id: u64, ok: bool, error: string]
  (persist-source-append-merged-index-root-sqlite-handle-with-stmts handle nil basis-tx index-name source view appended start-index order))

(defn persist-source-append-index-delta-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int, appended: []Datom, start-index: int] -> [chunk-id: u64, manifest-id: u64, ok: bool, error: string]
  (if (= view.kind .SQLite-Cursor)
    (persist-run-manifest-index-root-sqlite-handle-for-view-and-appended-with-stmts handle stmts basis-tx index-name view added appended start-index true)
    (let [[fallback-id fallback-ok fallback-error] (persist-appended-index-root-sqlite-handle-for-view-with-stmts handle stmts basis-tx index-name view added)]
      (return fallback-id 0 fallback-ok fallback-error))))

(defn sorted-appended-indexes-for-persist [appended: []Datom, start-index: int] -> [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int]
  (let [eavt-index (sorted-appended-datom-slice-indexes appended start-index "eavt")
        aevt-index (sorted-appended-datom-slice-indexes appended start-index "aevt")
        avet-index (sorted-appended-datom-slice-indexes appended start-index "avet")
        vaet-index (sorted-appended-datom-slice-indexes appended start-index "vaet")]
    (return eavt-index aevt-index avet-index vaet-index)))

(defn single-entry-index-delta [entry: int] -> [dynamic]int
  (let [out (make [dynamic]int 0 1)]
    (arr.push! out entry)
    out))

(defn sqlite-index-append-delta-from-appended [appended: []Datom, start-index: int, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> SQLite-Index-Append-Delta
  (when (= (count appended) 0)
    (return (sqlite-index-append-delta
              (make [dynamic]int)
              (make [dynamic]int)
              (make [dynamic]int)
              (make [dynamic]int)
              modes)))
  (when (= (count appended) 1)
    (let [eavt (single-entry-index-delta start-index)
          aevt (single-entry-index-delta start-index)
          avet (single-entry-index-delta start-index)
          vaet (single-entry-index-delta start-index)]
      (return (sqlite-index-append-delta eavt aevt avet vaet modes))))
  (let [sort-start (time.now)
        [eavt aevt avet vaet] (sorted-appended-indexes-for-persist appended start-index)]
    (when (not (= profile nil))
      (set! profile^.append-root-sort-us (+ profile^.append-root-sort-us (sqlite-profile-elapsed-us sort-start))))
    (sqlite-index-append-delta eavt aevt avet vaet modes)))

(defn persist-source-append-index-root-sqlite-handle-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string, force-append: bool, profile: ^SQLite-Direct-Write-Profile] -> [publish: SQLite-Index-Root-Publish, ok: bool, error: string]
  (let [sort-start (time.now)
        added (sorted-appended-datom-slice-indexes appended start-index order) :defer]
    (when (not (= profile nil))
      (set! profile^.append-root-sort-us (+ profile^.append-root-sort-us (sqlite-profile-elapsed-us sort-start))))
    (persist-source-append-index-root-sqlite-handle-with-added-stmts handle stmts basis-tx index-name source view (slice added 0) appended start-index order force-append profile)))

(defn persist-source-append-index-root-sqlite-handle-with-added-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, source: DB-Read-Source, view: DB-Index-View, added: []int, appended: []Datom, start-index: int, order: string, force-append: bool, profile: ^SQLite-Direct-Write-Profile] -> [publish: SQLite-Index-Root-Publish, ok: bool, error: string]
    (when force-append
      (let [persist-start (time.now)
            [chunk-id manifest-id chunk-ok chunk-error] (persist-source-append-index-delta-root-sqlite-handle-with-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index)]
        (when (not (= profile nil))
          (set! profile^.append-root-persist-us (+ profile^.append-root-persist-us (sqlite-profile-elapsed-us persist-start))))
        (return (SQLite-Index-Root-Publish {root-id: chunk-id manifest-id: manifest-id append-mode: true}) chunk-ok chunk-error)))
    (let [check-start (time.now)
          [appendable appendable-ok appendable-error] (source-append-index-view-can-append? source view (slice added 0) appended start-index order)]
      (when (not (= profile nil))
        (set! profile^.append-root-check-us (+ profile^.append-root-check-us (sqlite-profile-elapsed-us check-start))))
      (when (not appendable-ok)
        (return (SQLite-Index-Root-Publish {}) false appendable-error))
      (if appendable
        (let [persist-start (time.now)
              [chunk-id manifest-id chunk-ok chunk-error] (persist-source-append-index-delta-root-sqlite-handle-with-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index)]
          (when (not (= profile nil))
            (set! profile^.append-root-persist-us (+ profile^.append-root-persist-us (sqlite-profile-elapsed-us persist-start))))
          (return (SQLite-Index-Root-Publish {root-id: chunk-id manifest-id: manifest-id append-mode: true}) chunk-ok chunk-error))
        (let [persist-start (time.now)
              [chunk-id manifest-id chunk-ok chunk-error] (persist-run-manifest-index-root-sqlite-handle-for-view-and-appended-with-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index true)]
          (when (not (= profile nil))
            (set! profile^.append-root-persist-us (+ profile^.append-root-persist-us (sqlite-profile-elapsed-us persist-start))))
          (return (SQLite-Index-Root-Publish {root-id: chunk-id manifest-id: manifest-id append-mode: false}) chunk-ok chunk-error)))))

(defn persist-source-append-index-root-sqlite-handle [handle: rawptr, basis-tx: u64, index-name: string, source: DB-Read-Source, view: DB-Index-View, appended: []Datom, start-index: int, order: string, force-append: bool] -> [publish: SQLite-Index-Root-Publish, ok: bool, error: string]
  (persist-source-append-index-root-sqlite-handle-with-stmts handle nil basis-tx index-name source view appended start-index order force-append nil))

(defn persist-source-append-index-root-sqlite-handle-known-mode-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, appended: []Datom, start-index: int, order: string, append-mode: bool, profile: ^SQLite-Direct-Write-Profile] -> [publish: SQLite-Index-Root-Publish, ok: bool, error: string]
  (let [sort-start (time.now)
        added (sorted-appended-datom-slice-indexes appended start-index order) :defer]
    (when (not (= profile nil))
      (set! profile^.append-root-sort-us (+ profile^.append-root-sort-us (sqlite-profile-elapsed-us sort-start))))
    (persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index append-mode profile)))

(defn persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, index-name: string, view: DB-Index-View, added: []int, appended: []Datom, start-index: int, append-mode: bool, profile: ^SQLite-Direct-Write-Profile] -> [publish: SQLite-Index-Root-Publish, ok: bool, error: string]
    (let [persist-start (time.now)]
      (if append-mode
        (let [[chunk-id manifest-id chunk-ok chunk-error] (persist-source-append-index-delta-root-sqlite-handle-with-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index)]
          (when (not (= profile nil))
            (set! profile^.append-root-persist-us (+ profile^.append-root-persist-us (sqlite-profile-elapsed-us persist-start))))
          (return (SQLite-Index-Root-Publish {root-id: chunk-id manifest-id: manifest-id append-mode: true}) chunk-ok chunk-error))
        (let [[chunk-id manifest-id chunk-ok chunk-error] (persist-run-manifest-index-root-sqlite-handle-for-view-and-appended-with-stmts handle stmts basis-tx index-name view (slice added 0) appended start-index true)]
          (when (not (= profile nil))
            (set! profile^.append-root-persist-us (+ profile^.append-root-persist-us (sqlite-profile-elapsed-us persist-start))))
          (return (SQLite-Index-Root-Publish {root-id: chunk-id manifest-id: manifest-id append-mode: false}) chunk-ok chunk-error)))))

(defn persist-source-append-index-roots-sqlite-handle [handle: rawptr, basis-tx: u64, source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool, profile: ^SQLite-Direct-Write-Profile] -> [modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (when (= (count appended) 0)
    (let [publish-start (time.now)
          [_root-id root-ok root-error] (sqlite-republish-latest-index-root-set! handle basis-tx)]
      (when (not (= profile nil))
        (set! profile^.append-root-publish-us (+ profile^.append-root-publish-us (sqlite-profile-elapsed-us publish-start))))
      (return (SQLite-Index-Append-Modes {eavt: true aevt: true avet: true vaet: true}) root-ok root-error)))
  (let [eavt-view (db-read-source-index-view source .EAVT)
        aevt-view (db-read-source-index-view source .AEVT)
        avet-view (db-read-source-index-view source .AVET)
        vaet-view (db-read-source-index-view source .VAET)
        build-start (time.now)
    [stmts stmts-ok stmts-error] (sqlite-index-write-stmts-open handle)]
    (when (not stmts-ok)
      (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
      (return (SQLite-Index-Append-Modes {}) false stmts-error))
    (defer (sqlite-index-write-stmts-close stmts))
    (let [sort-start (time.now)
          [eavt-added aevt-added avet-added vaet-added] (sorted-appended-indexes-for-persist appended start-index)]
      (defer (delete eavt-added))
      (defer (delete aevt-added))
      (defer (delete avet-added))
      (defer (delete vaet-added))
      (set! profile^.append-root-sort-us (+ profile^.append-root-sort-us (sqlite-profile-elapsed-us sort-start)))
    (let [eavt-start (time.now)
          [eavt-publish eavt-ok eavt-error] (persist-source-append-index-root-sqlite-handle-with-added-stmts handle (addr stmts) basis-tx ":eavt" source eavt-view (slice eavt-added 0) appended start-index "eavt" new-entities-after-existing profile)]
      (set! profile^.append-eavt-root-build-us (+ profile^.append-eavt-root-build-us (sqlite-profile-elapsed-us eavt-start)))
      (when (not eavt-ok)
        (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
        (return (SQLite-Index-Append-Modes {}) false eavt-error))
      (let [aevt-start (time.now)
            [aevt-publish aevt-ok aevt-error] (persist-source-append-index-root-sqlite-handle-with-added-stmts handle (addr stmts) basis-tx ":aevt" source aevt-view (slice aevt-added 0) appended start-index "aevt" false profile)]
      (set! profile^.append-aevt-root-build-us (+ profile^.append-aevt-root-build-us (sqlite-profile-elapsed-us aevt-start)))
      (when (not aevt-ok)
        (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
        (return (SQLite-Index-Append-Modes {}) false aevt-error))
      (let [avet-start (time.now)
            [avet-publish avet-ok avet-error] (persist-source-append-index-root-sqlite-handle-with-added-stmts handle (addr stmts) basis-tx ":avet" source avet-view (slice avet-added 0) appended start-index "avet" false profile)]
        (set! profile^.append-avet-root-build-us (+ profile^.append-avet-root-build-us (sqlite-profile-elapsed-us avet-start)))
        (when (not avet-ok)
          (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
          (return (SQLite-Index-Append-Modes {}) false avet-error))
        (let [vaet-start (time.now)
              [vaet-publish vaet-ok vaet-error] (persist-source-append-index-root-sqlite-handle-with-added-stmts handle (addr stmts) basis-tx ":vaet" source vaet-view (slice vaet-added 0) appended start-index "vaet" false profile)]
          (set! profile^.append-vaet-root-build-us (+ profile^.append-vaet-root-build-us (sqlite-profile-elapsed-us vaet-start)))
          (when (not vaet-ok)
            (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
            (return (SQLite-Index-Append-Modes {}) false vaet-error))
          (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
          (let [publish-start (time.now)
                publishes (sqlite-index-root-publish-set eavt-publish aevt-publish avet-publish vaet-publish)
                [publish-modes root-ok root-error] (sqlite-publish-index-root-set-from-publishes-with-stmts! handle (addr stmts) basis-tx publishes true)]
            (set! profile^.append-root-publish-us (+ profile^.append-root-publish-us (sqlite-profile-elapsed-us publish-start)))
            (return publish-modes root-ok root-error)))))))))

(defn sqlite-durable-append-plan-root-publication-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, source: DB-Read-Source, appended: []Datom, plan: SQLite-Durable-Append-Plan, profile: ^SQLite-Direct-Write-Profile] -> [publication: SQLite-Durable-Append-Publication, ok: bool, error: string]
  (let [eavt-view (db-read-source-index-view source .EAVT)
        aevt-view (db-read-source-index-view source .AEVT)
        avet-view (db-read-source-index-view source .AVET)
        vaet-view (db-read-source-index-view source .VAET)
        eavt-page (sqlite-index-append-delta-page plan.prepared.delta 0)
        aevt-page (sqlite-index-append-delta-page plan.prepared.delta 1)
        avet-page (sqlite-index-append-delta-page plan.prepared.delta 2)
        vaet-page (sqlite-index-append-delta-page plan.prepared.delta 3)
        build-start (time.now)]
    (let [eavt-start (time.now)
          [eavt-publish eavt-ok eavt-error] (persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts handle stmts basis-tx eavt-page.index-name eavt-view (slice eavt-page.entries 0) appended plan.start-index eavt-page.append-mode profile)]
      (set! profile^.append-eavt-root-build-us (+ profile^.append-eavt-root-build-us (sqlite-profile-elapsed-us eavt-start)))
      (when (not eavt-ok)
        (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
        (return (SQLite-Durable-Append-Publication {}) false eavt-error))
      (let [aevt-start (time.now)
            [aevt-publish aevt-ok aevt-error] (persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts handle stmts basis-tx aevt-page.index-name aevt-view (slice aevt-page.entries 0) appended plan.start-index aevt-page.append-mode profile)]
        (set! profile^.append-aevt-root-build-us (+ profile^.append-aevt-root-build-us (sqlite-profile-elapsed-us aevt-start)))
        (when (not aevt-ok)
          (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
          (return (SQLite-Durable-Append-Publication {}) false aevt-error))
        (let [avet-start (time.now)
              [avet-publish avet-ok avet-error] (persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts handle stmts basis-tx avet-page.index-name avet-view (slice avet-page.entries 0) appended plan.start-index avet-page.append-mode profile)]
          (set! profile^.append-avet-root-build-us (+ profile^.append-avet-root-build-us (sqlite-profile-elapsed-us avet-start)))
          (when (not avet-ok)
            (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
            (return (SQLite-Durable-Append-Publication {}) false avet-error))
          (let [vaet-start (time.now)
                [vaet-publish vaet-ok vaet-error] (persist-source-append-index-root-sqlite-handle-known-mode-with-added-stmts handle stmts basis-tx vaet-page.index-name vaet-view (slice vaet-page.entries 0) appended plan.start-index vaet-page.append-mode profile)]
            (set! profile^.append-vaet-root-build-us (+ profile^.append-vaet-root-build-us (sqlite-profile-elapsed-us vaet-start)))
            (when (not vaet-ok)
              (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
              (return (SQLite-Durable-Append-Publication {}) false vaet-error))
            (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
            (let [publishes (sqlite-index-root-publish-set eavt-publish aevt-publish avet-publish vaet-publish)]
              (return (SQLite-Durable-Append-Publication {publishes: publishes
                                                          roots: (sqlite-index-root-set-from-publish-set publishes)
                                                          modes: (sqlite-index-append-modes-from-publish-set publishes)})
                      true
                      ""))))))))

(defn sqlite-publish-durable-append-plan-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, source: DB-Read-Source, appended: []Datom, plan: SQLite-Durable-Append-Plan, profile: ^SQLite-Direct-Write-Profile, enqueue-maintenance: bool] -> [published: SQLite-Durable-Published-Root, ok: bool, error: string]
  (when (= (count appended) 0)
    (let [publish-start (time.now)
          [root-row-id root-ok root-error] (sqlite-republish-latest-index-root-set-with-stmts! handle stmts basis-tx)]
      (set! profile^.append-root-publish-us (+ profile^.append-root-publish-us (sqlite-profile-elapsed-us publish-start)))
      (when (not root-ok)
        (return (SQLite-Durable-Published-Root {}) false root-error))
      (let [[roots roots-ok roots-error] (sqlite-index-root-set-at-basis handle basis-tx)]
        (if roots-ok
          (return (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                                  basis-tx: basis-tx
                                                  roots: roots
                                                  modes: plan.prepared.modes})
                  true
                  "")
          (return (SQLite-Durable-Published-Root {}) false roots-error)))))
  (let [[publication publication-ok publication-error] (sqlite-durable-append-plan-root-publication-with-stmts handle stmts basis-tx source appended plan profile)]
    (when (not publication-ok)
      (return (SQLite-Durable-Published-Root {}) false publication-error))
    (let [publish-start (time.now)
          [out-published root-ok root-error] (sqlite-publish-durable-append-publication-with-stmts! handle stmts basis-tx publication enqueue-maintenance)]
      (set! profile^.append-root-publish-us (+ profile^.append-root-publish-us (sqlite-profile-elapsed-us publish-start)))
      (return out-published root-ok root-error))))

(defn persist-source-append-index-roots-sqlite-handle-delta-known-modes-with-stmts [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, basis-tx: u64, source: DB-Read-Source, appended: []Datom, start-index: int, delta: SQLite-Index-Append-Delta, profile: ^SQLite-Direct-Write-Profile, enqueue-maintenance: bool] -> [ok: bool, error: string]
  (let [plan (sqlite-durable-append-plan-from-delta start-index delta)
        [_published root-ok root-error] (sqlite-publish-durable-append-plan-with-stmts! handle stmts basis-tx source appended plan profile enqueue-maintenance)]
    (discard _published)
    (return root-ok root-error)))

(defn persist-source-append-index-roots-sqlite-handle-delta-known-modes [handle: rawptr, basis-tx: u64, source: DB-Read-Source, appended: []Datom, start-index: int, delta: SQLite-Index-Append-Delta, profile: ^SQLite-Direct-Write-Profile] -> [ok: bool, error: string]
  (let [build-start (time.now)
        [stmts stmts-ok stmts-error] (sqlite-index-write-stmts-open handle)]
    (when (not stmts-ok)
      (set! profile^.append-root-build-us (+ profile^.append-root-build-us (sqlite-profile-elapsed-us build-start)))
      (return false stmts-error))
    (defer (sqlite-index-write-stmts-close stmts))
    (persist-source-append-index-roots-sqlite-handle-delta-known-modes-with-stmts handle (addr stmts) basis-tx source appended start-index delta profile true)))

(defn persist-source-append-index-roots-sqlite-handle-prepared [handle: rawptr, basis-tx: u64, source: DB-Read-Source, appended: []Datom, start-index: int, prepared: SQLite-Prepared-Index-Append, profile: ^SQLite-Direct-Write-Profile] -> [ok: bool, error: string]
  (when (= (count appended) 0)
    (let [publish-start (time.now)
          [_root-id root-ok root-error] (sqlite-republish-latest-index-root-set! handle basis-tx)]
      (set! profile^.append-root-publish-us (+ profile^.append-root-publish-us (sqlite-profile-elapsed-us publish-start)))
      (return root-ok root-error)))
  (persist-source-append-index-roots-sqlite-handle-delta-known-modes handle basis-tx source appended start-index prepared.delta profile))

(defn persist-source-append-index-roots-sqlite-handle-known-modes [handle: rawptr, basis-tx: u64, source: DB-Read-Source, appended: []Datom, start-index: int, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> [ok: bool, error: string]
  (let [prepared (sqlite-prepared-index-append-from-modes appended start-index modes profile)]
    (defer (delete-sqlite-prepared-index-append prepared))
    (persist-source-append-index-roots-sqlite-handle-prepared handle basis-tx source appended start-index prepared profile)))

(defn source-append-index-modes-for-persist [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (let [eavt-view (db-read-source-index-view source .EAVT)
        aevt-view (db-read-source-index-view source .AEVT)
        avet-view (db-read-source-index-view source .AVET)
        vaet-view (db-read-source-index-view source .VAET)]
      (let [[eavt-mode-value eavt-ok eavt-error] (source-append-index-mode-for-persist-view source eavt-view appended start-index "eavt" new-entities-after-existing)]
      (when (not eavt-ok)
        (return (SQLite-Index-Append-Modes {}) false eavt-error))
      (let [[aevt-mode-value aevt-ok aevt-error] (source-append-index-mode-for-persist-view source aevt-view appended start-index "aevt" false)]
        (when (not aevt-ok)
          (return (SQLite-Index-Append-Modes {}) false aevt-error))
        (let [[avet-mode-value avet-ok avet-error] (source-append-index-mode-for-persist-view source avet-view appended start-index "avet" false)]
          (when (not avet-ok)
            (return (SQLite-Index-Append-Modes {}) false avet-error))
          (let [[vaet-mode-value vaet-ok vaet-error] (source-append-index-mode-for-persist-view source vaet-view appended start-index "vaet" false)]
            (if vaet-ok
              (return (SQLite-Index-Append-Modes {eavt: eavt-mode-value
                                                  aevt: aevt-mode-value
                                                  avet: avet-mode-value
                                                  vaet: vaet-mode-value})
                      true
                      "")
              (return (SQLite-Index-Append-Modes {}) false vaet-error))))))))

(defn source-append-build-indexes [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int, ok: bool, error: string]
  (let [eavt-base (db-index-view-entries (db-read-source-index-view source .EAVT))
        aevt-base (db-index-view-entries (db-read-source-index-view source .AEVT))
        avet-base (db-index-view-entries (db-read-source-index-view source .AVET))
        vaet-base (db-index-view-entries (db-read-source-index-view source .VAET))
        [eavt-index eavt-ok eavt-error] (source-append-eavt-index source (slice eavt-base 0) appended start-index new-entities-after-existing)]
    (when (not eavt-ok)
      (delete eavt-base)
      (delete aevt-base)
      (delete avet-base)
      (delete vaet-base)
      (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false eavt-error))
    (let [[aevt-index aevt-ok aevt-error] (source-append-merge-index source (slice aevt-base 0) appended start-index "aevt")]
      (when (not aevt-ok)
        (delete eavt-index)
        (delete eavt-base)
        (delete aevt-base)
        (delete avet-base)
        (delete vaet-base)
        (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false aevt-error))
      (let [[avet-index avet-ok avet-error] (source-append-merge-index source (slice avet-base 0) appended start-index "avet")]
        (when (not avet-ok)
          (delete eavt-index)
          (delete aevt-index)
          (delete eavt-base)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false avet-error))
        (let [[vaet-index vaet-ok vaet-error] (source-append-merge-index source (slice vaet-base 0) appended start-index "vaet")]
          (when (not vaet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (delete avet-index)
            (delete eavt-base)
            (delete aevt-base)
            (delete avet-base)
            (delete vaet-base)
            (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false vaet-error))
          (delete eavt-base)
          (delete aevt-base)
          (delete avet-base)
          (delete vaet-base)
          (return eavt-index aevt-index avet-index vaet-index true ""))))))

(defn source-append-build-indexes-for-persist-with-eavt [source: DB-Read-Source, appended: []Datom, start-index: int, eavt-index: [dynamic]int, eavt-appended-only: bool] -> [eavt: [dynamic]int, eavt-append-mode: bool, aevt: [dynamic]int, aevt-append-mode: bool, avet: [dynamic]int, avet-append-mode: bool, vaet: [dynamic]int, vaet-append-mode: bool, ok: bool, error: string]
  (let [aevt-view (db-read-source-index-view source .AEVT)
        avet-view (db-read-source-index-view source .AVET)
        vaet-view (db-read-source-index-view source .VAET)]
    (let [[aevt-index aevt-appended-only aevt-ok aevt-error] (source-append-index-for-persist-view source aevt-view appended start-index "aevt" false)]
      (when (not aevt-ok)
        (delete eavt-index)
        (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false aevt-error))
      (let [[avet-index avet-appended-only avet-ok avet-error] (source-append-index-for-persist-view source avet-view appended start-index "avet" false)]
        (when (not avet-ok)
          (delete eavt-index)
          (delete aevt-index)
          (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false avet-error))
        (let [[vaet-index vaet-appended-only vaet-ok vaet-error] (source-append-index-for-persist-view source vaet-view appended start-index "vaet" false)]
          (when (not vaet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (delete avet-index)
            (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false vaet-error))
          (return eavt-index eavt-appended-only aevt-index aevt-appended-only avet-index avet-appended-only vaet-index vaet-appended-only true ""))))))

(defn source-append-build-indexes-for-persist [source: DB-Read-Source, appended: []Datom, start-index: int, new-entities-after-existing: bool] -> [eavt: [dynamic]int, eavt-append-mode: bool, aevt: [dynamic]int, aevt-append-mode: bool, avet: [dynamic]int, avet-append-mode: bool, vaet: [dynamic]int, vaet-append-mode: bool, ok: bool, error: string]
  (if new-entities-after-existing
    (let [eavt-index (sorted-appended-datom-slice-indexes appended start-index "eavt")]
      (source-append-build-indexes-for-persist-with-eavt source appended start-index eavt-index true))
    (let [eavt-view (db-read-source-index-view source .EAVT)
          [eavt-index eavt-appended-only eavt-ok eavt-error] (source-append-index-for-persist-view source eavt-view appended start-index "eavt" false)]
      (when (not eavt-ok)
        (return (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false (make [dynamic]int) false false eavt-error))
      (source-append-build-indexes-for-persist-with-eavt source appended start-index eavt-index eavt-appended-only))))

(defn source-append-build-indexes-for-persist-modes [source: DB-Read-Source, appended: []Datom, start-index: int, modes: SQLite-Index-Append-Modes] -> [eavt: [dynamic]int, aevt: [dynamic]int, avet: [dynamic]int, vaet: [dynamic]int, ok: bool, error: string]
  (let [eavt-view (db-read-source-index-view source .EAVT)
        aevt-view (db-read-source-index-view source .AEVT)
        avet-view (db-read-source-index-view source .AVET)
        vaet-view (db-read-source-index-view source .VAET)]
    (let [[eavt-index eavt-ok eavt-error] (source-append-index-for-persist-mode-view source eavt-view appended start-index "eavt" modes.eavt)]
      (when (not eavt-ok)
        (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false eavt-error))
      (let [[aevt-index aevt-ok aevt-error] (source-append-index-for-persist-mode-view source aevt-view appended start-index "aevt" modes.aevt)]
        (when (not aevt-ok)
          (delete eavt-index)
          (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false aevt-error))
        (let [[avet-index avet-ok avet-error] (source-append-index-for-persist-mode-view source avet-view appended start-index "avet" modes.avet)]
          (when (not avet-ok)
            (delete eavt-index)
            (delete aevt-index)
            (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false avet-error))
          (let [[vaet-index vaet-ok vaet-error] (source-append-index-for-persist-mode-view source vaet-view appended start-index "vaet" modes.vaet)]
            (when (not vaet-ok)
              (delete eavt-index)
              (delete aevt-index)
              (delete avet-index)
              (return (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) false vaet-error))
            (return eavt-index aevt-index avet-index vaet-index true "")))))))

(defn source-append-datoms-all-new-entities? [next-entity: u64, datoms: []Datom] -> bool
  (for [datom datoms]
    (when (< datom.e next-entity)
      (return false)))
  true)

(defn append-source-direct-sqlite-handle [handle: rawptr, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, delta: SQLite-Index-Append-Delta] -> [ok: bool, error: string]
  (let [[begin-ok begin-error] (sqlite-begin-immediate-raw handle)]
    (when (not begin-ok)
      (return false begin-error))
    (let [[write-stmts write-stmts-ok write-stmts-error] (sqlite-direct-write-stmts-open handle)]
      (when (not write-stmts-ok)
        (sqlite-rollback-raw handle)
        (return false write-stmts-error))
      (defer (sqlite-direct-write-stmts-close write-stmts))
      (let [[tx-ok tx-error] (insert-sqlite-tx-with-stmts! handle (addr write-stmts) tx)]
        (when (not tx-ok)
          (sqlite-rollback-raw handle)
          (return false tx-error)))
      (let [[datoms-ok datoms-error] (append-sqlite-datoms-with-stmts! handle (addr write-stmts) base-count tx-data)]
        (when (not datoms-ok)
          (sqlite-rollback-raw handle)
          (return false datoms-error)))
      (let [[meta-ok meta-error] (insert-sqlite-tx-meta-with-stmts! handle (addr write-stmts) tx tx-meta)]
        (when (not meta-ok)
          (sqlite-rollback-raw handle)
          (return false meta-error))))
    (let [[index-stmts index-stmts-ok index-stmts-error] (sqlite-index-write-stmts-open handle)]
      (when (not index-stmts-ok)
        (sqlite-rollback-raw handle)
        (return false index-stmts-error))
      (defer (sqlite-index-write-stmts-close index-stmts))
      (let [modes (sqlite-index-append-delta-modes delta)
            [root-ok root-error] (persist-index-root-sqlite-handle-from-indexes-mode-with-stmts handle (addr index-stmts) tx (slice delta.pages[0].entries 0) (slice delta.pages[1].entries 0) (slice delta.pages[2].entries 0) (slice delta.pages[3].entries 0) modes)]
        (when (not root-ok)
          (sqlite-rollback-raw handle)
          (return false root-error))))
    (sqlite-commit-raw handle)))

(defn sqlite-rollback-if-owned! [handle: rawptr, owns-tx: bool]
  (when owns-tx
    (sqlite-rollback-raw handle)))

(defn append-source-direct-sqlite-conn-from-source-plan-published-mode [store: ^SQLite-Conn, source: DB-Read-Source, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, plan: SQLite-Durable-Append-Plan, profile: ^SQLite-Direct-Write-Profile, owns-tx: bool] -> [published: SQLite-Durable-Published-Root, ok: bool, error: string]
  (let [handle store^.handle]
    (when owns-tx
      (let [begin-start (time.now)
            [begin-ok begin-error] (sqlite-begin-immediate-raw handle)]
        (set! profile^.append-begin-us (+ profile^.append-begin-us (sqlite-profile-elapsed-us begin-start)))
        (when (not begin-ok)
          (return (SQLite-Durable-Published-Root {}) false begin-error))))
    (let [tx-start (time.now)
          [write-stmts write-stmts-ok write-stmts-error] (sqlite-conn-direct-write-stmts store)]
      (when (not write-stmts-ok)
        (set! profile^.append-tx-us (+ profile^.append-tx-us (sqlite-profile-elapsed-us tx-start)))
        (sqlite-rollback-if-owned! handle owns-tx)
        (return (SQLite-Durable-Published-Root {}) false write-stmts-error))
      (let [[tx-ok tx-error] (insert-sqlite-tx-with-stmts! handle write-stmts tx)]
        (set! profile^.append-tx-us (+ profile^.append-tx-us (sqlite-profile-elapsed-us tx-start)))
        (when (not tx-ok)
          (sqlite-rollback-if-owned! handle owns-tx)
          (return (SQLite-Durable-Published-Root {}) false tx-error)))
      (let [datom-start (time.now)
            [datoms-ok datoms-error] (append-sqlite-datoms-with-stmts! handle write-stmts plan.start-index tx-data)]
        (set! profile^.append-datoms-us (+ profile^.append-datoms-us (sqlite-profile-elapsed-us datom-start)))
        (when (not datoms-ok)
          (sqlite-rollback-if-owned! handle owns-tx)
          (return (SQLite-Durable-Published-Root {}) false datoms-error)))
      (let [meta-start (time.now)
            [meta-ok meta-error] (insert-sqlite-tx-meta-with-stmts! handle write-stmts tx tx-meta)]
        (set! profile^.append-meta-us (+ profile^.append-meta-us (sqlite-profile-elapsed-us meta-start)))
        (when (not meta-ok)
          (sqlite-rollback-if-owned! handle owns-tx)
          (return (SQLite-Durable-Published-Root {}) false meta-error))))
    (let [roots-start (time.now)
          [stmts stmts-ok stmts-error] (sqlite-conn-index-write-stmts store)]
      (when (not stmts-ok)
        (set! profile^.append-roots-us (+ profile^.append-roots-us (sqlite-profile-elapsed-us roots-start)))
        (sqlite-rollback-if-owned! handle owns-tx)
        (return (SQLite-Durable-Published-Root {}) false stmts-error))
      (let [[out-published roots-ok roots-error] (sqlite-publish-durable-append-plan-with-stmts! handle stmts tx source tx-data plan profile owns-tx)]
        (set! profile^.append-roots-us (+ profile^.append-roots-us (sqlite-profile-elapsed-us roots-start)))
        (when (not roots-ok)
          (sqlite-rollback-if-owned! handle owns-tx)
          (return (SQLite-Durable-Published-Root {}) false roots-error))
        (if owns-tx
          (let [commit-start (time.now)
                [commit-ok commit-error] (sqlite-commit-raw handle)]
            (set! profile^.append-commit-us (+ profile^.append-commit-us (sqlite-profile-elapsed-us commit-start)))
            (if commit-ok
              (return out-published true "")
              (return (SQLite-Durable-Published-Root {}) false commit-error)))
          (return out-published true ""))))))

(defn append-source-direct-sqlite-conn-from-source-plan-mode [store: ^SQLite-Conn, source: DB-Read-Source, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, plan: SQLite-Durable-Append-Plan, profile: ^SQLite-Direct-Write-Profile, owns-tx: bool] -> [out-modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (let [[published publish-ok publish-error] (append-source-direct-sqlite-conn-from-source-plan-published-mode store source tx tx-data tx-meta plan profile owns-tx)]
    (if publish-ok
      (return published.modes true "")
      (return (SQLite-Index-Append-Modes {}) false publish-error))))

(defn append-source-direct-sqlite-conn-from-source-prepared-mode [store: ^SQLite-Conn, source: DB-Read-Source, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, prepared: SQLite-Prepared-Index-Append, profile: ^SQLite-Direct-Write-Profile, owns-tx: bool] -> [out-modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (let [plan (SQLite-Durable-Append-Plan {start-index: base-count prepared: prepared})]
    (append-source-direct-sqlite-conn-from-source-plan-mode store source tx tx-data tx-meta plan profile owns-tx)))

(defn append-source-direct-sqlite-conn-from-source-mode [store: ^SQLite-Conn, source: DB-Read-Source, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile, owns-tx: bool] -> [out-modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (let [plan (sqlite-durable-append-plan-from-modes tx-data base-count modes profile)]
    (defer (delete-sqlite-durable-append-plan plan))
    (append-source-direct-sqlite-conn-from-source-plan-mode store source tx tx-data tx-meta plan profile owns-tx)))

(defn append-source-direct-sqlite-conn-from-source [store: ^SQLite-Conn, source: DB-Read-Source, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> [out-modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (append-source-direct-sqlite-conn-from-source-mode store source base-count tx tx-data tx-meta modes profile true))

(defn append-source-direct-sqlite-conn-from-source-open-tx [store: ^SQLite-Conn, source: DB-Read-Source, base-count: int, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, modes: SQLite-Index-Append-Modes, profile: ^SQLite-Direct-Write-Profile] -> [out-modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (append-source-direct-sqlite-conn-from-source-mode store source base-count tx tx-data tx-meta modes profile false))

(defn append-tx-report-sqlite [path: string, report: Tx-Report] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[append-ok append-error] (append-tx-report-sqlite-handle handle report)]
      (sqlite-close-live-raw handle)
      (return append-ok append-error))))

(defn sqlite-tx-meta-row-from-edn-node [doc: EDN-Doc, node-index: int] -> [row: SQLite-Tx-Meta-Row, ok: bool, error: string]
  (when (or (= node-index -1)
            (not (= doc.nodes[node-index].kind .Vector))
            (not (= doc.nodes[node-index].child-count 3)))
    (return (SQLite-Tx-Meta-Row {}) false "expected serialized tx metadata vector [tx a v]"))
  (let [tx-node (edn-child-at doc node-index 0)
        a-node (edn-child-at doc node-index 1)
        v-node (edn-child-at doc node-index 2)
        [tx tx-ok tx-error] (edn-int-u64 doc tx-node "tx")
        [attr attr-ok] (edn-attr-text doc a-node)]
    (when (not tx-ok)
      (return (SQLite-Tx-Meta-Row {}) false tx-error))
    (when (not attr-ok)
      (return (SQLite-Tx-Meta-Row {}) false "expected tx metadata attribute keyword or string"))
    (let [[value value-ok value-error] (serial-value-from-edn-node doc v-node)]
      (when (not value-ok)
        (return (SQLite-Tx-Meta-Row {}) false value-error))
      (let [owned (value-owned value)]
        (delete-value-containers-shallow value)
        (return (SQLite-Tx-Meta-Row {tx: tx a: (string-owned attr) v: owned}) true "")))))

(defn delete-sqlite-tx-meta-rows [rows: [dynamic]SQLite-Tx-Meta-Row]
  (for [row rows]
    (delete row.a)
    (delete-owned-value row.v))
  (delete rows))

(defn load-sqlite-tx-meta-rows [path: string] -> [rows: [dynamic]SQLite-Tx-Meta-Row, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-tx-meta-rows-text-raw path)]
    (when (not loaded-ok)
      (return (make [dynamic]SQLite-Tx-Meta-Row) false loaded-error))
    (defer (delete text))
    (let [[value read-error read-ok] (edn.try-read text)]
      (when (not read-ok)
        (return (make [dynamic]SQLite-Tx-Meta-Row) false read-error.message))
      (let [doc (edn-doc-from-data value)]
        (defer (delete doc.nodes))
        (when (not (= doc.nodes[doc.root].kind .Vector))
          (return (make [dynamic]SQLite-Tx-Meta-Row) false "expected serialized tx metadata vector"))
        (let [out (make [dynamic]SQLite-Tx-Meta-Row)
              child doc.nodes[doc.root].first-child]
          (while (not (= child -1))
            (let [[row row-ok row-error] (sqlite-tx-meta-row-from-edn-node doc child)]
              (when (not row-ok)
                (delete-sqlite-tx-meta-rows out)
                (return (make [dynamic]SQLite-Tx-Meta-Row) false row-error))
              (arr.push! out row)
              (set! child doc.nodes[child].next-sibling)))
          (return out true ""))))))

(defn create-sqlite-conn [path: string] -> SQLite-Conn
  (SQLite-Conn {path: (string-owned path)
                conn: (create-conn)
                resident-loaded: true
                direct-attr-cache: (make [dynamic]SQLite-Direct-Attr-Info)}))

(defn open-sqlite-conn [path: string] -> [store: SQLite-Conn, ok: bool, error: string]
  (let [[handle handle-ok handle-error] (sqlite-open-live-raw path)]
    (if handle-ok
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            handle: handle
                            source-only: false
                            resident-loaded: false
                            direct-attr-cache: (make [dynamic]SQLite-Direct-Attr-Info)})
              true
              "")
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            resident-loaded: true
                            direct-attr-cache: (make [dynamic]SQLite-Direct-Attr-Info)})
              false
              (string-owned handle-error)))))

(defn open-sqlite-source-conn [path: string] -> [store: SQLite-Conn, ok: bool, error: string]
  (let [[handle handle-ok handle-error] (sqlite-open-live-raw path)]
    (if handle-ok
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            handle: handle
                            source-only: true
                            resident-loaded: false
                            direct-attr-cache: (make [dynamic]SQLite-Direct-Attr-Info)})
              true
              "")
      (return (SQLite-Conn {path: (string-owned path)
                            conn: (create-conn)
                            source-only: true
                            resident-loaded: false
                            direct-attr-cache: (make [dynamic]SQLite-Direct-Attr-Info)})
              false
              (string-owned handle-error)))))

(defn sqlite-conn-ensure-resident! [store: ^SQLite-Conn] -> [ok: bool, error: string]
  (when store^.resident-loaded
    (return true ""))
  (sqlite-conn-invalidate-write-state-cache! store)
  (sqlite-conn-invalidate-direct-attr-cache! store)
  (let [[conn opened-ok opened-error] (open-conn-sqlite-resident store^.path)]
    (when (and (not opened-ok)
               (not (= opened-error "sqlite DB has no Vev datom rows")))
      (delete-owned-db conn.db)
      (delete conn.listeners)
      (return false opened-error))
    (delete-owned-db store^.conn.db)
    (delete store^.conn.listeners)
    (set! store^.conn conn)
    (set! store^.resident-loaded true)
    (return true "")))

(defn sqlite-conn-basis-t [store: ^SQLite-Conn] -> [basis-t: u64, ok: bool, error: string]
  (when store^.resident-loaded
    (let [next-tx store^.conn.next-tx]
      (return (if (= next-tx 0) 0 (- next-tx 1)) true "")))
  (sqlite-latest-index-root-basis-raw store^.handle))

(defn sqlite-conn-tx-count [store: ^SQLite-Conn] -> [tx-count: u64, ok: bool, error: string]
  (sqlite-tx-count-raw store^.handle))

(defn sqlite-conn-datom-count [store: ^SQLite-Conn] -> [datom-count: u64, ok: bool, error: string]
  (if store^.datom-count-cache-valid
    (return store^.datom-count-cache true "")
    (let [[count-value count-ok count-error] (sqlite-datom-count-raw store^.handle)]
      (when count-ok
        (set! store^.datom-count-cache count-value)
        (set! store^.datom-count-cache-valid true))
      (return count-value count-ok count-error))))

(defn sqlite-conn-datom-count-and-retractions [store: ^SQLite-Conn] -> [datom-count: u64, has-retractions: bool, ok: bool, error: string]
  (let [[count-value count-ok count-error] (sqlite-conn-datom-count store)]
    (when (not count-ok)
      (return 0 false false count-error))
    (if store^.has-retractions-cache-valid
      (return count-value store^.has-retractions-cache true "")
      (let [[has-retractions retractions-ok retractions-error] (sqlite-datom-has-retractions-raw store^.handle)]
        (when retractions-ok
          (set! store^.has-retractions-cache has-retractions)
          (set! store^.has-retractions-cache-valid true))
        (return count-value has-retractions retractions-ok retractions-error)))))

(defn sqlite-conn-tx-ids [store: ^SQLite-Conn] -> [tx-ids: [dynamic]u64, ok: bool, error: string]
  (sqlite-tx-ids-raw store^.handle))

(defn sqlite-conn-tx-data-text [store: ^SQLite-Conn, tx: u64] -> [text: string, ok: bool, error: string]
  (sqlite-tx-data-text-raw store^.handle tx))

(defn sqlite-conn-storage-architecture [store: ^SQLite-Conn] -> [architecture: string, ok: bool, error: string]
  (sqlite-meta-value-raw store^.handle "storage-architecture"))

(defn sqlite-conn-index-root-count [store: ^SQLite-Conn] -> [root-count: u64, ok: bool, error: string]
  (sqlite-index-root-count-raw store^.handle))

(defn sqlite-conn-index-root-page-count [store: ^SQLite-Conn] -> [page-count: u64, ok: bool, error: string]
  (sqlite-index-root-page-count-raw store^.handle))

(defn sqlite-conn-index-chunk-count [store: ^SQLite-Conn] -> [chunk-count: u64, ok: bool, error: string]
  (sqlite-index-chunk-count-raw store^.handle))

(defn sqlite-conn-index-maintenance-count [store: ^SQLite-Conn] -> [maintenance-count: u64, ok: bool, error: string]
  (sqlite-index-maintenance-count-raw store^.handle))

(defn sqlite-profile-elapsed-us [start: time.Time] -> f64
  (time.duration_microseconds (time.since start)))

(defn reset-sqlite-direct-write-profile! [store: ^SQLite-Conn]
  (set! store^.direct-write-profile (SQLite-Direct-Write-Profile {})))

(defn sqlite-direct-write-profile [store: ^SQLite-Conn] -> SQLite-Direct-Write-Profile
  store^.direct-write-profile)

(defn sqlite-conn-latest-index-root-basis [store: ^SQLite-Conn] -> [basis-tx: u64, ok: bool, error: string]
  (sqlite-latest-index-root-basis-raw store^.handle))

(defn sqlite-conn-latest-index-chunk-row-count [store: ^SQLite-Conn, index-name: string] -> [basis-tx: u64, row-count: u64, ok: bool, error: string]
  (sqlite-latest-index-chunk-row-count-raw store^.handle index-name))

(defn sqlite-conn-latest-index-entries [store: ^SQLite-Conn, index-name: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [[cursor cursor-ok cursor-error] (sqlite-conn-open-index-cursor store index-name sqlite-index-leaf-chunk-size)]
    (when (not cursor-ok)
      (return (make [dynamic]int) false cursor-error))
    (defer (close-sqlite-index-cursor! (addr cursor)))
    (let [out (make [dynamic]int 0 (sqlite-index-cursor-count cursor))]
      (for [index (arr.range 0 (sqlite-index-cursor-count cursor))]
        (let [[entry entry-ok entry-error] (sqlite-index-cursor-at (addr cursor) index)]
          (when (not entry-ok)
            (when (sqlite-index-cursor-stream-ended? (addr cursor) entry-error)
              (return out true ""))
            (delete out)
            (return (make [dynamic]int) false entry-error))
          (arr.push! out entry)))
      (return out true ""))))

(defn sqlite-conn-compact-indexes! [store: ^SQLite-Conn] -> [compacted: bool, ok: bool, error: string]
  (when store^.source-only
    (return false false "SQLite source connection is read-only; open a writable SQLite connection to compact indexes"))
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw store^.handle)]
    (when (not basis-ok)
      (if (= basis-error "sqlite DB has no Vev index roots")
        (return false true "")
        (return false false basis-error)))
    (let [[eavt eavt-ok eavt-error] (sqlite-conn-latest-index-entries store ":eavt")]
      (when (not eavt-ok)
        (return false false eavt-error))
      (defer (delete eavt))
      (let [[aevt aevt-ok aevt-error] (sqlite-conn-latest-index-entries store ":aevt")]
        (when (not aevt-ok)
          (return false false aevt-error))
        (defer (delete aevt))
        (let [[avet avet-ok avet-error] (sqlite-conn-latest-index-entries store ":avet")]
          (when (not avet-ok)
            (return false false avet-error))
          (defer (delete avet))
          (let [[vaet vaet-ok vaet-error] (sqlite-conn-latest-index-entries store ":vaet")]
            (when (not vaet-ok)
              (return false false vaet-error))
            (defer (delete vaet))
            (let [[stmts stmts-ok stmts-error] (sqlite-index-write-stmts-open store^.handle)]
              (when (not stmts-ok)
                (return false false stmts-error))
              (defer (sqlite-index-write-stmts-close stmts))
              (let [[root-ok root-error] (persist-index-root-sqlite-handle-from-indexes-with-stmts store^.handle (addr stmts) basis (slice eavt 0) (slice aevt 0) (slice avet 0) (slice vaet 0))]
                (return root-ok root-ok root-error)))))))))

(defn sqlite-maintain-queued-index-root-step! [handle: rawptr] -> [handled: bool, compacted: bool, ok: bool, error: string]
  (let [[task-id task-index task-basis task-root has-task task-ok task-error] (sqlite_next_index_maintenance_raw handle)]
    (when (not task-ok)
      (return false false false task-error))
    (when (not has-task)
      (return false false true ""))
    (defer (delete task-index))
    (let [[latest-basis _ latest-root latest-ok latest-error] (sqlite-latest-index-root-chunk-info-raw handle task-index)]
      (when (not latest-ok)
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (return true false delete-ok (if delete-ok "" delete-error))))
      (when (or (not (= latest-basis task-basis)) (not (= latest-root task-root)))
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (return true false delete-ok (if delete-ok "" delete-error))))
      (let [[task-compacted task-compact-ok task-compact-error] (sqlite-maintain-latest-index-root-step! handle task-basis task-index)]
        (when (not task-compact-ok)
          (return true false false task-compact-error))
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (if delete-ok
            (return true task-compacted true "")
            (return true task-compacted false delete-error)))))))

(defn sqlite-maintain-queued-index-root-foreground-step! [handle: rawptr, row-budget: int] -> [handled: bool, compacted: bool, ok: bool, error: string]
  (let [[task-id task-index task-basis task-root has-task task-ok task-error] (sqlite_next_index_maintenance_raw handle)]
    (when (not task-ok)
      (return false false false task-error))
    (when (not has-task)
      (return false false true ""))
    (defer (delete task-index))
    (let [[latest-basis _ latest-root latest-ok latest-error] (sqlite-latest-index-root-chunk-info-raw handle task-index)]
      (when (not latest-ok)
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (return true false delete-ok (if delete-ok "" delete-error))))
      (when (or (not (= latest-basis task-basis)) (not (= latest-root task-root)))
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (return true false delete-ok (if delete-ok "" delete-error))))
      (let [[row-count needed row-ok row-error] (sqlite-latest-index-root-next-compaction-row-count handle task-index)]
        (when (not row-ok)
          (return true false false row-error))
        (when (and needed
                   (> row-count row-budget))
          ;; Keep normal commits bounded. Explicit/background maintenance can still
          ;; discover and compact this latest root via the scan path.
          (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
            (return true false delete-ok (if delete-ok "" delete-error)))))
      (let [[task-compacted task-compact-ok task-compact-error] (sqlite-maintain-latest-index-root-step! handle task-basis task-index)]
        (when (not task-compact-ok)
          (return true false false task-compact-error))
        (let [[delete-ok delete-error] (sqlite_delete_index_maintenance_raw handle task-id)]
          (if delete-ok
            (return true task-compacted true "")
            (return true task-compacted false delete-error)))))))

(defn sqlite-maintain-latest-index-roots-scan-step! [handle: rawptr, basis: u64] -> [compacted: bool, ok: bool, error: string]
  (let [[eavt-compacted eavt-ok eavt-error] (sqlite-maintain-latest-index-root-step! handle basis ":eavt")]
      (when (or eavt-compacted (not eavt-ok))
        (return eavt-compacted eavt-ok eavt-error))
      (let [[aevt-compacted aevt-ok aevt-error] (sqlite-maintain-latest-index-root-step! handle basis ":aevt")]
        (when (or aevt-compacted (not aevt-ok))
          (return aevt-compacted aevt-ok aevt-error))
        (let [[avet-compacted avet-ok avet-error] (sqlite-maintain-latest-index-root-step! handle basis ":avet")]
          (when (or avet-compacted (not avet-ok))
            (return avet-compacted avet-ok avet-error))
          (sqlite-maintain-latest-index-root-step! handle basis ":vaet")))))

(defn sqlite-conn-maintain-indexes-step! [store: ^SQLite-Conn] -> [compacted: bool, ok: bool, error: string]
  (when store^.source-only
    (return false false "SQLite source connection is read-only; open a writable SQLite connection to maintain indexes"))
  (let [[handled queued-compacted queued-ok queued-error] (sqlite-maintain-queued-index-root-step! store^.handle)]
    (when (or handled (not queued-ok))
      (return queued-compacted queued-ok queued-error)))
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw store^.handle)]
    (when (not basis-ok)
      (if (= basis-error "sqlite DB has no Vev index roots")
        (return false true "")
        (return false false basis-error)))
    (sqlite-maintain-latest-index-roots-scan-step! store^.handle basis)))

(defn sqlite-conn-maintain-indexes! [store: ^SQLite-Conn, max-steps: int] -> [steps: int, compacted: bool, ok: bool, error: string]
  (when store^.source-only
    (return 0 false false "SQLite source connection is read-only; open a writable SQLite connection to maintain indexes"))
  (let [limit (max 1 max-steps)
        step-count 0
        any-compacted false]
    (while (< step-count limit)
      (let [[handled queued-compacted queued-ok queued-error] (sqlite-maintain-queued-index-root-step! store^.handle)]
        (when (not queued-ok)
          (return step-count any-compacted false queued-error))
        (when handled
          (set! step-count (+ step-count 1))
          (set! any-compacted (or any-compacted queued-compacted))
          (continue)))
      (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw store^.handle)]
        (when (not basis-ok)
          (if (= basis-error "sqlite DB has no Vev index roots")
            (return step-count any-compacted true "")
            (return step-count any-compacted false basis-error)))
        (let [[scan-compacted scan-ok scan-error] (sqlite-maintain-latest-index-roots-scan-step! store^.handle basis)]
          (when (not scan-ok)
            (return step-count any-compacted false scan-error))
          (when (not scan-compacted)
            (return step-count any-compacted true ""))
          (set! step-count (+ step-count 1))
          (set! any-compacted true))))
    (return step-count any-compacted true "")))

(defn sqlite-conn-maintain-indexes-foreground! [store: ^SQLite-Conn, max-steps: int, row-budget: int] -> [steps: int, compacted: bool, ok: bool, error: string]
  (when store^.source-only
    (return 0 false false "SQLite source connection is read-only; open a writable SQLite connection to maintain indexes"))
  (let [limit (max 1 max-steps)
        step-count 0
        any-compacted false]
    (while (< step-count limit)
      (let [[handled queued-compacted queued-ok queued-error] (sqlite-maintain-queued-index-root-foreground-step! store^.handle row-budget)]
        (when (not queued-ok)
          (return step-count any-compacted false queued-error))
        (when handled
          (set! step-count (+ step-count 1))
          (set! any-compacted (or any-compacted queued-compacted))
          (continue)))
      (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw store^.handle)]
        (when (not basis-ok)
          (if (= basis-error "sqlite DB has no Vev index roots")
            (return step-count any-compacted true "")
            (return step-count any-compacted false basis-error)))
        (let [[eavt-rows eavt-needed eavt-ok eavt-error] (sqlite-latest-index-root-next-compaction-row-count store^.handle ":eavt")]
          (when (not eavt-ok)
            (return step-count any-compacted false eavt-error))
          (when (and eavt-needed (<= eavt-rows row-budget))
            (let [[compacted compact-ok compact-error] (sqlite-maintain-latest-index-root-step! store^.handle basis ":eavt")]
              (when (not compact-ok)
                (return step-count any-compacted false compact-error))
              (set! step-count (+ step-count 1))
              (set! any-compacted (or any-compacted compacted))
              (continue))))
        (let [[aevt-rows aevt-needed aevt-ok aevt-error] (sqlite-latest-index-root-next-compaction-row-count store^.handle ":aevt")]
          (when (not aevt-ok)
            (return step-count any-compacted false aevt-error))
          (when (and aevt-needed (<= aevt-rows row-budget))
            (let [[compacted compact-ok compact-error] (sqlite-maintain-latest-index-root-step! store^.handle basis ":aevt")]
              (when (not compact-ok)
                (return step-count any-compacted false compact-error))
              (set! step-count (+ step-count 1))
              (set! any-compacted (or any-compacted compacted))
              (continue))))
        (let [[avet-rows avet-needed avet-ok avet-error] (sqlite-latest-index-root-next-compaction-row-count store^.handle ":avet")]
          (when (not avet-ok)
            (return step-count any-compacted false avet-error))
          (when (and avet-needed (<= avet-rows row-budget))
            (let [[compacted compact-ok compact-error] (sqlite-maintain-latest-index-root-step! store^.handle basis ":avet")]
              (when (not compact-ok)
                (return step-count any-compacted false compact-error))
              (set! step-count (+ step-count 1))
              (set! any-compacted (or any-compacted compacted))
              (continue))))
        (let [[vaet-rows vaet-needed vaet-ok vaet-error] (sqlite-latest-index-root-next-compaction-row-count store^.handle ":vaet")]
          (when (not vaet-ok)
            (return step-count any-compacted false vaet-error))
          (when (and vaet-needed (<= vaet-rows row-budget))
            (let [[compacted compact-ok compact-error] (sqlite-maintain-latest-index-root-step! store^.handle basis ":vaet")]
              (when (not compact-ok)
                (return step-count any-compacted false compact-error))
              (set! step-count (+ step-count 1))
              (set! any-compacted (or any-compacted compacted))
              (continue))))
        (return step-count any-compacted true "")))
    (return step-count any-compacted true "")))

(defn sqlite-conn-maintain-indexes-to-target! [store: ^SQLite-Conn, max-steps: int, target-pending: u64] -> [steps: int, compacted: bool, pending: u64, ok: bool, error: string]
  (when store^.source-only
    (return 0 false 0 false "SQLite source connection is read-only; open a writable SQLite connection to maintain indexes"))
  (let [[initial-pending initial-ok initial-error] (sqlite-index-maintenance-count-raw store^.handle)]
    (when (not initial-ok)
      (return 0 false 0 false initial-error))
    (when (<= initial-pending target-pending)
      (return 0 false initial-pending true ""))
    (let [[drain-steps drain-compacted drain-ok drain-error] (sqlite-conn-maintain-indexes! store max-steps)]
      (when (not drain-ok)
        (return drain-steps drain-compacted initial-pending false drain-error))
      (let [[remaining remaining-ok remaining-error] (sqlite-index-maintenance-count-raw store^.handle)]
        (return drain-steps drain-compacted remaining remaining-ok remaining-error)))))

(defn sqlite-conn-maintain-indexes-to-target-foreground! [store: ^SQLite-Conn, max-steps: int, target-pending: u64, row-budget: int] -> [steps: int, compacted: bool, pending: u64, ok: bool, error: string]
  (when store^.source-only
    (return 0 false 0 false "SQLite source connection is read-only; open a writable SQLite connection to maintain indexes"))
  (let [[initial-pending initial-ok initial-error] (sqlite-index-maintenance-count-raw store^.handle)]
    (when (not initial-ok)
      (return 0 false 0 false initial-error))
    (let [[drain-steps drain-compacted drain-ok drain-error] (sqlite-conn-maintain-indexes-foreground! store max-steps row-budget)]
      (when (not drain-ok)
        (return drain-steps drain-compacted initial-pending false drain-error))
      (let [[remaining remaining-ok remaining-error] (sqlite-index-maintenance-count-raw store^.handle)]
        (return drain-steps drain-compacted remaining remaining-ok remaining-error)))))

(defn sqlite-conn-latest-index-entry-page [store: ^SQLite-Conn, index-name: string, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (when (< offset 0)
    (return (make [dynamic]int) false "sqlite index page offset was negative"))
  (when (<= limit 0)
    (return (make [dynamic]int) true ""))
  (let [[text base-offset loaded-ok loaded-error] (sqlite-latest-index-entries-page-text-raw store^.handle index-name (i64 offset) (i64 limit))]
    (when (not loaded-ok)
      (return (make [dynamic]int) false loaded-error))
    (defer (delete text))
    (parse-index-entries-page-text-window text base-offset offset limit)))

(defn sqlite-conn-datom-at-log-index [store: ^SQLite-Conn, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw store^.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
    (let [[value read-error read-ok] (edn.try-read text)]
      (when (not read-ok)
        (return (Datom {}) false read-error.message))
      (let [doc (edn-doc-from-data value)]
        (defer (delete doc.nodes))
        (datom-from-edn-node doc doc.root)))))

(defn sqlite-latest-index-entry-pages-count-handle [handle: rawptr, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (when (<= page-size 0)
    (return 0 false "sqlite index page size must be positive"))
  (let [[_ row-count rows-ok rows-error] (sqlite-latest-index-chunk-row-count-raw handle index-name)]
    (when (not rows-ok)
      (return 0 false rows-error))
    (let [total 0
          offset 0
          expected (int row-count)]
      (while (< offset expected)
        (let [[text base-offset page-ok page-error] (sqlite-latest-index-entries-page-text-raw handle index-name (i64 offset) (i64 page-size))]
          (when (not page-ok)
            (return total false page-error))
          (let [[window window-ok window-error] (parse-index-entries-page-text-window text base-offset offset page-size)]
            (when (not window-ok)
              (delete text)
              (return total false window-error))
            (set! total (+ total (count window)))
            (delete window))
          (delete text))
        (set! offset (+ offset page-size)))
      (return total true ""))))

(defn sqlite-conn-latest-index-entry-pages-count [store: ^SQLite-Conn, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (sqlite-latest-index-entry-pages-count-handle store^.handle index-name page-size))

(defn sqlite-storage-architecture [path: string] -> [architecture: string, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return "" false open-error))
    (let [[value value-ok value-error] (sqlite-meta-value-raw handle "storage-architecture")]
      (sqlite-close-live-raw handle)
      (return value value-ok value-error))))

(defn sqlite-index-root-count [path: string] -> [root-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-root-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-root-page-count [path: string] -> [page-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-root-page-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-chunk-count [path: string] -> [chunk-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-chunk-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-entry-backed-index-chunk-count-for-test [path: string] -> [chunk-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-entry-backed-index-chunk-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-maintenance-count [path: string] -> [maintenance-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-maintenance-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-run-manifest-count [path: string] -> [manifest-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-run-manifest-count-raw handle)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-index-run-manifest-run-count-for-test [path: string, manifest-id: u64] -> [run-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[count count-ok count-error] (sqlite-index-run-manifest-run-count-raw handle manifest-id)]
      (sqlite-close-live-raw handle)
      (return count count-ok count-error))))

(defn sqlite-create-index-run-manifest-for-test [path: string, index-name: string] -> [manifest-id: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[basis rows root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (when (not root-ok)
        (sqlite-close-live-raw handle)
        (return 0 false root-error))
      (let [[created-manifest-id manifest-ok manifest-error] (sqlite-insert-index-run-manifest-raw handle index-name basis root rows 1 basis)]
        (when (not manifest-ok)
          (sqlite-close-live-raw handle)
          (return 0 false manifest-error))
        (let [[run-ok run-error] (sqlite-insert-index-run-manifest-run-raw handle created-manifest-id 0 root rows)]
          (when (not run-ok)
            (sqlite-close-live-raw handle)
            (return 0 false run-error))
          (let [[entity-range-ok entity-range-error] (sqlite-insert-index-run-manifest-entity-attr-ranges-from-root! handle created-manifest-id 0 index-name root)]
            (when (not entity-range-ok)
              (sqlite-close-live-raw handle)
              (return 0 false entity-range-error)))
          (if (sqlite-index-name-has-contiguous-attrs? index-name)
            (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-ranges-from-root! handle created-manifest-id 0 root (int rows))]
              (sqlite-close-live-raw handle)
              (return created-manifest-id range-ok range-error))
            (do
              (sqlite-close-live-raw handle)
              (return created-manifest-id true ""))))))))

(defn sqlite-latest-index-root-basis [path: string] -> [basis-tx: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
      (sqlite-close-live-raw handle)
      (return basis basis-ok basis-error))))

(defn sqlite-latest-index-chunk-row-count [path: string, index-name: string] -> [basis-tx: u64, row-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 0 false open-error))
    (let [[basis rows row-ok row-error] (sqlite-latest-index-chunk-row-count-raw handle index-name)]
      (sqlite-close-live-raw handle)
      (return basis rows row-ok row-error))))

(defn sqlite-latest-index-root-id [path: string, index-name: string] -> [root-id: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (sqlite-close-live-raw handle)
      (return root root-ok root-error))))

(defn sqlite-latest-index-root-child-count [path: string, index-name: string] -> [child-count: u64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (when (not root-ok)
        (sqlite-close-live-raw handle)
        (return 0 false root-error))
      (let [[children children-ok children-error] (sqlite-index-chunk-child-count-raw handle root)]
        (sqlite-close-live-raw handle)
        (return (u64 children) children-ok children-error)))))

(defn sqlite-latest-index-root-level [path: string, index-name: string] -> [level: i64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (when (not root-ok)
        (sqlite-close-live-raw handle)
        (return 0 false root-error))
      (let [[root-level root-level-ok root-level-error] (sqlite-index-chunk-level-raw handle root)]
        (sqlite-close-live-raw handle)
        (return root-level root-level-ok root-level-error)))))

(defn sqlite-latest-index-root-tree-stats [path: string, index-name: string] -> [node-count: u64, leaf-count: u64, max-level: i64, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 0 0 false open-error))
    (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (when (not root-ok)
        (sqlite-close-live-raw handle)
        (return 0 0 0 false root-error))
      (let [[nodes leaves level stats-ok stats-error] (sqlite-index-tree-stats-raw handle root)]
        (sqlite-close-live-raw handle)
        (return nodes leaves level stats-ok stats-error)))))

(defn sqlite-conn-latest-index-root-tree-stats [store: ^SQLite-Conn, index-name: string] -> [node-count: u64, leaf-count: u64, max-level: i64, ok: bool, error: string]
  (when (= store nil)
    (return 0 0 0 false "sqlite store was nil"))
  (when (= store^.handle nil)
    (return 0 0 0 false "sqlite store has no live handle"))
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw store^.handle index-name)]
    (when (not root-ok)
      (return 0 0 0 false root-error))
    (sqlite-index-tree-stats-raw store^.handle root)))

(defn sqlite-conn-latest-index-root-child-count [store: ^SQLite-Conn, index-name: string] -> [child-count: u64, ok: bool, error: string]
  (when (= store nil)
    (return 0 false "sqlite store was nil"))
  (when (= store^.handle nil)
    (return 0 false "sqlite store has no live handle"))
  (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw store^.handle index-name)]
    (when (not root-ok)
      (return 0 false root-error))
    (let [[children children-ok children-error] (sqlite-index-chunk-child-count-raw store^.handle root)]
      (return (u64 children) children-ok children-error))))

(defn sqlite-clear-latest-index-root-child-count-for-test [path: string, index-name: string] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[_ _ root root-ok root-error] (sqlite-latest-index-root-chunk-info-raw handle index-name)]
      (when (not root-ok)
        (sqlite-close-live-raw handle)
        (return false root-error))
      (let [[clear-ok clear-error] (sqlite-clear-index-chunk-child-count-raw handle root)]
        (sqlite-close-live-raw handle)
        (return clear-ok clear-error)))))

(defn sqlite-clear-latest-index-root-wide-columns-for-test [path: string] -> [ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return false open-error))
    (let [[clear-ok clear-error] (sqlite-clear-latest-index-root-wide-columns-raw handle)]
      (sqlite-close-live-raw handle)
      (return clear-ok clear-error))))

(defn sqlite-latest-index-entries [path: string, index-name: string] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (make [dynamic]int) false open-error))
    (let [[cursor cursor-ok cursor-error] (sqlite-open-index-cursor-handle handle index-name sqlite-index-leaf-chunk-size)]
      (when (not cursor-ok)
        (sqlite-close-live-raw handle)
        (return (make [dynamic]int) false cursor-error))
      (let [out (make [dynamic]int 0 (sqlite-index-cursor-count cursor))]
        (for [index (arr.range 0 (sqlite-index-cursor-count cursor))]
          (let [[entry entry-ok entry-error] (sqlite-index-cursor-at (addr cursor) index)]
            (when (not entry-ok)
              (when (sqlite-index-cursor-stream-ended? (addr cursor) entry-error)
                (close-sqlite-index-cursor! (addr cursor))
                (sqlite-close-live-raw handle)
                (return out true ""))
              (delete out)
              (close-sqlite-index-cursor! (addr cursor))
              (sqlite-close-live-raw handle)
              (return (make [dynamic]int) false entry-error))
            (arr.push! out entry)))
        (close-sqlite-index-cursor! (addr cursor))
        (sqlite-close-live-raw handle)
        (return out true "")))))

(defn sqlite-latest-index-entry-page [path: string, index-name: string, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (when (< offset 0)
    (return (make [dynamic]int) false "sqlite index page offset was negative"))
  (when (<= limit 0)
    (return (make [dynamic]int) true ""))
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (make [dynamic]int) false open-error))
    (let [[text base-offset loaded-ok loaded-error] (sqlite-latest-index-entries-page-text-raw handle index-name (i64 offset) (i64 limit))]
      (sqlite-close-live-raw handle)
      (when (not loaded-ok)
        (return (make [dynamic]int) false loaded-error))
      (defer (delete text))
      (parse-index-entries-page-text-window text base-offset offset limit))))

(defn sqlite-latest-index-entry-pages-count [path: string, index-name: string, page-size: int] -> [loaded-count: int, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return 0 false open-error))
    (let [[total total-ok total-error] (sqlite-latest-index-entry-pages-count-handle handle index-name page-size)]
      (sqlite-close-live-raw handle)
      (return total total-ok total-error))))

(defn sqlite-open-index-cursor-handle [handle: rawptr, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Cursor {}) false "sqlite index page size must be positive"))
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return (SQLite-Index-Cursor {}) false basis-error))
    (sqlite-open-index-cursor-handle-at-basis handle index-name basis page-size)))

(defn sqlite-open-index-cursor-handle-at-basis [handle: rawptr, index-name: string, basis-tx: u64, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Cursor {}) false "sqlite index page size must be positive"))
  (let [[rows root-id manifest-id manifest-run-count first-key root-level root-child-count info-ok info-error] (sqlite-index-root-chunk-info-at-basis-raw handle index-name basis-tx)]
    (when (not info-ok)
      (return (SQLite-Index-Cursor {}) false info-error))
    (let [order-text (if (= index-name ":eavt")
                       (string-owned "eavt")
                       (if (= index-name ":aevt")
                         (string-owned "aevt")
                         (if (= index-name ":avet")
                           (string-owned "avet")
                           (string-owned "vaet"))))
          root-is-merge (sqlite-index-merge-root-key? first-key)
          root-is-manifest (> manifest-id 0)
          datom-stmt: rawptr nil]
      (when (or root-is-merge root-is-manifest)
        (let [[prepared prepared-ok prepared-error] (sqlite-prepare-datom-by-log-index-raw handle)]
          (when (not prepared-ok)
            (delete first-key)
            (delete order-text)
            (return (SQLite-Index-Cursor {}) false prepared-error))
          (set! datom-stmt prepared)))
    (return (SQLite-Index-Cursor {handle: handle
                                  owns-handle: false
                                  index-name: (string-owned index-name)
                                  basis-tx: basis-tx
                                  root-id: root-id
                                  manifest-id: manifest-id
                                  manifest-run-count: manifest-run-count
                                  root-first-key: first-key
                                  root-is-merge: root-is-merge
                                  root-is-manifest: root-is-manifest
                                  root-level: root-level
                                  root-child-count: root-child-count
                                  order-text: order-text
                                  datom-stmt: datom-stmt
                                  entry-page-stmt: nil
                                  page-size: page-size
                                  row-count: (int rows)
                                  page: (sqlite-loaded-index-page-empty 0)
                                  page-cache: (sqlite-index-page-cache-empty)
                                  merge-ready: false
                                  merge-next-output: 0
                                  merge-roots: (make [dynamic]u64)
                                  merge-counts: (make [dynamic]int)
                                  merge-positions: (make [dynamic]int)
                                  merge-current-entries: (make [dynamic]int)
                                  merge-current-datoms: (make [dynamic]Datom)
                                  merge-has-current: (make [dynamic]bool)
                                  merge-loaded-pages: (make [dynamic]SQLite-Loaded-Index-Page)
                                  merge-loaded-page-valid: (make [dynamic]bool)
                                  merge-page0: (make [dynamic]int)
                                  merge-page-start0: -1
                                  merge-page-end0: -1
                                  merge-page1: (make [dynamic]int)
                                  merge-page-start1: -1
                                  merge-page-end1: -1
                                  merge-page2: (make [dynamic]int)
                                  merge-page-start2: -1
                                  merge-page-end2: -1
                                  merge-page3: (make [dynamic]int)
                                  merge-page-start3: -1
                                  merge-page-end3: -1
                                  direct-children-ready: false
                                  direct-child-roots: (make [dynamic]u64)
                                  direct-child-counts: (make [dynamic]int)
                                  entry-runs-ready: false
                                  entry-run-roots: (make [dynamic]u64)
                                  entry-run-bases: (make [dynamic]int)
                                  entry-run-counts: (make [dynamic]int)
                                  entry-run-entry-payloads: (make [dynamic]bool)})
            true
            ""))))

(defn sqlite-open-index-cursor-handle-at-root-page [handle: rawptr, index-name: string, basis-tx: u64, root-page: SQLite-Index-Root-Page, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Cursor {}) false "sqlite index page size must be positive"))
  (let [[rows first-key root-level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root-page.root-id)]
    (when (not info-ok)
      (return (SQLite-Index-Cursor {}) false info-error))
    (let [[root-child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root-page.root-id)]
      (when (not child-count-ok)
        (delete first-key)
        (return (SQLite-Index-Cursor {}) false child-count-error))
      (let [order-text (if (= index-name ":eavt")
                         (string-owned "eavt")
                         (if (= index-name ":aevt")
                           (string-owned "aevt")
                           (if (= index-name ":avet")
                             (string-owned "avet")
                             (string-owned "vaet"))))
            root-is-merge (sqlite-index-merge-root-key? first-key)
            root-is-manifest (> root-page.manifest-id 0)
            row-count rows
            manifest-run-count: u64 0
            datom-stmt: rawptr nil]
        (when root-is-manifest
          (let [[_parent-manifest-id _base-root manifest-row-count run-count manifest-ok manifest-error] (sqlite-index-run-manifest-info-raw handle root-page.manifest-id)]
            (discard _parent-manifest-id)
            (discard _base-root)
            (when (not manifest-ok)
              (delete first-key)
              (delete order-text)
              (return (SQLite-Index-Cursor {}) false manifest-error))
            (set! row-count manifest-row-count)
            (set! manifest-run-count run-count)))
        (when (or root-is-merge root-is-manifest)
          (let [[prepared prepared-ok prepared-error] (sqlite-prepare-datom-by-log-index-raw handle)]
            (when (not prepared-ok)
              (delete first-key)
              (delete order-text)
              (return (SQLite-Index-Cursor {}) false prepared-error))
            (set! datom-stmt prepared)))
        (return (SQLite-Index-Cursor {handle: handle
                                      owns-handle: false
                                      index-name: (string-owned index-name)
                                      basis-tx: basis-tx
                                      root-id: root-page.root-id
                                      manifest-id: root-page.manifest-id
                                      manifest-run-count: manifest-run-count
                                      root-first-key: first-key
                                      root-is-merge: root-is-merge
                                      root-is-manifest: root-is-manifest
                                      root-level: root-level
                                      root-child-count: root-child-count
                                      order-text: order-text
                                      datom-stmt: datom-stmt
                                      entry-page-stmt: nil
                                      page-size: page-size
                                      row-count: (int row-count)
                                      page: (sqlite-loaded-index-page-empty 0)
                                      page-cache: (sqlite-index-page-cache-empty)
                                      merge-ready: false
                                      merge-next-output: 0
                                      merge-roots: (make [dynamic]u64)
                                      merge-counts: (make [dynamic]int)
                                      merge-positions: (make [dynamic]int)
                                      merge-current-entries: (make [dynamic]int)
                                      merge-current-datoms: (make [dynamic]Datom)
                                      merge-has-current: (make [dynamic]bool)
                                      merge-loaded-pages: (make [dynamic]SQLite-Loaded-Index-Page)
                                      merge-loaded-page-valid: (make [dynamic]bool)
                                      merge-page0: (make [dynamic]int)
                                      merge-page-start0: -1
                                      merge-page-end0: -1
                                      merge-page1: (make [dynamic]int)
                                      merge-page-start1: -1
                                      merge-page-end1: -1
                                      merge-page2: (make [dynamic]int)
                                      merge-page-start2: -1
                                      merge-page-end2: -1
                                      merge-page3: (make [dynamic]int)
                                      merge-page-start3: -1
                                      merge-page-end3: -1
                                      direct-children-ready: false
                                      direct-child-roots: (make [dynamic]u64)
                                      direct-child-counts: (make [dynamic]int)
                                      entry-runs-ready: false
                                      entry-run-roots: (make [dynamic]u64)
                                      entry-run-bases: (make [dynamic]int)
                                      entry-run-counts: (make [dynamic]int)
                                      entry-run-entry-payloads: (make [dynamic]bool)})
                true
                "")))))

(defn sqlite-conn-open-index-cursor [store: ^SQLite-Conn, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (sqlite-open-index-cursor-handle store^.handle index-name page-size))

(defn sqlite-open-index-cursor [path: string, index-name: string, page-size: int] -> [out-cursor: SQLite-Index-Cursor, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-Index-Cursor {}) false open-error))
    (let [[cursor cursor-ok cursor-error] (sqlite-open-index-cursor-handle handle index-name page-size)]
      (when (not cursor-ok)
        (sqlite-close-live-raw handle)
        (return cursor false cursor-error))
      (set! cursor.owns-handle true)
      (return cursor true ""))))

(defn sqlite-index-cursor-count [cursor: SQLite-Index-Cursor] -> int
  cursor.row-count)

(defn sqlite-index-cursor-use-page-cache! [cursor: ^SQLite-Index-Cursor, cache: SQLite-Index-Page-Cache]
  (release-sqlite-index-page-cache! cursor^.page-cache)
  (set! cursor^.page-cache (retain-sqlite-index-page-cache cache)))

(defn sqlite-index-cursor-stream-ended? [cursor: ^SQLite-Index-Cursor, error: string] -> bool
  (or (and (or cursor^.root-is-merge cursor^.root-is-manifest)
           (or (= error "sqlite index cursor page did not contain requested position")
               (= error "sqlite merge root page ended before expected row count")))
      (and (= error "sqlite index cursor page did not contain requested position")
           (< cursor^.page.end cursor^.row-count)
           (= cursor^.page.end (+ cursor^.page.start (count cursor^.page.entries))))))

(defn sqlite-index-cursor-ensure-direct-children! [cursor: ^SQLite-Index-Cursor] -> [ok: bool, error: string]
  (when cursor^.direct-children-ready
    (return true ""))
  (delete cursor^.direct-child-roots)
  (delete cursor^.direct-child-counts)
  (let [[roots counts children-ok children-error] (sqlite-index-child-chunks-with-counts-raw cursor^.handle cursor^.root-id)]
    (when (not children-ok)
      (delete roots)
      (delete counts)
      (set! cursor^.direct-child-roots (make [dynamic]u64))
      (set! cursor^.direct-child-counts (make [dynamic]int))
      (set! cursor^.direct-children-ready false)
      (return false children-error))
    (set! cursor^.direct-child-roots roots)
    (set! cursor^.direct-child-counts counts)
    (set! cursor^.direct-children-ready true)
    (return true "")))

(defn sqlite-index-cursor-ensure-entry-runs! [cursor: ^SQLite-Index-Cursor] -> [ok: bool, error: string]
  (when cursor^.entry-runs-ready
    (return true ""))
  (delete cursor^.entry-run-roots)
  (delete cursor^.entry-run-bases)
  (delete cursor^.entry-run-counts)
  (delete cursor^.entry-run-entry-payloads)
  (let [[roots bases counts entry-payloads runs-ok runs-error] (sqlite-index-entry-runs-for-root-raw cursor^.handle cursor^.root-id)]
    (when (not runs-ok)
      (delete roots)
      (delete bases)
      (delete counts)
      (delete entry-payloads)
      (set! cursor^.entry-run-roots (make [dynamic]u64))
      (set! cursor^.entry-run-bases (make [dynamic]int))
      (set! cursor^.entry-run-counts (make [dynamic]int))
      (set! cursor^.entry-run-entry-payloads (make [dynamic]bool))
      (set! cursor^.entry-runs-ready false)
      (return false runs-error))
    (set! cursor^.entry-run-roots roots)
    (set! cursor^.entry-run-bases bases)
    (set! cursor^.entry-run-counts counts)
    (set! cursor^.entry-run-entry-payloads entry-payloads)
    (set! cursor^.entry-runs-ready true)
    (return true "")))

(defn sqlite-index-cursor-entry-run-start-index [cursor: ^SQLite-Index-Cursor, page-start: int] -> int
  (let [lo 0
        hi (count cursor^.entry-run-roots)]
    (while (< lo hi)
      (let [mid (+ lo (/ (- hi lo) 2))
            run-end (+ cursor^.entry-run-bases[mid] cursor^.entry-run-counts[mid])]
        (if (<= run-end page-start)
          (set! lo (+ mid 1))
          (set! hi mid))))
    lo))

(defn sqlite-index-cursor-ensure-entry-page-stmt! [cursor: ^SQLite-Index-Cursor] -> [ok: bool, error: string]
  (when (not (= cursor^.entry-page-stmt nil))
    (return true ""))
  (let [[stmt stmt-ok stmt-error] (sqlite-prepare-index-chunk-entries-page-raw cursor^.handle)]
    (when (not stmt-ok)
      (return false stmt-error))
    (set! cursor^.entry-page-stmt stmt)
    (return true "")))

(defn sqlite-index-cursor-load-entry-run-window [cursor: ^SQLite-Index-Cursor, page-start: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [page-end (min (+ page-start cursor^.page-size) cursor^.row-count)
        [runs-ok runs-error] (sqlite-index-cursor-ensure-entry-runs! cursor)]
    (when (not runs-ok)
      (return (make [dynamic]int) false runs-error))
    (let [selected-roots (make [dynamic]u64) :defer
          selected-starts (make [dynamic]int) :defer
          selected-limits (make [dynamic]int) :defer
          selected-total 0
          run-index (sqlite-index-cursor-entry-run-start-index cursor page-start)]
      (while (< run-index (count cursor^.entry-run-roots))
        (let [run-base cursor^.entry-run-bases[run-index]
              run-count cursor^.entry-run-counts[run-index]
              run-end (+ run-base run-count)]
          (when (>= run-base page-end)
            (break))
          (when (and (< page-start run-end)
                     (> page-end run-base))
            (when (not cursor^.entry-run-entry-payloads[run-index])
              (return (make [dynamic]int) false "sqlite index entry run window included inline payload"))
            (let [local-start (max 0 (- page-start run-base))
                  local-end (min run-count (- page-end run-base))
                  local-limit (- local-end local-start)]
              (arr.push! selected-roots cursor^.entry-run-roots[run-index])
              (arr.push! selected-starts local-start)
              (arr.push! selected-limits local-limit)
              (set! selected-total (+ selected-total local-limit)))))
          (set! run-index (+ run-index 1)))
      (when (= selected-total 0)
        (return (make [dynamic]int) true ""))
      (when (= (count selected-roots) 1)
        (let [[stmt-ok stmt-error] (sqlite-index-cursor-ensure-entry-page-stmt! cursor)]
          (when (not stmt-ok)
            (return (make [dynamic]int) false stmt-error))
          (return (sqlite-step-prepared-index-chunk-entries-page-raw cursor^.handle cursor^.entry-page-stmt selected-roots[0] (i64 selected-starts[0]) (i64 selected-limits[0])))))
      (let [[loaded-entries loaded-ok loaded-error] (sqlite-index-chunk-entries-windows-raw cursor^.handle (slice selected-roots 0) (slice selected-starts 0) (slice selected-limits 0))]
        (return loaded-entries loaded-ok loaded-error)))))

(defn sqlite-index-cursor-load-direct-root-window [cursor: ^SQLite-Index-Cursor, page-start: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [out (make [dynamic]int 0 cursor^.page-size)
        page-end (min (+ page-start cursor^.page-size) cursor^.row-count)
        [entry-run-window entry-run-ok _entry-run-error] (sqlite-index-cursor-load-entry-run-window cursor page-start)]
    (when entry-run-ok
      (delete out)
      (return entry-run-window true ""))
    (delete entry-run-window)
    (let [[children-ok children-error] (sqlite-index-cursor-ensure-direct-children! cursor)]
    (when (not children-ok)
      (delete out)
      (return (make [dynamic]int) false children-error))
    (let [selected-roots (make [dynamic]u64) :defer
          selected-starts (make [dynamic]int) :defer
          selected-limits (make [dynamic]int) :defer
          selected-total 0
          child-base 0
          covers-payload false]
      (for [child-root child-index cursor^.direct-child-roots]
        (let [child-row-count cursor^.direct-child-counts[child-index]
              child-start child-base
              child-end (+ child-base child-row-count)]
          (when (and (< page-start child-end)
                     (> page-end child-start))
            (let [local-start (max 0 (- page-start child-start))
                  local-end (min child-row-count (- page-end child-start))
                  local-limit (- local-end local-start)]
              (arr.push! selected-roots child-root)
              (arr.push! selected-starts local-start)
              (arr.push! selected-limits local-limit)
              (set! selected-total (+ selected-total local-limit))))
          (set! child-base child-end)))
      (when (< child-base cursor^.row-count)
        (let [payload-start child-base
              payload-end cursor^.row-count]
          (when (and (< page-start payload-end)
                     (> page-end payload-start))
            (set! covers-payload true))))
      (when (and (not covers-payload)
                 (> selected-total 0))
        (let [[batched batched-ok _batched-error] (sqlite-index-chunk-entries-windows-raw cursor^.handle (slice selected-roots 0) (slice selected-starts 0) (slice selected-limits 0))]
          (when batched-ok
            (delete out)
            (return batched true ""))
          (delete batched))))
    (let [child-base 0]
      (for [child-root child-index cursor^.direct-child-roots]
        (let [child-row-count cursor^.direct-child-counts[child-index]
              child-start child-base
              child-end (+ child-base child-row-count)]
          (when (and (< page-start child-end)
                     (> page-end child-start))
            (let [local-start (max 0 (- page-start child-start))
                  local-end (min child-row-count (- page-end child-start))
                  [child-ok child-error] (sqlite-index-root-ordered-window-direct-into! (addr out) cursor^.handle child-root local-start (- local-end local-start))]
              (when (not child-ok)
                (delete out)
                (return (make [dynamic]int) false child-error))))
          (set! child-base child-end)))
      (when (< child-base cursor^.row-count)
        (let [payload-start child-base
              payload-end cursor^.row-count]
          (when (and (< page-start payload-end)
                     (> page-end payload-start))
            (let [local-start (max 0 (- page-start payload-start))
                  local-end (min (- payload-end payload-start) (- page-end payload-start))
                  [payload-ok payload-error] (sqlite-index-chunk-append-payload-window! (addr out) cursor^.handle cursor^.root-id local-start (- local-end local-start))]
              (when (not payload-ok)
                (delete out)
                (return (make [dynamic]int) false payload-error)))))))
    (return out true ""))))

(defn sqlite-index-chunk-append-payload-window! [out: ^[dynamic]int, handle: rawptr, chunk-id: u64, offset: int, limit: int] -> [ok: bool, error: string]
  (when (<= limit 0)
    (return true ""))
  (let [[payload payload-ok payload-error] (sqlite-index-chunk-payload-text-raw handle chunk-id)]
    (when (not payload-ok)
      (return false payload-error))
    (defer (delete payload))
    (when (= payload "[]")
      (return true ""))
    (if (= payload ":entries")
      (let [[entries entries-ok entries-error] (sqlite-index-chunk-entries-page-raw handle chunk-id (i64 offset) (i64 limit))]
        (when (not entries-ok)
          (return false entries-error))
        (for [entry entries]
          (arr.push! out^ entry))
        (delete entries)
        (return true ""))
      (let [[entries entries-ok entries-error] (parse-index-entries-text-window payload offset limit)]
        (when (not entries-ok)
          (return false entries-error))
        (for [entry entries]
          (arr.push! out^ entry))
        (delete entries)
        (return true "")))))

(defn sqlite-index-root-ordered-window-direct-into! [out: ^[dynamic]int, handle: rawptr, root-id: u64, offset: int, limit: int] -> [ok: bool, error: string]
  (when (<= limit 0)
    (return true ""))
  (let [[row-count first-key level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root-id)]
    (when (not info-ok)
      (return false info-error))
    (defer (delete first-key))
    (when (< offset 0)
      (return false "sqlite index direct window offset was negative"))
    (when (>= offset (int row-count))
      (return true ""))
    (let [clamped-limit (min limit (- (int row-count) offset))]
      (when (= level 0)
        (return (sqlite-index-chunk-append-payload-window! out handle root-id offset clamped-limit)))
      (let [[child-roots child-counts children-ok children-error] (sqlite-index-child-chunks-with-counts-raw handle root-id)]
        (defer (delete child-roots))
        (defer (delete child-counts))
        (when (not children-ok)
          (return false children-error))
        (let [remaining-start offset
              remaining-end (+ offset clamped-limit)
              child-base 0]
          (for [child-root child-index child-roots]
            (let [child-row-count child-counts[child-index]
                  child-start child-base
                  child-end (+ child-base child-row-count)]
              (when (and (< remaining-start child-end)
                         (> remaining-end child-start))
                (let [local-start (max 0 (- remaining-start child-start))
                      local-end (min child-row-count (- remaining-end child-start))
                      [child-window-ok child-window-error] (sqlite-index-root-ordered-window-direct-into! out handle child-root local-start (- local-end local-start))]
                  (when (not child-window-ok)
                    (return false child-window-error))))
              (set! child-base child-end)))
          (when (< child-base (int row-count))
            (let [payload-start child-base
                  payload-end (int row-count)]
              (when (and (< remaining-start payload-end)
                         (> remaining-end payload-start))
                (let [local-start (max 0 (- remaining-start payload-start))
                      local-end (min (- payload-end payload-start) (- remaining-end payload-start))
                      [payload-ok payload-error] (sqlite-index-chunk-append-payload-window! out handle root-id local-start (- local-end local-start))]
                  (when (not payload-ok)
                    (return false payload-error)))))))
        (return true "")))))

(defn sqlite-index-root-ordered-window-direct [handle: rawptr, root-id: u64, offset: int, limit: int] -> [entries: [dynamic]int, ok: bool, error: string]
  (let [out (make [dynamic]int 0 limit)
        [append-ok append-error] (sqlite-index-root-ordered-window-direct-into! (addr out) handle root-id offset limit)]
    (if append-ok
      (return out true "")
      (do
        (delete out)
        (return (make [dynamic]int) false append-error)))))

(defn sqlite-index-root-ordered-window [handle: rawptr, root-id: u64, offset: int, limit: int] -> [entries: [dynamic]int, base-offset: int, ok: bool, error: string]
  (let [[_row-count _first-key level info-ok _info-error] (sqlite-index-chunk-info-by-id-raw handle root-id)]
    (when info-ok
      (delete _first-key)
      (when (= level 0)
        (let [[payload payload-ok _payload-error] (sqlite-index-chunk-payload-text-raw handle root-id)]
          (when payload-ok
            (defer (delete payload))
            (when (= payload ":entries")
              (let [[entries entries-ok entries-error] (sqlite-index-chunk-entries-page-raw handle root-id (i64 offset) (i64 limit))]
                (return entries offset entries-ok entries-error)))))))
    (when info-ok
      (let [[direct direct-ok _direct-error] (sqlite-index-root-ordered-window-direct handle root-id offset limit)]
        (when direct-ok
          (return direct offset true ""))
        (delete direct))))
  (let [[text raw-base loaded-ok loaded-error] (sqlite-index-entries-page-text-for-root-raw handle root-id (i64 offset) (i64 limit))]
    (when (not loaded-ok)
      (return (make [dynamic]int) 0 false loaded-error))
    (defer (delete text))
    (let [[window window-ok window-error] (parse-index-entries-page-text-window text raw-base offset limit)]
      (if window-ok
        (return window offset true "")
        (return window 0 false window-error)))))

(defn sqlite-index-root-ordered-entry-at [handle: rawptr, root-id: u64, index: int] -> [entry: int, ok: bool, error: string]
  (let [[page base page-ok page-error] (sqlite-index-root-ordered-window handle root-id index 1)]
    (when (not page-ok)
      (return 0 false page-error))
    (defer (delete page))
    (let [offset (- index base)]
      (when (or (< offset 0)
                (>= offset (count page)))
        (return 0 false "sqlite index ordered root entry was outside loaded page"))
      (return page[offset] true ""))))

(defn sqlite-index-root-ordered-entry-at-cached [handle: rawptr, root-id: u64, index: int, row-count: int, page-size: int, page: ^[dynamic]int, page-start: ^int, page-end: ^int] -> [entry: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index row-count))
    (return 0 false "sqlite index ordered root cached entry position out of range"))
  (when (not (and (>= index page-start^)
                  (< index page-end^)))
    (let [next-page-start (* (/ index page-size) page-size)
          [window _base page-ok page-error] (sqlite-index-root-ordered-window handle root-id next-page-start page-size)]
      (when (not page-ok)
        (return 0 false page-error))
      (delete page^)
      (set! page^ window)
      (set! page-start^ next-page-start)
      (set! page-end^ (min (+ next-page-start (count window)) row-count))))
  (let [offset (- index page-start^)]
    (when (or (< offset 0)
              (>= offset (count page^)))
      (return 0 false "sqlite index ordered root cached entry was outside loaded page"))
    (return page^[offset] true "")))

(defn sqlite-index-root-ordered-entry-at-shared-cache [handle: rawptr, root-id: u64, index: int, row-count: int, page-size: int, page-cache: ^SQLite-Index-Page-Cache, page: ^[dynamic]int, page-start: ^int, page-end: ^int] -> [entry: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index row-count))
    (return 0 false "sqlite index ordered root shared-cache entry position out of range"))
  (when (not (and (>= index page-start^)
                  (< index page-end^)))
    (let [next-page-start (* (/ index page-size) page-size)
          [cached-page cached?] (sqlite-index-page-cache-find-retained page-cache^ root-id 0 next-page-start)]
      (if cached?
        (do
          (delete page^)
          (set! page^ (arr.into [dynamic]int (slice cached-page.entries 0)))
          (set! page-start^ cached-page.start)
          (set! page-end^ cached-page.end)
          (release-sqlite-loaded-index-page! cached-page))
        (let [[window _base page-ok page-error] (sqlite-index-root-ordered-window handle root-id next-page-start page-size)]
          (when (not page-ok)
            (return 0 false page-error))
          (let [loaded-page (sqlite-loaded-index-page-from-entries window
                                                                   next-page-start
                                                                   (min (+ next-page-start (count window)) row-count))]
            (sqlite-index-page-cache-store! page-cache root-id 0 next-page-start loaded-page)
            (delete page^)
            (set! page^ (arr.into [dynamic]int (slice loaded-page.entries 0)))
            (set! page-start^ next-page-start)
            (set! page-end^ (min (+ next-page-start (count loaded-page.entries)) row-count))
            (release-sqlite-loaded-index-page! loaded-page))
          ))))
  (let [offset (- index page-start^)]
    (when (or (< offset 0)
              (>= offset (count page^)))
      (return 0 false "sqlite index ordered root shared-cache entry was outside loaded page"))
    (return page^[offset] true "")))

(defn delete-owned-strings-array [values: [dynamic]string]
  (for [value values]
    (delete value))
  (delete values))

(defn delete-owned-strings-array-with-moved [values: [dynamic]string, moved: [dynamic]bool]
  (for [value index values]
    (when (or (>= index (count moved))
              (not moved[index]))
      (delete value)))
  (delete values)
  (delete moved))

(defn sqlite-direct-frontier-datoms [handle: rawptr, order-text: string, entities: []u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[loaded-entities value-texts value-entities txs added loaded-ok loaded-error] (sqlite-direct-frontier-datom-parts-raw handle order-text entities attr)
        datoms (make [dynamic]Datom 0 (count loaded-entities))]
    (defer (delete loaded-entities))
    (defer (delete value-entities))
    (defer (delete-owned-strings-array value-texts))
    (defer (delete txs))
    (defer (delete added))
    (when (not loaded-ok)
      (delete-owned-datoms datoms)
      (return (make [dynamic]Datom) false loaded-error))
    (for [_ index loaded-entities]
      (when (or (>= index (count value-texts))
                (>= index (count value-entities))
                (>= index (count txs))
                (>= index (count added)))
        (delete-owned-datoms datoms)
        (return (make [dynamic]Datom) false "sqlite direct frontier datom parts were uneven"))
      (let [value (Value {})
            value-ok false
            value-error ""]
        (if (>= value-entities[index] 0)
          (do
            (set! value (value-entity (u64 value-entities[index])))
            (set! value-ok true))
          (let [[parsed parsed-ok parsed-error] (value-from-owned-serial-text value-texts[index])]
            (set! value parsed)
            (set! value-ok parsed-ok)
            (set! value-error parsed-error)))
        (when (not value-ok)
          (delete-owned-datoms datoms)
          (return (make [dynamic]Datom) false value-error))
        (arr.push! datoms (Datom {e: loaded-entities[index]
                                  a: (string-owned attr)
                                  v: value
                                  tx: txs[index]
                                  added: added[index]}))))
    (return datoms true "")))

(defn sqlite-direct-eavt-entity-attrs-datoms [handle: rawptr, entities: []u64, attrs: []string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[loaded-entities loaded-attrs value-texts value-entities txs added loaded-ok loaded-error] (sqlite-direct-eavt-entity-attrs-datom-parts-raw handle entities attrs)
        datoms (make [dynamic]Datom 0 (count loaded-entities))]
    (defer (delete loaded-entities))
    (defer (delete value-entities))
    (defer (delete-owned-strings-array value-texts))
    (defer (delete txs))
    (defer (delete added))
    (let [moved-attrs (arr.repeat (count loaded-attrs) false)]
      (defer (delete-owned-strings-array-with-moved loaded-attrs moved-attrs))
      (when (not loaded-ok)
        (delete-owned-datoms datoms)
        (return (make [dynamic]Datom) false loaded-error))
      (for [_ index loaded-entities]
        (when (or (>= index (count loaded-attrs))
                  (>= index (count value-texts))
                  (>= index (count value-entities))
                  (>= index (count txs))
                  (>= index (count added)))
          (delete-owned-datoms datoms)
          (return (make [dynamic]Datom) false "sqlite direct EAVT entity attrs datom parts were uneven"))
        (let [value (Value {})
              value-ok false
              value-error ""]
          (if (>= value-entities[index] 0)
            (do
              (set! value (value-entity (u64 value-entities[index])))
              (set! value-ok true))
            (let [[parsed parsed-ok parsed-error] (value-from-owned-serial-text value-texts[index])]
              (set! value parsed)
              (set! value-ok parsed-ok)
              (set! value-error parsed-error)))
          (when (not value-ok)
            (delete-owned-datoms datoms)
            (return (make [dynamic]Datom) false value-error))
          (set! moved-attrs[index] true)
          (arr.push! datoms (Datom {e: loaded-entities[index]
                                    a: loaded-attrs[index]
                                    v: value
                                    tx: txs[index]
                                    added: added[index]}))))
      (return datoms true ""))))

(defn sqlite-loaded-index-page-with-owned-datom-entries [handle: rawptr, stmt: rawptr, owned-entries: [dynamic]int, start: int, end: int] -> [page: SQLite-Loaded-Index-Page, ok: bool, error: string]
  (discard stmt)
  (let [entry-count (count owned-entries)
        entries (slice owned-entries 0)
        datoms (make [dynamic]Datom 0 entry-count)
        [ordinals entities attrs value-texts txs added batch-ok batch-error] (sqlite-load-datoms-by-log-indexes-parts-raw handle entries)]
    (defer (delete ordinals))
    (defer (delete entities))
    (let [moved-attrs (arr.repeat (count attrs) false)]
      (defer (delete-owned-strings-array-with-moved attrs moved-attrs))
      (defer (delete-owned-strings-array value-texts))
      (defer (delete txs))
      (defer (delete added))
      (when (not batch-ok)
        (delete owned-entries)
        (delete-owned-datoms datoms)
        (return (SQLite-Loaded-Index-Page {}) false batch-error))
      (when (not (= (count ordinals) entry-count))
        (delete owned-entries)
        (delete-owned-datoms datoms)
        (return (SQLite-Loaded-Index-Page {}) false "sqlite batch datom page did not return every requested log index"))
      (for [_ index entries]
        (when (or (not (= ordinals[index] index))
                  (>= index (count entities))
                  (>= index (count attrs))
                  (>= index (count value-texts))
                  (>= index (count txs))
                  (>= index (count added)))
          (delete owned-entries)
          (delete-owned-datoms datoms)
          (return (SQLite-Loaded-Index-Page {}) false "sqlite batch datom page returned rows out of order"))
        (let [[value value-ok value-error] (value-from-owned-serial-text value-texts[index])]
          (when (not value-ok)
            (delete owned-entries)
            (delete-owned-datoms datoms)
            (return (SQLite-Loaded-Index-Page {}) false value-error))
          (set! moved-attrs[index] true)
          (arr.push! datoms (Datom {e: entities[index]
                                    a: attrs[index]
                                    v: value
                                    tx: txs[index]
                                    added: added[index]}))))
      (return (sqlite-loaded-index-page-from-entries-and-datoms owned-entries datoms start end) true ""))))

(defn sqlite-loaded-index-page-with-datoms [handle: rawptr, stmt: rawptr, entries: []int, start: int, end: int] -> [page: SQLite-Loaded-Index-Page, ok: bool, error: string]
  (let [owned-entries (arr.into [dynamic]int entries)]
    (sqlite-loaded-index-page-with-owned-datom-entries handle stmt owned-entries start end)))

(defn sqlite-index-root-ordered-datom-at-shared-cache [handle: rawptr, stmt: rawptr, root-id: u64, index: int, row-count: int, page-size: int, page-cache: ^SQLite-Index-Page-Cache, page: ^[dynamic]int, page-start: ^int, page-end: ^int] -> [entry: int, datom: Datom, ok: bool, error: string]
  (when (or (< index 0)
            (>= index row-count))
    (return 0 (Datom {}) false "sqlite index ordered root shared-cache datom position out of range"))
  (let [next-page-start (* (/ index page-size) page-size)
        page-row-end (min (+ next-page-start page-size) row-count)
        [cached-page cached?] (sqlite-index-page-cache-find-retained page-cache^ root-id 0 next-page-start)]
    (if cached?
      (if cached-page.has-datoms
        (do
          (delete page^)
          (set! page^ (arr.into [dynamic]int (slice cached-page.entries 0)))
          (set! page-start^ cached-page.start)
          (set! page-end^ cached-page.end)
          (let [offset (- index cached-page.start)]
            (when (or (< offset 0)
                      (>= offset (count cached-page.entries))
                      (>= offset (count cached-page.datoms)))
              (release-sqlite-loaded-index-page! cached-page)
              (return 0 (Datom {}) false "sqlite index ordered root shared-cache datom was outside loaded page"))
            (let [entry cached-page.entries[offset]
                  datom (datom-owned cached-page.datoms[offset])]
              (release-sqlite-loaded-index-page! cached-page)
              (return entry datom true ""))))
        (let [[loaded-page loaded-ok loaded-error] (sqlite-loaded-index-page-with-datoms handle stmt (slice cached-page.entries 0) cached-page.start cached-page.end)]
          (release-sqlite-loaded-index-page! cached-page)
          (when (not loaded-ok)
            (return 0 (Datom {}) false loaded-error))
          (sqlite-index-page-cache-store! page-cache root-id 0 next-page-start loaded-page)
          (delete page^)
          (set! page^ (arr.into [dynamic]int (slice loaded-page.entries 0)))
          (set! page-start^ loaded-page.start)
          (set! page-end^ loaded-page.end)
          (let [offset (- index loaded-page.start)]
            (when (or (< offset 0)
                      (>= offset (count loaded-page.entries))
                      (>= offset (count loaded-page.datoms)))
              (release-sqlite-loaded-index-page! loaded-page)
              (return 0 (Datom {}) false "sqlite index ordered root loaded datom was outside loaded page"))
            (let [entry loaded-page.entries[offset]
                  datom (datom-owned loaded-page.datoms[offset])]
              (release-sqlite-loaded-index-page! loaded-page)
              (return entry datom true "")))))
      (let [[window _base page-ok page-error] (sqlite-index-root-ordered-window handle root-id next-page-start page-size)]
        (when (not page-ok)
          (return 0 (Datom {}) false page-error))
        (let [loaded-page-end (min (+ next-page-start (count window)) row-count)
              [loaded-page loaded-ok loaded-error] (sqlite-loaded-index-page-with-owned-datom-entries handle stmt window next-page-start loaded-page-end)]
          (when (not loaded-ok)
            (return 0 (Datom {}) false loaded-error))
          (sqlite-index-page-cache-store! page-cache root-id 0 next-page-start loaded-page)
          (delete page^)
          (set! page^ (arr.into [dynamic]int (slice loaded-page.entries 0)))
          (set! page-start^ loaded-page.start)
          (set! page-end^ loaded-page.end)
          (let [offset (- index loaded-page.start)]
            (when (or (< offset 0)
                      (>= offset (count loaded-page.entries))
                      (>= offset (count loaded-page.datoms)))
              (release-sqlite-loaded-index-page! loaded-page)
              (return 0 (Datom {}) false "sqlite index ordered root loaded datom was outside new page"))
            (let [entry loaded-page.entries[offset]
                  datom (datom-owned loaded-page.datoms[offset])]
              (release-sqlite-loaded-index-page! loaded-page)
              (return entry datom true ""))))))))

(defn sqlite-index-root-ordered-entry-offset-at-retained-page-cache [handle: rawptr, stmt: rawptr, root-id: u64, index: int, row-count: int, page-size: int, page-cache: ^SQLite-Index-Page-Cache, current-page: ^SQLite-Loaded-Index-Page, current-page-valid: ^bool] -> [out-entry: int, out-offset: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index row-count))
    (return 0 0 false "sqlite index ordered root retained-page datom position out of range"))
  (when (and current-page-valid^
             (>= index current-page^.start)
             (< index current-page^.end)
             current-page^.has-datoms)
    (let [offset (- index current-page^.start)]
      (when (or (< offset 0)
                (>= offset (count current-page^.entries))
                (>= offset (count current-page^.datoms)))
        (return 0 0 false "sqlite index ordered root retained-page datom was outside loaded page"))
      (return current-page^.entries[offset] offset true "")))
  (when current-page-valid^
    (release-sqlite-loaded-index-page! current-page^)
    (set! current-page-valid^ false))
  (let [next-page-start (* (/ index page-size) page-size)
        [cached-page cached?] (sqlite-index-page-cache-find-retained page-cache^ root-id 0 next-page-start)]
    (if cached?
      (if cached-page.has-datoms
        (do
          (set! current-page^ cached-page)
          (set! current-page-valid^ true))
        (let [[loaded-page loaded-ok loaded-error] (sqlite-loaded-index-page-with-datoms handle stmt (slice cached-page.entries 0) cached-page.start cached-page.end)]
          (release-sqlite-loaded-index-page! cached-page)
          (when (not loaded-ok)
            (return 0 0 false loaded-error))
          (sqlite-index-page-cache-store! page-cache root-id 0 next-page-start loaded-page)
          (set! current-page^ loaded-page)
          (set! current-page-valid^ true)))
      (let [[window _base page-ok page-error] (sqlite-index-root-ordered-window handle root-id next-page-start page-size)]
        (when (not page-ok)
          (return 0 0 false page-error))
        (let [loaded-page-end (min (+ next-page-start (count window)) row-count)
              [loaded-page loaded-ok loaded-error] (sqlite-loaded-index-page-with-owned-datom-entries handle stmt window next-page-start loaded-page-end)]
          (when (not loaded-ok)
            (return 0 0 false loaded-error))
          (sqlite-index-page-cache-store! page-cache root-id 0 next-page-start loaded-page)
          (set! current-page^ loaded-page)
          (set! current-page-valid^ true)))))
  (let [offset (- index current-page^.start)]
    (when (or (not current-page-valid^)
              (not current-page^.has-datoms)
              (< offset 0)
              (>= offset (count current-page^.entries))
              (>= offset (count current-page^.datoms)))
      (return 0 0 false "sqlite index ordered root retained-page datom was outside loaded page after load"))
    (return current-page^.entries[offset] offset true "")))

(defn sqlite-index-root-ordered-datom-at-retained-page-cache [handle: rawptr, stmt: rawptr, root-id: u64, index: int, row-count: int, page-size: int, page-cache: ^SQLite-Index-Page-Cache, current-page: ^SQLite-Loaded-Index-Page, current-page-valid: ^bool] -> [out-entry: int, datom: Datom, ok: bool, error: string]
  (let [[found-entry found-offset offset-ok offset-error] (sqlite-index-root-ordered-entry-offset-at-retained-page-cache handle stmt root-id index row-count page-size page-cache current-page current-page-valid)]
    (when (not offset-ok)
      (return 0 (Datom {}) false offset-error))
    (return found-entry (datom-owned current-page^.datoms[found-offset]) true "")))

(defn sqlite-index-root-boundary-entry [handle: rawptr, root-id: u64, order: string, last?: bool] -> [entry: int, ok: bool, error: string]
  (let [[row-count first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root-id)]
    (when (not info-ok)
      (return 0 false info-error))
    (defer (delete first-key))
    (when (= row-count 0)
      (return 0 false "sqlite index root boundary requested for empty root"))
    (let [[bound-first bound-last bounds-ok bounds-error] (sqlite-index-chunk-bounds-by-id-raw handle root-id)]
      (when (not bounds-ok)
        (return 0 false bounds-error))
      (let [bound-text (if last? bound-last bound-first)
            [bound-entry bound-entry-ok] (parse-index-bound-entry bound-text)]
        (delete bound-first)
        (delete bound-last)
        (when bound-entry-ok
          (return bound-entry true ""))))
    (when (not (sqlite-index-merge-root-key? first-key))
      (return (sqlite-index-root-ordered-entry-at handle root-id (if last? (- (int row-count) 1) 0))))
    (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root-id)]
      (when (not child-count-ok)
        (return 0 false child-count-error))
      (let [found false
            best-entry 0]
        (for [ordinal (arr.range 0 (int child-count))]
          (let [[child-root child-ok child-error] (sqlite-index-child-chunk-id-raw handle root-id (i64 ordinal))]
            (when (not child-ok)
              (return 0 false child-error))
            (let [[child-entry child-entry-ok child-entry-error] (sqlite-index-root-boundary-entry handle child-root order last?)]
              (when (not child-entry-ok)
                (return 0 false child-entry-error))
              (if (not found)
                (do
                  (set! found true)
                  (set! best-entry child-entry))
                (let [[child-less less-ok less-error] (sqlite-index-root-entry-less? handle order child-entry best-entry)]
                  (when (not less-ok)
                    (return 0 false less-error))
                  (when (if last? (not child-less) child-less)
                    (set! best-entry child-entry)))))))
        (if found
          (return best-entry true "")
          (return 0 false "sqlite merge root boundary had no children"))))))

(defn sqlite-index-cursor-boundary-entry [cursor: ^SQLite-Index-Cursor, last?: bool] -> [entry: int, ok: bool, error: string]
  (when (= cursor^.row-count 0)
    (return 0 false "sqlite index cursor boundary requested for empty cursor"))
  (when cursor^.root-is-manifest
    (return (sqlite-index-cursor-at cursor (if last? (- cursor^.row-count 1) 0))))
  (sqlite-index-root-boundary-entry cursor^.handle cursor^.root-id cursor^.order-text last?))

(defn sqlite-index-merge-child-entry-at-cached [handle: rawptr, roots: []u64, counts: []int, child-index: int, position: int, page-size: int, page0: ^[dynamic]int, page-start0: ^int, page-end0: ^int, page1: ^[dynamic]int, page-start1: ^int, page-end1: ^int, page2: ^[dynamic]int, page-start2: ^int, page-end2: ^int, page3: ^[dynamic]int, page-start3: ^int, page-end3: ^int] -> [entry: int, ok: bool, error: string]
  (cond
    (= child-index 0)
      (sqlite-index-root-ordered-entry-at-cached handle roots[child-index] position counts[child-index] page-size page0 page-start0 page-end0)
    (= child-index 1)
      (sqlite-index-root-ordered-entry-at-cached handle roots[child-index] position counts[child-index] page-size page1 page-start1 page-end1)
    (= child-index 2)
      (sqlite-index-root-ordered-entry-at-cached handle roots[child-index] position counts[child-index] page-size page2 page-start2 page-end2)
    (= child-index 3)
      (sqlite-index-root-ordered-entry-at-cached handle roots[child-index] position counts[child-index] page-size page3 page-start3 page-end3)
    :else
      (sqlite-index-root-ordered-entry-at handle roots[child-index] position)))

(defn sqlite-index-merge-child-entry-and-datom-at-cached [cursor: ^SQLite-Index-Cursor, child-index: int, position: int] -> [entry: int, datom: Datom, ok: bool, error: string]
  (when (or (< child-index 0)
            (>= child-index (count cursor^.merge-roots))
            (>= child-index (count cursor^.merge-counts))
            (>= child-index (count cursor^.merge-loaded-pages))
            (>= child-index (count cursor^.merge-loaded-page-valid)))
    (return 0 (Datom {}) false "sqlite merge child index out of range"))
  (sqlite-index-root-ordered-datom-at-retained-page-cache
    cursor^.handle
    cursor^.datom-stmt
    cursor^.merge-roots[child-index]
    position
    cursor^.merge-counts[child-index]
    cursor^.page-size
    (addr cursor^.page-cache)
    (addr cursor^.merge-loaded-pages[child-index])
    (addr cursor^.merge-loaded-page-valid[child-index])))

(defn sqlite-index-root-entry-less? [handle: rawptr, order: string, left: int, right: int] -> [less: bool, ok: bool, error: string]
  (let [[left-text left-text-ok left-text-error] (sqlite-load-datom-by-log-index-text-raw handle (i64 left))]
    (when (not left-text-ok)
      (return false false left-text-error))
    (defer (delete left-text))
    (let [[left-datom left-ok left-error] (datom-from-owned-serial-text left-text)]
      (when (not left-ok)
        (return false false left-error))
      (defer (delete-owned-datom left-datom))
      (let [[right-text right-text-ok right-text-error] (sqlite-load-datom-by-log-index-text-raw handle (i64 right))]
        (when (not right-text-ok)
          (return false false right-text-error))
        (defer (delete right-text))
        (let [[right-datom right-ok right-error] (datom-from-owned-serial-text right-text)]
          (when (not right-ok)
            (return false false right-error))
          (defer (delete-owned-datom right-datom))
          (return (datom-less-order? left-datom right-datom order left right) true ""))))))

(defn sqlite-load-datom-by-log-index-handle [handle: rawptr, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
    (datom-from-owned-serial-text text)))

(defn sqlite-load-datom-by-log-index-handle-stmt [handle: rawptr, stmt: rawptr, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[entity attr value-text tx added loaded-ok loaded-error] (sqlite-step-prepared-datom-by-log-index-parts-raw handle stmt (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete value-text))
    (let [[value value-ok value-error] (value-from-owned-serial-text value-text)]
      (when (not value-ok)
        (delete attr)
        (return (Datom {}) false value-error))
      (return (Datom {e: entity a: attr v: value tx: tx added: added}) true ""))))

(defn sqlite-load-datom-entity-by-log-index-handle-stmt [handle: rawptr, stmt: rawptr, log-index: int] -> [entity: u64, ok: bool, error: string]
  (sqlite-step-prepared-datom-entity-by-log-index-raw handle stmt (i64 log-index)))

(defn sqlite-load-datom-attr-by-log-index-handle-stmt [handle: rawptr, stmt: rawptr, log-index: int] -> [attr: string, ok: bool, error: string]
  (sqlite-step-prepared-datom-attr-by-log-index-raw handle stmt (i64 log-index)))

(defn delete-active-datoms! [datoms: ^[dynamic]Datom, active: ^[dynamic]bool]
  (for [index (arr.range 0 (count active^))]
    (when active^[index]
      (delete-owned-datom datoms^[index])
      (set! active^[index] false))))

(defn sqlite-index-root-entry-at [handle: rawptr, root-id: u64, order: string, index: int] -> [entry: int, ok: bool, error: string]
  (let [[row-count first-key _level info-ok info-error] (sqlite-index-chunk-info-by-id-raw handle root-id)]
    (when (not info-ok)
      (return 0 false info-error))
    (defer (delete first-key))
    (when (or (< index 0)
              (>= index (int row-count)))
      (return 0 false "sqlite index root entry position out of range"))
    (when (not (sqlite-index-merge-root-key? first-key))
      (return (sqlite-index-root-ordered-entry-at handle root-id index)))
    (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root-id)]
      (when (not child-count-ok)
        (return 0 false child-count-error))
      (let [roots (make [dynamic]u64) :defer
            counts (make [dynamic]int) :defer
            positions (make [dynamic]int) :defer]
        (for [ordinal (arr.range 0 (int child-count))]
          (let [[child-root child-ok child-error] (sqlite-index-child-chunk-id-raw handle root-id (i64 ordinal))]
            (when (not child-ok)
              (return 0 false child-error))
            (let [[child-count-value child-key _child-level child-info-ok child-info-error] (sqlite-index-chunk-info-by-id-raw handle child-root)]
              (when (not child-info-ok)
                (return 0 false child-info-error))
              (delete child-key)
              (arr.push! roots child-root)
              (arr.push! counts (int child-count-value))
              (arr.push! positions 0))))
        (let [produced 0]
          (while true
            (let [best-child -1
                  best-entry 0]
              (for [child-index (arr.range 0 (count roots))]
                (when (< positions[child-index] counts[child-index])
                  (let [[candidate candidate-ok candidate-error] (sqlite-index-root-entry-at handle roots[child-index] order positions[child-index])]
                    (when (not candidate-ok)
                      (return 0 false candidate-error))
                    (if (= best-child -1)
                      (do
                        (set! best-child child-index)
                        (set! best-entry candidate))
                      (let [[candidate-less less-ok less-error] (sqlite-index-root-entry-less? handle order candidate best-entry)]
                        (when (not less-ok)
                          (return 0 false less-error))
                        (when candidate-less
                          (set! best-child child-index)
                          (set! best-entry candidate)))))))
              (when (= best-child -1)
                (return 0 false "sqlite merge root entry was not found"))
              (when (= produced index)
                (return best-entry true ""))
              (set! positions[best-child] (+ positions[best-child] 1))
              (set! produced (+ produced 1)))))
          (return 0 false "sqlite merge root entry loop exited unexpectedly")))))

(defn sqlite-index-merge-root-child-runs-into! [handle: rawptr, root-id: u64, roots: ^[dynamic]u64, counts: ^[dynamic]int] -> [ok: bool, error: string]
  (let [[child-count child-count-ok child-count-error] (sqlite-index-chunk-child-count-raw handle root-id)]
    (when (not child-count-ok)
      (return false child-count-error))
    (for [ordinal (arr.range 0 (int child-count))]
      (let [[child-root child-ok child-error] (sqlite-index-child-chunk-id-raw handle root-id (i64 ordinal))]
        (when (not child-ok)
          (return false child-error))
        (let [[child-count-value child-key _child-level child-info-ok child-info-error] (sqlite-index-chunk-info-by-id-raw handle child-root)]
          (when (not child-info-ok)
            (return false child-info-error))
          (if (sqlite-index-merge-root-key? child-key)
            (do
              (delete child-key)
              (let [[nested-ok nested-error] (sqlite-index-merge-root-child-runs-into! handle child-root roots counts)]
                (when (not nested-ok)
                  (return false nested-error))))
            (do
              (delete child-key)
              (arr.push! roots^ child-root)
              (arr.push! counts^ (int child-count-value)))))))
    (return true "")))

(defn sqlite-index-merge-root-child-runs [handle: rawptr, root-id: u64] -> [roots: [dynamic]u64, counts: [dynamic]int, ok: bool, error: string]
  (let [run-roots (make [dynamic]u64)
        run-counts (make [dynamic]int)
        [runs-ok runs-error] (sqlite-index-merge-root-child-runs-into! handle root-id (addr run-roots) (addr run-counts))]
    (if runs-ok
      (return run-roots run-counts true "")
      (do
        (delete run-roots)
        (delete run-counts)
        (return (make [dynamic]u64) (make [dynamic]int) false runs-error)))))

(defn sqlite-datom-from-persisted-parts [entity: u64, attr: string, value-text: string, tx: u64, added: bool] -> [datom: Datom, ok: bool, error: string]
  (let [[value value-ok value-error] (value-from-owned-serial-text value-text)]
    (when (not value-ok)
      (return (Datom {}) false value-error))
    (return (Datom {e: entity a: (string-owned attr) v: value tx: tx added: added}) true "")))

(defn sqlite-index-root-bound-datoms [handle: rawptr, root-id: u64] -> [first: Datom, last: Datom, ok: bool, error: string]
  (let [[first-bound last-bound bounds-ok bounds-error] (sqlite-index-chunk-bounds-by-id-raw handle root-id)]
    (when (not bounds-ok)
      (return (Datom {}) (Datom {}) false bounds-error))
    (defer (delete first-bound))
    (defer (delete last-bound))
    (let [[first-entry first-ok] (parse-index-bound-entry first-bound)
          [last-entry last-ok] (parse-index-bound-entry last-bound)]
      (when (not (and first-ok last-ok))
        (return (Datom {}) (Datom {}) false "sqlite index root had invalid bound entries"))
      (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
        (when (not datom-stmt-ok)
          (return (Datom {}) (Datom {}) false datom-stmt-error))
        (defer (sqlite-finalize-stmt-raw datom-stmt))
        (let [[first-datom first-datom-ok first-datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt first-entry)]
          (when (not first-datom-ok)
            (return (Datom {}) (Datom {}) false first-datom-error))
          (let [[last-datom last-datom-ok last-datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt last-entry)]
            (when (not last-datom-ok)
              (delete-owned-datom first-datom)
              (return (Datom {}) (Datom {}) false last-datom-error))
            (return first-datom last-datom true "")))))))

(defn sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, first-position: int, first-datom: Datom, last-position: int, last-datom: Datom] -> [ok: bool, error: string]
  (let [first-value-text (value-serializable-text first-datom.v)
        last-value-text (value-serializable-text last-datom.v)
        [range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-with-stmts handle stmts manifest-id ordinal first-datom.a (i64 first-position) first-datom.e first-value-text first-datom.tx first-datom.added (i64 last-position) last-datom.e last-value-text last-datom.tx last-datom.added)]
    (delete first-value-text)
    (delete last-value-text)
    (return range-ok range-error)))

(defn sqlite-insert-index-run-manifest-attr-range-from-datoms! [handle: rawptr, manifest-id: u64, ordinal: u64, first-position: int, first-datom: Datom, last-position: int, last-datom: Datom] -> [ok: bool, error: string]
  (sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! handle nil manifest-id ordinal first-position first-datom last-position last-datom))

(defn sqlite-index-name-has-contiguous-attrs? [index-name: string] -> bool
  (or (= index-name ":aevt")
      (= index-name ":avet")))

(defn sqlite-index-name-has-entity-attr-prefixes? [index-name: string] -> bool
  (or (= index-name ":eavt")
      (= index-name ":vaet")))

(defn sqlite-index-entity-attr-prefix-from-datom [index-name: string, datom: Datom] -> [entity: u64, attr: string, ok: bool]
  (cond
    (= index-name ":eavt")
      (return datom.e datom.a true)
    (= index-name ":vaet")
      (if (= datom.v.kind .Entity)
        (return datom.v.entity datom.a true)
        (return 0 "" false))
    :else (return 0 "" false)))

(defn sqlite-insert-index-run-manifest-entity-attr-range! [handle: rawptr, manifest-id: u64, ordinal: u64, index-name: string, entity: u64, attr: string, first-position: int, last-position: int] -> [ok: bool, error: string]
  (sqlite-insert-index-run-manifest-entity-attr-range-raw handle manifest-id ordinal index-name entity attr (i64 first-position) (i64 last-position)))

(defn sqlite-insert-index-run-manifest-entity-attr-ranges-from-root! [handle: rawptr, manifest-id: u64, ordinal: u64, index-name: string, root-id: u64] -> [ok: bool, error: string]
  (when (not (sqlite-index-name-has-entity-attr-prefixes? index-name))
    (return true ""))
  (let [[row-count row-count-ok row-count-error] (sqlite-index-chunk-row-count-by-id-raw handle root-id)]
    (when (not row-count-ok)
      (return false row-count-error))
    (when (= row-count 0)
      (return true ""))
    (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
      (when (not datom-stmt-ok)
        (return false datom-stmt-error))
      (defer (sqlite-finalize-stmt-raw datom-stmt))
      (let [page (make [dynamic]int) :defer
            page-start -1
            page-end -1
            has-range false
            current-entity: u64 0
            current-attr ""
            first-position 0
            last-position 0]
        (for [position (arr.range 0 (int row-count))]
          (let [[entry entry-ok entry-error] (sqlite-index-root-ordered-entry-at-cached handle root-id position (int row-count) sqlite-index-leaf-chunk-size (addr page) (addr page-start) (addr page-end))]
            (when (not entry-ok)
              (when has-range
                (delete current-attr))
              (return false entry-error))
            (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt entry)]
              (when (not datom-ok)
                (when has-range
                  (delete current-attr))
                (return false datom-error))
              (let [[entity attr prefix-ok] (sqlite-index-entity-attr-prefix-from-datom index-name datom)]
                (if prefix-ok
                  (do
                    (if (not has-range)
                      (do
                        (set! current-entity entity)
                        (set! current-attr (string-owned attr))
                        (set! first-position position)
                        (set! last-position position)
                        (set! has-range true))
                      (if (and (= entity current-entity)
                               (= attr current-attr))
                        (set! last-position position)
                        (do
                          (let [[range-ok range-error] (sqlite-insert-index-run-manifest-entity-attr-range! handle manifest-id ordinal index-name current-entity current-attr first-position last-position)]
                            (when (not range-ok)
                              (delete current-attr)
                              (delete-owned-datom datom)
                              (return false range-error)))
                          (delete current-attr)
                          (set! current-entity entity)
                          (set! current-attr (string-owned attr))
                          (set! first-position position)
                          (set! last-position position))))
                    (delete-owned-datom datom))
                  (do
                    (when has-range
                      (let [[range-ok range-error] (sqlite-insert-index-run-manifest-entity-attr-range! handle manifest-id ordinal index-name current-entity current-attr first-position last-position)]
                        (when (not range-ok)
                          (delete current-attr)
                          (delete-owned-datom datom)
                          (return false range-error)))
                      (delete current-attr)
                      (set! has-range false))
                    (delete-owned-datom datom)))))))
        (when has-range
          (let [[range-ok range-error] (sqlite-insert-index-run-manifest-entity-attr-range! handle manifest-id ordinal index-name current-entity current-attr first-position last-position)]
            (delete current-attr)
            (when (not range-ok)
              (return false range-error))))
        (return true "")))))

(defn sqlite-index-run-manifest-entity-attr-range-for-test [store: ^Store-Conn, manifest-id: u64, ordinal: u64, order-text: string, entity: u64, attr: string] -> [first-ordinal: i64, last-ordinal: i64, found: bool, ok: bool, error: string]
  (when (not (= store^.kind .SQLite))
    (return -1 -1 false false "entity/attr manifest range test lookup requires a SQLite store"))
  (sqlite-index-run-manifest-entity-attr-range-parts-raw store^.sqlite.handle manifest-id ordinal order-text entity attr))

(defn sqlite-insert-index-run-manifest-attr-ranges-from-entries-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, entries: []int] -> [ok: bool, error: string]
  (when (= (count entries) 0)
    (return true ""))
  (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
    (when (not datom-stmt-ok)
      (return false datom-stmt-error))
    (defer (sqlite-finalize-stmt-raw datom-stmt))
    (let [has-range false
          first-position 0
          last-position 0
          first-datom (Datom {})
          last-datom (Datom {})]
      (for [entry position entries]
        (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt entry)]
          (when (not datom-ok)
            (when has-range
              (delete-owned-datom first-datom)
              (delete-owned-datom last-datom))
            (return false datom-error))
          (if (not has-range)
            (do
              (set! first-datom datom)
              (set! last-datom (datom-owned datom))
              (set! first-position position)
              (set! last-position position)
              (set! has-range true))
            (if (= datom.a first-datom.a)
              (do
                (delete-owned-datom last-datom)
                (set! last-datom datom)
                (set! last-position position))
              (do
                (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! handle stmts manifest-id ordinal first-position first-datom last-position last-datom)]
                  (when (not range-ok)
                    (delete-owned-datom first-datom)
                    (delete-owned-datom last-datom)
                    (delete-owned-datom datom)
                    (return false range-error)))
                (delete-owned-datom first-datom)
                (delete-owned-datom last-datom)
                (set! first-datom datom)
                (set! last-datom (datom-owned datom))
                (set! first-position position)
                (set! last-position position))))))
      (when has-range
        (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! handle stmts manifest-id ordinal first-position first-datom last-position last-datom)]
          (delete-owned-datom first-datom)
          (delete-owned-datom last-datom)
          (when (not range-ok)
            (return false range-error)))))
    (return true "")))

(defn sqlite-insert-index-run-manifest-attr-ranges-from-entries! [handle: rawptr, manifest-id: u64, ordinal: u64, entries: []int] -> [ok: bool, error: string]
  (sqlite-insert-index-run-manifest-attr-ranges-from-entries-with-stmts! handle nil manifest-id ordinal entries))

(defn sqlite-insert-index-run-manifest-attr-ranges-from-appended-entries-with-stmts! [handle: rawptr, stmts: ^SQLite-Index-Write-Stmts, manifest-id: u64, ordinal: u64, entries: []int, appended: []Datom, start-index: int] -> [ok: bool, error: string]
  (when (= (count entries) 0)
    (return true ""))
  (let [has-range false
        first-position 0
        last-position 0
        first-local 0
        last-local 0]
    (for [entry position entries]
      (let [local (- entry start-index)]
        (when (or (< local 0)
                  (>= local (count appended)))
          (return false "manifest attr range entry was outside appended datoms"))
        (if (not has-range)
          (do
            (set! first-local local)
            (set! last-local local)
            (set! first-position position)
            (set! last-position position)
            (set! has-range true))
          (if (= appended[local].a appended[first-local].a)
            (do
              (set! last-local local)
              (set! last-position position))
            (do
              (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! handle stmts manifest-id ordinal first-position appended[first-local] last-position appended[last-local])]
                (when (not range-ok)
                  (return false range-error)))
              (set! first-local local)
              (set! last-local local)
              (set! first-position position)
              (set! last-position position))))))
    (when has-range
      (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms-with-stmts! handle stmts manifest-id ordinal first-position appended[first-local] last-position appended[last-local])]
        (when (not range-ok)
          (return false range-error))))
    (return true "")))

(defn sqlite-insert-index-run-manifest-attr-ranges-from-root! [handle: rawptr, manifest-id: u64, ordinal: u64, root-id: u64, row-count: int] -> [ok: bool, error: string]
  (when (= row-count 0)
    (return true ""))
  (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
    (when (not datom-stmt-ok)
      (return false datom-stmt-error))
    (defer (sqlite-finalize-stmt-raw datom-stmt))
    (let [page (make [dynamic]int) :defer
          page-start -1
          page-end -1
          has-range false
          first-position 0
          last-position 0
          first-datom (Datom {})
          last-datom (Datom {})]
      (for [position (arr.range 0 row-count)]
        (let [[entry entry-ok entry-error] (sqlite-index-root-ordered-entry-at-cached handle root-id position row-count sqlite-index-leaf-chunk-size (addr page) (addr page-start) (addr page-end))]
          (when (not entry-ok)
            (when has-range
              (delete-owned-datom first-datom)
              (delete-owned-datom last-datom))
            (return false entry-error))
          (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt handle datom-stmt entry)]
            (when (not datom-ok)
              (when has-range
                (delete-owned-datom first-datom)
                (delete-owned-datom last-datom))
              (return false datom-error))
            (if (not has-range)
              (do
                (set! first-datom datom)
                (set! last-datom (datom-owned datom))
                (set! first-position position)
                (set! last-position position)
                (set! has-range true))
              (if (= datom.a first-datom.a)
                (do
                  (delete-owned-datom last-datom)
                  (set! last-datom datom)
                  (set! last-position position))
                (do
                  (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms! handle manifest-id ordinal first-position first-datom last-position last-datom)]
                    (when (not range-ok)
                      (delete-owned-datom first-datom)
                      (delete-owned-datom last-datom)
                      (delete-owned-datom datom)
                      (return false range-error)))
                  (delete-owned-datom first-datom)
                  (delete-owned-datom last-datom)
                  (set! first-datom datom)
                  (set! last-datom (datom-owned datom))
                  (set! first-position position)
                  (set! last-position position)))))))
      (when has-range
        (let [[range-ok range-error] (sqlite-insert-index-run-manifest-attr-range-from-datoms! handle manifest-id ordinal first-position first-datom last-position last-datom)]
          (delete-owned-datom first-datom)
          (delete-owned-datom last-datom)
          (when (not range-ok)
            (return false range-error)))))
    (return true "")))

(defn sqlite-index-run-manifest-child-runs-into! [handle: rawptr, manifest-id: u64, roots: ^[dynamic]u64, counts: ^[dynamic]int] -> [ok: bool, error: string]
  (let [[parent-manifest-id base-root _total-count _total-run-count info-ok info-error] (sqlite-index-run-manifest-info-raw handle manifest-id)]
    (when (not info-ok)
      (return false info-error))
    (if (> parent-manifest-id 0)
      (let [[parent-ok parent-error] (sqlite-index-run-manifest-child-runs-into! handle parent-manifest-id roots counts)]
        (when (not parent-ok)
          (return false parent-error)))
      (let [[base-count base-key base-level base-ok base-error] (sqlite-index-chunk-info-by-id-raw handle base-root)]
        (discard base-level)
        (when (not base-ok)
          (return false base-error))
        (delete base-key)
        (arr.push! roots^ base-root)
        (arr.push! counts^ (int base-count))))
    (let [[direct-run-count direct-count-ok direct-count-error] (sqlite-index-run-manifest-run-count-raw handle manifest-id)]
      (when (not direct-count-ok)
        (return false direct-count-error))
      (for [ordinal (arr.range 0 (int direct-run-count))]
        (let [[run-root row-count run-ok run-error] (sqlite-index-run-manifest-run-raw handle manifest-id (u64 ordinal))]
          (when (not run-ok)
            (return false run-error))
          (arr.push! roots^ run-root)
          (arr.push! counts^ (int row-count))))
      (return true ""))))

(defn sqlite-index-run-manifest-child-runs [handle: rawptr, manifest-id: u64] -> [roots: [dynamic]u64, counts: [dynamic]int, ok: bool, error: string]
  (let [run-roots (make [dynamic]u64)
        run-counts (make [dynamic]int)
        [runs-ok runs-error] (sqlite-index-run-manifest-child-runs-into! handle manifest-id (addr run-roots) (addr run-counts))]
    (if runs-ok
      (return run-roots run-counts true "")
      (do
        (delete run-roots)
        (delete run-counts)
        (return (make [dynamic]u64) (make [dynamic]int) false runs-error)))))

(defn sqlite-index-run-manifest-child-runs-with-bound-datoms-into! [handle: rawptr, manifest-id: u64, roots: ^[dynamic]u64, counts: ^[dynamic]int, lows: ^[dynamic]int, highs: ^[dynamic]int, first-datoms: ^[dynamic]Datom, last-datoms: ^[dynamic]Datom] -> [ok: bool, error: string]
  (let [[parent-manifest-id base-root _total-count _total-run-count info-ok info-error] (sqlite-index-run-manifest-info-raw handle manifest-id)]
    (when (not info-ok)
      (return false info-error))
    (if (> parent-manifest-id 0)
      (let [[parent-ok parent-error] (sqlite-index-run-manifest-child-runs-with-bound-datoms-into! handle parent-manifest-id roots counts lows highs first-datoms last-datoms)]
        (when (not parent-ok)
          (return false parent-error)))
      (let [[base-count base-key base-level base-ok base-error] (sqlite-index-chunk-info-by-id-raw handle base-root)]
        (discard base-level)
        (when (not base-ok)
          (return false base-error))
        (delete base-key)
        (let [[first-bound last-bound bound-ok bound-error] (sqlite-index-root-bound-datoms handle base-root)]
          (when (not bound-ok)
            (return false bound-error))
          (arr.push! roots^ base-root)
          (arr.push! counts^ (int base-count))
          (arr.push! lows^ 0)
          (arr.push! highs^ (int base-count))
          (arr.push! first-datoms^ first-bound)
          (arr.push! last-datoms^ last-bound))))
    (let [[direct-run-count direct-count-ok direct-count-error] (sqlite-index-run-manifest-run-count-raw handle manifest-id)]
      (when (not direct-count-ok)
        (return false direct-count-error))
      (for [ordinal (arr.range 0 (int direct-run-count))]
        (let [[run-root row-count first-e first-a first-value first-tx first-added last-e last-a last-value last-tx last-added run-ok run-error] (sqlite-index-run-manifest-run-bound-parts-raw handle manifest-id (u64 ordinal))]
          (when (not run-ok)
            (return false run-error))
          (let [[first-datom first-datom-ok first-datom-error] (sqlite-datom-from-persisted-parts first-e first-a first-value first-tx first-added)]
            (when (not first-datom-ok)
              (delete first-a)
              (delete first-value)
              (delete last-a)
              (delete last-value)
              (return false first-datom-error))
            (let [[last-datom last-datom-ok last-datom-error] (sqlite-datom-from-persisted-parts last-e last-a last-value last-tx last-added)]
              (delete first-a)
              (delete first-value)
              (delete last-a)
              (delete last-value)
              (when (not last-datom-ok)
                (delete-owned-datom first-datom)
                (return false last-datom-error))
              (arr.push! roots^ run-root)
              (arr.push! counts^ (int row-count))
              (arr.push! lows^ 0)
              (arr.push! highs^ (int row-count))
              (arr.push! first-datoms^ first-datom)
              (arr.push! last-datoms^ last-datom)))))
      (return true ""))))

(defn sqlite-index-run-manifest-child-runs-with-bound-datoms [handle: rawptr, manifest-id: u64] -> [roots: [dynamic]u64, counts: [dynamic]int, lows: [dynamic]int, highs: [dynamic]int, first-datoms: [dynamic]Datom, last-datoms: [dynamic]Datom, ok: bool, error: string]
  (let [run-roots (make [dynamic]u64)
        run-counts (make [dynamic]int)
        run-lows (make [dynamic]int)
        run-highs (make [dynamic]int)
        run-first-datoms (make [dynamic]Datom)
        run-last-datoms (make [dynamic]Datom)
        [runs-ok runs-error] (sqlite-index-run-manifest-child-runs-with-bound-datoms-into! handle manifest-id (addr run-roots) (addr run-counts) (addr run-lows) (addr run-highs) (addr run-first-datoms) (addr run-last-datoms))]
    (when (not runs-ok)
      (delete run-roots)
      (delete run-counts)
      (delete run-lows)
      (delete run-highs)
      (delete-owned-datoms run-first-datoms)
      (delete-owned-datoms run-last-datoms)
      (return (make [dynamic]u64) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]Datom) (make [dynamic]Datom) false runs-error))
    (return run-roots run-counts run-lows run-highs run-first-datoms run-last-datoms true "")))

(defn sqlite-index-run-manifest-push-root-bound-datoms! [handle: rawptr, root-id: u64, row-count: int, roots: ^[dynamic]u64, counts: ^[dynamic]int, first-datoms: ^[dynamic]Datom, last-datoms: ^[dynamic]Datom] -> [ok: bool, error: string]
  (let [[first-bound last-bound bound-ok bound-error] (sqlite-index-root-bound-datoms handle root-id)]
    (when (not bound-ok)
      (return false bound-error))
    (arr.push! roots^ root-id)
    (arr.push! counts^ row-count)
    (arr.push! first-datoms^ first-bound)
    (arr.push! last-datoms^ last-bound)
    (return true "")))

(defn sqlite-index-run-manifest-child-runs-with-attr-bound-datoms-into! [handle: rawptr, manifest-id: u64, attr: string, roots: ^[dynamic]u64, counts: ^[dynamic]int, lows: ^[dynamic]int, highs: ^[dynamic]int, first-datoms: ^[dynamic]Datom, last-datoms: ^[dynamic]Datom] -> [ok: bool, error: string]
  (let [[parent-manifest-id base-root _total-count _total-run-count info-ok info-error] (sqlite-index-run-manifest-info-raw handle manifest-id)]
    (when (not info-ok)
      (return false info-error))
    (if (> parent-manifest-id 0)
      (let [[parent-ok parent-error] (sqlite-index-run-manifest-child-runs-with-attr-bound-datoms-into! handle parent-manifest-id attr roots counts lows highs first-datoms last-datoms)]
        (when (not parent-ok)
          (return false parent-error)))
      (let [[base-count base-key base-level base-ok base-error] (sqlite-index-chunk-info-by-id-raw handle base-root)]
        (discard base-level)
        (when (not base-ok)
          (return false base-error))
        (delete base-key)
        (let [[base-push-ok base-push-error] (sqlite-index-run-manifest-push-root-bound-datoms! handle base-root (int base-count) roots counts first-datoms last-datoms)]
          (when (not base-push-ok)
            (return false base-push-error))
          (arr.push! lows^ 0)
          (arr.push! highs^ (int base-count)))))
    (let [[direct-run-count direct-count-ok direct-count-error] (sqlite-index-run-manifest-run-count-raw handle manifest-id)]
      (when (not direct-count-ok)
        (return false direct-count-error))
      (for [ordinal (arr.range 0 (int direct-run-count))]
        (let [[run-root row-count run-ok run-error] (sqlite-index-run-manifest-run-raw handle manifest-id (u64 ordinal))]
          (when (not run-ok)
            (return false run-error))
          (let [[first-position first-e first-value first-tx first-added last-position last-e last-value last-tx last-added found attr-ok attr-error] (sqlite-index-run-manifest-attr-range-parts-raw handle manifest-id (u64 ordinal) attr)]
            (when (not attr-ok)
              (return false attr-error))
            (if found
              (let [[first-datom first-datom-ok first-datom-error] (sqlite-datom-from-persisted-parts first-e attr first-value first-tx first-added)]
                (when (not first-datom-ok)
                  (delete first-value)
                  (delete last-value)
                  (return false first-datom-error))
                (let [[last-datom last-datom-ok last-datom-error] (sqlite-datom-from-persisted-parts last-e attr last-value last-tx last-added)]
                  (delete first-value)
                  (delete last-value)
                  (when (not last-datom-ok)
                    (delete-owned-datom first-datom)
                    (return false last-datom-error))
                  (arr.push! roots^ run-root)
                  (arr.push! counts^ (int row-count))
                  (arr.push! lows^ (if (>= first-position 0) (int first-position) 0))
                  (arr.push! highs^ (if (>= last-position first-position) (+ (int last-position) 1) (int row-count)))
                  (arr.push! first-datoms^ first-datom)
                  (arr.push! last-datoms^ last-datom)))
              (let [[_run-count run-key run-level run-info-ok run-info-error] (sqlite-index-chunk-info-by-id-raw handle run-root)]
                (discard _run-count)
                (discard run-level)
                (when (not run-info-ok)
                  (return false run-info-error))
                (delete run-key)
                (let [[fallback-ok fallback-error] (sqlite-index-run-manifest-push-root-bound-datoms! handle run-root (int row-count) roots counts first-datoms last-datoms)]
                  (when (not fallback-ok)
                    (return false fallback-error))
                  (arr.push! lows^ 0)
                  (arr.push! highs^ (int row-count))))))))
      (return true ""))))

(defn sqlite-index-run-manifest-child-runs-with-attr-bound-datoms [handle: rawptr, manifest-id: u64, attr: string] -> [roots: [dynamic]u64, counts: [dynamic]int, lows: [dynamic]int, highs: [dynamic]int, first-datoms: [dynamic]Datom, last-datoms: [dynamic]Datom, ok: bool, error: string]
  (let [run-roots (make [dynamic]u64)
        run-counts (make [dynamic]int)
        run-lows (make [dynamic]int)
        run-highs (make [dynamic]int)
        run-first-datoms (make [dynamic]Datom)
        run-last-datoms (make [dynamic]Datom)
        [runs-ok runs-error] (sqlite-index-run-manifest-child-runs-with-attr-bound-datoms-into! handle manifest-id attr (addr run-roots) (addr run-counts) (addr run-lows) (addr run-highs) (addr run-first-datoms) (addr run-last-datoms))]
    (when (not runs-ok)
      (delete run-roots)
      (delete run-counts)
      (delete run-lows)
      (delete run-highs)
      (delete-owned-datoms run-first-datoms)
      (delete-owned-datoms run-last-datoms)
      (return (make [dynamic]u64) (make [dynamic]int) (make [dynamic]int) (make [dynamic]int) (make [dynamic]Datom) (make [dynamic]Datom) false runs-error))
    (return run-roots run-counts run-lows run-highs run-first-datoms run-last-datoms true "")))

(defn sqlite-index-cursor-child-runs [cursor: ^SQLite-Index-Cursor] -> [roots: [dynamic]u64, counts: [dynamic]int, ok: bool, error: string]
  (if cursor^.root-is-manifest
    (sqlite-index-run-manifest-child-runs cursor^.handle cursor^.manifest-id)
    (sqlite-index-merge-root-child-runs cursor^.handle cursor^.root-id)))

(defn sqlite-index-cursor-init-merge-state! [cursor: ^SQLite-Index-Cursor] -> [ok: bool, error: string]
  (when (= cursor^.datom-stmt nil)
    (return false "sqlite merge index cursor was missing datom lookup statement"))
  (sqlite-index-cursor-clear-merge-state! cursor)
  (let [[roots counts runs-ok runs-error] (sqlite-index-cursor-child-runs cursor)]
    (when (not runs-ok)
      (delete roots)
      (delete counts)
      (return false runs-error))
    (delete cursor^.merge-roots)
    (delete cursor^.merge-counts)
    (set! cursor^.merge-roots roots)
    (set! cursor^.merge-counts counts)
    (for [child-index (arr.range 0 (count cursor^.merge-roots))]
      (arr.push! cursor^.merge-positions 0)
      (arr.push! cursor^.merge-loaded-pages (SQLite-Loaded-Index-Page {}))
      (arr.push! cursor^.merge-loaded-page-valid false)
      (if (> cursor^.merge-counts[child-index] 0)
        (let [[entry datom entry-ok entry-error] (sqlite-index-merge-child-entry-and-datom-at-cached cursor child-index 0)]
          (when (not entry-ok)
            (sqlite-index-cursor-clear-merge-state! cursor)
            (return false entry-error))
          (arr.push! cursor^.merge-current-datoms datom)
          (arr.push! cursor^.merge-current-entries entry)
          (arr.push! cursor^.merge-has-current true))
        (do
          (arr.push! cursor^.merge-current-datoms (Datom {}))
          (arr.push! cursor^.merge-current-entries 0)
          (arr.push! cursor^.merge-has-current false))))
    (set! cursor^.merge-ready true)
    (set! cursor^.merge-next-output 0)
    (return true "")))

(defn sqlite-index-cursor-produce-next-merge-entry! [cursor: ^SQLite-Index-Cursor] -> [entry: int, datom: Datom, ok: bool, error: string]
  (let [best-child -1
        best-entry 0]
    (for [child-index (arr.range 0 (count cursor^.merge-roots))]
      (when cursor^.merge-has-current[child-index]
        (if (= best-child -1)
          (do
            (set! best-child child-index)
            (set! best-entry cursor^.merge-current-entries[child-index]))
          (let [candidate-less (datom-less-order? cursor^.merge-current-datoms[child-index] cursor^.merge-current-datoms[best-child] cursor^.order-text cursor^.merge-current-entries[child-index] best-entry)]
            (when candidate-less
              (set! best-child child-index)
              (set! best-entry cursor^.merge-current-entries[child-index]))))))
    (when (= best-child -1)
      (return 0 (Datom {}) false "sqlite merge root page ended before expected row count"))
    (set! cursor^.merge-positions[best-child] (+ cursor^.merge-positions[best-child] 1))
    (let [out-datom cursor^.merge-current-datoms[best-child]]
    (set! cursor^.merge-has-current[best-child] false)
    (set! cursor^.merge-current-datoms[best-child] (Datom {}))
    (if (< cursor^.merge-positions[best-child] cursor^.merge-counts[best-child])
      (let [[next-entry next-datom next-ok next-error] (sqlite-index-merge-child-entry-and-datom-at-cached cursor best-child cursor^.merge-positions[best-child])]
        (when (not next-ok)
          (delete-owned-datom out-datom)
          (return 0 (Datom {}) false next-error))
        (set! cursor^.merge-current-datoms[best-child] next-datom)
        (set! cursor^.merge-current-entries[best-child] next-entry)
        (set! cursor^.merge-has-current[best-child] true))
      (set! cursor^.merge-has-current[best-child] false))
    (set! cursor^.merge-next-output (+ cursor^.merge-next-output 1))
      (return best-entry out-datom true ""))))

(defn sqlite-index-cursor-load-merge-page! [cursor: ^SQLite-Index-Cursor, page-start: int] -> [ok: bool, error: string]
  (let [page-end (min (+ page-start cursor^.page-size) cursor^.row-count)
        out (make [dynamic]int 0 (- page-end page-start))
        out-datoms (make [dynamic]Datom 0 (- page-end page-start))]
    (when (or (not cursor^.merge-ready)
              (> cursor^.merge-next-output page-start))
      (let [[init-ok init-error] (sqlite-index-cursor-init-merge-state! cursor)]
        (when (not init-ok)
          (delete out)
          (delete-owned-datoms out-datoms)
          (return false init-error))))
    (while (< cursor^.merge-next-output page-start)
      (let [[skipped-entry skipped-datom skipped-ok skipped-error] (sqlite-index-cursor-produce-next-merge-entry! cursor)]
        (discard skipped-entry)
        (delete-owned-datom skipped-datom)
        (when (not skipped-ok)
          (delete out)
          (delete-owned-datoms out-datoms)
          (return false skipped-error))))
    (while (< cursor^.merge-next-output page-end)
      (let [[entry datom entry-ok entry-error] (sqlite-index-cursor-produce-next-merge-entry! cursor)]
        (when (not entry-ok)
          (if (= entry-error "sqlite merge root page ended before expected row count")
            (break)
            (do
              (delete out)
              (delete-owned-datoms out-datoms)
              (return false entry-error))))
        (arr.push! out entry)
        (arr.push! out-datoms datom)))
    (let [loaded-page (sqlite-loaded-index-page-from-entries-and-datoms out out-datoms page-start (+ page-start (count out)))]
      (sqlite-index-page-cache-store! (addr cursor^.page-cache) cursor^.root-id cursor^.manifest-id page-start loaded-page)
      (release-sqlite-loaded-index-page! cursor^.page)
      (set! cursor^.page loaded-page))
    (return true "")))

(defn sqlite-index-cursor-load-page! [cursor: ^SQLite-Index-Cursor, offset: int] -> [ok: bool, error: string]
  (when (< offset 0)
    (return false "sqlite index cursor offset was negative"))
  (when (>= offset cursor^.row-count)
    (release-sqlite-loaded-index-page! cursor^.page)
    (set! cursor^.page (sqlite-loaded-index-page-empty cursor^.row-count))
    (return true ""))
  (when (and (>= offset cursor^.page.start)
             (< offset cursor^.page.end))
    (return true ""))
  (let [page-start (* (/ offset cursor^.page-size) cursor^.page-size)]
    (let [[cached-page cached?] (sqlite-index-page-cache-find-retained cursor^.page-cache cursor^.root-id cursor^.manifest-id page-start)]
      (when cached?
        (release-sqlite-loaded-index-page! cursor^.page)
        (set! cursor^.page cached-page)
        (return true "")))
    (when (or cursor^.root-is-merge cursor^.root-is-manifest)
      (return (sqlite-index-cursor-load-merge-page! cursor page-start)))
    (let [[window loaded-ok loaded-error] (sqlite-index-cursor-load-direct-root-window cursor page-start)]
      (when (not loaded-ok)
        (return false loaded-error))
      (let [page-end (min (+ page-start (count window)) cursor^.row-count)]
        (let [loaded-page (sqlite-loaded-index-page-from-entries window page-start page-end)]
          (sqlite-index-page-cache-store! (addr cursor^.page-cache) cursor^.root-id cursor^.manifest-id page-start loaded-page)
          (release-sqlite-loaded-index-page! cursor^.page)
          (set! cursor^.page loaded-page)))
      (return true ""))))

(defn sqlite-index-cursor-load-page-with-datoms! [cursor: ^SQLite-Index-Cursor, offset: int] -> [ok: bool, error: string]
  (when (< offset 0)
    (return false "sqlite index cursor offset was negative"))
  (when (>= offset cursor^.row-count)
    (release-sqlite-loaded-index-page! cursor^.page)
    (set! cursor^.page (sqlite-loaded-index-page-empty cursor^.row-count))
    (return true ""))
  (when (and (>= offset cursor^.page.start)
             (< offset cursor^.page.end)
             cursor^.page.has-datoms)
    (return true ""))
  (let [page-start (* (/ offset cursor^.page-size) cursor^.page-size)]
    (let [[cached-page cached?] (sqlite-index-page-cache-find-retained cursor^.page-cache cursor^.root-id cursor^.manifest-id page-start)]
      (when cached?
        (when cached-page.has-datoms
          (release-sqlite-loaded-index-page! cursor^.page)
          (set! cursor^.page cached-page)
          (return true ""))
        (release-sqlite-loaded-index-page! cached-page)))
    (when (or cursor^.root-is-merge cursor^.root-is-manifest)
      (let [[merge-ok merge-error] (sqlite-index-cursor-load-merge-page! cursor page-start)]
        (return merge-ok merge-error)))
    (when (not (and (>= offset cursor^.page.start)
                    (< offset cursor^.page.end)))
      (let [[page-ok page-error] (sqlite-index-cursor-load-page! cursor offset)]
        (when (not page-ok)
          (return false page-error))))
    (let [[loaded-page loaded-ok loaded-error] (sqlite-loaded-index-page-with-datoms cursor^.handle cursor^.datom-stmt (slice cursor^.page.entries 0) cursor^.page.start cursor^.page.end)]
      (when (not loaded-ok)
        (return false loaded-error))
      (sqlite-index-page-cache-store! (addr cursor^.page-cache) cursor^.root-id cursor^.manifest-id cursor^.page.start loaded-page)
      (release-sqlite-loaded-index-page! cursor^.page)
      (set! cursor^.page loaded-page)
      (return true ""))))

(defn sqlite-index-cursor-at [cursor: ^SQLite-Index-Cursor, index: int] -> [entry: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index cursor^.row-count))
    (return 0 false "sqlite index cursor position out of range"))
  (let [[page-ok page-error] (sqlite-index-cursor-load-page! cursor index)]
    (when (not page-ok)
      (return 0 false page-error))
    (let [offset (- index cursor^.page.start)]
      (when (or (< offset 0)
                (>= offset (count cursor^.page.entries)))
        (return 0 false "sqlite index cursor page did not contain requested position"))
      (return cursor^.page.entries[offset] true ""))))

(defn sqlite-index-cursor-datom-at [cursor: ^SQLite-Index-Cursor, index: int] -> [datom: Datom, ok: bool, error: string]
  (when (or (< index 0)
            (>= index cursor^.row-count))
    (return (Datom {}) false "sqlite index cursor datom position out of range"))
  (let [[page-ok page-error] (sqlite-index-cursor-load-page-with-datoms! cursor index)]
    (when (not page-ok)
      (return (Datom {}) false page-error))
    (let [offset (- index cursor^.page.start)]
      (when (or (< offset 0)
                (>= offset (count cursor^.page.datoms)))
        (return (Datom {}) false "sqlite index cursor datom page did not contain requested position"))
      (return (datom-owned cursor^.page.datoms[offset]) true ""))))

(defn sqlite-index-cursor-entry-offset-at [cursor: ^SQLite-Index-Cursor, index: int] -> [out-entry: int, out-offset: int, ok: bool, error: string]
  (when (or (< index 0)
            (>= index cursor^.row-count))
    (return 0 0 false "sqlite index cursor datom position out of range"))
  (let [[page-ok page-error] (sqlite-index-cursor-load-page-with-datoms! cursor index)]
    (when (not page-ok)
      (return 0 0 false page-error))
    (let [offset (- index cursor^.page.start)]
      (when (or (< offset 0)
                (>= offset (count cursor^.page.entries)))
        (return 0 0 false "sqlite index cursor page did not contain requested position"))
      (let [loaded-entry cursor^.page.entries[offset]]
        (when (or (< offset 0)
                  (>= offset (count cursor^.page.datoms)))
          (return 0 0 false "sqlite index cursor datom page did not contain requested position"))
        (return loaded-entry offset true "")))))

(defn sqlite-index-cursor-entry-and-datom-at [cursor: ^SQLite-Index-Cursor, index: int] -> [out-entry: int, datom: Datom, ok: bool, error: string]
  (let [[found-entry found-offset offset-ok offset-error] (sqlite-index-cursor-entry-offset-at cursor index)]
    (when (not offset-ok)
      (return 0 (Datom {}) false offset-error))
    (return found-entry (datom-owned cursor^.page.datoms[found-offset]) true "")))

(defn sqlite-index-cursor-clear-merge-state! [cursor: ^SQLite-Index-Cursor]
  (delete-active-datoms! (addr cursor^.merge-current-datoms) (addr cursor^.merge-has-current))
  (delete cursor^.merge-roots)
  (delete cursor^.merge-counts)
  (delete cursor^.merge-positions)
  (delete cursor^.merge-current-entries)
  (delete cursor^.merge-current-datoms)
  (delete cursor^.merge-has-current)
  (for [loaded-page page-index cursor^.merge-loaded-pages]
    (when cursor^.merge-loaded-page-valid[page-index]
      (release-sqlite-loaded-index-page! loaded-page)))
  (delete cursor^.merge-loaded-pages)
  (delete cursor^.merge-loaded-page-valid)
  (delete cursor^.merge-page0)
  (delete cursor^.merge-page1)
  (delete cursor^.merge-page2)
  (delete cursor^.merge-page3)
  (set! cursor^.merge-ready false)
  (set! cursor^.merge-next-output 0)
  (set! cursor^.merge-roots (make [dynamic]u64))
  (set! cursor^.merge-counts (make [dynamic]int))
  (set! cursor^.merge-positions (make [dynamic]int))
  (set! cursor^.merge-current-entries (make [dynamic]int))
  (set! cursor^.merge-current-datoms (make [dynamic]Datom))
  (set! cursor^.merge-has-current (make [dynamic]bool))
  (set! cursor^.merge-loaded-pages (make [dynamic]SQLite-Loaded-Index-Page))
  (set! cursor^.merge-loaded-page-valid (make [dynamic]bool))
  (set! cursor^.merge-page0 (make [dynamic]int))
  (set! cursor^.merge-page-start0 -1)
  (set! cursor^.merge-page-end0 -1)
  (set! cursor^.merge-page1 (make [dynamic]int))
  (set! cursor^.merge-page-start1 -1)
  (set! cursor^.merge-page-end1 -1)
  (set! cursor^.merge-page2 (make [dynamic]int))
  (set! cursor^.merge-page-start2 -1)
  (set! cursor^.merge-page-end2 -1)
  (set! cursor^.merge-page3 (make [dynamic]int))
  (set! cursor^.merge-page-start3 -1)
  (set! cursor^.merge-page-end3 -1))

(defn close-sqlite-index-cursor! [cursor: ^SQLite-Index-Cursor]
  (sqlite-index-cursor-clear-merge-state! cursor)
  (when (not (= cursor^.datom-stmt nil))
    (sqlite-finalize-stmt-raw cursor^.datom-stmt))
  (when (not (= cursor^.entry-page-stmt nil))
    (sqlite-finalize-stmt-raw cursor^.entry-page-stmt))
  (when cursor^.owns-handle
    (sqlite-close-live-raw cursor^.handle))
  (delete cursor^.index-name)
  (delete cursor^.root-first-key)
  (delete cursor^.order-text)
  (delete cursor^.direct-child-roots)
  (delete cursor^.direct-child-counts)
  (delete cursor^.entry-run-roots)
  (delete cursor^.entry-run-bases)
  (delete cursor^.entry-run-counts)
  (delete cursor^.entry-run-entry-payloads)
  (release-sqlite-loaded-index-page! cursor^.page)
  (release-sqlite-index-page-cache! cursor^.page-cache)
  (set! cursor^ (SQLite-Index-Cursor {})))

(defn close-sqlite-index-cursor [cursor: SQLite-Index-Cursor]
  (let [owned cursor]
    (close-sqlite-index-cursor! (addr owned))))

(defn sqlite-index-snapshot-cursor [snapshot: ^SQLite-Index-Snapshot, order: Public-Index-Order] -> ^SQLite-Index-Cursor
  (cond
    (= order .EAVT) (addr snapshot^.eavt)
    (= order .AEVT) (addr snapshot^.aevt)
    (= order .AVET) (addr snapshot^.avet)
    :else (addr snapshot^.vaet)))

(defn sqlite-index-snapshot-view [snapshot: ^SQLite-Index-Snapshot, order: Public-Index-Order] -> DB-Index-View
  (db-index-view-from-sqlite-cursor order (sqlite-index-snapshot-cursor snapshot order)))

(defn sqlite-index-snapshot-share-page-cache! [snapshot: ^SQLite-Index-Snapshot]
  (let [cache (sqlite-index-page-cache-empty)]
    (sqlite-index-cursor-use-page-cache! (addr snapshot^.eavt) cache)
    (sqlite-index-cursor-use-page-cache! (addr snapshot^.aevt) cache)
    (sqlite-index-cursor-use-page-cache! (addr snapshot^.avet) cache)
    (sqlite-index-cursor-use-page-cache! (addr snapshot^.vaet) cache)
    (release-sqlite-index-page-cache! cache)))

(defn sqlite-index-snapshot-use-page-cache! [snapshot: ^SQLite-Index-Snapshot, cache: SQLite-Index-Page-Cache]
  (sqlite-index-cursor-use-page-cache! (addr snapshot^.eavt) cache)
  (sqlite-index-cursor-use-page-cache! (addr snapshot^.aevt) cache)
  (sqlite-index-cursor-use-page-cache! (addr snapshot^.avet) cache)
  (sqlite-index-cursor-use-page-cache! (addr snapshot^.vaet) cache))

(defn sqlite-index-snapshot-page-cache-ref-count [snapshot: ^SQLite-Index-Snapshot] -> int
  (sqlite-index-page-cache-ref-count snapshot^.eavt.page-cache))

(defn sqlite-index-snapshot-page-cache-count [snapshot: ^SQLite-Index-Snapshot] -> int
  (sqlite-index-page-cache-count snapshot^.eavt.page-cache))

(defn sqlite-index-snapshot-page-cache-hit-count [snapshot: ^SQLite-Index-Snapshot] -> int
  (sqlite-index-page-cache-hit-count snapshot^.eavt.page-cache))

(defn sqlite-index-snapshot-page-cache-miss-count [snapshot: ^SQLite-Index-Snapshot] -> int
  (sqlite-index-page-cache-miss-count snapshot^.eavt.page-cache))

(defn sqlite-index-snapshot-datom-at-log-index [snapshot: ^SQLite-Index-Snapshot, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw snapshot^.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
    (let [[value read-error read-ok] (edn.try-read text)]
      (when (not read-ok)
        (return (Datom {}) false read-error.message))
      (let [doc (edn-doc-from-data value)]
        (defer (delete doc.nodes))
        (datom-from-edn-node doc doc.root)))))

(defn sqlite-open-index-snapshot-handle [handle: rawptr, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Snapshot {}) false "sqlite index snapshot page size must be positive"))
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return (SQLite-Index-Snapshot {}) false basis-error))
    (sqlite-open-index-snapshot-handle-at-basis handle basis page-size)))

(defn sqlite-open-index-snapshot-handle-at-basis [handle: rawptr, basis-tx: u64, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Snapshot {}) false "sqlite index snapshot page size must be positive"))
  (let [[eavt eavt-ok eavt-error] (sqlite-open-index-cursor-handle-at-basis handle ":eavt" basis-tx page-size)]
    (when (not eavt-ok)
      (return (SQLite-Index-Snapshot {}) false eavt-error))
    (let [[aevt aevt-ok aevt-error] (sqlite-open-index-cursor-handle-at-basis handle ":aevt" basis-tx page-size)]
      (when (not aevt-ok)
        (close-sqlite-index-cursor eavt)
        (return (SQLite-Index-Snapshot {}) false aevt-error))
      (let [[avet avet-ok avet-error] (sqlite-open-index-cursor-handle-at-basis handle ":avet" basis-tx page-size)]
        (when (not avet-ok)
          (close-sqlite-index-cursor eavt)
          (close-sqlite-index-cursor aevt)
          (return (SQLite-Index-Snapshot {}) false avet-error))
        (let [[vaet vaet-ok vaet-error] (sqlite-open-index-cursor-handle-at-basis handle ":vaet" basis-tx page-size)]
          (when (not vaet-ok)
            (close-sqlite-index-cursor eavt)
            (close-sqlite-index-cursor aevt)
            (close-sqlite-index-cursor avet)
            (return (SQLite-Index-Snapshot {}) false vaet-error))
          (let [opened-indexes (SQLite-Index-Snapshot {handle: handle
                                                       owns-handle: false
                                                       page-size: page-size
                                                       eavt: eavt
                                                       aevt: aevt
                                                       avet: avet
                                                       vaet: vaet})]
            (sqlite-index-snapshot-share-page-cache! (addr opened-indexes))
            (return opened-indexes true "")))))))

(defn sqlite-open-index-snapshot-handle-at-root-set [handle: rawptr, basis-tx: u64, roots: SQLite-Index-Root-Set, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (when (<= page-size 0)
    (return (SQLite-Index-Snapshot {}) false "sqlite index snapshot page size must be positive"))
  (let [[eavt eavt-ok eavt-error] (sqlite-open-index-cursor-handle-at-root-page handle ":eavt" basis-tx roots.eavt page-size)]
    (when (not eavt-ok)
      (return (SQLite-Index-Snapshot {}) false eavt-error))
    (let [[aevt aevt-ok aevt-error] (sqlite-open-index-cursor-handle-at-root-page handle ":aevt" basis-tx roots.aevt page-size)]
      (when (not aevt-ok)
        (close-sqlite-index-cursor eavt)
        (return (SQLite-Index-Snapshot {}) false aevt-error))
      (let [[avet avet-ok avet-error] (sqlite-open-index-cursor-handle-at-root-page handle ":avet" basis-tx roots.avet page-size)]
        (when (not avet-ok)
          (close-sqlite-index-cursor eavt)
          (close-sqlite-index-cursor aevt)
          (return (SQLite-Index-Snapshot {}) false avet-error))
        (let [[vaet vaet-ok vaet-error] (sqlite-open-index-cursor-handle-at-root-page handle ":vaet" basis-tx roots.vaet page-size)]
          (when (not vaet-ok)
            (close-sqlite-index-cursor eavt)
            (close-sqlite-index-cursor aevt)
            (close-sqlite-index-cursor avet)
            (return (SQLite-Index-Snapshot {}) false vaet-error))
          (let [opened-indexes (SQLite-Index-Snapshot {handle: handle
                                                       owns-handle: false
                                                       page-size: page-size
                                                       eavt: eavt
                                                       aevt: aevt
                                                       avet: avet
                                                       vaet: vaet})]
            (sqlite-index-snapshot-share-page-cache! (addr opened-indexes))
            (return opened-indexes true "")))))))

(defn sqlite-conn-open-index-snapshot [store: ^SQLite-Conn, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (sqlite-open-index-snapshot-handle store^.handle page-size))

(defn sqlite-open-index-snapshot [path: string, page-size: int] -> [snapshot: SQLite-Index-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-Index-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-index-snapshot-handle handle page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.owns-handle true)
      (return opened-snapshot true ""))))

(defn close-sqlite-index-snapshot! [snapshot: ^SQLite-Index-Snapshot]
  (close-sqlite-index-cursor! (addr snapshot^.eavt))
  (close-sqlite-index-cursor! (addr snapshot^.aevt))
  (close-sqlite-index-cursor! (addr snapshot^.avet))
  (close-sqlite-index-cursor! (addr snapshot^.vaet))
  (when snapshot^.owns-handle
    (sqlite-close-live-raw snapshot^.handle))
  (set! snapshot^ (SQLite-Index-Snapshot {})))

(defn close-sqlite-index-snapshot [snapshot: SQLite-Index-Snapshot]
  (let [owned snapshot]
    (close-sqlite-index-snapshot! (addr owned))))

(defn sqlite-db-snapshot-index-view [snapshot: ^SQLite-DB-Snapshot, order: Public-Index-Order] -> DB-Index-View
  (sqlite-index-snapshot-view (addr snapshot^.indexes) order))

(defn datom-from-owned-serial-text [text: string] -> [datom: Datom, ok: bool, error: string]
  (let [[value read-error read-ok] (edn.try-read text)]
    (when (not read-ok)
      (return (Datom {}) false read-error.message))
    (let [doc (edn-doc-from-data value)]
      (defer (delete doc.nodes))
      (datom-from-edn-node doc doc.root))))

(defn serialized-simple-string-value [text: string] -> [value: Value, ok: bool, matched: bool, error: string]
  (let [n (kstr.count text)]
    (when (or (< n 2)
              (not (= (kstr.get text 0) 34))
              (not (= (kstr.get text (- n 1)) 34)))
      (return (Value {}) false false ""))
    (let [cursor 1
          escaped false]
      (while (< cursor (- n 1))
        (let [ch (kstr.get text cursor)]
          (cond
            (= ch 34) (return (Value {}) false true "unexpected quote in serialized string value")
            (= ch 92)
              (do
                (set! escaped true)
                (set! cursor (+ cursor 2)))
            :else
              (set! cursor (+ cursor 1)))))
      (when (> cursor (- n 1))
        (return (Value {}) false true "unterminated escape in serialized string value"))
      (let [body (kstr.slice text 1 (- n 1))]
        (if escaped
          (return (value-string (kstr.unescape body)) true true "")
          (return (value-string (string-owned body)) true true ""))))))

(defn serialized-simple-entity-value [text: string] -> [value: Value, ok: bool, matched: bool, error: string]
  (let [prefix "[:vev/entity "
        suffix "]"
        n (kstr.count text)
        prefix-n (kstr.count prefix)]
    (when (not (and (storage-string-starts-with? text prefix)
                    (> n (+ prefix-n (kstr.count suffix)))
                    (= (kstr.get text (- n 1)) 93)))
      (return (Value {}) false false ""))
    (let [payload (kstr.slice text prefix-n (- n 1))
          [parsed parsed-ok] (strconv.parse_int payload)]
      (if (and parsed-ok (>= parsed 0))
        (return (value-entity (u64 parsed)) true true "")
        (return (Value {}) false true "invalid serialized entity value")))))

(defn serialized-simple-float-value [text: string] -> [value: Value, ok: bool, matched: bool, error: string]
  (let [prefix "[:vev/float \""
        n (kstr.count text)
        prefix-n (kstr.count prefix)]
    (when (not (and (storage-string-starts-with? text prefix)
                    (> n (+ prefix-n 2))
                    (= (kstr.get text (- n 2)) 34)
                    (= (kstr.get text (- n 1)) 93)))
      (return (Value {}) false false ""))
    (let [payload (kstr.slice text prefix-n (- n 2))
          [parsed parsed-ok] (serializable-float-from-text payload)]
      (if parsed-ok
        (return (value-float parsed) true true "")
        (return (Value {}) false true "invalid serialized float value")))))

(defn serialized-simple-value [text: string] -> [value: Value, ok: bool, matched: bool, error: string]
  (cond
    (= text "nil") (return (value-nil) true true "")
    (= text "true") (return (value-bool true) true true "")
    (= text "false") (return (value-bool false) true true "")
    (storage-string-starts-with? text "\"") (serialized-simple-string-value text)
    (storage-string-starts-with? text ":") (return (value-keyword (string-owned text)) true true "")
    (storage-string-starts-with? text "[:vev/entity ") (serialized-simple-entity-value text)
    (storage-string-starts-with? text "[:vev/float \"") (serialized-simple-float-value text)
    (edn-int-token? text)
      (let [[parsed parsed-ok] (strconv.parse_int text)]
        (if parsed-ok
          (return (value-int (i64 parsed)) true true "")
          (return (Value {}) false false "")))
    :else
      (return (Value {}) false false "")))

(defn value-from-owned-serial-text [text: string] -> [value: Value, ok: bool, error: string]
  (let [[simple simple-ok simple-matched simple-error] (serialized-simple-value text)]
    (when simple-matched
      (return simple simple-ok simple-error)))
  (let [[parsed-data read-error read-ok] (edn.try-read text)]
    (when (not read-ok)
      (return (Value {}) false read-error.message))
    (let [doc (edn-doc-from-data parsed-data)]
      (defer (delete doc.nodes))
      (let [[parsed-value parsed-ok parsed-error] (serial-value-from-edn-node doc doc.root)]
        (when (not parsed-ok)
          (return (Value {}) false parsed-error))
        (let [owned-value (value-owned parsed-value)]
          (delete-value-containers-shallow parsed-value)
          (return owned-value true ""))))))

(defn sqlite-db-snapshot-datom-at-log-index [snapshot: ^SQLite-DB-Snapshot, log-index: int] -> [datom: Datom, ok: bool, error: string]
  (let [[cached cached?] (sqlite-db-snapshot-cache-find-datom snapshot log-index)]
    (when cached?
      (return cached true "")))
  (if (not (= snapshot^.datom-stmt nil))
    (let [[entity attr value-text tx added loaded-ok loaded-error] (sqlite-step-prepared-datom-by-log-index-parts-raw snapshot^.indexes.handle snapshot^.datom-stmt (i64 log-index))]
      (when (not loaded-ok)
        (return (Datom {}) false loaded-error))
      (defer (delete value-text))
      (let [[value value-ok value-error] (value-from-owned-serial-text value-text)]
        (when (not value-ok)
          (delete attr)
          (return (Datom {}) false value-error))
        (let [loaded (Datom {e: entity a: attr v: value tx: tx added: added})]
          (sqlite-db-snapshot-cache-store-datom! snapshot log-index loaded)
          (return loaded true ""))))
    (let [[text loaded-ok loaded-error] (sqlite-load-datom-by-log-index-text-raw snapshot^.indexes.handle (i64 log-index))]
    (when (not loaded-ok)
      (return (Datom {}) false loaded-error))
    (defer (delete text))
      (let [[loaded parsed-ok parsed-error] (datom-from-owned-serial-text text)]
        (when parsed-ok
          (sqlite-db-snapshot-cache-store-datom! snapshot log-index loaded))
        (return loaded parsed-ok parsed-error)))))

(defn sqlite-db-snapshot-eavt-entity-bound [snapshot: ^SQLite-DB-Snapshot, entity: u64, upper: bool] -> [position: int, ok: bool, error: string]
  (let [view (sqlite-db-snapshot-index-view snapshot .EAVT)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            log-index (db-index-view-at view mid)
            [datom-entity entity-ok entity-error] (sqlite-load-datom-entity-by-log-index-handle-stmt snapshot^.indexes.handle snapshot^.datom-stmt log-index)]
        (when (not entity-ok)
          (return low false entity-error))
        (if (if upper (<= datom-entity entity) (< datom-entity entity))
          (set! low (+ mid 1))
          (set! high mid))))
    (return low true "")))

(defn sqlite-db-snapshot-eavt-entity-range [snapshot: ^SQLite-DB-Snapshot, entity: u64] -> [low: int, high: int, ok: bool, error: string]
  (let [[range-low low-ok low-error] (sqlite-db-snapshot-eavt-entity-bound snapshot entity false)]
    (when (not low-ok)
      (return range-low range-low false low-error))
    (let [[range-high high-ok high-error] (sqlite-db-snapshot-eavt-entity-bound snapshot entity true)]
      (return range-low range-high high-ok high-error))))

(defn sqlite-db-snapshot-entity-datoms [snapshot: ^SQLite-DB-Snapshot, entity: u64] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-eavt-entity-range snapshot entity)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom 0 (- high low))
          view (sqlite-db-snapshot-index-view snapshot .EAVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (arr.push! out datom)))
      (return out true ""))))

(defn sqlite-db-snapshot-aevt-attr-bound [snapshot: ^SQLite-DB-Snapshot, attr: string, upper: bool] -> [position: int, ok: bool, error: string]
  (let [view (sqlite-db-snapshot-index-view snapshot .AEVT)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            log-index (db-index-view-at view mid)
            [datom-attr attr-ok attr-error] (sqlite-load-datom-attr-by-log-index-handle-stmt snapshot^.indexes.handle snapshot^.datom-stmt log-index)]
        (when (not attr-ok)
          (return low false attr-error))
        (let [compare (strings.compare datom-attr attr)]
          (delete datom-attr)
          (if (if upper (<= compare 0) (< compare 0))
            (set! low (+ mid 1))
            (set! high mid)))))
    (return low true "")))

(defn sqlite-db-snapshot-aevt-attr-range [snapshot: ^SQLite-DB-Snapshot, attr: string] -> [low: int, high: int, ok: bool, error: string]
  (let [[range-low low-ok low-error] (sqlite-db-snapshot-aevt-attr-bound snapshot attr false)]
    (when (not low-ok)
      (return range-low range-low false low-error))
    (let [[range-high high-ok high-error] (sqlite-db-snapshot-aevt-attr-bound snapshot attr true)]
      (return range-low range-high high-ok high-error))))

(defn sqlite-db-snapshot-attr-datoms [snapshot: ^SQLite-DB-Snapshot, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-aevt-attr-range snapshot attr)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom 0 (- high low))
          view (sqlite-db-snapshot-index-view snapshot .AEVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (arr.push! out datom)))
      (return out true ""))))

(defn sqlite-db-snapshot-attr-string-contains-datoms [snapshot: ^SQLite-DB-Snapshot, attr: string, search: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[term-entities term-attrs term-value-texts term-txs term-added term-loaded-ok _term-loaded-error] (sqlite_attr_string_term_datom_parts_raw snapshot^.indexes.handle attr search)
        entities (make [dynamic]u64)
        attrs (make [dynamic]string)
        value-texts (make [dynamic]string)
        txs (make [dynamic]u64)
        added (make [dynamic]bool)
        loaded-ok false
        loaded-error ""]
    (if term-loaded-ok
      (do
        (delete entities)
        (delete attrs)
        (delete value-texts)
        (delete txs)
        (delete added)
        (set! entities term-entities)
        (set! attrs term-attrs)
        (set! value-texts term-value-texts)
        (set! txs term-txs)
        (set! added term-added)
        (set! loaded-ok true))
      (do
        (delete term-entities)
        (delete-owned-strings-array term-attrs)
        (delete-owned-strings-array term-value-texts)
        (delete term-txs)
        (delete term-added)
        (let [[fts-entities fts-attrs fts-value-texts fts-txs fts-added fts-loaded-ok _fts-loaded-error] (sqlite_attr_string_fts_datom_parts_raw snapshot^.indexes.handle attr search)]
          (if fts-loaded-ok
            (do
              (delete entities)
              (delete attrs)
              (delete value-texts)
              (delete txs)
              (delete added)
              (set! entities fts-entities)
              (set! attrs fts-attrs)
              (set! value-texts fts-value-texts)
              (set! txs fts-txs)
              (set! added fts-added)
              (set! loaded-ok true))
            (do
              (delete fts-entities)
              (delete-owned-strings-array fts-attrs)
              (delete-owned-strings-array fts-value-texts)
              (delete fts-txs)
              (delete fts-added)
              (let [[scan-entities scan-attrs scan-value-texts scan-txs scan-added scan-loaded-ok scan-loaded-error] (sqlite_attr_string_contains_datom_parts_raw snapshot^.indexes.handle attr search)]
                (delete entities)
                (delete attrs)
                (delete value-texts)
                (delete txs)
                (delete added)
                (set! entities scan-entities)
                (set! attrs scan-attrs)
                (set! value-texts scan-value-texts)
                (set! txs scan-txs)
                (set! added scan-added)
                (set! loaded-ok scan-loaded-ok)
                (set! loaded-error scan-loaded-error)))))))
    (let [
        datoms (make [dynamic]Datom 0 (count entities))]
    (defer (delete entities))
    (let [moved-attrs (arr.repeat (count attrs) false)]
      (defer (delete-owned-strings-array-with-moved attrs moved-attrs))
      (defer (delete-owned-strings-array value-texts))
      (defer (delete txs))
      (defer (delete added))
      (when (not loaded-ok)
        (delete-owned-datoms datoms)
        (return (make [dynamic]Datom) false loaded-error))
      (for [_ index entities]
        (when (or (>= index (count attrs))
                  (>= index (count value-texts))
                  (>= index (count txs))
                  (>= index (count added)))
          (delete-owned-datoms datoms)
          (return (make [dynamic]Datom) false "sqlite attr string contains datom parts were uneven"))
        (let [[value value-ok value-error] (value-from-owned-serial-text value-texts[index])]
          (when (not value-ok)
            (delete-owned-datoms datoms)
            (return (make [dynamic]Datom) false value-error))
          (set! moved-attrs[index] true)
          (arr.push! datoms (Datom {e: entities[index]
                                    a: attrs[index]
                                    v: value
                                    tx: txs[index]
                                    added: added[index]}))))
      (return datoms true "")))))

(defn sqlite-db-snapshot-entity-attr-datoms [snapshot: ^SQLite-DB-Snapshot, entity: u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[low high range-ok range-error] (sqlite-db-snapshot-eavt-entity-range snapshot entity)]
    (when (not range-ok)
      (return (make [dynamic]Datom) false range-error))
    (let [out (make [dynamic]Datom)
          view (sqlite-db-snapshot-index-view snapshot .EAVT)]
      (for [pos (arr.range low high)]
        (let [log-index (db-index-view-at view pos)
              [datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index snapshot log-index)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (if (= datom.a attr)
            (arr.push! out datom)
            (delete-owned-datom datom))))
      (return out true ""))))

(defn sqlite-open-db-snapshot-handle [handle: rawptr, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[basis basis-ok basis-error] (sqlite-latest-index-root-basis-raw handle)]
    (when (not basis-ok)
      (return (SQLite-DB-Snapshot {}) false basis-error))
    (sqlite-open-db-snapshot-handle-at-basis handle basis page-size)))

(defn sqlite-open-db-snapshot-handle-at-basis-known-log [handle: rawptr, basis-tx: u64, page-size: int, datom-count: u64, has-retractions: bool] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
      (let [[root-row-id root-ok root-error] (sqlite-index-root-row-id-at-basis handle basis-tx)]
        (when (not root-ok)
          (return (SQLite-DB-Snapshot {}) false root-error))
      (let [[indexes indexes-ok indexes-error] (sqlite-open-index-snapshot-handle-at-basis handle basis-tx page-size)]
        (when (not indexes-ok)
          (return (SQLite-DB-Snapshot {}) false indexes-error))
        (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
          (when (not datom-stmt-ok)
            (close-sqlite-index-snapshot indexes)
            (return (SQLite-DB-Snapshot {}) false datom-stmt-error))
        (return (SQLite-DB-Snapshot {indexes: indexes
                                     datom-stmt: datom-stmt
                                     datom-cache-log-indexes: (sqlite-db-snapshot-empty-datom-cache-log-indexes)
                                     datom-cache-valids: (sqlite-db-snapshot-empty-datom-cache-valids)
                                     datom-cache-datoms: (sqlite-db-snapshot-empty-datom-cache-datoms)
                                     basis-tx: basis-tx
                                     root-row-id: root-row-id
                                     datom-count: (int datom-count)
                                     has-retractions: has-retractions})
                true
                "")))))

(defn sqlite-open-db-snapshot-handle-at-root-set-known-log [handle: rawptr, published: SQLite-Durable-Published-Root, page-size: int, datom-count: u64, has-retractions: bool] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
      (let [basis-tx (if (> published.basis-tx 0) published.basis-tx published.root-row-id)
            [indexes indexes-ok indexes-error] (sqlite-open-index-snapshot-handle-at-root-set handle basis-tx published.roots page-size)]
        (when (not indexes-ok)
          (return (SQLite-DB-Snapshot {}) false indexes-error))
        (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
          (when (not datom-stmt-ok)
            (close-sqlite-index-snapshot indexes)
            (return (SQLite-DB-Snapshot {}) false datom-stmt-error))
        (return (SQLite-DB-Snapshot {indexes: indexes
                                     datom-stmt: datom-stmt
                                     datom-cache-log-indexes: (sqlite-db-snapshot-empty-datom-cache-log-indexes)
                                     datom-cache-valids: (sqlite-db-snapshot-empty-datom-cache-valids)
                                     datom-cache-datoms: (sqlite-db-snapshot-empty-datom-cache-datoms)
                                     basis-tx: basis-tx
                                     root-row-id: published.root-row-id
                                     datom-count: (int datom-count)
                                     has-retractions: has-retractions})
                true
                ""))))

(defn sqlite-open-db-snapshot-handle-at-root-set [handle: rawptr, published: SQLite-Durable-Published-Root, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
      (let [basis-tx (if (> published.basis-tx 0) published.basis-tx published.root-row-id)
            [indexes indexes-ok indexes-error] (sqlite-open-index-snapshot-handle-at-root-set handle basis-tx published.roots page-size)]
        (when (not indexes-ok)
          (return (SQLite-DB-Snapshot {}) false indexes-error))
        (let [[datom-stmt datom-stmt-ok datom-stmt-error] (sqlite-prepare-datom-by-log-index-raw handle)]
          (when (not datom-stmt-ok)
            (close-sqlite-index-snapshot indexes)
            (return (SQLite-DB-Snapshot {}) false datom-stmt-error))
          (let [[has-retractions retractions-ok retractions-error] (sqlite-datom-has-retractions-raw handle)]
            (when (not retractions-ok)
              (sqlite-finalize-stmt-raw datom-stmt)
              (close-sqlite-index-snapshot indexes)
              (return (SQLite-DB-Snapshot {}) false retractions-error))
            (return (SQLite-DB-Snapshot {indexes: indexes
                                         datom-stmt: datom-stmt
                                         datom-cache-log-indexes: (sqlite-db-snapshot-empty-datom-cache-log-indexes)
                                         datom-cache-valids: (sqlite-db-snapshot-empty-datom-cache-valids)
                                         datom-cache-datoms: (sqlite-db-snapshot-empty-datom-cache-datoms)
                                         basis-tx: basis-tx
                                         root-row-id: published.root-row-id
                                         datom-count: indexes.eavt.row-count
                                         has-retractions: has-retractions})
                    true
                    "")))))

(defn sqlite-open-db-snapshot-handle-at-basis [handle: rawptr, basis-tx: u64, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
    (let [[datom-count datom-count-ok datom-count-error] (sqlite-datom-count-raw handle)]
      (when (not datom-count-ok)
        (return (SQLite-DB-Snapshot {}) false datom-count-error))
      (let [[has-retractions retractions-ok retractions-error] (sqlite-datom-has-retractions-raw handle)]
        (when (not retractions-ok)
          (return (SQLite-DB-Snapshot {}) false retractions-error))
        (sqlite-open-db-snapshot-handle-at-basis-known-log handle basis-tx page-size datom-count has-retractions))))

(defn sqlite-conn-current-root-basis [store: ^SQLite-Conn] -> [basis: u64, ok: bool, error: string]
  (when store^.write-state-cache-valid
    (when (> store^.write-state-cache.conn.next-tx 0)
      (return (- store^.write-state-cache.conn.next-tx 1) true "")))
  (sqlite-latest-index-root-basis-raw store^.handle))

(defn sqlite-conn-open-db-snapshot [store: ^SQLite-Conn, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[basis basis-ok basis-error] (sqlite-conn-current-root-basis store)]
    (when (not basis-ok)
      (return (SQLite-DB-Snapshot {}) false basis-error))
    (let [[datom-count has-retractions log-ok log-error] (sqlite-conn-datom-count-and-retractions store)]
      (when (not log-ok)
        (return (SQLite-DB-Snapshot {}) false log-error))
      (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-basis-known-log store^.handle basis page-size datom-count has-retractions)]
        (when snapshot-ok
          (set! opened-snapshot.path (string-owned store^.path)))
        (return opened-snapshot snapshot-ok snapshot-error)))))

(def sqlite-db-source-default-page-size 512)

(defn query-result-owned-copy [result: Query-Result] -> Query-Result
  (when (query-result-owns-values? result)
    (return result))
  (let [owned (query-result-owned-values (result-set-owned result.result))]
    (delete-query-result result)
    owned))

(defn q-result-sqlite-conn-text [store: ^SQLite-Conn, text: string] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-cached store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-text-owned (addr snapshot) text)]
      (close-store-db! (addr snapshot))
      result)))

(defn q-result-sqlite-conn-text-with-input-text [store: ^SQLite-Conn, text: string, inputs-text: string] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-cached store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-text-owned-with-input-text (addr snapshot) text inputs-text)]
      (close-store-db! (addr snapshot))
      result)))

(defn q-result-sqlite-conn-prepared [store: ^SQLite-Conn, prepared: Prepared-Query] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-cached store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-prepared-owned (addr snapshot) prepared)]
      (close-store-db! (addr snapshot))
      result)))

(defn q-result-sqlite-conn-prepared-with-input-text [store: ^SQLite-Conn, prepared: Prepared-Query, inputs-text: string] -> Query-Result
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-cached store)]
    (when (not snapshot-ok)
      (return (query-result-owned-values (result-set-error snapshot-error))))
    (let [result (q-result-store-db-prepared-owned-with-input-text (addr snapshot) prepared inputs-text)]
      (close-store-db! (addr snapshot))
      result)))

(defn sqlite-store-db-current-root-cached [store: ^SQLite-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (when store^.resident-loaded
    (return (sqlite-store-db store)))
  (let [[basis basis-ok basis-error] (sqlite-conn-current-root-basis store)]
    (when (not basis-ok)
      (return (sqlite-store-db store)))
    (when (and store^.current-root-cache-valid
               (= store^.current-root-cache-basis basis))
      (return (sqlite-root-store-db-with-cache store^.path store^.current-root-cache-published store^.current-root-cache-page-cache) true ""))
    (let [[roots roots-ok roots-error] (sqlite-index-root-set-at-basis store^.handle basis)]
      (when (not roots-ok)
        (return (sqlite-store-db store)))
      (let [[root-row-id row-ok _row-error] (sqlite-index-root-row-id-at-basis store^.handle basis)]
        (when (not row-ok)
          (return (sqlite-store-db store)))
        (sqlite-conn-invalidate-current-root-cache! store)
        (let [published (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                                         basis-tx: basis
                                                         roots: roots
                                                         modes: (SQLite-Index-Append-Modes {})})
              cache (sqlite-index-page-cache-empty)]
          (set! store^.current-root-cache-basis basis)
          (set! store^.current-root-cache-published published)
          (set! store^.current-root-cache-page-cache cache)
          (set! store^.current-root-cache-valid true)
          (return (sqlite-root-store-db-with-cache store^.path published cache) true ""))))))

(defn sqlite-store-db [store: ^SQLite-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [[sqlite-snapshot snapshot-ok snapshot-error] (sqlite-conn-open-db-snapshot store sqlite-db-source-default-page-size)]
    (if snapshot-ok
      (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: sqlite-snapshot}) true "")
      (return (Store-DB {}) false snapshot-error))))

(defn sqlite-lazy-store-db-at-basis [path: string, basis-tx: u64] -> Store-DB
  (Store-DB {kind: .SQLite-Lazy-Snapshot
             sqlite-lazy-path: (string-owned path)
             sqlite-lazy-basis-tx: basis-tx}))

(defn sqlite-root-store-db [path: string, published: SQLite-Durable-Published-Root] -> Store-DB
  (Store-DB {kind: .SQLite-Root-Snapshot
             sqlite-root-path: (string-owned path)
             sqlite-root-published: published
             sqlite-root-page-cache: (sqlite-index-page-cache-empty)}))

(defn sqlite-root-store-db-with-cache [path: string, published: SQLite-Durable-Published-Root, cache: SQLite-Index-Page-Cache] -> Store-DB
  (Store-DB {kind: .SQLite-Root-Snapshot
             sqlite-root-path: (string-owned path)
             sqlite-root-published: published
             sqlite-root-page-cache: (retain-sqlite-index-page-cache cache)}))

(defn sqlite-conn-open-root-store-db-with-live-handle [store: ^SQLite-Conn, snapshot: ^Store-DB] -> [opened: Store-DB, ok: bool, error: string]
  (when (not (= snapshot^.kind .SQLite-Root-Snapshot))
    (return (retain-store-db snapshot^) true ""))
  (let [[datom-count has-retractions log-ok log-error] (sqlite-conn-datom-count-and-retractions store)]
    (when (not log-ok)
      (return (Store-DB {}) false log-error))
    (let [[sqlite-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-root-set-known-log
                                                         store^.handle
                                                         snapshot^.sqlite-root-published
                                                         sqlite-db-source-default-page-size
                                                         datom-count
                                                         has-retractions)]
      (when (not snapshot-ok)
        (return (Store-DB {}) false snapshot-error))
      (sqlite-index-snapshot-use-page-cache! (addr sqlite-snapshot.indexes) snapshot^.sqlite-root-page-cache)
      (set! sqlite-snapshot.path (string-owned store^.path))
      (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: sqlite-snapshot}) true ""))))

(defn sqlite-store-db-current-root-open-cached [store: ^SQLite-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [[root root-ok root-error] (sqlite-store-db-current-root-cached store)]
    (when (not root-ok)
      (return root false root-error))
    (let [[opened opened-ok opened-error] (sqlite-conn-open-root-store-db-with-live-handle store (addr root))]
      (close-store-db root)
      (return opened opened-ok opened-error))))

(defn sqlite-root-store-db-from-open-snapshot [snapshot: SQLite-DB-Snapshot] -> [store-db: Store-DB, ok: bool]
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot snapshot)]
    (if root-ok
      (return (Store-DB {kind: .SQLite-Root-Snapshot
                         sqlite-root-path: root-path
                         sqlite-root-published: root-published
                         sqlite-root-page-cache: root-cache})
              true)
      (return (Store-DB {}) false))))

(defn sqlite-root-fields-from-open-snapshot [snapshot: SQLite-DB-Snapshot] -> [path: string, published: SQLite-Durable-Published-Root, cache: SQLite-Index-Page-Cache, ok: bool]
  (when (= snapshot.path "")
    (return "" (SQLite-Durable-Published-Root {}) (SQLite-Index-Page-Cache {}) false))
  (when (= snapshot.root-row-id 0)
    (return "" (SQLite-Durable-Published-Root {}) (SQLite-Index-Page-Cache {}) false))
  (when (or (= snapshot.indexes.eavt.root-id 0)
            (= snapshot.indexes.aevt.root-id 0)
            (= snapshot.indexes.avet.root-id 0)
            (= snapshot.indexes.vaet.root-id 0))
      (return "" (SQLite-Durable-Published-Root {}) (SQLite-Index-Page-Cache {}) false))
  (let [roots (SQLite-Index-Root-Set {eavt: (SQLite-Index-Root-Page {root-id: snapshot.indexes.eavt.root-id
                                                                     manifest-id: snapshot.indexes.eavt.manifest-id})
                                      aevt: (SQLite-Index-Root-Page {root-id: snapshot.indexes.aevt.root-id
                                                                     manifest-id: snapshot.indexes.aevt.manifest-id})
                                      avet: (SQLite-Index-Root-Page {root-id: snapshot.indexes.avet.root-id
                                                                     manifest-id: snapshot.indexes.avet.manifest-id})
                                      vaet: (SQLite-Index-Root-Page {root-id: snapshot.indexes.vaet.root-id
                                                                     manifest-id: snapshot.indexes.vaet.manifest-id})})
        published-root (SQLite-Durable-Published-Root {root-row-id: snapshot.root-row-id
                                                       basis-tx: snapshot.basis-tx
                                                       roots: roots
                                                       modes: (SQLite-Index-Append-Modes {})})]
    (return (string-owned snapshot.path) published-root (retain-sqlite-index-page-cache snapshot.indexes.eavt.page-cache) true)))

(defn sqlite-root-store-db-at-basis-or-lazy [path: string, basis-tx: u64] -> Store-DB
  (let [[handle open-ok _open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (sqlite-lazy-store-db-at-basis path basis-tx)))
    (let [[roots roots-ok _roots-error] (sqlite-index-root-set-at-basis handle basis-tx)
          [root-row-id row-ok _row-error] (sqlite-index-root-row-id-at-basis handle basis-tx)]
      (sqlite-close-live-raw handle)
      (if (and roots-ok row-ok)
        (sqlite-root-store-db path (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                                                   basis-tx: basis-tx
                                                                   roots: roots
                                                                   modes: (SQLite-Index-Append-Modes {})}))
        (sqlite-lazy-store-db-at-basis path basis-tx)))))

(defn store-db-sqlite-page-cache-count [snapshot: ^Store-DB] -> int
  (case snapshot^.kind
    .SQLite-Root-Snapshot (sqlite-index-page-cache-count snapshot^.sqlite-root-page-cache)
    .SQLite-Tx-Ops-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Log-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Snapshot (sqlite-index-snapshot-page-cache-count (addr snapshot^.sqlite-snapshot.indexes))
     0))

(defn store-db-sqlite-page-cache-ref-count [snapshot: ^Store-DB] -> int
  (case snapshot^.kind
    .SQLite-Root-Snapshot (sqlite-index-page-cache-ref-count snapshot^.sqlite-root-page-cache)
    .SQLite-Tx-Ops-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-ref-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-ref-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-ref-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-ref-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Log-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-ref-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-ref-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Snapshot (sqlite-index-snapshot-page-cache-ref-count (addr snapshot^.sqlite-snapshot.indexes))
     0))

(defn store-db-sqlite-page-cache-hit-count [snapshot: ^Store-DB] -> int
  (case snapshot^.kind
    .SQLite-Root-Snapshot (sqlite-index-page-cache-hit-count snapshot^.sqlite-root-page-cache)
    .SQLite-Tx-Ops-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-hit-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-hit-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-hit-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-hit-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Log-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-hit-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-hit-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Snapshot (sqlite-index-snapshot-page-cache-hit-count (addr snapshot^.sqlite-snapshot.indexes))
     0))

(defn store-db-sqlite-page-cache-miss-count [snapshot: ^Store-DB] -> int
  (case snapshot^.kind
    .SQLite-Root-Snapshot (sqlite-index-page-cache-miss-count snapshot^.sqlite-root-page-cache)
    .SQLite-Tx-Ops-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-miss-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-miss-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-miss-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-miss-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Datom-Log-Overlay
      (if (not (= snapshot^.sqlite-root-path ""))
        (sqlite-index-page-cache-miss-count snapshot^.sqlite-root-page-cache)
        (sqlite-index-snapshot-page-cache-miss-count (addr snapshot^.sqlite-snapshot.indexes)))
    .SQLite-Snapshot (sqlite-index-snapshot-page-cache-miss-count (addr snapshot^.sqlite-snapshot.indexes))
     0))

(defn sqlite-conn-current-root-page-cache-count [store: ^SQLite-Conn] -> int
  (if store^.current-root-cache-valid
    (sqlite-index-page-cache-count store^.current-root-cache-page-cache)
    0))

(defn sqlite-conn-current-root-page-cache-hit-count [store: ^SQLite-Conn] -> int
  (if store^.current-root-cache-valid
    (sqlite-index-page-cache-hit-count store^.current-root-cache-page-cache)
    0))

(defn sqlite-conn-current-root-page-cache-miss-count [store: ^SQLite-Conn] -> int
  (if store^.current-root-cache-valid
    (sqlite-index-page-cache-miss-count store^.current-root-cache-page-cache)
    0))

(defn sqlite-open-db-snapshot-at-root [path: string, published: SQLite-Durable-Published-Root, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-DB-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-root-set handle published page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.indexes.owns-handle true)
      (set! opened-snapshot.path (string-owned path))
      (return opened-snapshot true ""))))

(defn sqlite-open-db-snapshot-at-root-with-cache [path: string, published: SQLite-Durable-Published-Root, page-size: int, cache: SQLite-Index-Page-Cache] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[opened opened-ok opened-error] (sqlite-open-db-snapshot-at-root path published page-size)]
    (when opened-ok
      (sqlite-index-snapshot-use-page-cache! (addr opened.indexes) cache))
    (return opened opened-ok opened-error)))

(defn sqlite-conn-store-db-at-basis [store: ^SQLite-Conn, basis-tx: u64] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [[roots roots-ok _] (sqlite-index-root-set-at-basis store^.handle basis-tx)
        [root-row-id row-ok _row-error] (sqlite-index-root-row-id-at-basis store^.handle basis-tx)]
    (when (and roots-ok row-ok)
      (return (sqlite-root-store-db
                store^.path
                (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                                basis-tx: basis-tx
                                                roots: roots
                                                modes: (SQLite-Index-Append-Modes {})}))
              true
              "")))
  (let [[sqlite-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-basis store^.handle basis-tx sqlite-db-source-default-page-size)]
    (when snapshot-ok
      (set! sqlite-snapshot.path (string-owned store^.path))
      (let [[root-backed root-backed-ok] (sqlite-root-store-db-from-open-snapshot sqlite-snapshot)]
        (when root-backed-ok
          (close-sqlite-db-snapshot! (addr sqlite-snapshot))
          (return root-backed true "")))
      (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: sqlite-snapshot}) true ""))
    (return (Store-DB {}) false snapshot-error)))

(defn sqlite-conn-has-durable-index-roots [store: ^SQLite-Conn] -> [has-roots: bool, ok: bool, error: string]
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db store)]
    (when snapshot-ok
      (close-store-db snapshot)
      (return true true ""))
    (if (= snapshot-error "sqlite DB has no Vev index roots")
      (return false true "")
      (return false false snapshot-error))))

(defn retain-sqlite-db-snapshot [snapshot: SQLite-DB-Snapshot] -> SQLite-DB-Snapshot
  (when (= snapshot.path "")
    (return (SQLite-DB-Snapshot {})))
  (let [[retained retained-ok _] (sqlite-open-db-snapshot-at-basis snapshot.path snapshot.basis-tx sqlite-db-source-default-page-size)]
    (if retained-ok
      retained
      (SQLite-DB-Snapshot {}))))

(defn shared-store-db [conn: ^Shared-Conn] -> Store-DB
  (Store-DB {kind: .Shared-Snapshot
             shared-snapshot: (retain-shared-db-snapshot conn^.snapshot)}))

(defn tx-op-owned [op: Tx-Op] -> Tx-Op
  (Tx-Op {kind: op.kind
          e: op.e
          a: (string-owned op.a)
          owned-attr: true
          v: (value-owned op.v)
          owned-value: true
          derived: op.derived
          tuple-identity: op.tuple-identity
          map-group: (string-owned op.map-group)}))

(defn tx-op-from-datom-owned [datom: Datom] -> Tx-Op
  (Tx-Op {kind: (if datom.added .Add .Retract)
          e: datom.e
          a: (string-owned datom.a)
          owned-attr: true
          v: (value-owned datom.v)
          owned-value: true}))

(defn tx-ops-from-datoms-owned [datoms: []Datom] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count datoms))]
    (for [datom datoms]
      (arr.push! out (tx-op-from-datom-owned datom)))
    out))

(defn clone-tx-ops-owned [ops: []Tx-Op] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (arr.push! out (tx-op-owned op)))
    out))

(defn delete-owned-tx-ops [ops: [dynamic]Tx-Op]
  (for [op ops]
    (when op.owned-attr
      (delete op.a))
    (when op.owned-value
      (delete-owned-value op.v))
    (when (not (= op.map-group ""))
      (delete op.map-group)))
  (delete ops))

(defn append-overlay-cardinality-one-retractions! [out: ^[dynamic]Tx-Op, op: Tx-Op]
  (let [index 0]
    (while (< index (count out^))
      (let [existing out^[index]]
        (if (and (= existing.kind .Add)
                 (= existing.e op.e)
                 (= existing.a op.a)
                 (not (value-equal? existing.v op.v)))
          (do
            (when existing.owned-attr
              (delete existing.a))
            (when existing.owned-value
              (delete-owned-value existing.v))
            (when (not (= existing.map-group ""))
              (delete existing.map-group))
            (arr.remove-ordered-at! out^ index))
          (set! index (+ index 1)))))))

(defn append-source-cardinality-one-retractions! [out: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source op.e op.a)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (not (value-equal? stream.current.v op.v))
        (arr.push! out^ (Tx-Op {kind: .Retract
                                e: stream.current.e
                                a: (string-owned stream.current.a)
                                owned-attr: true
                                v: (value-owned stream.current.v)
                                owned-value: true})))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (return true "")))

(defn overlay-ops-declare-cardinality-many? [ops: []Tx-Op, attr: string] -> bool
  (let [schema-e: u64 0
        found-schema false]
    (for [op ops]
      (when (and (= op.kind .Add)
                 (= op.a ":db/ident")
                 (= op.v.kind .Keyword)
                 (= op.v.text attr))
        (set! schema-e op.e)
        (set! found-schema true)))
    (when (not found-schema)
      (return false))
    (for [op ops]
      (when (and (= op.kind .Add)
                 (= op.e schema-e)
                 (= op.a ":db/cardinality")
                 (= op.v.kind .Keyword)
                 (= op.v.text ":db.cardinality/many"))
        (return true))))
  false)

(defn overlay-ops-schema-entity-for-attr [ops: []Tx-Op, attr: string] -> [entity: u64, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.a ":db/ident")
               (= op.v.kind .Keyword)
               (= op.v.text attr))
      (return op.e true)))
  (return 0 false))

(defn overlay-ops-schema-ident-for-entity [ops: []Tx-Op, entity: u64] -> [attr: string, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.e entity)
               (= op.a ":db/ident")
               (= op.v.kind .Keyword))
      (return (string-owned op.v.text) true)))
  (return "" false))

(defn overlay-ops-schema-keyword-property [ops: []Tx-Op, entity: u64, schema-attr: string] -> [value: string, ok: bool]
  (for [op ops]
    (when (and (= op.kind .Add)
               (= op.e entity)
               (= op.a schema-attr)
               (= op.v.kind .Keyword))
      (return (string-owned op.v.text) true)))
  (return "" false))

(defn overlay-ops-schema-keyword [ops: []Tx-Op, attr: string, schema-attr: string] -> [value: string, ok: bool]
  (let [[schema-e schema-ok] (overlay-ops-schema-entity-for-attr ops attr)]
    (when (not schema-ok)
      (return "" false))
    (overlay-ops-schema-keyword-property ops schema-e schema-attr)))

(defn shared-store-db-with-overlay [base: Shared-DB-Snapshot, ops: []Tx-Op, tx: u64] -> Store-DB
  (Store-DB {kind: .Shared-Tx-Ops-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-ops: (clone-tx-ops-owned ops)
             overlay-tx: tx}))

(defn sqlite-store-db-with-overlay [base: SQLite-DB-Snapshot, ops: []Tx-Op, tx: u64] -> Store-DB
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot base)]
    (if root-ok
      (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                 sqlite-root-path: root-path
                 sqlite-root-published: root-published
                 sqlite-root-page-cache: root-cache
                 overlay-ops: (clone-tx-ops-owned ops)
                 overlay-tx: tx})
      (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot base)
                 overlay-ops: (clone-tx-ops-owned ops)
                 overlay-tx: tx}))))

(defn sqlite-root-store-db-with-overlay [base: Store-DB, ops: []Tx-Op, tx: u64] -> Store-DB
  (Store-DB {kind: .SQLite-Tx-Ops-Overlay
             sqlite-root-path: (string-owned base.sqlite-root-path)
             sqlite-root-published: base.sqlite-root-published
             sqlite-root-page-cache: (retain-sqlite-index-page-cache base.sqlite-root-page-cache)
             overlay-ops: (clone-tx-ops-owned ops)
             overlay-tx: tx}))

(defn shared-store-db-with-datom-overlay [base: Shared-DB-Snapshot, datoms: []Datom] -> Store-DB
  (Store-DB {kind: .Shared-Datom-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-datoms: (clone-owned-datom-slice datoms)}))

(defn sqlite-store-db-with-datom-overlay [base: SQLite-DB-Snapshot, datoms: []Datom] -> Store-DB
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot base)]
    (if root-ok
      (Store-DB {kind: .SQLite-Datom-Overlay
                 sqlite-root-path: root-path
                 sqlite-root-published: root-published
                 sqlite-root-page-cache: root-cache
                 overlay-datoms: (clone-owned-datom-slice datoms)})
      (Store-DB {kind: .SQLite-Datom-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot base)
                 overlay-datoms: (clone-owned-datom-slice datoms)}))))

(defn shared-store-db-with-datom-log-overlay [base: Shared-DB-Snapshot, datoms: []Datom] -> Store-DB
  (Store-DB {kind: .Shared-Datom-Log-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-log: (shared-datom-log-from-slice datoms base.datoms.chunk-size)}))

(defn sqlite-store-db-with-datom-log-overlay [base: SQLite-DB-Snapshot, datoms: []Datom] -> Store-DB
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot base)]
    (if root-ok
      (Store-DB {kind: .SQLite-Datom-Log-Overlay
                 sqlite-root-path: root-path
                 sqlite-root-published: root-published
                 sqlite-root-page-cache: root-cache
                 overlay-log: (shared-datom-log-from-slice datoms sqlite-index-leaf-chunk-size)})
      (Store-DB {kind: .SQLite-Datom-Log-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot base)
                 overlay-log: (shared-datom-log-from-slice datoms sqlite-index-leaf-chunk-size)}))))

(defn sqlite-root-store-db-with-datom-log-overlay [base: Store-DB, datoms: []Datom] -> Store-DB
  (Store-DB {kind: .SQLite-Datom-Log-Overlay
             sqlite-root-path: (string-owned base.sqlite-root-path)
             sqlite-root-published: base.sqlite-root-published
             sqlite-root-page-cache: (retain-sqlite-index-page-cache base.sqlite-root-page-cache)
             overlay-log: (shared-datom-log-from-slice datoms sqlite-index-leaf-chunk-size)}))

(defn shared-store-db-with-retained-datom-log-overlay [base: Shared-DB-Snapshot, log: Shared-Datom-Log] -> Store-DB
  (Store-DB {kind: .Shared-Datom-Log-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-log: (retain-shared-datom-log log)}))

(defn sqlite-store-db-with-retained-datom-log-overlay [base: SQLite-DB-Snapshot, log: Shared-Datom-Log] -> Store-DB
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot base)]
    (if root-ok
      (Store-DB {kind: .SQLite-Datom-Log-Overlay
                 sqlite-root-path: root-path
                 sqlite-root-published: root-published
                 sqlite-root-page-cache: root-cache
                 overlay-log: (retain-shared-datom-log log)})
      (Store-DB {kind: .SQLite-Datom-Log-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot base)
                 overlay-log: (retain-shared-datom-log log)}))))

(defn sqlite-root-store-db-with-retained-datom-log-overlay [base: Store-DB, log: Shared-Datom-Log] -> Store-DB
  (Store-DB {kind: .SQLite-Datom-Log-Overlay
             sqlite-root-path: (string-owned base.sqlite-root-path)
             sqlite-root-published: base.sqlite-root-published
             sqlite-root-page-cache: (retain-sqlite-index-page-cache base.sqlite-root-page-cache)
             overlay-log: (retain-shared-datom-log log)}))

(defn shared-store-db-with-report-overlay [base: Shared-DB-Snapshot, report: Tx-Report] -> Store-DB
  (Store-DB {kind: .Shared-Tx-Ops-Overlay
             shared-snapshot: (retain-shared-db-snapshot base)
             overlay-ops: (tx-ops-from-datoms-owned (slice report.tx-data 0))
             overlay-tx: report.tx}))

(defn sqlite-store-db-with-report-overlay [base: SQLite-DB-Snapshot, report: Tx-Report] -> Store-DB
  (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot base)]
    (if root-ok
      (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                 sqlite-root-path: root-path
                 sqlite-root-published: root-published
                 sqlite-root-page-cache: root-cache
                 overlay-ops: (tx-ops-from-datoms-owned (slice report.tx-data 0))
                 overlay-tx: report.tx})
      (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                 sqlite-snapshot: (retain-sqlite-db-snapshot base)
                 overlay-ops: (tx-ops-from-datoms-owned (slice report.tx-data 0))
                 overlay-tx: report.tx}))))

(defn source-overlay-schema-unique-kind [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [unique-kind: string, unique: bool, ok: bool, error: string]
  (let [[unique-kind unique-ok unique-error] (db-read-source-schema-keyword source attr ":db/unique")]
    (when unique-ok
      (return unique-kind true true ""))
    (when (not (= unique-error ""))
      (return "" false false unique-error)))
  (let [[overlay-kind overlay-ok] (overlay-ops-schema-keyword ops attr ":db/unique")]
    (if overlay-ok
      (return overlay-kind true true "")
      (return "" false true ""))))

(defn source-overlay-schema-unique-identity? [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [identity: bool, ok: bool, error: string]
  (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source ops attr)]
    (when (not unique-ok)
      (return false false unique-error))
    (when (not unique)
      (return false true ""))
    (let [is-identity (= unique-kind ":db.unique/identity")]
      (delete unique-kind)
      (return is-identity true ""))))

(defn source-overlay-unique-error [source: DB-Read-Source, ops: []Tx-Op, op: Tx-Op] -> [error-text: string, ok: bool]
  (let [[identity identity-ok identity-error] (source-overlay-schema-unique-identity? source ops op.a)]
    (when (not identity-ok)
      (return identity-error false))
    (if (and identity (not op.tuple-identity))
      (return "conflicting upsert" true)
      (return "schema unique conflict" true))))

(defn source-overlay-existing-unique-conflict? [source: DB-Read-Source, op: Tx-Op] -> [conflict: bool, ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-avet-attr-value-stream source op.a op.v)]
    (when (not stream-ok)
      (return false false stream-error))
    (while stream.has-current
      (when (not (= stream.current.e op.e))
        (delete-source-index-datom-stream stream)
        (return true true ""))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false false advance-error))))
    (delete-source-index-datom-stream stream)
    (return false true "")))

(defn source-overlay-prior-unique-conflict? [ops: []Tx-Op, op: Tx-Op] -> bool
  (for [prior ops]
    (when (and (= prior.kind .Add)
               (= prior.a op.a)
               (value-equal? prior.v op.v)
               (not (= prior.e op.e)))
      (return true)))
  false)

(defn source-overlay-fact-matches? [fact: Tx-Op, op: Tx-Op] -> bool
  (and (= fact.e op.e)
       (= fact.a op.a)
       (value-equal? fact.v op.v)))

(defn source-overlay-prior-fact-state [ops: []Tx-Op, op: Tx-Op] -> [touched: bool, current: bool]
  (let [index (- (count ops) 1)]
    (while (>= index 0)
      (let [prior ops[index]]
        (when (source-overlay-fact-matches? prior op)
          (return true (= prior.kind .Add))))
      (set! index (- index 1))))
  (return false false))

(defn source-overlay-existing-current-fact? [source: DB-Read-Source, op: Tx-Op] -> [exists: bool, ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source op.e op.a)]
    (when (not stream-ok)
      (return false false stream-error))
    (while stream.has-current
      (when (value-equal? stream.current.v op.v)
        (delete-source-index-datom-stream stream)
        (return true true ""))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false false advance-error))))
    (delete-source-index-datom-stream stream)
    (return false true "")))

(defn remove-source-overlay-prior-fact-retractions! [ops: ^[dynamic]Tx-Op, op: Tx-Op]
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [prior ops^[index]]
        (when (and (= prior.kind .Retract)
                   (source-overlay-fact-matches? prior op))
          (when prior.owned-attr
            (delete prior.a))
          (when prior.owned-value
            (delete-owned-value prior.v))
          (when (not (= prior.map-group ""))
            (delete prior.map-group))
          (arr.remove-ordered-at! ops^ index)))
      (set! index (- index 1)))))

(defn validate-source-overlay-unique-attr [source: DB-Read-Source, ops: []Tx-Op, attr: string] -> [ok: bool, error: string]
  (let [seen (mmap.empty string u64)
        [stream source-ok source-error] (source-index-datom-stream source attr)]
    (defer (do
             (for [key seen]
               (delete key))
             (delete seen)))
    (when (not source-ok)
      (return false source-error))
    (while stream.has-current
      (let [fact (datom-add-op stream.current)
            [key key-ok] (unique-op-value-key fact)]
        (when (not key-ok)
          (delete-source-index-datom-stream stream)
          (return false "schema unique value unsupported"))
        (let [[existing existing-ok] (mmap.get seen key)]
          (when (and existing-ok (not (= existing fact.e)))
            (delete key)
            (delete-source-index-datom-stream stream)
            (return false "schema unique conflict"))
          (if existing-ok
            (delete key)
            (mmap.assoc! seen key fact.e))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (for [op ops]
      (when (not (= op.a attr))
        (continue))
      (let [[key key-ok] (unique-op-value-key op)]
        (when (not key-ok)
          (return false "schema unique value unsupported"))
        (if (= op.kind .Retract)
          (do
            (let [[existing existing-ok] (mmap.get seen key)]
              (when (and existing-ok (= existing op.e))
                (for [stored-key seen]
                  (when (= stored-key key)
                    (delete stored-key)
                    (mmap.dissoc! seen key)
                    (break)))))
            (delete key))
          (when (= op.kind .Add)
            (let [[existing existing-ok] (mmap.get seen key)]
              (when (and existing-ok (not (= existing op.e)))
                (delete key)
                (return false "schema unique conflict"))
              (if existing-ok
                (delete key)
                (mmap.assoc! seen key op.e)))))))
    (return true "")))

(defn validate-source-overlay-new-unique-schemas [source: DB-Read-Source, ops: []Tx-Op] -> [ok: bool, error: string]
  (let [checked (mmap.empty string bool)]
    (defer (do
             (for [key checked]
               (delete key))
             (delete checked)))
    (for [op ops]
      (when (not (and (= op.kind .Add)
                      (= op.a ":db/unique")
                      (= op.v.kind .Keyword)))
        (continue))
      (let [[attr attr-ok] (overlay-ops-schema-ident-for-entity ops op.e)]
        (when (not attr-ok)
          (let [[source-attr source-attr-ok source-attr-error] (db-read-source-schema-ident-for-entity source op.e)]
            (when (not source-attr-ok)
              (when (not (= source-attr-error ""))
                (return false source-attr-error))
              (continue))
            (let [[already _] (mmap.get checked source-attr)]
              (when already
                (delete source-attr)
                (continue))
                (let [[attr-ok attr-error] (validate-source-overlay-unique-attr source ops source-attr)]
                  (when (not attr-ok)
                    (delete source-attr)
                    (return false attr-error)))
                (mmap.assoc! checked source-attr true))
            (continue)))
        (let [[already _] (mmap.get checked attr)]
          (when already
            (delete attr)
            (continue))
            (let [[attr-ok attr-error] (validate-source-overlay-unique-attr source ops attr)]
              (when (not attr-ok)
                (delete attr)
                (return false attr-error)))
            (mmap.assoc! checked attr true)))))
  (return true ""))

(defn append-source-overlay-op! [out: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (when (= op.kind .Add)
    (let [[touched current] (source-overlay-prior-fact-state (slice out^ 0) op)]
      (when current
        (return true ""))
      (when touched
        (remove-source-overlay-prior-fact-retractions! out op))
      (let [[exists exists-ok exists-error] (source-overlay-existing-current-fact? source op)]
        (when (not exists-ok)
          (return false exists-error))
        (when exists
          (return true ""))))
    (let [[schema-type has-type type-ok type-error] (db-read-source-schema-value-type source op.a)]
      (when (not type-ok)
        (return false type-error))
      (when has-type
        (let [matches (value-matches-schema-type? op.v schema-type)]
          (delete schema-type)
          (when (not matches)
            (return false "schema value type mismatch")))))
    (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source (slice out^ 0) op.a)]
      (when (not unique-ok)
        (return false unique-error))
      (when unique
        (delete unique-kind)
        (when (source-overlay-prior-unique-conflict? (slice out^ 0) op)
          (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
            (return false (if error-ok error-text "schema unique conflict"))))
        (let [[conflict conflict-ok conflict-error] (source-overlay-existing-unique-conflict? source op)]
          (when (not conflict-ok)
            (return false conflict-error))
          (when conflict
            (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
              (return false (if error-ok error-text "schema unique conflict")))))))
    (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source op.a)]
      (when (not many-ok)
        (return false many-error))
      (when (and (not many)
                 (not (overlay-ops-declare-cardinality-many? (slice out^ 0) op.a)))
        (let [[source-ok source-error] (append-source-cardinality-one-retractions! out source op)]
          (when (not source-ok)
            (return false source-error)))
        (append-overlay-cardinality-one-retractions! out op))))
  (arr.push! out^ (tx-op-owned op))
  (return true ""))

(defn append-source-new-entity-overlay-op! [out: ^[dynamic]Tx-Op, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (when (not (= op.kind .Add))
    (return false "new-entity overlay fast path only supports adds"))
  (let [[schema-type has-type type-ok type-error] (db-read-source-schema-value-type source op.a)]
    (when (not type-ok)
      (return false type-error))
    (when has-type
      (let [matches (value-matches-schema-type? op.v schema-type)]
        (delete schema-type)
        (when (not matches)
          (return false "schema value type mismatch")))))
  (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source (slice out^ 0) op.a)]
    (when (not unique-ok)
      (return false unique-error))
    (when unique
      (delete unique-kind)
      (when (source-overlay-prior-unique-conflict? (slice out^ 0) op)
        (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
          (return false (if error-ok error-text "schema unique conflict"))))
      (let [[conflict conflict-ok conflict-error] (source-overlay-existing-unique-conflict? source op)]
        (when (not conflict-ok)
          (return false conflict-error))
        (when conflict
          (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
            (return false (if error-ok error-text "schema unique conflict")))))))
  (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source op.a)]
    (when (not many-ok)
      (return false many-error))
    (when (and (not many)
               (not (overlay-ops-declare-cardinality-many? (slice out^ 0) op.a)))
      (append-overlay-cardinality-one-retractions! out op)))
  (arr.push! out^ (tx-op-owned op))
  (return true ""))

(defn tx-op-schema-mutation-attr? [attr: string] -> bool
  (or (= attr ":db/ident")
      (= attr ":db/valueType")
      (= attr ":db/cardinality")
      (= attr ":db/unique")))

(defn source-overlay-ops-contain-schema-mutation? [ops: []Tx-Op] -> bool
  (for [op ops]
    (when (tx-op-schema-mutation-attr? op.a)
      (return true)))
  false)

(defn sqlite-conn-direct-attr-info [store: ^SQLite-Conn, source: DB-Read-Source, attr: string] -> [info: SQLite-Direct-Attr-Info, ok: bool, error: string]
  (for [entry store^.direct-attr-cache]
    (when (= entry.attr attr)
      (return entry true "")))
  (let [[schema-type has-type type-ok type-error] (db-read-source-schema-value-type source attr)]
    (when (not type-ok)
      (return (SQLite-Direct-Attr-Info {}) false type-error))
    (let [[unique-kind unique unique-ok unique-error] (source-overlay-schema-unique-kind source ([]Tx-Op []) attr)]
      (when (not unique-ok)
        (when has-type
          (delete schema-type))
        (return (SQLite-Direct-Attr-Info {}) false unique-error))
      (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source attr)]
        (when (not many-ok)
          (when has-type
            (delete schema-type))
          (when unique
            (delete unique-kind))
          (return (SQLite-Direct-Attr-Info {}) false many-error))
        (let [entry (SQLite-Direct-Attr-Info {attr: (string-owned attr)
                                             has-type: has-type
                                             schema-type: (if has-type schema-type "")
                                             unique: unique
                                             unique-kind: (if unique unique-kind "")
                                             cardinality-many: many})]
          (arr.push! store^.direct-attr-cache entry)
          (return entry true ""))))))

(defn append-source-new-entity-overlay-op-cached! [out: ^[dynamic]Tx-Op, store: ^SQLite-Conn, source: DB-Read-Source, op: Tx-Op] -> [ok: bool, error: string]
  (when (not (= op.kind .Add))
    (return false "new-entity overlay cached path only supports adds"))
  (let [[info info-ok info-error] (sqlite-conn-direct-attr-info store source op.a)]
    (when (not info-ok)
      (return false info-error))
    (when info.has-type
      (when (not (value-matches-schema-type? op.v info.schema-type))
        (return false "schema value type mismatch")))
    (when info.unique
      (when (source-overlay-prior-unique-conflict? (slice out^ 0) op)
        (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
          (return false (if error-ok error-text "schema unique conflict"))))
      (let [[conflict conflict-ok conflict-error] (source-overlay-existing-unique-conflict? source op)]
        (when (not conflict-ok)
          (return false conflict-error))
        (when conflict
          (let [[error-text error-ok] (source-overlay-unique-error source (slice out^ 0) op)]
            (return false (if error-ok error-text "schema unique conflict"))))))
    (when (not info.cardinality-many)
      (append-overlay-cardinality-one-retractions! out op))
    (arr.push! out^ (tx-op-owned op))
    (return true "")))

(defn source-overlay-ops-from-resolved [source: DB-Read-Source, resolved: Resolved-Tx] -> [ops: [dynamic]Tx-Op, ok: bool, error: string]
  (source-overlay-ops-from-ops source (slice resolved.ops 0)))

(defn finalize-source-transaction-instant! [source: DB-Read-Source, ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tx: u64] -> [ok: bool, error: string]
  (let [clock-instant (current-instant)
        tx-instant clock-instant
        has-explicit false]
    (for [op ops^]
      (when (and (= op.e tx) (= op.a ":db/txInstant"))
        (when (or has-explicit
                  (not (= op.kind .Add))
                  (not (= op.v.kind .Instant)))
          (return false "invalid explicit :db/txInstant"))
        (set! has-explicit true)
        (set! tx-instant op.v)))
    (when has-explicit
      (when (> tx-instant.int-value clock-instant.int-value)
        (return false ":db/txInstant cannot be newer than the wall clock"))
      (let [[prior prior-ok prior-error] (db-read-source-datoms-by-attr source ":db/txInstant")]
        (when (not prior-ok)
          (return false prior-error))
        (defer (delete-owned-datoms prior))
        (for [datom prior]
          (when (and datom.added
                     (= datom.e datom.tx)
                     (= datom.v.kind .Instant)
                     (< tx-instant.int-value datom.v.int-value))
            (return false ":db/txInstant must be monotonic")))))
    (when (not has-explicit)
      (arr.push! ops^ (tx-add tx ":db/txInstant" tx-instant)))
    (let [has-meta false]
      (for [meta tx-meta^]
        (when (= meta.a ":db/txInstant")
          (set! has-meta true)))
      (when (not has-meta)
        (arr.push! tx-meta^ (Tx-Meta {a: ":db/txInstant" v: tx-instant}))))
    (return true "")))

(defn source-overlay-ops-all-new-entity-adds? [next-entity-id: u64, ops: []Tx-Op] -> bool
  (for [op ops]
    (when (or (not (= op.kind .Add))
              (< op.e next-entity-id))
      (return false)))
  true)

(defn source-overlay-ops-from-resolved-for-direct-write [source: DB-Read-Source, resolved: Resolved-Tx, next-entity-id: u64] -> [ops: [dynamic]Tx-Op, ok: bool, error: string]
  (if (source-overlay-ops-all-new-entity-adds? next-entity-id (slice resolved.ops 0))
    (source-overlay-new-entity-ops-from-ops source (slice resolved.ops 0))
    (source-overlay-ops-from-resolved source resolved)))

(defn source-overlay-ops-from-resolved-for-direct-write-cached [store: ^SQLite-Conn, source: DB-Read-Source, resolved: Resolved-Tx, next-entity-id: u64] -> [ops: [dynamic]Tx-Op, ok: bool, error: string]
  (if (and (source-overlay-ops-all-new-entity-adds? next-entity-id (slice resolved.ops 0))
           (not (source-overlay-ops-contain-schema-mutation? (slice resolved.ops 0))))
    (let [out (make [dynamic]Tx-Op 0 (count resolved.ops))]
      (for [op resolved.ops]
        (let [[append-ok append-error] (append-source-new-entity-overlay-op-cached! (addr out) store source op)]
          (when (not append-ok)
            (delete-owned-tx-ops out)
            (return (make [dynamic]Tx-Op) false append-error))))
      (return out true ""))
    (source-overlay-ops-from-resolved-for-direct-write source resolved next-entity-id)))

(defn source-overlay-new-entity-ops-from-ops [source: DB-Read-Source, ops: []Tx-Op] -> [out-ops: [dynamic]Tx-Op, ok: bool, error: string]
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (let [[append-ok append-error] (append-source-new-entity-overlay-op! (addr out) source op)]
        (when (not append-ok)
          (delete-owned-tx-ops out)
          (return (make [dynamic]Tx-Op) false append-error))))
    (let [[unique-ok unique-error] (validate-source-overlay-new-unique-schemas source (slice out 0))]
      (when (not unique-ok)
        (delete-owned-tx-ops out)
        (return (make [dynamic]Tx-Op) false unique-error)))
    (return out true "")))

(defn source-overlay-ops-from-ops [source: DB-Read-Source, ops: []Tx-Op] -> [out-ops: [dynamic]Tx-Op, ok: bool, error: string]
  (let [out (make [dynamic]Tx-Op 0 (count ops))]
    (for [op ops]
      (let [[append-ok append-error] (append-source-overlay-op! (addr out) source op)]
        (when (not append-ok)
          (delete-owned-tx-ops out)
          (return (make [dynamic]Tx-Op) false append-error))))
    (let [[unique-ok unique-error] (validate-source-overlay-new-unique-schemas source (slice out 0))]
      (when (not unique-ok)
        (delete-owned-tx-ops out)
        (return (make [dynamic]Tx-Op) false unique-error)))
    (return out true "")))

(defn shared-store-db-with-source-overlay-tx-data [snapshot: Shared-DB-Snapshot, tx-data: []Tx-Data] -> [next: Store-DB, used: bool, ok: bool, error: string]
  (let [base snapshot
        source (shared-db-snapshot-read-source (addr base))
        [state state-ok state-error] (shared-write-state-from-shared-snapshot-metadata base)]
    (when (not state-ok)
      (return (Store-DB {}) false false state-error))
    (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
      (when (not resolved.ok)
        (delete-resolved-tx resolved)
        (delete-shared-write-state-metadata state)
        (return (Store-DB {}) false true ""))
      (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr resolved.ops) (addr resolved.tx-meta) state.conn.next-tx)]
        (when (not instant-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-DB {}) false false instant-error)))
      (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
        (when (not overlay-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-DB {}) false false overlay-error))
        (let [out (shared-store-db-with-overlay base (slice overlay-ops 0) state.conn.next-tx)]
          (delete-owned-tx-ops overlay-ops)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return out true true ""))))))

(defn store-db-source-overlay-from-resolved [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64] -> Store-DB
  (case snapshot.kind
    .SQLite-Snapshot (sqlite-store-db-with-overlay snapshot.sqlite-snapshot overlay-ops tx)
    .SQLite-Root-Snapshot (sqlite-root-store-db-with-overlay snapshot overlay-ops tx)
    .Shared-Snapshot (shared-store-db-with-overlay snapshot.shared-snapshot overlay-ops tx)
    .SQLite-Tx-Ops-Overlay
      (let [datoms (make [dynamic]Datom)]
        (append-overlay-datoms-from-ops! (addr datoms) (slice snapshot.overlay-ops 0) snapshot.overlay-tx)
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (if (not (= snapshot.sqlite-root-path ""))
                    (sqlite-root-store-db-with-datom-log-overlay snapshot (slice datoms 0))
                    (sqlite-store-db-with-datom-log-overlay snapshot.sqlite-snapshot (slice datoms 0)))]
          (delete-owned-datoms datoms)
          out))
    .SQLite-Datom-Overlay
      (let [datoms (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))]
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (if (not (= snapshot.sqlite-root-path ""))
                    (sqlite-root-store-db-with-datom-log-overlay snapshot (slice datoms 0))
                    (sqlite-store-db-with-datom-log-overlay snapshot.sqlite-snapshot (slice datoms 0)))]
          (delete-owned-datoms datoms)
          out))
    .SQLite-Datom-Log-Overlay
      (let [datoms (source-overlay-datoms-from-ops overlay-ops tx)
            log (shared-datom-log-with-appended-slice snapshot.overlay-log (slice datoms 0))
            out (if (not (= snapshot.sqlite-root-path ""))
                  (sqlite-root-store-db-with-retained-datom-log-overlay snapshot log)
                  (sqlite-store-db-with-retained-datom-log-overlay snapshot.sqlite-snapshot log))]
        (delete-shared-datom-log log)
        (delete-owned-datoms datoms)
        out)
    .Shared-Tx-Ops-Overlay
      (let [datoms (make [dynamic]Datom)]
        (append-overlay-datoms-from-ops! (addr datoms) (slice snapshot.overlay-ops 0) snapshot.overlay-tx)
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (shared-store-db-with-datom-log-overlay snapshot.shared-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
    .Shared-Datom-Overlay
      (let [datoms (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))]
        (append-overlay-datoms-from-ops! (addr datoms) overlay-ops tx)
        (let [out (shared-store-db-with-datom-log-overlay snapshot.shared-snapshot (slice datoms 0))]
          (delete-owned-datoms datoms)
          out))
    .Shared-Datom-Log-Overlay
      (let [datoms (source-overlay-datoms-from-ops overlay-ops tx)
            log (shared-datom-log-with-appended-slice snapshot.overlay-log (slice datoms 0))
            out (shared-store-db-with-retained-datom-log-overlay snapshot.shared-snapshot log)]
        (delete-shared-datom-log log)
        (delete-owned-datoms datoms)
        out)
     (Store-DB {})))

(defn store-db-with-source-overlay-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [next: Store-DB, used: bool, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-DB {}) false false source-error))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
      (when (not state-ok)
        (return (Store-DB {}) false false state-error))
      (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
        (when (not resolved.ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-DB {}) false true ""))
        (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr resolved.ops) (addr resolved.tx-meta) state.conn.next-tx)]
          (when (not instant-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-DB {}) false false instant-error)))
        (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
          (when (not overlay-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-DB {}) false false overlay-error))
          (let [out (store-db-source-overlay-from-resolved snapshot^ (slice overlay-ops 0) state.conn.next-tx)]
            (delete-owned-tx-ops overlay-ops)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return out true true "")))))))

(defstruct Store-Tx-Report {
  ok: bool
  error: string
  db-before: Store-DB
  db-after: Store-DB
  tx-data: [dynamic]Datom
  tx: u64
  tx-meta: [dynamic]Tx-Meta
  tempids: [dynamic]Tempid
  source-append-metadata-known: bool
  source-new-entities-after-existing: bool
  source-eavt-append-mode: bool
  source-aevt-append-mode: bool
  source-avet-append-mode: bool
  source-vaet-append-mode: bool
  source-published-root-known: bool
  source-published-root: SQLite-Durable-Published-Root
})

(defstruct Store-Tx-Data-Group {
  tx-data: [dynamic]Tx-Data
  owns-items: bool
})

(defn store-tx-data-group [tx-data: []Tx-Data] -> Store-Tx-Data-Group
  (Store-Tx-Data-Group {tx-data: (tx-data-slice-owned tx-data) owns-items: true}))

(defn delete-store-tx-data-group [group: Store-Tx-Data-Group]
  (if group.owns-items
    (delete-owned-tx-data group.tx-data)
    (do
      (for [data group.tx-data]
        (delete-parser-tx-data-owned-values data))
      (delete group.tx-data))))

(defn delete-store-tx-data-groups [groups: [dynamic]Store-Tx-Data-Group]
  (for [group groups]
    (delete-store-tx-data-group group))
  (delete groups))

(defn flatten-store-tx-data-groups [groups: []Store-Tx-Data-Group] -> [dynamic]Tx-Data
  (let [total 0]
    (for [group groups]
      (set! total (+ total (count group.tx-data))))
    (let [out (make [dynamic]Tx-Data 0 total)]
      (for [group groups]
        (for [data group.tx-data]
          (arr.push! out data)))
      out)))

(defn store-tx-data-groups-from-texts [texts: []string] -> [groups: [dynamic]Store-Tx-Data-Group, ok: bool, error: string]
  (let [out (make [dynamic]Store-Tx-Data-Group 0 (count texts))]
    (for [text text-index texts]
      (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
        (when (not prepared.ok)
          (delete-store-tx-data-groups out)
          (return (make [dynamic]Store-Tx-Data-Group) false (fmt.tprintf "transaction group %d: %s" text-index prepared.error)))
        (let [group (store-tx-data-group (slice prepared.tx-data 0))]
          (arr.push! out group))))
    (return out true "")))

(defn store-tx-report-value [report: Store-Tx-Report] -> Value
  (value-map
    ([]Value [(value-keyword (string-owned ":ok")) (value-bool report.ok)
              (value-keyword (string-owned ":error")) (value-string (string-owned report.error))
              (value-keyword (string-owned ":tx")) (if report.ok (value-entity report.tx) (value-nil))
              (value-keyword (string-owned ":tx-data")) (datoms-value (slice report.tx-data 0))
              (value-keyword (string-owned ":tempids")) (tempids-value (slice report.tempids 0))
              (value-keyword (string-owned ":tx-meta")) (tx-metas-value (slice report.tx-meta 0))])))

(defn delete-store-tx-report [report: Store-Tx-Report]
  (close-store-db report.db-before)
  (close-store-db report.db-after)
  (delete-owned-datoms report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids))

(defn delete-store-tx-report-preserve-db-before [report: Store-Tx-Report]
  (close-store-db report.db-after)
  (delete-owned-datoms report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids))

(defn delete-store-tx-reports [reports: [dynamic]Store-Tx-Report]
  (for [report reports]
    (delete-store-tx-report report))
  (delete reports))

(defn clone-store-tx-report [report: Store-Tx-Report] -> Store-Tx-Report
  (let [tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Store-Tx-Report {ok: report.ok
                      error: report.error
                      db-before: (retain-store-db report.db-before)
                      db-after: (retain-store-db report.db-after)
                      tx-data: (clone-owned-datom-slice (slice report.tx-data 0))
                      tx: report.tx
                      tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                      tempids: tempids
                      source-append-metadata-known: report.source-append-metadata-known
                      source-new-entities-after-existing: report.source-new-entities-after-existing
                      source-eavt-append-mode: report.source-eavt-append-mode
                      source-aevt-append-mode: report.source-aevt-append-mode
                      source-avet-append-mode: report.source-avet-append-mode
                      source-vaet-append-mode: report.source-vaet-append-mode
                      source-published-root-known: report.source-published-root-known
                      source-published-root: report.source-published-root})))

(defn listen-store-report! [store: ^Store-Conn, name: string, reports: ^[dynamic]Store-Tx-Report] -> bool
  (for [listener index store^.listeners]
    (when (= listener.name name)
      (set! store^.listeners[index] (Store-Tx-Listener {name: name reports: reports}))
      (return true)))
  (arr.push! store^.listeners (Store-Tx-Listener {name: name reports: reports}))
  true)

(defn unlisten-store-report! [store: ^Store-Conn, name: string] -> bool
  (for [listener index store^.listeners]
    (when (= listener.name name)
      (arr.remove-ordered-at! store^.listeners index)
      (return true)))
  false)

(defn notify-store-report-listeners! [store: ^Store-Conn, report: Store-Tx-Report]
  (when report.ok
    (for [listener store^.listeners]
      (arr.push! listener.reports^ (clone-store-tx-report report)))))

(defn failed-store-tx-report [snapshot: Store-DB, error: string] -> Store-Tx-Report
  (let [before (retain-store-db snapshot)]
    (Store-Tx-Report {ok: false
                      error: error
                      db-before: before
                      db-after: (retain-store-db before)
                      tx-data: (make [dynamic]Datom)
                      tx: 0
                      tx-meta: (make [dynamic]Tx-Meta)
                      tempids: (make [dynamic]Tempid)
                      source-append-metadata-known: false
                      source-new-entities-after-existing: false
                      source-eavt-append-mode: false
                      source-aevt-append-mode: false
                      source-avet-append-mode: false
                      source-vaet-append-mode: false
                      source-published-root-known: false
                      source-published-root: (SQLite-Durable-Published-Root {})})))

(defn failed-owned-store-tx-report [snapshot: Store-DB, error: string] -> Store-Tx-Report
  (let [out (failed-store-tx-report snapshot error)]
    (close-store-db snapshot)
    out))

(defn store-report-tempids-with-current-tx [tempids: []Tempid, tx: u64] -> [dynamic]Tempid
  (let [out (arr.into [dynamic]Tempid tempids)
        [_ has-current-tx] (tempid-lookup (slice out 0) ":db/current-tx")]
    (when (not has-current-tx)
      (arr.push! out (Tempid {tempid: ":db/current-tx" e: tx})))
    out))

(defn store-tx-report-from-resident-report [report: Tx-Report] -> Store-Tx-Report
  (let [before (Store-DB {kind: .Resident resident: (clone-db report.db-before)})
        after (Store-DB {kind: .Resident resident: (clone-db report.db-after)})
        tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Store-Tx-Report {ok: report.ok
                      error: report.error
                      db-before: before
                      db-after: after
                      tx-data: (clone-datoms report.tx-data)
                      tx: report.tx
                      tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                      tempids: tempids
                      source-append-metadata-known: false
                      source-new-entities-after-existing: false
                      source-eavt-append-mode: false
                      source-aevt-append-mode: false
                      source-avet-append-mode: false
                      source-vaet-append-mode: false
                      source-published-root-known: false
                      source-published-root: (SQLite-Durable-Published-Root {})})))

(defn delete-temp-resident-store-report-source [report: Tx-Report]
  (if report.ok
    (delete-live-tx-report-shallow report)
    (do
      (delete report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))))

(defn store-tx-report-from-temp-resident-report [report: Tx-Report] -> Store-Tx-Report
  (let [out (store-tx-report-from-resident-report report)]
    (delete-temp-resident-store-report-source report)
    out))

(defn initial-source-overlay-report-from-resident-report [before: Store-DB, report: Tx-Report] -> Store-Tx-Report
  (let [after-snapshot (shared-db-snapshot-from-db report.db-after sqlite-db-source-default-page-size)
        tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Store-Tx-Report {ok: report.ok
                      error: report.error
                      db-before: (retain-store-db before)
                      db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: after-snapshot})
                      tx-data: (clone-datoms report.tx-data)
                      tx: report.tx
                      tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                      tempids: tempids
                      source-append-metadata-known: false
                      source-new-entities-after-existing: false
                      source-eavt-append-mode: false
                      source-aevt-append-mode: false
                      source-avet-append-mode: false
                      source-vaet-append-mode: false
                      source-published-root-known: false
                      source-published-root: (SQLite-Durable-Published-Root {})})))

(defn initial-source-overlay-report-from-tx-data [before: Store-DB, tx-data: []Tx-Data] -> Store-Tx-Report
  (let [empty-db (build-db (make [dynamic]Datom))
        resident-report (with-tx-data empty-db tx-data)
        report (initial-source-overlay-report-from-resident-report before resident-report)]
    (delete-owned-db empty-db)
    (delete-store-db-temp-tx-report resident-report)
    report))

(defn failed-sqlite-store-tx-report [store: ^SQLite-Conn, error: string] -> Store-Tx-Report
  (let [[snapshot snapshot-ok _] (sqlite-store-db-current-root-cached store)]
    (if snapshot-ok
      (let [out (failed-store-tx-report snapshot error)]
        (close-store-db snapshot)
        out)
      (failed-store-tx-report (Store-DB {}) error))))

(defn empty-shared-store-db-for-sqlite-bootstrap [] -> Store-DB
  (let [empty-db (build-db (make [dynamic]Datom))
        snapshot (shared-db-snapshot-from-db empty-db sqlite-db-source-default-page-size)]
    (delete-owned-db empty-db)
    (Store-DB {kind: .Shared-Snapshot shared-snapshot: snapshot})))

(defn sqlite-commit-initial-source-overlay-report-mode [store: ^SQLite-Conn, overlay-report: Store-Tx-Report, owns-sqlite-tx: bool] -> Store-Tx-Report
  (when (not overlay-report.ok)
    (return overlay-report))
  (when (not (= overlay-report.db-before.kind .Shared-Snapshot))
    (let [failed (failed-store-tx-report overlay-report.db-before "initial SQLite source overlay report must use a shared snapshot db-before")]
      (delete-store-tx-report overlay-report)
      (return failed)))
  (let [base overlay-report.db-before.shared-snapshot
        source (shared-db-snapshot-read-source (addr base))
        [append-modes modes-ok modes-error] (source-append-modes-for-store-report source overlay-report 0)]
      (when (not modes-ok)
        (let [failed (failed-store-tx-report overlay-report.db-before modes-error)]
          (delete-store-tx-report overlay-report)
          (return failed)))
      (let [plan (sqlite-durable-append-plan-from-modes (slice overlay-report.tx-data 0) 0 append-modes (addr store^.direct-write-profile))
            [published-root append-ok append-error] (append-source-direct-sqlite-conn-from-source-plan-published-mode store
                                                                                                                       source
                                                                                                                       overlay-report.tx
                                                                                                                       (slice overlay-report.tx-data 0)
                                                                                                                       (slice overlay-report.tx-meta 0)
                                                                                                                       plan
                                                                                                                       (addr store^.direct-write-profile)
                                                                                                                       owns-sqlite-tx)]
        (defer (delete-sqlite-durable-append-plan plan))
        (when (not append-ok)
          (let [failed (failed-store-tx-report overlay-report.db-before append-error)]
            (delete-store-tx-report overlay-report)
            (return failed)))
        (sqlite-conn-invalidate-write-state-cache! store)
        (sqlite-conn-invalidate-log-metadata-cache! store)
        (sqlite-conn-invalidate-direct-attr-cache! store)
        (let [out (Store-Tx-Report {ok: true
                                    error: ""
                                    db-before: (retain-store-db overlay-report.db-before)
                                    db-after: (sqlite-root-store-db store^.path published-root)
                                    tx-data: (clone-owned-datom-slice (slice overlay-report.tx-data 0))
                                    tx: overlay-report.tx
                                    tx-meta: (clone-tx-meta (slice overlay-report.tx-meta 0))
                                    tempids: (store-report-tempids-with-current-tx (slice overlay-report.tempids 0) overlay-report.tx)
                                    source-append-metadata-known: overlay-report.source-append-metadata-known
                                    source-new-entities-after-existing: overlay-report.source-new-entities-after-existing
                                    source-eavt-append-mode: published-root.modes.eavt
                                    source-aevt-append-mode: published-root.modes.aevt
                                    source-avet-append-mode: published-root.modes.avet
                                    source-vaet-append-mode: published-root.modes.vaet
                                    source-published-root-known: true
                                    source-published-root: published-root})]
          (delete-store-tx-report overlay-report)
          out))))

(defn sqlite-commit-initial-source-overlay-report [store: ^SQLite-Conn, overlay-report: Store-Tx-Report] -> Store-Tx-Report
  (sqlite-commit-initial-source-overlay-report-mode store overlay-report true))

(defn transact-sqlite-store-report-initial-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> Store-Tx-Report
  (let [before (empty-shared-store-db-for-sqlite-bootstrap)
        overlay-report (initial-source-overlay-report-from-tx-data before tx-data)]
    (close-store-db before)
    (sqlite-commit-initial-source-overlay-report store overlay-report)))

(defn transact-sqlite-store-report-initial-tx-data-with-source-string-fns [store: ^SQLite-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [before (empty-shared-store-db-for-sqlite-bootstrap)
        overlay-report (with-store-db-report-tx-data-with-source-string-fns (addr before) tx-data registry)]
    (close-store-db before)
    (sqlite-commit-initial-source-overlay-report store overlay-report)))

(defn transact-sqlite-store-report-direct-tx-data-with-before-mode [store: ^SQLite-Conn, before: Store-DB, tx-data: []Tx-Data, owns-sqlite-tx: bool] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (let [owned-before before
        read-source-start (time.now)
        [source source-ok source-error] (store-db-read-source (addr owned-before))]
    (set! store^.direct-write-profile.read-source-us (+ store^.direct-write-profile.read-source-us (sqlite-profile-elapsed-us read-source-start)))
    (when (not source-ok)
      (close-store-db owned-before)
      (return (Store-Tx-Report {}) false false source-error))
    (let [resolve-start (time.now)
          [state-ok state-error] (sqlite-conn-ensure-write-state-cache! store source)]
      (when (not state-ok)
        (close-store-db owned-before)
        (return (Store-Tx-Report {}) false false state-error))
      (let [state (addr store^.write-state-cache)
            resolved (shared-write-state-resolve-tx-data-source-only state source tx-data)]
        (set! store^.direct-write-profile.resolve-us (+ store^.direct-write-profile.resolve-us (sqlite-profile-elapsed-us resolve-start)))
        (when (not resolved.ok)
          (let [failed (failed-store-tx-report owned-before resolved.error)]
            (delete-resolved-tx resolved)
            (close-store-db owned-before)
            (return failed true true "")))
        (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr resolved.ops) (addr resolved.tx-meta) state^.conn.next-tx)]
          (when (not instant-ok)
            (let [failed (failed-store-tx-report owned-before instant-error)]
              (delete-resolved-tx resolved)
              (close-store-db owned-before)
              (return failed true true ""))))
        (let [overlay-start (time.now)
              [overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved-for-direct-write-cached store source resolved state^.next-entity-id)]
          (set! store^.direct-write-profile.overlay-us (+ store^.direct-write-profile.overlay-us (sqlite-profile-elapsed-us overlay-start)))
          (when (not overlay-ok)
            (delete-resolved-tx resolved)
            (close-store-db owned-before)
            (return (Store-Tx-Report {}) false false overlay-error))
          (when (not (= owned-before.kind .SQLite-Snapshot))
            (delete-owned-tx-ops overlay-ops)
            (delete-resolved-tx resolved)
            (close-store-db owned-before)
            (return (Store-Tx-Report {}) false false "source-direct SQLite write requires a SQLite snapshot basis"))
          (let [tx state^.conn.next-tx
                start-index owned-before.sqlite-snapshot.datom-count
                new-entities-after-existing (source-append-ops-all-new-entities? state^.next-entity-id (slice overlay-ops 0))
                appended (source-overlay-datoms-from-ops (slice overlay-ops 0) tx)]
            (let [append-start (time.now)
                  append-modes (SQLite-Index-Append-Modes {eavt: new-entities-after-existing
                                                           aevt: false
                                                           avet: false
                                                           vaet: false})
                  plan (sqlite-durable-append-plan-from-modes (slice appended 0) start-index append-modes (addr store^.direct-write-profile))
                  [published-root append-ok append-error] (append-source-direct-sqlite-conn-from-source-plan-published-mode store source tx (slice appended 0) (slice resolved.tx-meta 0) plan (addr store^.direct-write-profile) owns-sqlite-tx)]
              (defer (delete-sqlite-durable-append-plan plan))
              (set! store^.direct-write-profile.append-us (+ store^.direct-write-profile.append-us (sqlite-profile-elapsed-us append-start)))
              (when (not append-ok)
                (let [failed (failed-store-tx-report owned-before append-error)]
                  (delete-owned-datoms appended)
                  (delete-owned-tx-ops overlay-ops)
                  (delete-resolved-tx resolved)
                  (close-store-db owned-before)
                  (return failed true true "")))
              (let [report-open-start (time.now)
                    out-report (sqlite-committed-source-store-tx-report-with-before
                                 store^.path
                                 owned-before
                                 tx
                                 (slice appended 0)
                                 (slice resolved.tx-meta 0)
                                 (slice resolved.tempids 0)
                                 new-entities-after-existing
                                 published-root)]
                (set! store^.direct-write-profile.report-open-us (+ store^.direct-write-profile.report-open-us (sqlite-profile-elapsed-us report-open-start)))
                (sqlite-conn-advance-write-state-cache-after-datoms! store (slice appended 0))
                (set! store^.direct-write-profile.writes (+ store^.direct-write-profile.writes 1))
                (delete-owned-datoms appended)
                (delete-owned-tx-ops overlay-ops)
                (delete-resolved-tx resolved)
                (close-store-db owned-before)
                (return out-report true true "")))))))))

(defn transact-sqlite-store-report-direct-tx-data-mode [store: ^SQLite-Conn, tx-data: []Tx-Data, owns-sqlite-tx: bool] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (when store^.resident-loaded
    (return (Store-Tx-Report {}) false true ""))
  (let [open-before-start (time.now)
        [before before-ok before-error] (sqlite-store-db-current-root-open-cached store)]
    (set! store^.direct-write-profile.open-before-us (+ store^.direct-write-profile.open-before-us (sqlite-profile-elapsed-us open-before-start)))
      (when (not before-ok)
        (if (= before-error "sqlite DB has no Vev index roots")
        (let [before (empty-shared-store-db-for-sqlite-bootstrap)
              overlay-report (with-store-db-report-tx-data (addr before) tx-data)]
          (close-store-db before)
          (return (sqlite-commit-initial-source-overlay-report-mode store overlay-report owns-sqlite-tx) true true ""))
        (return (Store-Tx-Report {}) false false before-error)))
    (transact-sqlite-store-report-direct-tx-data-with-before-mode store before tx-data owns-sqlite-tx)))

(defn transact-sqlite-store-report-direct-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (transact-sqlite-store-report-direct-tx-data-mode store tx-data true))

(defn transact-sqlite-store-report-direct-tx-data-open-tx [store: ^SQLite-Conn, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (transact-sqlite-store-report-direct-tx-data-mode store tx-data false))

(defn source-overlay-datoms-from-ops [ops: []Tx-Op, tx: u64] -> [dynamic]Datom
  (let [out (make [dynamic]Datom 0 (count ops))]
    (for [op ops]
      (let [datom (Datom {e: op.e
                          a: op.a
                          v: op.v
                          tx: tx
                          added: (= op.kind .Add)})]
        (arr.push! out (datom-owned datom))))
    out))

(defn clone-owned-datom-slice [datoms: []Datom] -> [dynamic]Datom
  (let [out (make [dynamic]Datom 0 (count datoms))]
    (for [datom datoms]
      (arr.push! out (datom-owned datom)))
    out))

(defn append-overlay-datoms-from-ops! [out: ^[dynamic]Datom, ops: []Tx-Op, tx: u64]
  (for [op ops]
    (let [datom (Datom {e: op.e
                        a: op.a
                        v: op.v
                        tx: tx
                        added: (= op.kind .Add)})]
      (arr.push! out^ (datom-owned datom)))))

(defn store-source-append-modes-for-report [snapshot: Store-DB, datoms: []Datom, new-entities-after-existing: bool] -> [known: bool, eavt-mode: bool, aevt-mode: bool, avet-mode: bool, vaet-mode: bool]
  (let [snapshot-value (retain-store-db snapshot)
        [source source-ok _] (store-db-read-source (addr snapshot-value))]
    (when (not source-ok)
      (close-store-db snapshot-value)
      (return false false false false false))
    (let [view (db-read-source-index-view source .EAVT)
          start-index (db-index-view-count view)
          [modes modes-ok _] (source-append-index-modes-for-persist source datoms start-index new-entities-after-existing)]
      (close-store-db snapshot-value)
      (if modes-ok
        (return true modes.eavt modes.aevt modes.avet modes.vaet)
        (return false false false false false)))))

(defn store-tx-report-from-source-overlay-parts [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64, tx-meta: []Tx-Meta, tempids: []Tempid, next-entity: u64] -> Store-Tx-Report
  (let [tx-data (source-overlay-datoms-from-ops overlay-ops tx)
        cloned-tempids (store-report-tempids-with-current-tx tempids tx)
        new-entities-after-existing (source-append-ops-all-new-entities? next-entity overlay-ops)
        [modes-known eavt-mode aevt-mode avet-mode vaet-mode] (store-source-append-modes-for-report snapshot (slice tx-data 0) new-entities-after-existing)]
    (Store-Tx-Report {ok: true
                      error: ""
                      db-before: (retain-store-db snapshot)
                      db-after: (store-db-source-overlay-from-resolved snapshot overlay-ops tx)
                      tx-data: tx-data
                      tx: tx
                      tx-meta: (clone-tx-meta tx-meta)
                      tempids: cloned-tempids
                      source-append-metadata-known: modes-known
                      source-new-entities-after-existing: new-entities-after-existing
                      source-eavt-append-mode: (and modes-known eavt-mode)
                      source-aevt-append-mode: (and modes-known aevt-mode)
                      source-avet-append-mode: (and modes-known avet-mode)
                      source-vaet-append-mode: (and modes-known vaet-mode)
                      source-published-root-known: false
                      source-published-root: (SQLite-Durable-Published-Root {})})))

(defn store-tx-report-from-source-overlay [snapshot: Store-DB, overlay-ops: []Tx-Op, tx: u64, resolved: Resolved-Tx, next-entity: u64] -> Store-Tx-Report
  (store-tx-report-from-source-overlay-parts snapshot overlay-ops tx (slice resolved.tx-meta 0) (slice resolved.tempids 0) next-entity))

(defn with-shared-store-db-source-overlay-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (let [base snapshot^.shared-snapshot
        source (shared-db-snapshot-read-source (addr base))
        [state state-ok state-error] (shared-write-state-from-shared-snapshot-metadata base)]
    (when (not state-ok)
      (return (Store-Tx-Report {}) false false state-error))
    (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
      (when (not resolved.ok)
        (let [error resolved.error]
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-Tx-Report {}) false false error)))
      (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr resolved.ops) (addr resolved.tx-meta) state.conn.next-tx)]
        (when (not instant-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-Tx-Report {}) false false instant-error)))
      (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
        (when (not overlay-ok)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return (Store-Tx-Report {}) false false overlay-error))
        (let [out-report (store-tx-report-from-source-overlay snapshot^ (slice overlay-ops 0) state.conn.next-tx resolved state.next-entity-id)]
          (delete-owned-tx-ops overlay-ops)
          (delete-resolved-tx resolved)
          (delete-shared-write-state-metadata state)
          (return out-report true true ""))))))

(defn with-store-db-source-overlay-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-Tx-Report {}) false false source-error))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
      (when (not state-ok)
        (return (Store-Tx-Report {}) false false state-error))
      (let [resolved (shared-write-state-resolve-tx-data-source-only (addr state) source tx-data)]
        (when (not resolved.ok)
          (let [error resolved.error]
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-Tx-Report {}) false false error)))
        (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr resolved.ops) (addr resolved.tx-meta) state.conn.next-tx)]
          (when (not instant-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-Tx-Report {}) false false instant-error)))
        (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-resolved source resolved)]
          (when (not overlay-ok)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return (Store-Tx-Report {}) false false overlay-error))
          (let [out-report (store-tx-report-from-source-overlay snapshot^ (slice overlay-ops 0) state.conn.next-tx resolved state.next-entity-id)]
            (delete-owned-tx-ops overlay-ops)
            (delete-resolved-tx resolved)
            (delete-shared-write-state-metadata state)
            (return out-report true true "")))))))

(defn failed-store-source-registered-tx [snapshot: Store-DB, ops: [dynamic]Tx-Op, tx-meta: [dynamic]Tx-Meta, tempids: [dynamic]Tempid, segment: [dynamic]Tx-Data, error: string] -> Store-Tx-Report
  (delete ops)
  (delete tx-meta)
  (delete tempids)
  (delete segment)
  (failed-store-tx-report snapshot error))

(defn with-store-db-report-tx-data-with-source-string-fns-state [snapshot: ^Store-DB, base-source: DB-Read-Source, state: ^Shared-Write-State, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [source base-source
        [duplicate-ident has-duplicate] (tx-fn-source-string-duplicate-ident registry)
        tx state^.conn.next-tx
        ops (make [dynamic]Tx-Op)
        tx-meta (make [dynamic]Tx-Meta)
        tempids (make [dynamic]Tempid)
        segment (make [dynamic]Tx-Data)]
    (when has-duplicate
      (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment (fmt.tprintf "duplicate transaction fn registration: %s" duplicate-ident))))
    (for [data tx-data]
      (when (= data.op ":db.fn/call-ident")
        (let [current-source (tx-ops-overlay-db-read-source (addr source) (addr ops) tx)
              [segment-ok segment-error] (resolve-shared-source-tx-segment-source-only! state current-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
          (when (not segment-ok)
            (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment segment-error)))
          (let [call-source (tx-ops-overlay-db-read-source (addr source) (addr ops) tx)
                [fn-index fn-ok] (tx-fn-source-string-index registry data.ident)]
            (when (not fn-ok)
              (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment "transaction fn not registered")))
            (let [result (call-source-registered-tx-fn registry[fn-index] call-source data)]
              (when (not result.ok)
                (delete result.tx-data)
                (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment result.error)))
              (let [result-source (tx-ops-overlay-db-read-source (addr source) (addr ops) tx)
                    [result-ok result-error] (resolve-shared-source-tx-segment-source-only! state result-source (addr ops) (addr tx-meta) (addr tempids) (addr result.tx-data))]
                (delete result.tx-data)
                (when (not result-ok)
                  (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment result-error)))))))
        (continue))
      (arr.push! segment data))
    (let [tail-source (tx-ops-overlay-db-read-source (addr source) (addr ops) tx)
          [tail-ok tail-error] (resolve-shared-source-tx-segment-source-only! state tail-source (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
      (when (not tail-ok)
        (return (failed-store-source-registered-tx snapshot^ ops tx-meta tempids segment tail-error))))
    (delete segment)
    (let [[instant-ok instant-error] (finalize-source-transaction-instant! source (addr ops) (addr tx-meta) tx)]
      (when (not instant-ok)
        (delete ops)
        (delete tx-meta)
        (delete tempids)
        (return (failed-store-tx-report snapshot^ instant-error))))
    (let [[overlay-ops overlay-ok overlay-error] (source-overlay-ops-from-ops source (slice ops 0))]
      (when (not overlay-ok)
        (delete ops)
        (delete tx-meta)
        (delete tempids)
        (return (failed-store-tx-report snapshot^ overlay-error)))
      (let [report (store-tx-report-from-source-overlay-parts snapshot^ (slice overlay-ops 0) tx (slice tx-meta 0) (slice tempids 0) state^.next-entity-id)]
        (delete-owned-tx-ops overlay-ops)
        (delete ops)
        (delete tx-meta)
        (delete tempids)
        report))))

(defn with-store-db-report-tx-data-with-source-string-fns [snapshot: ^Store-DB, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (when (not (source-backed-store-db? snapshot))
    (return (failed-store-tx-report snapshot^ "source transaction functions require a source-backed Store-DB")))
  (let [[base-source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (failed-store-tx-report snapshot^ source-error)))
    (let [[state state-ok state-error] (shared-write-state-from-source-metadata base-source)]
      (when (not state-ok)
        (return (failed-store-tx-report snapshot^ state-error)))
      (let [report (with-store-db-report-tx-data-with-source-string-fns-state snapshot base-source (addr state) tx-data registry)]
        (delete-shared-write-state-metadata state)
        report))))

(defn retain-store-db [snapshot: Store-DB] -> Store-DB
  (case snapshot.kind
    .Resident (Store-DB {kind: .Resident
                         resident: (clone-db snapshot.resident)})
    .SQLite-Snapshot
      (let [[root-backed root-backed-ok] (sqlite-root-store-db-from-open-snapshot snapshot.sqlite-snapshot)]
        (if root-backed-ok
          root-backed
          (Store-DB {kind: .SQLite-Snapshot
                     sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)})))
    .SQLite-Lazy-Snapshot (Store-DB {kind: .SQLite-Lazy-Snapshot
                                     sqlite-lazy-path: (string-owned snapshot.sqlite-lazy-path)
                                     sqlite-lazy-basis-tx: snapshot.sqlite-lazy-basis-tx})
    .SQLite-Root-Snapshot (Store-DB {kind: .SQLite-Root-Snapshot
                                     sqlite-root-path: (string-owned snapshot.sqlite-root-path)
                                     sqlite-root-published: snapshot.sqlite-root-published
                                     sqlite-root-page-cache: (retain-sqlite-index-page-cache snapshot.sqlite-root-page-cache)})
    .SQLite-Tx-Ops-Overlay
      (if (not (= snapshot.sqlite-root-path ""))
        (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                   sqlite-root-path: (string-owned snapshot.sqlite-root-path)
                   sqlite-root-published: snapshot.sqlite-root-published
                   sqlite-root-page-cache: (retain-sqlite-index-page-cache snapshot.sqlite-root-page-cache)
                   overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                   overlay-tx: snapshot.overlay-tx})
        (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot snapshot.sqlite-snapshot)]
          (if root-ok
            (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                       sqlite-root-path: root-path
                       sqlite-root-published: root-published
                       sqlite-root-page-cache: root-cache
                       overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                       overlay-tx: snapshot.overlay-tx})
            (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                       sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)
                       overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                       overlay-tx: snapshot.overlay-tx}))))
    .SQLite-Datom-Overlay
      (if (not (= snapshot.sqlite-root-path ""))
        (Store-DB {kind: .SQLite-Datom-Overlay
                   sqlite-root-path: (string-owned snapshot.sqlite-root-path)
                   sqlite-root-published: snapshot.sqlite-root-published
                   sqlite-root-page-cache: (retain-sqlite-index-page-cache snapshot.sqlite-root-page-cache)
                   overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))})
        (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot snapshot.sqlite-snapshot)]
          (if root-ok
            (Store-DB {kind: .SQLite-Datom-Overlay
                       sqlite-root-path: root-path
                       sqlite-root-published: root-published
                       sqlite-root-page-cache: root-cache
                       overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))})
            (Store-DB {kind: .SQLite-Datom-Overlay
                       sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)
                       overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))}))))
    .SQLite-Datom-Log-Overlay
      (if (not (= snapshot.sqlite-root-path ""))
        (Store-DB {kind: .SQLite-Datom-Log-Overlay
                   sqlite-root-path: (string-owned snapshot.sqlite-root-path)
                   sqlite-root-published: snapshot.sqlite-root-published
                   sqlite-root-page-cache: (retain-sqlite-index-page-cache snapshot.sqlite-root-page-cache)
                   overlay-log: (retain-shared-datom-log snapshot.overlay-log)})
        (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot snapshot.sqlite-snapshot)]
          (if root-ok
            (Store-DB {kind: .SQLite-Datom-Log-Overlay
                       sqlite-root-path: root-path
                       sqlite-root-published: root-published
                       sqlite-root-page-cache: root-cache
                       overlay-log: (retain-shared-datom-log snapshot.overlay-log)})
            (Store-DB {kind: .SQLite-Datom-Log-Overlay
                       sqlite-snapshot: (retain-sqlite-db-snapshot snapshot.sqlite-snapshot)
                       overlay-log: (retain-shared-datom-log snapshot.overlay-log)}))))
    .Shared-Snapshot (Store-DB {kind: .Shared-Snapshot
                                shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)})
    .Shared-Tx-Ops-Overlay (Store-DB {kind: .Shared-Tx-Ops-Overlay
                                      shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)
                                      overlay-ops: (clone-tx-ops-owned (slice snapshot.overlay-ops 0))
                                      overlay-tx: snapshot.overlay-tx})
    .Shared-Datom-Overlay (Store-DB {kind: .Shared-Datom-Overlay
                                     shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)
                                     overlay-datoms: (clone-owned-datom-slice (slice snapshot.overlay-datoms 0))})
    .Shared-Datom-Log-Overlay (Store-DB {kind: .Shared-Datom-Log-Overlay
                                         shared-snapshot: (retain-shared-db-snapshot snapshot.shared-snapshot)
                                         overlay-log: (retain-shared-datom-log snapshot.overlay-log)})
     (Store-DB {})))

(defn store-db-from-read-source [source: DB-Read-Source] -> [snapshot: Store-DB, ok: bool, error: string]
  (case source.kind
    .Resident
      (return (Store-DB {kind: .Resident
                         resident: (clone-db source.db^)})
              true
              "")
    .Shared-Resident-Indexes
      (return (Store-DB {kind: .Resident
                         resident: (clone-db source.db^)})
              true
              "")
    .Shared-Resident-Datoms-And-Indexes
      (return (Store-DB {kind: .Shared-Snapshot
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})})
              true
              "")
    .Shared-Tx-Ops-Overlay
      (return (Store-DB {kind: .Shared-Tx-Ops-Overlay
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})
                         overlay-ops: (clone-tx-ops-owned (slice source.overlay-ops^ 0))
                         overlay-tx: source.overlay-tx})
              true
              "")
    .Shared-Datom-Overlay
      (return (Store-DB {kind: .Shared-Datom-Overlay
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})
                         overlay-datoms: (clone-owned-datom-slice (slice source.overlay-datoms^ 0))})
              true
              "")
    .Shared-Datom-Log-Overlay
      (return (Store-DB {kind: .Shared-Datom-Log-Overlay
                         shared-snapshot: (Shared-DB-Snapshot {datoms: (retain-shared-datom-log source.shared-datoms^)
                                                               indexes: (retain-shared-db-int-indexes source.shared-indexes^)})
                         overlay-log: (retain-shared-datom-log source.overlay-log^)})
              true
              "")
    .SQLite-Snapshot
      (let [[root-backed root-backed-ok] (sqlite-root-store-db-from-open-snapshot source.sqlite-snapshot^)]
        (if root-backed-ok
          (return root-backed true "")
          (return (Store-DB {kind: .SQLite-Snapshot
                             sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)})
                  true
                  "")))
    .SQLite-Tx-Ops-Overlay
      (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot source.sqlite-snapshot^)]
        (if root-ok
          (return (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                             sqlite-root-path: root-path
                             sqlite-root-published: root-published
                             sqlite-root-page-cache: root-cache
                             overlay-ops: (clone-tx-ops-owned (slice source.overlay-ops^ 0))
                             overlay-tx: source.overlay-tx})
                  true
                  "")
          (return (Store-DB {kind: .SQLite-Tx-Ops-Overlay
                             sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)
                             overlay-ops: (clone-tx-ops-owned (slice source.overlay-ops^ 0))
                             overlay-tx: source.overlay-tx})
                  true
                  "")))
    .SQLite-Datom-Overlay
      (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot source.sqlite-snapshot^)]
        (if root-ok
          (return (Store-DB {kind: .SQLite-Datom-Overlay
                             sqlite-root-path: root-path
                             sqlite-root-published: root-published
                             sqlite-root-page-cache: root-cache
                             overlay-datoms: (clone-owned-datom-slice (slice source.overlay-datoms^ 0))})
                  true
                  "")
          (return (Store-DB {kind: .SQLite-Datom-Overlay
                             sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)
                             overlay-datoms: (clone-owned-datom-slice (slice source.overlay-datoms^ 0))})
                  true
                  "")))
    .SQLite-Datom-Log-Overlay
      (let [[root-path root-published root-cache root-ok] (sqlite-root-fields-from-open-snapshot source.sqlite-snapshot^)]
        (if root-ok
          (return (Store-DB {kind: .SQLite-Datom-Log-Overlay
                             sqlite-root-path: root-path
                             sqlite-root-published: root-published
                             sqlite-root-page-cache: root-cache
                             overlay-log: (retain-shared-datom-log source.overlay-log^)})
                  true
                  "")
          (return (Store-DB {kind: .SQLite-Datom-Log-Overlay
                             sqlite-snapshot: (retain-sqlite-db-snapshot source.sqlite-snapshot^)
                             overlay-log: (retain-shared-datom-log source.overlay-log^)})
                  true
                  "")))
    .Tx-Ops-Overlay
      (let [[base base-ok base-error] (store-db-from-read-source source.overlay-base^)]
        (when (not base-ok)
          (return (Store-DB {}) false base-error))
        (let [out (store-db-source-overlay-from-resolved base (slice source.overlay-ops^ 0) source.overlay-tx)]
          (close-store-db base)
          (return out true "")))
    .Relation-Value
      (return (Store-DB {}) false "relation-value source cannot be exposed as a DB handle")
     (return (Store-DB {}) false "unsupported read source for DB handle")))

(defn ensure-sqlite-overlay-base-open! [snapshot: ^Store-DB] -> [ok: bool, error: string]
  (when (not (= snapshot^.sqlite-snapshot.path ""))
    (return true ""))
  (when (= snapshot^.sqlite-root-path "")
    (return false "SQLite overlay has no open or root-backed base snapshot"))
  (let [path (string-owned snapshot^.sqlite-root-path)
        published-root snapshot^.sqlite-root-published
        root-cache snapshot^.sqlite-root-page-cache
        [opened opened-ok opened-error] (sqlite-open-db-snapshot-at-root-with-cache path published-root sqlite-db-source-default-page-size root-cache)]
    (delete path)
    (when (not opened-ok)
      (return false opened-error))
    (set! snapshot^.sqlite-snapshot opened)
    (return true "")))

(defn store-db-read-source [snapshot: ^Store-DB] -> [source: DB-Read-Source, ok: bool, error: string]
  (case snapshot^.kind
    .Resident (return (resident-db-read-source (addr snapshot^.resident)) true "")
    .SQLite-Snapshot (return (sqlite-db-read-source (addr snapshot^.sqlite-snapshot)) true "")
    .SQLite-Lazy-Snapshot
      (let [path (string-owned snapshot^.sqlite-lazy-path)
            basis-tx snapshot^.sqlite-lazy-basis-tx
            [opened opened-ok opened-error] (sqlite-open-db-snapshot-at-basis path basis-tx sqlite-db-source-default-page-size)]
        (delete path)
        (when (not opened-ok)
          (return (DB-Read-Source {}) false opened-error))
        (delete snapshot^.sqlite-lazy-path)
        (set! snapshot^.sqlite-snapshot opened)
        (set! snapshot^.kind .SQLite-Snapshot)
        (return (sqlite-db-read-source (addr snapshot^.sqlite-snapshot)) true ""))
    .SQLite-Root-Snapshot
      (let [path (string-owned snapshot^.sqlite-root-path)
            published-root snapshot^.sqlite-root-published
            root-cache snapshot^.sqlite-root-page-cache
            [opened opened-ok opened-error] (sqlite-open-db-snapshot-at-root-with-cache path published-root sqlite-db-source-default-page-size root-cache)]
        (delete path)
        (when (not opened-ok)
          (return (DB-Read-Source {}) false opened-error))
        (delete snapshot^.sqlite-root-path)
        (set! snapshot^.sqlite-snapshot opened)
        (release-sqlite-index-page-cache! snapshot^.sqlite-root-page-cache)
        (set! snapshot^.sqlite-root-page-cache (SQLite-Index-Page-Cache {}))
        (set! snapshot^.kind .SQLite-Snapshot)
        (return (sqlite-db-read-source (addr snapshot^.sqlite-snapshot)) true ""))
    .SQLite-Tx-Ops-Overlay
      (let [[base-ok base-error] (ensure-sqlite-overlay-base-open! snapshot)]
        (if base-ok
          (return (sqlite-tx-ops-overlay-db-read-source (addr snapshot^.sqlite-snapshot) (addr snapshot^.overlay-ops) snapshot^.overlay-tx) true "")
          (return (DB-Read-Source {}) false base-error)))
    .SQLite-Datom-Overlay
      (let [[base-ok base-error] (ensure-sqlite-overlay-base-open! snapshot)]
        (if base-ok
          (return (sqlite-datom-overlay-db-read-source (addr snapshot^.sqlite-snapshot) (addr snapshot^.overlay-datoms)) true "")
          (return (DB-Read-Source {}) false base-error)))
    .SQLite-Datom-Log-Overlay
      (let [[base-ok base-error] (ensure-sqlite-overlay-base-open! snapshot)]
        (if base-ok
          (return (sqlite-datom-log-overlay-db-read-source (addr snapshot^.sqlite-snapshot) (addr snapshot^.overlay-log)) true "")
          (return (DB-Read-Source {}) false base-error)))
    .Shared-Snapshot (return (shared-db-snapshot-read-source (addr snapshot^.shared-snapshot)) true "")
    .Shared-Tx-Ops-Overlay (return (shared-tx-ops-overlay-db-read-source (addr snapshot^.shared-snapshot.datoms) (addr snapshot^.shared-snapshot.indexes) (addr snapshot^.overlay-ops) snapshot^.overlay-tx) true "")
    .Shared-Datom-Overlay (return (shared-datom-overlay-db-read-source (addr snapshot^.shared-snapshot.datoms) (addr snapshot^.shared-snapshot.indexes) (addr snapshot^.overlay-datoms)) true "")
    .Shared-Datom-Log-Overlay (return (shared-datom-log-overlay-db-read-source (addr snapshot^.shared-snapshot.datoms) (addr snapshot^.shared-snapshot.indexes) (addr snapshot^.overlay-log)) true "")
     (return (DB-Read-Source {}) false "store DB snapshot is not open")))

(defn q-result-store-db-text [snapshot: ^Store-DB, text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source source text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-text-owned [snapshot: ^Store-DB, text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source-owned source text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-text [snapshot: ^Store-DB, text: string] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-text-db-read-source-profiled source text)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source-with-input-text source text inputs-text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-text-owned-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-text-db-read-source-owned-with-input-text source text inputs-text)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-text-db-read-source-profiled-with-input-text source text inputs-text)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-prepared [snapshot: ^Store-DB, prepared: Prepared-Query] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source source prepared)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-prepared-with-inputs [snapshot: ^Store-DB, prepared: Prepared-Query, inputs: []Query-Input] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source-with-inputs source prepared inputs)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-prepared-with-inputs-and-fns [snapshot: ^Store-DB, prepared: Prepared-Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source-with-sources-inputs-and-fns source ([]DB-Read-Named-Source []) prepared inputs registry)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-query-with-inputs [snapshot: ^Store-DB, query: Query, inputs: []Query-Input] -> Query-Result
  (let [prepared (Prepared-Query {ok: true error: "" query: query})]
    (defer (delete-prepared-query-shallow prepared))
    (q-result-store-db-prepared-with-inputs snapshot prepared inputs)))

(defn q-result-store-db-query-with-inputs-and-fns [snapshot: ^Store-DB, query: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Query-Result
  (let [prepared (Prepared-Query {ok: true error: "" query: query})]
    (defer (delete-prepared-query-shallow prepared))
    (q-result-store-db-prepared-with-inputs-and-fns snapshot prepared inputs registry)))

(defn q-result-store-db-prepared-owned [snapshot: ^Store-DB, prepared: Prepared-Query] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source-owned source prepared)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-prepared-owned-with-inputs [snapshot: ^Store-DB, prepared: Prepared-Query, inputs: []Query-Input] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source-owned-with-inputs source prepared inputs)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-profiled-store-db-prepared [snapshot: ^Store-DB, prepared: Prepared-Query] -> Profiled-Result-Set
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-prepared-db-read-source-profiled source prepared)
      (profiled-result-set (result-set-error source-error) (query-stats-empty)))))

(defn q-result-store-db-prepared-with-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, inputs-text: string] -> Query-Result
  (when (not prepared.ok)
    (return (query-result-owned-values (result-set-error prepared.error))))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (query-result-owned-values (result-set-error source-error))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
      (when (not input-ok)
        (delete-owned-query-inputs inputs)
        (return (query-result-owned-values (result-set-error input-error))))
      (let [result (db-read-source-q-query-with-inputs source prepared.query (slice inputs 0))]
        (delete-owned-query-inputs inputs)
        (query-result-db-read-source-query-result prepared.query result)))))

(defn q-result-store-db-prepared-owned-with-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, inputs-text: string] -> Query-Result
  (when (not prepared.ok)
    (return (query-result-owned-values (result-set-error prepared.error))))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (query-result-owned-values (result-set-error source-error))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
      (when (not input-ok)
        (delete-owned-query-inputs inputs)
        (return (query-result-owned-values (result-set-error input-error))))
      (let [result (db-read-source-q-query-with-inputs source prepared.query (slice inputs 0))]
        (delete-owned-query-inputs inputs)
        (query-result-db-read-source-query-result-owned prepared.query result)))))

(defn q-profiled-store-db-prepared-with-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, inputs-text: string] -> Profiled-Result-Set
  (when (not prepared.ok)
    (return (profiled-result-set (result-set-error prepared.error) (query-stats-empty))))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (profiled-result-set (result-set-error source-error) (query-stats-empty))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
      (when (not input-ok)
        (delete-owned-query-inputs inputs)
        (return (profiled-result-set (result-set-error input-error) (query-stats-empty))))
      (let [profiled (q-prepared-db-read-source-profiled-with-inputs source prepared (slice inputs 0))]
        (delete-owned-query-inputs inputs)
        profiled))))

(defn q-result-store-db-prepared-with-rules [snapshot: ^Store-DB, prepared: Prepared-Query, prepared-rules: Prepared-Rules, inputs: []Query-Input] -> Query-Result
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (q-result-prepared-db-read-source-with-rules source prepared prepared-rules inputs)
      (query-result-owned-values (result-set-error source-error)))))

(defn q-result-store-db-prepared-with-rules-input-text [snapshot: ^Store-DB, prepared: Prepared-Query, prepared-rules: Prepared-Rules, inputs-text: string] -> Query-Result
  (when (not prepared.ok)
    (return (query-result-owned-values (result-set-error prepared.error))))
  (when (not prepared-rules.ok)
    (return (query-result-owned-values (result-set-error prepared-rules.error))))
  (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
    (when (not input-ok)
      (delete-owned-query-inputs inputs)
      (return (query-result-owned-values (result-set-error input-error))))
    (let [out (q-result-store-db-prepared-with-rules snapshot prepared prepared-rules (slice inputs 0))]
      (delete-owned-query-inputs inputs)
      out)))

(defn q-result-store-db-text-with-rules [snapshot: ^Store-DB, text: string, rules-text: string] -> Query-Result
  (let [prepared (prepare-query-text text)
        rules (parse-rules-text rules-text)]
    (defer (delete-prepared-query-shallow prepared))
    (defer (delete-prepared-rules-shallow rules))
    (q-result-store-db-prepared-with-rules snapshot prepared rules ([]Query-Input []))))

(defn q-result-store-db-text-with-rules-input-text [snapshot: ^Store-DB, text: string, rules-text: string, inputs-text: string] -> Query-Result
  (let [prepared (prepare-query-text text)
        rules (parse-rules-text rules-text)]
    (defer (delete-prepared-query-shallow prepared))
    (defer (delete-prepared-rules-shallow rules))
    (q-result-store-db-prepared-with-rules-input-text snapshot prepared rules inputs-text)))

(defn store-db-result-value [snapshot: ^Store-DB, result: Result-Set] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (if source-ok
      (db-read-source-result-set-value source result)
      (return (Value {}) false source-error))))

(defn store-db-materialize-db [snapshot: ^Store-DB] -> [db: DB, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (build-db (make [dynamic]Datom)) false source-error))
    (db-read-source-materialize-db source)))

(defn with-store-db-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Tx-Report
  (when (source-backed-store-db? snapshot)
    (return (failed-tx-report
              (build-db (make [dynamic]Datom))
              "with-store-db-tx-data is resident-only; use with-store-db-report-tx-data for source-backed Store-DB values")))
  (let [[db db-ok db-error] (store-db-materialize-db snapshot)]
    (when (not db-ok)
      (return (failed-tx-report db db-error)))
    (with-tx-data db tx-data)))

(defn with-store-db-report-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Store-Tx-Report
  (when (source-backed-store-db? snapshot)
    (let [[report used ok error] (with-store-db-source-overlay-report-tx-data snapshot tx-data)]
      (when ok
        (when used
          (return report)))
      (when (not ok)
        (return (failed-store-tx-report snapshot^ error)))))
  (when (source-backed-store-db? snapshot)
    (return (failed-store-tx-report snapshot^ "unsupported source-backed transaction shape")))
  (let [resident-report (with-store-db-tx-data snapshot tx-data)
        before (Store-DB {kind: .Resident
                          resident: (build-db (clone-owned-datom-slice (slice resident-report.db-before.datoms 0)))})
        after (Store-DB {kind: .Resident
                         resident: (build-db (clone-owned-datom-slice (slice resident-report.db-after.datoms 0)))})
        tempids (arr.into [dynamic]Tempid (slice resident-report.tempids 0))
        report (Store-Tx-Report {ok: resident-report.ok
                                 error: (string-owned resident-report.error)
                                 db-before: before
                                 db-after: after
                                 tx-data: (clone-owned-datom-slice (slice resident-report.tx-data 0))
                                 tx: resident-report.tx
                                 tx-meta: (clone-tx-meta (slice resident-report.tx-meta 0))
                                 tempids: tempids
                                 source-append-metadata-known: false
                                 source-new-entities-after-existing: false
                                 source-eavt-append-mode: false
                                 source-aevt-append-mode: false
                                 source-avet-append-mode: false
                                 source-vaet-append-mode: false
                                 source-published-root-known: false
                                 source-published-root: (SQLite-Durable-Published-Root {})})]
    (delete-store-db-temp-tx-report resident-report)
    report))

(defn delete-store-db-temp-tx-report [report: Tx-Report]
  (if report.ok
    (do
      ;; The temporary resident db-after is the last owner of the full datom
      ;; log once its store snapshot has been built. db-before shares the old
      ;; portion of that log, while tx-data owns a separate copy.
      (delete-owned-db report.db-before)
      (delete-resident-db report.db-after)
      (delete report.error)
      (delete-owned-datoms report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))
    (do
      (delete-owned-db report.db-before)
      (delete report.error)
      (delete report.tx-data)
      (delete report.tx-meta)
      (delete report.tempids)
      (delete-tx-publish-plan report.publish-plan))))

(defn db-with-store-db-tx-data [snapshot: ^Store-DB, tx-data: []Tx-Data] -> Store-DB
  (when (= snapshot^.kind .Shared-Snapshot)
    (let [[source-snapshot source-used source-ok _] (shared-db-snapshot-db-with-source-append-tx-data snapshot^.shared-snapshot tx-data)]
      (when source-ok
        (when source-used
          (return (Store-DB {kind: .Shared-Snapshot
                             shared-snapshot: source-snapshot}))))
      (let [[overlay-snapshot overlay-used overlay-ok _] (shared-store-db-with-source-overlay-tx-data snapshot^.shared-snapshot tx-data)]
        (when overlay-ok
          (when overlay-used
            (return overlay-snapshot))))))
  (when (= snapshot^.kind .SQLite-Snapshot)
    (let [[overlay-snapshot overlay-used overlay-ok _] (store-db-with-source-overlay-tx-data snapshot tx-data)]
      (when overlay-ok
        (when overlay-used
          (return overlay-snapshot)))))
  (when (or (= snapshot^.kind .Shared-Tx-Ops-Overlay)
            (= snapshot^.kind .SQLite-Tx-Ops-Overlay)
            (= snapshot^.kind .Shared-Datom-Overlay)
            (= snapshot^.kind .SQLite-Datom-Overlay)
            (= snapshot^.kind .Shared-Datom-Log-Overlay)
            (= snapshot^.kind .SQLite-Datom-Log-Overlay))
    (let [[overlay-snapshot overlay-used overlay-ok _] (store-db-with-source-overlay-tx-data snapshot tx-data)]
      (when overlay-ok
        (when overlay-used
          (return overlay-snapshot)))))
  (when (source-backed-store-db? snapshot)
    (let [report (with-store-db-report-tx-data snapshot tx-data)
          out (if report.ok
                (retain-store-db report.db-after)
                (retain-store-db report.db-before))]
      (delete-store-tx-report report)
      (return out)))
  (let [report (with-store-db-tx-data snapshot tx-data)]
    (case snapshot^.kind
      .SQLite-Snapshot
        (if report.ok
          (let [out (sqlite-store-db-with-report-overlay snapshot^.sqlite-snapshot report)]
            (delete-store-db-temp-tx-report report)
            out)
          (let [out (retain-store-db snapshot^)]
            (delete-store-db-temp-tx-report report)
            out))
      .Shared-Snapshot
        (if report.ok
          (let [out (shared-store-db-with-report-overlay snapshot^.shared-snapshot report)]
            (delete-store-db-temp-tx-report report)
            out)
          (let [out (retain-store-db snapshot^)]
            (delete-store-db-temp-tx-report report)
            out))
      (if report.ok
        (let [out (Store-DB {kind: .Resident
                             resident: (clone-db report.db-after)})]
          (delete-store-db-temp-tx-report report)
          out)
        (let [out (Store-DB {kind: .Resident
                             resident: (clone-db report.db-before)})]
          (delete-store-db-temp-tx-report report)
          out)))))

(defn source-backed-store-db? [snapshot: ^Store-DB] -> bool
  (or (= snapshot^.kind .Shared-Snapshot)
      (= snapshot^.kind .SQLite-Snapshot)
      (= snapshot^.kind .SQLite-Lazy-Snapshot)
      (= snapshot^.kind .SQLite-Root-Snapshot)
      (= snapshot^.kind .Shared-Tx-Ops-Overlay)
      (= snapshot^.kind .SQLite-Tx-Ops-Overlay)
      (= snapshot^.kind .Shared-Datom-Overlay)
      (= snapshot^.kind .SQLite-Datom-Overlay)
      (= snapshot^.kind .Shared-Datom-Log-Overlay)
      (= snapshot^.kind .SQLite-Datom-Log-Overlay)))

(defn with-store-db-text [snapshot: ^Store-DB, text: string] -> Tx-Report
  (when (source-backed-store-db? snapshot)
    (return (failed-tx-report
              (build-db (make [dynamic]Datom))
              "with-store-db-text is resident-only; use with-store-db-report-text for source-backed Store-DB values")))
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (when (not prepared.ok)
      (let [[db db-ok _] (store-db-materialize-db snapshot)]
        (return (failed-tx-report db prepared.error))))
    (with-store-db-tx-data snapshot (slice prepared.tx-data 0))))

(defn with-store-db-report-text [snapshot: ^Store-DB, text: string] -> Store-Tx-Report
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (if prepared.ok
      (with-store-db-report-tx-data snapshot (slice prepared.tx-data 0))
      (failed-store-tx-report snapshot^ prepared.error))))

(defn with-store-db-report-text-with-source-string-fns [snapshot: ^Store-DB, text: string, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (if prepared.ok
      (with-store-db-report-tx-data-with-source-string-fns snapshot (slice prepared.tx-data 0) registry)
      (failed-store-tx-report snapshot^ prepared.error))))

(defn db-with-store-db-tx-data-with-source-string-fns [snapshot: ^Store-DB, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-DB
  (let [report (with-store-db-report-tx-data-with-source-string-fns snapshot tx-data registry)
        out (if report.ok
              (retain-store-db report.db-after)
              (retain-store-db report.db-before))]
    (delete-store-tx-report report)
    out))

(defn db-with-store-db-text-with-source-string-fns [snapshot: ^Store-DB, text: string, registry: []Tx-Fn-Source-String] -> Store-DB
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (if prepared.ok
      (db-with-store-db-tx-data-with-source-string-fns snapshot (slice prepared.tx-data 0) registry)
      (retain-store-db snapshot^))))

(defn store-tx-report-source-append-modes [report: Store-Tx-Report] -> SQLite-Index-Append-Modes
  (SQLite-Index-Append-Modes {eavt: report.source-eavt-append-mode
                              aevt: report.source-aevt-append-mode
                              avet: report.source-avet-append-mode
                              vaet: report.source-vaet-append-mode}))

(defn source-append-modes-for-store-report [source: DB-Read-Source, report: Store-Tx-Report, start-index: int] -> [modes: SQLite-Index-Append-Modes, ok: bool, error: string]
  (if report.source-append-metadata-known
    (return (store-tx-report-source-append-modes report) true "")
    (source-append-index-modes-for-persist source (slice report.tx-data 0) start-index report.source-new-entities-after-existing)))

(defn sqlite-committed-source-store-tx-report-with-before [path: string, before: Store-DB, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, tempids: []Tempid, new-entities-after-existing: bool, published-root: SQLite-Durable-Published-Root] -> Store-Tx-Report
  (Store-Tx-Report {ok: true
                    error: ""
                    db-before: (retain-store-db before)
                    db-after: (sqlite-root-store-db path published-root)
                    tx-data: (clone-owned-datom-slice tx-data)
                    tx: tx
                    tx-meta: (clone-tx-meta tx-meta)
                    tempids: (store-report-tempids-with-current-tx tempids tx)
                    source-append-metadata-known: true
                    source-new-entities-after-existing: new-entities-after-existing
                    source-eavt-append-mode: published-root.modes.eavt
                    source-aevt-append-mode: published-root.modes.aevt
                    source-avet-append-mode: published-root.modes.avet
                    source-vaet-append-mode: published-root.modes.vaet
                    source-published-root-known: true
                    source-published-root: published-root}))

(defn sqlite-committed-source-store-tx-report [path: string, tx: u64, tx-data: []Datom, tx-meta: []Tx-Meta, tempids: []Tempid, new-entities-after-existing: bool, published-root: SQLite-Durable-Published-Root] -> Store-Tx-Report
  (let [before (sqlite-root-store-db-at-basis-or-lazy path (- tx 1))
        out (sqlite-committed-source-store-tx-report-with-before path before tx tx-data tx-meta tempids new-entities-after-existing published-root)]
    (close-store-db before)
    out))

(defn sqlite-commit-source-overlay-report-mode [store: ^SQLite-Conn, overlay-report: Store-Tx-Report, owns-sqlite-tx: bool] -> Store-Tx-Report
  (when (not overlay-report.ok)
    (return overlay-report))
  (let [report-before (retain-store-db overlay-report.db-before)
        borrow-before (= overlay-report.db-before.kind .SQLite-Snapshot)
        opened-before (if borrow-before
                        overlay-report.db-before
                        (retain-store-db overlay-report.db-before))
        [_ before-source-ok before-source-error] (store-db-read-source (addr opened-before))]
    (when (not before-source-ok)
      (let [failed (failed-store-tx-report overlay-report.db-before before-source-error)]
        (close-store-db report-before)
        (if borrow-before
          (do
            (delete-store-tx-report-preserve-db-before overlay-report)
            (close-store-db opened-before))
          (do
            (close-store-db opened-before)
            (delete-store-tx-report overlay-report)))
        (return failed)))
    (when (not (= opened-before.kind .SQLite-Snapshot))
      (let [failed (failed-store-tx-report opened-before "source transaction functions require a SQLite-backed Store-DB")]
        (close-store-db report-before)
        (if borrow-before
          (do
            (delete-store-tx-report-preserve-db-before overlay-report)
            (close-store-db opened-before))
          (do
            (close-store-db opened-before)
            (delete-store-tx-report overlay-report)))
        (return failed)))
  (let [before-snapshot opened-before.sqlite-snapshot
        source (sqlite-db-read-source (addr before-snapshot))
        start-index before-snapshot.datom-count]
    (let [append-modes (store-tx-report-source-append-modes overlay-report)
          plan (sqlite-durable-append-plan-from-modes (slice overlay-report.tx-data 0) start-index append-modes (addr store^.direct-write-profile))
          [published-root append-ok append-error]
          (append-source-direct-sqlite-conn-from-source-plan-published-mode
            store
            source
            overlay-report.tx
            (slice overlay-report.tx-data 0)
            (slice overlay-report.tx-meta 0)
            plan
            (addr store^.direct-write-profile)
            owns-sqlite-tx)]
      (defer (delete-sqlite-durable-append-plan plan))
      (when (not append-ok)
        (let [failed (failed-store-tx-report opened-before append-error)]
          (close-store-db report-before)
          (if borrow-before
            (do
              (delete-store-tx-report-preserve-db-before overlay-report)
              (close-store-db opened-before))
            (do
              (close-store-db opened-before)
              (delete-store-tx-report overlay-report)))
          (return failed)))
      (sqlite-conn-advance-write-state-cache-after-datoms! store (slice overlay-report.tx-data 0))
      (let [out (sqlite-committed-source-store-tx-report-with-before
                  store^.path
                  report-before
                  overlay-report.tx
                  (slice overlay-report.tx-data 0)
                  (slice overlay-report.tx-meta 0)
                  (slice overlay-report.tempids 0)
                  overlay-report.source-new-entities-after-existing
                  published-root)]
        (close-store-db report-before)
        (if borrow-before
          (do
            (delete-store-tx-report-preserve-db-before overlay-report)
            (close-store-db opened-before))
          (do
            (close-store-db opened-before)
            (delete-store-tx-report overlay-report)))
        out)))))

(defn sqlite-commit-source-overlay-report [store: ^SQLite-Conn, overlay-report: Store-Tx-Report] -> Store-Tx-Report
  (sqlite-commit-source-overlay-report-mode store overlay-report true))

(defn db-with-store-db-text [snapshot: ^Store-DB, text: string] -> Store-DB
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (if prepared.ok
      (db-with-store-db-tx-data snapshot (slice prepared.tx-data 0))
      (retain-store-db snapshot^))))

(defn q-store-db-value-text-with-input-text [snapshot: ^Store-DB, text: string, inputs-text: string] -> [value: Value, ok: bool, error: string]
  (let [result (q-result-store-db-text-with-input-text snapshot text inputs-text)]
    (defer (delete-query-result result))
    (if result.result.ok
      (store-db-result-value snapshot result.result)
      (return (value-map
                ([]Value [(value-keyword ":ok") (value-bool false)
                          (value-keyword ":error") (value-string result.result.error)
                          (value-keyword ":rows") (value-vector ([]Value []))]))
              true
              ""))))

(defn store-db-entity [snapshot: ^Store-DB, entity-id: u64] -> [entity: Store-Entity, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-Entity {}) false source-error))
    (let [[_ _ exists range-ok range-error] (db-read-source-eavt-entity-range source entity-id)]
      (when (not range-ok)
        (return (Store-Entity {}) false range-error))
      (return (Store-Entity {db: (retain-store-db snapshot^) e: entity-id found: exists}) true ""))))

(defn store-db-entity-lookup-ref [snapshot: ^Store-DB, attr: string, lookup-value: Value] -> [entity: Store-Entity, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-Entity {}) false source-error))
    (let [[entity-id entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attr lookup-value)]
      (when (not entity-ok)
        (if (= lookup-error "")
          (return (Store-Entity {db: (retain-store-db snapshot^) e: 0 found: false}) true "")
          (return (Store-Entity {}) false lookup-error)))
      (store-db-entity snapshot entity-id))))

(defn store-db-entity-ident [snapshot: ^Store-DB, ident: string] -> [entity: Store-Entity, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Store-Entity {}) false source-error))
    (let [[entity-id entity-ok ident-error] (db-read-source-schema-entity-for-attr source ident)]
      (when (not entity-ok)
        (if (= ident-error "")
          (return (Store-Entity {db: (retain-store-db snapshot^) e: 0 found: false}) true "")
          (return (Store-Entity {}) false ident-error)))
      (store-db-entity snapshot entity-id))))

(defn store-entity-id [entity: Store-Entity] -> u64
  entity.e)

(defn store-entity-found? [entity: Store-Entity] -> bool
  entity.found)

(defn store-entity-values [entity: ^Store-Entity, attr: string] -> [values: [dynamic]Value, ok: bool, error: string]
  (let [out (make [dynamic]Value)]
    (when (not entity^.found)
      (return out true ""))
    (when (= attr ":db/id")
      (arr.push! out (value-entity entity^.e))
      (return out true ""))
    (let [[source source-ok source-error] (store-db-read-source (addr entity^.db))]
      (when (not source-ok)
        (delete out)
        (return (make [dynamic]Value) false source-error))
      (if (reverse-attr? attr)
        (let [forward-attr (forward-attr-for-reverse attr)
              [datoms datoms-ok datoms-error] (db-read-source-datoms-by-reverse-entity-attr source entity^.e forward-attr)]
          (when (not datoms-ok)
            (delete out)
            (return (make [dynamic]Value) false datoms-error))
          (for [datom datoms]
            (arr.push! out (value-entity datom.e)))
          (delete-owned-datoms datoms)
          (return out true ""))
        (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity^.e attr)]
          (when (not datoms-ok)
            (delete out)
            (return (make [dynamic]Value) false datoms-error))
          (for [datom datoms]
            (arr.push! out (value-owned datom.v)))
          (delete-owned-datoms datoms)
          (return out true ""))))))

(defn store-entity-first-value [entity: ^Store-Entity, attr: string] -> [value: Value, ok: bool, error: string]
  (let [[values values-ok values-error] (store-entity-values entity attr)]
    (when (not values-ok)
      (return (Value {}) false values-error))
    (when (= (count values) 0)
      (delete values)
      (return (Value {}) false ""))
    (let [out (value-owned values[0])]
      (for [value values]
        (delete-owned-value value))
      (delete values)
      (return out true ""))))

(defn store-entity-first-value-kw [entity: ^Store-Entity, attr: keyword] -> [value: Value, ok: bool, error: string]
  (store-entity-first-value entity (keyword-text attr)))

(defn store-entity-get [entity: ^Store-Entity, attr: string] -> Value
  (let [[value value-ok _] (store-entity-first-value entity attr)]
    (if value-ok
      value
      (value-nil))))

(defn store-entity-get-kw [entity: ^Store-Entity, attr: keyword] -> Value
  (store-entity-get entity (keyword-text attr)))

(defn store-entity-contains? [entity: ^Store-Entity, attr: string] -> bool
  (let [[value value-ok _] (store-entity-first-value entity attr)]
    (when value-ok
      (delete-owned-value value))
    value-ok))

(defn store-entity-ref [entity: ^Store-Entity, attr: string] -> [ref: Store-Entity, ok: bool, error: string]
  (let [[value value-ok value-error] (store-entity-first-value entity attr)]
    (when (not value-ok)
      (if (= value-error "")
        (return (Store-Entity {db: (retain-store-db entity^.db) e: 0 found: false}) true "")
        (return (Store-Entity {}) false value-error)))
    (defer (delete-owned-value value))
    (when (not (= value.kind .Entity))
      (return (Store-Entity {db: (retain-store-db entity^.db) e: 0 found: false}) true ""))
    (store-db-entity (addr entity^.db) value.entity)))

(defn store-entity-ref-kw [entity: ^Store-Entity, attr: keyword] -> [ref: Store-Entity, ok: bool, error: string]
  (store-entity-ref entity (keyword-text attr)))

(defn store-entity-refs [entity: ^Store-Entity, attr: string] -> [refs: [dynamic]Store-Entity, ok: bool, error: string]
  (let [out (make [dynamic]Store-Entity)
        [values values-ok values-error] (store-entity-values entity attr)]
    (when (not values-ok)
      (return out false values-error))
    (for [value values]
      (when (= value.kind .Entity)
        (let [[ref ref-ok ref-error] (store-db-entity (addr entity^.db) value.entity)]
          (when (not ref-ok)
            (for [existing out]
              (close-store-entity existing))
            (delete out)
            (for [existing-value values]
              (delete-owned-value existing-value))
            (delete values)
            (return (make [dynamic]Store-Entity) false ref-error))
          (when ref.found
            (arr.push! out ref)))))
    (for [value values]
      (delete-owned-value value))
    (delete values)
    (return out true "")))

(defn store-entity-refs-kw [entity: ^Store-Entity, attr: keyword] -> [refs: [dynamic]Store-Entity, ok: bool, error: string]
  (store-entity-refs entity (keyword-text attr)))

(defn close-store-entities [entities: [dynamic]Store-Entity]
  (for [entity entities]
    (close-store-entity entity))
  (delete entities))

(defn touch-store-entity [entity: ^Store-Entity] -> [value: Value, ok: bool, error: string]
  (if entity^.found
    (pull-store-db-value-text (addr entity^.db) "[*]" entity^.e)
    (return (value-map ([]Value [])) true "")))

(defn pull-store-db-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, entity: u64] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity pattern)]
      (when (not pull-ok)
        (return (Value {}) false pull-error))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-result-value source pull)]
        (delete-pull-result-owned-values pull)
        (return rendered rendered-ok rendered-error)))))

(defn pull-store-db-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, entity: u64] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-store-db-value-pattern snapshot (slice prepared.pattern 0) entity))

(defn pull-store-db-value-text [snapshot: ^Store-DB, pattern-text: string, entity: u64] -> [value: Value, ok: bool, error: string]
  (let [prepared (prepare-pull-pattern-text pattern-text)]
    (defer (delete-prepared-pull-pattern-shallow prepared))
    (pull-store-db-value-prepared snapshot prepared entity)))

(defn pull-store-db-lookup-ref-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attr lookup-value)]
      (when (not entity-ok)
        (if (= lookup-error "")
          (return (value-nil) true "")
          (return (Value {}) false lookup-error)))
      (pull-store-db-value-pattern snapshot pattern entity))))

(defn pull-store-db-lookup-ref-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-store-db-lookup-ref-value-pattern snapshot (slice prepared.pattern 0) attr lookup-value))

(defn pull-store-db-lookup-ref-value-text [snapshot: ^Store-DB, pattern-text: string, attr: string, lookup-value: Value] -> [value: Value, ok: bool, error: string]
  (let [prepared (prepare-pull-pattern-text pattern-text)]
    (defer (delete-prepared-pull-pattern-shallow prepared))
    (pull-store-db-lookup-ref-value-prepared snapshot prepared attr lookup-value)))

(defn pull-many-store-db-value-pattern [snapshot: ^Store-DB, pattern: []Pull-Spec, entities: []u64] -> [value: Value, ok: bool, error: string]
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [pulls (make [dynamic]Pull-Result 0 (count entities))]
      (for [entity entities]
        (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity pattern)]
          (when (not pull-ok)
            (for [existing pulls]
              (delete-pull-result-owned-values existing))
            (delete pulls)
            (return (Value {}) false pull-error))
          (arr.push! pulls pull)))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-many-results-value source (slice pulls 0))]
        (for [pull pulls]
          (delete-pull-result-owned-values pull))
        (delete pulls)
        (return rendered rendered-ok rendered-error)))))

(defn pull-many-store-db-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, entities: []u64] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (pull-many-store-db-value-pattern snapshot (slice prepared.pattern 0) entities))

(defn pull-many-store-db-value-text [snapshot: ^Store-DB, pattern-text: string, entities: []u64] -> [value: Value, ok: bool, error: string]
  (let [prepared (prepare-pull-pattern-text pattern-text)]
    (defer (delete-prepared-pull-pattern-shallow prepared))
    (pull-many-store-db-value-prepared snapshot prepared entities)))

(defn pull-many-store-db-lookup-refs-value-prepared [snapshot: ^Store-DB, prepared: Prepared-Pull-Pattern, attrs: []string, lookup-values: []Value] -> [value: Value, ok: bool, error: string]
  (when (not prepared.ok)
    (return (Value {}) false prepared.error))
  (let [[source source-ok source-error] (store-db-read-source snapshot)]
    (when (not source-ok)
      (return (Value {}) false source-error))
    (let [pulls (make [dynamic]Pull-Result 0 (count lookup-values))]
      (for [lookup-value index lookup-values]
        (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attrs[index] lookup-value)]
          (if entity-ok
            (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern source entity (slice prepared.pattern 0))]
              (when (not pull-ok)
                (for [existing pulls]
                  (delete-pull-result-owned-values existing))
                (delete pulls)
                (return (Value {}) false pull-error))
              (arr.push! pulls pull))
            (if (= lookup-error "")
              (arr.push! pulls (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))
              (do
                (for [existing pulls]
                  (delete-pull-result-owned-values existing))
                (delete pulls)
                (return (Value {}) false lookup-error))))))
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-many-results-value source (slice pulls 0))]
        (for [pull pulls]
          (delete-pull-result-owned-values pull))
        (delete pulls)
        (return rendered rendered-ok rendered-error)))))

(defn pull-many-store-db-lookup-refs-value-text [snapshot: ^Store-DB, pattern-text: string, attrs: []string, lookup-values: []Value] -> [value: Value, ok: bool, error: string]
  (let [prepared (prepare-pull-pattern-text pattern-text)]
    (defer (delete-prepared-pull-pattern-shallow prepared))
    (pull-many-store-db-lookup-refs-value-prepared snapshot prepared attrs lookup-values)))

(defn sqlite-open-db-snapshot [path: string, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-DB-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle handle page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.indexes.owns-handle true)
      (set! opened-snapshot.path (string-owned path))
      (return opened-snapshot true ""))))

(defn sqlite-open-db-snapshot-at-basis [path: string, basis-tx: u64, page-size: int] -> [snapshot: SQLite-DB-Snapshot, ok: bool, error: string]
  (let [[handle open-ok open-error] (sqlite-open-live-raw path)]
    (when (not open-ok)
      (return (SQLite-DB-Snapshot {}) false open-error))
    (let [[opened-snapshot snapshot-ok snapshot-error] (sqlite-open-db-snapshot-handle-at-basis handle basis-tx page-size)]
      (when (not snapshot-ok)
        (sqlite-close-live-raw handle)
        (return opened-snapshot false snapshot-error))
      (set! opened-snapshot.indexes.owns-handle true)
      (set! opened-snapshot.path (string-owned path))
      (return opened-snapshot true ""))))

(defn close-sqlite-db-snapshot! [snapshot: ^SQLite-DB-Snapshot]
  (sqlite-finalize-stmt-raw snapshot^.datom-stmt)
  (close-sqlite-index-snapshot! (addr snapshot^.indexes))
  (delete-sqlite-db-snapshot-datom-cache! snapshot)
  (delete snapshot^.path)
  (set! snapshot^ (SQLite-DB-Snapshot {})))

(defn close-sqlite-db-snapshot [snapshot: SQLite-DB-Snapshot]
  (let [owned snapshot]
    (close-sqlite-db-snapshot! (addr owned))))

(defn close-store-db! [snapshot: ^Store-DB]
  (case snapshot^.kind
    .Resident (delete-owned-db snapshot^.resident)
    .SQLite-Snapshot (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot))
    .SQLite-Lazy-Snapshot (delete snapshot^.sqlite-lazy-path)
    .SQLite-Root-Snapshot
      (do
        (delete snapshot^.sqlite-root-path)
        (release-sqlite-index-page-cache! snapshot^.sqlite-root-page-cache))
    .SQLite-Tx-Ops-Overlay
      (do
        (when (not (= snapshot^.sqlite-snapshot.path ""))
          (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot)))
        (when (not (= snapshot^.sqlite-root-path ""))
          (do
            (delete snapshot^.sqlite-root-path)
            (release-sqlite-index-page-cache! snapshot^.sqlite-root-page-cache)))
        (delete-owned-tx-ops snapshot^.overlay-ops))
    .SQLite-Datom-Overlay
      (do
        (when (not (= snapshot^.sqlite-snapshot.path ""))
          (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot)))
        (when (not (= snapshot^.sqlite-root-path ""))
          (do
            (delete snapshot^.sqlite-root-path)
            (release-sqlite-index-page-cache! snapshot^.sqlite-root-page-cache)))
        (delete-owned-datoms snapshot^.overlay-datoms))
    .SQLite-Datom-Log-Overlay
      (do
        (when (not (= snapshot^.sqlite-snapshot.path ""))
          (close-sqlite-db-snapshot! (addr snapshot^.sqlite-snapshot)))
        (when (not (= snapshot^.sqlite-root-path ""))
          (do
            (delete snapshot^.sqlite-root-path)
            (release-sqlite-index-page-cache! snapshot^.sqlite-root-page-cache)))
        (delete-shared-datom-log snapshot^.overlay-log))
    .Shared-Snapshot (delete-shared-db-snapshot snapshot^.shared-snapshot)
    .Shared-Tx-Ops-Overlay
      (do
        (delete-shared-db-snapshot snapshot^.shared-snapshot)
        (delete-owned-tx-ops snapshot^.overlay-ops))
    .Shared-Datom-Overlay
      (do
        (delete-shared-db-snapshot snapshot^.shared-snapshot)
        (delete-owned-datoms snapshot^.overlay-datoms))
    .Shared-Datom-Log-Overlay
      (do
        (delete-shared-db-snapshot snapshot^.shared-snapshot)
        (delete-shared-datom-log snapshot^.overlay-log))
     (do))
  (set! snapshot^ (Store-DB {})))

(defn close-store-db [snapshot: Store-DB]
  (let [owned snapshot]
    (close-store-db! (addr owned))))

(defn close-store-entity! [entity: ^Store-Entity]
  (close-store-db! (addr entity^.db))
  (set! entity^ (Store-Entity {})))

(defn close-store-entity [entity: Store-Entity]
  (let [owned entity]
    (close-store-entity! (addr owned))))

(defn close-sqlite-conn [store: SQLite-Conn]
  (let [owned store]
    (sqlite-conn-close-direct-write-stmts! (addr owned))
    (sqlite-conn-close-index-write-stmts! (addr owned))
    (sqlite-conn-invalidate-current-root-cache! (addr owned)))
  (sqlite-close-live-raw store.handle)
  (delete store.path)
  (when store.write-state-cache-valid
    (delete-shared-write-state-metadata store.write-state-cache))
  (delete-sqlite-direct-attr-cache store.direct-attr-cache)
  (delete store.conn.listeners)
  (delete-resident-db store.conn.db))

(defn delete-sqlite-direct-attr-cache [cache: [dynamic]SQLite-Direct-Attr-Info]
  (for [entry cache]
    (delete entry.attr)
    (when entry.has-type
      (delete entry.schema-type))
    (when entry.unique
      (delete entry.unique-kind)))
  (delete cache))

(defn sqlite-conn-invalidate-direct-attr-cache! [store: ^SQLite-Conn]
  (delete-sqlite-direct-attr-cache store^.direct-attr-cache)
  (set! store^.direct-attr-cache (make [dynamic]SQLite-Direct-Attr-Info)))

(defn sqlite-conn-invalidate-log-metadata-cache! [store: ^SQLite-Conn]
  (set! store^.datom-count-cache-valid false)
  (set! store^.has-retractions-cache-valid false))

(defn sqlite-conn-invalidate-current-root-cache! [store: ^SQLite-Conn]
  (when store^.current-root-cache-valid
    (release-sqlite-index-page-cache! store^.current-root-cache-page-cache)
    (set! store^.current-root-cache-page-cache (SQLite-Index-Page-Cache {}))
    (set! store^.current-root-cache-published (SQLite-Durable-Published-Root {}))
    (set! store^.current-root-cache-basis 0)
    (set! store^.current-root-cache-valid false)))

(defn sqlite-conn-cache-current-root-from-store-db! [store: ^SQLite-Conn, snapshot: ^Store-DB] -> bool
  (when (not (= snapshot^.kind .SQLite-Root-Snapshot))
    (return false))
  (sqlite-conn-invalidate-current-root-cache! store)
  (set! store^.current-root-cache-basis snapshot^.sqlite-root-published.basis-tx)
  (set! store^.current-root-cache-published snapshot^.sqlite-root-published)
  (set! store^.current-root-cache-page-cache (retain-sqlite-index-page-cache snapshot^.sqlite-root-page-cache))
  (set! store^.current-root-cache-valid true)
  true)

(defn sqlite-store-refresh-current-root-cache-after-write! [store: ^Store-Conn, snapshot: ^Store-DB, compacted: bool, ok: bool]
  (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite))
  (when (and ok (not compacted))
    (discard (sqlite-conn-cache-current-root-from-store-db! (addr store^.sqlite) snapshot))))

(defn sqlite-conn-invalidate-write-state-cache! [store: ^SQLite-Conn]
  (when store^.write-state-cache-valid
    (delete-shared-write-state-metadata store^.write-state-cache)
    (set! store^.write-state-cache-valid false)))

(defn sqlite-conn-ensure-write-state-cache! [store: ^SQLite-Conn, source: DB-Read-Source] -> [ok: bool, error: string]
  (when store^.write-state-cache-valid
    (return true ""))
  (let [[state state-ok state-error] (shared-write-state-from-source-metadata source)]
    (when (not state-ok)
      (return false state-error))
    (set! store^.write-state-cache state)
    (set! store^.write-state-cache-valid true)
    (return true "")))

(defn datoms-contain-retraction? [datoms: []Datom] -> bool
  (for [datom datoms]
    (when (not datom.added)
      (return true)))
  false)

(defstruct SQLite-Logical-Group-State {
  datom-count: u64
  has-retractions: bool
  current-basis-tx: u64
  has-current-basis: bool
  current-published-root: SQLite-Durable-Published-Root
  current-published-root-known: bool
  carried-before-basis-tx: u64
  carried-before-published-root: SQLite-Durable-Published-Root
  carried-before-published-root-known: bool
  has-carried-before: bool
})

(defn sqlite-logical-group-state-open [store: ^SQLite-Conn] -> [state: SQLite-Logical-Group-State, ok: bool, error: string]
  (let [[datom-count has-retractions log-ok log-error] (sqlite-conn-datom-count-and-retractions store)]
    (when (not log-ok)
      (return (SQLite-Logical-Group-State {}) false log-error))
    (let [[basis basis-ok basis-error] (sqlite-conn-current-root-basis store)]
      (when (not basis-ok)
        (if (= basis-error "sqlite DB has no Vev index roots")
          (return (SQLite-Logical-Group-State {datom-count: datom-count
                                               has-retractions: has-retractions
                                               current-basis-tx: 0
                                               has-current-basis: false
                                               current-published-root: (SQLite-Durable-Published-Root {})
                                               current-published-root-known: false
                                               carried-before-basis-tx: 0
                                               carried-before-published-root: (SQLite-Durable-Published-Root {})
                                               carried-before-published-root-known: false
                                               has-carried-before: false})
                  true
                  "")
          (return (SQLite-Logical-Group-State {}) false basis-error)))
      (let [[roots roots-ok roots-error] (sqlite-index-root-set-at-basis store^.handle basis)]
        (when (not roots-ok)
          (return (SQLite-Logical-Group-State {}) false roots-error))
        (let [[root-row-id row-ok row-error] (sqlite-index-root-row-id-at-basis store^.handle basis)]
          (when (not row-ok)
            (return (SQLite-Logical-Group-State {}) false row-error))
      (return (SQLite-Logical-Group-State {datom-count: datom-count
                                           has-retractions: has-retractions
                                           current-basis-tx: basis
                                           has-current-basis: true
                                           current-published-root: (SQLite-Durable-Published-Root {root-row-id: root-row-id
                                                                                                  basis-tx: basis
                                                                                                  roots: roots
                                                                                                  modes: (SQLite-Index-Append-Modes {})})
                                           current-published-root-known: true
                                           carried-before-basis-tx: 0
                                           carried-before-published-root: (SQLite-Durable-Published-Root {})
                                           carried-before-published-root-known: false
                                           has-carried-before: false})
              true
              ""))))))

(defn sqlite-logical-group-state-close! [state: ^SQLite-Logical-Group-State]
  (set! state^.current-published-root-known false)
  (set! state^.current-published-root (SQLite-Durable-Published-Root {}))
  (set! state^.has-carried-before false)
  (set! state^.carried-before-published-root-known false)
  (set! state^.carried-before-published-root (SQLite-Durable-Published-Root {}))
  (set! state^.carried-before-basis-tx 0))

(defn sqlite-logical-group-state-advance-after-report! [state: ^SQLite-Logical-Group-State, report: Store-Tx-Report]
  (set! state^.datom-count (+ state^.datom-count (u64 (count report.tx-data))))
  (when (datoms-contain-retraction? (slice report.tx-data 0))
    (set! state^.has-retractions true)))

(defn sqlite-logical-group-state-carry-before-after-report! [store: ^SQLite-Conn, state: ^SQLite-Logical-Group-State, report: Store-Tx-Report] -> [ok: bool, error: string]
  (discard store)
  (set! state^.carried-before-basis-tx report.tx)
  (if report.source-published-root-known
    (do
      (set! state^.carried-before-published-root report.source-published-root)
      (set! state^.carried-before-published-root-known true))
    (do
      (set! state^.carried-before-published-root (SQLite-Durable-Published-Root {}))
      (set! state^.carried-before-published-root-known false)))
  (set! state^.has-carried-before true)
  (return true ""))

(defn sqlite-logical-group-state-store-db-at-basis [store: ^SQLite-Conn, basis-tx: u64, datom-count: u64, has-retractions: bool] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [open-before-start (time.now)
        [opened opened-ok opened-error] (sqlite-open-db-snapshot-handle-at-basis-known-log
                                          store^.handle
                                          basis-tx
                                          sqlite-db-source-default-page-size
                                          datom-count
                                          has-retractions)]
    (set! store^.direct-write-profile.open-before-us (+ store^.direct-write-profile.open-before-us (sqlite-profile-elapsed-us open-before-start)))
    (when (not opened-ok)
      (return (Store-DB {}) false opened-error))
    (set! opened.path (string-owned store^.path))
    (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: opened}) true "")))

(defn sqlite-logical-group-state-store-db-at-published-root [store: ^SQLite-Conn, published: SQLite-Durable-Published-Root, datom-count: u64, has-retractions: bool] -> [snapshot: Store-DB, ok: bool, error: string]
  (let [open-before-start (time.now)
        [opened opened-ok opened-error] (sqlite-open-db-snapshot-handle-at-root-set-known-log
                                          store^.handle
                                          published
                                          sqlite-db-source-default-page-size
                                          datom-count
                                          has-retractions)]
    (set! store^.direct-write-profile.open-before-us (+ store^.direct-write-profile.open-before-us (sqlite-profile-elapsed-us open-before-start)))
    (when (not opened-ok)
      (return (Store-DB {}) false opened-error))
    (set! opened.path (string-owned store^.path))
    (return (Store-DB {kind: .SQLite-Snapshot sqlite-snapshot: opened}) true "")))

(defn sqlite-logical-group-state-current-before-store-db [store: ^SQLite-Conn, state: ^SQLite-Logical-Group-State] -> [snapshot: Store-DB, ok: bool, error: string]
  (when (not state^.has-current-basis)
    (return (Store-DB {}) false "logical group state has no current basis"))
  (if state^.current-published-root-known
    (sqlite-logical-group-state-store-db-at-published-root
      store
      state^.current-published-root
      state^.datom-count
      state^.has-retractions)
    (sqlite-logical-group-state-store-db-at-basis
      store
      state^.current-basis-tx
      state^.datom-count
      state^.has-retractions)))

(defn sqlite-logical-group-state-take-carried-before-store-db! [store: ^SQLite-Conn, state: ^SQLite-Logical-Group-State] -> [snapshot: Store-DB, ok: bool, error: string]
  (when (not state^.has-carried-before)
    (return (Store-DB {}) false "logical group state has no carried before basis"))
  (let [basis-tx state^.carried-before-basis-tx
        datom-count state^.datom-count
        has-retractions state^.has-retractions
        root-known state^.carried-before-published-root-known
        published-root state^.carried-before-published-root]
    (sqlite-logical-group-state-close! state)
    (if root-known
      (sqlite-logical-group-state-store-db-at-published-root store published-root datom-count has-retractions)
      (sqlite-logical-group-state-store-db-at-basis store basis-tx datom-count has-retractions))))

(defn sqlite-conn-advance-log-metadata-cache-after-datoms! [store: ^SQLite-Conn, datoms: []Datom]
  (when store^.datom-count-cache-valid
    (set! store^.datom-count-cache (+ store^.datom-count-cache (u64 (count datoms)))))
  (when (and store^.has-retractions-cache-valid
             (datoms-contain-retraction? datoms))
    (set! store^.has-retractions-cache true)))

(defn sqlite-conn-advance-write-state-cache-after-datoms! [store: ^SQLite-Conn, datoms: []Datom]
  (sqlite-conn-advance-log-metadata-cache-after-datoms! store datoms)
  (when store^.write-state-cache-valid
    (set! store^.write-state-cache.conn.next-tx (+ store^.write-state-cache.conn.next-tx 1))
    (if (shared-write-state-datoms-modify-schema? datoms)
      (do
        (sqlite-conn-invalidate-write-state-cache! store)
        (sqlite-conn-invalidate-direct-attr-cache! store))
      (shared-write-state-advance-next-entity-from-datoms! (addr store^.write-state-cache) datoms))))

(defn rollback-sqlite-conn! [store: ^SQLite-Conn, before: DB]
  (let [restored (conn-from-db before)]
    (delete-owned-db store^.conn.db)
    (set! store^.conn.db restored.db)
    (set! store^.conn.next-tx restored.next-tx)
    (sqlite-conn-invalidate-write-state-cache! store)
    (sqlite-conn-invalidate-direct-attr-cache! store)
    (sqlite-conn-invalidate-log-metadata-cache! store)
    (delete restored.listeners)))

(defn transact-sqlite-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> Tx-Report
  (when store^.source-only
    (return (failed-tx-report store^.conn.db "SQLite source connection is read-only; open a writable SQLite connection to transact")))
  (when (not store^.resident-loaded)
    (let [[has-roots roots-ok roots-error] (sqlite-conn-has-durable-index-roots store)]
      (when (not roots-ok)
        (return (failed-tx-report store^.conn.db roots-error)))
      (when has-roots
        (return (failed-tx-report
                  store^.conn.db
                  "transact-sqlite-tx-data is resident-only for reopened durable SQLite stores; use transact-sqlite-store-report-tx-data")))))
  (let [[resident-ok resident-error] (sqlite-conn-ensure-resident! store)]
    (when (not resident-ok)
      (return (failed-tx-report store^.conn.db resident-error))))
  (let [report (transact-tx-data (addr store^.conn) tx-data)]
    (when (not report.ok)
      (return report))
    (let [[saved-ok save-error] (append-tx-report-sqlite-handle store^.handle report)]
      (when (not saved-ok)
        (rollback-sqlite-conn! store report.db-before)
        (delete-live-tx-report-shallow report)
        (return (failed-tx-report store^.conn.db save-error))))
    (sqlite-conn-invalidate-log-metadata-cache! store)
    report))

(defn transact-sqlite-text [store: ^SQLite-Conn, text: string] -> Tx-Report
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (when (not prepared.ok)
      (return (failed-tx-report store^.conn.db prepared.error)))
    (transact-sqlite-tx-data store (slice prepared.tx-data 0))))

(defn transact-sqlite-store-report-tx-data [store: ^SQLite-Conn, tx-data: []Tx-Data] -> Store-Tx-Report
  (when store^.source-only
    (return (failed-sqlite-store-tx-report store "SQLite source connection is read-only; open a writable SQLite connection to transact")))
  (let [[direct-report direct-used direct-ok direct-error] (transact-sqlite-store-report-direct-tx-data store tx-data)]
    (when direct-ok
      (when direct-used
        (return direct-report)))
    (when (not direct-ok)
      (return (failed-sqlite-store-tx-report store direct-error))))
  (when (not store^.resident-loaded)
    (return (failed-sqlite-store-tx-report store "unsupported source-backed durable transaction shape")))
  (let [report (transact-sqlite-tx-data store tx-data)
        out (store-tx-report-from-temp-resident-report report)]
    out))

(defn transact-sqlite-store-report-text [store: ^SQLite-Conn, text: string] -> Store-Tx-Report
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (when (not prepared.ok)
      (return (failed-sqlite-store-tx-report store prepared.error)))
    (transact-sqlite-store-report-tx-data store (slice prepared.tx-data 0))))

(defn transact-sqlite-store-report-tx-data-with-source-string-fns-mode [store: ^SQLite-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String, owns-sqlite-tx: bool] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (when store^.source-only
    (return (Store-Tx-Report {}) false false "SQLite source connection is read-only; open a writable SQLite connection to transact"))
  (when store^.resident-loaded
    (return (Store-Tx-Report {}) false true ""))
  (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-open-cached store)]
    (when (not snapshot-ok)
      (if (= snapshot-error "sqlite DB has no Vev index roots")
        (let [before (empty-shared-store-db-for-sqlite-bootstrap)
              overlay-report (with-store-db-report-tx-data-with-source-string-fns (addr before) tx-data registry)]
          (close-store-db before)
          (return (sqlite-commit-initial-source-overlay-report-mode store overlay-report owns-sqlite-tx) true true ""))
        (return (Store-Tx-Report {}) false false snapshot-error)))
    (let [report-before (retain-store-db snapshot)
          overlay-report (with-store-db-report-tx-data-with-source-string-fns (addr snapshot) tx-data registry)]
      (close-store-db snapshot)
      (close-store-db overlay-report.db-before)
      (set! overlay-report.db-before report-before)
      (return (sqlite-commit-source-overlay-report-mode store overlay-report owns-sqlite-tx) true true ""))))

(defn- transact-sqlite-store-report-tx-data-with-source-string-fns-before-mode [store: ^SQLite-Conn, before: Store-DB, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String, owns-sqlite-tx: bool] -> [report: Store-Tx-Report, used: bool, ok: bool, error: string]
  (when store^.source-only
    (close-store-db before)
    (return (Store-Tx-Report {}) false false "SQLite source connection is read-only; open a writable SQLite connection to transact"))
  (when store^.resident-loaded
    (close-store-db before)
    (return (Store-Tx-Report {}) false true ""))
  (let [snapshot before
        [source source-ok source-error] (store-db-read-source (addr snapshot))]
    (when (not source-ok)
      (close-store-db snapshot)
      (return (Store-Tx-Report {}) false false source-error))
    (let [[state-ok state-error] (sqlite-conn-ensure-write-state-cache! store source)]
      (when (not state-ok)
        (close-store-db snapshot)
        (return (Store-Tx-Report {}) false false state-error)))
    (let [overlay-report (with-store-db-report-tx-data-with-source-string-fns-state (addr snapshot) source (addr store^.write-state-cache) tx-data registry)]
    (when (not overlay-report.ok)
      (close-store-db snapshot)
      (return overlay-report true true ""))
    (close-store-db overlay-report.db-before)
    (set! overlay-report.db-before snapshot)
    (return (sqlite-commit-source-overlay-report-mode store overlay-report owns-sqlite-tx) true true ""))))

(defn transact-sqlite-store-report-tx-data-with-source-string-fns [store: ^SQLite-Conn, tx-data: []Tx-Data, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [[direct-report direct-used direct-ok direct-error] (transact-sqlite-store-report-tx-data-with-source-string-fns-mode store tx-data registry true)]
    (when direct-ok
      (when direct-used
        (return direct-report)))
    (when (not direct-ok)
      (return (failed-sqlite-store-tx-report store direct-error))))
  (when (not store^.resident-loaded)
    (return (failed-sqlite-store-tx-report store "unsupported source-backed durable transaction shape")))
  (store-tx-report-from-temp-resident-report (transact-sqlite-tx-data store tx-data)))

(defn transact-sqlite-store-report-text-with-source-string-fns [store: ^SQLite-Conn, text: string, registry: []Tx-Fn-Source-String] -> Store-Tx-Report
  (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
    (when (not prepared.ok)
      (return (failed-sqlite-store-tx-report store prepared.error)))
    (transact-sqlite-store-report-tx-data-with-source-string-fns store (slice prepared.tx-data 0) registry)))

(defn store-from-sqlite-conn [store: SQLite-Conn] -> Store-Conn
  (Store-Conn {kind: .SQLite
               sqlite: store
               listeners: (make [dynamic]Store-Tx-Listener)
               auto-maintenance-enabled: false
               auto-maintenance-steps: 0
               auto-maintenance-target: 0
               auto-maintenance-trigger: 1}))

(defn create-shared-store [chunk-size: int] -> Store-Conn
  (Store-Conn {kind: .Shared
               shared: (create-shared-conn chunk-size)
               listeners: (make [dynamic]Store-Tx-Listener)
               auto-maintenance-enabled: false
               auto-maintenance-steps: 0
               auto-maintenance-target: 0
               auto-maintenance-trigger: 1}))

(defn open-store [uri: string] -> [store: Store-Conn, ok: bool, error: string]
  (let [[sqlite sqlite-ok sqlite-error] (open-sqlite-conn uri)
        out-store (store-from-sqlite-conn sqlite)]
    (if sqlite-ok
      (do
        (delete sqlite-error)
        (return out-store true ""))
      (return out-store false sqlite-error))))

(defn open-store-read-only [uri: string] -> [store: Store-Conn, ok: bool, error: string]
  (let [[sqlite sqlite-ok sqlite-error] (open-sqlite-source-conn uri)
        out-store (store-from-sqlite-conn sqlite)]
    (if sqlite-ok
      (do
        (delete sqlite-error)
        (return out-store true ""))
      (return out-store false sqlite-error))))

(defn close-store [store: Store-Conn]
  (do
    (case store.kind
      .SQLite (close-sqlite-conn store.sqlite)
      .Shared (delete-shared-conn store.shared)
       (do))
    (delete store.listeners)))

(defn store-read-only? [store: ^Store-Conn] -> bool
  (case store^.kind
    .SQLite store^.sqlite.source-only
     false))

(defn store-resident-db-available? [store: ^Store-Conn] -> bool
  (case store^.kind
    .SQLite store^.sqlite.resident-loaded
    .Shared true
     false))

(defn store-db [store: ^Store-Conn] -> [snapshot: Store-DB, ok: bool, error: string]
  (case store^.kind
    .SQLite (let [[snapshot snapshot-ok snapshot-error] (sqlite-store-db-current-root-cached (addr store^.sqlite))]
              (when (and (not snapshot-ok)
                         (= snapshot-error "sqlite DB has no Vev index roots"))
                ;; SQLite root lookup errors are borrowed literals. The fresh
                ;; durable-store bootstrap path must not free this sentinel.
                (return (empty-shared-store-db-for-sqlite-bootstrap) true ""))
              (return snapshot snapshot-ok snapshot-error))
    .Shared (return (shared-store-db (addr store^.shared)) true "")
     (return (Store-DB {}) false "store is not open")))

(defn store-current-root-page-cache-count [store: ^Store-Conn] -> int
  (case store^.kind
    .SQLite (sqlite-conn-current-root-page-cache-count (addr store^.sqlite))
     0))

(defn store-current-root-page-cache-hit-count [store: ^Store-Conn] -> int
  (case store^.kind
    .SQLite (sqlite-conn-current-root-page-cache-hit-count (addr store^.sqlite))
     0))

(defn store-current-root-page-cache-miss-count [store: ^Store-Conn] -> int
  (case store^.kind
    .SQLite (sqlite-conn-current-root-page-cache-miss-count (addr store^.sqlite))
     0))

(defn store-tx-count [store: ^Store-Conn] -> [tx-count: u64, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-conn-tx-count (addr store^.sqlite))
    .Shared (return (shared-write-state-next-tx (addr store^.shared.write)) true "")
     (return 0 false "store is not open")))

(defn store-index-maintenance-count [store: ^Store-Conn] -> [maintenance-count: u64, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-conn-index-maintenance-count (addr store^.sqlite))
    .Shared (return 0 true "")
     (return 0 false "store is not open")))

(defn reset-store-direct-write-profile! [store: ^Store-Conn]
  (case store^.kind
    .SQLite (reset-sqlite-direct-write-profile! (addr store^.sqlite))
     (do)))

(defn store-direct-write-profile [store: ^Store-Conn] -> SQLite-Direct-Write-Profile
  (case store^.kind
    .SQLite (sqlite-direct-write-profile (addr store^.sqlite))
     (SQLite-Direct-Write-Profile {})))

(defn store-latest-index-merge-run-count [store: ^Store-Conn, index-name: string] -> [run-count: int, is-merge: bool, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-latest-index-root-merge-run-count store^.sqlite.handle index-name)
    .Shared (return 1 false true "")
     (return 0 false false "store is not open")))

(defn store-latest-index-root-tree-stats [store: ^Store-Conn, index-name: string] -> [node-count: u64, leaf-count: u64, max-level: i64, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-conn-latest-index-root-tree-stats (addr store^.sqlite) index-name)
    .Shared (return 0 0 0 false "shared store has no persisted index tree")
     (return 0 0 0 false "store is not open")))

(defn store-latest-index-root-child-count [store: ^Store-Conn, index-name: string] -> [child-count: u64, ok: bool, error: string]
  (case store^.kind
    .SQLite (sqlite-conn-latest-index-root-child-count (addr store^.sqlite) index-name)
    .Shared (return 0 false "shared store has no persisted index tree")
     (return 0 false "store is not open")))

(defn sqlite-set-synchronous-raw [handle: rawptr, level: int] -> [ok: bool, error: string]
  (odin "return sqlite_set_synchronous_raw(handle, c.int(level))"))

(defn configure-store-durability! [store: ^Store-Conn, mode: string] -> [ok: bool, error: string]
  (case store^.kind
    .SQLite
      (cond
        (= mode ":strict") (sqlite-set-synchronous-raw store^.sqlite.handle 2)
        (= mode ":normal") (sqlite-set-synchronous-raw store^.sqlite.handle 1)
        (= mode ":relaxed") (sqlite-set-synchronous-raw store^.sqlite.handle 0)
        :else (return false "expected durability mode :strict, :normal, or :relaxed"))
    .Shared
      (if (or (= mode ":strict")
              (= mode ":normal")
              (= mode ":relaxed"))
        (return true "")
        (return false "expected durability mode :strict, :normal, or :relaxed"))
     (return false "store is not open")))

(defn compact-store-indexes! [store: ^Store-Conn] -> [compacted: bool, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [[compacted ok error] (sqlite-conn-compact-indexes! (addr store^.sqlite))]
        (when (and ok compacted)
          (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite)))
        (return compacted ok error))
    .Shared (return false true "")
     (return false false "store is not open")))

(defn maintain-store-indexes-step! [store: ^Store-Conn] -> [compacted: bool, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [[compacted ok error] (sqlite-conn-maintain-indexes-step! (addr store^.sqlite))]
        (when (and ok compacted)
          (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite)))
        (return compacted ok error))
    .Shared (return false true "")
     (return false false "store is not open")))

(defn maintain-store-indexes! [store: ^Store-Conn, max-steps: int] -> [steps: int, compacted: bool, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [[steps compacted ok error] (sqlite-conn-maintain-indexes! (addr store^.sqlite) max-steps)]
        (when (and ok compacted)
          (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite)))
        (return steps compacted ok error))
    .Shared (return 0 false true "")
     (return 0 false false "store is not open")))

(defn maintain-store-indexes-to-target! [store: ^Store-Conn, max-steps: int, target-pending: u64] -> [steps: int, compacted: bool, pending: u64, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [[steps compacted pending ok error] (sqlite-conn-maintain-indexes-to-target! (addr store^.sqlite) max-steps target-pending)]
        (when (and ok compacted)
          (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite)))
        (return steps compacted pending ok error))
    .Shared (return 0 false 0 true "")
     (return 0 false 0 false "store is not open")))

(defn configure-store-auto-maintenance! [store: ^Store-Conn, max-steps: int, target-pending: u64] -> [ok: bool, error: string]
  (configure-store-auto-maintenance-threshold! store max-steps target-pending (+ target-pending 1)))

(defn configure-store-auto-maintenance-threshold! [store: ^Store-Conn, max-steps: int, target-pending: u64, trigger-pending: u64] -> [ok: bool, error: string]
  (when (< max-steps 0)
    (return false "auto maintenance step budget cannot be negative"))
  (when (and (> max-steps 0)
             (<= trigger-pending target-pending))
    (return false "auto maintenance trigger must be greater than target"))
  (case store^.kind
    .SQLite
      (do
        (set! store^.auto-maintenance-enabled (> max-steps 0))
        (set! store^.auto-maintenance-steps max-steps)
        (set! store^.auto-maintenance-target target-pending)
        (set! store^.auto-maintenance-trigger trigger-pending)
        (return true ""))
    .Shared
      (do
        (set! store^.auto-maintenance-enabled false)
        (set! store^.auto-maintenance-steps 0)
        (set! store^.auto-maintenance-target 0)
        (set! store^.auto-maintenance-trigger 1)
        (return true ""))
     (return false "store is not open")))

(defn disable-store-auto-maintenance! [store: ^Store-Conn] -> [ok: bool, error: string]
  (do
    (set! store^.auto-maintenance-enabled false)
    (set! store^.auto-maintenance-steps 0)
    (set! store^.auto-maintenance-target 0)
    (set! store^.auto-maintenance-trigger 1)
    (return true "")))

(defn run-store-auto-maintenance! [store: ^Store-Conn] -> [steps: int, compacted: bool, pending: u64, ok: bool, error: string]
  (if store^.auto-maintenance-enabled
    (let [[pending pending-ok pending-error] (store-index-maintenance-count store)]
      (when (not pending-ok)
        (return 0 false 0 false pending-error))
      (when (< pending store^.auto-maintenance-trigger)
        (case store^.kind
          .SQLite
            (let [[eavt-runs _ eavt-ok eavt-error] (sqlite-latest-index-root-merge-run-count store^.sqlite.handle ":eavt")]
              (when (not eavt-ok)
                (return 0 false pending false eavt-error))
              (let [[aevt-runs _ aevt-ok aevt-error] (sqlite-latest-index-root-merge-run-count store^.sqlite.handle ":aevt")]
                (when (not aevt-ok)
                  (return 0 false pending false aevt-error))
                (let [[avet-runs _ avet-ok avet-error] (sqlite-latest-index-root-merge-run-count store^.sqlite.handle ":avet")]
                  (when (not avet-ok)
                    (return 0 false pending false avet-error))
                  (let [[vaet-runs _ vaet-ok vaet-error] (sqlite-latest-index-root-merge-run-count store^.sqlite.handle ":vaet")]
                    (when (not vaet-ok)
                      (return 0 false pending false vaet-error))
                    (let [max-runs (max (max eavt-runs aevt-runs) (max avet-runs vaet-runs))]
                      (when (< (u64 max-runs) store^.auto-maintenance-trigger)
                        (return 0 false pending true "")))))))
           (return 0 false pending true "")))
      (case store^.kind
        .SQLite (sqlite-conn-maintain-indexes-to-target-foreground! (addr store^.sqlite) store^.auto-maintenance-steps store^.auto-maintenance-target sqlite-index-auto-maintenance-row-budget)
        .Shared (return 0 false 0 true "")
         (return 0 false pending false "store is not open")))
    (let [[pending pending-ok pending-error] (store-index-maintenance-count store)]
      (return 0 false pending pending-ok pending-error))))

(defn q-result-store-text [store: ^Store-Conn, text: string] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-text (addr store^.sqlite) text)
    .Shared (q-result-text-db-read-source (shared-conn-read-source (addr store^.shared)) text)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn q-result-store-text-with-input-text [store: ^Store-Conn, text: string, inputs-text: string] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-text-with-input-text (addr store^.sqlite) text inputs-text)
    .Shared (q-result-text-db-read-source-with-input-text (shared-conn-read-source (addr store^.shared)) text inputs-text)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn q-result-store-prepared [store: ^Store-Conn, prepared: Prepared-Query] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-prepared (addr store^.sqlite) prepared)
    .Shared (q-result-prepared-db-read-source (shared-conn-read-source (addr store^.shared)) prepared)
     (query-result-owned-values (result-set-error "store is not open"))))

(defn q-result-store-prepared-with-input-text [store: ^Store-Conn, prepared: Prepared-Query, inputs-text: string] -> Query-Result
  (case store^.kind
    .SQLite (q-result-sqlite-conn-prepared-with-input-text (addr store^.sqlite) prepared inputs-text)
    .Shared
      (do
        (when (not prepared.ok)
          (return (query-result-owned-values (result-set-error prepared.error))))
        (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
          (when (not input-ok)
            (delete-owned-query-inputs inputs)
            (return (query-result-owned-values (result-set-error input-error))))
          (let [result (q-result-prepared-db-read-source-with-inputs (shared-conn-read-source (addr store^.shared)) prepared (slice inputs 0))]
            (delete-owned-query-inputs inputs)
            result)))
     (query-result-owned-values (result-set-error "store is not open"))))

(defn transact-store-tx-data [store: ^Store-Conn, tx-data: []Tx-Data] -> Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-tx-data (addr store^.sqlite) tx-data)
    .Shared (shared-conn-transact (addr store^.shared) tx-data)
     (failed-tx-report (build-db (make [dynamic]Datom)) "store is not open")))

(defn transact-store-text [store: ^Store-Conn, text: string] -> Tx-Report
  (case store^.kind
    .SQLite (transact-sqlite-text (addr store^.sqlite) text)
    .Shared
      (let [prepared (prepare-tx-text text) :defer-with delete-prepared-tx-data-shallow]
        (when (not prepared.ok)
          (return (failed-tx-report (shared-write-state-before-db (addr store^.shared.write)) prepared.error)))
        (shared-conn-transact (addr store^.shared) (slice prepared.tx-data 0)))
     (failed-tx-report (build-db (make [dynamic]Datom)) "store is not open")))

(defn transact-store-report-tx-data [store: ^Store-Conn, tx-data: []Tx-Data] -> Store-Tx-Report
  (case store^.kind
    .SQLite
      (let [direct-start (time.now)
            report (transact-sqlite-store-report-tx-data (addr store^.sqlite) tx-data)]
        (set! store^.sqlite.direct-write-profile.direct-call-us (+ store^.sqlite.direct-write-profile.direct-call-us (sqlite-profile-elapsed-us direct-start)))
        (when report.ok
          (let [auto-start (time.now)
                [auto-steps auto-compacted auto-pending auto-ok auto-error] (run-store-auto-maintenance! store)]
            (set! store^.sqlite.direct-write-profile.auto-maintenance-us (+ store^.sqlite.direct-write-profile.auto-maintenance-us (sqlite-profile-elapsed-us auto-start)))
            (discard auto-steps)
            (discard auto-pending)
            (discard auto-error)
            (sqlite-store-refresh-current-root-cache-after-write! store (addr report.db-after) auto-compacted auto-ok)))
        (let [listener-start (time.now)]
          (notify-store-report-listeners! store report)
          (set! store^.sqlite.direct-write-profile.listener-us (+ store^.sqlite.direct-write-profile.listener-us (sqlite-profile-elapsed-us listener-start))))
        report)
    .Shared
      (let [report (shared-conn-transact-report (addr store^.shared) tx-data)]
        (when report.ok
          (let [tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
            (let [out (Store-Tx-Report {ok: true
                                         error: ""
                                         db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-before})
                                         db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-after})
                                         tx-data: (clone-owned-datom-slice (slice report.tx-data 0))
                                         tx: report.tx
                                         tx-meta: (clone-tx-meta (slice report.tx-meta 0))
                                         tempids: tempids
                                         source-append-metadata-known: false
                                         source-new-entities-after-existing: false
                                         source-eavt-append-mode: false
                                         source-aevt-append-mode: false
                                         source-avet-append-mode: false
                                         source-vaet-append-mode: false
                                         source-published-root-known: false
                                         source-published-root: (SQLite-Durable-Published-Root {})})]
              (notify-store-report-listeners! store out)
              (return out))))
        (let [out (Store-Tx-Report {ok: false
                                    error: report.error
                                    db-before: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-before})
                                    db-after: (Store-DB {kind: .Shared-Snapshot shared-snapshot: report.db-after})
                                    tx-data: (make [dynamic]Datom)
                                    tx: 0
                                    tx-meta: (make [dynamic]Tx-Meta)
                                    tempids: (make [dynamic]Tempid)
                                    source-append-metadata-known: false
                                    source-new-entities-after-existing: false
                                    source-eavt-append-mode: false
                                    source-aevt-append-mode: false
                                    source-avet-append-mode: false
                                    source-vaet-append-mode: false
                                    source-published-root-known: false
                                    source-published-root: (SQLite-Durable-Published-Root {})})]
          (notify-store-report-listeners! store out)
          out))
     (failed-store-tx-report (Store-DB {}) "store is not open")))

(defn transact-store-report-tx-data-groups [store: ^Store-Conn, groups: []Store-Tx-Data-Group] -> Store-Tx-Report
  (let [tx-data (flatten-store-tx-data-groups groups) :defer]
    (transact-store-report-tx-data store (slice tx-data 0))))

(defn transact-sqlite-store-report-tx-data-groups [store: ^SQLite-Conn, groups: []Store-Tx-Data-Group] -> Store-Tx-Report
  (let [tx-data (flatten-store-tx-data-groups groups) :defer]
    (transact-sqlite-store-report-tx-data store (slice tx-data 0))))

(defn rollback-sqlite-logical-group! [store: ^SQLite-Conn, reports: [dynamic]Store-Tx-Report]
  (sqlite-rollback-raw store^.handle)
  (sqlite-conn-invalidate-write-state-cache! store)
  (sqlite-conn-invalidate-log-metadata-cache! store)
  (sqlite-conn-invalidate-direct-attr-cache! store)
  (delete-store-tx-reports reports))

(defn- tx-data-has-source-fn-call? [tx-data: []Tx-Data] -> bool
  (for [data tx-data]
    (when (= data.op ":db.fn/call-ident")
      (return true)))
  false)

(defn- transact-sqlite-store-report-logical-tx-data-groups-mode [store: ^SQLite-Conn, groups: []Store-Tx-Data-Group, registry: []Tx-Fn-Source-String, use-source-fns: bool] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (let [out-reports (make [dynamic]Store-Tx-Report 0 (count groups))]
    (when store^.source-only
      (return out-reports false "SQLite source connection is read-only; open a writable SQLite connection to transact"))
    (when store^.resident-loaded
      (return out-reports false "logical group commit requires source-backed SQLite store reports"))
    (when (= (count groups) 0)
      (return out-reports true ""))
    (let [begin-start (time.now)
          [begin-ok begin-error] (sqlite-begin-immediate-raw store^.handle)]
      (set! store^.direct-write-profile.append-begin-us (+ store^.direct-write-profile.append-begin-us (sqlite-profile-elapsed-us begin-start)))
      (when (not begin-ok)
        (return out-reports false begin-error)))
    (let [[group-state state-ok state-error] (sqlite-logical-group-state-open store)]
      (when (not state-ok)
        (rollback-sqlite-logical-group! store out-reports)
        (return (make [dynamic]Store-Tx-Report) false state-error))
      (for [group group-index groups]
        (let [report (Store-Tx-Report {})
              direct-used false
              direct-ok false
              direct-error ""
              group-uses-source-fns (and use-source-fns (tx-data-has-source-fn-call? (slice group.tx-data 0)))]
        (if group-state.has-carried-before
          (let [[before before-ok before-error] (sqlite-logical-group-state-take-carried-before-store-db! store (addr group-state))]
            (when (not before-ok)
              (sqlite-logical-group-state-close! (addr group-state))
              (rollback-sqlite-logical-group! store out-reports)
              (return (make [dynamic]Store-Tx-Report) false before-error))
            (if group-uses-source-fns
              (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-tx-data-with-source-string-fns-before-mode store before (slice group.tx-data 0) registry false)]
                (set! report next-report)
                (set! direct-used next-used)
                (set! direct-ok next-ok)
                (set! direct-error next-error))
              (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-direct-tx-data-with-before-mode store before (slice group.tx-data 0) false)]
                (set! report next-report)
                (set! direct-used next-used)
                (set! direct-ok next-ok)
                (set! direct-error next-error))))
          (if group-state.has-current-basis
            (let [[before before-ok before-error] (sqlite-logical-group-state-current-before-store-db store (addr group-state))]
              (when (not before-ok)
                (sqlite-logical-group-state-close! (addr group-state))
                (rollback-sqlite-logical-group! store out-reports)
                (return (make [dynamic]Store-Tx-Report) false before-error))
              (if group-uses-source-fns
                (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-tx-data-with-source-string-fns-before-mode store before (slice group.tx-data 0) registry false)]
                  (set! report next-report)
                  (set! direct-used next-used)
                  (set! direct-ok next-ok)
                  (set! direct-error next-error))
                (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-direct-tx-data-with-before-mode store before (slice group.tx-data 0) false)]
                  (set! report next-report)
                  (set! direct-used next-used)
                  (set! direct-ok next-ok)
                  (set! direct-error next-error))))
            (if group-uses-source-fns
              (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-tx-data-with-source-string-fns-mode store (slice group.tx-data 0) registry false)]
                (set! report next-report)
                (set! direct-used next-used)
                (set! direct-ok next-ok)
                (set! direct-error next-error))
              (let [[next-report next-used next-ok next-error] (transact-sqlite-store-report-direct-tx-data-open-tx store (slice group.tx-data 0))]
                (set! report next-report)
                (set! direct-used next-used)
                (set! direct-ok next-ok)
                (set! direct-error next-error)))))
        (when (not direct-ok)
          (sqlite-logical-group-state-close! (addr group-state))
          (rollback-sqlite-logical-group! store out-reports)
          (return (make [dynamic]Store-Tx-Report) false direct-error))
        (when (not direct-used)
          (sqlite-logical-group-state-close! (addr group-state))
          (rollback-sqlite-logical-group! store out-reports)
          (return (make [dynamic]Store-Tx-Report) false "logical group commit could not use source-backed direct write path"))
        (when (not report.ok)
          (let [error report.error]
            (delete-store-tx-report report)
            (sqlite-logical-group-state-close! (addr group-state))
            (rollback-sqlite-logical-group! store out-reports)
            (return (make [dynamic]Store-Tx-Report) false error)))
        (sqlite-logical-group-state-advance-after-report! (addr group-state) report)
        (when (< group-index (- (count groups) 1))
          (let [[next-before-ok next-before-error] (sqlite-logical-group-state-carry-before-after-report! store (addr group-state) report)]
            (when (not next-before-ok)
              (delete-store-tx-report report)
              (sqlite-logical-group-state-close! (addr group-state))
              (rollback-sqlite-logical-group! store out-reports)
              (return (make [dynamic]Store-Tx-Report) false next-before-error))))
        (arr.push! out-reports report)))
      (sqlite-logical-group-state-close! (addr group-state)))
    (when (> (count out-reports) 0)
      (let [latest-report out-reports[(- (count out-reports) 1)]
            [maintenance-ok maintenance-error] (sqlite-enqueue-latest-root-set-maintenance-unless-manifest! store^.handle latest-report.tx)]
        (when (not maintenance-ok)
          (sqlite-rollback-raw store^.handle)
          (sqlite-conn-invalidate-write-state-cache! store)
          (sqlite-conn-invalidate-log-metadata-cache! store)
          (sqlite-conn-invalidate-direct-attr-cache! store)
          (delete-store-tx-reports out-reports)
          (return (make [dynamic]Store-Tx-Report) false maintenance-error))))
    (let [commit-start (time.now)
          [commit-ok commit-error] (sqlite-commit-raw store^.handle)]
      (set! store^.direct-write-profile.append-commit-us (+ store^.direct-write-profile.append-commit-us (sqlite-profile-elapsed-us commit-start)))
      (when (not commit-ok)
        (sqlite-conn-invalidate-write-state-cache! store)
        (sqlite-conn-invalidate-log-metadata-cache! store)
        (sqlite-conn-invalidate-direct-attr-cache! store)
        (delete-store-tx-reports out-reports)
        (return (make [dynamic]Store-Tx-Report) false commit-error)))
    (sqlite-conn-invalidate-write-state-cache! store)
    (sqlite-conn-invalidate-direct-attr-cache! store)
    (return out-reports true "")))

(defn transact-sqlite-store-report-logical-tx-data-groups [store: ^SQLite-Conn, groups: []Store-Tx-Data-Group] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (let [registry ([]Tx-Fn-Source-String [])]
    (transact-sqlite-store-report-logical-tx-data-groups-mode store groups registry false)))

(defn transact-sqlite-store-report-logical-tx-data-groups-with-source-string-fns [store: ^SQLite-Conn, groups: []Store-Tx-Data-Group, registry: []Tx-Fn-Source-String] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (transact-sqlite-store-report-logical-tx-data-groups-mode store groups registry true))

(defn transact-sqlite-store-report-logical-text-groups [store: ^SQLite-Conn, texts: []string] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (let [[groups groups-ok groups-error] (store-tx-data-groups-from-texts texts)]
    (when (not groups-ok)
      (return (make [dynamic]Store-Tx-Report) false groups-error))
    (let [[out-reports out-ok out-error] (transact-sqlite-store-report-logical-tx-data-groups store (slice groups 0))]
      (delete-store-tx-data-groups groups)
      (return out-reports out-ok out-error))))

(defn transact-sqlite-store-report-logical-text-groups-with-source-string-fns [store: ^SQLite-Conn, texts: []string, registry: []Tx-Fn-Source-String] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (let [[groups groups-ok groups-error] (store-tx-data-groups-from-texts texts)]
    (when (not groups-ok)
      (return (make [dynamic]Store-Tx-Report) false groups-error))
    (let [[out-reports out-ok out-error] (transact-sqlite-store-report-logical-tx-data-groups-with-source-string-fns store (slice groups 0) registry)]
      (delete-store-tx-data-groups groups)
      (return out-reports out-ok out-error))))

(defn transact-store-report-logical-tx-data-groups [store: ^Store-Conn, groups: []Store-Tx-Data-Group] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [direct-start (time.now)
            [reports reports-ok reports-error] (transact-sqlite-store-report-logical-tx-data-groups (addr store^.sqlite) groups)]
        (set! store^.sqlite.direct-write-profile.direct-call-us (+ store^.sqlite.direct-write-profile.direct-call-us (sqlite-profile-elapsed-us direct-start)))
        (when reports-ok
          (let [auto-start (time.now)
                [auto-steps auto-compacted auto-pending auto-ok auto-error] (run-store-auto-maintenance! store)]
            (set! store^.sqlite.direct-write-profile.auto-maintenance-us (+ store^.sqlite.direct-write-profile.auto-maintenance-us (sqlite-profile-elapsed-us auto-start)))
            (discard auto-steps)
            (discard auto-pending)
            (discard auto-error)
            (if (> (count reports) 0)
              (sqlite-store-refresh-current-root-cache-after-write! store (addr reports[(- (count reports) 1)].db-after) auto-compacted auto-ok)
              (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite))))
          (let [listener-start (time.now)]
            (for [report reports]
              (notify-store-report-listeners! store report))
            (set! store^.sqlite.direct-write-profile.listener-us (+ store^.sqlite.direct-write-profile.listener-us (sqlite-profile-elapsed-us listener-start)))))
        (return reports reports-ok reports-error))
    .Shared
      (return (make [dynamic]Store-Tx-Report) false "logical group commit is only implemented for durable SQLite stores")
     (return (make [dynamic]Store-Tx-Report) false "store is not open")))

(defn transact-store-report-logical-tx-data-groups-with-source-string-fns [store: ^Store-Conn, groups: []Store-Tx-Data-Group, registry: []Tx-Fn-Source-String] -> [reports: [dynamic]Store-Tx-Report, ok: bool, error: string]
  (case store^.kind
    .SQLite
      (let [direct-start (time.now)
            [reports reports-ok reports-error] (transact-sqlite-store-report-logical-tx-data-groups-with-source-string-fns (addr store^.sqlite) groups registry)]
        (set! store^.sqlite.direct-write-profile.direct-call-us (+ store^.sqlite.direct-write-profile.direct-call-us (sqlite-profile-elapsed-us direct-start)))
        (when reports-ok
          (let [auto-start (time.now)
                [auto-steps auto-compacted auto-pending auto-ok auto-error] (run-store-auto-maintenance! store)]
            (set! store^.sqlite.direct-write-profile.auto-maintenance-us (+ store^.sqlite.direct-write-profile.auto-maintenance-us (sqlite-profile-elapsed-us auto-start)))
            (discard auto-steps)
            (discard auto-pending)
            (discard auto-error)
            (if (> (count reports) 0)
              (sqlite-store-refresh-current-root-cache-after-write! store (addr reports[(- (count reports) 1)].db-after) auto-compacted auto-ok)
              (sqlite-conn-invalidate-current-root-cache! (addr store^.sqlite))))
          (let [listener-start (time.now)]
            (for [report reports]
              (notify-store-report-listeners! store report))
            (set! store^.sqlite.direct-write-profile.listener-us (+ store^.sqlite.direct-write-profile.listener-us (sqlite-profile-elapsed-us listener-start)))))
        (return reports reports-ok reports-error))
    .Shared
      (return (make [dynamic]Store-Tx-Report) false "logical group commit is only implemented for durable SQLite stores")
     (return (make [dynamic]Store-Tx-Report) false "store is not open")))

