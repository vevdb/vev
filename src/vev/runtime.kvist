(defn db-read-source-query-anchor-two-branch-join-projection [query: Query] -> [projection: Source-Anchor-Two-Branch-Join-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 8)
                  (= (count query.where-steps) 9)
                  (query-find-vars-unique? query)))
    (return (empty-source-anchor-two-branch-join-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (and (= step.kind .Predicate)
                        (= step.index 0))))
      (return (empty-source-anchor-two-branch-join-projection) false)))
  (let [anchor query.clauses[0]
        direct-ref query.clauses[1]
        direct-value query.clauses[2]
        first-ref query.clauses[3]
        filter-clause query.clauses[4]
        first-value query.clauses[5]
        hop1 query.clauses[6]
        hop2 query.clauses[7]
        [filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
    (when (not filter-ok)
      (return (empty-source-anchor-two-branch-join-projection) false))
    (for [clause-value query.clauses]
      (when (or (not (= anchor.has-source clause-value.has-source))
                (and anchor.has-source
                     (not (= anchor.source clause-value.source)))
                (not (source-clause-fixed-forward-attr? clause-value)))
        (return (empty-source-anchor-two-branch-join-projection) false)))
    (when (or (not (= anchor.e.kind .Var))
              (not (or (= anchor.v.kind .Value)
                       (and (= anchor.v.kind .Var)
                            (db-read-source-query-has-one-scalar-input? query anchor.v.name))))
              (not (= direct-ref.e.kind .Var))
              (not (= direct-ref.v.kind .Var))
              (not (= direct-ref.v.name anchor.e.name))
              (not (= direct-value.e.kind .Var))
              (not (= direct-value.e.name direct-ref.e.name))
              (not (= direct-value.v.kind .Var))
              (not (= first-ref.e.kind .Var))
              (not (= first-ref.v.kind .Var))
              (not (= first-ref.v.name anchor.e.name))
              (not (= filter-clause.e.kind .Var))
              (not (= filter-clause.e.name first-ref.e.name))
              (not (= filter-clause.v.kind .Var))
              (not (= first-value.e.kind .Var))
              (not (= first-value.e.name first-ref.e.name))
              (not (= first-value.v.kind .Var))
              (not (= hop1.e.kind .Var))
              (not (= hop1.e.name first-ref.e.name))
              (not (= hop1.v.kind .Var))
              (not (= hop2.e.kind .Var))
              (not (= hop2.e.name hop1.v.name))
              (not (= hop2.v.kind .Var))
              (not (= hop2.v.name direct-ref.e.name))
              (= direct-ref.e.name first-ref.e.name)
              (= direct-value.v.name first-value.v.name)
              (= direct-value.v.name filter-clause.v.name)
              (= first-value.v.name filter-clause.v.name))
      (return (empty-source-anchor-two-branch-join-projection) false))
    (for [find-var query.find]
      (when (not (or (= find-var direct-value.v.name)
                     (= find-var first-value.v.name)
                     (= find-var filter-clause.v.name)))
        (return (empty-source-anchor-two-branch-join-projection) false)))
    (return (Source-Anchor-Two-Branch-Join-Projection {anchor-var: anchor.e.name
                                                       anchor-attr: anchor.a.value.text
                                                       anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                       anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                       has-anchor-input: (= anchor.v.kind .Var)
                                                       direct-entity-var: direct-ref.e.name
                                                       direct-ref-attr: direct-ref.a.value.text
                                                       direct-value-attr: direct-value.a.value.text
                                                       direct-value-var: direct-value.v.name
                                                       first-entity-var: first-ref.e.name
                                                       first-ref-attr: first-ref.a.value.text
                                                       filter-attr: filter-clause.a.value.text
                                                       filter-var: filter-clause.v.name
                                                       filter-op: filter-op
                                                       filter-value: filter-value
                                                       first-value-attr: first-value.a.value.text
                                                       first-value-var: first-value.v.name
                                                       hop1-attr: hop1.a.value.text
                                                       hop1-var: hop1.v.name
                                                       hop2-attr: hop2.a.value.text})
            true)))

(defn source-two-branch-projection-from-candidates [query: Query, anchor: Clause, direct-ref: Clause, direct-value: Clause, first-ref: Clause, filter-clause: Clause, first-value: Clause, hop1: Clause, hop2: Clause] -> [projection: Source-Anchor-Two-Branch-Join-Projection, ok: bool]
  (when (not (and (= filter-clause.v.kind .Var)
                  (source-clause-entity-var? filter-clause first-ref.e.name)))
    (return (empty-source-anchor-two-branch-join-projection) false))
  (let [[filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
    (when (not filter-ok)
      (return (empty-source-anchor-two-branch-join-projection) false))
    (when (or (not (source-multi-hop-anchor-clause? query anchor))
              (not (source-clause-same-source? anchor direct-ref))
              (not (source-clause-same-source? anchor direct-value))
              (not (source-clause-same-source? anchor first-ref))
              (not (source-clause-same-source? anchor filter-clause))
              (not (source-clause-same-source? anchor first-value))
              (not (source-clause-same-source? anchor hop1))
              (not (source-clause-same-source? anchor hop2))
              (not (source-clause-fixed-forward-attr? direct-ref))
              (not (source-clause-fixed-forward-attr? direct-value))
              (not (source-clause-fixed-forward-attr? first-ref))
              (not (source-clause-fixed-forward-attr? filter-clause))
              (not (source-clause-fixed-forward-attr? first-value))
              (not (source-clause-fixed-forward-attr? hop1))
              (not (source-clause-fixed-forward-attr? hop2))
              (not (= direct-ref.e.kind .Var))
              (not (= direct-ref.v.kind .Var))
              (not (= direct-ref.v.name anchor.e.name))
              (not (= direct-value.e.kind .Var))
              (not (= direct-value.e.name direct-ref.e.name))
              (not (= direct-value.v.kind .Var))
              (not (= first-ref.e.kind .Var))
              (not (= first-ref.v.kind .Var))
              (not (= first-ref.v.name anchor.e.name))
              (not (= first-value.e.kind .Var))
              (not (= first-value.e.name first-ref.e.name))
              (not (= first-value.v.kind .Var))
              (not (= hop1.e.kind .Var))
              (not (= hop1.e.name first-ref.e.name))
              (not (= hop1.v.kind .Var))
              (not (= hop2.e.kind .Var))
              (not (= hop2.e.name hop1.v.name))
              (not (= hop2.v.kind .Var))
              (not (= hop2.v.name direct-ref.e.name))
              (= direct-ref.e.name first-ref.e.name)
              (= direct-value.v.name first-value.v.name)
              (= direct-value.v.name filter-clause.v.name)
              (= first-value.v.name filter-clause.v.name)
              (not (query-find-three-vars? query direct-value.v.name first-value.v.name filter-clause.v.name)))
      (return (empty-source-anchor-two-branch-join-projection) false))
    (return (Source-Anchor-Two-Branch-Join-Projection {anchor-var: anchor.e.name
                                                       anchor-attr: anchor.a.value.text
                                                       anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                       anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                       has-anchor-input: (= anchor.v.kind .Var)
                                                       direct-entity-var: direct-ref.e.name
                                                       direct-ref-attr: direct-ref.a.value.text
                                                       direct-value-attr: direct-value.a.value.text
                                                       direct-value-var: direct-value.v.name
                                                       first-entity-var: first-ref.e.name
                                                       first-ref-attr: first-ref.a.value.text
                                                       filter-attr: filter-clause.a.value.text
                                                       filter-var: filter-clause.v.name
                                                       filter-op: filter-op
                                                       filter-value: filter-value
                                                       first-value-attr: first-value.a.value.text
                                                       first-value-var: first-value.v.name
                                                       hop1-attr: hop1.a.value.text
                                                       hop1-var: hop1.v.name
                                                       hop2-attr: hop2.a.value.text})
            true)))

(defn db-read-source-query-anchor-two-branch-join-projection-any-order [query: Query] -> [projection: Source-Anchor-Two-Branch-Join-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 8)
                  (= (count query.where-steps) 9)
                  (query-find-vars-unique? query)))
    (return (empty-source-anchor-two-branch-join-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (and (= step.kind .Predicate)
                        (= step.index 0))))
      (return (empty-source-anchor-two-branch-join-projection) false)))
  (for [anchor-index (arr.range 0 (count query.clauses))]
    (let [anchor query.clauses[anchor-index]]
      (when (and (source-multi-hop-anchor-clause? query anchor)
                 (source-multi-hop-clauses-compatible? query anchor))
        (for [direct-ref-index (arr.range 0 (count query.clauses))]
          (let [direct-ref query.clauses[direct-ref-index]]
            (when (and (not (= direct-ref-index anchor-index))
                       (= direct-ref.e.kind .Var)
                       (= direct-ref.v.kind .Var)
                       (= direct-ref.v.name anchor.e.name)
                       (not (= direct-ref.e.name anchor.e.name)))
              (for [first-ref-index (arr.range 0 (count query.clauses))]
                (let [first-ref query.clauses[first-ref-index]]
                  (when (and (not (= first-ref-index anchor-index))
                             (not (= first-ref-index direct-ref-index))
                             (= first-ref.e.kind .Var)
                             (= first-ref.v.kind .Var)
                             (= first-ref.v.name anchor.e.name)
                             (not (= first-ref.e.name anchor.e.name))
                             (not (= first-ref.e.name direct-ref.e.name)))
                    (for [direct-value-index (arr.range 0 (count query.clauses))]
                      (let [direct-value query.clauses[direct-value-index]]
                        (when (and (not (= direct-value-index anchor-index))
                                   (not (= direct-value-index direct-ref-index))
                                   (not (= direct-value-index first-ref-index))
                                   (source-clause-entity-var? direct-value direct-ref.e.name)
                                   (= direct-value.v.kind .Var)
                                   (source-query-find-has-var? query direct-value.v.name))
                          (for [filter-index (arr.range 0 (count query.clauses))]
                            (let [filter-clause query.clauses[filter-index]]
                              (when (and (not (= filter-index anchor-index))
                                         (not (= filter-index direct-ref-index))
                                         (not (= filter-index first-ref-index))
                                         (not (= filter-index direct-value-index))
                                         (source-clause-entity-var? filter-clause first-ref.e.name)
                                         (= filter-clause.v.kind .Var))
                                (let [[_ _ filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
                                  (when filter-ok
                                    (for [first-value-index (arr.range 0 (count query.clauses))]
                                      (let [first-value query.clauses[first-value-index]]
                                        (when (and (not (= first-value-index anchor-index))
                                                   (not (= first-value-index direct-ref-index))
                                                   (not (= first-value-index first-ref-index))
                                                   (not (= first-value-index direct-value-index))
                                                   (not (= first-value-index filter-index))
                                                   (source-clause-entity-var? first-value first-ref.e.name)
                                                   (= first-value.v.kind .Var)
                                                   (not (= first-value.v.name filter-clause.v.name))
                                                   (source-query-find-has-var? query first-value.v.name))
                                          (for [hop1-index (arr.range 0 (count query.clauses))]
                                            (let [hop1 query.clauses[hop1-index]]
                                              (when (and (not (= hop1-index anchor-index))
                                                         (not (= hop1-index direct-ref-index))
                                                         (not (= hop1-index first-ref-index))
                                                         (not (= hop1-index direct-value-index))
                                                         (not (= hop1-index filter-index))
                                                         (not (= hop1-index first-value-index))
                                                         (source-clause-entity-var? hop1 first-ref.e.name)
                                                         (= hop1.v.kind .Var))
                                                (for [hop2-index (arr.range 0 (count query.clauses))]
                                                  (let [hop2 query.clauses[hop2-index]]
                                                    (when (and (not (= hop2-index anchor-index))
                                                               (not (= hop2-index direct-ref-index))
                                                               (not (= hop2-index first-ref-index))
                                                               (not (= hop2-index direct-value-index))
                                                               (not (= hop2-index filter-index))
                                                               (not (= hop2-index first-value-index))
                                                               (not (= hop2-index hop1-index))
                                                               (source-clause-entity-var? hop2 hop1.v.name)
                                                               (= hop2.v.kind .Var)
                                                               (= hop2.v.name direct-ref.e.name))
                                                      (let [[candidate candidate-ok] (source-two-branch-projection-from-candidates query anchor direct-ref direct-value first-ref filter-clause first-value hop1 hop2)]
                                                        (when candidate-ok
                                                          (return candidate true)))))))))))))))))))))))))))))
  (return (empty-source-anchor-two-branch-join-projection) false))

(defn db-read-source-query-two-attr-entity-projection [query: Query] -> [projection: Two-Attr-Entity-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-two-attr-entity-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]]
    (when (or (not (= first.has-source second.has-source))
              (and first.has-source (not (= first.source second.source)))
              (not (= first.e.kind .Var))
              (not (= second.e.kind .Var))
              (not (= first.e.name second.e.name))
              (not (= first.a.kind .Value))
              (not (= second.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (not (= second.a.value.kind .Keyword))
              (not (= first.v.kind .Var))
              (not (= second.v.kind .Var))
              (= first.v.name second.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard)))
      (return (empty-two-attr-entity-projection) false))
    (when (not (or (and (= query.find[0] first.v.name)
                        (= query.find[1] second.v.name))
                   (and (= query.find[0] second.v.name)
                        (= query.find[1] first.v.name))))
      (return (empty-two-attr-entity-projection) false))
    (return (Two-Attr-Entity-Projection {first-attr: first.a.value.text
                                         first-var: first.v.name
                                         second-attr: second.a.value.text
                                         second-var: second.v.name})
            true)))

(defn db-read-source-query-direct-operator? [query: Query] -> bool
  (let [[_ top-n-ok] (query-attr-top-n-aggregate-plan query)]
    (when top-n-ok
      (return true)))
  (let [[_ aggregate-ok] (db-read-source-single-clause-aggregate-query query)]
    (when aggregate-ok
      (return true)))
  (let [[_ grouped-aggregate-ok] (db-read-source-single-clause-grouped-aggregate-query query)]
    (when grouped-aggregate-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-value-entity-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-input-entity-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-filtered-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-range-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-range-filtered-entity-attr-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-attr-entity-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-entity-pull-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-entity-get-else-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-ground-fixed-entity-get-else-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-entity-get-some-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-ground-fixed-entity-get-some-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-missing-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-fixed-entity-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-ground-fixed-entity-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-fixed-reverse-entity-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-fixed-entity-two-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-fixed-entity-ref-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-value-ref-attr-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-value-ref-star-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-multi-hop-ref-chain-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-multi-hop-ref-chain-projection-any-order query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-multi-hop-ref-chain-two-final-values-projection-ordered query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-multi-hop-ref-chain-final-filter-projection-ordered query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-anchor-two-branch-join-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-anchor-two-branch-join-projection-any-order query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-fixed-entity-attr-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-entity-attr-value-vars-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-filtered-entity-attr-value-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-two-attr-entity-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-three-attr-entity-projection query)]
    (when projection-ok
      (return true)))
  (let [[_ projection-ok] (db-read-source-query-entity-attr-value-projection query)]
    (when projection-ok
      (return true)))
  false)

(defn db-read-source-query-direct-operator-with-source? [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query] -> bool
  (when (db-read-source-relation-value-typed-query? sources query ([]Native-Query-Fn []))
    (return true))
  (let [[range-projection range-ok] (db-read-source-query-range-star-projection query)]
    (when range-ok
      (let [[projection-source _ source-ok _] (db-read-source-query-clause-source source sources query.clauses[0])]
        (when (not source-ok)
          (return false))
        (let [[ready-ok _] (db-read-source-range-star-projection-ready? projection-source query range-projection)]
          (return ready-ok)))))
  (when (db-read-source-query-star-attr-entity-projection? query)
    (let [[projection-source _ source-ok _] (db-read-source-query-clause-source source sources query.clauses[0])]
      (when (not source-ok)
        (return false))
      (let [[ready-ok _] (db-read-source-star-attr-entity-projection-ready? projection-source query)]
        (return ready-ok))))
  (when (= (count sources) 0)
    (let [[plan plan-ok plan-error] (db-read-source-query-string-int-pair-plan source query)]
      (delete plan.filters)
      (when (not (= plan-error ""))
        (return false))
      (when plan-ok
        (return true)))
    (let [[plan plan-ok plan-error] (db-read-source-query-entity-two-value-plan source query)]
      (delete plan.filters)
      (when (not (= plan-error ""))
        (return false))
      (when plan-ok
        (return true))))
  (db-read-source-query-direct-operator? query))

(defn db-read-source-query-profile-stats [query: Query, result: Result-Set] -> Query-Stats
  (let [stats (query-stats-empty)]
    (set! stats.steps (count query.where-steps))
    (set! stats.clauses (count query.clauses))
    (set! stats.output-rows (count result.rows))
    (when result.ok
      (if (db-read-source-query-direct-operator? query)
        (do
          (set! stats.source-index-scans (max 1 (count query.clauses)))
          (set! stats.source-operators 1)
          (set! stats.clause-candidates (count result.rows))
          (set! stats.max-intermediate-bindings (count result.rows)))
        (do
          (set! stats.source-index-scans (count query.clauses))
          (set! stats.generic-materialization-steps 1)
          (set! stats.binding-materializations (count result.rows))
          (set! stats.clause-candidates (count result.rows))
          (set! stats.max-intermediate-bindings (count result.rows)))))
    stats))

(defn query-stats-copy-typed-source! [stats: ^Query-Stats, typed-stats: Query-Stats, result: Result-Set]
  (set! stats^.input-bindings typed-stats.input-bindings)
  (set! stats^.source-index-scans typed-stats.source-index-scans)
  (set! stats^.source-operators typed-stats.source-operators)
  (set! stats^.clause-candidates (max typed-stats.clause-candidates (count result.rows)))
  (set! stats^.max-intermediate-bindings (max typed-stats.max-intermediate-bindings (count result.rows)))
  (set! stats^.generic-materialization-steps 0)
  (set! stats^.binding-materializations 0))

(defn query-logical-clause-count [query: Query] -> int
  (let [out (count query.clauses)
        step-count 0]
    (for [step query.where-steps]
      (when (= step.kind .Clause)
        (inc! step-count)))
    (max out step-count)))

(defn db-read-source-query-input-binding-count [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [count-value: int, ok: bool]
  (let [[rel binding-count input-ok] (db-read-source-query-relation-initial-from-inputs source query inputs)]
    (delete-query-relation rel)
    (return binding-count input-ok)))

(defn db-read-source-query-profile-stats-with-source-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, inputs: []Query-Input, result: Result-Set, registry: []Native-Query-Fn] -> Query-Stats
  (when (and (= source.kind .Resident)
             (= (count sources) 0)
             (not (db-read-source-query-has-source-inputs? query)))
    (return (q-query-profiled-with-sources-and-fns source.db^ query inputs ([]DB-Source []) registry).stats))
  (let [owned-source-values (make [dynamic]Value 0 (count inputs)) :defer
        augmented-sources (arr.into [dynamic]DB-Read-Named-Source sources) :defer
        [input-sources-ok _] (append-db-read-source-query-input-sources! (addr augmented-sources) (addr owned-source-values) query inputs)]
    (defer
      (do
        (for [value owned-source-values]
          (delete-owned-value value))))
    (if input-sources-ok
      (let [stats (db-read-source-query-profile-stats-with-source source (slice augmented-sources 0) query result)]
        (when (> (count inputs) 0)
          (let [[input-binding-count input-binding-ok] (db-read-source-query-input-binding-count source query inputs)]
            (when input-binding-ok
              (set! stats.input-bindings input-binding-count))))
        (when result.ok
          (let [[typed-result typed-stats typed-used] (db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns source (slice augmented-sources 0) query inputs registry)]
            (delete-result-rows-owned-values typed-result.rows)
            (when typed-used
              (query-stats-copy-typed-source! (addr stats) typed-stats result))))
        stats)
      (db-read-source-query-profile-stats-with-source source sources query result))))

(defn db-read-source-query-profile-stats-with-source-inputs [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, inputs: []Query-Input, result: Result-Set] -> Query-Stats
  (db-read-source-query-profile-stats-with-source-inputs-and-fns source sources query inputs result ([]Native-Query-Fn [])))

(defn db-read-source-query-profile-stats-with-source [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, result: Result-Set] -> Query-Stats
  (let [stats (query-stats-empty)]
    (set! stats.steps (count query.where-steps))
    (set! stats.clauses (count query.clauses))
    (set! stats.output-rows (count result.rows))
    (when result.ok
      (let [[typed-result typed-stats typed-used] (db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns source sources query ([]Query-Input []) ([]Native-Query-Fn []))]
        (delete-result-rows-owned-values typed-result.rows)
        (when typed-used
          (query-stats-copy-typed-source! (addr stats) typed-stats result)
          (return stats)))
      (if (db-read-source-query-direct-operator-with-source? source sources query)
        (do
          (set! stats.source-index-scans (max 1 (count query.clauses)))
          (set! stats.source-operators 1)
          (set! stats.clause-candidates (count result.rows))
          (set! stats.max-intermediate-bindings (count result.rows)))
        (do
          (set! stats.source-index-scans (count query.clauses))
          (set! stats.generic-materialization-steps 1)
          (set! stats.binding-materializations (count result.rows))
          (set! stats.clause-candidates (count result.rows))
          (set! stats.max-intermediate-bindings (count result.rows)))))
    stats))

(defn query-entity-attr-value-projection [db: DB, query: Query] -> [projection: Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-entity-attr-value-projection) false))
  (let [left query.clauses[0]
        right query.clauses[1]]
    (when (or left.has-source
              right.has-source
              (not (= left.e.kind .Var))
              (not (= right.e.kind .Var))
              (not (= left.e.name right.e.name))
              (not (= left.a.kind .Value))
              (not (= right.a.kind .Value))
              (not (= left.a.value.kind .Keyword))
              (not (= right.a.value.kind .Keyword))
              (not (= left.tx-term.kind .Wildcard))
              (not (= right.tx-term.kind .Wildcard))
              (not (= left.op-term.kind .Wildcard))
              (not (= right.op-term.kind .Wildcard)))
      (return (empty-entity-attr-value-projection) false))
    (let [filter-clause (if (= left.v.kind .Value) left right)
          value-clause (if (= left.v.kind .Value) right left)]
      (when (or (not (= filter-clause.v.kind .Value))
                (not (= value-clause.v.kind .Var))
                (tx-data-modifies-validation-schema? (Tx-Data {a: filter-clause.a.value.text}))
                (schema-ref-target? db filter-clause.a.value.text)
                (not (or (and (= query.find[0] filter-clause.e.name)
                              (= query.find[1] value-clause.v.name))
                         (and (= query.find[0] value-clause.v.name)
                              (= query.find[1] filter-clause.e.name)))))
        (return (empty-entity-attr-value-projection) false))
      (return (Entity-Attr-Value-Projection {entity-var: filter-clause.e.name
                                             filter-attr: filter-clause.a.value.text
                                             filter-value: filter-clause.v.value
                                             value-attr: value-clause.a.value.text
                                             value-var: value-clause.v.name})
              true))))

(defn query-entity-int-pair-plan [db: DB, query: Query] -> [plan: Entity-Int-Pair-Plan, ok: bool]
  (let [out (empty-entity-int-pair-plan)]
    (when (not (and (= (count query.find) 2)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 2)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false)))
    (let [entity-var query.find[0]
          value-var query.find[1]
          value-clause-found false
          value-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.e.name entity-var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard))
                  (not (schema-cardinality-one? db item.a.value.text)))
          (return out false))
        (if (= item.v.kind .Var)
          (do
            (when (or value-clause-found
                      (not (= item.v.name value-var)))
              (return out false))
            (set! value-clause-found true)
            (set! value-attr item.a.value.text))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false))))
      (when (or (not value-clause-found)
                (= (count out.filters) 0))
        (return out false))
      (set! out.entity-var entity-var)
      (set! out.value-var value-var)
      (set! out.value-attr value-attr)
      (return out true))))

(defn query-entity-two-value-plan [db: DB, query: Query] -> [plan: Entity-Two-Value-Plan, ok: bool]
  (let [out (empty-entity-two-value-plan)]
    (when (not (and (= (count query.find) 3)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 3)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false)))
    (let [entity-var query.find[0]
          first-var query.find[1]
          second-var query.find[2]
          first-found false
          second-found false
          first-attr ""
          second-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.e.name entity-var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard))
                  (not (schema-cardinality-one? db item.a.value.text)))
          (return out false))
        (if (= item.v.kind .Var)
          (cond
            (= item.v.name first-var)
              (do
                (when first-found
                  (return out false))
                (set! first-found true)
                (set! first-attr item.a.value.text))
            (= item.v.name second-var)
              (do
                (when second-found
                  (return out false))
                (set! second-found true)
                (set! second-attr item.a.value.text))
            :else (return out false))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false))))
      (when (or (not first-found)
                (not second-found)
                (= (count out.filters) 0)
                (not (all-datoms-current? db)))
        (return out false))
      (set! out.entity-var entity-var)
      (set! out.first-var first-var)
      (set! out.first-attr first-attr)
      (set! out.second-var second-var)
      (set! out.second-attr second-attr)
      (return out true))))

(defn query-input-by-name-scalar-value [query: Query, inputs: []Query-Input, name: string] -> [value: Value, ok: bool]
  (for [input-name index (slice query.inputs 0)]
    (when (= input-name name)
      (when (>= index (count inputs))
        (return (Value {}) false))
      (let [input inputs[index]]
        (when (= input.kind .Scalar)
          (return input.value true))
        (return (Value {}) false))))
  (return (Value {}) false))

(defn query-input-by-name [query: Query, inputs: []Query-Input, name: string] -> [input: Query-Input, ok: bool]
  (for [input-name index (slice query.inputs 0)]
    (when (= input-name name)
      (when (>= index (count inputs))
        (return (Query-Input {}) false))
      (return inputs[index] true)))
  (return (Query-Input {}) false))

(defn query-threshold-term-int [query: Query, inputs: []Query-Input, term: Term] -> [value: i64, ok: bool]
  (when (= term.kind .Value)
    (when (= term.value.kind .Int)
      (return term.value.int-value true))
    (return 0 false))
  (when (= term.kind .Var)
    (let [[input-value input-ok] (query-input-by-name-scalar-value query inputs term.name)]
      (when (and input-ok (= input-value.kind .Int))
        (return input-value.int-value true))))
  (return 0 false))

(defn query-entity-int-threshold-plan [db: DB, query: Query, inputs: []Query-Input] -> [plan: Entity-Int-Threshold-Plan, ok: bool]
  (let [out (empty-entity-int-threshold-plan)]
    (when (not (and (= (count query.find) 2)
                    (= (count query.with) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.predicates) 1)
                    (= (count query.where-steps) 2)))
      (return out false))
    (when (not (and (= query.where-steps[0].kind .Clause)
                    (= query.where-steps[1].kind .Predicate)))
      (return out false))
    (let [entity-var query.find[0]
          value-var query.find[1]
          query-clause query.clauses[0]
          predicate query.predicates[0]]
      (when (or query-clause.has-source
                (not (= query-clause.e.kind .Var))
                (not (= query-clause.e.name entity-var))
                (not (= query-clause.a.kind .Value))
                (not (= query-clause.a.value.kind .Keyword))
                (not (= query-clause.v.kind .Var))
                (not (= query-clause.v.name value-var))
                (not (= query-clause.tx-term.kind .Wildcard))
                (not (= query-clause.op-term.kind .Wildcard))
                (not (schema-cardinality-one? db query-clause.a.value.text))
                (not (= predicate.op ">"))
                (not (= (count predicate.terms) 2))
                (not (= predicate.terms[0].kind .Var))
                (not (= predicate.terms[0].name value-var)))
        (return out false))
      (let [[threshold threshold-ok] (query-threshold-term-int query inputs predicate.terms[1])]
        (when (not threshold-ok)
          (return out false))
        (set! out.entity-var entity-var)
        (set! out.value-var value-var)
        (set! out.value-attr query-clause.a.value.text)
        (set! out.threshold threshold)
        (return out true)))))

(defn query-entity-value-self-join-plan [db: DB, query: Query] -> [plan: Entity-Value-Self-Join-Plan, ok: bool]
  (let [out (empty-entity-value-self-join-plan)]
    (when (not (and (= (count query.find) 3)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 4)
                    (= (count query.where-steps) 4)
                    (all-datoms-current? db)))
      (return out false))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false)))
    (let [right-entity-var query.find[0]
          output-var query.find[1]
          join-var query.find[2]
          left-entity-var ""
          join-attr ""
          left-filter-attr ""
          left-filter-value (Value {})
          output-attr ""
          right-join-found false
          left-join-found false
          left-filter-found false
          output-found false]
      (for [item query.clauses]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard))
                  (not (schema-cardinality-one? db item.a.value.text)))
          (return out false))
        (cond
          (and (= item.e.name right-entity-var)
               (= item.v.kind .Var)
               (= item.v.name output-var))
            (do
              (when output-found
                (return out false))
              (set! output-found true)
              (set! output-attr item.a.value.text))
          (and (= item.e.name right-entity-var)
               (= item.v.kind .Var)
               (= item.v.name join-var))
            (do
              (when right-join-found
                (return out false))
              (set! right-join-found true)
              (set! join-attr item.a.value.text))
          (and (= item.v.kind .Var)
               (= item.v.name join-var))
            (do
              (when left-join-found
                (return out false))
              (when (= item.e.name right-entity-var)
                (return out false))
              (when (and (> (count left-entity-var) 0)
                         (not (= left-entity-var item.e.name)))
                (return out false))
              (set! left-join-found true)
              (set! left-entity-var item.e.name)
              (when (> (count join-attr) 0)
                (when (not (= join-attr item.a.value.text))
                  (return out false)))
              (set! join-attr item.a.value.text))
          (= item.v.kind .Value)
            (do
              (when (or left-filter-found
                        (= item.e.name right-entity-var))
                (return out false))
              (when (and (> (count left-entity-var) 0)
                         (not (= left-entity-var item.e.name)))
                (return out false))
              (set! left-filter-found true)
              (set! left-entity-var item.e.name)
              (set! left-filter-attr item.a.value.text)
              (set! left-filter-value item.v.value))
          :else (return out false)))
      (when (or (not right-join-found)
                (not left-join-found)
                (not left-filter-found)
                (not output-found))
        (return out false))
      (return (Entity-Value-Self-Join-Plan {left-entity-var: left-entity-var
                                            right-entity-var: right-entity-var
                                            join-var: join-var
                                            join-attr: join-attr
                                            left-filter-attr: left-filter-attr
                                            left-filter-value: left-filter-value
                                            output-var: output-var
                                            output-attr: output-attr})
              true))))

(defn entity-star-stream-datom-index [stream: Entity-Star-Stream] -> int
  (db-index-view-at stream.view stream.index))

(defn entity-star-stream-entity [db: DB, stream: Entity-Star-Stream] -> u64
  db.datoms[(entity-star-stream-datom-index stream)].e)

(defn entity-star-stream-advance-to! [db: DB, stream: ^Entity-Star-Stream, entity: u64] -> bool
  (while (and (< stream^.index stream^.high)
              (< db.datoms[(entity-star-stream-datom-index stream^)].e entity))
    (set! stream^.index (+ stream^.index 1)))
  (< stream^.index stream^.high))

(defn entity-star-streams-align! [db: DB, streams: ^[dynamic]Entity-Star-Stream] -> [entity: u64, ok: bool]
  (when (= (count streams^) 0)
    (return 0 false))
  (let [target: u64 0]
    (for [stream streams^]
      (when (>= stream.index stream.high)
        (return 0 false))
      (let [entity (entity-star-stream-entity db stream)]
        (when (> entity target)
          (set! target entity))))
    (let [changed true]
      (while changed
        (set! changed false)
        (for [_ stream-index streams^]
          (when (not (entity-star-stream-advance-to! db (addr streams^[stream-index]) target))
            (return 0 false))
          (let [entity (entity-star-stream-entity db streams^[stream-index])]
            (when (> entity target)
              (set! target entity)
              (set! changed true))))))
    (return target true)))

(defn entity-star-streams-advance-all! [streams: ^[dynamic]Entity-Star-Stream]
  (for [_ stream-index streams^]
    (set! streams^[stream-index].index (+ streams^[stream-index].index 1))))

(defn entity-star-output-value [db: DB, streams: []Entity-Star-Stream, output-index: int] -> [value: Value, ok: bool]
  (for [stream streams]
    (when (= stream.output-index output-index)
      (let [datom db.datoms[(entity-star-stream-datom-index stream)]]
        (return datom.v true))))
  (return (Value {}) false))

(defn entity-star-streams-for-filters-and-outputs [db: DB, filters: []Entity-Int-Pair-Filter, output-attrs: []string] -> [streams: [dynamic]Entity-Star-Stream]
  (let [out (make [dynamic]Entity-Star-Stream)
        avet-view (db-index-view db .AVET)
        aevt-view (db-index-view db .AEVT)]
    (for [filter filters]
      (let [low (lower-bound-index-view db avet-view "avet" 0 filter.attr filter.value)
            high (upper-bound-index-view db avet-view "avet" 0 filter.attr filter.value)]
        (arr.push! out (Entity-Star-Stream {view: avet-view
                                            index: low
                                            high: high
                                            output-index: -1}))))
    (for [attr output-index output-attrs]
      (let [low (lower-bound-index-view db aevt-view "aevt" 0 attr (Value {}))
            high (upper-bound-index-view db aevt-view "aevt" 0 attr (Value {}))]
        (arr.push! out (Entity-Star-Stream {view: aevt-view
                                            index: low
                                            high: high
                                            output-index: output-index}))))
    out))

(defn relation-add-entity-value-row! [columns: ^[dynamic]Relation-Column, rows: ^int, entity: u64, value: Value] -> bool
  (let [entity-value (value-entity entity)]
    (when (not (and (relation-column-can-add? columns^[0] entity-value)
                    (relation-column-can-add? columns^[1] value)))
      (return false))
    (discard (relation-column-add! (addr columns^[0]) entity-value))
    (discard (relation-column-add! (addr columns^[1]) value))
    (set! rows^ (+ rows^ 1))
    true))

(defn relation-add-entity-two-value-row! [columns: ^[dynamic]Relation-Column, rows: ^int, entity: u64, first-value: Value, second-value: Value] -> bool
  (let [entity-value (value-entity entity)]
    (when (not (and (relation-column-can-add? columns^[0] entity-value)
                    (relation-column-can-add? columns^[1] first-value)
                    (relation-column-can-add? columns^[2] second-value)))
      (return false))
    (discard (relation-column-add! (addr columns^[0]) entity-value))
    (discard (relation-column-add! (addr columns^[1]) first-value))
    (discard (relation-column-add! (addr columns^[2]) second-value))
    (set! rows^ (+ rows^ 1))
    true))

(defn query-relation-from-entity-int-pair-star-plan [db: DB, query: Query, plan: Entity-Int-Pair-Plan, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (and (all-datoms-current? db)
                  (> (count plan.filters) 0)))
    (return (query-relation-empty) false))
  (let [attrs ([dynamic]string [plan.entity-var plan.value-var])
        attr-sources ([dynamic]string ["" ""])
        typed-columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0
        output-attrs ([]string [plan.value-attr])
        streams (entity-star-streams-for-filters-and-outputs db (slice plan.filters 0) output-attrs)]
    (defer (delete streams))
    (set! stats^.steps (+ stats^.steps (count query.where-steps)))
    (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
    (for [stream streams]
      (set! stats^.clause-candidates (+ stats^.clause-candidates (- stream.high stream.index))))
    (let [done false]
      (while (not done)
      (let [[entity entity-ok] (entity-star-streams-align! db (addr streams))]
        (when (not entity-ok)
          (set! done true))
        (when entity-ok
          (let [[value value-ok] (entity-star-output-value db (slice streams 0) 0)]
            (when value-ok
              (when (not (relation-add-entity-value-row! (addr typed-columns) (addr typed-rows) entity value))
                (delete attrs)
                (delete attr-sources)
                (delete-relation-columns typed-columns)
                (return (query-relation-empty) false))))
          (entity-star-streams-advance-all! (addr streams))))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: typed-columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-entity-two-value-star-plan [db: DB, query: Query, plan: Entity-Two-Value-Plan, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (and (all-datoms-current? db)
                  (> (count plan.filters) 0)))
    (return (query-relation-empty) false))
  (let [attrs ([dynamic]string [plan.entity-var plan.first-var plan.second-var])
        attr-sources ([dynamic]string ["" "" ""])
        typed-columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0
        output-attrs ([]string [plan.first-attr plan.second-attr])
        streams (entity-star-streams-for-filters-and-outputs db (slice plan.filters 0) output-attrs)]
    (defer (delete streams))
    (set! stats^.steps (+ stats^.steps (count query.where-steps)))
    (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
    (for [stream streams]
      (set! stats^.clause-candidates (+ stats^.clause-candidates (- stream.high stream.index))))
    (let [done false]
      (while (not done)
      (let [[entity entity-ok] (entity-star-streams-align! db (addr streams))]
        (when (not entity-ok)
          (set! done true))
        (when entity-ok
          (let [[first-value first-ok] (entity-star-output-value db (slice streams 0) 0)
                [second-value second-ok] (entity-star-output-value db (slice streams 0) 1)]
            (when (and first-ok second-ok)
              (when (not (relation-add-entity-two-value-row! (addr typed-columns) (addr typed-rows) entity first-value second-value))
                (delete attrs)
                (delete attr-sources)
                (delete-relation-columns typed-columns)
                (return (query-relation-empty) false))))
          (entity-star-streams-advance-all! (addr streams))))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: typed-columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-entity-star-plan [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (or (> (count inputs) 0)
            (> (count sources) 0)
            (> (count registry) 0))
    (return (query-relation-empty) false))
  (let [[two-plan two-ok] (query-entity-two-value-plan db query)]
    (when two-ok
      (let [[rel ok] (query-relation-from-entity-two-value-star-plan db query two-plan stats)]
        (delete two-plan.filters)
        (return rel ok)))
    (delete two-plan.filters))
  (let [[pair-plan pair-ok] (query-entity-int-pair-plan db query)]
    (when pair-ok
      (let [[rel ok] (query-relation-from-entity-int-pair-star-plan db query pair-plan stats)]
        (delete pair-plan.filters)
        (return rel ok)))
    (delete pair-plan.filters))
  (return (query-relation-empty) false))

(defn q-query-entity-int-threshold-pair-columns [db: DB, plan: Entity-Int-Threshold-Plan] -> Entity-Int-Pair-Columns
  (let [view (db-index-view db .AVET)
        all-current (all-datoms-current? db)]
    (when (and all-current (schema-value-type-long? db plan.value-attr))
      (let [low (upper-bound-index-view db view "avet" 0 plan.value-attr (value-int plan.threshold))
            high (lower-bound-index-view db view "avet" 0 plan.value-attr (Value {kind: .Float}))
            out (entity-int-pair-columns-with-capacity (- high low))
            i low]
        (while (< i high)
          (let [datom db.datoms[(db-index-view-at view i)]]
            (append-entity-int-pair-column! (addr out) datom.e datom.v.int-value))
          (set! i (+ i 1)))
        (return out)))
    (let [low (lower-bound-index-view db view "avet" 0 plan.value-attr (value-int plan.threshold))
          attr-prefix ([]Value [(value-keyword plan.value-attr)])
          high (upper-bound-index-view-values db view attr-prefix)
          out (entity-int-pair-columns-with-capacity (- high low))
          i low]
      (while (< i high)
        (let [datom-index (db-index-view-at view i)
              datom db.datoms[datom-index]]
          (when (and (or all-current (datom-current-at? db datom-index))
                     (= datom.a plan.value-attr)
                     (= datom.v.kind .Int)
                     (> datom.v.int-value plan.threshold))
            (append-entity-int-pair-column! (addr out) datom.e datom.v.int-value)))
        (set! i (+ i 1)))
      out)))

(defn q-entity-value-self-join-profiled [db: DB, plan: Entity-Value-Self-Join-Plan, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        seen-join-values (set.empty string)
        join-values (make [dynamic]Value)
        output-by-entity (make (map u64 Value))
        avet-view (db-index-view db .AVET)
        aevt-view (db-index-view db .AEVT)
        left-low (lower-bound-index-view db avet-view "avet" 0 plan.left-filter-attr plan.left-filter-value)
        left-high (upper-bound-index-view db avet-view "avet" 0 plan.left-filter-attr plan.left-filter-value)
        output-low (lower-bound-index-view db aevt-view "aevt" 0 plan.output-attr (Value {}))
        output-high (upper-bound-index-view db aevt-view "aevt" 0 plan.output-attr (Value {}))]
    (defer (delete seen-join-values))
    (defer (delete join-values))
    (defer (delete output-by-entity))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 4)
    (set! out-stats.clause-candidates (- left-high left-low))
    (let [output-index output-low]
      (while (< output-index output-high)
        (let [datom db.datoms[(db-index-view-at aevt-view output-index)]]
          (mmap.assoc! output-by-entity datom.e datom.v))
        (set! output-index (+ output-index 1))))
    (let [left-index left-low]
      (while (< left-index left-high)
        (let [left-datom db.datoms[(db-index-view-at avet-view left-index)]
              [join-value join-ok] (cardinality-one-value-fast-all-current db left-datom.e plan.join-attr)]
          (when join-ok
            (let [[join-key join-key-ok] (primitive-value-dedupe-key join-value)]
              (if join-key-ok
                (let [already-seen (set.contains? seen-join-values join-key)]
                  (when (not already-seen)
                    (set.add! seen-join-values join-key)
                    (arr.push! join-values join-value)))
                (when (not (value-slice-contains? (slice join-values 0) join-value))
                  (arr.push! join-values join-value))))))
        (set! left-index (+ left-index 1))))
    (let [right-candidates 0]
      (for [join-value join-values]
        (let [right-low (lower-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
              right-high (upper-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)]
          (set! right-candidates (+ right-candidates (- right-high right-low)))))
      (let [rows (make [dynamic]Result-Row 0 right-candidates)]
        (for [join-value join-values]
          (let [right-low (lower-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
                right-high (upper-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
                right-index right-low]
            (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- right-high right-low)))
            (while (< right-index right-high)
              (let [right-datom db.datoms[(db-index-view-at avet-view right-index)]
                    [output output-ok] (mmap.get output-by-entity right-datom.e)]
                (when output-ok
                  (append-three-value-row! (addr rows) (value-entity right-datom.e) output join-value)))
              (set! right-index (+ right-index 1)))))
        (set! out-stats.max-intermediate-bindings (count rows))
        (set! out-stats.output-rows (count rows))
        (profiled-result-set (result-set-ok rows) out-stats)))))

(defn q-entity-value-self-join-triples [db: DB, plan: Entity-Value-Self-Join-Plan] -> Entity-String-Int-Triples
  (let [seen-join-values (set.empty string)
        join-values (make [dynamic]Value)
        output-by-entity (make (map u64 string))
        avet-view (db-index-view db .AVET)
        aevt-view (db-index-view db .AEVT)
        left-low (lower-bound-index-view db avet-view "avet" 0 plan.left-filter-attr plan.left-filter-value)
        left-high (upper-bound-index-view db avet-view "avet" 0 plan.left-filter-attr plan.left-filter-value)
        output-low (lower-bound-index-view db aevt-view "aevt" 0 plan.output-attr (Value {}))
        output-high (upper-bound-index-view db aevt-view "aevt" 0 plan.output-attr (Value {}))]
    (defer (delete seen-join-values))
    (defer (delete join-values))
    (defer (delete output-by-entity))
    (let [output-index output-low]
      (while (< output-index output-high)
        (let [datom db.datoms[(db-index-view-at aevt-view output-index)]]
          (when (= datom.v.kind .String)
            (mmap.assoc! output-by-entity datom.e datom.v.text)))
        (set! output-index (+ output-index 1))))
    (let [left-index left-low]
      (while (< left-index left-high)
        (let [left-datom db.datoms[(db-index-view-at avet-view left-index)]
              [join-value join-ok] (cardinality-one-value-fast-all-current db left-datom.e plan.join-attr)]
          (when (and join-ok (= join-value.kind .Int))
            (let [[join-key join-key-ok] (primitive-value-dedupe-key join-value)]
              (if join-key-ok
                (let [already-seen (set.contains? seen-join-values join-key)]
                  (when (not already-seen)
                    (set.add! seen-join-values join-key)
                    (arr.push! join-values join-value)))
                (when (not (value-slice-contains? (slice join-values 0) join-value))
                  (arr.push! join-values join-value))))))
        (set! left-index (+ left-index 1))))
    (let [right-candidates 0]
      (for [join-value join-values]
        (let [right-low (lower-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
              right-high (upper-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)]
          (set! right-candidates (+ right-candidates (- right-high right-low)))))
      (let [out (Entity-String-Int-Triples {entities: (make [dynamic]u64 0 right-candidates)
                                            strings: (make [dynamic]string 0 right-candidates)
                                            ints: (make [dynamic]i64 0 right-candidates)})]
        (for [join-value join-values]
          (let [right-low (lower-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
                right-high (upper-bound-index-view db avet-view "avet" 0 plan.join-attr join-value)
                right-index right-low]
            (while (< right-index right-high)
              (let [right-datom db.datoms[(db-index-view-at avet-view right-index)]
                    [output output-ok] (mmap.get output-by-entity right-datom.e)]
                (when output-ok
                  (append-entity-string-int-triple! (addr out) right-datom.e output join-value.int-value)))
              (set! right-index (+ right-index 1)))))
        out))))

(defn append-two-attr-projection-row! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, query: Query, projection: Two-Attr-Entity-Projection, first-value-source: Value, second-value-source: Value]
  (let [first-value (if (= query.find[0] projection.first-var) first-value-source second-value-source)
        second-value (if (= query.find[1] projection.second-var) second-value-source first-value-source)
        [added added-ok] (two-value-seen-add seen first-value second-value)]
    (if added-ok
      (when added
        (append-two-value-row! rows first-value second-value))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-two-value-row! rows first-value second-value))))))

(defn append-db-read-source-two-attr-projection-row! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, query: Query, projection: Two-Attr-Entity-Projection, first-value-source: Value, second-value-source: Value]
  (let [first-value (if (= query.find[0] projection.first-var) first-value-source second-value-source)
        second-value (if (= query.find[1] projection.second-var) second-value-source first-value-source)
        [added added-ok] (two-value-seen-add seen first-value second-value)]
    (if added-ok
      (when added
        (append-owned-two-value-row! rows first-value second-value))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-owned-two-value-row! rows first-value second-value))))))

(defn append-db-read-source-entity-value-projection-row! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, query: Query, projection: Source-Entity-Value-Projection, entity: u64, source-value: Value]
  (let [entity-value (value-entity entity)
        first-value (if (= query.find[0] projection.entity-var) entity-value source-value)
        second-value (if (= query.find[1] projection.value-var) source-value entity-value)
        [added added-ok] (two-value-seen-add seen first-value second-value)]
    (if added-ok
      (when added
        (append-owned-two-value-row! rows first-value second-value))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-owned-two-value-row! rows first-value second-value))))))

(defn db-read-source-entity-attr-value-projection-value [projection: Source-Entity-Attr-Value-Projection, datom: Datom, name: string] -> Value
  (cond
    (= name projection.entity-var) (value-entity datom.e)
    (= name projection.attr-var) (value-keyword datom.a)
    (= name projection.value-var) datom.v
    :else (Value {})))

(defn db-read-source-entity-attr-value-projection-owned-value [projection: Source-Entity-Attr-Value-Projection, datom: Datom, name: string] -> Value
  (cond
    (= name projection.entity-var) (value-entity datom.e)
    (= name projection.attr-var) (value-keyword (string-owned datom.a))
    (= name projection.value-var) (value-owned datom.v)
    :else (Value {})))

(defn append-db-read-source-entity-attr-value-projection-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Entity-Attr-Value-Projection, datom: Datom]
  (let [first-value (db-read-source-entity-attr-value-projection-value projection datom query.find[0])
        second-value (db-read-source-entity-attr-value-projection-value projection datom query.find[1])
        third-value (db-read-source-entity-attr-value-projection-value projection datom query.find[2])
        dedupe-values ([]Value [first-value second-value third-value])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-three-value-row! rows
                               (db-read-source-entity-attr-value-projection-owned-value projection datom query.find[0])
                               (db-read-source-entity-attr-value-projection-owned-value projection datom query.find[1])
                               (db-read-source-entity-attr-value-projection-owned-value projection datom query.find[2])))))

(defn q-db-read-source-entity-attr-value-vars-projection [source: DB-Read-Source, query: Query, clause-value: Clause, projection: Source-Entity-Attr-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)]
    (if (db-read-source-has-overlay? source)
      (let [[datoms datoms-ok datoms-error] (db-read-source-clause-candidates source clause-value)]
        (when (not datoms-ok)
          (return (result-set-error datoms-error)))
        (defer (delete-owned-datoms datoms))
        (for [datom datoms]
          (append-db-read-source-entity-attr-value-projection-row! (addr rows) query projection datom)))
      (let [[stream stream-ok stream-error] (source-clause-datom-stream source clause-value)]
        (when (not stream-ok)
          (return (result-set-error stream-error)))
        (while stream.has-current
          (append-db-read-source-entity-attr-value-projection-row! (addr rows) query projection stream.current)
          (let [[advance-ok advance-error] (advance-source-clause-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-clause-datom-stream stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (delete-source-clause-datom-stream stream)))
    (result-set-ok rows)))

(defn q-db-read-source-entity-attr-value-projection [source: DB-Read-Source, query: Query, projection: Source-Entity-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen (two-primitive-seen)]
    (defer (delete-two-primitive-seen seen))
    (if (reverse-attr? projection.attr)
      (let [forward-attr (forward-attr-for-reverse projection.attr) :defer]
        (if (db-read-source-has-overlay? source)
          (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source forward-attr)]
            (when (not datoms-ok)
              (return (result-set-error datoms-error)))
            (defer (delete-owned-datoms datoms))
            (for [datom datoms]
              (when (= datom.v.kind .Entity)
                (append-db-read-source-entity-value-projection-row! (addr rows) (addr seen) query projection datom.v.entity (value-entity datom.e)))))
          (let [[stream stream-ok stream-error] (source-index-datom-stream source forward-attr)]
            (when (not stream-ok)
              (return (result-set-error stream-error)))
            (while stream.has-current
              (when (= stream.current.v.kind .Entity)
                (append-db-read-source-entity-value-projection-row! (addr rows) (addr seen) query projection stream.current.v.entity (value-entity stream.current.e)))
              (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                (when (not advance-ok)
                  (delete-source-index-datom-stream stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error advance-error)))))
            (delete-source-index-datom-stream stream))))
      (if (db-read-source-has-overlay? source)
        (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source projection.attr)]
          (when (not datoms-ok)
            (return (result-set-error datoms-error)))
          (defer (delete-owned-datoms datoms))
          (for [datom datoms]
            (append-db-read-source-entity-value-projection-row! (addr rows) (addr seen) query projection datom.e datom.v)))
        (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.attr)]
          (when (not stream-ok)
            (return (result-set-error stream-error)))
          (while stream.has-current
            (append-db-read-source-entity-value-projection-row! (addr rows) (addr seen) query projection stream.current.e stream.current.v)
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream stream)
                (delete-result-rows-owned-values rows)
                (return (result-set-error advance-error)))))
          (delete-source-index-datom-stream stream))))
    (result-set-ok rows)))

(defn append-db-read-source-filtered-entity-attr-value-projection-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Entity-Attr-Value-Projection, entity: u64, source-value: Value]
  (if (= (count query.find) 1)
    (when (not (row-values-exist? (slice rows^ 0) ([]Value [source-value])))
      (append-distinct-single-value-row! rows (value-owned source-value)))
    (let [entity-value (value-entity entity)
          first-value (if (= query.find[0] projection.entity-var) entity-value source-value)
          second-value (if (= query.find[1] projection.value-var) source-value entity-value)
          dedupe-values ([]Value [first-value second-value])]
      (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
        (append-owned-two-value-row! rows first-value second-value)))))

(defn append-db-read-source-filtered-projection-values! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Entity-Attr-Value-Projection, entity: u64, many: bool] -> [ok: bool, error: string]
  (if many
    (if (db-read-source-has-overlay? source)
      (let [[projected-datoms projected-ok projected-error] (db-read-source-datoms-by-entity-attr source entity projection.value-attr)]
        (when (not projected-ok)
          (return false projected-error))
        (for [projected-datom projected-datoms]
          (append-db-read-source-filtered-entity-attr-value-projection-row! rows query projection entity projected-datom.v))
        (delete-owned-datoms projected-datoms)
        (return true ""))
      (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity projection.value-attr)]
        (when (not stream-ok)
          (return false stream-error))
        (while stream.has-current
          (append-db-read-source-filtered-entity-attr-value-projection-row! rows query projection entity stream.current.v)
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false advance-error))))
        (delete-source-index-datom-stream stream)
        (return true "")))
    (let [[projected-value projected-ok projected-error] (db-read-source-cardinality-one-value-fast-all-current source entity projection.value-attr)]
      (when (not (= projected-error ""))
        (return false projected-error))
      (when projected-ok
        (append-db-read-source-filtered-entity-attr-value-projection-row! rows query projection entity projected-value)
        (delete-owned-value projected-value))
      (return true ""))))

(defn q-db-read-source-filtered-entity-attr-value-projection [source: DB-Read-Source, query: Query, projection: Entity-Attr-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [filter-stream filter-ok filter-error] (source-attr-value-match-stream source projection.filter-attr projection.filter-value)
        [many many-ok many-error] (db-read-source-schema-cardinality-many? source projection.value-attr)]
    (when (not filter-ok)
      (return (result-set-error filter-error)))
    (when (not many-ok)
      (delete-source-attr-value-match-stream filter-stream)
      (return (result-set-error many-error)))
    (while filter-stream.has-current
      (let [filter-datom (source-attr-value-match-current filter-stream)
            [append-ok append-error] (append-db-read-source-filtered-projection-values! (addr rows) source query projection filter-datom.e many)]
        (when (not append-ok)
          (delete-source-attr-value-match-stream filter-stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error append-error))))
      (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr filter-stream))]
        (when (not advance-ok)
          (delete-source-attr-value-match-stream filter-stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error advance-error)))))
    (delete-source-attr-value-match-stream filter-stream)
    (result-set-ok rows)))

(defn q-db-read-source-attr-value-entity-projection [source: DB-Read-Source, projection: Source-Attr-Value-Entity-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)]
    (if (reverse-attr? projection.attr)
      (let [forward-attr (forward-attr-for-reverse projection.attr) :defer
            child-entity: u64 0
            child-ok false]
        (cond
          (= projection.value.kind .Entity)
            (do
              (set! child-entity projection.value.entity)
              (set! child-ok true))
          (= projection.value.kind .Int)
            (do
              (set! child-entity (u64 projection.value.int-value))
              (set! child-ok true))
          :else (do))
        (when child-ok
          (if (db-read-source-has-overlay? source)
            (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source child-entity forward-attr)]
              (when (not datoms-ok)
                (return (result-set-error datoms-error)))
              (defer (delete-owned-datoms datoms))
              (for [datom datoms]
                (when (= datom.v.kind .Entity)
                  (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.v.entity)])))
                    (append-entity-row! (addr rows) datom.v.entity)))))
            (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source child-entity forward-attr)]
              (when (not stream-ok)
                (return (result-set-error stream-error)))
              (while stream.has-current
                (when (= stream.current.v.kind .Entity)
                  (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity stream.current.v.entity)])))
                    (append-entity-row! (addr rows) stream.current.v.entity)))
                (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                  (when (not advance-ok)
                    (delete-source-index-datom-stream stream)
                    (delete-result-rows-owned-values rows)
                    (return (result-set-error advance-error)))))
              (delete-source-index-datom-stream stream)))))
      (if (db-read-source-has-overlay? source)
        (let [datoms (make [dynamic]Datom)
              [scan-ok scan-error] (db-read-source-append-attr-value-datoms! (addr datoms) source projection.attr projection.value)]
          (when (not scan-ok)
            (delete-owned-datoms datoms)
            (return (result-set-error scan-error)))
          (defer (delete-owned-datoms datoms))
          (for [datom datoms]
            (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.e)])))
              (append-entity-row! (addr rows) datom.e))))
        (let [[stream stream-ok stream-error] (source-attr-value-match-stream source projection.attr projection.value)]
          (when (not stream-ok)
            (return (result-set-error stream-error)))
          (while stream.has-current
            (let [datom (source-attr-value-match-current stream)]
              (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.e)])))
                (append-entity-row! (addr rows) datom.e)))
            (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
              (when (not advance-ok)
                (delete-source-attr-value-match-stream stream)
                (delete-result-rows-owned-values rows)
                (return (result-set-error advance-error)))))
          (delete-source-attr-value-match-stream stream))))
    (result-set-ok rows)))

(defn q-db-read-source-attr-input-entity-projection [source: DB-Read-Source, query: Query, inputs: []Query-Input, projection: Source-Attr-Input-Entity-Projection] -> Result-Set
  (let [[input input-found] (query-input-by-name query inputs projection.input-var)]
    (when (not input-found)
      (return (result-set-error "SQLite DB snapshot source could not bind scalar query input")))
  (let [[raw-input-value raw-input-ok raw-input-error] (db-read-source-query-input-scalar-value source input)]
    (when (not raw-input-ok)
      (return (result-set-error raw-input-error)))
    (let [rows (make [dynamic]Result-Row)
          [stream stream-ok stream-error] (source-attr-value-match-stream source projection.attr raw-input-value)]
      (when (not stream-ok)
        (return (result-set-error stream-error)))
      (while stream.has-current
        (let [datom (source-attr-value-match-current stream)]
          (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.e)])))
            (append-entity-row! (addr rows) datom.e)))
        (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
          (when (not advance-ok)
            (delete-source-attr-value-match-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-attr-value-match-stream stream)
      (result-set-ok rows)))))

(defn q-db-read-source-attr-value-projection [source: DB-Read-Source, projection: Source-Attr-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen (set.empty string)]
    (defer (delete seen))
    (if (reverse-attr? projection.attr)
      (let [forward-attr (forward-attr-for-reverse projection.attr) :defer]
        (if (db-read-source-has-overlay? source)
          (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source forward-attr)]
            (when (not datoms-ok)
              (return (result-set-error datoms-error)))
            (defer (delete-owned-datoms datoms))
            (for [datom datoms]
              (when (= datom.v.kind .Entity)
                (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.e)])))
                  (append-entity-row! (addr rows) datom.e)))))
          (let [[stream stream-ok stream-error] (source-index-datom-stream source forward-attr)]
            (when (not stream-ok)
              (return (result-set-error stream-error)))
            (while stream.has-current
              (when (= stream.current.v.kind .Entity)
                (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity stream.current.e)])))
                  (append-entity-row! (addr rows) stream.current.e)))
              (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                (when (not advance-ok)
                  (delete-source-index-datom-stream stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error advance-error)))))
            (delete-source-index-datom-stream stream))))
      (if (db-read-source-has-overlay? source)
        (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source projection.attr)]
          (when (not datoms-ok)
            (return (result-set-error datoms-error)))
          (defer (delete-owned-datoms datoms))
          (for [datom datoms]
            (append-distinct-single-value-row-if-new! (addr rows) (addr seen) datom.v)))
        (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.attr)]
          (when (not stream-ok)
            (return (result-set-error stream-error)))
          (while stream.has-current
            (append-distinct-single-value-row-if-new! (addr rows) (addr seen) stream.current.v)
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream stream)
                (delete-result-rows-owned-values rows)
                (return (result-set-error advance-error)))))
          (delete-source-index-datom-stream stream))))
    (result-set-ok rows)))

(defn q-db-read-source-attr-filtered-value-projection [source: DB-Read-Source, projection: Source-Attr-Filtered-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen (set.empty string)
        [stream stream-ok stream-error] (source-attr-value-match-stream source projection.attr projection.value)]
    (defer (delete seen))
    (when (not stream-ok)
      (return (result-set-error stream-error)))
    (while stream.has-current
      (let [datom (source-attr-value-match-current stream)]
        (append-distinct-single-value-row-if-new! (addr rows) (addr seen) datom.v))
      (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-attr-value-match-stream stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error advance-error)))))
    (delete-source-attr-value-match-stream stream)
    (result-set-ok rows)))

(defn db-read-source-attr-range-index-bounds [source: DB-Read-Source, projection: Source-Attr-Range-Value-Projection] -> [view: DB-Index-View, low: int, high: int, ok: bool, error: string]
  (let [range-view (db-read-source-index-view source .AVET)
        attr-values ([]Value [(value-keyword projection.attr)])
        bound-values ([]Value [(value-keyword projection.attr) projection.value])
        [attr-low attr-low-ok attr-low-error] (db-read-source-lower-bound-values source range-view attr-values)]
    (when (not attr-low-ok)
      (return range-view 0 0 false attr-low-error))
    (let [[attr-high attr-high-ok attr-high-error] (db-read-source-upper-bound-values source range-view attr-values)]
      (when (not attr-high-ok)
        (return range-view 0 0 false attr-high-error))
      (let [[bound-low bound-low-ok bound-low-error] (db-read-source-lower-bound-values source range-view bound-values)]
        (when (not bound-low-ok)
          (return range-view 0 0 false bound-low-error))
        (let [[bound-high bound-high-ok bound-high-error] (db-read-source-upper-bound-values source range-view bound-values)]
          (when (not bound-high-ok)
            (return range-view 0 0 false bound-high-error))
          (cond
            (= projection.op ">") (return range-view bound-high attr-high true "")
            (= projection.op ">=") (return range-view bound-low attr-high true "")
            (= projection.op "<") (return range-view attr-low bound-low true "")
            (= projection.op "<=") (return range-view attr-low bound-high true "")
            :else (return range-view 0 0 false "unsupported range predicate")))))))

(defn append-db-read-source-range-value-row-if-new! [rows: ^[dynamic]Result-Row, seen: (ptr (map string (struct {}))), projection: Source-Attr-Range-Value-Projection, datom: Datom]
  (when (and (= datom.a projection.attr)
             (predicate-pair-matches? projection.op datom.v projection.value))
    (append-distinct-single-value-row-if-new! rows seen datom.v)))

(defn q-db-read-source-attr-range-value-projection [source: DB-Read-Source, projection: Source-Attr-Range-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen (set.empty string)]
    (defer (delete seen))
    (let [[stream stream-ok stream-error] (source-index-datom-stream-for-attr-range source projection)]
      (when (not stream-ok)
        (delete-result-rows-owned-values rows)
        (return (result-set-error stream-error)))
      (while stream.has-current
        (append-db-read-source-range-value-row-if-new! (addr rows) (addr seen) projection stream.current)
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-index-datom-stream stream))
    (result-set-ok rows)))

(defn append-source-entity-column-if-new! [out: ^[dynamic]u64, seen: (ptr (map u64 (struct {}))), entity: u64]
  (when (not (set.contains? seen^ entity))
    (set.add! seen^ entity)
    (arr.push! out^ entity)))

(defn q-db-read-source-entity-column [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [entities: [dynamic]u64, ok: bool, error: string]
  (let [out (make [dynamic]u64)
        seen (set.empty u64)]
    (defer (delete seen))
    (let [[projection projection-ok] (db-read-source-query-attr-value-entity-projection query)]
      (when projection-ok
        (if (db-read-source-has-overlay? source)
          (let [datoms (make [dynamic]Datom)
                [scan-ok scan-error] (db-read-source-append-attr-value-datoms! (addr datoms) source projection.attr projection.value)]
            (when (not scan-ok)
              (delete-owned-datoms datoms)
              (return out false scan-error))
            (for [datom datoms]
              (append-source-entity-column-if-new! (addr out) (addr seen) datom.e))
            (delete-owned-datoms datoms))
          (let [[stream stream-ok stream-error] (source-attr-value-match-stream source projection.attr projection.value)]
            (when (not stream-ok)
              (return out false stream-error))
            (while stream.has-current
              (let [datom (source-attr-value-match-current stream)]
                (append-source-entity-column-if-new! (addr out) (addr seen) datom.e))
              (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
                (when (not advance-ok)
                  (delete-source-attr-value-match-stream stream)
                  (return out false advance-error))))
            (delete-source-attr-value-match-stream stream)))
        (return out true "")))
    (let [[input-projection input-projection-ok] (db-read-source-query-attr-input-entity-projection query)]
      (when input-projection-ok
        (let [[input input-found] (query-input-by-name query inputs input-projection.input-var)]
          (when (not input-found)
            (return out false "SQLite DB snapshot source could not bind scalar query input"))
          (let [[raw-input-value raw-input-ok raw-input-error] (db-read-source-query-input-scalar-value source input)]
            (when (not raw-input-ok)
              (return out false raw-input-error))
            (let [[stream stream-ok stream-error] (source-attr-value-match-stream source input-projection.attr raw-input-value)]
              (when (not stream-ok)
                (return out false stream-error))
              (while stream.has-current
                (let [datom (source-attr-value-match-current stream)]
                  (append-source-entity-column-if-new! (addr out) (addr seen) datom.e))
                (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
                  (when (not advance-ok)
                    (delete-source-attr-value-match-stream stream)
                    (return out false advance-error))))
              (delete-source-attr-value-match-stream stream)
              (return out true ""))))))
    (return out false "")))

(defn source-text-column-append-if-new! [out: ^[dynamic]string, seen: (ptr (map string (struct {}))), value: Value] -> [ok: bool, type-ok: bool]
  (when (not (or (= value.kind .String)
                 (= value.kind .Keyword)
                 (= value.kind .Symbol)
                 (= value.kind .Uuid)))
    (return true false))
  (let [[key key-ok] (primitive-value-dedupe-key value)]
    (when (not key-ok)
      (return true false))
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (arr.push! out^ (string-owned value.text)))
    (return true true)))

(defn source-int-column-append-if-new! [out: ^[dynamic]i64, seen: (ptr (map string (struct {}))), value: Value] -> [ok: bool, type-ok: bool]
  (when (not (= value.kind .Int))
    (return true false))
  (let [[key key-ok] (primitive-value-dedupe-key value)]
    (when (not key-ok)
      (return true false))
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (arr.push! out^ value.int-value))
    (return true true)))

(defn delete-string-column-values [values: [dynamic]string]
  (for [value values]
    (delete value))
  (delete values))

(defenum Source-Scalar-Column-Kind [
  Int
  String
])

(defstruct Source-Scalar-Column {
  kind: Source-Scalar-Column-Kind
  ints: [dynamic]i64
  strings: [dynamic]string
})

(defn empty-source-scalar-column [kind: Source-Scalar-Column-Kind] -> Source-Scalar-Column
  (Source-Scalar-Column {kind: kind
                         ints: (make [dynamic]i64)
                         strings: (make [dynamic]string)}))

(defn delete-source-scalar-column [column: Source-Scalar-Column]
  (delete column.ints)
  (delete-string-column-values column.strings))

(defn source-scalar-column-take-ints [column: Source-Scalar-Column] -> [dynamic]i64
  (delete-string-column-values column.strings)
  column.ints)

(defn source-scalar-column-take-strings [column: Source-Scalar-Column] -> [dynamic]string
  (delete column.ints)
  column.strings)

(defn source-scalar-column-append-if-new! [column: ^Source-Scalar-Column, seen: (ptr (map string (struct {}))), value: Value] -> [ok: bool, type-ok: bool]
  (if (= column^.kind .Int)
    (source-int-column-append-if-new! (addr column^.ints) seen value)
    (source-text-column-append-if-new! (addr column^.strings) seen value)))

(defn q-db-read-source-scalar-column-for-attr-value-projection [source: DB-Read-Source, projection: Source-Attr-Value-Projection, kind: Source-Scalar-Column-Kind] -> [column: Source-Scalar-Column, ok: bool, error: string]
  (let [out (empty-source-scalar-column kind)
        seen (set.empty string)]
    (defer (delete seen))
    (when (reverse-attr? projection.attr)
      (return out false ""))
    (if (db-read-source-has-overlay? source)
      (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source projection.attr)]
        (when (not datoms-ok)
          (delete-source-scalar-column out)
          (return (empty-source-scalar-column kind) false datoms-error))
        (for [datom datoms]
          (let [[_ type-ok] (source-scalar-column-append-if-new! (addr out) (addr seen) datom.v)]
            (when (not type-ok)
              (delete-owned-datoms datoms)
              (delete-source-scalar-column out)
              (return (empty-source-scalar-column kind) false ""))))
        (delete-owned-datoms datoms))
      (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.attr)]
        (when (not stream-ok)
          (delete-source-scalar-column out)
          (return (empty-source-scalar-column kind) false stream-error))
        (while stream.has-current
          (let [[_ type-ok] (source-scalar-column-append-if-new! (addr out) (addr seen) stream.current.v)]
            (when (not type-ok)
              (delete-source-index-datom-stream stream)
              (delete-source-scalar-column out)
              (return (empty-source-scalar-column kind) false "")))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (delete-source-scalar-column out)
              (return (empty-source-scalar-column kind) false advance-error))))
        (delete-source-index-datom-stream stream)))
    (return out true "")))

(defn q-db-read-source-scalar-column-for-filtered-projection [source: DB-Read-Source, filtered: Source-Attr-Filtered-Value-Projection, kind: Source-Scalar-Column-Kind] -> [column: Source-Scalar-Column, ok: bool, error: string]
  (let [out (empty-source-scalar-column kind)
        seen (set.empty string)
        [stream stream-ok stream-error] (source-attr-value-match-stream source filtered.attr filtered.value)]
    (defer (delete seen))
    (when (not stream-ok)
      (delete-source-scalar-column out)
      (return (empty-source-scalar-column kind) false stream-error))
    (while stream.has-current
      (let [datom (source-attr-value-match-current stream)
            [_ type-ok] (source-scalar-column-append-if-new! (addr out) (addr seen) datom.v)]
        (when (not type-ok)
          (delete-source-attr-value-match-stream stream)
          (delete-source-scalar-column out)
          (return (empty-source-scalar-column kind) false "")))
      (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-attr-value-match-stream stream)
          (delete-source-scalar-column out)
          (return (empty-source-scalar-column kind) false advance-error))))
    (delete-source-attr-value-match-stream stream)
    (return out true "")))

(defn q-db-read-source-scalar-column-for-range-projection [source: DB-Read-Source, range: Source-Attr-Range-Value-Projection, kind: Source-Scalar-Column-Kind] -> [column: Source-Scalar-Column, ok: bool, error: string]
  (let [out (empty-source-scalar-column kind)
        seen (set.empty string)]
    (defer (delete seen))
    (let [[stream stream-ok stream-error] (source-index-datom-stream-for-attr-range source range)]
      (when (not stream-ok)
        (delete-source-scalar-column out)
        (return (empty-source-scalar-column kind) false stream-error))
      (while stream.has-current
        (when (and (= stream.current.a range.attr)
                   (predicate-pair-matches? range.op stream.current.v range.value))
          (let [[_ type-ok] (source-scalar-column-append-if-new! (addr out) (addr seen) stream.current.v)]
            (when (not type-ok)
              (delete-source-index-datom-stream stream)
              (delete-source-scalar-column out)
              (return (empty-source-scalar-column kind) false ""))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream stream)
            (delete-source-scalar-column out)
            (return (empty-source-scalar-column kind) false advance-error))))
      (delete-source-index-datom-stream stream))
    (return out true "")))

(defn q-db-read-source-scalar-column [source: DB-Read-Source, query: Query, inputs: []Query-Input, kind: Source-Scalar-Column-Kind] -> [column: Source-Scalar-Column, ok: bool, error: string]
  (when (> (count inputs) 0)
    (return (empty-source-scalar-column kind) false ""))
  (let [[projection projection-ok] (db-read-source-query-attr-value-projection query)]
    (when projection-ok
      (return (q-db-read-source-scalar-column-for-attr-value-projection source projection kind))))
  (let [[filtered filtered-ok] (db-read-source-query-attr-filtered-value-projection query)]
    (when filtered-ok
      (return (q-db-read-source-scalar-column-for-filtered-projection source filtered kind))))
  (let [[range range-ok] (db-read-source-query-attr-range-value-projection query)]
    (when range-ok
      (return (q-db-read-source-scalar-column-for-range-projection source range kind))))
  (return (empty-source-scalar-column kind) false ""))

(defn q-db-read-source-int-column-for-attr-value-projection [source: DB-Read-Source, projection: Source-Attr-Value-Projection] -> [values: [dynamic]i64, ok: bool, error: string]
  (let [[column column-ok column-error] (q-db-read-source-scalar-column-for-attr-value-projection source projection .Int)]
    (if column-ok
      (return (source-scalar-column-take-ints column) true "")
      (do
        (delete-source-scalar-column column)
        (return (make [dynamic]i64) false column-error)))))

(defn q-db-read-source-int-column [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [values: [dynamic]i64, ok: bool, error: string]
  (let [[column column-ok column-error] (q-db-read-source-scalar-column source query inputs .Int)]
    (if column-ok
      (return (source-scalar-column-take-ints column) true "")
      (do
        (delete-source-scalar-column column)
        (return (make [dynamic]i64) false column-error)))))

(defn q-db-read-source-string-column-for-attr-value-projection [source: DB-Read-Source, projection: Source-Attr-Value-Projection] -> [values: [dynamic]string, ok: bool, error: string]
  (let [[column column-ok column-error] (q-db-read-source-scalar-column-for-attr-value-projection source projection .String)]
    (if column-ok
      (return (source-scalar-column-take-strings column) true "")
      (do
        (delete-source-scalar-column column)
        (return (make [dynamic]string) false column-error)))))

(defn q-db-read-source-string-column [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [values: [dynamic]string, ok: bool, error: string]
  (let [[column column-ok column-error] (q-db-read-source-scalar-column source query inputs .String)]
    (if column-ok
      (return (source-scalar-column-take-strings column) true "")
      (do
        (delete-source-scalar-column column)
        (return (make [dynamic]string) false column-error)))))

(defn source-entity-int-pair-dedupe-key [entity: u64, value: i64] -> string
  (fmt.tprintf "e:%d/i:%d" entity value))

(defn source-entity-string-pair-dedupe-key [entity: u64, text: string] -> string
  (fmt.tprintf "e:%d/s:%s" entity text))

(defn source-entity-string-int-triple-dedupe-key [entity: u64, text: string, value: i64] -> string
  (fmt.tprintf "e:%d/s:%s/i:%d" entity text value))

(defn source-string-int-pair-dedupe-key [text: string, value: i64] -> string
  (fmt.tprintf "s:%s/i:%d" text value))

(defn source-string-string-pair-dedupe-key [first: string, second: string] -> string
  (fmt.tprintf "s1:%s/s2:%s" first second))

(defn source-entity-string-pair-append-if-new! [columns: ^Entity-String-Pair-Columns, seen: (ptr (map string (struct {}))), entity: u64, value: Value] -> bool
  (when (not (= value.kind .String))
    (return false))
  (let [key (source-entity-string-pair-dedupe-key entity value.text)]
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (append-owned-entity-string-pair-column! columns entity value.text))
    true))

(defn source-entity-string-int-triple-append-if-new! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), entity: u64, text-value: Value, int-value: Value] -> bool
  (when (not (and (= text-value.kind .String)
                  (= int-value.kind .Int)))
    (return false))
  (let [key (source-entity-string-int-triple-dedupe-key entity text-value.text int-value.int-value)]
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (append-owned-entity-string-int-triple! columns entity text-value.text int-value.int-value))
    true))

(defn source-string-int-pair-append-if-new! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), text-value: Value, int-value: Value] -> bool
  (when (not (and (= text-value.kind .String)
                  (= int-value.kind .Int)))
    (return false))
  (let [key (source-string-int-pair-dedupe-key text-value.text int-value.int-value)]
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (append-owned-entity-string-int-triple! columns 0 text-value.text int-value.int-value))
    true))

(defn source-string-string-pair-append-if-new! [columns: ^String-String-Pair-Columns, seen: (ptr (map string (struct {}))), first-value: Value, second-value: Value] -> bool
  (when (not (and (= first-value.kind .String)
                  (= second-value.kind .String)))
    (return false))
  (let [key (source-string-string-pair-dedupe-key first-value.text second-value.text)]
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (append-owned-string-string-pair-column! columns first-value.text second-value.text))
    true))

(defn source-entity-int-pair-append-if-new! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), entity: u64, value: Value] -> bool
  (when (not (= value.kind .Int))
    (return false))
  (let [key (source-entity-int-pair-dedupe-key entity value.int-value)]
    (when (not (set.contains? seen^ key))
      (set.add! seen^ key)
      (append-entity-int-pair-column! columns entity value.int-value))
    true))

(defn source-entity-int-pair-append-values-for-entity! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, entity: u64, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (if many
    (if (db-read-source-has-overlay? source)
      (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity value-attr)]
        (when (not datoms-ok)
          (return false false datoms-error))
        (for [datom datoms]
          (when (not (source-entity-int-pair-append-if-new! columns seen entity datom.v))
            (delete-owned-datoms datoms)
            (return true false "")))
        (delete-owned-datoms datoms)
        (return true true ""))
      (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity value-attr)]
        (when (not stream-ok)
          (return false false stream-error))
        (while stream.has-current
          (when (not (source-entity-int-pair-append-if-new! columns seen entity stream.current.v))
            (delete-source-index-datom-stream stream)
            (return true false ""))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false false advance-error))))
        (delete-source-index-datom-stream stream)
        (return true true "")))
    (let [[value value-ok value-error] (db-read-source-cardinality-one-value-fast-all-current source entity value-attr)]
      (when (not (= value-error ""))
        (return false false value-error))
      (when value-ok
        (let [type-ok (source-entity-int-pair-append-if-new! columns seen entity value)]
          (delete-owned-value value)
          (when (not type-ok)
            (return true false ""))))
      (return true true ""))))

(defn source-entity-int-pair-append-filter-datom! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, filter-datom: Datom, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (source-entity-int-pair-append-values-for-entity! columns seen source filter-datom.e value-attr many))

(defn source-entity-int-pair-append-filter-datoms! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, datoms: []Datom, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (for [datom datoms]
    (let [[append-ok type-ok append-error] (source-entity-int-pair-append-filter-datom! columns seen source datom value-attr many)]
      (when (not append-ok)
        (return false false append-error))
      (when (not type-ok)
        (return true false ""))))
  (return true true ""))

(defn source-entity-string-pair-append-values-for-entity! [columns: ^Entity-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, entity: u64, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (if many
    (if (db-read-source-has-overlay? source)
      (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity value-attr)]
        (when (not datoms-ok)
          (return false false datoms-error))
        (for [datom datoms]
          (when (not (source-entity-string-pair-append-if-new! columns seen entity datom.v))
            (delete-owned-datoms datoms)
            (return true false "")))
        (delete-owned-datoms datoms)
        (return true true ""))
      (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity value-attr)]
        (when (not stream-ok)
          (return false false stream-error))
        (while stream.has-current
          (when (not (source-entity-string-pair-append-if-new! columns seen entity stream.current.v))
            (delete-source-index-datom-stream stream)
            (return true false ""))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false false advance-error))))
        (delete-source-index-datom-stream stream)
        (return true true "")))
    (let [[value value-ok value-error] (db-read-source-cardinality-one-value-fast-all-current source entity value-attr)]
      (when (not (= value-error ""))
        (return false false value-error))
      (when value-ok
        (let [type-ok (source-entity-string-pair-append-if-new! columns seen entity value)]
          (delete-owned-value value)
          (when (not type-ok)
            (return true false ""))))
      (return true true ""))))

(defn source-entity-string-pair-append-filter-datom! [columns: ^Entity-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, filter-datom: Datom, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (source-entity-string-pair-append-values-for-entity! columns seen source filter-datom.e value-attr many))

(defn source-entity-string-pair-append-filter-datoms! [columns: ^Entity-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, datoms: []Datom, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (for [datom datoms]
    (let [[append-ok type-ok append-error] (source-entity-string-pair-append-filter-datom! columns seen source datom value-attr many)]
      (when (not append-ok)
        (return false false append-error))
      (when (not type-ok)
        (return true false ""))))
  (return true true ""))

(defn source-entity-int-pair-append-range-datom! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), projection: Source-Attr-Range-Value-Projection, datom: Datom] -> [matched: bool, type-ok: bool]
  (when (not (and (= datom.a projection.attr)
                  (predicate-pair-matches? projection.op datom.v projection.value)))
    (return false true))
  (return true (source-entity-int-pair-append-if-new! columns seen datom.e datom.v)))

(defn source-entity-string-int-triple-append-values-for-entity! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, entity: u64, first-attr: string, second-attr: string] -> [ok: bool, type-ok: bool, error: string]
  (let [[first-value first-ok first-error] (db-read-source-cardinality-one-value-fast-all-current source entity first-attr)]
    (when (not (= first-error ""))
      (return false false first-error))
    (when first-ok
      (let [[second-value second-ok second-error] (db-read-source-cardinality-one-value-fast-all-current source entity second-attr)]
        (when (not (= second-error ""))
          (delete-owned-value first-value)
          (return false false second-error))
        (when second-ok
          (let [type-ok (source-entity-string-int-triple-append-if-new! columns seen entity first-value second-value)]
            (delete-owned-value second-value)
            (delete-owned-value first-value)
            (when (not type-ok)
              (return true false ""))))
        (when (not second-ok)
          (delete-owned-value second-value)
          (delete-owned-value first-value))))
    (when (not first-ok)
      (delete-owned-value first-value)))
  (return true true ""))

(defn source-string-int-pair-append-values-for-entity! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, entity: u64, first-attr: string, second-attr: string] -> [ok: bool, type-ok: bool, error: string]
  (let [[first-value first-ok first-error] (db-read-source-cardinality-one-value-fast-all-current source entity first-attr)]
    (when (not (= first-error ""))
      (return false false first-error))
    (when first-ok
      (let [[second-value second-ok second-error] (db-read-source-cardinality-one-value-fast-all-current source entity second-attr)]
        (when (not (= second-error ""))
          (delete-owned-value first-value)
          (return false false second-error))
        (when second-ok
          (let [type-ok (source-string-int-pair-append-if-new! columns seen first-value second-value)]
            (delete-owned-value second-value)
            (delete-owned-value first-value)
            (when (not type-ok)
              (return true false ""))))
        (when (not second-ok)
          (delete-owned-value second-value)
          (delete-owned-value first-value))))
    (when (not first-ok)
      (delete-owned-value first-value)))
  (return true true ""))

(defn source-string-string-pair-append-values-for-entity! [columns: ^String-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, entity: u64, first-attr: string, second-attr: string] -> [ok: bool, type-ok: bool, error: string]
  (let [[first-value first-ok first-error] (db-read-source-cardinality-one-value-fast-all-current source entity first-attr)]
    (when (not (= first-error ""))
      (return false false first-error))
    (when first-ok
      (let [[second-value second-ok second-error] (db-read-source-cardinality-one-value-fast-all-current source entity second-attr)]
        (when (not (= second-error ""))
          (delete-owned-value first-value)
          (return false false second-error))
        (when second-ok
          (let [type-ok (source-string-string-pair-append-if-new! columns seen first-value second-value)]
            (delete-owned-value second-value)
            (delete-owned-value first-value)
            (when (not type-ok)
              (return true false ""))))
        (when (not second-ok)
          (delete-owned-value second-value)
          (delete-owned-value first-value))))
    (when (not first-ok)
      (delete-owned-value first-value)))
  (return true true ""))

(defn source-entity-string-int-triple-append-filter-datom! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, filter-datom: Datom, plan: Entity-Two-Value-Plan, best-filter-index: int] -> [ok: bool, type-ok: bool, error: string]
  (let [[filters-match filters-ok filters-error] (db-read-source-entity-two-value-plan-filters-match? source filter-datom.e plan best-filter-index)]
    (when (not filters-ok)
      (return false false filters-error))
    (when filters-match
      (return (source-entity-string-int-triple-append-values-for-entity! columns seen source filter-datom.e plan.first-attr plan.second-attr))))
  (return true true ""))

(defn source-entity-string-int-triple-append-driver-datom! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, driver-datom: Datom, plan: Entity-Two-Value-Plan] -> [ok: bool, type-ok: bool, error: string]
  (let [[filters-match filters-ok filters-error] (db-read-source-entity-two-value-plan-filters-match? source driver-datom.e plan -1)]
    (when (not filters-ok)
      (return false false filters-error))
    (when filters-match
      (return (source-string-int-pair-append-values-for-entity! columns seen source driver-datom.e plan.first-attr plan.second-attr))))
  (return true true ""))

(defn source-string-string-pair-append-driver-datom! [columns: ^String-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, driver-datom: Datom, plan: Entity-Two-Value-Plan] -> [ok: bool, type-ok: bool, error: string]
  (let [[filters-match filters-ok filters-error] (db-read-source-entity-two-value-plan-filters-match? source driver-datom.e plan -1)]
