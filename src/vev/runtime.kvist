              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (not (= clause-value.v.kind .Var))
              (not (db-read-source-query-has-one-scalar-input? query clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-attr-input-entity-projection) false))
    (return (Source-Attr-Input-Entity-Projection {entity-var: clause-value.e.name
                                                  attr: clause-value.a.value.text
                                                  input-var: clause-value.v.name})
