              (return out false append-error))
            (when (not type-ok)
              (delete-source-attr-value-match-stream stream)
              (delete plan.filters)
              (return out false "")))
          (delete-source-attr-value-match-stream stream)))
      (delete plan.filters)
      (return out true ""))))

