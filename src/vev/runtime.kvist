      (return (query-relation-empty) false anchor-value-error))
    (let [anchor-entities (set.empty u64) :defer
          anchor-entity-list (make [dynamic]u64) :defer
          first-entities (set.empty u64) :defer
          first-entity-list (make [dynamic]u64) :defer
          hop1-entities (set.empty u64) :defer
          hop1-entity-list (make [dynamic]u64) :defer
          hop2-entities (set.empty u64) :defer
          hop2-entity-list (make [dynamic]u64) :defer
          final-entities (set.empty u64) :defer
          final-entity-list (make [dynamic]u64) :defer
          first-value-heads (make (map u64 int)) :defer
          first-value-links (make [dynamic]Source-Multi-Hop-Ref-Chain-Link)
          hop1-heads (make (map u64 int)) :defer
          hop1-links (make [dynamic]Source-Multi-Hop-Ref-Chain-Link)
          hop2-heads (make (map u64 int)) :defer
          hop2-links (make [dynamic]Source-Multi-Hop-Ref-Chain-Link)
          final-heads (make (map u64 int)) :defer
          final-links (make [dynamic]Source-Multi-Hop-Ref-Chain-Link)]
      (defer (delete-source-multi-hop-ref-chain-links first-value-links))
      (defer (delete-source-multi-hop-ref-chain-links hop1-links))
      (defer (delete-source-multi-hop-ref-chain-links hop2-links))
      (defer (delete-source-multi-hop-ref-chain-links final-links))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false anchor-error))
        (query-stats-observe-source-operator! stats)
        (mut! stats^.source-index-scans += 1)
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)]
            (when (not (set.contains? anchor-entities anchor-datom.e))
              (set.add! anchor-entities anchor-datom.e)
              (arr.push! anchor-entity-list anchor-datom.e))
            (mut! stats^.clause-candidates += 1))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete attrs)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false anchor-advance-error))))
        (delete-source-attr-value-match-stream anchor-stream))
      (query-stats-observe-source-operator! stats)
      (arr.sort! anchor-entity-list)
      (let [[reverse-ok reverse-error reverse-scans reverse-candidates] (append-source-multi-hop-ref-chain-first-entities-from-frontier! source projection.reverse-ref-attr (slice anchor-entity-list 0) (addr first-entities) (addr first-entity-list))]
        (when (not reverse-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false reverse-error))
        (mut! stats^.source-index-scans += reverse-scans)
        (mut! stats^.clause-candidates += reverse-candidates))
      (arr.sort! first-entity-list)
      (let [[first-value-ok first-value-error first-value-scans first-value-candidates] (append-source-multi-hop-ref-chain-first-value-links-from-frontier! source projection.first-value-attr (slice first-entity-list 0) (addr first-value-heads) (addr first-value-links))]
        (when (not first-value-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false first-value-error))
        (query-stats-observe-source-operator! stats)
        (mut! stats^.source-index-scans += first-value-scans)
        (mut! stats^.clause-candidates += first-value-candidates))
      (let [[hop1-ok hop1-error hop1-scans hop1-candidates] (append-source-multi-hop-ref-chain-reverse-propagated-links-from-frontier! source projection.hop1-attr (slice first-entity-list 0) (addr first-value-heads) (slice first-value-links 0) (addr hop1-entities) (addr hop1-entity-list) (addr hop1-heads) (addr hop1-links))]
        (when (not hop1-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false hop1-error))
        (query-stats-observe-source-operator! stats)
        (mut! stats^.source-index-scans += hop1-scans)
        (mut! stats^.clause-candidates += hop1-candidates))
      (arr.sort! hop1-entity-list)
      (let [[hop2-ok hop2-error hop2-scans hop2-candidates] (append-source-multi-hop-ref-chain-reverse-propagated-links-from-frontier! source projection.hop2-attr (slice hop1-entity-list 0) (addr hop1-heads) (slice hop1-links 0) (addr hop2-entities) (addr hop2-entity-list) (addr hop2-heads) (addr hop2-links))]
        (when (not hop2-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false hop2-error))
        (query-stats-observe-source-operator! stats)
        (mut! stats^.source-index-scans += hop2-scans)
        (mut! stats^.clause-candidates += hop2-candidates))
      (query-stats-observe-source-operator! stats)
      (arr.sort! hop2-entity-list)
      (let [[final-ok final-error final-scans final-candidates] (append-source-multi-hop-ref-chain-value-links-from-frontier! source projection.final-value-attr (slice hop2-entity-list 0) (addr hop2-heads) (slice hop2-links 0) (addr final-entities) (addr final-entity-list) (addr final-heads) (addr final-links))]
        (when (not final-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false final-error))
        (mut! stats^.source-index-scans += final-scans)
        (mut! stats^.clause-candidates += final-candidates))
      (query-stats-observe-source-operator! stats)
      (arr.sort! final-entity-list)
      (let [[second-ok second-error second-scans second-candidates] (append-source-multi-hop-ref-chain-two-final-value-rows-from-frontier! source projection.filter-attr (slice final-entity-list 0) (addr final-heads) (slice final-links 0) (addr builder) (addr seen) query projection)]
        (when (not second-ok)
          (delete attrs)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false second-error))
        (mut! stats^.source-index-scans += second-scans)
        (mut! stats^.clause-candidates += second-candidates))
      (mut! stats^.clauses += 7)
      (return (source-query-relation-from-multi-hop-builder attrs builder) true ""))))

(defn q-db-read-source-multi-hop-ref-chain-projection [source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, inputs: []Query-Input] -> Result-Set
  (when (not (db-read-source-has-overlay? source))
    (return (q-db-read-source-multi-hop-ref-chain-projection-batched source query projection inputs)))
  (let [rows (make [dynamic]Result-Row)
        [anchor-value anchor-value-ok anchor-value-error] (db-read-source-multi-hop-ref-chain-anchor-value source projection inputs)]
    (when (not anchor-value-ok)
      (return (result-set-error anchor-value-error)))
    (if (db-read-source-has-overlay? source)
      (let [anchor-datoms (make [dynamic]Datom)
            [anchor-ok anchor-error] (db-read-source-append-attr-value-datoms! (addr anchor-datoms) source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (delete-owned-datoms anchor-datoms)
          (return (result-set-error anchor-error)))
        (defer (delete-owned-datoms anchor-datoms))
        (for [anchor-datom anchor-datoms]
          (let [[ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.reverse-ref-attr)]
            (when (not ref-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-first-entity-rows! (addr rows) source query projection ref-stream.current.e)]
                (when (not append-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error append-error))))
              (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not load-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error load-error))))))))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (return (result-set-error anchor-error)))
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)
                [ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.reverse-ref-attr)]
            (when (not ref-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-first-entity-rows! (addr rows) source query projection ref-stream.current.e)]
                (when (not append-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error append-error))))
              (let [[ref-advance-ok ref-advance-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not ref-advance-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error ref-advance-error)))))
            (delete-source-index-datom-stream ref-stream))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error anchor-advance-error)))))
        (delete-source-attr-value-match-stream anchor-stream)))
    (result-set-ok rows)))

(defstruct Source-Anchor-Direct-Entity-Value {
  entity: u64
  value: Value
  next: int
})

(defn delete-source-anchor-direct-entity-values [items: [dynamic]Source-Anchor-Direct-Entity-Value]
  (for [item items]
    (delete-owned-value item.value))
  (delete items))

(defn db-read-source-anchor-two-branch-anchor-value [source: DB-Read-Source, projection: Source-Anchor-Two-Branch-Join-Projection, inputs: []Query-Input] -> [value: Value, ok: bool, error: string]
  (when (not projection.has-anchor-input)
    (return projection.anchor-value true ""))
  (when (not (= (count inputs) 1))
    (return (Value {}) false "wrong number of query inputs for source anchor/two-branch projection"))
  (db-read-source-query-input-scalar-value source inputs[0]))

(defn source-anchor-two-branch-value-for-var [projection: Source-Anchor-Two-Branch-Join-Projection, name: string, direct-value: Value, first-value: Value, filter-value: Value] -> Value
  (cond
    (= name projection.direct-value-var) direct-value
    (= name projection.first-value-var) first-value
    :else filter-value))

(defn append-db-read-source-anchor-two-branch-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, direct-value: Value, first-value: Value, filter-value: Value]
  (let [out-first (source-anchor-two-branch-value-for-var projection query.find[0] direct-value first-value filter-value)
        out-second (source-anchor-two-branch-value-for-var projection query.find[1] direct-value first-value filter-value)
        out-third (source-anchor-two-branch-value-for-var projection query.find[2] direct-value first-value filter-value)
        dedupe-values ([]Value [out-first out-second out-third])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-three-value-row! rows (value-owned out-first) (value-owned out-second) (value-owned out-third)))))

(defn db-read-source-anchor-two-branch-direct-entities [source: DB-Read-Source, projection: Source-Anchor-Two-Branch-Join-Projection, anchor-entity: u64] -> [items: [dynamic]Source-Anchor-Direct-Entity-Value, ok: bool, error: string]
  (let [out (make [dynamic]Source-Anchor-Direct-Entity-Value)
        [direct-stream direct-ok direct-error] (source-vaet-entity-attr-stream source anchor-entity projection.direct-ref-attr)]
    (when (not direct-ok)
      (return out false direct-error))
    (while direct-stream.has-current
      (let [[value-stream value-ok value-error] (source-eavt-entity-attr-stream source direct-stream.current.e projection.direct-value-attr)]
        (when (not value-ok)
          (delete-source-index-datom-stream direct-stream)
          (delete-source-anchor-direct-entity-values out)
          (return (make [dynamic]Source-Anchor-Direct-Entity-Value) false value-error))
        (while value-stream.has-current
          (arr.push! out (Source-Anchor-Direct-Entity-Value {entity: direct-stream.current.e value: (value-owned value-stream.current.v) next: -1}))
          (let [[value-load-ok value-load-error] (advance-source-index-datom-stream! source (addr value-stream))]
            (when (not value-load-ok)
              (delete-source-index-datom-stream value-stream)
              (delete-source-index-datom-stream direct-stream)
              (delete-source-anchor-direct-entity-values out)
              (return (make [dynamic]Source-Anchor-Direct-Entity-Value) false value-load-error)))))
      (let [[direct-load-ok direct-load-error] (advance-source-index-datom-stream! source (addr direct-stream))]
        (when (not direct-load-ok)
          (delete-source-index-datom-stream direct-stream)
          (delete-source-anchor-direct-entity-values out)
          (return (make [dynamic]Source-Anchor-Direct-Entity-Value) false direct-load-error))))
    (return out true "")))

(defn index-source-anchor-direct-entity-values! [items: ^[dynamic]Source-Anchor-Direct-Entity-Value] -> (map u64 int)
  (let [bucket-heads (make (map u64 int))]
    (for [item index items^]
      (let [[head found] (mmap.get bucket-heads item.entity)]
        (if found
          (set! items^[index].next head)
          (set! items^[index].next -1))
        (mmap.assoc! bucket-heads item.entity index)))
    bucket-heads))

(defn append-db-read-source-anchor-two-branch-final-join-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, direct-items: []Source-Anchor-Direct-Entity-Value, direct-entity-heads: (map u64 int), hop1-entity: u64, first-value: Value, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source hop1-entity projection.hop2-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[head found] (mmap.get direct-entity-heads stream.current.v.entity)]
          (when found
            (let [direct-index head]
              (while (>= direct-index 0)
                (append-db-read-source-anchor-two-branch-row! rows query projection direct-items[direct-index].value first-value filter-value)
                (set! direct-index direct-items[direct-index].next))))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-anchor-two-branch-hop-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, direct-items: []Source-Anchor-Direct-Entity-Value, direct-entity-heads: (map u64 int), first-entity: u64, first-value: Value, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.hop1-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[append-ok append-error] (append-db-read-source-anchor-two-branch-final-join-rows! rows source query projection direct-items direct-entity-heads stream.current.v.entity first-value filter-value)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return false append-error))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-anchor-two-branch-first-value-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, direct-items: []Source-Anchor-Direct-Entity-Value, direct-entity-heads: (map u64 int), first-entity: u64, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.first-value-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (let [[append-ok append-error] (append-db-read-source-anchor-two-branch-hop-rows! rows source query projection direct-items direct-entity-heads first-entity stream.current.v filter-value)]
        (when (not append-ok)
          (delete-source-index-datom-stream stream)
          (return false append-error)))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-anchor-two-branch-first-entity-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, direct-items: []Source-Anchor-Direct-Entity-Value, direct-entity-heads: (map u64 int), first-entity: u64] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.filter-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (and (= stream.current.a projection.filter-attr)
                 (predicate-pair-matches? projection.filter-op stream.current.v projection.filter-value))
        (let [[append-ok append-error] (append-db-read-source-anchor-two-branch-first-value-rows! rows source query projection direct-items direct-entity-heads first-entity stream.current.v)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return false append-error))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn q-db-read-source-anchor-two-branch-join-projection [source: DB-Read-Source, query: Query, projection: Source-Anchor-Two-Branch-Join-Projection, inputs: []Query-Input] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [anchor-value anchor-value-ok anchor-value-error] (db-read-source-anchor-two-branch-anchor-value source projection inputs)]
    (when (not anchor-value-ok)
      (delete-result-rows-owned-values rows)
      (return (result-set-error anchor-value-error)))
    (if (db-read-source-has-overlay? source)
      (let [anchor-datoms (make [dynamic]Datom)
            [anchor-ok anchor-error] (db-read-source-append-attr-value-datoms! (addr anchor-datoms) source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (delete-owned-datoms anchor-datoms)
          (return (result-set-error anchor-error)))
        (defer (delete-owned-datoms anchor-datoms))
        (for [anchor-datom anchor-datoms]
          (let [[direct-items direct-ok direct-error] (db-read-source-anchor-two-branch-direct-entities source projection anchor-datom.e)]
            (when (not direct-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error direct-error)))
            (let [direct-entity-heads (index-source-anchor-direct-entity-values! (addr direct-items)) :defer]
            (let [[first-stream first-ok first-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.first-ref-attr)]
              (when (not first-ok)
                (delete-source-anchor-direct-entity-values direct-items)
                (delete-result-rows-owned-values rows)
                (return (result-set-error first-error)))
              (while first-stream.has-current
                (let [[append-ok append-error] (append-db-read-source-anchor-two-branch-first-entity-rows! (addr rows) source query projection (slice direct-items 0) direct-entity-heads first-stream.current.e)]
                  (when (not append-ok)
                    (delete-source-index-datom-stream first-stream)
                    (delete-source-anchor-direct-entity-values direct-items)
                    (delete-result-rows-owned-values rows)
                    (return (result-set-error append-error))))
                (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr first-stream))]
                  (when (not load-ok)
                    (delete-source-index-datom-stream first-stream)
                    (delete-source-anchor-direct-entity-values direct-items)
                    (delete-result-rows-owned-values rows)
                    (return (result-set-error load-error)))))))
            (delete-source-anchor-direct-entity-values direct-items))))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (return (result-set-error anchor-error)))
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)
                [direct-items direct-ok direct-error] (db-read-source-anchor-two-branch-direct-entities source projection anchor-datom.e)]
            (when (not direct-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error direct-error)))
            (let [direct-entity-heads (index-source-anchor-direct-entity-values! (addr direct-items)) :defer]
            (let [[first-stream first-ok first-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.first-ref-attr)]
              (when (not first-ok)
                (delete-source-anchor-direct-entity-values direct-items)
                (delete-source-attr-value-match-stream anchor-stream)
                (delete-result-rows-owned-values rows)
                (return (result-set-error first-error)))
              (while first-stream.has-current
                (let [[append-ok append-error] (append-db-read-source-anchor-two-branch-first-entity-rows! (addr rows) source query projection (slice direct-items 0) direct-entity-heads first-stream.current.e)]
                  (when (not append-ok)
                    (delete-source-index-datom-stream first-stream)
                    (delete-source-anchor-direct-entity-values direct-items)
                    (delete-source-attr-value-match-stream anchor-stream)
                    (delete-result-rows-owned-values rows)
                    (return (result-set-error append-error))))
                (let [[first-advance-ok first-advance-error] (advance-source-index-datom-stream! source (addr first-stream))]
                  (when (not first-advance-ok)
                    (delete-source-index-datom-stream first-stream)
                    (delete-source-anchor-direct-entity-values direct-items)
                    (delete-source-attr-value-match-stream anchor-stream)
                    (delete-result-rows-owned-values rows)
                    (return (result-set-error first-advance-error)))))
              (delete-source-index-datom-stream first-stream)))
            (delete-source-anchor-direct-entity-values direct-items))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error anchor-advance-error)))))
        (delete-source-attr-value-match-stream anchor-stream)))
    (result-set-ok rows)))

(defn db-read-source-attr-range-entry-count [source: DB-Read-Source, attr: string] -> [entry-count: int, ok: bool, error: string]
  (let [values ([]Value [(value-keyword attr)])
        [_ low high range-ok range-error] (db-read-source-prefix-index-range source .AEVT values)]
    (if range-ok
      (return (- high low) true "")
      (return 0 false range-error))))

(defn db-read-source-attr-value-entry-count [source: DB-Read-Source, attr: string, value: Value] -> [entry-count: int, ok: bool, error: string]
  (let [values ([]Value [(value-keyword attr) value])
        [_ low high range-ok range-error] (db-read-source-prefix-index-range source .AVET values)]
    (if range-ok
      (return (- high low) true "")
      (return 0 false range-error))))

(defn db-read-source-two-attr-use-second-driver? [source: DB-Read-Source, projection: Two-Attr-Entity-Projection] -> bool
  (when (db-read-source-has-overlay? source)
    (return false))
  (let [[first-count first-ok _] (db-read-source-attr-range-entry-count source projection.first-attr)
        [second-count second-ok _] (db-read-source-attr-range-entry-count source projection.second-attr)]
    (and first-ok
         second-ok
         (< second-count first-count))))

(defn append-db-read-source-other-attr-projection-values! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, source: DB-Read-Source, query: Query, projection: Two-Attr-Entity-Projection, driver-datom: Datom, driver-is-first: bool, many: bool] -> [ok: bool, error: string]
  (let [lookup-attr (if driver-is-first projection.second-attr projection.first-attr)]
    (if many
      (if (db-read-source-has-overlay? source)
        (let [[lookup-datoms lookup-ok lookup-error] (db-read-source-datoms-by-entity-attr source driver-datom.e lookup-attr)]
          (when (not lookup-ok)
            (return false lookup-error))
          (for [lookup-datom lookup-datoms]
            (if driver-is-first
              (append-db-read-source-two-attr-projection-row! rows seen query projection driver-datom.v lookup-datom.v)
              (append-db-read-source-two-attr-projection-row! rows seen query projection lookup-datom.v driver-datom.v)))
          (delete-owned-datoms lookup-datoms)
          (return true ""))
        (let [[lookup-stream lookup-ok lookup-error] (source-eavt-entity-attr-stream source driver-datom.e lookup-attr)]
          (when (not lookup-ok)
            (return false lookup-error))
          (while lookup-stream.has-current
            (if driver-is-first
              (append-db-read-source-two-attr-projection-row! rows seen query projection driver-datom.v lookup-stream.current.v)
              (append-db-read-source-two-attr-projection-row! rows seen query projection lookup-stream.current.v driver-datom.v))
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr lookup-stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream lookup-stream)
                (return false advance-error))))
          (delete-source-index-datom-stream lookup-stream)
          (return true "")))
      (let [[lookup-value lookup-ok lookup-error] (db-read-source-cardinality-one-value-fast-all-current source driver-datom.e lookup-attr)]
        (when (not (= lookup-error ""))
          (return false lookup-error))
        (when lookup-ok
          (if driver-is-first
            (append-db-read-source-two-attr-projection-row! rows seen query projection driver-datom.v lookup-value)
            (append-db-read-source-two-attr-projection-row! rows seen query projection lookup-value driver-datom.v))
          (delete-owned-value lookup-value))
        (return true "")))))

(defstruct Source-Index-Datom-Stream {
  view: DB-Index-View
  owned-datoms: [dynamic]Datom
  owned-order-indexes: [dynamic]int
  use-owned-datoms: bool
  use-sqlite-run-ranges: bool
  run-roots: [dynamic]u64
  run-counts: [dynamic]int
  run-lows: [dynamic]int
  run-highs: [dynamic]int
  run-values: [dynamic]Value
  run-order-text: string
  run-check-values: bool
  run-index: int
  run-position: int
  run-page: [dynamic]int
  run-page-start: int
  run-page-end: int
  run-loaded-page: SQLite-Loaded-Index-Page
  run-loaded-page-valid: bool
  run-dedupe-entries: bool
  run-seen-entries: (map int (struct {}))
  use-sqlite-sparse-prefixes: bool
  sparse-roots: [dynamic]u64
  sparse-counts: [dynamic]int
  sparse-entities: [dynamic]u64
  sparse-attr: string
  sparse-order-text: string
  sparse-prefix-index: int
  sparse-run-index: int
  sparse-position: int
  sparse-high: int
  sparse-range-active: bool
  sparse-loaded-page: SQLite-Loaded-Index-Page
  sparse-loaded-page-valid: bool
  sparse-dedupe-entries: bool
  sparse-seen-entries: (map int (struct {}))
  index: int
  high: int
  current: Datom
  current-owned: bool
  has-current: bool
})

(defn delete-source-index-datom-streams [streams: [dynamic]Source-Index-Datom-Stream]
  (for [stream streams]
    (delete-source-index-datom-stream stream))
  (delete streams))

(defn delete-source-index-datom-stream [stream: Source-Index-Datom-Stream]
  (when stream.has-current
    (when stream.current-owned
      (delete-owned-datom stream.current)))
  (when stream.use-owned-datoms
    (delete stream.owned-order-indexes)
    (delete-owned-datoms stream.owned-datoms))
  (when stream.use-sqlite-run-ranges
    (delete stream.run-roots)
    (delete stream.run-counts)
    (delete stream.run-lows)
    (delete stream.run-highs)
    (delete-owned-values-array stream.run-values)
    (delete stream.run-seen-entries)
    (delete stream.run-page)
    (when stream.run-loaded-page-valid
      (release-sqlite-loaded-index-page! stream.run-loaded-page)))
  (when stream.use-sqlite-sparse-prefixes
    (delete stream.sparse-roots)
    (delete stream.sparse-counts)
    (delete stream.sparse-entities)
    (delete stream.sparse-seen-entries)
    (when stream.sparse-loaded-page-valid
      (release-sqlite-loaded-index-page! stream.sparse-loaded-page))))

(defn clear-source-index-datom-stream-current! [stream: ^Source-Index-Datom-Stream]
  (when stream^.has-current
    (when stream^.current-owned
      (delete-owned-datom stream^.current))
    (set! stream^.has-current false)
    (set! stream^.current-owned false)))

(defn set-source-index-datom-stream-current-owned! [stream: ^Source-Index-Datom-Stream, datom: Datom]
  (set! stream^.current datom)
  (set! stream^.current-owned true)
  (set! stream^.has-current true))

(defn set-source-index-datom-stream-current-borrowed! [stream: ^Source-Index-Datom-Stream, datom: Datom]
  (set! stream^.current datom)
  (set! stream^.current-owned false)
  (set! stream^.has-current true))

(defn values-owned-array [values: []Value] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count values))]
    (for [value values]
      (arr.push! out (value-owned value)))
    out))

(defn db-read-source-all-index-entries-current? [source: DB-Read-Source] -> bool
  (and (= source.kind .SQLite-Snapshot)
       (not source.sqlite-snapshot^.has-retractions)))

(defn load-source-index-datom-stream-current-from-sqlite-run-ranges! [source: DB-Read-Source, stream: ^Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (while (< stream^.run-index (count stream^.run-roots))
    (when (< stream^.run-position stream^.run-lows[stream^.run-index])
      (set! stream^.run-position stream^.run-lows[stream^.run-index]))
    (while (< stream^.run-position stream^.run-highs[stream^.run-index])
      (let [[entry offset entry-ok entry-error] (sqlite-index-root-ordered-entry-offset-at-retained-page-cache stream^.view.sqlite-cursor^.handle
                                                                                                             stream^.view.sqlite-cursor^.datom-stmt
                                                                                                             stream^.run-roots[stream^.run-index]
                                                                                                             stream^.run-position
                                                                                                             stream^.run-counts[stream^.run-index]
                                                                                                             stream^.view.sqlite-cursor^.page-size
                                                                                                             (addr stream^.view.sqlite-cursor^.page-cache)
                                                                                                             (addr stream^.run-loaded-page)
                                                                                                             (addr stream^.run-loaded-page-valid))]
        (when (not entry-ok)
          (return false entry-error))
        (let [datom stream^.run-loaded-page.datoms[offset]]
        (when stream^.run-dedupe-entries
          (when (set.contains? stream^.run-seen-entries entry)
            (set! stream^.run-position (+ stream^.run-position 1))
            (continue))
          (set.add! stream^.run-seen-entries entry))
        (let [current true
              current-ok true
              current-error ""]
          (when (not (db-read-source-all-index-entries-current? source))
            (let [[checked-current checked-ok checked-error] (db-read-source-datom-current-at-entry? source entry)]
              (set! current checked-current)
              (set! current-ok checked-ok)
              (set! current-error checked-error)))
          (when (not current-ok)
            (return false current-error))
          (when current
            (when (or (not stream^.run-check-values)
                      (datom-matches-index-values? datom stream^.run-order-text (slice stream^.run-values 0)))
              (set-source-index-datom-stream-current-borrowed! stream datom)
              (return true ""))))))
      (set! stream^.run-position (+ stream^.run-position 1)))
    (set! stream^.run-index (+ stream^.run-index 1))
    (set! stream^.run-position 0)
    (delete stream^.run-page)
    (set! stream^.run-page (make [dynamic]int))
    (set! stream^.run-page-start -1)
    (set! stream^.run-page-end -1)
    (when stream^.run-loaded-page-valid
      (release-sqlite-loaded-index-page! stream^.run-loaded-page)
      (set! stream^.run-loaded-page-valid false)))
  (return true ""))

(defn load-source-index-datom-stream-current-from-sqlite-sparse-prefixes! [source: DB-Read-Source, stream: ^Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (while (< stream^.sparse-prefix-index (count stream^.sparse-entities))
    (while (< stream^.sparse-run-index (count stream^.sparse-roots))
      (when (not stream^.sparse-range-active)
        (let [values ([]Value [(value-entity stream^.sparse-entities[stream^.sparse-prefix-index]) (value-keyword stream^.sparse-attr)])
              [low low-ok low-error] (sqlite-index-root-bound-values stream^.view.sqlite-cursor stream^.sparse-roots[stream^.sparse-run-index] stream^.sparse-counts[stream^.sparse-run-index] stream^.sparse-order-text values false)]
          (when (not low-ok)
            (return false low-error))
          (let [[high high-ok high-error] (sqlite-index-root-bound-values stream^.view.sqlite-cursor stream^.sparse-roots[stream^.sparse-run-index] stream^.sparse-counts[stream^.sparse-run-index] stream^.sparse-order-text values true)]
            (when (not high-ok)
              (return false high-error))
            (set! stream^.sparse-position low)
            (set! stream^.sparse-high high)
            (set! stream^.sparse-range-active true))))
      (while (< stream^.sparse-position stream^.sparse-high)
        (let [[entry offset entry-ok entry-error] (sqlite-index-root-ordered-entry-offset-at-retained-page-cache stream^.view.sqlite-cursor^.handle
                                                                                                                 stream^.view.sqlite-cursor^.datom-stmt
                                                                                                                 stream^.sparse-roots[stream^.sparse-run-index]
                                                                                                                 stream^.sparse-position
                                                                                                                 stream^.sparse-counts[stream^.sparse-run-index]
                                                                                                                 stream^.view.sqlite-cursor^.page-size
                                                                                                                 (addr stream^.view.sqlite-cursor^.page-cache)
                                                                                                                 (addr stream^.sparse-loaded-page)
                                                                                                                 (addr stream^.sparse-loaded-page-valid))]
          (when (not entry-ok)
            (return false entry-error))
          (let [datom stream^.sparse-loaded-page.datoms[offset]]
            (when stream^.sparse-dedupe-entries
              (when (set.contains? stream^.sparse-seen-entries entry)
                (set! stream^.sparse-position (+ stream^.sparse-position 1))
                (continue))
              (set.add! stream^.sparse-seen-entries entry))
            (let [current true
                  current-ok true
                  current-error ""]
              (when (not (db-read-source-all-index-entries-current? source))
                (let [[checked-current checked-ok checked-error] (db-read-source-datom-current-at-entry? source entry)]
                  (set! current checked-current)
                  (set! current-ok checked-ok)
                  (set! current-error checked-error)))
              (when (not current-ok)
                (return false current-error))
              (when current
                (set-source-index-datom-stream-current-borrowed! stream datom)
                (return true "")))))
        (set! stream^.sparse-position (+ stream^.sparse-position 1)))
      (set! stream^.sparse-run-index (+ stream^.sparse-run-index 1))
      (set! stream^.sparse-range-active false)
      (set! stream^.sparse-position 0)
      (set! stream^.sparse-high 0)
      (when stream^.sparse-loaded-page-valid
        (release-sqlite-loaded-index-page! stream^.sparse-loaded-page)
        (set! stream^.sparse-loaded-page-valid false)))
    (set! stream^.sparse-prefix-index (+ stream^.sparse-prefix-index 1))
    (set! stream^.sparse-run-index 0)
    (set! stream^.sparse-range-active false)
    (set! stream^.sparse-position 0)
    (set! stream^.sparse-high 0))
  (return true ""))

(defn load-source-index-datom-stream-current! [source: DB-Read-Source, stream: ^Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (clear-source-index-datom-stream-current! stream)
  (when stream^.use-sqlite-run-ranges
    (return (load-source-index-datom-stream-current-from-sqlite-run-ranges! source stream)))
  (when stream^.use-sqlite-sparse-prefixes
    (return (load-source-index-datom-stream-current-from-sqlite-sparse-prefixes! source stream)))
  (when stream^.use-owned-datoms
    (when (< stream^.index stream^.high)
      (set-source-index-datom-stream-current-borrowed! stream stream^.owned-datoms[stream^.owned-order-indexes[stream^.index]]))
    (return true ""))
  (while (< stream^.index stream^.high)
    (if (and (= stream^.view.kind .SQLite-Cursor)
             (= source.kind .SQLite-Snapshot)
             (not source.sqlite-snapshot^.has-retractions))
      (let [[_entry offset datom-ok datom-error] (sqlite-index-cursor-entry-offset-at stream^.view.sqlite-cursor stream^.index)]
        (discard _entry)
        (when (not datom-ok)
          (return false datom-error))
        (set-source-index-datom-stream-current-borrowed! stream stream^.view.sqlite-cursor^.page.datoms[offset])
        (return true ""))
      (let [entry (db-index-view-at stream^.view stream^.index)
            [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
        (when (not current-ok)
          (return false current-error))
        (when current
          (if (= stream^.view.kind .SQLite-Cursor)
            (let [[_same-entry datom datom-ok datom-error] (sqlite-index-cursor-entry-and-datom-at stream^.view.sqlite-cursor stream^.index)]
              (discard _same-entry)
              (when (not datom-ok)
                (return false datom-error))
              (set-source-index-datom-stream-current-owned! stream datom)
              (return true ""))
            (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
              (when (not datom-ok)
                (return false datom-error))
              (set-source-index-datom-stream-current-owned! stream datom)
              (return true ""))))))
    (set! stream^.index (+ stream^.index 1)))
  (return true ""))

(defn advance-source-index-datom-stream! [source: DB-Read-Source, stream: ^Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (if stream^.use-sqlite-sparse-prefixes
    (set! stream^.sparse-position (+ stream^.sparse-position 1))
    (if stream^.use-sqlite-run-ranges
    (set! stream^.run-position (+ stream^.run-position 1))
    (set! stream^.index (+ stream^.index 1))))
  (load-source-index-datom-stream-current! source stream))

(defn source-entity-int-pair-append-range-stream! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, stream: ^Source-Index-Datom-Stream, projection: Source-Attr-Range-Value-Projection] -> [ok: bool, type-ok: bool, error: string]
  (while stream^.has-current
    (let [[_ type-ok] (source-entity-int-pair-append-range-datom! columns seen projection stream^.current)]
      (when (not type-ok)
        (return true false "")))
    (let [[advance-ok advance-error] (advance-source-index-datom-stream! source stream)]
      (when (not advance-ok)
        (return false false advance-error))))
  (return true true ""))

(defn sqlite-merge-index-view? [view: DB-Index-View] -> bool
  (and (= view.kind .SQLite-Cursor)
       (or view.sqlite-cursor^.root-is-merge
           view.sqlite-cursor^.root-is-manifest)))

(defn source-index-datom-stream-from-owned-datoms [source: DB-Read-Source, datoms: [dynamic]Datom] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [order-indexes (make [dynamic]int 0 (count datoms))]
    (for [_ index datoms]
      (arr.push! order-indexes index))
    (let [out-stream (Source-Index-Datom-Stream {owned-datoms: datoms owned-order-indexes: order-indexes use-owned-datoms: true index: 0 high: (count datoms) current: (Datom {}) has-current: false})
          [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
      (if load-ok
        (return out-stream true "")
        (do
          (delete-source-index-datom-stream out-stream)
          (return (Source-Index-Datom-Stream {}) false load-error))))))

(defn source-direct-sqlite-frontier-stream-for-order [source: DB-Read-Source, order: Public-Index-Order, entities: []u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, used: bool, candidates: int, error: string]
  (when (= (count entities) 0)
    (return (Source-Index-Datom-Stream {owned-datoms: (make [dynamic]Datom) owned-order-indexes: (make [dynamic]int) use-owned-datoms: true index: 0 high: 0 current: (Datom {}) has-current: false}) true true 0 ""))
  (when (not (= source.kind .SQLite-Snapshot))
    (return (Source-Index-Datom-Stream {}) true false 0 ""))
  (when source.sqlite-snapshot^.has-retractions
    (return (Source-Index-Datom-Stream {}) true false 0 ""))
  (when (not (or (= order .EAVT)
                 (= order .VAET)))
    (return (Source-Index-Datom-Stream {}) true false 0 ""))
  (let [[latest-basis latest-ok latest-error] (sqlite-latest-index-root-basis-raw source.sqlite-snapshot^.indexes.handle)]
    (when (not latest-ok)
      (return (Source-Index-Datom-Stream {}) false true 0 latest-error))
    (when (not (= latest-basis source.sqlite-snapshot^.basis-tx))
      (return (Source-Index-Datom-Stream {}) true false 0 "")))
  (let [unique (set.empty u64) :defer
        sorted-entities (make [dynamic]u64)]
    (for [entity entities]
      (when (not (set.contains? unique entity))
        (set.add! unique entity)
        (arr.push! sorted-entities entity)))
    (arr.sort! sorted-entities)
  (let [[datoms datoms-ok datoms-error] (sqlite-direct-frontier-datoms source.sqlite-snapshot^.indexes.handle (public-index-order-text order) (slice sorted-entities 0) attr)]
    (delete sorted-entities)
    (when (not datoms-ok)
      (delete-owned-datoms datoms)
      (return (Source-Index-Datom-Stream {}) false true 0 datoms-error))
    (let [candidate-count (count datoms)
          [out-stream stream-ok stream-error] (source-index-datom-stream-from-owned-datoms source datoms)]
      (if stream-ok
        (return out-stream true true candidate-count "")
        (return (Source-Index-Datom-Stream {}) false true candidate-count stream-error))))))

(defn source-direct-sqlite-eavt-entity-attrs-datoms [source: DB-Read-Source, entities: []u64, attrs: []string] -> [datoms: [dynamic]Datom, ok: bool, used: bool, scans: int, candidates: int, error: string]
  (when (or (not (= source.kind .SQLite-Snapshot))
            source.sqlite-snapshot^.has-retractions)
    (return (make [dynamic]Datom) true false 0 0 ""))
  (let [[latest-basis latest-ok latest-error] (sqlite-latest-index-root-basis-raw source.sqlite-snapshot^.indexes.handle)]
    (when (not latest-ok)
      (return (make [dynamic]Datom) false true 0 0 latest-error))
    (when (not (= latest-basis source.sqlite-snapshot^.basis-tx))
      (return (make [dynamic]Datom) true false 0 0 "")))
  (let [unique-entities (set.empty u64) :defer
        sorted-entities (make [dynamic]u64)
        unique-attrs (set.empty string) :defer
        sorted-attrs (make [dynamic]string)]
    (defer (delete sorted-entities))
    (defer (delete sorted-attrs))
    (for [entity entities]
      (when (not (set.contains? unique-entities entity))
        (set.add! unique-entities entity)
        (arr.push! sorted-entities entity)))
    (for [attr attrs]
      (when (not (set.contains? unique-attrs attr))
        (set.add! unique-attrs attr)
        (arr.push! sorted-attrs attr)))
    (arr.sort! sorted-entities)
    (arr.sort! sorted-attrs)
    (let [[datoms datoms-ok datoms-error] (sqlite-direct-eavt-entity-attrs-datoms source.sqlite-snapshot^.indexes.handle (slice sorted-entities 0) (slice sorted-attrs 0))]
      (if datoms-ok
        (return datoms true true 1 (count datoms) "")
        (return datoms false true 1 0 datoms-error)))))

(defn source-eavt-entity-attrs-datoms [source: DB-Read-Source, entities: []u64, attrs: []string] -> [datoms: [dynamic]Datom, ok: bool, used: bool, scans: int, candidates: int, error: string]
  (let [[direct direct-ok direct-used direct-scans direct-candidates direct-error] (source-direct-sqlite-eavt-entity-attrs-datoms source entities attrs)]
    (when (or (not direct-ok) direct-used)
      (return direct direct-ok direct-used direct-scans direct-candidates direct-error))
    (delete-owned-datoms direct))
  (let [out (make [dynamic]Datom)
        scan-count 0
        candidate-count 0]
    (for [attr attrs]
      (let [[stream stream-ok stream-used stream-candidates stream-error] (source-eavt-entity-attr-frontier-stream source entities attr)]
        (when (not stream-ok)
          (delete-owned-datoms out)
          (return (make [dynamic]Datom) false true scan-count candidate-count stream-error))
        (when (not stream-used)
          (delete-source-index-datom-stream stream)
          (delete-owned-datoms out)
          (return (make [dynamic]Datom) true false scan-count candidate-count ""))
        (mut! scan-count += 1)
        (when (>= stream-candidates 0)
          (mut! candidate-count += stream-candidates))
        (while stream.has-current
          (arr.push! out (datom-owned stream.current))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (delete-owned-datoms out)
              (return (make [dynamic]Datom) false true scan-count candidate-count advance-error))))
        (delete-source-index-datom-stream stream)))
    (return out true true scan-count candidate-count "")))

(defn source-frontier-datom-matches? [datom: Datom, order: Public-Index-Order, entities: (ptr (map u64 (struct {}))), attr: string] -> bool
  (cond
    (= order .EAVT)
      (and (= datom.a attr)
           (set.contains? entities^ datom.e))
    (= order .VAET)
      (and (= datom.a attr)
           (= datom.v.kind .Entity)
           (set.contains? entities^ datom.v.entity))
    :else false))

(defn append-sqlite-index-root-frontier-datoms! [out: ^[dynamic]Datom, source: DB-Read-Source, cursor: ^SQLite-Index-Cursor, root-id: u64, row-count: int, order: Public-Index-Order, min-entity: u64, max-entity: u64, attr: string, entities: (ptr (map u64 (struct {})))] -> [ok: bool, error: string, candidates: int]
  (let [order-text (public-index-order-text order)
        lower-values ([]Value [(value-entity min-entity) (value-keyword attr)])
        upper-values ([]Value [(value-entity max-entity) (value-keyword attr)])
        [low low-ok low-error] (sqlite-index-root-bound-values cursor root-id row-count order-text lower-values false)]
    (when (not low-ok)
      (return false low-error 0))
    (let [[high high-ok high-error] (sqlite-index-root-bound-values cursor root-id row-count order-text upper-values true)]
      (when (not high-ok)
        (return false high-error 0))
      (let [candidate-count 0
            loaded-page (SQLite-Loaded-Index-Page {})
            loaded-page-valid false]
        (for [position (arr.range low high)]
          (let [[entry offset entry-ok entry-error] (sqlite-index-root-ordered-entry-offset-at-retained-page-cache cursor^.handle
                                                                                                                   cursor^.datom-stmt
                                                                                                                   root-id
                                                                                                                   position
                                                                                                                   row-count
                                                                                                                   cursor^.page-size
                                                                                                                   (addr cursor^.page-cache)
                                                                                                                   (addr loaded-page)
                                                                                                                   (addr loaded-page-valid))]
            (when (not entry-ok)
              (when loaded-page-valid
                (release-sqlite-loaded-index-page! loaded-page))
              (return false entry-error candidate-count))
            (mut! candidate-count += 1)
            (let [datom loaded-page.datoms[offset]]
              (when (source-frontier-datom-matches? datom order entities attr)
                (let [current true
                      current-ok true
                      current-error ""]
                  (when (not (db-read-source-all-index-entries-current? source))
                    (let [[checked-current checked-ok checked-error] (db-read-source-datom-current-at-entry? source entry)]
                      (set! current checked-current)
                      (set! current-ok checked-ok)
                      (set! current-error checked-error)))
                  (when (not current-ok)
                    (when loaded-page-valid
                      (release-sqlite-loaded-index-page! loaded-page))
                    (return false current-error candidate-count))
                  (when current
                    (arr.push! out^ (datom-owned datom))))))))
        (when loaded-page-valid
          (release-sqlite-loaded-index-page! loaded-page))
        (return true "" candidate-count)))))

(defn sqlite-index-view-root-counts-for-sparse-prefix-stream [view: DB-Index-View] -> [roots: [dynamic]u64, counts: [dynamic]int, ok: bool, error: string]
  (if (sqlite-merge-index-view? view)
    (sqlite-index-cursor-child-runs view.sqlite-cursor)
    (let [roots (make [dynamic]u64)
          counts (make [dynamic]int)]
      (arr.push! roots view.sqlite-cursor^.root-id)
      (arr.push! counts view.sqlite-cursor^.row-count)
      (return roots counts true ""))))

(defn source-entity-attr-sparse-prefix-stream-for-order [source: DB-Read-Source, order: Public-Index-Order, entities: []u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, used: bool, candidates: int, error: string]
  (when (= (count entities) 0)
    (return (Source-Index-Datom-Stream {owned-datoms: (make [dynamic]Datom) owned-order-indexes: (make [dynamic]int) use-owned-datoms: true index: 0 high: 0 current: (Datom {}) has-current: false}) true true 0 ""))
  (when (db-read-source-has-overlay? source)
    (return (Source-Index-Datom-Stream {}) true false 0 ""))
  (let [view (db-read-source-index-view source order)]
    (when (not (= view.kind .SQLite-Cursor))
      (return (Source-Index-Datom-Stream {}) true false 0 ""))
    (when (sqlite-merge-index-view? view)
      (return (Source-Index-Datom-Stream {}) true false 0 ""))
    (let [unique (set.empty u64) :defer
          sorted-entities (make [dynamic]u64)]
      (for [entity entities]
        (when (not (set.contains? unique entity))
          (set.add! unique entity)
          (arr.push! sorted-entities entity)))
      (arr.sort! sorted-entities)
      (when (> (count sorted-entities) 32)
        (delete sorted-entities)
        (return (Source-Index-Datom-Stream {}) true false 0 ""))
      (let [[roots counts roots-ok roots-error] (sqlite-index-view-root-counts-for-sparse-prefix-stream view)]
        (when (not roots-ok)
          (delete sorted-entities)
          (delete roots)
          (delete counts)
          (return (Source-Index-Datom-Stream {}) false true 0 roots-error))
        (let [seek-budget (* (count roots) (count sorted-entities))]
          (when (> seek-budget 1024)
            (delete sorted-entities)
            (delete roots)
            (delete counts)
            (return (Source-Index-Datom-Stream {}) true false 0 "")))
        (let [out-stream (Source-Index-Datom-Stream {view: view
                                                     use-sqlite-sparse-prefixes: true
                                                     sparse-roots: roots
                                                     sparse-counts: counts
                                                     sparse-entities: sorted-entities
                                                     sparse-attr: attr
                                                     sparse-order-text: (public-index-order-text order)
                                                     sparse-prefix-index: 0
                                                     sparse-run-index: 0
                                                     sparse-position: 0
                                                     sparse-high: 0
                                                     sparse-range-active: false
                                                     sparse-loaded-page: (SQLite-Loaded-Index-Page {})
                                                     sparse-loaded-page-valid: false
                                                     sparse-dedupe-entries: (> (count roots) 1)
                                                     sparse-seen-entries: (set.empty int)
                                                     current: (Datom {})
                                                     has-current: false})
              [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
          (if load-ok
            (return out-stream true true -1 "")
            (do
              (delete-source-index-datom-stream out-stream)
              (return (Source-Index-Datom-Stream {}) false true -1 load-error))))))))

(defn source-entity-attr-frontier-stream-for-order [source: DB-Read-Source, order: Public-Index-Order, entities: []u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, used: bool, candidates: int, error: string]
  (let [[direct-stream direct-ok direct-used direct-candidates direct-error] (source-direct-sqlite-frontier-stream-for-order source order entities attr)]
    (when (or (not direct-ok) direct-used)
      (return direct-stream direct-ok direct-used direct-candidates direct-error)))
  (when (= (count entities) 0)
    (return (Source-Index-Datom-Stream {owned-datoms: (make [dynamic]Datom) owned-order-indexes: (make [dynamic]int) use-owned-datoms: true index: 0 high: 0 current: (Datom {}) has-current: false}) true true 0 ""))
  (when (db-read-source-has-overlay? source)
    (return (Source-Index-Datom-Stream {}) true false 0 ""))
  (let [view (db-read-source-index-view source order)]
    (when (not (= view.kind .SQLite-Cursor))
      (return (Source-Index-Datom-Stream {}) true false 0 ""))
    (let [entity-set (set.empty u64) :defer
          min-entity entities[0]
          max-entity entities[0]
          datoms (make [dynamic]Datom)
          candidate-count 0]
      (for [entity entities]
        (set.add! entity-set entity)
        (when (< entity min-entity)
          (set! min-entity entity))
        (when (> entity max-entity)
          (set! max-entity entity)))
      (let [span (+ (- max-entity min-entity) 1)
            dense-limit (* (u64 (count entities)) (u64 16))]
        (when (> span dense-limit)
          (delete-owned-datoms datoms)
          (return (Source-Index-Datom-Stream {}) true false 0 "")))
      (if (sqlite-merge-index-view? view)
        (let [[roots counts runs-ok runs-error] (sqlite-index-cursor-child-runs view.sqlite-cursor)]
          (when (not runs-ok)
            (delete-owned-datoms datoms)
            (delete roots)
            (delete counts)
            (return (Source-Index-Datom-Stream {}) false true candidate-count runs-error))
          (for [run-index (arr.range 0 (count roots))]
            (let [[append-ok append-error append-candidates] (append-sqlite-index-root-frontier-datoms! (addr datoms) source view.sqlite-cursor roots[run-index] counts[run-index] order min-entity max-entity attr (addr entity-set))]
              (mut! candidate-count += append-candidates)
              (when (not append-ok)
                (delete-owned-datoms datoms)
                (delete roots)
                (delete counts)
                (return (Source-Index-Datom-Stream {}) false true candidate-count append-error))))
          (delete roots)
          (delete counts))
        (let [[append-ok append-error append-candidates] (append-sqlite-index-root-frontier-datoms! (addr datoms) source view.sqlite-cursor view.sqlite-cursor^.root-id view.sqlite-cursor^.row-count order min-entity max-entity attr (addr entity-set))]
          (mut! candidate-count += append-candidates)
          (when (not append-ok)
            (delete-owned-datoms datoms)
            (return (Source-Index-Datom-Stream {}) false true candidate-count append-error))))
      (let [[out-stream stream-ok stream-error] (source-index-datom-stream-from-owned-datoms source datoms)]
        (if stream-ok
          (return out-stream true true candidate-count "")
          (return (Source-Index-Datom-Stream {}) false true candidate-count stream-error))))))

(defn source-eavt-entity-attr-frontier-stream [source: DB-Read-Source, entities: []u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, used: bool, candidates: int, error: string]
  (source-entity-attr-frontier-stream-for-order source .EAVT entities attr))

(defn source-vaet-entity-attr-frontier-stream [source: DB-Read-Source, entities: []u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, used: bool, candidates: int, error: string]
  (source-entity-attr-frontier-stream-for-order source .VAET entities attr))

(defn sqlite-index-root-bound-key-only-compare [cursor: ^SQLite-Index-Cursor, entry: int, order-text: string, values: []Value] -> [compare: int, ok: bool, matched: bool, error: string]
  (when (= (count values) 2)
    (let [first values[0]
          second values[1]]
      (cond
        (and (= order-text ":eavt")
             (or (= first.kind .Entity)
                 (= first.kind .Int))
             (or (= second.kind .Keyword)
                 (= second.kind .String)))
          (let [[entity entity-ok entity-error] (sqlite-load-datom-entity-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
            (when (not entity-ok)
              (return 0 false true entity-error))
            (let [expected-entity (if (= first.kind .Entity) first.entity (u64 first.int-value))]
              (cond
                (< entity expected-entity) (return -1 true true "")
                (> entity expected-entity) (return 1 true true "")
                :else
                  (let [[attr attr-ok attr-error] (sqlite-load-datom-attr-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
                    (when (not attr-ok)
                      (return 0 false true attr-error))
                    (defer (delete attr))
                    (return (strings.compare attr second.text) true true "")))))
        (and (= order-text ":aevt")
             (or (= first.kind .Keyword)
                 (= first.kind .String))
             (or (= second.kind .Entity)
                 (= second.kind .Int)))
          (let [[attr attr-ok attr-error] (sqlite-load-datom-attr-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
            (when (not attr-ok)
              (return 0 false true attr-error))
            (let [attr-compare (strings.compare attr first.text)]
              (delete attr)
              (when (not (= attr-compare 0))
                (return attr-compare true true "")))
            (let [[entity entity-ok entity-error] (sqlite-load-datom-entity-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
              (when (not entity-ok)
                (return 0 false true entity-error))
              (let [expected-entity (if (= second.kind .Entity) second.entity (u64 second.int-value))]
                (cond
                  (< entity expected-entity) (return -1 true true "")
                  (> entity expected-entity) (return 1 true true "")
                  :else (return 0 true true "")))))
        :else
          (discard first))))
  (when (not (= (count values) 1))
    (return 0 true false ""))
  (let [value values[0]]
    (cond
      (and (= order-text ":eavt")
           (or (= value.kind .Entity)
               (= value.kind .Int)))
        (let [[entity entity-ok entity-error] (sqlite-load-datom-entity-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
          (when (not entity-ok)
            (return 0 false true entity-error))
          (let [expected (if (= value.kind .Entity) value.entity (u64 value.int-value))]
            (cond
              (< entity expected) (return -1 true true "")
              (> entity expected) (return 1 true true "")
              :else (return 0 true true ""))))
      (and (or (= order-text ":aevt")
               (= order-text ":avet"))
           (or (= value.kind .Keyword)
               (= value.kind .String)))
        (let [[attr attr-ok attr-error] (sqlite-load-datom-attr-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
          (when (not attr-ok)
            (return 0 false true attr-error))
          (defer (delete attr))
          (return (strings.compare attr value.text) true true ""))
      :else
        (return 0 true false ""))))

(defn sqlite-index-root-overlaps-values? [cursor: ^SQLite-Index-Cursor, root-id: u64, order-text: string, values: []Value] -> [overlaps: bool, ok: bool, error: string]
  (when (= (count values) 0)
    (return true true ""))
  (let [[first-bound last-bound bounds-ok bounds-error] (sqlite-index-chunk-bounds-by-id-raw cursor^.handle root-id)]
    (when (not bounds-ok)
      (return false false bounds-error))
    (defer (delete first-bound))
    (defer (delete last-bound))
    (let [[first-entry first-ok] (parse-index-bound-entry first-bound)
          [last-entry last-ok] (parse-index-bound-entry last-bound)]
      (when (not (and first-ok last-ok))
        (return true true ""))
      (let [[first-key-compare first-key-ok first-key-matched first-key-error] (sqlite-index-root-bound-key-only-compare cursor first-entry order-text values)]
        (when (not first-key-ok)
          (return false false first-key-error))
        (when first-key-matched
          (let [[last-key-compare last-key-ok _last-key-matched last-key-error] (sqlite-index-root-bound-key-only-compare cursor last-entry order-text values)]
            (when (not last-key-ok)
              (return false false last-key-error))
            (return (and (not (< last-key-compare 0))
                         (not (> first-key-compare 0)))
                    true
                    ""))))
      (let [[first-datom first-datom-ok first-datom-error] (sqlite-load-datom-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt first-entry)]
        (when (not first-datom-ok)
          (return false false first-datom-error))
        (defer (delete-owned-datom first-datom))
        (let [[last-datom last-datom-ok last-datom-error] (sqlite-load-datom-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt last-entry)]
          (when (not last-datom-ok)
            (return false false last-datom-error))
          (defer (delete-owned-datom last-datom))
          (let [first-compare (datom-index-compare-values first-datom order-text values)
                last-compare (datom-index-compare-values last-datom order-text values)]
            (return (and (not (< last-compare 0))
                         (not (> first-compare 0)))
                    true
                    "")))))))

(defn sqlite-index-bound-datoms-overlap-values? [first-datom: Datom, last-datom: Datom, order-text: string, values: []Value] -> bool
  (when (= (count values) 0)
    (return true))
  (let [first-compare (datom-index-compare-values first-datom order-text values)
        last-compare (datom-index-compare-values last-datom order-text values)]
    (and (not (< last-compare 0))
         (not (> first-compare 0)))))

(defn sqlite-manifest-attr-prefix [order: Public-Index-Order, values: []Value] -> [attr: string, ok: bool]
  (when (not (or (= order .AEVT)
                 (= order .AVET)))
    (return "" false))
  (when (= (count values) 0)
    (return "" false))
  (let [value values[0]]
    (if (or (= value.kind .Keyword)
            (= value.kind .String))
      (return value.text true)
      (return "" false))))

(defn sqlite-index-root-bound-values [cursor: ^SQLite-Index-Cursor, root-id: u64, row-count: int, order-text: string, values: []Value, upper?: bool] -> [position: int, ok: bool, error: string]
  (when (= (count values) 0)
    (return (if upper? row-count 0) true ""))
  (let [page (make [dynamic]int)
        page-start -1
        page-end -1
        low 0
        high row-count]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            [entry entry-ok entry-error] (sqlite-index-root-ordered-entry-at-shared-cache cursor^.handle root-id mid row-count cursor^.page-size (addr cursor^.page-cache) (addr page) (addr page-start) (addr page-end))]
        (when (not entry-ok)
          (delete page)
          (return low false entry-error))
        (let [[key-compare key-ok key-matched key-error] (sqlite-index-root-bound-key-only-compare cursor entry order-text values)]
          (when (not key-ok)
            (delete page)
            (return low false key-error))
          (if key-matched
            (if (if upper? (<= key-compare 0) (< key-compare 0))
              (set! low (+ mid 1))
              (set! high mid))
            (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
              (when (not datom-ok)
                (delete page)
                (return low false datom-error))
              (let [compare (datom-index-compare-values datom order-text values)]
                (delete-owned-datom datom)
                (if (if upper? (<= compare 0) (< compare 0))
                  (set! low (+ mid 1))
                  (set! high mid))))))))
    (delete page)
    (return low true "")))

(defn append-sqlite-index-root-values! [out: ^[dynamic]Datom, source: DB-Read-Source, cursor: ^SQLite-Index-Cursor, root-id: u64, row-count: int, order-text: string, values: []Value, low: int, high: int] -> [ok: bool, error: string]
  (let [page (make [dynamic]int)
        page-start -1
        page-end -1]
    (for [position (arr.range low high)]
      (let [[entry entry-ok entry-error] (sqlite-index-root-ordered-entry-at-cached cursor^.handle root-id position row-count cursor^.page-size (addr page) (addr page-start) (addr page-end))]
        (when (not entry-ok)
          (delete page)
          (return false entry-error))
        (let [[current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
          (when (not current-ok)
            (delete page)
            (return false current-error))
          (when current
            (let [[datom datom-ok datom-error] (sqlite-load-datom-by-log-index-handle-stmt cursor^.handle cursor^.datom-stmt entry)]
              (when (not datom-ok)
                (delete page)
                (return false datom-error))
              (if (datom-matches-index-values? datom order-text values)
                (arr.push! out^ datom)
                (delete-owned-datom datom)))))))
    (delete page)
    (return true "")))

(defn source-index-datom-stream-from-sqlite-manifest-bound-runs [source: DB-Read-Source, order: Public-Index-Order, values: []Value, view: DB-Index-View, roots: [dynamic]u64, counts: [dynamic]int, lows: [dynamic]int, highs: [dynamic]int, first-datoms: [dynamic]Datom, last-datoms: [dynamic]Datom] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [selected-roots (make [dynamic]u64)
        selected-counts (make [dynamic]int)
        selected-lows (make [dynamic]int)
        selected-highs (make [dynamic]int)
        order-text (public-index-order-text order)]
    (for [child-index (arr.range 0 (count roots))]
      (when (sqlite-index-bound-datoms-overlap-values? first-datoms[child-index] last-datoms[child-index] order-text values)
        (let [stored-low lows[child-index]
              stored-high highs[child-index]
              use-stored-bounds (and (>= stored-low 0)
                                     (>= stored-high stored-low)
                                     (<= stored-high counts[child-index])
                                     (<= (count values) 1))
              low stored-low
              low-ok true
              low-error ""]
          (when (not use-stored-bounds)
            (let [[computed-low computed-low-ok computed-low-error] (sqlite-index-root-bound-values view.sqlite-cursor roots[child-index] counts[child-index] order-text values false)]
              (set! low computed-low)
              (set! low-ok computed-low-ok)
              (set! low-error computed-low-error)))
          (when (not low-ok)
            (delete selected-roots)
            (delete selected-counts)
            (delete selected-lows)
            (delete selected-highs)
            (delete roots)
            (delete counts)
            (delete lows)
            (delete highs)
            (delete-owned-datoms first-datoms)
            (delete-owned-datoms last-datoms)
            (return (Source-Index-Datom-Stream {}) false low-error))
          (let [high stored-high
                high-ok true
                high-error ""]
            (when (not use-stored-bounds)
              (let [[computed-high computed-high-ok computed-high-error] (sqlite-index-root-bound-values view.sqlite-cursor roots[child-index] counts[child-index] order-text values true)]
                (set! high computed-high)
                (set! high-ok computed-high-ok)
                (set! high-error computed-high-error)))
            (when (not high-ok)
              (delete selected-roots)
              (delete selected-counts)
              (delete selected-lows)
              (delete selected-highs)
              (delete roots)
              (delete counts)
              (delete lows)
              (delete highs)
              (delete-owned-datoms first-datoms)
              (delete-owned-datoms last-datoms)
              (return (Source-Index-Datom-Stream {}) false high-error))
            (when (< low high)
              (arr.push! selected-roots roots[child-index])
              (arr.push! selected-counts counts[child-index])
              (arr.push! selected-lows low)
              (arr.push! selected-highs high))))))
    (delete roots)
    (delete counts)
    (delete lows)
    (delete highs)
    (delete-owned-datoms first-datoms)
    (delete-owned-datoms last-datoms)
    (let [out-stream (Source-Index-Datom-Stream {view: view
                                                 use-sqlite-run-ranges: true
                                                 run-roots: selected-roots
                                                 run-counts: selected-counts
                                                 run-lows: selected-lows
                                                 run-highs: selected-highs
                                                 run-values: (values-owned-array values)
                                                 run-order-text: order-text
                                                 run-check-values: true
                                                 run-index: 0
                                                 run-position: 0
                                                 run-page: (make [dynamic]int)
                                                 run-page-start: -1
                                                 run-page-end: -1
                                                 run-loaded-page: (SQLite-Loaded-Index-Page {})
                                                 run-loaded-page-valid: false
                                                 run-dedupe-entries: (> (count selected-roots) 1)
                                                 run-seen-entries: (set.empty int)
                                                 current: (Datom {})
                                                 has-current: false})
          [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
      (if load-ok
        (return out-stream true "")
        (do
          (delete-source-index-datom-stream out-stream)
          (return (Source-Index-Datom-Stream {}) false load-error))))))

(defn source-index-datom-stream-for-sqlite-manifest-sequential-values [source: DB-Read-Source, order: Public-Index-Order, values: []Value, view: DB-Index-View] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [[prefix-attr has-prefix-attr] (sqlite-manifest-attr-prefix order values)]
    (if has-prefix-attr
      (let [[roots counts lows highs first-datoms last-datoms runs-ok runs-error] (sqlite-index-run-manifest-child-runs-with-attr-bound-datoms view.sqlite-cursor^.handle view.sqlite-cursor^.manifest-id prefix-attr)]
        (if runs-ok
          (source-index-datom-stream-from-sqlite-manifest-bound-runs source order values view roots counts lows highs first-datoms last-datoms)
          (do
            (delete roots)
            (delete counts)
            (delete lows)
            (delete highs)
            (delete-owned-datoms first-datoms)
            (delete-owned-datoms last-datoms)
            (return (Source-Index-Datom-Stream {}) false runs-error))))
      (let [[roots counts lows highs first-datoms last-datoms runs-ok runs-error] (sqlite-index-run-manifest-child-runs-with-bound-datoms view.sqlite-cursor^.handle view.sqlite-cursor^.manifest-id)]
        (if runs-ok
          (source-index-datom-stream-from-sqlite-manifest-bound-runs source order values view roots counts lows highs first-datoms last-datoms)
          (do
            (delete roots)
            (delete counts)
            (delete lows)
            (delete highs)
            (delete-owned-datoms first-datoms)
            (delete-owned-datoms last-datoms)
            (return (Source-Index-Datom-Stream {}) false runs-error)))))))

(defn source-index-datom-stream-for-sqlite-sequential-values [source: DB-Read-Source, order: Public-Index-Order, values: []Value, view: DB-Index-View] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (when view.sqlite-cursor^.root-is-manifest
    (return (source-index-datom-stream-for-sqlite-manifest-sequential-values source order values view)))
  (let [selected-roots (make [dynamic]u64)
        selected-counts (make [dynamic]int)
        selected-lows (make [dynamic]int)
        selected-highs (make [dynamic]int)
        order-text (public-index-order-text order)
        [roots counts runs-ok runs-error] (sqlite-index-cursor-child-runs view.sqlite-cursor)]
    (when (not runs-ok)
      (delete selected-roots)
      (delete selected-counts)
      (delete selected-lows)
      (delete selected-highs)
      (delete roots)
      (delete counts)
      (return (Source-Index-Datom-Stream {}) false runs-error))
    (for [child-index (arr.range 0 (count roots))]
      (let [[low low-ok low-error] (sqlite-index-root-bound-values view.sqlite-cursor roots[child-index] counts[child-index] order-text values false)]
        (when (not low-ok)
          (delete selected-roots)
          (delete selected-counts)
          (delete selected-lows)
          (delete selected-highs)
          (delete roots)
          (delete counts)
          (return (Source-Index-Datom-Stream {}) false low-error))
        (let [[high high-ok high-error] (sqlite-index-root-bound-values view.sqlite-cursor roots[child-index] counts[child-index] order-text values true)]
          (when (not high-ok)
            (delete selected-roots)
            (delete selected-counts)
            (delete selected-lows)
            (delete selected-highs)
            (delete roots)
            (delete counts)
            (return (Source-Index-Datom-Stream {}) false high-error))
          (when (< low high)
            (arr.push! selected-roots roots[child-index])
            (arr.push! selected-counts counts[child-index])
            (arr.push! selected-lows low)
            (arr.push! selected-highs high)))))
    (delete roots)
    (delete counts)
    (let [out-stream (Source-Index-Datom-Stream {view: view
                                                 use-sqlite-run-ranges: true
                                                 run-roots: selected-roots
                                                 run-counts: selected-counts
                                                 run-lows: selected-lows
                                                 run-highs: selected-highs
                                                 run-values: (values-owned-array values)
                                                 run-order-text: order-text
                                                 run-check-values: false
                                                 run-index: 0
                                                 run-position: 0
                                                 run-page: (make [dynamic]int)
                                                 run-page-start: -1
                                                 run-page-end: -1
                                                 run-loaded-page: (SQLite-Loaded-Index-Page {})
                                                 run-loaded-page-valid: false
                                                 run-dedupe-entries: (> (count selected-roots) 1)
                                                 run-seen-entries: (set.empty int)
                                                 current: (Datom {})
                                                 has-current: false})
          [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
      (if load-ok
        (return out-stream true "")
        (do
          (delete-source-index-datom-stream out-stream)
          (return (Source-Index-Datom-Stream {}) false load-error))))))

(defn source-index-datom-stream-for-values [source: DB-Read-Source, order: Public-Index-Order, values: []Value] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (when (db-read-source-has-overlay? source)
    (let [datoms (make [dynamic]Datom)
          [scan-ok scan-error] (db-read-source-append-index-datoms! (addr datoms) source order values)]
      (when (not scan-ok)
        (delete-owned-datoms datoms)
        (return (Source-Index-Datom-Stream {}) false scan-error))
      (let [order-indexes (sorted-datom-order-indexes (slice datoms 0) order)
            out-stream (Source-Index-Datom-Stream {owned-datoms: datoms owned-order-indexes: order-indexes use-owned-datoms: true index: 0 high: (count datoms) current: (Datom {}) has-current: false})
            [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
        (if load-ok
          (return out-stream true "")
          (do
            (delete-source-index-datom-stream out-stream)
            (return (Source-Index-Datom-Stream {}) false load-error))))))
  (let [view (db-read-source-index-view source order)]
    (when (sqlite-merge-index-view? view)
      (return (source-index-datom-stream-for-sqlite-sequential-values source order values view))))
  (let [[view low high range-ok range-error] (db-read-source-prefix-index-range source order values)]
    (when (not range-ok)
      (return (Source-Index-Datom-Stream {}) false range-error))
    (let [out-stream (Source-Index-Datom-Stream {view: view index: low high: high current: (Datom {}) has-current: false})
          [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
      (if load-ok
        (return out-stream true "")
        (return out-stream false load-error)))))

(defn source-index-datom-stream-for-index-range [source: DB-Read-Source, view: DB-Index-View, low: int, high: int] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [out-stream (Source-Index-Datom-Stream {view: view index: low high: high current: (Datom {}) has-current: false})
        [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
    (if load-ok
      (return out-stream true "")
      (return out-stream false load-error))))

(defn source-index-datom-stream-for-attr-range [source: DB-Read-Source, projection: Source-Attr-Range-Value-Projection] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (when (db-read-source-has-overlay? source)
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source projection.attr)]
      (when (not datoms-ok)
        (return (Source-Index-Datom-Stream {}) false datoms-error))
      (let [filtered (make [dynamic]Datom)]
        (for [datom datoms]
          (when (predicate-pair-matches? projection.op datom.v projection.value)
            (arr.push! filtered (datom-owned datom))))
        (delete-owned-datoms datoms)
        (let [order-indexes (sorted-datom-order-indexes (slice filtered 0) .AVET)
              out-stream (Source-Index-Datom-Stream {owned-datoms: filtered owned-order-indexes: order-indexes use-owned-datoms: true index: 0 high: (count filtered) current: (Datom {}) has-current: false})
              [load-ok load-error] (load-source-index-datom-stream-current! source (addr out-stream))]
          (if load-ok
            (return out-stream true "")
            (do
              (delete-source-index-datom-stream out-stream)
              (return (Source-Index-Datom-Stream {}) false load-error)))))))
  (let [[view low high range-ok range-error] (db-read-source-attr-range-index-bounds source projection)]
    (when (not range-ok)
      (return (Source-Index-Datom-Stream {}) false range-error))
    (source-index-datom-stream-for-index-range source view low high)))

(defstruct Source-Clause-Datom-Stream {
  scan: Clause-Index-Scan
  use-index-stream: bool
  index-stream: Source-Index-Datom-Stream
  index: int
  current: Datom
  current-owned: bool
  has-current: bool
})

(defn delete-source-clause-datom-stream [stream: Source-Clause-Datom-Stream]
  (when stream.has-current
    (when stream.current-owned
      (delete-owned-datom stream.current)))
  (when stream.use-index-stream
    (delete-source-index-datom-stream stream.index-stream))
  (delete-clause-index-scan stream.scan))

(defn load-source-clause-datom-stream-current! [source: DB-Read-Source, stream: ^Source-Clause-Datom-Stream] -> [ok: bool, error: string]
  (when stream^.has-current
    (when stream^.current-owned
      (delete-owned-datom stream^.current))
    (set! stream^.has-current false)
    (set! stream^.current-owned false))
  (when stream^.use-index-stream
    (while stream^.index-stream.has-current
      (let [datom stream^.index-stream.current]
        (when (db-read-source-clause-index-scan-candidate? stream^.scan datom)
          (set! stream^.current datom)
          (set! stream^.current-owned false)
          (set! stream^.has-current true)
          (return true "")))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream^.index-stream))]
        (when (not advance-ok)
          (return false advance-error))))
    (return true ""))
  (while (< stream^.index stream^.scan.high)
    (if (and (= stream^.scan.view.kind .SQLite-Cursor)
             (= source.kind .SQLite-Snapshot)
             (not source.sqlite-snapshot^.has-retractions))
      (let [[_entry offset datom-ok datom-error] (sqlite-index-cursor-entry-offset-at stream^.scan.view.sqlite-cursor stream^.index)]
        (discard _entry)
        (when (not datom-ok)
          (return false datom-error))
        (let [datom stream^.scan.view.sqlite-cursor^.page.datoms[offset]]
          (when (db-read-source-clause-index-scan-candidate? stream^.scan datom)
            (set! stream^.current datom)
            (set! stream^.current-owned false)
            (set! stream^.has-current true)
            (return true ""))))
      (let [entry (clause-index-scan-datom-index stream^.scan stream^.index)
            [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
        (when (not current-ok)
          (return false current-error))
        (when current
          (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
            (when (not datom-ok)
              (return false datom-error))
            (if (db-read-source-clause-index-scan-candidate? stream^.scan datom)
              (do
                (set! stream^.current datom)
                (set! stream^.current-owned true)
                (set! stream^.has-current true)
                (return true ""))
              (delete-owned-datom datom))))))
    (set! stream^.index (+ stream^.index 1)))
  (return true ""))

(defn source-index-datom-stream-for-clause-index-scan [source: DB-Read-Source, scan: Clause-Index-Scan] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values (make [dynamic]Value)
        order: Public-Index-Order .EAVT]
    (defer (delete-owned-values-array values))
    (if scan.reverse-attr
      (cond
        scan.e-ok
          (do
            (set! order .VAET)
            (arr.push! values (value-owned scan.e-value)))
        scan.v-ok
          (do
            (set! order .EAVT)
            (arr.push! values (value-owned scan.v-value))
            (arr.push! values (value-keyword scan.forward-attr)))
        :else
          (do
            (set! order .AEVT)
            (arr.push! values (value-keyword scan.forward-attr))))
      (cond
        (and scan.e-ok scan.a-ok)
          (do
            (set! order .EAVT)
            (arr.push! values (value-owned scan.e-value))
            (arr.push! values (value-owned scan.a-value)))
        (and scan.a-ok scan.v-ok)
          (do
            (set! order .AVET)
            (arr.push! values (value-owned scan.a-value))
            (arr.push! values (value-owned scan.v-value)))
        scan.e-ok
          (do
            (set! order .EAVT)
            (arr.push! values (value-owned scan.e-value)))
        scan.a-ok
          (do
            (set! order .AEVT)
            (arr.push! values (value-owned scan.a-value)))
        scan.v-ok
          (do
            (set! order .VAET)
            (arr.push! values (value-owned scan.v-value)))
        :else
          (set! order .EAVT)))
    (source-index-datom-stream-for-values source order (slice values 0))))

(defn source-clause-scan-should-use-index-stream? [scan: Clause-Index-Scan] -> bool
  (when (not (and (= scan.view.kind .SQLite-Cursor)
                  (sqlite-merge-index-view? scan.view)))
    (return false))
  (if scan.reverse-attr
    (not (or scan.e-ok scan.v-ok))
    (and (not scan.e-ok)
         (or scan.a-ok
             (not scan.v-ok)))))

(defn source-clause-datom-stream-for-scan [source: DB-Read-Source, scan: Clause-Index-Scan] -> [stream: Source-Clause-Datom-Stream, ok: bool, error: string]
  (when (source-clause-scan-should-use-index-stream? scan)
    (let [[index-stream index-ok index-error] (source-index-datom-stream-for-clause-index-scan source scan)]
      (when (not index-ok)
        (delete-source-index-datom-stream index-stream)
        (return (Source-Clause-Datom-Stream {}) false index-error))
      (let [out-stream (Source-Clause-Datom-Stream {scan: scan
                                                    use-index-stream: true
                                                    index-stream: index-stream
                                                    index: scan.index
                                                    current: (Datom {})
                                                    has-current: false})
            [load-ok load-error] (load-source-clause-datom-stream-current! source (addr out-stream))]
        (if load-ok
          (return out-stream true "")
          (do
            (delete-source-clause-datom-stream out-stream)
            (return (Source-Clause-Datom-Stream {}) false load-error))))))
  (let [out-stream (Source-Clause-Datom-Stream {scan: scan index: scan.index current: (Datom {}) has-current: false})
        [load-ok load-error] (load-source-clause-datom-stream-current! source (addr out-stream))]
    (if load-ok
      (return out-stream true "")
      (do
        (delete-source-clause-datom-stream out-stream)
        (return (Source-Clause-Datom-Stream {}) false load-error)))))

(defn source-clause-datom-stream-for-binding [source: DB-Read-Source, clause-value: Clause, binding: Binding] -> [stream: Source-Clause-Datom-Stream, ok: bool, error: string]
  (let [[scan scan-ok scan-error] (db-read-source-clause-index-scan source clause-value binding)]
    (when (not scan-ok)
      (delete-clause-index-scan scan)
      (return (Source-Clause-Datom-Stream {}) false scan-error))
    (source-clause-datom-stream-for-scan source scan)))

(defn source-clause-datom-stream-for-typed-row [source: DB-Read-Source, rel: Query-Relation, row: int, clause-value: Clause] -> [stream: Source-Clause-Datom-Stream, ok: bool, error: string]
  (let [[scan scan-ok scan-error] (db-read-source-clause-index-scan-typed-row source rel row clause-value)]
    (when (not scan-ok)
      (delete-clause-index-scan scan)
      (return (Source-Clause-Datom-Stream {}) false scan-error))
    (source-clause-datom-stream-for-scan source scan)))

(defn source-clause-datom-stream-for-typed-row-with-op [source: DB-Read-Source, rel: Query-Relation, row: int, clause-value: Clause, op: Physical-Op] -> [stream: Source-Clause-Datom-Stream, ok: bool, error: string]
  (let [[scan scan-ok scan-error] (db-read-source-clause-index-scan-typed-row source rel row clause-value)]
    (when (not scan-ok)
      (delete-clause-index-scan scan)
      (return (Source-Clause-Datom-Stream {}) false scan-error))
    (let [[tighten-ok tighten-error] (physical-op-tighten-db-read-source-attr-value-scan! source (addr scan) clause-value op rel row)]
      (when (not tighten-ok)
        (delete-clause-index-scan scan)
        (return (Source-Clause-Datom-Stream {}) false tighten-error)))
    (let [[tighten-ok tighten-error] (physical-op-tighten-db-read-source-eavt-ea-value-scan! source (addr scan) clause-value op rel row)]
      (when (not tighten-ok)
        (delete-clause-index-scan scan)
        (return (Source-Clause-Datom-Stream {}) false tighten-error)))
    (source-clause-datom-stream-for-scan source scan)))

(defn db-read-source-clause-candidates-for-typed-row-with-op [source: DB-Read-Source, rel: Query-Relation, row: int, clause-value: Clause, op: Physical-Op] -> [datoms: [dynamic]Datom, scan: Clause-Index-Scan, ok: bool, error: string]
  (let [[candidate-scan scan-ok scan-error] (db-read-source-clause-index-scan-typed-row source rel row clause-value)]
    (when (not scan-ok)
      (delete-clause-index-scan candidate-scan)
      (return (make [dynamic]Datom) (db-read-source-empty-clause-index-scan source) false scan-error))
    (let [[tighten-ok tighten-error] (physical-op-tighten-db-read-source-attr-value-scan! source (addr candidate-scan) clause-value op rel row)]
      (when (not tighten-ok)
        (delete-clause-index-scan candidate-scan)
        (return (make [dynamic]Datom) (db-read-source-empty-clause-index-scan source) false tighten-error)))
    (let [[tighten-ok tighten-error] (physical-op-tighten-db-read-source-eavt-ea-value-scan! source (addr candidate-scan) clause-value op rel row)]
      (when (not tighten-ok)
        (delete-clause-index-scan candidate-scan)
        (return (make [dynamic]Datom) (db-read-source-empty-clause-index-scan source) false tighten-error)))
    (let [out (make [dynamic]Datom)
          scan-source (if (= source.kind .Tx-Ops-Overlay) source.overlay-base^ source)
          scan-index candidate-scan.index]
      (if (source-clause-scan-should-use-index-stream? candidate-scan)
        (let [stream-scan (clause-index-scan-clone candidate-scan)
              [stream stream-ok stream-error] (source-clause-datom-stream-for-scan scan-source stream-scan)]
          (when (not stream-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) candidate-scan false stream-error))
          (while stream.has-current
            (arr.push! out (datom-owned stream.current))
            (let [[advance-ok advance-error] (advance-source-clause-datom-stream! scan-source (addr stream))]
              (when (not advance-ok)
                (delete-source-clause-datom-stream stream)
                (delete-owned-datoms out)
                (return (make [dynamic]Datom) candidate-scan false advance-error))))
          (delete-source-clause-datom-stream stream))
        (while (< scan-index candidate-scan.high)
          (let [entry (clause-index-scan-datom-index candidate-scan scan-index)
                [datom datom-ok datom-error] (db-read-source-datom-at-entry scan-source entry)]
            (when (not datom-ok)
              (delete-owned-datoms out)
              (return (make [dynamic]Datom) candidate-scan false datom-error))
            (if (db-read-source-clause-index-scan-candidate? candidate-scan datom)
              (let [[current current-ok current-error] (db-read-source-datom-current-at-entry? scan-source entry)]
                (when (not current-ok)
                  (delete-owned-datom datom)
                  (delete-owned-datoms out)
                  (return (make [dynamic]Datom) candidate-scan false current-error))
                (if current
                  (arr.push! out datom)
                  (delete-owned-datom datom)))
              (delete-owned-datom datom)))
          (set! scan-index (+ scan-index 1))))
      (if (= source.kind .Tx-Ops-Overlay)
        (db-read-source-apply-overlay-ops-for-clause-scan! (addr out) source candidate-scan)
        (when (db-read-source-has-inline-overlay? source)
          (db-read-source-apply-inline-overlay-for-clause-scan! (addr out) source candidate-scan)))
      (return out candidate-scan true ""))))

(defn source-clause-datom-stream [source: DB-Read-Source, clause-value: Clause] -> [stream: Source-Clause-Datom-Stream, ok: bool, error: string]
  (let [binding (Binding {items: (make [dynamic]Var-Binding)})
        [out-stream stream-ok stream-error] (source-clause-datom-stream-for-binding source clause-value binding)]
    (delete binding.items)
    (return out-stream stream-ok stream-error)))

(defn advance-source-clause-datom-stream! [source: DB-Read-Source, stream: ^Source-Clause-Datom-Stream] -> [ok: bool, error: string]
  (if stream^.use-index-stream
    (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream^.index-stream))]
      (when (not advance-ok)
        (return false advance-error)))
    (set! stream^.index (+ stream^.index 1)))
  (load-source-clause-datom-stream-current! source stream))

(defn source-index-datom-stream [source: DB-Read-Source, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values ([]Value [(value-keyword attr)])]
    (source-index-datom-stream-for-values source .AEVT values)))

(defn source-avet-attr-value-stream [source: DB-Read-Source, attr: string, value: Value] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values ([]Value [(value-keyword attr) value])]
    (source-index-datom-stream-for-values source .AVET values)))

(defn source-attr-scan-stream [source: DB-Read-Source, attr: string, has-value: bool, value: Value] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (if has-value
    (source-avet-attr-value-stream source attr value)
    (source-index-datom-stream source attr)))

(defstruct Source-Attr-Value-Match-Stream {
  exact-stream: Source-Index-Datom-Stream
  attr-stream: Source-Index-Datom-Stream
  resolved: Value
  use-fallback: bool
  has-current: bool
})

(defn source-attr-value-match-current [stream: Source-Attr-Value-Match-Stream] -> Datom
  (if stream.use-fallback
    stream.attr-stream.current
    stream.exact-stream.current))

(defn delete-source-attr-value-match-stream [stream: Source-Attr-Value-Match-Stream]
  (delete-source-index-datom-stream stream.exact-stream)
  (delete-source-index-datom-stream stream.attr-stream))

(defn load-source-attr-value-match-fallback-current! [source: DB-Read-Source, stream: ^Source-Attr-Value-Match-Stream] -> [ok: bool, error: string]
  (set! stream^.has-current false)
  (while stream^.attr-stream.has-current
    (when (= (index-position-compare stream^.attr-stream.current.v stream^.resolved) 0)
      (set! stream^.has-current true)
      (return true ""))
    (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream^.attr-stream))]
      (when (not advance-ok)
        (return false advance-error))))
  (return true ""))

(defn source-attr-value-match-stream [source: DB-Read-Source, attr: string, value: Value] -> [stream: Source-Attr-Value-Match-Stream, ok: bool, error: string]
  (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-clause-value-for-attr source attr value)]
    (when (not resolved-ok)
      (return (Source-Attr-Value-Match-Stream {}) false resolved-error))
    (let [[exact exact-ok exact-error] (source-avet-attr-value-stream source attr resolved)]
      (when (not exact-ok)
        (return (Source-Attr-Value-Match-Stream {}) false exact-error))
      (when exact.has-current
        (return (Source-Attr-Value-Match-Stream {exact-stream: exact resolved: resolved use-fallback: false has-current: true}) true ""))
      (let [[attr-stream attr-ok attr-error] (source-index-datom-stream source attr)]
        (when (not attr-ok)
          (delete-source-index-datom-stream exact)
          (return (Source-Attr-Value-Match-Stream {}) false attr-error))
        (let [out (Source-Attr-Value-Match-Stream {exact-stream: exact attr-stream: attr-stream resolved: resolved use-fallback: true has-current: false})
              [load-ok load-error] (load-source-attr-value-match-fallback-current! source (addr out))]
          (if load-ok
            (return out true "")
            (return out false load-error)))))))

(defn advance-source-attr-value-match-stream! [source: DB-Read-Source, stream: ^Source-Attr-Value-Match-Stream] -> [ok: bool, error: string]
  (if stream^.use-fallback
    (do
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream^.attr-stream))]
        (when (not advance-ok)
          (return false advance-error)))
      (load-source-attr-value-match-fallback-current! source stream))
    (do
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream^.exact-stream))]
        (when (not advance-ok)
          (return false advance-error)))
      (set! stream^.has-current stream^.exact-stream.has-current)
      (return true ""))))

(defn source-entity-int-pair-append-filter-stream! [columns: ^Entity-Int-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, stream: ^Source-Attr-Value-Match-Stream, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (while stream^.has-current
    (let [filter-datom (source-attr-value-match-current stream^)
          [append-ok type-ok append-error] (source-entity-int-pair-append-filter-datom! columns seen source filter-datom value-attr many)]
      (when (not append-ok)
        (return false false append-error))
      (when (not type-ok)
        (return true false "")))
    (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source stream)]
      (when (not advance-ok)
        (return false false advance-error))))
  (return true true ""))

(defn source-entity-string-pair-append-filter-stream! [columns: ^Entity-String-Pair-Columns, seen: (ptr (map string (struct {}))), source: DB-Read-Source, stream: ^Source-Attr-Value-Match-Stream, value-attr: string, many: bool] -> [ok: bool, type-ok: bool, error: string]
  (while stream^.has-current
    (let [filter-datom (source-attr-value-match-current stream^)
          [append-ok type-ok append-error] (source-entity-string-pair-append-filter-datom! columns seen source filter-datom value-attr many)]
      (when (not append-ok)
        (return false false append-error))
      (when (not type-ok)
        (return true false "")))
    (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source stream)]
      (when (not advance-ok)
        (return false false advance-error))))
  (return true true ""))

(defn source-entity-string-int-triple-append-filter-stream! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, stream: ^Source-Attr-Value-Match-Stream, plan: Entity-Two-Value-Plan, best-filter-index: int] -> [ok: bool, type-ok: bool, error: string]
  (while stream^.has-current
    (let [filter-datom (source-attr-value-match-current stream^)
          [append-ok type-ok append-error] (source-entity-string-int-triple-append-filter-datom! columns seen source filter-datom plan best-filter-index)]
      (when (not append-ok)
        (return false false append-error))
      (when (not type-ok)
        (return true false "")))
    (let [[advance-ok advance-error] (advance-source-attr-value-match-stream! source stream)]
      (when (not advance-ok)
        (return false false advance-error))))
  (return true true ""))

(defn source-eavt-entity-attr-stream [source: DB-Read-Source, entity: u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values ([]Value [(value-entity entity) (value-keyword attr)])]
    (source-index-datom-stream-for-values source .EAVT values)))

(defn source-eavt-entity-stream [source: DB-Read-Source, entity: u64] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values ([]Value [(value-entity entity)])]
    (source-index-datom-stream-for-values source .EAVT values)))

(defn source-vaet-entity-attr-stream [source: DB-Read-Source, entity: u64, attr: string] -> [stream: Source-Index-Datom-Stream, ok: bool, error: string]
  (let [values ([]Value [(value-entity entity) (value-keyword attr)])]
    (source-index-datom-stream-for-values source .VAET values)))

(defn append-source-entity-attr-option-values! [option-row: ^Result-Row, source: DB-Read-Source, entity: u64, attr: string] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (arr.push! option-row^.values (value-owned stream.current.v))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-distinct-source-entity-attr-value-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, entity: u64, attr: string] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (not (row-values-exist? (slice rows^ 0) ([]Value [stream.current.v])))
        (append-distinct-single-value-row! rows (value-owned stream.current.v)))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn source-index-datom-streams-active? [streams: []Source-Index-Datom-Stream] -> bool
  (for [stream streams]
    (when (not stream.has-current)
      (return false)))
  true)

(defn source-index-datom-streams-same-entity? [streams: []Source-Index-Datom-Stream] -> bool
  (when (= (count streams) 0)
    (return false))
  (let [entity streams[0].current.e]
    (for [stream streams]
      (when (not (= stream.current.e entity))
        (return false)))
    true))

(defn source-index-datom-streams-max-entity [streams: []Source-Index-Datom-Stream] -> u64
  (let [entity streams[0].current.e]
    (for [stream streams]
      (when (> stream.current.e entity)
        (set! entity stream.current.e)))
    entity))

(defn advance-source-index-datom-streams-to-entity! [source: DB-Read-Source, streams: ^[dynamic]Source-Index-Datom-Stream, entity: u64] -> [ok: bool, error: string]
  (for [_ stream-index streams^]
    (while (and streams^[stream-index].has-current
                (< streams^[stream-index].current.e entity))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr streams^[stream-index]))]
        (when (not load-ok)
          (return false load-error)))))
  (return true ""))

(defn q-db-read-source-two-attr-entity-projection-cardinality-one-merge [source: DB-Read-Source, query: Query, projection: Two-Attr-Entity-Projection] -> Result-Set
  (let [[first-count first-count-ok _first-count-error] (db-read-source-attr-range-entry-count source projection.first-attr)
        [second-count second-count-ok _second-count-error] (db-read-source-attr-range-entry-count source projection.second-attr)
        row-capacity (if (and first-count-ok second-count-ok) (min first-count second-count) 0)
        rows (make [dynamic]Result-Row 0 row-capacity)
        seen (two-primitive-seen)
        streams (make [dynamic]Source-Index-Datom-Stream)]
    (defer (delete-two-primitive-seen seen))
    (let [[first-stream first-ok first-error] (source-index-datom-stream source projection.first-attr)]
      (when (not first-ok)
        (delete streams)
        (delete-result-rows-owned-values rows)
        (return (result-set-error first-error)))
      (arr.push! streams first-stream))
    (let [[second-stream second-ok second-error] (source-index-datom-stream source projection.second-attr)]
      (when (not second-ok)
        (delete-source-index-datom-streams streams)
        (delete-result-rows-owned-values rows)
        (return (result-set-error second-error)))
      (arr.push! streams second-stream))
    (while (source-index-datom-streams-active? (slice streams 0))
      (if (source-index-datom-streams-same-entity? (slice streams 0))
        (do
          (append-db-read-source-two-attr-projection-row! (addr rows) (addr seen) query projection streams[0].current.v streams[1].current.v)
          (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
            (when (not advance-ok)
              (delete-source-index-datom-streams streams)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
          (when (not advance-ok)
            (delete-source-index-datom-streams streams)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error))))))
    (delete-source-index-datom-streams streams)
    (result-set-ok rows)))

(defn db-read-source-two-attr-can-merge-cardinality-one? [source: DB-Read-Source, projection: Two-Attr-Entity-Projection] -> [ok: bool, error: string]
  (let [[first-many first-many-ok first-many-error] (db-read-source-schema-cardinality-many? source projection.first-attr)]
    (when (not first-many-ok)
      (return false first-many-error))
    (let [[second-many second-many-ok second-many-error] (db-read-source-schema-cardinality-many? source projection.second-attr)]
      (when (not second-many-ok)
        (return false second-many-error))
      (return (and (not first-many)
                   (not second-many))
              ""))))

(defn db-read-source-query-relation-two-attr-cardinality-one-merge-row! [builder: ^Query-Relation-Builder, query: Query, projection: Two-Attr-Entity-Projection, first-value-source: Value, second-value-source: Value] -> [ok: bool, error: string]
  (let [first-value (if (= query.find[0] projection.first-var) first-value-source second-value-source)
        second-value (if (= query.find[1] projection.second-var) second-value-source first-value-source)]
    (when (not (query-relation-builder-add-two-borrowed-values! builder first-value second-value))
      (return false "source two-attr projection produced unsupported typed relation values"))
    (return true "")))

(defn db-read-source-query-relation-two-attr-cardinality-one-merge [source: DB-Read-Source, query: Query, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [[projection projection-ok] (db-read-source-query-two-attr-entity-projection query)]
    (when (not projection-ok)
      (return (query-relation-empty) false ""))
    (let [[merge-ok merge-error] (db-read-source-two-attr-can-merge-cardinality-one? source projection)]
      (when (not (= merge-error ""))
        (return (query-relation-empty) false merge-error))
      (when (not merge-ok)
        (return (query-relation-empty) false "")))
    (let [attrs (arr.into [dynamic]string (slice query.find 0))
          attr-sources (make [dynamic]string 0 (count query.find))
          streams (make [dynamic]Source-Index-Datom-Stream)]
      (for [_ query.find]
        (arr.push! attr-sources ""))
      (let [[first-stream first-ok first-error] (source-index-datom-stream source projection.first-attr)]
        (when (not first-ok)
          (delete attrs)
          (delete attr-sources)
          (delete streams)
          (return (query-relation-empty) false first-error))
        (arr.push! streams first-stream))
      (let [[second-stream second-ok second-error] (source-index-datom-stream source projection.second-attr)]
        (when (not second-ok)
          (delete attrs)
          (delete attr-sources)
          (delete-source-index-datom-streams streams)
          (return (query-relation-empty) false second-error))
        (arr.push! streams second-stream))
      (let [[first-count first-count-ok _first-count-error] (db-read-source-attr-range-entry-count source projection.first-attr)
            [second-count second-count-ok _second-count-error] (db-read-source-attr-range-entry-count source projection.second-attr)
            row-capacity (if (and first-count-ok second-count-ok) (min first-count second-count) 0)
            builder (query-relation-builder-with-capacity (slice attrs 0) row-capacity)]
        (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
        (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
        (query-stats-observe-source-operator! stats)
        (while (source-index-datom-streams-active? (slice streams 0))
          (if (source-index-datom-streams-same-entity? (slice streams 0))
            (do
              (let [[append-ok append-error] (db-read-source-query-relation-two-attr-cardinality-one-merge-row! (addr builder) query projection streams[0].current.v streams[1].current.v)]
                (when (not append-ok)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (delete-source-index-datom-streams streams)
                  (return (query-relation-empty) false append-error)))
              (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
                (when (not advance-ok)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (delete-source-index-datom-streams streams)
                  (return (query-relation-empty) false advance-error))))
            (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
              (when (not advance-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (delete-source-index-datom-streams streams)
                (return (query-relation-empty) false advance-error)))))
        (delete-source-index-datom-streams streams)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok})
                true
                "")))))

(defn q-db-read-source-two-attr-entity-projection [source: DB-Read-Source, query: Query, projection: Two-Attr-Entity-Projection] -> Result-Set
  (let [[merge-ok merge-error] (db-read-source-two-attr-can-merge-cardinality-one? source projection)]
    (when (not (= merge-error ""))
      (return (result-set-error merge-error)))
    (when merge-ok
      (return (q-db-read-source-two-attr-entity-projection-cardinality-one-merge source query projection))))
  (let [rows (make [dynamic]Result-Row)
        seen (two-primitive-seen)
        use-second-driver (db-read-source-two-attr-use-second-driver? source projection)
        driver-attr (if use-second-driver projection.second-attr projection.first-attr)
        lookup-attr (if use-second-driver projection.first-attr projection.second-attr)
        [many many-ok many-error] (db-read-source-schema-cardinality-many? source lookup-attr)]
    (defer (delete-two-primitive-seen seen))
    (when (not many-ok)
      (return (result-set-error many-error)))
    (if (db-read-source-has-overlay? source)
      (let [[driver-datoms driver-ok driver-error] (db-read-source-datoms-by-attr source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (defer (delete-owned-datoms driver-datoms))
        (for [driver-datom driver-datoms]
          (let [[append-ok append-error] (append-db-read-source-other-attr-projection-values! (addr rows) (addr seen) source query projection driver-datom (not use-second-driver) many)]
            (when (not append-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))))
      (let [[driver-stream driver-ok driver-error] (source-index-datom-stream source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (while driver-stream.has-current
          (let [[append-ok append-error] (append-db-read-source-other-attr-projection-values! (addr rows) (addr seen) source query projection driver-stream.current (not use-second-driver) many)]
            (when (not append-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr driver-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (delete-source-index-datom-stream driver-stream)))
    (result-set-ok rows)))

(defn source-three-attr-projection-attr [projection: Source-Three-Attr-Entity-Projection, index: int] -> string
  (cond
    (= index 0) projection.first-attr
    (= index 1) projection.second-attr
    :else projection.third-attr))

(defn source-three-attr-projection-var [projection: Source-Three-Attr-Entity-Projection, index: int] -> string
  (cond
    (= index 0) projection.first-var
    (= index 1) projection.second-var
    :else projection.third-var))

(defn source-three-attr-driver-index [source: DB-Read-Source, projection: Source-Three-Attr-Entity-Projection] -> int
  (when (db-read-source-has-overlay? source)
    (return 0))
  (let [[first-count first-ok _] (db-read-source-attr-range-entry-count source projection.first-attr)
        [second-count second-ok _] (db-read-source-attr-range-entry-count source projection.second-attr)
        [third-count third-ok _] (db-read-source-attr-range-entry-count source projection.third-attr)
        best-index 0
        best-count first-count]
    (when (not (and first-ok second-ok third-ok))
      (return 0))
    (when (< second-count best-count)
      (set! best-index 1)
      (set! best-count second-count))
    (when (< third-count best-count)
      (set! best-index 2))
    best-index))

(defn source-three-attr-value-for-var [projection: Source-Three-Attr-Entity-Projection, name: string, first-value: Value, second-value: Value, third-value: Value] -> Value
  (cond
    (= name projection.first-var) first-value
    (= name projection.second-var) second-value
    :else third-value))

(defn append-db-read-source-three-attr-projection-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Three-Attr-Entity-Projection, first-value: Value, second-value: Value, third-value: Value]
  (let [out-first (source-three-attr-value-for-var projection query.find[0] first-value second-value third-value)
        out-second (source-three-attr-value-for-var projection query.find[1] first-value second-value third-value)
        out-third (source-three-attr-value-for-var projection query.find[2] first-value second-value third-value)
        dedupe-values ([]Value [out-first out-second out-third])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-three-value-row! rows (value-owned out-first) (value-owned out-second) (value-owned out-third)))))

(defn append-db-read-source-three-attr-driver-row! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Three-Attr-Entity-Projection, driver-index: int, driver-datom: Datom] -> [ok: bool, error: string]
  (let [first-lookup-index (if (= driver-index 0) 1 0)
        second-lookup-index (if (= driver-index 2) 1 2)
        first-lookup-attr (source-three-attr-projection-attr projection first-lookup-index)
        second-lookup-attr (source-three-attr-projection-attr projection second-lookup-index)]
    (if (db-read-source-has-overlay? source)
      (let [[first-datoms first-ok first-error] (db-read-source-datoms-by-entity-attr source driver-datom.e first-lookup-attr)]
        (when (not first-ok)
          (return false first-error))
        (let [[second-datoms second-ok second-error] (db-read-source-datoms-by-entity-attr source driver-datom.e second-lookup-attr)]
          (when (not second-ok)
            (delete-owned-datoms first-datoms)
            (return false second-error))
          (for [first-datom first-datoms]
            (for [second-datom second-datoms]
              (let [first-value (cond
                                  (= driver-index 0) driver-datom.v
                                  (= first-lookup-index 0) first-datom.v
                                  :else second-datom.v)
                    second-value (cond
                                   (= driver-index 1) driver-datom.v
                                   (= first-lookup-index 1) first-datom.v
                                   :else second-datom.v)
                    third-value (cond
                                  (= driver-index 2) driver-datom.v
                                  (= first-lookup-index 2) first-datom.v
                                  :else second-datom.v)]
                (append-db-read-source-three-attr-projection-row! rows query projection first-value second-value third-value))))
          (delete-owned-datoms first-datoms)
          (delete-owned-datoms second-datoms)
          (return true "")))
      (let [[first-stream first-ok first-error] (source-eavt-entity-attr-stream source driver-datom.e first-lookup-attr)]
        (when (not first-ok)
          (return false first-error))
        (while first-stream.has-current
          (let [[second-stream second-ok second-error] (source-eavt-entity-attr-stream source driver-datom.e second-lookup-attr)]
            (when (not second-ok)
              (delete-source-index-datom-stream first-stream)
              (return false second-error))
            (while second-stream.has-current
              (let [first-value (cond
                                  (= driver-index 0) driver-datom.v
                                  (= first-lookup-index 0) first-stream.current.v
                                  :else second-stream.current.v)
                    second-value (cond
                                   (= driver-index 1) driver-datom.v
                                   (= first-lookup-index 1) first-stream.current.v
                                   :else second-stream.current.v)
                    third-value (cond
                                  (= driver-index 2) driver-datom.v
                                  (= first-lookup-index 2) first-stream.current.v
                                  :else second-stream.current.v)]
                (append-db-read-source-three-attr-projection-row! rows query projection first-value second-value third-value))
              (let [[second-advance-ok second-advance-error] (advance-source-index-datom-stream! source (addr second-stream))]
                (when (not second-advance-ok)
                  (delete-source-index-datom-stream second-stream)
                  (delete-source-index-datom-stream first-stream)
                  (return false second-advance-error))))
            (delete-source-index-datom-stream second-stream))
          (let [[first-advance-ok first-advance-error] (advance-source-index-datom-stream! source (addr first-stream))]
            (when (not first-advance-ok)
              (delete-source-index-datom-stream first-stream)
              (return false first-advance-error))))
        (delete-source-index-datom-stream first-stream)
        (return true "")))))

(defn db-read-source-three-attr-can-merge-cardinality-one? [source: DB-Read-Source, projection: Source-Three-Attr-Entity-Projection] -> [ok: bool, error: string]
  (for [index (arr.range 0 3)]
    (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source (source-three-attr-projection-attr projection index))]
      (when (not many-ok)
        (return false many-error))
      (when many
        (return false ""))))
  (return true ""))

(defn q-db-read-source-three-attr-entity-projection-cardinality-one-merge [source: DB-Read-Source, query: Query, projection: Source-Three-Attr-Entity-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        streams (make [dynamic]Source-Index-Datom-Stream)]
    (let [[first-stream first-ok first-error] (source-index-datom-stream source projection.first-attr)]
      (when (not first-ok)
        (delete streams)
        (delete-result-rows-owned-values rows)
        (return (result-set-error first-error)))
      (arr.push! streams first-stream))
    (let [[second-stream second-ok second-error] (source-index-datom-stream source projection.second-attr)]
      (when (not second-ok)
        (delete-source-index-datom-streams streams)
        (delete-result-rows-owned-values rows)
        (return (result-set-error second-error)))
      (arr.push! streams second-stream))
    (let [[third-stream third-ok third-error] (source-index-datom-stream source projection.third-attr)]
      (when (not third-ok)
        (delete-source-index-datom-streams streams)
        (delete-result-rows-owned-values rows)
        (return (result-set-error third-error)))
      (arr.push! streams third-stream))
    (while (source-index-datom-streams-active? (slice streams 0))
      (if (source-index-datom-streams-same-entity? (slice streams 0))
        (do
          (append-db-read-source-three-attr-projection-row! (addr rows) query projection streams[0].current.v streams[1].current.v streams[2].current.v)
          (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
            (when (not advance-ok)
              (delete-source-index-datom-streams streams)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
          (when (not advance-ok)
            (delete-source-index-datom-streams streams)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error))))))
    (delete-source-index-datom-streams streams)
    (result-set-ok rows)))

(defn db-read-source-query-relation-three-attr-cardinality-one-merge-row! [builder: ^Query-Relation-Builder, query: Query, projection: Source-Three-Attr-Entity-Projection, first-value-source: Value, second-value-source: Value, third-value-source: Value] -> [ok: bool, error: string]
  (let [values (make [dynamic]Value 0 (count query.find))]
    (for [find-var query.find]
      (arr.push! values (source-three-attr-value-for-var projection find-var first-value-source second-value-source third-value-source)))
    (when (not (query-relation-builder-add-column-row-with-values! builder ([]Relation-Column []) 0 (slice values 0)))
      (delete values)
      (return false "source three-attr projection produced unsupported typed relation values"))
    (delete values)
    (return true "")))

(defn db-read-source-query-relation-three-attr-cardinality-one-merge [source: DB-Read-Source, query: Query, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [[projection projection-ok] (db-read-source-query-three-attr-entity-projection query)]
    (when (not projection-ok)
      (return (query-relation-empty) false ""))
    (let [[merge-ok merge-error] (db-read-source-three-attr-can-merge-cardinality-one? source projection)]
      (when (not (= merge-error ""))
        (return (query-relation-empty) false merge-error))
      (when (not merge-ok)
        (return (query-relation-empty) false "")))
    (let [attrs (arr.into [dynamic]string (slice query.find 0))
          attr-sources (make [dynamic]string 0 (count query.find))
          streams (make [dynamic]Source-Index-Datom-Stream)]
      (for [_ query.find]
        (arr.push! attr-sources ""))
      (let [[first-stream first-ok first-error] (source-index-datom-stream source projection.first-attr)]
        (when (not first-ok)
          (delete attrs)
          (delete attr-sources)
          (delete streams)
          (return (query-relation-empty) false first-error))
        (arr.push! streams first-stream))
      (let [[second-stream second-ok second-error] (source-index-datom-stream source projection.second-attr)]
        (when (not second-ok)
          (delete attrs)
          (delete attr-sources)
          (delete-source-index-datom-streams streams)
          (return (query-relation-empty) false second-error))
        (arr.push! streams second-stream))
      (let [[third-stream third-ok third-error] (source-index-datom-stream source projection.third-attr)]
        (when (not third-ok)
          (delete attrs)
          (delete attr-sources)
          (delete-source-index-datom-streams streams)
          (return (query-relation-empty) false third-error))
        (arr.push! streams third-stream))
      (let [builder (query-relation-builder (slice attrs 0))]
        (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
        (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
        (query-stats-observe-source-operator! stats)
        (while (source-index-datom-streams-active? (slice streams 0))
          (if (source-index-datom-streams-same-entity? (slice streams 0))
            (do
              (let [[append-ok append-error] (db-read-source-query-relation-three-attr-cardinality-one-merge-row! (addr builder) query projection streams[0].current.v streams[1].current.v streams[2].current.v)]
                (when (not append-ok)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (delete-source-index-datom-streams streams)
                  (return (query-relation-empty) false append-error)))
              (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
                (when (not advance-ok)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (delete-source-index-datom-streams streams)
                  (return (query-relation-empty) false advance-error))))
            (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
              (when (not advance-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (delete-source-index-datom-streams streams)
                (return (query-relation-empty) false advance-error)))))
        (delete-source-index-datom-streams streams)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok})
                true
                "")))))

(defn q-db-read-source-three-attr-entity-projection [source: DB-Read-Source, query: Query, projection: Source-Three-Attr-Entity-Projection] -> Result-Set
  (let [[merge-ok merge-error] (db-read-source-three-attr-can-merge-cardinality-one? source projection)]
    (when (not (= merge-error ""))
      (return (result-set-error merge-error)))
    (when merge-ok
      (return (q-db-read-source-three-attr-entity-projection-cardinality-one-merge source query projection))))
  (let [rows (make [dynamic]Result-Row)
        driver-index (source-three-attr-driver-index source projection)
        driver-attr (source-three-attr-projection-attr projection driver-index)]
    (if (db-read-source-has-overlay? source)
      (let [[driver-datoms driver-ok driver-error] (db-read-source-datoms-by-attr source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (defer (delete-owned-datoms driver-datoms))
        (for [driver-datom driver-datoms]
          (let [[append-ok append-error] (append-db-read-source-three-attr-driver-row! (addr rows) source query projection driver-index driver-datom)]
            (when (not append-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))))
      (let [[driver-stream driver-ok driver-error] (source-index-datom-stream source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (while driver-stream.has-current
          (let [[append-ok append-error] (append-db-read-source-three-attr-driver-row! (addr rows) source query projection driver-index driver-stream.current)]
            (when (not append-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr driver-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (delete-source-index-datom-stream driver-stream)))
    (result-set-ok rows)))

(defn db-read-source-star-attr-entity-projection-ready? [source: DB-Read-Source, query: Query] -> [ok: bool, error: string]
  (for [clause-value query.clauses]
    (let [[_ many-ok many-error] (db-read-source-schema-cardinality-many? source clause-value.a.value.text)]
      (when (not many-ok)
        (return false many-error))))
  (return true ""))

(defn source-star-attr-driver-index [source: DB-Read-Source, query: Query] -> int
  (let [best-index 0
        [first-count first-ok _] (db-read-source-attr-range-entry-count source query.clauses[0].a.value.text)
        best-count first-count
        i 1]
    (when (not first-ok)
      (return 0))
    (while (< i (count query.clauses))
      (let [[entry-count entry-ok _] (db-read-source-attr-range-entry-count source query.clauses[i].a.value.text)]
        (when (not entry-ok)
          (return best-index))
        (when (< entry-count best-count)
          (set! best-index i)
          (set! best-count entry-count)))
      (set! i (+ i 1)))
    best-index))

(defn source-star-clause-index-for-value-var [query: Query, name: string] -> [index: int, ok: bool]
  (let [i 0]
    (while (< i (count query.clauses))
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name name))
        (return i true))
      (set! i (+ i 1)))
    (return 0 false)))

(defn db-read-source-star-attr-options-for-clause [source: DB-Read-Source, query: Query, driver-index: int, driver-datom: Datom, clause-index: int] -> [option-row: Result-Row, ok: bool, error: string]
  (let [values (make [dynamic]Value)
        pulls (make [dynamic]Pull-Result)
        out-row (Result-Row {values: values pulls: pulls})]
    (if (= clause-index driver-index)
      (arr.push! out-row.values (value-owned driver-datom.v))
      (let [[option-ok option-error] (append-source-entity-attr-option-values! (addr out-row) source driver-datom.e query.clauses[clause-index].a.value.text)]
        (when (not option-ok)
          (delete out-row.values)
          (delete out-row.pulls)
          (return out-row false option-error))))
    (return out-row true "")))

(defn append-db-read-source-star-option-product! [rows: ^[dynamic]Result-Row, options: []Result-Row, index: int, prefix: []Value] -> [ok: bool, error: string]
  (when (= index (count options))
    (when (not (row-values-exist? (slice rows^ 0) prefix))
      (let [values (make [dynamic]Value 0 (count prefix))
            pulls (make [dynamic]Pull-Result)]
        (for [value prefix]
          (arr.push! values (value-owned value)))
        (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))
    (return true ""))
  (for [option options[index].values]
    (let [next (make [dynamic]Value 0 (+ (count prefix) 1))]
      (for [value prefix]
        (arr.push! next (value-owned value)))
      (arr.push! next (value-owned option))
      (let [[ok error] (append-db-read-source-star-option-product! rows options (+ index 1) (slice next 0))]
        (delete-owned-values-array next)
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn append-db-read-source-star-attr-entity-row! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, driver-index: int, driver-datom: Datom] -> [ok: bool, error: string]
  (let [options (make [dynamic]Result-Row)
        prefix (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[clause-index clause-ok] (source-star-clause-index-for-value-var query find-var)]
        (when (not clause-ok)
          (delete-result-rows-owned-values options)
          (delete prefix)
          (return false "source star projection find var missing from clauses"))
        (let [[option option-ok option-error] (db-read-source-star-attr-options-for-clause source query driver-index driver-datom clause-index)]
          (when (not option-ok)
            (delete-owned-values-array option.values)
            (delete option.pulls)
            (delete-result-rows-owned-values options)
            (delete prefix)
            (return false option-error))
          (arr.push! options option))))
    (let [[product-ok product-error] (append-db-read-source-star-option-product! rows (slice options 0) 0 (slice prefix 0))]
      (delete-result-rows-owned-values options)
      (delete prefix)
      (return product-ok product-error))))

(defn db-read-source-star-can-merge-cardinality-one? [source: DB-Read-Source, query: Query] -> [ok: bool, error: string]
  (for [clause-value query.clauses]
    (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source clause-value.a.value.text)]
      (when (not many-ok)
        (return false many-error))
      (when many
        (return false ""))))
  (return true ""))

(defn db-read-source-star-cardinality-one-streams [source: DB-Read-Source, query: Query] -> [streams: [dynamic]Source-Index-Datom-Stream, ok: bool, error: string]
  (let [out (make [dynamic]Source-Index-Datom-Stream)]
    (for [clause-value query.clauses]
      (let [[stream stream-ok stream-error] (source-index-datom-stream source clause-value.a.value.text)]
        (when (not stream-ok)
          (delete-source-index-datom-streams out)
          (return (make [dynamic]Source-Index-Datom-Stream) false stream-error))
        (arr.push! out stream)))
    (return out true "")))

(defn append-db-read-source-star-cardinality-one-merge-row! [rows: ^[dynamic]Result-Row, query: Query, streams: []Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (let [values (make [dynamic]Value 0 (count query.find))
        pulls (make [dynamic]Pull-Result)
        dedupe-values (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[clause-index clause-ok] (source-star-clause-index-for-value-var query find-var)]
        (when (not clause-ok)
          (delete values)
          (delete pulls)
          (delete dedupe-values)
          (return false "source star projection find var missing from clauses"))
        (let [value streams[clause-index].current.v]
          (arr.push! values (value-owned value))
          (arr.push! dedupe-values value))))
    (if (row-values-exist? (slice rows^ 0) (slice dedupe-values 0))
      (do
        (delete-owned-values-array values)
        (delete pulls))
      (arr.push! rows^ (Result-Row {values: values pulls: pulls})))
    (delete dedupe-values)
    (return true "")))

(defn q-db-read-source-star-attr-entity-projection-cardinality-one-merge [source: DB-Read-Source, query: Query] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [streams streams-ok streams-error] (db-read-source-star-cardinality-one-streams source query)]
    (when (not streams-ok)
      (return (result-set-error streams-error)))
    (while (source-index-datom-streams-active? (slice streams 0))
      (if (source-index-datom-streams-same-entity? (slice streams 0))
        (do
          (let [[append-ok append-error] (append-db-read-source-star-cardinality-one-merge-row! (addr rows) query (slice streams 0))]
            (when (not append-ok)
              (delete-source-index-datom-streams streams)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))
          (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
            (when (not advance-ok)
              (delete-source-index-datom-streams streams)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
          (when (not advance-ok)
            (delete-source-index-datom-streams streams)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error))))))
    (delete-source-index-datom-streams streams)
    (result-set-ok rows)))

(defn db-read-source-query-relation-star-cardinality-one-merge-row! [builder: ^Query-Relation-Builder, query: Query, streams: []Source-Index-Datom-Stream] -> [ok: bool, error: string]
  (let [values (make [dynamic]Value 0 (count query.find))]
    (for [find-var query.find]
      (let [[clause-index clause-ok] (source-star-clause-index-for-value-var query find-var)]
        (when (not clause-ok)
          (delete values)
          (return false "source star projection find var missing from clauses"))
        (arr.push! values streams[clause-index].current.v)))
    (when (not (query-relation-builder-add-column-row-with-values! builder ([]Relation-Column []) 0 (slice values 0)))
      (delete values)
      (return false "source star projection produced unsupported typed relation values"))
    (delete values)
    (return true "")))

(defn db-read-source-query-relation-star-cardinality-one-merge [source: DB-Read-Source, query: Query, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (when (not (db-read-source-query-star-attr-entity-projection? query))
    (return (query-relation-empty) false ""))
  (let [[merge-ok merge-error] (db-read-source-star-can-merge-cardinality-one? source query)]
    (when (not (= merge-error ""))
      (return (query-relation-empty) false merge-error))
    (when (not merge-ok)
      (return (query-relation-empty) false "")))
  (let [attrs (arr.into [dynamic]string (slice query.find 0))
        attr-sources (make [dynamic]string 0 (count query.find))
        [streams streams-ok streams-error] (db-read-source-star-cardinality-one-streams source query)]
    (when (not streams-ok)
      (delete attrs)
      (delete attr-sources)
      (return (query-relation-empty) false streams-error))
    (for [_ query.find]
      (arr.push! attr-sources ""))
    (let [builder (query-relation-builder (slice attrs 0))]
      (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
      (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
      (query-stats-observe-source-operator! stats)
      (while (source-index-datom-streams-active? (slice streams 0))
        (if (source-index-datom-streams-same-entity? (slice streams 0))
          (do
            (let [[append-ok append-error] (db-read-source-query-relation-star-cardinality-one-merge-row! (addr builder) query (slice streams 0))]
              (when (not append-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (delete-source-index-datom-streams streams)
                (return (query-relation-empty) false append-error)))
            (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (+ streams[0].current.e 1))]
              (when (not advance-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (delete-source-index-datom-streams streams)
                (return (query-relation-empty) false advance-error))))
          (let [[advance-ok advance-error] (advance-source-index-datom-streams-to-entity! source (addr streams) (source-index-datom-streams-max-entity (slice streams 0)))]
            (when (not advance-ok)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (delete-source-index-datom-streams streams)
              (return (query-relation-empty) false advance-error)))))
      (delete-source-index-datom-streams streams)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok})
              true
              ""))))

(defn db-read-source-query-relation-star-add-driver-row! [builder: ^Query-Relation-Builder, source: DB-Read-Source, query: Query, driver-index: int, driver-datom: Datom] -> [ok: bool, error: string]
  (let [options (make [dynamic]Result-Row)
        prefix (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[clause-index clause-ok] (source-star-clause-index-for-value-var query find-var)]
        (when (not clause-ok)
          (delete-result-rows-owned-values options)
          (delete prefix)
          (return false "source star projection find var missing from clauses"))
        (let [[option option-ok option-error] (db-read-source-star-attr-options-for-clause source query driver-index driver-datom clause-index)]
          (when (not option-ok)
            (delete-owned-values-array option.values)
            (delete option.pulls)
            (delete-result-rows-owned-values options)
            (delete prefix)
          (return false option-error))
          (arr.push! options option))))
    (let [[product-ok product-error] (db-read-source-query-relation-value-ref-star-add-product! builder (slice options 0) 0 (slice prefix 0))]
      (delete-result-rows-owned-values options)
      (delete prefix)
      (return product-ok product-error))))

(defn db-read-source-query-relation-star-attr-entity-projection [source: DB-Read-Source, query: Query, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (when (not (db-read-source-query-star-attr-entity-projection? query))
    (return (query-relation-empty) false ""))
  (let [[ready-ok ready-error] (db-read-source-star-attr-entity-projection-ready? source query)]
    (when (not ready-ok)
      (return (query-relation-empty) false ready-error)))
  (let [attrs (arr.into [dynamic]string (slice query.find 0))
        attr-sources (make [dynamic]string 0 (count query.find))
        driver-index (source-star-attr-driver-index source query)
        driver-attr query.clauses[driver-index].a.value.text]
    (for [_ query.find]
      (arr.push! attr-sources ""))
    (let [builder (query-relation-builder (slice attrs 0))]
      (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
      (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
      (query-stats-observe-source-operator! stats)
      (if (db-read-source-has-overlay? source)
        (let [[driver-datoms driver-ok driver-error] (db-read-source-datoms-by-attr source driver-attr)]
          (when (not driver-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false driver-error))
          (defer (delete-owned-datoms driver-datoms))
          (for [driver-datom driver-datoms]
            (let [[append-ok append-error] (db-read-source-query-relation-star-add-driver-row! (addr builder) source query driver-index driver-datom)]
              (when (not append-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false append-error)))))
        (let [[driver-stream driver-ok driver-error] (source-index-datom-stream source driver-attr)]
          (when (not driver-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false driver-error))
          (while driver-stream.has-current
            (let [[append-ok append-error] (db-read-source-query-relation-star-add-driver-row! (addr builder) source query driver-index driver-stream.current)]
              (when (not append-ok)
                (delete-source-index-datom-stream driver-stream)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false append-error)))
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr driver-stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream driver-stream)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false advance-error))))
          (delete-source-index-datom-stream driver-stream)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok})
              true
              ""))))

(defstruct Source-Ref-Chain-String-Length-Aggregate-Projection {
  root-var: string
  middle-var: string
  leaf-var: string
  text-var: string
  length-var: string
  group-var: string
  root-ref-attr: string
  middle-ref-attr: string
  leaf-value-attr: string
  group-attr: string
})

(defn fixed-keyword-attr-clause [clause-value: Clause] -> [attr: string, ok: bool]
  (when (and (not clause-value.has-source)
             (= clause-value.a.kind .Value)
             (= clause-value.a.value.kind .Keyword)
             (= clause-value.e.kind .Var)
             (= clause-value.v.kind .Var))
    (return clause-value.a.value.text true))
  (return "" false))

(defn aggregate-uses-var? [aggregate: Aggregate-Find, name: string] -> bool
  (when (= aggregate.var name)
    (return true))
  (when (= (count aggregate.args) 1)
    (return (and (= aggregate.args[0].kind .Var)
                 (= aggregate.args[0].name name))))
  false)

(defn query-ref-chain-string-length-aggregate-projection [query: Query] -> [projection: Source-Ref-Chain-String-Length-Aggregate-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 1)
                  (= (count query.clauses) 4)
                  (= (count query.function-clauses) 1)
                  (> (count query.aggregates) 0)
                  (= (count query.predicates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.pulls) 0)))
    (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
  (let [function query.function-clauses[0]]
    (when (not (and (= function.op "count")
                    (= (count function.terms) 1)
                    (= function.terms[0].kind .Var)
                    (= function.out-binding.kind .None)
                    (not function.is-tuple)
                    (not (= function.out ""))))
      (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
    (for [aggregate query.aggregates]
      (when (not (aggregate-uses-var? aggregate function.out))
        (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false)))
    (let [group-var query.find[0]
          leaf-var query.with[0]
          text-var function.terms[0].name
          length-var function.out
          leaf-value-attr ""
          middle-var ""
          middle-ref-attr ""
          root-var ""
          root-ref-attr ""
          group-attr ""
          leaf-ok false
          middle-ok false
          root-ok false
          group-ok false]
      (for [clause-value query.clauses]
        (let [[attr attr-ok] (fixed-keyword-attr-clause clause-value)]
          (when (not attr-ok)
            (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
          (when (= clause-value.v.name text-var)
            (set! leaf-ok true)
            (set! leaf-value-attr attr)
            (when (not (= clause-value.e.name leaf-var))
              (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false)))))
      (when (not leaf-ok)
        (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
      (for [clause-value query.clauses]
        (let [[attr _] (fixed-keyword-attr-clause clause-value)]
          (when (= clause-value.v.name leaf-var)
            (set! middle-ok true)
            (set! middle-var clause-value.e.name)
            (set! middle-ref-attr attr))))
      (when (not middle-ok)
        (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
      (for [clause-value query.clauses]
        (let [[attr _] (fixed-keyword-attr-clause clause-value)]
          (when (= clause-value.v.name middle-var)
            (set! root-ok true)
            (set! root-var clause-value.e.name)
            (set! root-ref-attr attr))))
      (when (not root-ok)
        (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
      (for [clause-value query.clauses]
        (let [[attr _] (fixed-keyword-attr-clause clause-value)]
          (when (and (= clause-value.e.name root-var)
                     (= clause-value.v.name group-var))
            (set! group-ok true)
            (set! group-attr attr))))
      (when (not group-ok)
        (return (Source-Ref-Chain-String-Length-Aggregate-Projection {}) false))
      (return (Source-Ref-Chain-String-Length-Aggregate-Projection {root-var: root-var
                                                                    middle-var: middle-var
                                                                    leaf-var: leaf-var
                                                                    text-var: text-var
                                                                    length-var: length-var
                                                                    group-var: group-var
                                                                    root-ref-attr: root-ref-attr
                                                                    middle-ref-attr: middle-ref-attr
                                                                    leaf-value-attr: leaf-value-attr
                                                                    group-attr: group-attr})
              true))))

(defn append-entity-int-link! [heads: ^map[u64]int, values: ^[dynamic]i64, nexts: ^[dynamic]int, entity: u64, value: i64]
  (let [[head found] (mmap.get heads^ entity)
        next (if found head -1)
        index (count values^)]
    (arr.push! values^ value)
    (arr.push! nexts^ next)
    (mmap.assoc! heads^ entity index)))

(defn add-source-ref-chain-int-links-from-parent! [source: DB-Read-Source, attr: string, parent-heads: ^map[u64]int, parent-values: ^[dynamic]i64, parent-nexts: ^[dynamic]int, child-heads: ^map[u64]int, child-values: ^[dynamic]i64, child-nexts: ^[dynamic]int, stats: ^Query-Stats] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-index-datom-stream source attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
      (when (= stream.current.v.kind .Entity)
        (let [[head found] (mmap.get parent-heads^ stream.current.e)]
          (when found
            (let [index head]
              (while (>= index 0)
                (append-entity-int-link! child-heads child-values child-nexts stream.current.v.entity parent-values^[index])
                (set! index parent-nexts^[index]))))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn db-read-source-query-relation-ref-chain-string-length-aggregate [source: DB-Read-Source, query: Query, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [[projection projection-ok] (query-ref-chain-string-length-aggregate-projection query)]
    (when (not projection-ok)
      (return (query-relation-empty) false ""))
    (when (db-read-source-has-overlay? source)
      (return (query-relation-empty) false ""))
    (let [root-year-heads (make (map u64 int)) :defer
          root-years (make [dynamic]i64) :defer
          root-year-nexts (make [dynamic]int) :defer
          middle-year-heads (make (map u64 int)) :defer
          middle-years (make [dynamic]i64) :defer
          middle-year-nexts (make [dynamic]int) :defer
          leaf-year-heads (make (map u64 int)) :defer
          leaf-years (make [dynamic]i64) :defer
          leaf-year-nexts (make [dynamic]int) :defer]
      (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
      (set! stats^.source-index-scans (+ stats^.source-index-scans 4))
      (query-stats-observe-source-operator! stats)
      (let [[group-stream group-ok group-error] (source-index-datom-stream source projection.group-attr)]
        (when (not group-ok)
          (return (query-relation-empty) false group-error))
        (while group-stream.has-current
          (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
          (when (= group-stream.current.v.kind .Int)
            (append-entity-int-link! (addr root-year-heads) (addr root-years) (addr root-year-nexts) group-stream.current.e group-stream.current.v.int-value))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr group-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream group-stream)
              (return (query-relation-empty) false advance-error))))
        (delete-source-index-datom-stream group-stream))
      (let [[root-ok root-error] (add-source-ref-chain-int-links-from-parent! source projection.root-ref-attr (addr root-year-heads) (addr root-years) (addr root-year-nexts) (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) stats)]
        (when (not root-ok)
          (return (query-relation-empty) false root-error)))
      (let [[middle-ok middle-error] (add-source-ref-chain-int-links-from-parent! source projection.middle-ref-attr (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) (addr leaf-year-heads) (addr leaf-years) (addr leaf-year-nexts) stats)]
        (when (not middle-ok)
          (return (query-relation-empty) false middle-error)))
      (let [attrs ([dynamic]string [projection.group-var projection.leaf-var projection.length-var])
            attr-sources ([dynamic]string ["" "" ""])
            builder (query-relation-builder (slice attrs 0))
            [leaf-stream leaf-ok leaf-error] (source-index-datom-stream source projection.leaf-value-attr)]
        (when (not leaf-ok)
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false leaf-error))
        (while leaf-stream.has-current
          (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
          (when (= leaf-stream.current.v.kind .String)
            (let [[head found] (mmap.get leaf-year-heads leaf-stream.current.e)]
              (when found
                (let [index head]
                  (while (>= index 0)
                    (let [values ([]Value [(value-int leaf-years[index])
                                            (value-entity leaf-stream.current.e)
                                            (value-int (i64 (string-clojure-count leaf-stream.current.v.text)))])]
                      (when (not (query-relation-builder-add-column-row-with-values! (addr builder) ([]Relation-Column []) 0 values))
                        (delete-source-index-datom-stream leaf-stream)
                        (delete attrs)
                        (delete attr-sources)
                        (delete-query-relation-builder builder)
                        (return (query-relation-empty) false "ref-chain string-length aggregate produced unsupported typed relation values")))
                      (set! index leaf-year-nexts[index]))))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr leaf-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream leaf-stream)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false advance-error))))
        (delete-source-index-datom-stream leaf-stream)
        (set! stats^.max-intermediate-bindings (max stats^.max-intermediate-bindings builder.typed-rows))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok})
                true
                "")))))

(defn source-ref-chain-string-length-var-value [projection: Source-Ref-Chain-String-Length-Aggregate-Projection, name: string, year: i64, leaf: u64, length: i64] -> [value: Value, ok: bool]
  (cond
    (= name projection.group-var) (return (value-int year) true)
    (= name projection.leaf-var) (return (value-entity leaf) true)
    (= name projection.length-var) (return (value-int length) true)
    :else (return (Value {}) false)))

(defn source-ref-chain-string-length-term-value [projection: Source-Ref-Chain-String-Length-Aggregate-Projection, term: Term, year: i64, leaf: u64, length: i64] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (source-ref-chain-string-length-var-value projection term.name year leaf length))
     (return (Value {}) false)))

(defn source-ref-chain-string-length-key-values [query: Query, projection: Source-Ref-Chain-String-Length-Aggregate-Projection, aggregate: Aggregate-Find, year: i64, leaf: u64, length: i64] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query.find]
      (let [[value value-ok] (source-ref-chain-string-length-var-value projection name year leaf length)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (for [name query.with]
      (let [[value value-ok] (source-ref-chain-string-length-var-value projection name year leaf length)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (if (> (count aggregate.args) 0)
      (for [arg aggregate.args]
        (let [[value value-ok] (source-ref-chain-string-length-term-value projection arg year leaf length)]
          (if value-ok
            (arr.push! out value)
            (return out false))))
      (let [[value value-ok] (source-ref-chain-string-length-var-value projection aggregate.var year leaf length)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn source-ref-chain-string-length-aggregate-supported? [query: Query, registry: []Native-Query-Fn] -> bool
  (for [aggregate query.aggregates]
    (when (not (aggregate-supported-from-typed-relation-with-fns? aggregate registry))
      (return false)))
  true)

(defn accumulate-source-ref-chain-string-length-row! [query: Query, projection: Source-Ref-Chain-String-Length-Aggregate-Projection, registry: []Native-Query-Fn, groups: ^[dynamic]Result-Row, group-index: ^map[string]int, states: ^[dynamic]Typed-Aggregate-Accumulator, year: i64, leaf: u64, length: i64] -> bool
  (let [group-values ([]Value [(value-int year)])
        [existing-index existing-ok _] (typed-aggregate-group-index (slice groups^ 0) group-index group-values)
        group-row (if existing-ok existing-index (append-typed-aggregate-group! groups group-index states query group-values))]
    (for [aggregate aggregate-index query.aggregates]
      (let [state-index (+ (* group-row (count query.aggregates)) aggregate-index)
            [key key-ok] (source-ref-chain-string-length-key-values query projection aggregate year leaf length)]
        (when (not key-ok)
          (delete key)
          (return false))
        (when (not (typed-aggregate-key-seen-or-add! (addr states^[state-index]) (slice key 0)))
          (let [[input-value input-ok] (source-ref-chain-string-length-var-value projection aggregate.var year leaf length)]
            (when input-ok
              (typed-aggregate-accumulate-value! (addr states^[state-index]) aggregate input-value))))
        (delete key)))
    true))

(defn accumulate-ref-chain-string-length-typed-tuple! [query: Query, groups: ^[dynamic]Result-Row, year-group-index: ^map[i64]int, states: ^[dynamic]Typed-Aggregate-Accumulator, seen-tuples: (ptr (map string (struct {}))), year: i64, leaf: u64, length: i64]
  (let [[existing-group existing-ok] (mmap.get year-group-index^ year)
        group-row (if existing-ok existing-group (count groups^))]
    (when (not existing-ok)
      (mmap.assoc! year-group-index^ year group-row)
      (arr.push! groups^ (aggregate-owned-key-row ([]Value [(value-int year)])))
      (for [aggregate query.aggregates]
        (arr.push! states^ (typed-aggregate-accumulator aggregate))))
    (let [seen-key (fmt.tprintf "%d/%d/%d" year leaf length)]
      (when (not (set.contains? seen-tuples^ seen-key))
        (set.add! seen-tuples^ seen-key)
        (for [aggregate aggregate-index query.aggregates]
          (let [state-index (+ (* group-row (count query.aggregates)) aggregate-index)]
            (typed-aggregate-accumulate-value! (addr states^[state-index]) aggregate (value-int length))))))))

(defn source-ref-chain-string-length-aggregate-result-rows [query: Query, registry: []Native-Query-Fn, groups: []Result-Row, states: []Typed-Aggregate-Accumulator] -> [rows: [dynamic]Result-Row, ok: bool]
  (let [out (make [dynamic]Result-Row)]
    (for [group group-row groups]
      (let [values (arr.into [dynamic]Value (slice group.values 0))
            aggregate-ok true]
        (for [aggregate aggregate-index query.aggregates]
          (when aggregate-ok
            (let [state-index (+ (* group-row (count query.aggregates)) aggregate-index)
                  [aggregate-value one-ok] (typed-aggregate-accumulator-value states[state-index] aggregate registry)]
              (if one-ok
                (arr.push! values aggregate-value)
                (set! aggregate-ok false)))))
        (if aggregate-ok
          (arr.push! out (Result-Row {values: values pulls: (make [dynamic]Pull-Result)}))
          (do
            (delete values)
            (return out false)))))
    (return out true)))

(defn add-db-ref-chain-int-links-from-parent! [db: DB, attr: string, parent-heads: ^map[u64]int, parent-values: ^[dynamic]i64, parent-nexts: ^[dynamic]int, child-heads: ^map[u64]int, child-values: ^[dynamic]i64, child-nexts: ^[dynamic]int, stats: ^Query-Stats]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 attr (Value {}))
        i low]
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity))
          (let [[head found] (mmap.get parent-heads^ datom.e)]
            (when found
              (let [index head]
                (while (>= index 0)
                  (append-entity-int-link! child-heads child-values child-nexts datom.v.entity parent-values^[index])
                  (set! index parent-nexts^[index])))))))
      (set! i (+ i 1)))))

(defn q-resident-db-ref-chain-string-length-aggregate [db: DB, query: Query, registry: []Native-Query-Fn] -> [result: Result-Set, stats: Query-Stats, used: bool]
  (let [out-stats (query-stats-empty)
        [projection projection-ok] (query-ref-chain-string-length-aggregate-projection query)]
    (when (not projection-ok)
      (return (result-set-error "") out-stats false))
    (when (not (source-ref-chain-string-length-aggregate-supported? query registry))
      (return (result-set-error "") out-stats false))
    (let [root-year-heads (make (map u64 int)) :defer
          root-years (make [dynamic]i64) :defer
          root-year-nexts (make [dynamic]int) :defer
          middle-year-heads (make (map u64 int)) :defer
          middle-years (make [dynamic]i64) :defer
          middle-year-nexts (make [dynamic]int) :defer
          leaf-year-heads (make (map u64 int)) :defer
          leaf-years (make [dynamic]i64) :defer
          leaf-year-nexts (make [dynamic]int) :defer
          groups (make [dynamic]Result-Row)
          year-group-index (mmap.empty i64 int) :defer
          states (make [dynamic]Typed-Aggregate-Accumulator)
          seen-tuples (set.empty string) :defer]
      (defer (delete-result-rows-owned-values groups))
      (defer (delete-typed-aggregate-accumulators states))
      (set! out-stats.steps (count query.where-steps))
      (set! out-stats.clauses (count query.clauses))
      (set! out-stats.source-index-scans 4)
      (query-stats-observe-source-operator! (addr out-stats))
      (let [view (db-index-view db .AEVT)
            low (lower-bound-index-view db view "aevt" 0 projection.group-attr (Value {}))
            high (upper-bound-index-view db view "aevt" 0 projection.group-attr (Value {}))
            i low]
        (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- high low)))
        (while (< i high)
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (and (datom-current-at? db datom-index)
                       (= datom.v.kind .Int))
              (append-entity-int-link! (addr root-year-heads) (addr root-years) (addr root-year-nexts) datom.e datom.v.int-value)))
          (set! i (+ i 1))))
      (add-db-ref-chain-int-links-from-parent! db projection.root-ref-attr (addr root-year-heads) (addr root-years) (addr root-year-nexts) (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) (addr out-stats))
      (add-db-ref-chain-int-links-from-parent! db projection.middle-ref-attr (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) (addr leaf-year-heads) (addr leaf-years) (addr leaf-year-nexts) (addr out-stats))
      (let [view (db-index-view db .AEVT)
            low (lower-bound-index-view db view "aevt" 0 projection.leaf-value-attr (Value {}))
            high (upper-bound-index-view db view "aevt" 0 projection.leaf-value-attr (Value {}))
            i low
            logical-rows 0]
        (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- high low)))
        (while (< i high)
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (and (datom-current-at? db datom-index)
                       (= datom.v.kind .String))
              (let [[head found] (mmap.get leaf-year-heads datom.e)]
                (when found
                  (let [index head
                        name-length (i64 (string-clojure-count datom.v.text))]
                    (while (>= index 0)
                      (set! logical-rows (+ logical-rows 1))
                      (accumulate-ref-chain-string-length-typed-tuple! query (addr groups) (addr year-group-index) (addr states) (addr seen-tuples) leaf-years[index] datom.e name-length)
                      (set! index leaf-year-nexts[index]))))))
          (set! i (+ i 1)))
        (set! out-stats.max-intermediate-bindings logical-rows))
      (let [[rows rows-ok] (source-ref-chain-string-length-aggregate-result-rows query registry (slice groups 0) (slice states 0))]
        (when (not rows-ok)
          (delete-result-rows-owned-values rows)
          (return (result-set-error "resident ref-chain string-length aggregate could not produce aggregate rows") out-stats true))
        (set! out-stats.output-rows (count rows))
        (return (result-set-ok rows) out-stats true))))))

(defn db-read-source-q-ref-chain-string-length-aggregate [source: DB-Read-Source, query: Query, registry: []Native-Query-Fn] -> [result: Result-Set, stats: Query-Stats, used: bool]
  (let [out-stats (query-stats-empty)
        [projection projection-ok] (query-ref-chain-string-length-aggregate-projection query)]
    (when (not projection-ok)
      (return (result-set-error "") out-stats false))
    (when (= source.kind .Resident)
      (return (q-resident-db-ref-chain-string-length-aggregate source.db^ query registry)))
    (when (or (db-read-source-has-overlay? source)
              (not (source-ref-chain-string-length-aggregate-supported? query registry)))
      (return (result-set-error "") out-stats false))
    (let [root-year-heads (make (map u64 int)) :defer
          root-years (make [dynamic]i64) :defer
          root-year-nexts (make [dynamic]int) :defer
          middle-year-heads (make (map u64 int)) :defer
          middle-years (make [dynamic]i64) :defer
          middle-year-nexts (make [dynamic]int) :defer
          leaf-year-heads (make (map u64 int)) :defer
          leaf-years (make [dynamic]i64) :defer
          leaf-year-nexts (make [dynamic]int) :defer
          groups (make [dynamic]Result-Row)
          year-group-index (mmap.empty i64 int) :defer
          states (make [dynamic]Typed-Aggregate-Accumulator)
          seen-tuples (set.empty string) :defer]
      (defer (delete-result-rows-owned-values groups))
      (defer (delete-typed-aggregate-accumulators states))
      (set! out-stats.steps (count query.where-steps))
      (set! out-stats.clauses (+ out-stats.clauses (count query.clauses)))
      (set! out-stats.source-index-scans (+ out-stats.source-index-scans 4))
      (query-stats-observe-source-operator! (addr out-stats))
      (let [[group-stream group-ok group-error] (source-index-datom-stream source projection.group-attr)]
        (when (not group-ok)
          (return (result-set-error group-error) out-stats true))
        (while group-stream.has-current
          (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
          (when (= group-stream.current.v.kind .Int)
            (append-entity-int-link! (addr root-year-heads) (addr root-years) (addr root-year-nexts) group-stream.current.e group-stream.current.v.int-value))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr group-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream group-stream)
              (return (result-set-error advance-error) out-stats true))))
        (delete-source-index-datom-stream group-stream))
      (let [[root-ok root-error] (add-source-ref-chain-int-links-from-parent! source projection.root-ref-attr (addr root-year-heads) (addr root-years) (addr root-year-nexts) (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) (addr out-stats))]
        (when (not root-ok)
          (return (result-set-error root-error) out-stats true)))
      (let [[middle-ok middle-error] (add-source-ref-chain-int-links-from-parent! source projection.middle-ref-attr (addr middle-year-heads) (addr middle-years) (addr middle-year-nexts) (addr leaf-year-heads) (addr leaf-years) (addr leaf-year-nexts) (addr out-stats))]
        (when (not middle-ok)
          (return (result-set-error middle-error) out-stats true)))
      (let [[leaf-stream leaf-ok leaf-error] (source-index-datom-stream source projection.leaf-value-attr)
            logical-rows 0]
        (when (not leaf-ok)
          (return (result-set-error leaf-error) out-stats true))
        (while leaf-stream.has-current
          (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
          (when (= leaf-stream.current.v.kind .String)
            (let [[head found] (mmap.get leaf-year-heads leaf-stream.current.e)]
              (when found
                  (let [index head
                        name-length (i64 (string-clojure-count leaf-stream.current.v.text))]
                  (while (>= index 0)
                    (set! logical-rows (+ logical-rows 1))
                    (accumulate-ref-chain-string-length-typed-tuple! query (addr groups) (addr year-group-index) (addr states) (addr seen-tuples) leaf-years[index] leaf-stream.current.e name-length)
                    (set! index leaf-year-nexts[index]))))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr leaf-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream leaf-stream)
              (return (result-set-error advance-error) out-stats true))))
        (delete-source-index-datom-stream leaf-stream)
        (set! out-stats.max-intermediate-bindings logical-rows))
      (let [[rows rows-ok] (source-ref-chain-string-length-aggregate-result-rows query registry (slice groups 0) (slice states 0))]
        (when (not rows-ok)
          (delete-result-rows-owned-values rows)
          (return (result-set-error "ref-chain string-length aggregate could not produce aggregate rows") out-stats true))
        (set! out-stats.output-rows (count rows))
        (return (result-set-ok rows) out-stats true)))))

(defn q-db-read-source-star-attr-entity-projection [source: DB-Read-Source, query: Query] -> Result-Set
  (let [[merge-ok merge-error] (db-read-source-star-can-merge-cardinality-one? source query)]
    (when (not (= merge-error ""))
      (return (result-set-error merge-error)))
    (when merge-ok
      (return (q-db-read-source-star-attr-entity-projection-cardinality-one-merge source query))))
  (let [rows (make [dynamic]Result-Row)
        driver-index (source-star-attr-driver-index source query)
        driver-attr query.clauses[driver-index].a.value.text]
    (if (db-read-source-has-overlay? source)
      (let [[driver-datoms driver-ok driver-error] (db-read-source-datoms-by-attr source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (defer (delete-owned-datoms driver-datoms))
        (for [driver-datom driver-datoms]
          (let [[append-ok append-error] (append-db-read-source-star-attr-entity-row! (addr rows) source query driver-index driver-datom)]
            (when (not append-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))))
      (let [[driver-stream driver-ok driver-error] (source-index-datom-stream source driver-attr)]
        (when (not driver-ok)
          (return (result-set-error driver-error)))
        (while driver-stream.has-current
          (let [[append-ok append-error] (append-db-read-source-star-attr-entity-row! (addr rows) source query driver-index driver-stream.current)]
            (when (not append-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error append-error))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr driver-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream driver-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (delete-source-index-datom-stream driver-stream)))
    (result-set-ok rows)))

(defn current-entity-attr-values [db: DB, attr: string, stats: ^Query-Stats] -> (map u64 Value)
  (let [out (make (map u64 Value))
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 attr (Value {}))]
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (let [i low]
      (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (mmap.assoc! out datom.e datom.v)))
      (set! i (+ i 1))))
    out))

(defn append-two-attr-entity-projection-cardinality-one-current-merge! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, db: DB, query: Query, projection: Two-Attr-Entity-Projection, stats: ^Query-Stats]
  (let [view (db-index-view db .AEVT)
        first-low (lower-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        first-high (upper-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        second-low (lower-bound-index-view db view "aevt" 0 projection.second-attr (Value {}))
        second-high (upper-bound-index-view db view "aevt" 0 projection.second-attr (Value {}))
        first-i first-low
        second-i second-low]
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- first-high first-low) (- second-high second-low)))
    (while (and (< first-i first-high) (< second-i second-high))
      (let [first-datom db.datoms[(db-index-view-at view first-i)]
            second-datom db.datoms[(db-index-view-at view second-i)]]
        (cond
          (< first-datom.e second-datom.e)
          (set! first-i (+ first-i 1))

          (> first-datom.e second-datom.e)
          (set! second-i (+ second-i 1))

          :else
          (do
            (append-two-attr-projection-row! rows seen query projection first-datom.v second-datom.v)
            (set! first-i (+ first-i 1))
            (set! second-i (+ second-i 1))))))))

(defn append-two-attr-entity-projection-cardinality-one! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, db: DB, query: Query, projection: Two-Attr-Entity-Projection, stats: ^Query-Stats]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        all-current (all-datoms-current? db)]
    (if all-current
      (append-two-attr-entity-projection-cardinality-one-current-merge! rows seen db query projection stats)
      (let [second-values (current-entity-attr-values db projection.second-attr stats)]
        (defer (delete second-values))
        (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
        (let [i low]
          (while (< i high)
          (let [first-index (db-index-view-at view i)
                first-datom db.datoms[first-index]]
            (when (datom-current-at? db first-index)
              (let [[second-value has-second] (mmap.get second-values first-datom.e)]
                (when has-second
                  (append-two-attr-projection-row! rows seen query projection first-datom.v second-value)))))
          (set! i (+ i 1))))))))

(defn q-two-attr-entity-projection-profiled [db: DB, query: Query, projection: Two-Attr-Entity-Projection, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        seen (two-primitive-seen)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 projection.first-attr (Value {}))
        rows (make [dynamic]Result-Row 0 (- high low))]
    (defer (delete-two-primitive-seen seen))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 2)
    (if (schema-cardinality-one? db projection.second-attr)
      (append-two-attr-entity-projection-cardinality-one! (addr rows) (addr seen) db query projection (addr out-stats))
      (let [i low]
        (while (< i high)
        (let [first-index (db-index-view-at view i)
              first-datom db.datoms[first-index]]
          (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
          (when (datom-current-at? db first-index)
            (let [entity-view (db-index-view db .EAVT)
                  second-low (lower-bound-index-view db entity-view "eavt-ea" first-datom.e projection.second-attr (Value {}))
                  second-high (upper-bound-index-view db entity-view "eavt-ea" first-datom.e projection.second-attr (Value {}))
                  j second-low]
              (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- second-high second-low)))
              (while (< j second-high)
                (let [second-index (db-index-view-at entity-view j)
                      second-datom db.datoms[second-index]]
                  (when (datom-current-at? db second-index)
                    (append-two-attr-projection-row! (addr rows) (addr seen) query projection first-datom.v second-datom.v)))
                (set! j (+ j 1))))))
        (set! i (+ i 1)))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn append-entity-attr-value-projection-row! [rows: ^[dynamic]Result-Row, seen: ^Two-Primitive-Seen, query: Query, projection: Entity-Attr-Value-Projection, entity: u64, value: Value]
  (let [entity-value (value-entity entity)
        first-value (if (= query.find[0] projection.entity-var) entity-value value)
        second-value (if (= query.find[1] projection.value-var) value entity-value)
        [added added-ok] (two-value-seen-add seen first-value second-value)]
    (if added-ok
      (when added
        (append-two-value-row! rows first-value second-value))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-two-value-row! rows first-value second-value))))))

(defn append-entity-attr-value-projection-row-raw! [rows: ^[dynamic]Result-Row, query: Query, projection: Entity-Attr-Value-Projection, entity: u64, value: Value]
  (let [entity-value (value-entity entity)
        first-value (if (= query.find[0] projection.entity-var) entity-value value)
        second-value (if (= query.find[1] projection.value-var) value entity-value)]
    (append-two-value-row! rows first-value second-value)))

(defn append-entity-attr-value-projection-cardinality-one-current-merge! [rows: ^[dynamic]Result-Row, db: DB, query: Query, projection: Entity-Attr-Value-Projection, stats: ^Query-Stats, filter-low: int, filter-high: int]
  (let [filter-view (db-index-view db .AVET)
        value-view (db-index-view db .AEVT)
        value-low (lower-bound-index-view db value-view "aevt" 0 projection.value-attr (Value {}))
        value-high (upper-bound-index-view db value-view "aevt" 0 projection.value-attr (Value {}))
        filter-i filter-low
        value-i value-low]
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- value-high value-low)))
    (while (and (< filter-i filter-high)
                (< value-i value-high))
      (let [filter-datom db.datoms[(db-index-view-at filter-view filter-i)]
            value-datom db.datoms[(db-index-view-at value-view value-i)]]
        (cond
          (< filter-datom.e value-datom.e)
            (set! filter-i (+ filter-i 1))
          (> filter-datom.e value-datom.e)
            (set! value-i (+ value-i 1))
          :else
            (do
              (append-entity-attr-value-projection-row-raw! rows query projection filter-datom.e value-datom.v)
              (set! filter-i (+ filter-i 1))
              (set! value-i (+ value-i 1))))))))

(defn q-entity-attr-value-projection-profiled [db: DB, query: Query, projection: Entity-Attr-Value-Projection, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        rows (make [dynamic]Result-Row)
        seen (two-primitive-seen)
        filter-view (db-index-view db .AVET)
        low (lower-bound-index-view db filter-view "avet" 0 projection.filter-attr projection.filter-value)
        high (upper-bound-index-view db filter-view "avet" 0 projection.filter-attr projection.filter-value)
        dedupe-required (not (and (all-datoms-current? db)
                                  (schema-cardinality-one? db projection.filter-attr)
                                  (schema-cardinality-one? db projection.value-attr)))]
    (defer (delete-two-primitive-seen seen))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 2)
    (set! out-stats.clause-candidates (- high low))
    (when (not dedupe-required)
      (append-entity-attr-value-projection-cardinality-one-current-merge! (addr rows) db query projection (addr out-stats) low high)
      (set! out-stats.max-intermediate-bindings (count rows))
      (set! out-stats.output-rows (count rows))
      (return (profiled-result-set (result-set-ok rows) out-stats)))
    (let [i low]
      (while (< i high)
      (let [filter-index (db-index-view-at filter-view i)
            filter-datom db.datoms[filter-index]]
        (when (datom-current-at? db filter-index)
          (let [entity-view (db-index-view db .EAVT)
                value-low (lower-bound-index-view db entity-view "eavt-ea" filter-datom.e projection.value-attr (Value {}))
                value-high (upper-bound-index-view db entity-view "eavt-ea" filter-datom.e projection.value-attr (Value {}))
                j value-low]
            (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- value-high value-low)))
            (while (< j value-high)
              (let [value-index (db-index-view-at entity-view j)
                    value-datom db.datoms[value-index]]
                (when (datom-current-at? db value-index)
                  (if dedupe-required
                    (append-entity-attr-value-projection-row! (addr rows) (addr seen) query projection filter-datom.e value-datom.v)
                    (append-entity-attr-value-projection-row-raw! (addr rows) query projection filter-datom.e value-datom.v))))
              (set! j (+ j 1))))))
      (set! i (+ i 1))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-query-entity-int-pair-columns [db: DB, query: Query, inputs: []Query-Input] -> [columns: Entity-Int-Pair-Columns, ok: bool]
  (let [out (empty-entity-int-pair-columns)]
    (let [[threshold-plan threshold-ok] (query-entity-int-threshold-plan db query inputs)]
      (when threshold-ok
        (delete-entity-int-pair-columns out)
        (return (q-query-entity-int-threshold-pair-columns db threshold-plan) true)))
    (when (> (count inputs) 0)
      (return out false))
    (let [[plan plan-ok] (query-entity-int-pair-plan db query)]
      (when (not plan-ok)
        (delete plan.filters)
        (return out false))
      (when (and (all-datoms-current? db)
                 (> (count plan.filters) 0))
        (let [output-attrs ([]string [plan.value-attr])
              streams (entity-star-streams-for-filters-and-outputs db (slice plan.filters 0) output-attrs)]
          (defer (delete streams))
          (while true
            (let [[entity entity-ok] (entity-star-streams-align! db (addr streams))]
              (when (not entity-ok)
                (delete plan.filters)
                (return out true))
              (let [[value value-ok] (entity-star-output-value db (slice streams 0) 0)]
                (when (and value-ok (= value.kind .Int))
                  (append-entity-int-pair-column! (addr out) entity value.int-value)))
              (entity-star-streams-advance-all! (addr streams))))))
      (let [filter-view (db-index-view db .AVET)
            best-filter-index 0
            best-low 0
            best-high 0]
        (let [filter-i 0]
          (while (< filter-i (count plan.filters))
          (let [filter plan.filters[filter-i]
                low (lower-bound-index-view db filter-view "avet" 0 filter.attr filter.value)
                high (upper-bound-index-view db filter-view "avet" 0 filter.attr filter.value)]
            (when (or (= filter-i 0)
                      (< (- high low) (- best-high best-low)))
              (set! best-filter-index filter-i)
              (set! best-low low)
              (set! best-high high)))
          (set! filter-i (+ filter-i 1))))
        (when (= (count plan.filters) 0)
          (delete plan.filters)
          (return out false))
        (reset-entity-int-pair-columns-capacity! (addr out) (- best-high best-low))
        (let [direct-value-lookup (all-datoms-current? db)
              db-alias db
              source (resident-db-read-source (addr db-alias))]
          (let [i best-low]
            (while (< i best-high)
            (let [filter-datom-index (db-index-view-at filter-view i)
                  filter-datom db.datoms[filter-datom-index]]
              (when (or direct-value-lookup (datom-current-at? db filter-datom-index))
                (let [filters-match true]
                  (let [filter-i 0]
                    (while (< filter-i (count plan.filters))
                    (when (not (= filter-i best-filter-index))
                      (let [filter plan.filters[filter-i]]
                        (if direct-value-lookup
                          (let [[matches matches-ok _] (db-read-source-cardinality-one-value-matches-fast-all-current? source filter-datom.e filter.attr filter.value)]
                            (when (not (and matches-ok matches))
                              (set! filters-match false)))
                          (let [[filter-value filter-ok] (latest-attr-value db filter-datom.e filter.attr)]
                            (when (not (and filter-ok (value-equal? filter-value filter.value)))
                              (set! filters-match false))))))
                    (set! filter-i (+ filter-i 1))))
                  (when filters-match
                    (if direct-value-lookup
                      (let [[int-value int-ok _] (db-read-source-cardinality-one-int-value-fast-all-current source filter-datom.e plan.value-attr)]
                        (when int-ok
                          (append-entity-int-pair-column! (addr out) filter-datom.e int-value)))
                      (let [[value value-ok] (latest-attr-value db filter-datom.e plan.value-attr)]
                        (when (and value-ok (= value.kind .Int))
                          (append-entity-int-pair-column! (addr out) filter-datom.e value.int-value)))))))
            (set! i (+ i 1)))))
        (delete plan.filters)
        (return out true))))))

(defn q-entity-two-value-plan-profiled [db: DB, query: Query, plan: Entity-Two-Value-Plan, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        rows (make [dynamic]Result-Row)
        filter-view (db-index-view db .AVET)
        best-filter-index 0
        best-low 0
        best-high 0
        all-current (all-datoms-current? db)]
    (defer (delete plan.filters))
    (let [filter-i 0]
      (while (< filter-i (count plan.filters))
      (let [filter plan.filters[filter-i]
            low (lower-bound-index-view db filter-view "avet" 0 filter.attr filter.value)
            high (upper-bound-index-view db filter-view "avet" 0 filter.attr filter.value)]
        (when (or (= filter-i 0)
                  (< (- high low) (- best-high best-low)))
          (set! best-filter-index filter-i)
          (set! best-low low)
          (set! best-high high)))
      (set! filter-i (+ filter-i 1))))
    (set! out-stats.steps 1)
    (set! out-stats.clauses (count query.clauses))
    (set! out-stats.clause-candidates (- best-high best-low))
    (when (and all-current
               (> (count plan.filters) 2))
      (let [output-attrs ([]string [plan.first-attr plan.second-attr])
            streams (entity-star-streams-for-filters-and-outputs db (slice plan.filters 0) output-attrs)]
        (defer (delete streams))
        (while true
          (let [[entity entity-ok] (entity-star-streams-align! db (addr streams))]
            (when (not entity-ok)
              (set! out-stats.max-intermediate-bindings (count rows))
              (set! out-stats.output-rows (count rows))
              (return (profiled-result-set (result-set-ok rows) out-stats)))
            (let [[first-value first-ok] (entity-star-output-value db (slice streams 0) 0)
                  [second-value second-ok] (entity-star-output-value db (slice streams 0) 1)]
              (when (and first-ok second-ok)
                (append-three-value-row! (addr rows) (value-entity entity) first-value second-value)))
            (entity-star-streams-advance-all! (addr streams))))))
    (let [i best-low]
      (while (< i best-high)
      (let [filter-datom-index (db-index-view-at filter-view i)
            filter-datom db.datoms[filter-datom-index]]
        (when (or all-current (datom-current-at? db filter-datom-index))
          (let [filters-match true]
            (let [filter-i 0]
              (while (< filter-i (count plan.filters))
              (when (not (= filter-i best-filter-index))
                (let [filter plan.filters[filter-i]]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
                  (if all-current
                    (when (not (cardinality-one-value-matches-fast-all-current? db filter-datom.e filter.attr filter.value))
                      (set! filters-match false))
                    (when (not (current-cardinality-one-value-matches-fast? db filter-datom.e filter.attr filter.value))
                      (set! filters-match false)))))
              (set! filter-i (+ filter-i 1))))
            (when filters-match
              (if all-current
                (let [[first-value first-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.first-attr)
                      [second-value second-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.second-attr)]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 2))
                  (when (and first-ok second-ok)
                    (append-three-value-row! (addr rows) (value-entity filter-datom.e) first-value second-value)))
                (let [[first-value first-ok] (current-cardinality-one-value-fast db filter-datom.e plan.first-attr)
                      [second-value second-ok] (current-cardinality-one-value-fast db filter-datom.e plan.second-attr)]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 2))
                  (when (and first-ok second-ok)
                    (append-three-value-row! (addr rows) (value-entity filter-datom.e) first-value second-value)))))))
      (set! i (+ i 1))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats))))

(defn q-query-entity-string-int-triples [db: DB, query: Query, inputs: []Query-Input] -> [columns: Entity-String-Int-Triples, ok: bool]
  (let [out (empty-entity-string-int-triples)]
    (when (> (count inputs) 0)
      (return out false))
    (let [[self-join-plan self-join-ok] (query-entity-value-self-join-plan db query)]
      (when self-join-ok
        (delete-entity-string-int-triples out)
        (return (q-entity-value-self-join-triples db self-join-plan) true)))
    (let [[plan plan-ok] (query-entity-two-value-plan db query)]
      (when (not plan-ok)
        (delete plan.filters)
        (return out false))
      (when (and (all-datoms-current? db)
                 (> (count plan.filters) 1))
        (let [output-attrs ([]string [plan.first-attr plan.second-attr])
              streams (entity-star-streams-for-filters-and-outputs db (slice plan.filters 0) output-attrs)]
          (defer (delete streams))
          (while true
            (let [[entity entity-ok] (entity-star-streams-align! db (addr streams))]
              (when (not entity-ok)
                (delete plan.filters)
                (return out true))
              (let [[first-value first-ok] (entity-star-output-value db (slice streams 0) 0)
                    [second-value second-ok] (entity-star-output-value db (slice streams 0) 1)]
                (when (and first-ok
                           second-ok
                           (= first-value.kind .String)
                           (= second-value.kind .Int))
                  (append-entity-string-int-triple! (addr out) entity first-value.text second-value.int-value)))
              (entity-star-streams-advance-all! (addr streams))))))
      (let [filter-view (db-index-view db .AVET)
            best-filter-index 0
            best-low 0
            best-high 0]
        (let [filter-i 0]
          (while (< filter-i (count plan.filters))
          (let [filter plan.filters[filter-i]
                low (lower-bound-index-view db filter-view "avet" 0 filter.attr filter.value)
                high (upper-bound-index-view db filter-view "avet" 0 filter.attr filter.value)]
            (when (or (= filter-i 0)
                      (< (- high low) (- best-high best-low)))
              (set! best-filter-index filter-i)
              (set! best-low low)
              (set! best-high high)))
          (set! filter-i (+ filter-i 1))))
        (reset-entity-string-int-triples-capacity! (addr out) (- best-high best-low))
        (let [db-alias db
              source (resident-db-read-source (addr db-alias))
              i best-low]
          (while (< i best-high)
          (let [filter-datom-index (db-index-view-at filter-view i)
                filter-datom db.datoms[filter-datom-index]]
            (let [filters-match true]
              (let [filter-i 0]
                (while (< filter-i (count plan.filters))
                (when (not (= filter-i best-filter-index))
                  (let [filter plan.filters[filter-i]]
                    (let [[matches matches-ok _] (db-read-source-cardinality-one-value-matches-fast-all-current? source filter-datom.e filter.attr filter.value)]
                      (when (not (and matches-ok matches))
                        (set! filters-match false)))))
                (set! filter-i (+ filter-i 1))))
              (when filters-match
                (let [[first-value first-ok _] (db-read-source-cardinality-one-value-fast-all-current source filter-datom.e plan.first-attr)
                      [second-value second-ok _] (db-read-source-cardinality-one-value-fast-all-current source filter-datom.e plan.second-attr)]
                  (when (and first-ok
                             second-ok
                             (= first-value.kind .String)
                             (= second-value.kind .Int))
                    (append-owned-entity-string-int-triple! (addr out) filter-datom.e first-value.text second-value.int-value))
                  (when first-ok
                    (delete-owned-value first-value))
                  (when second-ok
                    (delete-owned-value second-value))))))
          (set! i (+ i 1))))
        (delete plan.filters)
        (return out true)))))

(defn q-db-read-source-entity-string-pair-columns [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [columns: Entity-String-Pair-Columns, ok: bool, error: string]
  (let [out (empty-entity-string-pair-columns)
        seen (set.empty string)]
    (defer (delete seen))
    (when (> (count inputs) 0)
      (return out false ""))
    (let [[projection projection-ok] (db-read-source-query-filtered-entity-attr-value-projection query)]
      (when (not projection-ok)
        (return out false ""))
      (when (not (and (= (count query.find) 2)
                      (= query.find[0] projection.entity-var)
                      (= query.find[1] projection.value-var)))
        (return out false ""))
      (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source projection.value-attr)]
        (when (not many-ok)
          (return out false many-error))
        (if (db-read-source-has-overlay? source)
          (let [filter-datoms (make [dynamic]Datom)
                [filter-ok filter-error] (db-read-source-append-attr-value-datoms! (addr filter-datoms) source projection.filter-attr projection.filter-value)]
            (when (not filter-ok)
              (delete-owned-datoms filter-datoms)
              (return out false filter-error))
            (let [[append-ok type-ok append-error] (source-entity-string-pair-append-filter-datoms! (addr out) (addr seen) source (slice filter-datoms 0) projection.value-attr many)]
              (when (not append-ok)
                (delete-owned-datoms filter-datoms)
                (return out false append-error))
              (when (not type-ok)
                (delete-owned-datoms filter-datoms)
                (return out false "")))
            (delete-owned-datoms filter-datoms))
          (let [[filter-stream filter-ok filter-error] (source-attr-value-match-stream source projection.filter-attr projection.filter-value)]
            (when (not filter-ok)
              (return out false filter-error))
            (let [[append-ok type-ok append-error] (source-entity-string-pair-append-filter-stream! (addr out) (addr seen) source (addr filter-stream) projection.value-attr many)]
              (when (not append-ok)
                (delete-source-attr-value-match-stream filter-stream)
                (return out false append-error))
              (when (not type-ok)
                (delete-source-attr-value-match-stream filter-stream)
                (return out false "")))
            (delete-source-attr-value-match-stream filter-stream)))
        (return out true "")))))

(defn q-query-profiled-with-sources-and-fns [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> Profiled-Result-Set
  (let [stats (query-stats-empty)
        [valid error] (validate-query-call-with-fns db query inputs sources registry)]
    (when (not valid)
      (return (profiled-result-set (result-set-error error) stats)))
  (let [[attr-top-n-plan attr-top-n-ok] (query-attr-top-n-aggregate-plan query)]
    (when attr-top-n-ok
      (return (q-attr-top-n-aggregate-profiled db query attr-top-n-plan stats))))
  (let [[missing-plan missing-ok] (query-missing-attr-projection-plan db query)]
    (when missing-ok
      (return (q-missing-attr-projection-profiled db missing-plan stats))))
  (let [[self-join-plan self-join-ok] (query-entity-value-self-join-plan db query)]
    (when self-join-ok
      (return (q-entity-value-self-join-profiled db self-join-plan stats))))
  (when (query-relation-engine-eligible? query sources)
    (let [post-rel (relation-engine-relation-profiled db query inputs sources registry (addr stats))
          rows (make [dynamic]Result-Row)]
      (if (> (count query.aggregates) 0)
        (let [[typed-aggregate-rows typed-aggregate-ok] (aggregate-result-rows-for-typed-relation-with-sources-and-fns db sources query inputs post-rel registry)]
          (if typed-aggregate-ok
            (do
              (delete rows)
              (set! rows typed-aggregate-rows))
            (do
              (delete-result-rows-shallow typed-aggregate-rows)
              (let [materialized (query-relation-materialized-bindings post-rel) :defer]
                (query-stats-observe-materialization! (addr stats) (count materialized))
                (if (= (count query.find) 0)
                  (let [values (make [dynamic]Value 0 (count query.aggregates))
                        pulls (make [dynamic]Pull-Result)]
                    (for [aggregate query.aggregates]
                      (arr.push! values (aggregate-value-for-group-with-fns (slice materialized 0) query aggregate ([]Value []) registry)))
                    (arr.push! rows (Result-Row {values: values pulls: pulls})))
                  (append-aggregate-rows-with-sources-and-fns! (addr rows) db sources query inputs (slice materialized 0) registry))))))
        (do
          (delete rows)
          (let [[typed-rows typed-ok] (result-rows-for-typed-relation-with-sources-and-fns db sources query inputs post-rel registry)]
            (if typed-ok
              (set! rows typed-rows)
              (do
                (delete-result-rows-shallow typed-rows)
                (let [materialized (query-relation-materialized-bindings post-rel) :defer]
                  (query-stats-observe-materialization! (addr stats) (count materialized))
                  (set! rows (result-rows-for-bindings-with-sources-and-fns db sources query inputs (slice materialized 0) registry))))))))
      (delete-query-relation post-rel)
      (set! stats.clauses (query-logical-clause-count query))
      (set! stats.output-rows (count rows))
      (return (profiled-result-set (result-set-ok rows) stats))))
  (let [[distinct-clause distinct-ok] (query-single-attr-value-distinct-clause query)]
    (when distinct-ok
      (return (q-single-attr-value-distinct-profiled db distinct-clause stats))))
  (let [[entity-clause entity-ok] (query-single-entity-by-attr-value-clause db query)]
    (when entity-ok
      (return (q-single-entity-by-attr-value-profiled db entity-clause stats))))
  (let [[entity-value-projection entity-value-ok] (query-entity-attr-value-projection db query)]
    (when entity-value-ok
      (return (q-entity-attr-value-projection-profiled db query entity-value-projection stats))))
  (let [[entity-two-plan entity-two-ok] (query-entity-two-value-plan db query)]
    (when entity-two-ok
      (return (q-entity-two-value-plan-profiled db query entity-two-plan stats)))
    (delete entity-two-plan.filters))
  (let [[projection projection-ok] (query-two-attr-entity-projection query)]
    (when projection-ok
      (return (q-two-attr-entity-projection-profiled db query projection stats))))
  (when (> (count query.where-steps) 0)
    (let [ordered-query query
          bindings (bindings-after-ordered-where-profiled-with-fns db sources (addr ordered-query) inputs registry (addr stats))]
      (when (> (count query.aggregates) 0)
        (let [rows (make [dynamic]Result-Row)]
          (if (= (count query.find) 0)
            (let [values (make [dynamic]Value 0 (count query.aggregates))
                  pulls (make [dynamic]Pull-Result)]
              (for [aggregate query.aggregates]
                (arr.push! values (aggregate-value-for-group-with-fns (slice bindings 0) query aggregate ([]Value []) registry)))
              (arr.push! rows (Result-Row {values: values pulls: pulls})))
            (append-aggregate-rows-with-sources-and-fns! (addr rows) db sources query inputs (slice bindings 0) registry))
          (delete bindings)
          (set! stats.output-rows (count rows))
          (return (profiled-result-set (result-set-ok rows) stats))))
      (let [rows (result-rows-for-bindings-with-sources-and-fns db sources query inputs (slice bindings 0) registry)]
        (delete bindings)
        (set! stats.output-rows (count rows))
        (return (profiled-result-set (result-set-ok rows) stats)))))
  (let [bindings (bindings-from-inputs db query inputs)
        remaining (arr.into [dynamic]Clause (slice query.clauses 0))]
    (set! stats.input-bindings (count bindings))
    (query-stats-observe-bindings! (addr stats) (count bindings))
    (defer (delete remaining))
    (while (and (> (count bindings) 0) (> (count remaining) 0))
      (let [clause-index (best-clause-index (slice remaining 0) bindings[0])
            clause remaining[clause-index]
            next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (append-bindings-after-clause-with-sources-profiled! (addr next-bindings) db sources clause binding (addr stats)))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))
        (arr.remove-ordered-at! remaining clause-index)))
    (for [call call-index query.rule-calls]
      (let [next-bindings (make [dynamic]Binding)
            use-cached-plan (< call-index (count query.rule-call-plans))
            plan (if use-cached-plan query.rule-call-plans[call-index] (rule-call-plan (slice query.rules 0) call.name))]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-profiled-with-plan db plan call binding registry (addr stats))]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (when (not use-cached-plan)
          (delete-rule-call-plan plan))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [ground query.grounds]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (apply-ground (slice bindings 0) ground)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [get-else query.get-elses]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [[next ok] (apply-get-else db binding get-else)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [get-some query.get-somes]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [[next ok] (apply-get-some db binding get-some)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [function query.function-clauses]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (bindings-after-function-with-fns (slice bindings 0) function registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [predicate query.predicates]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (bindings-after-predicate-with-db-and-fns db (slice bindings 0) predicate registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [group query.or-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-rules-sources-and-fns db (slice query.rules 0) sources group branch binding registry)]
              (for [branch-binding branch-bindings]
                (arr.push! next-bindings branch-binding))
              (delete branch-bindings))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [not-group query.not-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-rules-sources-and-fns? db (slice query.rules 0) sources not-group binding registry))
            (arr.push! next-bindings binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (when (> (count query.aggregates) 0)
      (let [rows (make [dynamic]Result-Row)]
        (if (= (count query.find) 0)
          (let [values (make [dynamic]Value 0 (count query.aggregates))
                pulls (make [dynamic]Pull-Result)]
            (for [aggregate query.aggregates]
              (arr.push! values (aggregate-value-for-group-with-fns (slice bindings 0) query aggregate ([]Value []) registry)))
            (arr.push! rows (Result-Row {values: values pulls: pulls})))
          (append-aggregate-rows-with-sources-and-fns! (addr rows) db sources query inputs (slice bindings 0) registry))
        (delete bindings)
        (set! stats.output-rows (count rows))
        (return (profiled-result-set (result-set-ok rows) stats))))
    (let [rows (result-rows-for-bindings-with-sources-and-fns db sources query inputs (slice bindings 0) registry)]
      (delete bindings)
      (set! stats.output-rows (count rows))
      (return (profiled-result-set (result-set-ok rows) stats))))))

(defn q-query-with-sources-and-fns [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> Result-Set
  (q-query-profiled-with-sources-and-fns db query inputs sources registry).result)

(defn q-query-with-sources [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source] -> Result-Set
  (q-query-with-sources-and-fns db query inputs sources ([]Native-Query-Fn [])))

(defn q-query-with-inputs-and-fns [db: DB, query: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (q-query-with-sources-and-fns db query inputs ([]DB-Source []) registry))

(defn q-query-with-fns [db: DB, query: Query, registry: []Native-Query-Fn] -> Result-Set
  (q-query-with-inputs-and-fns db query ([]Query-Input []) registry))

(defn relation-db-not-group [group: Not-Group, source: string] -> Not-Group
  (let [clauses (rule-clauses-with-source (slice group.clauses 0) source true) :defer
        owned-clauses (arr.into [dynamic]Clause (slice clauses 0))
        predicates (arr.into [dynamic]Predicate (slice group.predicates 0))
        function-clauses (arr.into [dynamic]Function-Clause (slice group.function-clauses 0))
        get-elses (get-elses-with-source (slice group.get-elses 0) source true)
        get-somes (get-somes-with-source (slice group.get-somes 0) source true)
        grounds (arr.into [dynamic]Ground (slice group.grounds 0))
        rule-calls (relation-db-rule-calls (slice group.rule-calls 0) source)
        child-groups (make [dynamic]Not-Group) :defer
        join-vars (arr.into [dynamic]string (slice group.join-vars 0))
        steps (arr.into [dynamic]Query-Step (slice group.steps 0))]
    (for [child group.not-groups]
      (arr.push! child-groups (relation-db-not-group child source)))
    (let [owned-child-groups (arr.into [dynamic]Not-Group (slice child-groups 0))]
    (Not-Group {clauses: owned-clauses
                predicates: predicates
                function-clauses: function-clauses
                get-elses: get-elses
                get-somes: get-somes
                grounds: grounds
                rule-calls: rule-calls
                not-groups: owned-child-groups
                steps: steps
                has-join: group.has-join
                join-vars: join-vars}))))

(defn relation-db-or-group [group: Or-Group, source: string] -> Or-Group
  (let [branches (make [dynamic]Not-Group) :defer]
    (for [branch group.branches]
      (arr.push! branches (relation-db-not-group branch source)))
    (if group.has-join
      (or-join-group (slice group.join-vars 0) (slice branches 0))
      (or-group (slice branches 0)))))

(defn relation-db-rule [rule: Rule, source: string] -> Rule
  (let [clauses (rule-clauses-with-source (slice rule.clauses 0) source true) :defer
        source-get-elses (get-elses-with-source (slice rule.get-elses 0) source true) :defer
        source-get-somes (get-somes-with-source (slice rule.get-somes 0) source true)
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer]
    (for [group rule.not-groups]
      (arr.push! not-groups (relation-db-not-group group source)))
    (for [group rule.or-groups]
      (arr.push! or-groups (relation-db-or-group group source)))
    (let [params (arr.into [dynamic]string (slice rule.params 0))
          owned-clauses (arr.into [dynamic]Clause (slice clauses 0))
          predicates (arr.into [dynamic]Predicate (slice rule.predicates 0))
          function-clauses (arr.into [dynamic]Function-Clause (slice rule.function-clauses 0))
          get-elses (arr.into [dynamic]Get-Else (slice source-get-elses 0))
          get-somes source-get-somes
          grounds (arr.into [dynamic]Ground (slice rule.grounds 0))
          rule-calls (arr.into [dynamic]Rule-Call (slice rule.rule-calls 0))
          owned-not-groups (arr.into [dynamic]Not-Group (slice not-groups 0))
          owned-or-groups (arr.into [dynamic]Or-Group (slice or-groups 0))
          body-steps (arr.into [dynamic]Query-Step (slice rule.body-steps 0))]
      (Rule {name: rule.name
             required-param-count: rule.required-param-count
             params: params
             clauses: owned-clauses
             predicates: predicates
             function-clauses: function-clauses
             get-elses: get-elses
             get-somes: get-somes
             grounds: grounds
             rule-calls: rule-calls
             not-groups: owned-not-groups
             or-groups: owned-or-groups
             body-steps: body-steps}))))

(defn relation-db-rule-call [call: Rule-Call, source: string] -> Rule-Call
  (when call.has-source
    (return call))
  (Rule-Call {name: call.name
              source: source
              has-source: true
              args: call.args}))

(defn relation-db-rule-calls [calls: []Rule-Call, source: string] -> [dynamic]Rule-Call
  (let [out (make [dynamic]Rule-Call 0 (count calls))]
    (for [call calls]
      (arr.push! out (relation-db-rule-call call source)))
    out))

(defn relation-db-inputs [query-value: Query, source: string] -> [dynamic]string
  (let [out (make [dynamic]string 0 (+ (count query-value.inputs) 1))]
    (for [input query-value.inputs]
      (when (not (= input "$"))
        (arr.push! out input)))
    (arr.push! out source)
    out))

(defn relation-db-input-specs [query-value: Query, source: string] -> [dynamic]Query-Input-Spec
  (let [out (make [dynamic]Query-Input-Spec)]
    (if (> (count query-value.input-specs) 0)
      (for [spec query-value.input-specs]
        (when (not (and (= spec.kind .Scalar)
                        (= spec.name "$")))
          (arr.push! out spec)))
      (do
        (for [input query-value.inputs]
          (when (not (= input "$"))
            (arr.push! out (Query-Input-Spec {kind: .Scalar name: input}))))
        (for [input query-value.collection-inputs]
          (arr.push! out (Query-Input-Spec {kind: .Collection name: input})))
        (for [input query-value.tuple-inputs]
          (arr.push! out (Query-Input-Spec {kind: .Tuple tuple: input}))
        (for [input query-value.relation-inputs]
          (arr.push! out (Query-Input-Spec {kind: .Relation relation: input}))))))
    (arr.push! out (Query-Input-Spec {kind: .Scalar name: source}))
    out))

(defn relation-db-query [query-value: Query, source: string] -> Query
  (let [inputs (relation-db-inputs query-value source) :defer
        input-specs (relation-db-input-specs query-value source) :defer
        clauses (rule-clauses-with-source (slice query-value.clauses 0) source true) :defer
        rule-calls (relation-db-rule-calls (slice query-value.rule-calls 0) source) :defer
        rules (make [dynamic]Rule) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer]
    (for [rule query-value.rules]
      (arr.push! rules (relation-db-rule rule source)))
    (for [group query-value.not-groups]
      (arr.push! not-groups (relation-db-not-group group source)))
    (for [group query-value.or-groups]
      (arr.push! or-groups (relation-db-or-group group source)))
    (let [out (query (slice query-value.find 0)
                     (slice query-value.with 0)
                     (slice inputs 0)
                     (slice query-value.collection-inputs 0)
                     (slice query-value.tuple-inputs 0)
                     (slice query-value.relation-inputs 0)
                     (slice clauses 0)
                     (slice query-value.predicates 0)
                     (slice query-value.function-clauses 0)
                     (slice rules 0)
                     (slice rule-calls 0)
                     (slice query-value.get-elses 0)
                     (slice query-value.get-somes 0)
                     (slice query-value.grounds 0)
                     (slice not-groups 0)
                     (slice or-groups 0)
                     (slice query-value.pulls 0)
                     (slice query-value.aggregates 0))]
      (delete out.input-specs)
      (set! out.input-specs (arr.into [dynamic]Query-Input-Spec (slice input-specs 0)))
      (query-with-rules-input
        (query-with-where-steps out (slice query-value.where-steps 0))
        query-value.has-rules-input))))

(defn q-query-relation-db-with-fns [rows: Value, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (let [source (primary-relation-db-source-name)
        relation-query (relation-db-query query-value source)
        relation-inputs (arr.into [dynamic]Query-Input inputs) :defer
        empty-datoms (make [dynamic]Datom)
        empty (build-db empty-datoms)]
    (if (= rows.kind .Map)
      (arr.push! relation-inputs (query-input-map-relation rows))
      (arr.push! relation-inputs (query-input-scalar rows)))
    (let [result (q-query-with-sources-and-fns empty relation-query (slice relation-inputs 0) ([]DB-Source []) registry)]
      (delete empty-datoms)
      (delete empty.current)
      (delete empty.eavt)
      (delete empty.aevt)
      (delete empty.avet)
      (delete empty.vaet)
      result)))

(defn q-query-relation-db [rows: Value, query-value: Query, inputs: []Query-Input] -> Result-Set
  (q-query-relation-db-with-fns rows query-value inputs ([]Native-Query-Fn [])))

(defn q-query-with-inputs [db: DB, query: Query, inputs: []Query-Input] -> Result-Set
  (q-query-with-sources db query inputs ([]DB-Source [])))

(defn q-query [db: DB, query: Query] -> Result-Set
  (q-query-with-inputs db query ([]Query-Input [])))

(defn result-scalar [result: Result-Set] -> [value: Value, ok: bool]
  (when (= (count result.rows) 0)
    (return (Value {}) false))
  (when (not (= (count result.rows[0].values) 1))
    (return (Value {}) false))
  (return result.rows[0].values[0] true))

(defn result-collection [result: Result-Set] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) 1)
        (arr.push! out row.values[0])))
    out))

(defn result-tuple [result: Result-Set] -> [dynamic]Value
  (if (> (count result.rows) 0)
    (arr.into [dynamic]Value (slice result.rows[0].values 0))
    (make [dynamic]Value)))

(defn result-pull-scalar [result: Result-Set] -> [pull: Pull-Result, ok: bool]
  (when (= (count result.rows) 0)
    (return (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}) false))
  (when (not (= (count result.rows[0].pulls) 1))
    (return (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}) false))
  (return result.rows[0].pulls[0] true))

(defn result-pull-collection [result: Result-Set] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.pulls) 1)
        (arr.push! out row.pulls[0])))
    out))

(defn pull-render-attr-key [pulled: Pull-Attr] -> Value
  (case pulled.key-kind
    .Keyword (value-keyword pulled.a)
    .Symbol (value-symbol pulled.a)
    .String (value-string pulled.a)
     (value-keyword pulled.a)))

(defn pull-render-ref-id-map [entity: u64] -> Value
  (value-map ([]Value [(value-keyword ":db/id") (value-entity entity)])))

(defn pull-render-attr-value [db: DB, pulled: Pull-Attr] -> Value
  (if (> (count pulled.attrs) 0)
    (pull-render-attrs-map db (slice pulled.attrs 0))
    (if pulled.has-explicit-pattern
      (value-map ([]Value []))
      (if (and (= pulled.v.kind .Entity)
               (not (= pulled.a ":db/id")))
        (pull-render-ref-id-map pulled.v.entity)
        pulled.v))))

(defn pull-render-attr-is-many? [db: DB, pulled: Pull-Attr, count-for-attr: int] -> bool
  (when (> count-for-attr 1)
    (return true))
  (when (reverse-attr? pulled.a)
    (let [forward (forward-attr-for-reverse pulled.a) :defer]
      (return (not (schema-component? db forward)))))
  (schema-cardinality-many? db pulled.a))

(defstruct Value-Map-Builder {
  items: [dynamic]Value
})

(defn value-map-builder [capacity: int] -> Value-Map-Builder
  (Value-Map-Builder {items: (make [dynamic]Value 0 capacity)}))

(defn delete-value-map-builder [builder: Value-Map-Builder]
  (delete builder.items))

(defn value-map-builder-key-index [builder: Value-Map-Builder, key: Value] -> [index: int, ok: bool]
  (let [i 0]
    (while (< i (count builder.items))
      (when (value-equal? builder.items[i] key)
        (return i true))
      (set! i (+ i 2))))
  (return 0 false))

(defn value-map-builder-has-key? [builder: Value-Map-Builder, key: Value] -> bool
  (let [[_ ok] (value-map-builder-key-index builder key)]
    ok))

(defn value-map-builder-put-new! [builder: ^Value-Map-Builder, key: Value, value: Value] -> bool
  (when (value-map-builder-has-key? builder^ key)
    (return false))
  (arr.push! builder^.items key)
  (arr.push! builder^.items value)
  true)

(defn value-map-builder-value [builder: Value-Map-Builder] -> Value
  (value-map (slice builder.items 0)))

(defn pull-render-group-values [db: DB, attrs: []Pull-Attr, attr-name: string] -> [dynamic]Value
  (let [values (make [dynamic]Value)]
    (for [pulled attrs]
      (when (= pulled.a attr-name)
        (arr.push! values (pull-render-attr-value db pulled))))
    values))

(defn pull-render-attrs-map [db: DB, attrs: []Pull-Attr] -> Value
  (let [builder (value-map-builder (* (count attrs) 2))
        i 0]
    (defer (delete-value-map-builder builder))
    (while (< i (count attrs))
      (let [pulled attrs[i]
            key (pull-render-attr-key pulled)]
        (when (not (value-map-builder-has-key? builder key))
          (let [values (pull-render-group-values db attrs pulled.a)
                rendered (if (pull-render-attr-is-many? db pulled (count values))
                           (value-vector (slice values 0))
                           values[0])]
            (discard (value-map-builder-put-new! (addr builder) key rendered))
            (delete values))))
      (set! i (+ i 1)))
    (value-map-builder-value builder)))

(defn pull-result-value [db: DB, result: Pull-Result] -> Value
  (if (= (count result.attrs) 0)
    (value-nil)
    (pull-render-attrs-map db (slice result.attrs 0))))

(defn db-read-source-pull-render-attr-value [source: DB-Read-Source, pulled: Pull-Attr] -> [value: Value, ok: bool, error: string]
  (if (> (count pulled.attrs) 0)
    (db-read-source-pull-render-attrs-map source (slice pulled.attrs 0))
    (if pulled.has-explicit-pattern
      (return (value-map ([]Value [])) true "")
      (if (and (= pulled.v.kind .Entity)
               (not (= pulled.a ":db/id")))
        (return (value-map ([]Value [(value-keyword (string-owned ":db/id")) (value-entity pulled.v.entity)])) true "")
        (return (value-owned pulled.v) true "")))))

(defn db-read-source-pull-render-attr-is-many? [source: DB-Read-Source, pulled: Pull-Attr, count-for-attr: int] -> [many: bool, ok: bool, error: string]
  (when (> count-for-attr 1)
    (return true true ""))
  (when (reverse-attr? pulled.a)
    (let [forward (forward-attr-for-reverse pulled.a) :defer
          [component component-ok component-error] (db-read-source-schema-component? source forward)]
      (return (not component) component-ok component-error)))
  (db-read-source-schema-cardinality-many? source pulled.a))

(defn db-read-source-pull-render-group-values [source: DB-Read-Source, attrs: []Pull-Attr, attr-name: string] -> [values: [dynamic]Value, ok: bool, error: string]
  (let [out (make [dynamic]Value)]
    (for [pulled attrs]
      (when (= pulled.a attr-name)
        (let [[rendered rendered-ok rendered-error] (db-read-source-pull-render-attr-value source pulled)]
          (when (not rendered-ok)
            (delete out)
            (return (make [dynamic]Value) false rendered-error))
          (arr.push! out rendered))))
    (return out true "")))

(defn db-read-source-pull-render-attrs-map [source: DB-Read-Source, attrs: []Pull-Attr] -> [value: Value, ok: bool, error: string]
  (let [items (make [dynamic]Value 0 (* (count attrs) 2))
        emitted (make [dynamic]string)
        i 0]
    (defer (delete emitted))
    (while (< i (count attrs))
      (let [pulled attrs[i]]
        (if (string-slice-contains? (slice emitted 0) pulled.a)
          (do)
          (let [[values values-ok values-error] (db-read-source-pull-render-group-values source attrs pulled.a)]
            (when (not values-ok)
              (delete-owned-value (value-map-owned items))
              (return (Value {}) false values-error))
            (let [[many many-ok many-error] (db-read-source-pull-render-attr-is-many? source pulled (count values))]
              (when (not many-ok)
                (delete-owned-value (value-vector-owned values))
                (delete-owned-value (value-map-owned items))
                (return (Value {}) false many-error))
              (let [rendered (if many
                               (value-vector (slice values 0))
                               values[0])]
                (arr.push! items (value-owned (pull-render-attr-key pulled)))
                (arr.push! items rendered)
                (arr.push! emitted pulled.a)
                (delete values)))))
      (set! i (+ i 1))))
    (return (value-map-owned items) true "")))

(defn db-read-source-pull-result-value [source: DB-Read-Source, result: Pull-Result] -> [value: Value, ok: bool, error: string]
  (if (= (count result.attrs) 0)
    (return (value-nil) true "")
    (db-read-source-pull-render-attrs-map source (slice result.attrs 0))))

(defn db-read-source-pull-many-result-values [source: DB-Read-Source, results: []Pull-Result] -> [values: [dynamic]Value, ok: bool, error: string]
  (let [out (make [dynamic]Value 0 (count results))]
    (for [result results]
      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-result-value source result)]
        (when (not rendered-ok)
          (delete out)
          (return (make [dynamic]Value) false rendered-error))
        (arr.push! out rendered)))
    (return out true "")))

(defn db-read-source-pull-many-results-value [source: DB-Read-Source, results: []Pull-Result] -> [value: Value, ok: bool, error: string]
  (let [[items items-ok items-error] (db-read-source-pull-many-result-values source results)]
    (when (not items-ok)
      (return (Value {}) false items-error))
    (defer (delete items))
    (return (value-vector (slice items 0)) true "")))

(defn pull-many-result-values [db: DB, results: []Pull-Result] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count results))]
    (for [result results]
      (arr.push! out (pull-result-value db result)))
    out))

(defn pull-many-results-value [db: DB, results: []Pull-Result] -> Value
  (let [items (pull-many-result-values db results)]
    (defer (delete items))
    (value-vector (slice items 0))))

(defn result-row-value [db: DB, row: Result-Row] -> Value
  (let [values (value-vector (slice row.values 0))
        pulls (pull-many-results-value db (slice row.pulls 0))]
    (value-map
      ([]Value [(value-keyword ":values") values
                (value-keyword ":pulls") pulls]))))

(defn result-rows-value [db: DB, rows: []Result-Row] -> Value
  (let [items (make [dynamic]Value 0 (count rows))]
    (defer (delete items))
    (for [row rows]
      (arr.push! items (result-row-value db row)))
    (value-vector (slice items 0))))

(defn result-set-value [db: DB, result: Result-Set] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool result.ok)
              (value-keyword ":error") (value-string result.error)
              (value-keyword ":rows") (result-rows-value db (slice result.rows 0))])))

(defn db-read-source-result-row-values-value [row: Result-Row] -> Value
  (let [items (make [dynamic]Value 0 (count row.values))]
    (defer (delete items))
    (for [item row.values]
      (arr.push! items (value-owned item)))
    (value-vector (slice items 0))))

(defn db-read-source-result-row-value [source: DB-Read-Source, row: Result-Row] -> [value: Value, ok: bool, error: string]
  (let [values (db-read-source-result-row-values-value row)
        [pulls pulls-ok pulls-error] (db-read-source-pull-many-results-value source (slice row.pulls 0))]
    (when (not pulls-ok)
      (delete-owned-value values)
      (return (Value {}) false pulls-error))
    (return (value-map
              ([]Value [(value-keyword (string-owned ":values")) values
                        (value-keyword (string-owned ":pulls")) pulls]))
            true
            "")))

(defn db-read-source-result-rows-value [source: DB-Read-Source, rows: []Result-Row] -> [value: Value, ok: bool, error: string]
  (let [items (make [dynamic]Value 0 (count rows))]
    (defer (delete items))
    (for [row rows]
      (let [[row-value row-ok row-error] (db-read-source-result-row-value source row)]
        (when (not row-ok)
          (return (Value {}) false row-error))
        (arr.push! items row-value)))
    (return (value-vector (slice items 0)) true "")))

(defn db-read-source-result-set-value [source: DB-Read-Source, result: Result-Set] -> [value: Value, ok: bool, error: string]
  (let [[rows rows-ok rows-error] (db-read-source-result-rows-value source (slice result.rows 0))]
    (when (not rows-ok)
      (return (Value {}) false rows-error))
    (return (value-map
              ([]Value [(value-keyword (string-owned ":ok")) (value-bool result.ok)
                        (value-keyword (string-owned ":error")) (value-string (string-owned result.error))
                        (value-keyword (string-owned ":rows")) rows]))
            true
            "")))

(defn query-stats-value [stats: Query-Stats] -> Value
  (value-map
    ([]Value [(value-keyword ":input-bindings") (value-int (i64 stats.input-bindings))
              (value-keyword ":steps") (value-int (i64 stats.steps))
              (value-keyword ":clauses") (value-int (i64 stats.clauses))
              (value-keyword ":clause-candidates") (value-int (i64 stats.clause-candidates))
              (value-keyword ":typed-index-scans") (value-int (i64 stats.typed-index-scans))
              (value-keyword ":source-index-scans") (value-int (i64 stats.source-index-scans))
              (value-keyword ":source-operators") (value-int (i64 stats.source-operators))
              (value-keyword ":binding-materializations") (value-int (i64 stats.binding-materializations))
              (value-keyword ":generic-materialization-steps") (value-int (i64 stats.generic-materialization-steps))
              (value-keyword ":rule-calls") (value-int (i64 stats.rule-calls))
              (value-keyword ":rule-iterations") (value-int (i64 stats.rule-iterations))
              (value-keyword ":max-intermediate-bindings") (value-int (i64 stats.max-intermediate-bindings))
              (value-keyword ":output-rows") (value-int (i64 stats.output-rows))])))

(defn profiled-result-set-value [db: DB, profiled: Profiled-Result-Set] -> Value
  (value-map
    ([]Value [(value-keyword ":result") (result-set-value db profiled.result)
              (value-keyword ":stats") (query-stats-value profiled.stats)])))

(defn result-row-tuple [result: Result-Set] -> Result-Row
  (if (> (count result.rows) 0)
    (let [values (arr.into [dynamic]Value (slice result.rows[0].values 0))
          pulls (arr.into [dynamic]Pull-Result (slice result.rows[0].pulls 0))]
      (Result-Row {values: values pulls: pulls}))
    (Result-Row {values: (make [dynamic]Value)
                 pulls: (make [dynamic]Pull-Result)})))

(defn result-keys [result: Result-Set, kind: Key-Kind, keys: []string] -> [dynamic]Keyed-Row
  (let [out (make [dynamic]Keyed-Row 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) (count keys))
        (let [items (make [dynamic]Keyed-Value 0 (count keys))]
          (for [key index keys]
            (arr.push! items
              (Keyed-Value {kind: kind
                            key: (string-owned key)
                            value: (value-owned row.values[index])})))
          (arr.push! out (Keyed-Row {items: items})))))
    out))

(defn delete-keyed-rows [rows: [dynamic]Keyed-Row]
  (for [row rows]
    (for [item row.items]
      (delete item.key)
      (delete-owned-value item.value))
    (delete row.items))
  (delete rows))

(defn q-strings [db: DB, query: Query] -> [dynamic]string
  (let [result (q-query db query)
        out (make [dynamic]string 0 (count result.rows))]
    (for [row result.rows]
      (when (and (= (count row.values) 1)
                 (= row.values[0].kind .String))
        (arr.push! out row.values[0].text)))
    out))

(defn reverse-attr? [attr: string] -> bool
  (when (strings.has_prefix attr ":_")
    (return true))
  (for [_ index attr]
    (when (and (< (+ index 2) (count attr))
               (= (slice attr index (+ index 2)) "/_"))
      (return true)))
  false)

(defn forward-attr-for-reverse [attr: string] -> string
  (when (strings.has_prefix attr ":_")
    (return (strings.concatenate ([]string [":" (slice attr 2)]))))
  (for [_ index attr]
    (when (and (< (+ index 2) (count attr))
               (= (slice attr index (+ index 2)) "/_"))
      (return (strings.concatenate ([]string [(slice attr 0 (+ index 1))
                                              (slice attr (+ index 2))])))))
  attr)

(defn validate-pull-spec-schema [db: DB, spec: Pull-Spec] -> [ok: bool, error: string]
  (when (or (= spec.a "*")
            (= spec.a ":db/id"))
    (return true ""))
  (let [has-schema (db-has-schema? db)
        reverse? (reverse-attr? spec.a)
        attr (if reverse?
               (forward-attr-for-reverse spec.a)
               spec.a)]
    (defer (when reverse? (delete attr)))
    (when (and has-schema
               reverse?
               (not (schema-ref? db attr)))
      (return false (fmt.tprintf "pull reverse attr must be ref: %s" spec.a)))
    (when (and has-schema
               spec.has-limit
               (not (schema-cardinality-many? db attr)))
      (return false (fmt.tprintf "pull limit attr must be cardinality many: %s" spec.a)))
    (when (and has-schema
               (or (> (count spec.pattern) 0)
                   spec.has-recursion)
               (not (schema-ref? db attr)))
      (return false (fmt.tprintf "pull nested attr must be ref: %s" spec.a)))
    (for [child spec.pattern]
      (let [[child-ok child-error] (validate-pull-spec-schema db child)]
        (when (not child-ok)
          (return false child-error)))))
  (return true ""))

(defn validate-pull-pattern [db: DB, pattern: []Pull-Spec] -> [ok: bool, error: string]
  (for [spec pattern]
    (let [[spec-ok spec-error] (validate-pull-spec-schema db spec)]
      (when (not spec-ok)
        (return false spec-error))))
  (return true ""))

(defn pull-output-has-attr? [out: [dynamic]Pull-Attr, attr: string] -> bool
  (for [pulled out]
    (when (= pulled.a attr)
      (return true)))
  false)

(defn pull-remove-output-attr-shallow! [out: ^[dynamic]Pull-Attr, attr: string]
  (let [index 0]
    (while (< index (count out^))
      (if (= out^[index].a attr)
        (do
          (delete-pull-attr-shallow-owned-key out^[index])
          (arr.remove-ordered-at! out^ index))
        (set! index (+ index 1))))))

(defn pull-remove-output-attr-owned-values! [out: ^[dynamic]Pull-Attr, attr: string]
  (let [index 0]
    (while (< index (count out^))
      (if (= out^[index].a attr)
        (do
          (delete-pull-attr-owned-values out^[index])
          (arr.remove-ordered-at! out^ index))
        (set! index (+ index 1))))))

(defn pull-spec-output-index [pattern: []Pull-Spec, spec: Pull-Spec] -> [index: int, ok: bool]
  (let [attr (pull-output-attr spec)]
    (for [existing index pattern]
      (when (and (not (= existing.a "*"))
                 (= (pull-output-attr existing) attr))
        (return index true))))
  (return 0 false))

(defn normalize-pull-pattern [pattern: []Pull-Spec] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec 0 (count pattern))]
    (for [spec pattern]
      (if (= spec.a "*")
        (arr.push! out spec)
        (let [[index exists] (pull-spec-output-index (slice out 0) spec)]
          (if exists
            (set! out[index] spec)
            (arr.push! out spec)))))
    out))

(defn pull-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (return datom.v true)))))
  (return (Value {}) false))

(defn pull-attr-entity-target [db: DB, entity: u64, attr: string] -> [target: u64, ok: bool, many: bool]
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        found-target: u64 0
        found false]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity))
          (when found
            (return found-target true true))
          (set! found-target datom.v.entity)
          (set! found true))))
    (return found-target found false)))

(defn pull-limit [spec: Pull-Spec] -> int
  (if (= spec.limit -1)
    2147483647
    (if (> spec.limit 0) spec.limit 1000)))

(defn pull-id-attrs [entity: u64] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (arr.push! out (Pull-Attr {a: ":db/id"
                               v: (value-entity entity)
                               attrs: (make [dynamic]Pull-Attr)}))
    out))

(defn pull-seen-counts [seen: []u64] -> map[u64]int
  (let [out (make (map u64 int) (count seen))]
    (for [entity seen]
      (let [[count found] (mmap.get out entity)]
        (if found
          (mmap.assoc! out entity (+ count 1))
          (mmap.assoc! out entity 1))))
    out))

(defn pull-seen-count [counts: (ptr (map u64 int)), entity: u64] -> int
  (let [[count found] (mmap.get counts^ entity)]
    (if found count 0)))

(defn pull-seen-contains? [counts: (ptr (map u64 int)), entity: u64] -> bool
  (> (pull-seen-count counts entity) 0))

(defn pull-seen-push! [counts: (ptr (map u64 int)), entity: u64]
  (mmap.assoc! counts^ entity (+ (pull-seen-count counts entity) 1)))

(defn pull-seen-pop! [counts: (ptr (map u64 int)), entity: u64]
  (let [count (pull-seen-count counts entity)]
    (when (<= count 1)
      (mmap.dissoc! counts^ entity)
      (return))
    (mmap.assoc! counts^ entity (- count 1))))

(defn pull-child-pattern-normalized-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [seen-count (count seen^)]
    (arr.push! seen^ entity)
    (pull-seen-push! seen-counts entity)
    (let [pulled (pull-pattern-spec-seen-with-fns db entity pattern root seen seen-counts registry)]
      (pull-seen-pop! seen-counts entity)
      (arr.remove-unordered-at! seen^ seen-count)
      pulled.attrs)))

(defn pull-child-pattern-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [normalized (normalize-pull-pattern pattern) :defer]
    (pull-child-pattern-normalized-mut-with-fns db entity (slice normalized 0) (slice normalized 0) seen seen-counts registry)))

(defn pull-child-pattern-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [child-seen (arr.into [dynamic]u64 seen)
        seen-counts (pull-seen-counts seen)]
    (defer (delete child-seen))
    (defer (delete seen-counts))
    (pull-child-pattern-mut-with-fns db entity pattern root (addr child-seen) (addr seen-counts) registry)))

(defn pull-child-pattern [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (pull-child-pattern-with-fns db entity pattern root seen ([]Native-Query-Fn [])))

(defn pull-child-recursion-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (if (pull-seen-contains? seen-counts entity)
    (pull-id-attrs entity)
    (pull-child-pattern-normalized-mut-with-fns db entity pattern pattern seen seen-counts registry)))

(defn pull-child-recursion-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, seen: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [child-seen (arr.into [dynamic]u64 seen)
        seen-counts (pull-seen-counts seen)]
    (defer (delete child-seen))
    (defer (delete seen-counts))
    (pull-child-recursion-mut-with-fns db entity pattern (addr child-seen) (addr seen-counts) registry)))

(defn pull-child-recursion [db: DB, entity: u64, pattern: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (pull-child-recursion-with-fns db entity pattern seen ([]Native-Query-Fn [])))

(defn pull-include-ref-result? [spec: Pull-Spec, children: []Pull-Attr] -> bool
  (or (= (count spec.pattern) 0)
      (> (count children) 0)))

(defn pull-reverse-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> bool
  (let [forward-attr (forward-attr-for-reverse spec.a) :defer
        ref-value (value-entity entity)
        view (db-index-view db .VAET)
        low (lower-bound-index-view db view "vaet" 0 "" ref-value)
        high (upper-bound-index-view db view "vaet" 0 "" ref-value)
        limit (pull-limit spec)
        seen 0
        found false]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? db datom-index))
          (let [children (make [dynamic]Pull-Attr)]
            (when (> (count spec.pattern) 0)
              (set! children (pull-child-pattern-mut-with-fns db datom.e spec.pattern spec.pattern seen-entities seen-counts registry)))
            (when (and (= (count spec.pattern) 0)
                       spec.has-recursion
                       (not (= spec.recursion-depth 0)))
              (if (pull-unbounded-recursion-depth? spec.recursion-depth)
                (set! children (pull-child-recursion-mut-with-fns db datom.e root seen-entities seen-counts registry))
                (let [pattern (pull-recursion-pattern root spec.a)]
                  (defer (delete pattern))
                  (set! children (pull-child-recursion-mut-with-fns db datom.e (slice pattern 0) seen-entities seen-counts registry)))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^
                  (pull-spec-transform-attr-with-fns
                    spec
                    (pull-attr-from-spec spec (value-entity datom.e) children)
                    registry))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-reverse-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-reverse-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-wildcard-seen! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, seen-counts: (ptr (map u64 int))]
  (when (not (pull-output-has-attr? out^ ":db/id"))
    (arr.push! out^ (Pull-Attr {a: ":db/id"
                                v: (value-entity entity)
                                attrs: (make [dynamic]Pull-Attr)})))
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt" entity "" (Value {}))
        high (upper-bound-index-view db view "eavt" entity "" (Value {}))]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (not (pull-output-has-attr? out^ datom.a))
            (let [children (make [dynamic]Pull-Attr)]
              (when (and (= datom.v.kind .Entity)
                         (schema-component? db datom.a))
                (set! children (pull-component-attrs db datom.v.entity seen-counts)))
              (arr.push! out^ (Pull-Attr {a: (string-owned datom.a)
                                          a-owned: true
                                          v: datom.v
                                          attrs: children})))))))))

(defn pull-component-attrs [db: DB, entity: u64, seen-counts: (ptr (map u64 int))] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (if (pull-seen-contains? seen-counts entity)
      (arr.push! out (Pull-Attr {a: ":db/id"
                                 v: (value-entity entity)
                                 attrs: (make [dynamic]Pull-Attr)}))
      (do
        (pull-seen-push! seen-counts entity)
        (pull-wildcard-seen! (addr out) db entity seen-counts)))
    out))

(defn pull-wildcard! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64]
  (let [seen-counts (make (map u64 int))]
    (defer (delete seen-counts))
    (pull-seen-push! (addr seen-counts) entity)
    (pull-wildcard-seen! out db entity (addr seen-counts))))

(defn pull-component-children [db: DB, parent: u64, child: u64] -> [dynamic]Pull-Attr
  (let [seen-counts (make (map u64 int))]
    (defer (delete seen-counts))
    (pull-seen-push! (addr seen-counts) parent)
    (pull-component-attrs db child (addr seen-counts))))

(defn pull-output-attr [spec: Pull-Spec] -> string
  (if spec.has-alias spec.alias spec.a))

(defn pull-output-key-kind [spec: Pull-Spec] -> Key-Kind
  (if spec.has-alias spec.alias-kind .Keyword))

(defn pull-attr-from-spec [spec: Pull-Spec, value: Value, attrs: [dynamic]Pull-Attr] -> Pull-Attr
  (Pull-Attr {a: (string-owned (pull-output-attr spec))
              a-owned: true
              key-kind: (pull-output-key-kind spec)
              v: value
              attrs: attrs
              has-explicit-pattern: (> (count spec.pattern) 0)}))

(defn pull-next-recursion-depth [depth: int] -> int
  (- depth 1))

(defn pull-unbounded-recursion-depth? [depth: int] -> bool
  (= depth 2147483647))

(defn pull-simple-unbounded-forward-recursion-spec [pattern: []Pull-Spec] -> [spec: Pull-Spec, ok: bool]
  (let [candidate (Pull-Spec {})
        found false]
    (for [spec index pattern]
      (if (and spec.has-recursion
               (pull-unbounded-recursion-depth? spec.recursion-depth)
               (= (count spec.pattern) 0)
               (not (reverse-attr? spec.a)))
        (do
          (when (or found (not (= index (- (count pattern) 1))))
            (return (Pull-Spec {}) false))
          (set! candidate spec)
          (set! found true))
        (when (or spec.has-recursion
                  (> (count spec.pattern) 0)
                  (= spec.a "*"))
          (return (Pull-Spec {}) false))))
    (return candidate found)))

(defn pull-flat-pattern-except-attr-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, attr: string, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (when (not (= spec.a attr))
        (pull-spec-attr-with-fns! (addr out) db entity spec pattern seen seen-counts registry)))
    out))

(defn pull-pattern-simple-unbounded-forward-chain-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, spec: Pull-Spec, registry: []Native-Query-Fn] -> [result: Pull-Result, ok: bool]
  (let [path (make [dynamic]u64)
        seen-counts (make (map u64 int))
        cycle false]
    (arr.push! path entity)
    (pull-seen-push! (addr seen-counts) entity)
    (while true
      (let [current path[(- (count path) 1)]
            [target found many] (pull-attr-entity-target db current spec.a)]
        (when many
          (delete path)
          (delete seen-counts)
          (return (Pull-Result {e: entity attrs: (make [dynamic]Pull-Attr)}) false))
        (when (not found)
          (break))
        (arr.push! path target)
        (when (pull-seen-contains? (addr seen-counts) target)
          (set! cycle true)
          (break))
        (pull-seen-push! (addr seen-counts) target)))
    (let [build-seen (make [dynamic]u64)
          build-counts (make (map u64 int))
          last-entity path[(- (count path) 1)]
          child-attrs (if cycle
                        (pull-id-attrs last-entity)
                        (pull-flat-pattern-except-attr-with-fns db last-entity pattern spec.a (addr build-seen) (addr build-counts) registry))
          i (- (count path) 2)]
      (while (>= i 0)
        (let [parent path[i]
              child path[(+ i 1)]
              attrs (pull-flat-pattern-except-attr-with-fns db parent pattern spec.a (addr build-seen) (addr build-counts) registry)]
          (arr.push! attrs
            (pull-spec-transform-attr-with-fns
              spec
              (pull-attr-from-spec spec (value-entity child) child-attrs)
              registry))
          (set! child-attrs attrs)
          (set! i (- i 1))))
      (let [built-result (Pull-Result {e: entity attrs: child-attrs})]
        (delete build-seen)
        (delete build-counts)
        (delete path)
        (delete seen-counts)
        (return built-result true)))))

(defn pull-spec-decrement-recursion [spec: Pull-Spec, attr: string] -> Pull-Spec
  (if (and spec.has-recursion
           (= spec.a attr)
           (not (= spec.recursion-depth 0)))
    (pull-spec-with-recursion spec (pull-next-recursion-depth spec.recursion-depth))
    spec))

(defn pull-recursion-pattern [root: []Pull-Spec, attr: string] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec)]
    (for [spec root]
      (arr.push! out (pull-spec-decrement-recursion spec attr)))
    out))

(defn pull-attr-child-value [children: []Pull-Attr, attr: string] -> [value: Value, ok: bool]
  (for [child children]
    (when (= child.a attr)
      (return child.v true)))
  (return (Value {}) false))

(defn pull-spec-transform-attr-with-fns [spec: Pull-Spec, attr: Pull-Attr, registry: []Native-Query-Fn] -> Pull-Attr
  (when (not spec.has-xform)
    (return attr))
  (when (= spec.xform "vector")
    (return (Pull-Attr {a: attr.a
                        a-owned: attr.a-owned
                        key-kind: attr.key-kind
                        v: (value-vector ([]Value [attr.v]))
                        attrs: (make [dynamic]Pull-Attr)
                        has-explicit-pattern: attr.has-explicit-pattern})))
  (when (= spec.xform "name")
    (let [[name name-ok] (pull-attr-child-value (slice attr.attrs 0) ":name")]
      (when name-ok
        (delete attr.attrs)
        (return (Pull-Attr {a: attr.a
                            a-owned: attr.a-owned
                            key-kind: attr.key-kind
                            v: name
                            attrs: (make [dynamic]Pull-Attr)
                            has-explicit-pattern: attr.has-explicit-pattern})))))
  (let [[index found] (query-fn-index registry spec.xform)]
    (when found
      (let [entry registry[index]]
        (when entry.has-pull-xform-callback
          (let [result (entry.pull-xform-callback attr.v)]
            (when result.ok
              (delete attr.attrs)
              (return (Pull-Attr {a: attr.a
                                  a-owned: attr.a-owned
                                  key-kind: attr.key-kind
                                  v: result.value
                                  attrs: (make [dynamic]Pull-Attr)
                                  has-explicit-pattern: attr.has-explicit-pattern}))))))))
  attr)

(defn pull-spec-transform-attr [spec: Pull-Spec, attr: Pull-Attr] -> Pull-Attr
  (pull-spec-transform-attr-with-fns spec attr ([]Native-Query-Fn [])))

(defn pull-spec-missing-attr-with-fns [spec: Pull-Spec, registry: []Native-Query-Fn] -> Pull-Attr
  (if spec.has-default
    (pull-attr-from-spec spec spec.default-value (make [dynamic]Pull-Attr))
    (pull-spec-transform-attr-with-fns
      spec
      (pull-attr-from-spec spec (value-nil) (make [dynamic]Pull-Attr))
      registry)))

(defn pull-spec-missing-attr [spec: Pull-Spec] -> Pull-Attr
  (pull-spec-missing-attr-with-fns spec ([]Native-Query-Fn [])))

(defn pull-forward-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> bool
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity spec.a (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity spec.a (Value {}))
        limit (pull-limit spec)
        seen 0
        found false]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [children (make [dynamic]Pull-Attr)]
            (when (= datom.v.kind .Entity)
              (if (> (count spec.pattern) 0)
                (set! children (pull-child-pattern-mut-with-fns db datom.v.entity spec.pattern spec.pattern seen-entities seen-counts registry))
                (if (and spec.has-recursion (not (= spec.recursion-depth 0)))
                  (if (pull-unbounded-recursion-depth? spec.recursion-depth)
                    (set! children (pull-child-recursion-mut-with-fns db datom.v.entity root seen-entities seen-counts registry))
                    (let [pattern (pull-recursion-pattern root spec.a)]
                      (defer (delete pattern))
                      (set! children (pull-child-recursion-mut-with-fns db datom.v.entity (slice pattern 0) seen-entities seen-counts registry))))
                  (when (schema-component? db datom.a)
                    (set! children (pull-component-children db entity datom.v.entity))))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^
                  (pull-spec-transform-attr-with-fns
                    spec
                    (pull-attr-from-spec spec datom.v children)
                    registry))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-forward-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-forward-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-spec-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn]
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (when (= spec.a "*")
    (pull-wildcard! out db entity)
    (return))
  (when (= spec.a ":db/id")
    (when (not (pull-output-has-attr? out^ (pull-output-attr spec)))
      (arr.push! out^
        (pull-spec-transform-attr-with-fns
          spec
          (pull-attr-from-spec spec (value-entity entity) (make [dynamic]Pull-Attr))
          registry)))
    (return))
  (when (reverse-attr? spec.a)
    (pull-remove-output-attr-shallow! out (pull-output-attr spec))
    (let [found (pull-reverse-attr-with-fns! out db entity spec root seen-entities seen-counts registry)]
      (when (and (not found) (or spec.has-default spec.has-xform))
        (arr.push! out^ (pull-spec-missing-attr-with-fns spec registry))))
    (return))
  (pull-remove-output-attr-shallow! out (pull-output-attr spec))
  (let [found (pull-forward-attr-with-fns! out db entity spec root seen-entities seen-counts registry)]
    (when (and (not found) (or spec.has-default spec.has-xform))
      (arr.push! out^ (pull-spec-missing-attr-with-fns spec registry)))))

(defn pull-spec-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-spec-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-pattern-spec-seen-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> Pull-Result
  (let [out (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (pull-spec-attr-with-fns! (addr out) db entity spec root seen-entities seen-counts registry))
    (Pull-Result {e: entity attrs: out})))

(defn pull-pattern-spec-seen [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> Pull-Result
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-pattern-spec-seen-with-fns db entity pattern root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-pattern-spec-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [seen (make [dynamic]u64)
        seen-counts (make (map u64 int))
        normalized (normalize-pull-pattern pattern)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (defer (delete normalized))
    (let [[chain-spec chain-ok] (pull-simple-unbounded-forward-recursion-spec (slice normalized 0))]
      (when chain-ok
        (let [[chain chain-built] (pull-pattern-simple-unbounded-forward-chain-with-fns db entity (slice normalized 0) chain-spec registry)]
          (when chain-built
            (return chain)))))
    (arr.push! seen entity)
    (pull-seen-push! (addr seen-counts) entity)
    (pull-pattern-spec-seen-with-fns db entity (slice normalized 0) (slice normalized 0) (addr seen) (addr seen-counts) registry)))

(defn pull-pattern-spec [db: DB, entity: u64, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-spec-with-fns db entity pattern ([]Native-Query-Fn [])))

(defn pull-pattern-lookup-ref-with-fns [db: DB, attr: string, value: Value, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [[entity ok] (resolve-lookup-ref db attr value)]
    (if ok
      (pull-pattern-spec-with-fns db entity pattern registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-pattern-lookup-ref [db: DB, attr: string, value: Value, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-lookup-ref-with-fns db attr value pattern ([]Native-Query-Fn [])))

(defn pull-pattern-ident-with-fns [db: DB, ident: string, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [[entity ok] (schema-entity-for-attr db ident)]
    (if ok
      (pull-pattern-spec-with-fns db entity pattern registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-pattern-ident [db: DB, ident: string, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-ident-with-fns db ident pattern ([]Native-Query-Fn [])))

(defn pull-visit-attr [entity: u64, attr: string] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/attr"
               has-e: true
               e: entity
               a: attr
               has-v: false}))

(defn pull-visit-wildcard [entity: u64] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/wildcard"
               has-e: true
               e: entity
               a: ""
               has-v: false}))

(defn pull-visit-reverse [attr: string, entity: u64] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/reverse"
               has-e: false
               e: 0
               a: attr
               has-v: true
               v-entity: entity}))

(defn string-seen? [items: []string, value: string] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn trace-pull-wildcard! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64]
  (arr.push! visits^ (pull-visit-wildcard entity))
  (let [seen-attrs (make [dynamic]string) :defer
        view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt" entity "" (Value {}))
        high (upper-bound-index-view db view "eavt" entity "" (Value {}))]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (string-seen? (slice seen-attrs 0) datom.a)))
          (arr.push! seen-attrs datom.a)
          (arr.push! visits^ (pull-visit-attr entity datom.a)))))))

(defn trace-pull-reverse-refs! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int))]
  (arr.push! visits^ (pull-visit-reverse (forward-attr-for-reverse spec.a) entity))
  (when (and (= (count spec.pattern) 0)
             (not spec.has-recursion))
    (return))
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (let [forward-attr (forward-attr-for-reverse spec.a) :defer
        ref-value (value-entity entity)
        view (db-index-view db .VAET)
        low (lower-bound-index-view db view "vaet" 0 "" ref-value)
        high (upper-bound-index-view db view "vaet" 0 "" ref-value)
        limit (pull-limit spec)
        seen 0]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? db datom-index)
                   (< seen limit))
          (if (> (count spec.pattern) 0)
            (trace-pull-pattern! visits db datom.e spec.pattern spec.pattern seen-counts)
            (when spec.has-recursion
              (let [pattern (pull-recursion-pattern root spec.a)]
                (defer (delete pattern))
                (trace-pull-pattern! visits db datom.e (slice pattern 0) (slice pattern 0) seen-counts))))
          (set! seen (+ seen 1)))))))

(defn trace-pull-forward-refs! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int))]
  (arr.push! visits^ (pull-visit-attr entity spec.a))
  (when (and (= (count spec.pattern) 0)
             (not spec.has-recursion))
    (return))
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity spec.a (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity spec.a (Value {}))
        limit (pull-limit spec)
        seen 0]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (< seen limit))
          (if (> (count spec.pattern) 0)
            (trace-pull-pattern! visits db datom.v.entity spec.pattern spec.pattern seen-counts)
            (when spec.has-recursion
              (let [pattern (pull-recursion-pattern root spec.a)]
                (defer (delete pattern))
                (trace-pull-pattern! visits db datom.v.entity (slice pattern 0) (slice pattern 0) seen-counts))))
          (set! seen (+ seen 1)))))))

(defn trace-pull-spec! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int))]
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (when (= spec.a "*")
    (trace-pull-wildcard! visits db entity)
    (return))
  (when (= spec.a ":db/id")
    (return))
  (if (reverse-attr? spec.a)
    (trace-pull-reverse-refs! visits db entity spec root seen-counts)
    (trace-pull-forward-refs! visits db entity spec root seen-counts)))

(defn trace-pull-pattern! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int))]
  (when (pull-seen-contains? seen-counts entity)
    (return))
  (pull-seen-push! seen-counts entity)
  (let [normalized (normalize-pull-pattern pattern) :defer]
    (for [spec normalized]
      (trace-pull-spec! visits db entity spec root seen-counts)))
  (pull-seen-pop! seen-counts entity))

(defn pull-visits-pattern-spec [db: DB, entity: u64, pattern: []Pull-Spec] -> [dynamic]Pull-Visit
  (let [visits (make [dynamic]Pull-Visit)
        seen-counts (make (map u64 int)) :defer
        normalized (normalize-pull-pattern pattern) :defer]
    (trace-pull-pattern! (addr visits) db entity (slice normalized 0) (slice normalized 0) (addr seen-counts))
    visits))

(defn pull-pattern-spec-traced [db: DB, entity: u64, pattern: []Pull-Spec] -> [result: Pull-Result, visits: [dynamic]Pull-Visit]
  (let [pulled (pull-pattern-spec db entity pattern)
        trace (pull-visits-pattern-spec db entity pattern)]
    (return pulled trace)))

(defn entity-exists? [db: DB, e: u64] -> bool
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt" e "" (Value {}))
        high (upper-bound-index-view db view "eavt" e "" (Value {}))]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)]
      (when (datom-current-at? db datom-index)
        (return true)))))
  false)

(defn db-entity [db: DB, e: u64] -> Entity
  (Entity {db: db e: e found: (entity-exists? db e)}))

(defn entity-lookup-ref [db: DB, attr: string, value: Value] -> Entity
  (let [[e ok] (resolve-lookup-ref db attr value)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-ident [db: DB, ident: string] -> Entity
  (let [[e ok] (schema-entity-for-attr db ident)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-id [entity: Entity] -> u64
  entity.e)

(defn entity-db [entity: Entity] -> DB
  entity.db)

(defn entity-forward-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [view (db-index-view entity.db .EAVT)
          low (lower-bound-index-view entity.db view "eavt-ea" entity.e attr (Value {}))
          high (upper-bound-index-view entity.db view "eavt-ea" entity.e attr (Value {}))]
      (for [index (arr.range low high)]
        (let [datom-index (db-index-view-at view index)
              datom entity.db.datoms[datom-index]]
          (when (datom-current-at? entity.db datom-index)
            (arr.push! out datom.v)))))
    out))

(defn entity-reverse-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [forward-attr (forward-attr-for-reverse attr)
          ref-value (value-entity entity.e)
          view (db-index-view entity.db .VAET)
          low (lower-bound-index-view entity.db view "vaet" 0 "" ref-value)
          high (upper-bound-index-view entity.db view "vaet" 0 "" ref-value)]
      (for [index (arr.range low high)]
        (let [datom-index (db-index-view-at view index)
              datom entity.db.datoms[datom-index]]
          (when (and (= datom.a forward-attr)
                     (datom-current-at? entity.db datom-index))
            (arr.push! out (value-entity datom.e))))))
    out))

(defn entity-values [entity: Entity, attr: string] -> [dynamic]Value
  (if (reverse-attr? attr)
    (entity-reverse-values entity attr)
    (entity-forward-values entity attr)))

(defn entity-first-forward-value [entity: Entity, attr: string] -> [value: Value, ok: bool]
  (when (not entity.found)
    (return (Value {}) false))
  (let [view (db-index-view entity.db .EAVT)
        low (lower-bound-index-view entity.db view "eavt-ea" entity.e attr (Value {}))
        high (upper-bound-index-view entity.db view "eavt-ea" entity.e attr (Value {}))]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom entity.db.datoms[datom-index]]
        (when (datom-current-at? entity.db datom-index)
          (return datom.v true)))))
  (return (Value {}) false))

(defn entity-first-reverse-value [entity: Entity, attr: string] -> [value: Value, ok: bool]
  (when (not entity.found)
    (return (Value {}) false))
  (let [forward-attr (forward-attr-for-reverse attr)
        ref-value (value-entity entity.e)
        view (db-index-view entity.db .VAET)
        low (lower-bound-index-view entity.db view "vaet" 0 "" ref-value)
        high (upper-bound-index-view entity.db view "vaet" 0 "" ref-value)]
    (for [index (arr.range low high)]
      (let [datom-index (db-index-view-at view index)
            datom entity.db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? entity.db datom-index))
          (return (value-entity datom.e) true)))))
  (return (Value {}) false))

(defn entity-first-value [entity: Entity, attr: string] -> [value: Value, ok: bool]
  (when (= attr ":db/id")
    (if entity.found
      (return (value-entity entity.e) true)
      (return (Value {}) false)))
  (if (reverse-attr? attr)
    (entity-first-reverse-value entity attr)
    (entity-first-forward-value entity attr)))

(defn entity-first-value-kw [entity: Entity, attr: keyword] -> [value: Value, ok: bool]
  (entity-first-value entity (keyword-text attr)))

(defn entity-get [entity: Entity, attr: string] -> Value
  (let [[value ok] (entity-first-value entity attr)]
    (if ok
      value
      (value-nil))))

(defn entity-get-kw [entity: Entity, attr: keyword] -> Value
  (entity-get entity (keyword-text attr)))

(defn entity-contains? [entity: Entity, attr: string] -> bool
  (let [[_ ok] (entity-first-value entity attr)]
    ok))

(defn entity-has-value? [entity: Entity, attr: string] -> bool
  (entity-contains? entity attr))

(defn entity-has-value-kw? [entity: Entity, attr: keyword] -> bool
  (entity-has-value? entity (keyword-text attr)))

(defn entity-refs [entity: Entity, attr: string] -> [dynamic]Entity
  (let [out (make [dynamic]Entity)
        values (entity-values entity attr)]
    (defer (delete values))
    (for [value values]
      (when (= value.kind .Entity)
        (let [ref (db-entity entity.db value.entity)]
          (when ref.found
            (arr.push! out ref)))))
    out))

(defn entity-ref [entity: Entity, attr: string] -> Entity
  (let [[ref ok] (entity-first-ref entity attr)]
    (if ok
      ref
      (Entity {db: entity.db e: 0 found: false}))))

(defn entity-ref-kw [entity: Entity, attr: keyword] -> Entity
  (entity-ref entity (keyword-text attr)))

(defn entity-first-ref [entity: Entity, attr: string] -> [ref: Entity, ok: bool]
  (let [[value value-ok] (entity-first-value entity attr)]
    (when (and value-ok (= value.kind .Entity))
      (let [ref (db-entity entity.db value.entity)]
        (when ref.found
          (return ref true)))))
  (return (Entity {db: entity.db e: 0 found: false}) false))

(defn entity-first-ref-kw [entity: Entity, attr: keyword] -> [ref: Entity, ok: bool]
  (entity-first-ref entity (keyword-text attr)))

(defn touch [entity: Entity] -> Pull-Result
  (if entity.found
    (pull-pattern-spec entity.db entity.e ([]Pull-Spec [(flat-pull-spec "*")]))
    (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))

(defn flat-pull-spec [attr: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: (make [dynamic]Pull-Spec)}))

(defn flat-pull-spec-kw [attr: keyword] -> Pull-Spec
  (flat-pull-spec (keyword-text attr)))

(defn pull-alias-key-kind [alias: string] -> Key-Kind
  (if (strings.has_prefix alias ":")
    .Keyword
    .String))

(defn pull-spec-pattern-copy [pattern: []Pull-Spec] -> [dynamic]Pull-Spec
  (arr.into [dynamic]Pull-Spec pattern))

(defn pull-spec-base [attr: string, pattern: []Pull-Spec] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: (pull-spec-pattern-copy pattern)}))

(defn pull-spec [attr: string, pattern: []Pull-Spec] -> Pull-Spec
  (pull-spec-base attr pattern))

(defn pull-spec-with-pattern [base: Pull-Spec, pattern: []Pull-Spec] -> Pull-Spec
  (let [out base]
    (set! out.pattern (pull-spec-pattern-copy pattern))
    out))

(defn pull-spec-with-default [base: Pull-Spec, default-value: Value] -> Pull-Spec
  (let [out base]
    (set! out.has-default true)
    (set! out.default-value default-value)
    out))

(defn pull-spec-with-alias-kind [base: Pull-Spec, alias: string, kind: Key-Kind] -> Pull-Spec
  (let [out base]
    (set! out.has-alias true)
    (set! out.alias alias)
    (set! out.alias-kind kind)
    out))

(defn pull-spec-with-alias [base: Pull-Spec, alias: string] -> Pull-Spec
  (pull-spec-with-alias-kind base alias (pull-alias-key-kind alias)))

(defn pull-spec-with-limit [base: Pull-Spec, limit: int] -> Pull-Spec
  (let [out base]
    (set! out.has-limit true)
    (set! out.limit limit)
    out))

(defn pull-spec-with-xform [base: Pull-Spec, xform: string] -> Pull-Spec
  (let [out base]
    (set! out.has-xform true)
    (set! out.xform xform)
    out))

(defn pull-spec-with-recursion [base: Pull-Spec, depth: int] -> Pull-Spec
  (let [out base]
    (set! out.has-recursion true)
    (set! out.recursion-depth depth)
    out))

(defn pull-spec-kw [attr: keyword, pattern: []Pull-Spec] -> Pull-Spec
  (pull-spec (keyword-text attr) pattern))

(defn query-input-pull-pattern [pattern: []Pull-Spec] -> Query-Input
  (let [owned (arr.into [dynamic]Pull-Spec pattern)]
    (Query-Input {kind: .PullPattern pattern: owned})))

(defn query-input-pull-pattern-owned [pattern: [dynamic]Pull-Spec] -> Query-Input
  (Query-Input {kind: .PullPattern pattern: pattern}))

(defn pull-spec-recursion [attr: string, depth: int] -> Pull-Spec
  (pull-spec-with-recursion (flat-pull-spec attr) depth))

(defn pull-spec-recursion-kw [attr: keyword, depth: int] -> Pull-Spec
  (pull-spec-recursion (keyword-text attr) depth))

(defn pull-spec-limit [attr: string, pattern: []Pull-Spec, limit: int] -> Pull-Spec
  (pull-spec-with-limit (pull-spec attr pattern) limit))

(defn pull-spec-limit-kw [attr: keyword, pattern: []Pull-Spec, limit: int] -> Pull-Spec
  (pull-spec-limit (keyword-text attr) pattern limit))

(defn pull-spec-limit-as [attr: string, pattern: []Pull-Spec, limit: int, alias: string] -> Pull-Spec
  (pull-spec-with-alias (pull-spec-limit attr pattern limit) alias))

(defn pull-spec-default [attr: string, default-value: Value] -> Pull-Spec
  (pull-spec-with-default (flat-pull-spec attr) default-value))

(defn pull-spec-default-kw [attr: keyword, default-value: Value] -> Pull-Spec
  (pull-spec-default (keyword-text attr) default-value))

(defn pull-spec-as [attr: string, alias: string] -> Pull-Spec
  (pull-spec-with-alias (flat-pull-spec attr) alias))

(defn pull-spec-default-as [attr: string, default-value: Value, alias: string] -> Pull-Spec
  (pull-spec-with-alias (pull-spec-default attr default-value) alias))

(defn pull-spec-xform [attr: string, pattern: []Pull-Spec, xform: string] -> Pull-Spec
  (pull-spec-with-xform (pull-spec attr pattern) xform))

(defn pull-spec-default-xform [attr: string, default-value: Value, xform: string] -> Pull-Spec
  (pull-spec-with-xform (pull-spec-default attr default-value) xform))

(defn pull-pattern [db: DB, entity: u64, attrs: []string] -> Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-pattern-spec db entity (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn pull-many-pattern-spec-with-fns [db: DB, entities: []u64, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count entities))]
    (for [entity entities]
      (arr.push! out (pull-pattern-spec-with-fns db entity pattern registry)))
    out))

(defn pull-many-pattern-spec [db: DB, entities: []u64, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (pull-many-pattern-spec-with-fns db entities pattern ([]Native-Query-Fn [])))

(defn pull-many-pattern-lookup-refs-with-fns [db: DB, attrs: []string, values: []Value, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count values))]
    (for [value index values]
      (let [[entity ok] (resolve-lookup-ref db attrs[index] value)]
        (if ok
          (arr.push! out (pull-pattern-spec-with-fns db entity pattern registry))
          (arr.push! out (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))))
    out))

(defn pull-many-pattern-lookup-refs [db: DB, attrs: []string, values: []Value, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (pull-many-pattern-lookup-refs-with-fns db attrs values pattern ([]Native-Query-Fn [])))

(defn pull-many-pattern [db: DB, entities: []u64, attrs: []string] -> [dynamic]Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-many-pattern-spec db entities (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn query-name-by-email [email: string] -> Query
  (query ([]string ["name"])
    ([]string [])
    ([]string [])
    ([]string [])
    ([]Tuple-Input [])
    ([]Relation-Input [])
    ([]Clause
      [(clause (term-var "e") ":user/email" (term-string email))
       (clause (term-var "e") ":user/name" (term-var "name"))])
    ([]Predicate [])
    ([]Function-Clause [])
    ([]Rule [])
    ([]Rule-Call [])
    ([]Get-Else [])
    ([]Get-Some [])
    ([]Ground [])
    ([]Not-Group [])
    ([]Or-Group [])
    ([]Pull-Find [])
    ([]Aggregate-Find [])))

(defn seed-people [conn: ^Conn] -> Tx-Report
  (transact conn
    ([]Tx-Data
      [(add 1 ":user/email" (value-string "ada@example.com"))
       (add 1 ":user/name" (value-string "Ada"))
       (add 1 ":user/age" (value-int 37))
       (add 1 ":user/active" (value-bool true))
       (add 1 ":user/friend" (value-entity 2))
       (add 2 ":user/email" (value-string "grace@example.com"))
       (add 2 ":user/name" (value-string "Grace"))
       (add 2 ":user/age" (value-int 41))
       (add 2 ":user/active" (value-bool false))])))
