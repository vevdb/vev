  (when columns.owns-strings
    (for [text columns.strings]
      (delete text)))
  (delete columns.entities)
  (delete columns.strings))

(defn delete-entity-string-pair-columns-shallow [columns: Entity-String-Pair-Columns]
  (delete columns.entities)
  (delete columns.strings))

(defn append-entity-string-pair-column! [columns: ^Entity-String-Pair-Columns, entity: u64, text: string]
  (arr.push! columns^.entities entity)
  (arr.push! columns^.strings text))

