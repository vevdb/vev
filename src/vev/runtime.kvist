(defn result-set-from-source-string-int-pair-columns [columns: Entity-String-Int-Triples] -> Result-Set
  (let [rows (make [dynamic]Result-Row 0 (count columns.strings))]
    (for [index (arr.range 0 (count columns.strings))]
      (append-two-value-row! (addr rows)
                             (value-string (if columns.owns-strings columns.strings[index] (string-owned columns.strings[index])))
                             (value-int columns.ints[index])))
    (if columns.owns-strings
      (delete-entity-string-int-triples-shallow columns)
      (delete-entity-string-int-triples columns))
    (result-set-ok rows)))

(defn result-set-from-source-string-string-pair-columns [columns: String-String-Pair-Columns] -> Result-Set
  (let [rows (make [dynamic]Result-Row 0 (count columns.first))]
    (for [index (arr.range 0 (count columns.first))]
      (append-two-value-row! (addr rows)
                             (value-string (if columns.owns-strings columns.first[index] (string-owned columns.first[index])))
                             (value-string (if columns.owns-strings columns.second[index] (string-owned columns.second[index])))))
    (if columns.owns-strings
      (delete-string-string-pair-columns-shallow columns)
      (delete-string-string-pair-columns columns))
    (result-set-ok rows)))

(defn result-set-from-source-entity-string-int-triples [columns: Entity-String-Int-Triples] -> Result-Set
  (let [rows (make [dynamic]Result-Row 0 (count columns.entities))]
    (for [index (arr.range 0 (count columns.entities))]
      (append-three-value-row! (addr rows)
                               (value-entity columns.entities[index])
                               (value-string (if columns.owns-strings columns.strings[index] (string-owned columns.strings[index])))
                               (value-int columns.ints[index])))
    (if columns.owns-strings
      (delete-entity-string-int-triples-shallow columns)
      (delete-entity-string-int-triples columns))
    (result-set-ok rows)))

(defn q-db-read-source-entity-int-pair-columns [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [columns: Entity-Int-Pair-Columns, ok: bool, error: string]
  (let [out (empty-entity-int-pair-columns)
        seen (set.empty string)]
    (defer (delete seen))
    (when (> (count inputs) 0)
      (return out false ""))
    (let [[projection projection-ok] (db-read-source-query-filtered-entity-attr-value-projection query)]
      (when (not projection-ok)
        (return out false ""))
      (when (not (and (= (count query.find) 2)
                      (= query.find[0] projection.entity-var)
                      (= query.find[1] projection.value-var)))
        (return out false ""))
      (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source projection.value-attr)]
        (when (not many-ok)
          (return out false many-error))
        (if (db-read-source-has-overlay? source)
          (let [filter-datoms (make [dynamic]Datom)
                [filter-ok filter-error] (db-read-source-append-attr-value-datoms! (addr filter-datoms) source projection.filter-attr projection.filter-value)]
            (when (not filter-ok)
              (delete-owned-datoms filter-datoms)
              (return out false filter-error))
            (let [[append-ok type-ok append-error] (source-entity-int-pair-append-filter-datoms! (addr out) (addr seen) source (slice filter-datoms 0) projection.value-attr many)]
              (when (not append-ok)
                (delete-owned-datoms filter-datoms)
                (return out false append-error))
              (when (not type-ok)
                (delete-owned-datoms filter-datoms)
                (return out false "")))
            (delete-owned-datoms filter-datoms))
          (let [[filter-stream filter-ok filter-error] (source-attr-value-match-stream source projection.filter-attr projection.filter-value)]
            (when (not filter-ok)
              (return out false filter-error))
            (let [[append-ok type-ok append-error] (source-entity-int-pair-append-filter-stream! (addr out) (addr seen) source (addr filter-stream) projection.value-attr many)]
              (when (not append-ok)
                (delete-source-attr-value-match-stream filter-stream)
                (return out false append-error))
              (when (not type-ok)
                (delete-source-attr-value-match-stream filter-stream)
                (return out false "")))
            (delete-source-attr-value-match-stream filter-stream)))
        (return out true "")))))

(defn append-db-read-source-range-filtered-entity-attr-value-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Range-Filtered-Entity-Attr-Value-Projection, entity: u64, source-value: Value]
  (if (= (count query.find) 1)
    (when (not (row-values-exist? (slice rows^ 0) ([]Value [source-value])))
      (append-distinct-single-value-row! rows (value-owned source-value)))
    (let [entity-value (value-entity entity)
          first-value (if (= query.find[0] projection.entity-var) entity-value source-value)
          second-value (if (= query.find[1] projection.value-var) source-value entity-value)
          dedupe-values ([]Value [first-value second-value])]
      (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
        (append-owned-two-value-row! rows first-value second-value)))))

(defn append-db-read-source-range-filtered-projection-values! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Range-Filtered-Entity-Attr-Value-Projection, entity: u64, many: bool] -> [ok: bool, error: string]
  (if many
    (if (db-read-source-has-overlay? source)
      (let [[projected-datoms projected-ok projected-error] (db-read-source-datoms-by-entity-attr source entity projection.value-attr)]
        (when (not projected-ok)
          (return false projected-error))
        (for [projected-datom projected-datoms]
          (append-db-read-source-range-filtered-entity-attr-value-row! rows query projection entity projected-datom.v))
        (delete-owned-datoms projected-datoms)
        (return true ""))
      (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity projection.value-attr)]
        (when (not stream-ok)
          (return false stream-error))
        (while stream.has-current
          (append-db-read-source-range-filtered-entity-attr-value-row! rows query projection entity stream.current.v)
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false advance-error))))
        (delete-source-index-datom-stream stream)
        (return true "")))
    (let [[projected-value projected-ok projected-error] (db-read-source-cardinality-one-value-fast-all-current source entity projection.value-attr)]
      (when (not (= projected-error ""))
        (return false projected-error))
      (when projected-ok
        (append-db-read-source-range-filtered-entity-attr-value-row! rows query projection entity projected-value)
        (delete-owned-value projected-value))
      (return true ""))))

(defn append-db-read-source-range-filtered-projection-from-filter-datom! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Range-Filtered-Entity-Attr-Value-Projection, filter-datom: Datom, many: bool] -> [ok: bool, error: string]
  (when (not (and (= filter-datom.a projection.filter-attr)
                  (predicate-pair-matches? projection.filter-op filter-datom.v projection.filter-value)))
    (return true ""))
  (append-db-read-source-range-filtered-projection-values! rows source query projection filter-datom.e many))

(defn q-db-read-source-range-filtered-entity-attr-value-projection [source: DB-Read-Source, query: Query, projection: Source-Range-Filtered-Entity-Attr-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [many many-ok many-error] (db-read-source-schema-cardinality-many? source projection.value-attr)]
    (when (not many-ok)
      (return (result-set-error many-error)))
    (let [range-projection (Source-Attr-Range-Value-Projection {attr: projection.filter-attr
                                                                value-var: projection.filter-var
                                                                op: projection.filter-op
                                                                value: projection.filter-value})
          [filter-stream filter-ok filter-error] (source-index-datom-stream-for-attr-range source range-projection)]
      (when (not filter-ok)
        (delete-result-rows-owned-values rows)
        (return (result-set-error filter-error)))
      (while filter-stream.has-current
        (let [[append-ok append-error] (append-db-read-source-range-filtered-projection-from-filter-datom! (addr rows) source query projection filter-stream.current many)]
          (when (not append-ok)
            (delete-source-index-datom-stream filter-stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error append-error))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr filter-stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream filter-stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-index-datom-stream filter-stream))
    (result-set-ok rows)))

(defn db-read-source-range-star-projection-ready? [source: DB-Read-Source, query: Query, projection: Source-Range-Star-Projection] -> [ok: bool, error: string]
  (let [i 0]
    (while (< i (count query.clauses))
      (when (not (= i projection.filter-index))
        (let [[_ many-ok many-error] (db-read-source-schema-cardinality-many? source query.clauses[i].a.value.text)]
          (when (not many-ok)
            (return false many-error))))
      (set! i (+ i 1)))
    (return true "")))

(defn source-range-star-clause-index-for-var [query: Query, entity-var: string, name: string] -> [index: int, entity?: bool, ok: bool]
  (when (= name entity-var)
    (return 0 true true))
  (let [i 0]
    (while (< i (count query.clauses))
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name name))
        (return i false true))
      (set! i (+ i 1)))
    (return 0 false false)))

(defn db-read-source-range-star-options-for-find-var [source: DB-Read-Source, query: Query, projection: Source-Range-Star-Projection, filter-datom: Datom, find-var: string] -> [option-row: Result-Row, ok: bool, error: string]
  (let [values (make [dynamic]Value)
        pulls (make [dynamic]Pull-Result)
        out-row (Result-Row {values: values pulls: pulls})
        [clause-index entity? clause-ok] (source-range-star-clause-index-for-var query projection.entity-var find-var)]
    (when (not clause-ok)
      (delete out-row.values)
      (delete out-row.pulls)
      (return out-row false "source range projection find var missing from clauses"))
    (cond
      entity?
        (arr.push! out-row.values (value-entity filter-datom.e))
      (= clause-index projection.filter-index)
        (arr.push! out-row.values (value-owned filter-datom.v))
      :else
        (let [[option-ok option-error] (append-source-entity-attr-option-values! (addr out-row) source filter-datom.e query.clauses[clause-index].a.value.text)]
          (when (not option-ok)
            (delete out-row.values)
            (delete out-row.pulls)
            (return out-row false option-error))))
    (return out-row true "")))

(defn append-db-read-source-range-star-row! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Range-Star-Projection, filter-datom: Datom] -> [ok: bool, error: string]
  (when (not (and (= filter-datom.a projection.filter-attr)
                  (predicate-pair-matches? projection.filter-op filter-datom.v projection.filter-value)))
    (return true ""))
  (let [options (make [dynamic]Result-Row)
        prefix (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[option option-ok option-error] (db-read-source-range-star-options-for-find-var source query projection filter-datom find-var)]
        (when (not option-ok)
          (delete-owned-values-array option.values)
          (delete option.pulls)
          (delete-result-rows-owned-values options)
          (delete prefix)
          (return false option-error))
        (arr.push! options option)))
    (let [[product-ok product-error] (append-db-read-source-star-option-product! rows (slice options 0) 0 (slice prefix 0))]
      (delete-result-rows-owned-values options)
      (delete prefix)
      (return product-ok product-error))))

(defn q-db-read-source-range-star-projection [source: DB-Read-Source, query: Query, projection: Source-Range-Star-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        range-projection (Source-Attr-Range-Value-Projection {attr: projection.filter-attr
                                                              value-var: projection.filter-var
                                                              op: projection.filter-op
                                                              value: projection.filter-value})]
    (let [[filter-stream filter-ok filter-error] (source-index-datom-stream-for-attr-range source range-projection)]
      (when (not filter-ok)
        (delete-result-rows-owned-values rows)
        (return (result-set-error filter-error)))
      (while filter-stream.has-current
        (let [[append-ok append-error] (append-db-read-source-range-star-row! (addr rows) source query projection filter-stream.current)]
          (when (not append-ok)
            (delete-source-index-datom-stream filter-stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error append-error))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr filter-stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream filter-stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-index-datom-stream filter-stream))
    (result-set-ok rows)))

(defn q-db-read-source-attr-entity-projection [source: DB-Read-Source, projection: Source-Attr-Entity-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)]
    (if (reverse-attr? projection.attr)
      (let [forward-attr (forward-attr-for-reverse projection.attr) :defer]
        (if (db-read-source-has-overlay? source)
          (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source forward-attr)]
            (when (not datoms-ok)
              (return (result-set-error datoms-error)))
            (defer (delete-owned-datoms datoms))
            (for [datom datoms]
              (when (= datom.v.kind .Entity)
                (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.v.entity)])))
                  (append-entity-row! (addr rows) datom.v.entity)))))
          (let [[stream stream-ok stream-error] (source-index-datom-stream source forward-attr)]
            (when (not stream-ok)
              (return (result-set-error stream-error)))
            (while stream.has-current
              (when (= stream.current.v.kind .Entity)
                (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity stream.current.v.entity)])))
                  (append-entity-row! (addr rows) stream.current.v.entity)))
              (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                (when (not advance-ok)
                  (delete-source-index-datom-stream stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error advance-error)))))
            (delete-source-index-datom-stream stream))))
      (if (db-read-source-has-overlay? source)
        (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source projection.attr)]
          (when (not datoms-ok)
            (return (result-set-error datoms-error)))
          (defer (delete-owned-datoms datoms))
          (for [datom datoms]
            (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity datom.e)])))
              (append-entity-row! (addr rows) datom.e))))
        (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.attr)]
          (when (not stream-ok)
            (return (result-set-error stream-error)))
          (while stream.has-current
            (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity stream.current.e)])))
              (append-entity-row! (addr rows) stream.current.e))
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream stream)
                (delete-result-rows-owned-values rows)
                (return (result-set-error advance-error)))))
          (delete-source-index-datom-stream stream))))
    (result-set-ok rows)))

(defn source-entity-pull-datom-matches-filter? [projection: Source-Entity-Pull-Projection, datom: Datom] -> bool
  (or (not projection.has-entity-filter)
      (predicate-value-equal? (value-entity datom.e) projection.entity-filter)))

(defn append-db-read-source-entity-pull-rows! [rows: ^[dynamic]Result-Row, seen: (ptr (map u64 (struct {}))), pull-source: DB-Read-Source, query: Query, projection: Source-Entity-Pull-Projection, pattern: []Pull-Spec, datoms: []Datom, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (for [datom datoms]
    (let [[append-ok append-error] (append-db-read-source-entity-pull-row! rows seen pull-source query projection pattern datom registry)]
      (when (not append-ok)
        (return false append-error))))
  (return true ""))

(defn append-db-read-source-entity-pull-row! [rows: ^[dynamic]Result-Row, seen: (ptr (map u64 (struct {}))), pull-source: DB-Read-Source, query: Query, projection: Source-Entity-Pull-Projection, pattern: []Pull-Spec, datom: Datom, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (when (and (source-entity-pull-datom-matches-filter? projection datom)
             (not (set.contains? seen^ datom.e)))
    (set.add! seen datom.e)
    (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-source datom.e pattern registry)]
      (when (not pull-ok)
        (return false pull-error))
      (let [values (make [dynamic]Value 0 (count query.find))
            pulls (make [dynamic]Pull-Result 0 1)]
        (when (= (count query.find) 1)
          (arr.push! values (value-entity datom.e)))
        (arr.push! pulls pull)
        (arr.push! rows^ (Result-Row {values: values pulls: pulls})))))
  (return true ""))

(defn q-db-read-source-entity-pull-projection [scan-source: DB-Read-Source, pull-source: DB-Read-Source, query: Query, inputs: []Query-Input, projection: Source-Entity-Pull-Projection, pull-find: Pull-Find, registry: []Native-Query-Fn] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen (set.empty u64)
        [pattern pattern-ok] (db-read-source-pull-find-pattern query inputs pull-find)]
    (when (not pattern-ok)
      (delete seen)
      (return (result-set-error "pull pattern input must be a pull pattern")))
    (defer (delete seen))
    (let [[stream stream-ok stream-error] (source-attr-scan-stream scan-source projection.attr projection.has-value projection.value)]
      (when (not stream-ok)
        (return (result-set-error stream-error)))
      (while stream.has-current
        (let [[append-ok append-error] (append-db-read-source-entity-pull-row! (addr rows) (addr seen) pull-source query projection pattern stream.current registry)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error append-error))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! scan-source (addr stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-index-datom-stream stream))
    (result-set-ok rows)))

(defn append-db-read-source-entity-get-else-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Entity-Get-Else-Projection, source-value: Value, get-else-value: Value]
  (let [first-value (if (= query.find[0] projection.value-var) source-value get-else-value)
        second-value (if (= query.find[1] projection.get-else-var) get-else-value source-value)
        dedupe-values ([]Value [first-value second-value])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-owned-two-value-row! rows first-value second-value))))

(defn db-read-source-get-else-direct-value [source: DB-Read-Source, entity: u64, attr: string, default-value: Value, many: bool] -> [value: Value, ok: bool, error: string]
  (if many
    (let [[attr-value attr-ok attr-error] (db-read-source-pull-attr-value source entity attr)]
      (when (not (= attr-error ""))
        (return (Value {}) false attr-error))
      (if attr-ok
        (return attr-value true "")
        (return (value-owned default-value) true "")))
    (let [[attr-value attr-ok attr-error] (db-read-source-cardinality-one-value-fast-all-current source entity attr)]
      (when (not (= attr-error ""))
        (return (Value {}) false attr-error))
      (if attr-ok
        (return attr-value true "")
        (return (value-owned default-value) true "")))))

(defn q-db-read-source-entity-get-else-projection [scan-source: DB-Read-Source, get-else-source: DB-Read-Source, query: Query, projection: Source-Entity-Get-Else-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [stream stream-ok stream-error] (source-index-datom-stream scan-source projection.value-attr)
        [many many-ok many-error] (db-read-source-schema-cardinality-many? get-else-source projection.get-else-attr)]
    (when (not stream-ok)
      (return (result-set-error stream-error)))
    (when (not many-ok)
      (delete-source-index-datom-stream stream)
      (return (result-set-error many-error)))
    (while stream.has-current
      (let [[get-else-value value-ok value-error] (db-read-source-get-else-direct-value get-else-source stream.current.e projection.get-else-attr projection.default-value many)]
        (when (not value-ok)
          (delete-source-index-datom-stream stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error value-error)))
        (append-db-read-source-entity-get-else-row! (addr rows) query projection stream.current.v get-else-value)
        (delete-owned-value get-else-value))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! scan-source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error advance-error)))))
    (delete-source-index-datom-stream stream)
    (result-set-ok rows)))

(defn q-db-read-source-fixed-entity-get-else-projection [source: DB-Read-Source, projection: Source-Fixed-Entity-Get-Else-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [many many-ok many-error] (db-read-source-schema-cardinality-many? source projection.get-else-attr)]
    (when (not many-ok)
      (return (result-set-error many-error)))
    (let [[get-else-value value-ok value-error] (db-read-source-get-else-direct-value source projection.entity projection.get-else-attr projection.default-value many)]
      (when (not value-ok)
        (return (result-set-error value-error)))
      (append-distinct-single-value-row! (addr rows) (value-owned get-else-value))
      (delete-owned-value get-else-value))
    (result-set-ok rows)))

(defn append-db-read-source-entity-get-some-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Entity-Get-Some-Projection, attr-value: Value, source-value: Value]
  (let [first-value (if (= query.find[0] projection.out-attr) attr-value source-value)
        second-value (if (= query.find[1] projection.out-value) source-value attr-value)
        dedupe-values ([]Value [first-value second-value])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-owned-two-value-row! rows first-value second-value))))

(defn db-read-source-get-some-direct-values [source: DB-Read-Source, entity: u64, attrs: []string] -> [attr-value: Value, source-value: Value, ok: bool, error: string]
  (for [attr attrs]
    (let [[value value-ok value-error] (db-read-source-pull-attr-value source entity attr)]
      (when (not (= value-error ""))
        (return (Value {}) (Value {}) false value-error))
      (when value-ok
        (return (value-keyword (string-owned attr)) value true ""))))
  (return (Value {}) (Value {}) false ""))

(defn append-db-read-source-entity-get-some-rows! [rows: ^[dynamic]Result-Row, get-some-source: DB-Read-Source, query: Query, projection: Source-Entity-Get-Some-Projection, get-some: Get-Some, datoms: []Datom] -> [ok: bool, error: string]
  (for [datom datoms]
    (let [[append-ok append-error] (append-db-read-source-entity-get-some-row-for-datom! rows get-some-source query projection get-some datom)]
      (when (not append-ok)
        (return false append-error))))
  (return true ""))

(defn append-db-read-source-entity-get-some-row-for-datom! [rows: ^[dynamic]Result-Row, get-some-source: DB-Read-Source, query: Query, projection: Source-Entity-Get-Some-Projection, get-some: Get-Some, datom: Datom] -> [ok: bool, error: string]
  (let [[attr-value source-value values-ok values-error] (db-read-source-get-some-direct-values get-some-source datom.e (slice get-some.attrs 0))]
    (when (not (= values-error ""))
      (return false values-error))
    (when values-ok
      (append-db-read-source-entity-get-some-row! rows query projection attr-value source-value)
      (delete-owned-value attr-value)
      (delete-owned-value source-value)))
  (return true ""))

(defn q-db-read-source-entity-get-some-projection [scan-source: DB-Read-Source, get-some-source: DB-Read-Source, query: Query, projection: Source-Entity-Get-Some-Projection, get-some: Get-Some] -> Result-Set
  (let [rows (make [dynamic]Result-Row)]
    (let [[stream stream-ok stream-error] (source-attr-scan-stream scan-source projection.attr projection.has-value projection.value)]
      (when (not stream-ok)
        (return (result-set-error stream-error)))
      (while stream.has-current
        (let [[append-ok append-error] (append-db-read-source-entity-get-some-row-for-datom! (addr rows) get-some-source query projection get-some stream.current)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error append-error))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! scan-source (addr stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream stream)
            (delete-result-rows-owned-values rows)
            (return (result-set-error advance-error)))))
      (delete-source-index-datom-stream stream))
    (result-set-ok rows)))

(defn q-db-read-source-fixed-entity-get-some-projection [source: DB-Read-Source, query: Query, projection: Source-Fixed-Entity-Get-Some-Projection, get-some: Get-Some] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [attr-value source-value values-ok values-error] (db-read-source-get-some-direct-values source projection.entity (slice get-some.attrs 0))]
    (when (not (= values-error ""))
      (return (result-set-error values-error)))
    (when values-ok
      (let [first-value (if (= query.find[0] projection.out-attr) attr-value source-value)
            second-value (if (= query.find[1] projection.out-value) source-value attr-value)]
        (append-owned-two-value-row! (addr rows) first-value second-value)
        (delete-owned-value attr-value)
        (delete-owned-value source-value)))
    (result-set-ok rows)))

(defn db-read-source-current-attr-exists? [source: DB-Read-Source, entity: u64, attr: string] -> [exists: bool, ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity attr)]
    (when (not stream-ok)
      (return false false stream-error))
    (let [found stream.has-current]
      (delete-source-index-datom-stream stream)
      (return found true ""))))

(defn q-db-read-source-missing-attr-projection [source: DB-Read-Source, projection: Missing-Attr-Projection-Plan] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [stream stream-ok stream-error] (source-index-datom-stream source projection.value-attr)]
    (when (not stream-ok)
      (return (result-set-error stream-error)))
    (while stream.has-current
      (let [[exists exists-ok exists-error] (db-read-source-current-attr-exists? source stream.current.e projection.missing-attr)]
        (when (not exists-ok)
          (delete-source-index-datom-stream stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error exists-error)))
        (when (not exists)
          (when (not (row-values-exist? (slice rows 0) ([]Value [stream.current.v])))
            (append-distinct-single-value-row! (addr rows) (value-owned stream.current.v)))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (delete-result-rows-owned-values rows)
          (return (result-set-error advance-error)))))
    (delete-source-index-datom-stream stream)
    (result-set-ok rows)))

(defn q-db-read-source-fixed-entity-attr-projection [source: DB-Read-Source, projection: Source-Fixed-Entity-Attr-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [append-ok append-error] (append-distinct-source-entity-attr-value-rows! (addr rows) source projection.entity projection.attr)]
    (when (not append-ok)
      (delete-result-rows-owned-values rows)
      (return (result-set-error append-error)))
    (result-set-ok rows)))

(defn q-db-read-source-fixed-reverse-entity-attr-projection [source: DB-Read-Source, projection: Source-Fixed-Reverse-Entity-Attr-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        forward-attr (forward-attr-for-reverse projection.attr) :defer
        [stream stream-ok stream-error] (source-vaet-entity-attr-stream source projection.entity forward-attr)]
    (when (not stream-ok)
      (return (result-set-error stream-error)))
    (while stream.has-current
      (when (not (row-values-exist? (slice rows 0) ([]Value [(value-entity stream.current.e)])))
        (append-entity-row! (addr rows) stream.current.e))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-result-rows-owned-values rows)
          (delete-source-index-datom-stream stream)
          (return (result-set-error load-error)))))
    (delete-source-index-datom-stream stream)
    (result-set-ok rows)))

(defn db-read-source-fixed-entity-attr-value-projection-value [projection: Source-Fixed-Entity-Attr-Value-Projection, datom: Datom, name: string] -> Value
  (cond
    (= name projection.attr-var) (value-keyword datom.a)
    (= name projection.value-var) datom.v
    :else (Value {})))

(defn db-read-source-fixed-entity-attr-value-projection-owned-value [projection: Source-Fixed-Entity-Attr-Value-Projection, datom: Datom, name: string] -> Value
  (cond
    (= name projection.attr-var) (value-keyword (string-owned datom.a))
    (= name projection.value-var) (value-owned datom.v)
    :else (Value {})))

(defn append-db-read-source-fixed-entity-attr-value-projection-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Fixed-Entity-Attr-Value-Projection, datom: Datom]
  (let [first-value (db-read-source-fixed-entity-attr-value-projection-value projection datom query.find[0])
        second-value (db-read-source-fixed-entity-attr-value-projection-value projection datom query.find[1])
        dedupe-values ([]Value [first-value second-value])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-two-value-row! rows
                             (db-read-source-fixed-entity-attr-value-projection-owned-value projection datom query.find[0])
                             (db-read-source-fixed-entity-attr-value-projection-owned-value projection datom query.find[1])))))

(defn q-db-read-source-fixed-entity-attr-value-projection [source: DB-Read-Source, query: Query, projection: Source-Fixed-Entity-Attr-Value-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [stream stream-ok stream-error] (source-eavt-entity-stream source projection.entity)]
    (when (not stream-ok)
      (return (result-set-error stream-error)))
    (while stream.has-current
      (append-db-read-source-fixed-entity-attr-value-projection-row! (addr rows) query projection stream.current)
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-result-rows-owned-values rows)
          (delete-source-index-datom-stream stream)
          (return (result-set-error load-error)))))
    (delete-source-index-datom-stream stream)
    (result-set-ok rows)))

(defn append-db-read-source-fixed-entity-two-attr-projection-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Fixed-Entity-Two-Attr-Projection, first-value-source: Value, second-value-source: Value]
  (let [first-value (if (= query.find[0] projection.first-var) first-value-source second-value-source)
        second-value (if (= query.find[1] projection.second-var) second-value-source first-value-source)
        dedupe-values ([]Value [first-value second-value])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-owned-two-value-row! rows first-value second-value))))

(defn q-db-read-source-fixed-entity-two-attr-projection [source: DB-Read-Source, query: Query, projection: Source-Fixed-Entity-Two-Attr-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [first-stream first-ok first-error] (source-eavt-entity-attr-stream source projection.entity projection.first-attr)]
    (when (not first-ok)
      (delete-result-rows-owned-values rows)
      (return (result-set-error first-error)))
    (while first-stream.has-current
      (let [[second-stream second-ok second-error] (source-eavt-entity-attr-stream source projection.entity projection.second-attr)]
      (when (not second-ok)
        (delete-result-rows-owned-values rows)
        (delete-source-index-datom-stream first-stream)
        (return (result-set-error second-error)))
      (while second-stream.has-current
        (append-db-read-source-fixed-entity-two-attr-projection-row! (addr rows) query projection first-stream.current.v second-stream.current.v)
        (let [[second-load-ok second-load-error] (advance-source-index-datom-stream! source (addr second-stream))]
          (when (not second-load-ok)
            (delete-result-rows-owned-values rows)
            (delete-source-index-datom-stream second-stream)
            (delete-source-index-datom-stream first-stream)
            (return (result-set-error second-load-error)))))
      (delete-source-index-datom-stream second-stream)
      )
      (let [[first-load-ok first-load-error] (advance-source-index-datom-stream! source (addr first-stream))]
        (when (not first-load-ok)
          (delete-result-rows-owned-values rows)
          (delete-source-index-datom-stream first-stream)
          (return (result-set-error first-load-error)))))
    (delete-source-index-datom-stream first-stream)
    (result-set-ok rows)))

(defn q-db-read-source-fixed-entity-ref-attr-projection [source: DB-Read-Source, projection: Source-Fixed-Entity-Ref-Attr-Projection] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [ref-stream ref-ok ref-error] (source-eavt-entity-attr-stream source projection.entity projection.ref-attr)]
    (when (not ref-ok)
      (return (result-set-error ref-error)))
    (while ref-stream.has-current
      (when (= ref-stream.current.v.kind .Entity)
        (let [[append-ok append-error] (append-distinct-source-entity-attr-value-rows! (addr rows) source ref-stream.current.v.entity projection.value-attr)]
          (when (not append-ok)
            (delete-result-rows-owned-values rows)
            (delete-source-index-datom-stream ref-stream)
            (return (result-set-error append-error)))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr ref-stream))]
        (when (not load-ok)
          (delete-result-rows-owned-values rows)
          (delete-source-index-datom-stream ref-stream)
          (return (result-set-error load-error)))))
    (result-set-ok rows)))

(defn db-read-source-value-ref-attr-anchor-value [source: DB-Read-Source, projection: Source-Value-Ref-Attr-Projection, inputs: []Query-Input] -> [value: Value, ok: bool, error: string]
  (when (not projection.has-anchor-input)
    (return projection.anchor-value true ""))
  (when (not (= (count inputs) 1))
    (return (Value {}) false "wrong number of query inputs for source value/ref/value projection"))
  (db-read-source-query-input-scalar-value source inputs[0]))

(defn q-db-read-source-value-ref-attr-projection [source: DB-Read-Source, projection: Source-Value-Ref-Attr-Projection, inputs: []Query-Input] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [anchor-value anchor-value-ok anchor-value-error] (db-read-source-value-ref-attr-anchor-value source projection inputs)]
    (when (not anchor-value-ok)
      (return (result-set-error anchor-value-error)))
    (if (db-read-source-has-overlay? source)
      (let [anchor-datoms (make [dynamic]Datom)
            [anchor-ok anchor-error] (db-read-source-append-attr-value-datoms! (addr anchor-datoms) source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (delete-owned-datoms anchor-datoms)
          (return (result-set-error anchor-error)))
        (defer (delete-owned-datoms anchor-datoms))
        (for [anchor-datom anchor-datoms]
          (let [[ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.ref-attr)]
            (when (not ref-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-distinct-source-entity-attr-value-rows! (addr rows) source ref-stream.current.e projection.value-attr)]
                (when (not append-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error append-error))))
              (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not load-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error load-error))))))))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (return (result-set-error anchor-error)))
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)
                [ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.ref-attr)]
            (when (not ref-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-distinct-source-entity-attr-value-rows! (addr rows) source ref-stream.current.e projection.value-attr)]
                (when (not append-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error append-error))))
              (let [[ref-advance-ok ref-advance-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not ref-advance-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error ref-advance-error)))))
            (delete-source-index-datom-stream ref-stream))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error anchor-advance-error)))))
        (delete-source-attr-value-match-stream anchor-stream)))
    (result-set-ok rows)))

(defn db-read-source-query-relation-value-ref-attr-add-values! [builder: ^Query-Relation-Builder, source: DB-Read-Source, entity: u64, attr: string] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (let [values ([]Value [stream.current.v])]
        (when (not (query-relation-builder-add-column-row-with-values! builder ([]Relation-Column []) 0 values))
          (delete-source-index-datom-stream stream)
          (return false "source value/ref/attr projection produced unsupported typed relation values")))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn db-read-source-query-relation-value-ref-attr-projection [source: DB-Read-Source, query: Query, inputs: []Query-Input, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [[projection projection-ok] (db-read-source-query-value-ref-attr-projection query)]
    (when (not projection-ok)
      (return (query-relation-empty) false ""))
    (let [[anchor-value anchor-value-ok anchor-value-error] (db-read-source-value-ref-attr-anchor-value source projection inputs)]
      (when (not anchor-value-ok)
        (return (query-relation-empty) false anchor-value-error))
      (when projection.has-anchor-input
        (set! stats^.input-bindings 1))
      (let [attrs (arr.into [dynamic]string (slice query.find 0))
            attr-sources (make [dynamic]string 0 (count query.find))]
        (for [_ query.find]
          (arr.push! attr-sources ""))
        (let [builder (query-relation-builder (slice attrs 0))
              [anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
          (when (not anchor-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false anchor-error))
          (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
          (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
          (query-stats-observe-source-operator! stats)
          (while anchor-stream.has-current
            (let [anchor-datom (source-attr-value-match-current anchor-stream)
                  [ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.ref-attr)]
              (when (not ref-ok)
                (delete-source-attr-value-match-stream anchor-stream)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false ref-error))
              (while ref-stream.has-current
                (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                (let [[append-ok append-error] (db-read-source-query-relation-value-ref-attr-add-values! (addr builder) source ref-stream.current.e projection.value-attr)]
                  (when (not append-ok)
                    (delete-source-index-datom-stream ref-stream)
                    (delete-source-attr-value-match-stream anchor-stream)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false append-error)))
                (let [[ref-advance-ok ref-advance-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                  (when (not ref-advance-ok)
                    (delete-source-index-datom-stream ref-stream)
                    (delete-source-attr-value-match-stream anchor-stream)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false ref-advance-error))))
              (delete-source-index-datom-stream ref-stream))
            (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
              (when (not anchor-advance-ok)
                (delete-source-attr-value-match-stream anchor-stream)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false anchor-advance-error))))
          (delete-source-attr-value-match-stream anchor-stream)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok})
                  true
                  ""))))))

(defn source-value-ref-star-clause-index-for-find-var [query: Query, projection: Source-Value-Ref-Star-Projection, find-var: string] -> [index: int, entity?: bool, ok: bool]
  (when (= find-var projection.ref-entity-var)
    (return 0 true true))
  (let [i 2]
    (while (< i (count query.clauses))
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name find-var))
        (return i false true))
      (set! i (+ i 1)))
    (return 0 false false)))

(defn db-read-source-value-ref-star-options-for-find-var [source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, ref-entity: u64, find-var: string] -> [option-row: Result-Row, ok: bool, error: string]
  (let [values (make [dynamic]Value)
        pulls (make [dynamic]Pull-Result)
        out-row (Result-Row {values: values pulls: pulls})
        [clause-index entity? clause-ok] (source-value-ref-star-clause-index-for-find-var query projection find-var)]
    (when (not clause-ok)
      (delete out-row.values)
      (delete out-row.pulls)
      (return out-row false "source value/ref/star projection find var missing from clauses"))
    (if entity?
      (arr.push! out-row.values (value-entity ref-entity))
      (let [[option-ok option-error] (append-source-entity-attr-option-values! (addr out-row) source ref-entity query.clauses[clause-index].a.value.text)]
        (when (not option-ok)
          (delete out-row.values)
          (delete out-row.pulls)
          (return out-row false option-error))))
    (return out-row true "")))

(defn append-db-read-source-value-ref-star-row! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, ref-entity: u64] -> [ok: bool, error: string]
  (let [options (make [dynamic]Result-Row)
        prefix (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[option option-ok option-error] (db-read-source-value-ref-star-options-for-find-var source query projection ref-entity find-var)]
        (when (not option-ok)
          (delete-owned-values-array option.values)
          (delete option.pulls)
          (delete-result-rows-owned-values options)
          (delete prefix)
          (return false option-error))
        (arr.push! options option)))
    (let [[product-ok product-error] (append-db-read-source-star-option-product! rows (slice options 0) 0 (slice prefix 0))]
      (delete-result-rows-owned-values options)
      (delete prefix)
      (return product-ok product-error))))

(defn db-read-source-query-relation-value-ref-star-add-product! [builder: ^Query-Relation-Builder, options: []Result-Row, index: int, prefix: []Value] -> [ok: bool, error: string]
  (when (= index (count options))
    (when (not (query-relation-builder-add-column-row-with-values! builder ([]Relation-Column []) 0 prefix))
      (return false "source value/ref/star projection produced unsupported typed relation values"))
    (return true ""))
  (for [option options[index].values]
    (let [next (make [dynamic]Value 0 (+ (count prefix) 1))]
      (for [value prefix]
        (arr.push! next (value-owned value)))
      (arr.push! next (value-owned option))
      (let [[ok error] (db-read-source-query-relation-value-ref-star-add-product! builder options (+ index 1) (slice next 0))]
        (delete-owned-values-array next)
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn db-read-source-query-relation-value-ref-star-add-row! [builder: ^Query-Relation-Builder, source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, ref-entity: u64] -> [ok: bool, error: string]
  (let [options (make [dynamic]Result-Row)
        prefix (make [dynamic]Value)]
    (for [find-var query.find]
      (let [[option option-ok option-error] (db-read-source-value-ref-star-options-for-find-var source query projection ref-entity find-var)]
        (when (not option-ok)
          (delete-owned-values-array option.values)
          (delete option.pulls)
          (delete-result-rows-owned-values options)
          (delete prefix)
          (return false option-error))
        (arr.push! options option)))
    (let [[product-ok product-error] (db-read-source-query-relation-value-ref-star-add-product! builder (slice options 0) 0 (slice prefix 0))]
      (delete-result-rows-owned-values options)
      (delete prefix)
      (return product-ok product-error))))

(defn db-read-source-query-relation-value-ref-star-add-ref-stream! [builder: ^Query-Relation-Builder, source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, stream: ^Source-Index-Datom-Stream, stats: ^Query-Stats] -> [ok: bool, error: string]
  (while stream^.has-current
    (mut! stats^.clause-candidates += 1)
    (let [[append-ok append-error] (db-read-source-query-relation-value-ref-star-add-row! builder source query projection stream^.current.e)]
      (when (not append-ok)
        (return false append-error)))
    (let [[advance-ok advance-error] (advance-source-index-datom-stream! source stream)]
      (when (not advance-ok)
        (return false advance-error))))
  (return true ""))

(defn db-read-source-query-relation-value-ref-star-add-frontier! [builder: ^Query-Relation-Builder, source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, anchor-entities: []u64, stats: ^Query-Stats] -> [ok: bool, error: string]
  (let [[frontier-stream frontier-ok frontier-used _frontier-candidates frontier-error] (source-vaet-entity-attr-frontier-stream source anchor-entities projection.ref-attr)]
    (discard _frontier-candidates)
    (when (not frontier-ok)
      (return false frontier-error))
    (when frontier-used
      (let [[append-ok append-error] (db-read-source-query-relation-value-ref-star-add-ref-stream! builder source query projection (addr frontier-stream) stats)]
        (delete-source-index-datom-stream frontier-stream)
        (return append-ok append-error)))
    (for [anchor-entity anchor-entities]
      (let [[ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-entity projection.ref-attr)]
        (when (not ref-ok)
          (return false ref-error))
        (let [[append-ok append-error] (db-read-source-query-relation-value-ref-star-add-ref-stream! builder source query projection (addr ref-stream) stats)]
          (delete-source-index-datom-stream ref-stream)
          (when (not append-ok)
            (return false append-error)))))
    (return true "")))

(defn db-read-source-value-ref-star-anchor-value [source: DB-Read-Source, projection: Source-Value-Ref-Star-Projection, inputs: []Query-Input] -> [value: Value, ok: bool, error: string]
  (when (not projection.has-anchor-input)
    (return projection.anchor-value true ""))
  (when (not (= (count inputs) 1))
    (return (Value {}) false "wrong number of query inputs for source value/ref/star projection"))
  (db-read-source-query-input-scalar-value source inputs[0]))

(defn db-read-source-query-relation-value-ref-star-projection [source: DB-Read-Source, query: Query, inputs: []Query-Input, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [[projection projection-ok] (db-read-source-query-value-ref-star-projection query)]
    (when (not projection-ok)
      (return (query-relation-empty) false ""))
    (let [[anchor-value anchor-value-ok anchor-value-error] (db-read-source-value-ref-star-anchor-value source projection inputs)]
      (when (not anchor-value-ok)
        (return (query-relation-empty) false anchor-value-error))
      (when projection.has-anchor-input
        (set! stats^.input-bindings 1))
      (let [attrs (arr.into [dynamic]string (slice query.find 0))
            attr-sources (make [dynamic]string 0 (count query.find))]
        (for [_ query.find]
          (arr.push! attr-sources ""))
        (let [builder (query-relation-builder (slice attrs 0))
              [anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
          (when (not anchor-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false anchor-error))
          (set! stats^.clauses (+ stats^.clauses (count query.clauses)))
          (set! stats^.source-index-scans (+ stats^.source-index-scans (count query.clauses)))
          (query-stats-observe-source-operator! stats)
          (let [anchor-entities (make [dynamic]u64)]
          (while anchor-stream.has-current
            (let [anchor-datom (source-attr-value-match-current anchor-stream)]
              (arr.push! anchor-entities anchor-datom.e))
            (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
              (when (not anchor-advance-ok)
                (delete-source-attr-value-match-stream anchor-stream)
                (delete anchor-entities)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false anchor-advance-error))))
          (delete-source-attr-value-match-stream anchor-stream)
          (let [[frontier-ok frontier-error] (db-read-source-query-relation-value-ref-star-add-frontier! (addr builder) source query projection (slice anchor-entities 0) stats)]
            (delete anchor-entities)
            (when (not frontier-ok)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false frontier-error)))
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok})
                  true
                  "")))))))

(defn q-db-read-source-value-ref-star-projection [source: DB-Read-Source, query: Query, projection: Source-Value-Ref-Star-Projection, inputs: []Query-Input] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [anchor-value anchor-value-ok anchor-value-error] (db-read-source-value-ref-star-anchor-value source projection inputs)]
    (when (not anchor-value-ok)
      (return (result-set-error anchor-value-error)))
    (if (db-read-source-has-overlay? source)
      (let [anchor-datoms (make [dynamic]Datom)
            [anchor-ok anchor-error] (db-read-source-append-attr-value-datoms! (addr anchor-datoms) source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (delete-owned-datoms anchor-datoms)
          (return (result-set-error anchor-error)))
        (defer (delete-owned-datoms anchor-datoms))
        (for [anchor-datom anchor-datoms]
          (let [[ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.ref-attr)]
            (when (not ref-ok)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-db-read-source-value-ref-star-row! (addr rows) source query projection ref-stream.current.e)]
                (when (not append-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error append-error))))
              (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not load-ok)
                  (delete-result-rows-owned-values rows)
                  (delete-source-index-datom-stream ref-stream)
                  (return (result-set-error load-error))))))))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (return (result-set-error anchor-error)))
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)
                [ref-stream ref-ok ref-error] (source-vaet-entity-attr-stream source anchor-datom.e projection.ref-attr)]
            (when (not ref-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error ref-error)))
            (while ref-stream.has-current
              (let [[append-ok append-error] (append-db-read-source-value-ref-star-row! (addr rows) source query projection ref-stream.current.e)]
                (when (not append-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error append-error))))
              (let [[ref-advance-ok ref-advance-error] (advance-source-index-datom-stream! source (addr ref-stream))]
                (when (not ref-advance-ok)
                  (delete-source-index-datom-stream ref-stream)
                  (delete-source-attr-value-match-stream anchor-stream)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error ref-advance-error)))))
            (delete-source-index-datom-stream ref-stream))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error anchor-advance-error)))))
        (delete-source-attr-value-match-stream anchor-stream)))
    (result-set-ok rows)))

(defn db-read-source-multi-hop-ref-chain-anchor-value [source: DB-Read-Source, projection: Source-Multi-Hop-Ref-Chain-Projection, inputs: []Query-Input] -> [value: Value, ok: bool, error: string]
  (when (not projection.has-anchor-input)
    (return projection.anchor-value true ""))
  (when (not (= (count inputs) 1))
    (return (Value {}) false "wrong number of query inputs for source multi-hop ref-chain projection"))
  (db-read-source-query-input-scalar-value source inputs[0]))

(defn source-multi-hop-ref-chain-value-for-var [projection: Source-Multi-Hop-Ref-Chain-Projection, name: string, final-value: Value, first-value: Value, filter-value: Value] -> Value
  (cond
    (= name projection.final-value-var) final-value
    (= name projection.first-value-var) first-value
    :else filter-value))

(defn append-db-read-source-multi-hop-ref-chain-row! [rows: ^[dynamic]Result-Row, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, final-value: Value, first-value: Value, filter-value: Value]
  (let [out-first (source-multi-hop-ref-chain-value-for-var projection query.find[0] final-value first-value filter-value)
        out-second (source-multi-hop-ref-chain-value-for-var projection query.find[1] final-value first-value filter-value)
        out-third (source-multi-hop-ref-chain-value-for-var projection query.find[2] final-value first-value filter-value)
        dedupe-values ([]Value [out-first out-second out-third])]
    (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
      (append-three-value-row! rows (value-owned out-first) (value-owned out-second) (value-owned out-third)))))

(defn append-db-read-source-multi-hop-ref-chain-relation-row! [builder: ^Query-Relation-Builder, seen: (ptr (map string (struct {}))), query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, final-value: Value, first-value: Value, filter-value: Value] -> bool
  (let [out-first (source-multi-hop-ref-chain-value-for-var projection query.find[0] final-value first-value filter-value)
        out-second (source-multi-hop-ref-chain-value-for-var projection query.find[1] final-value first-value filter-value)
        out-third (source-multi-hop-ref-chain-value-for-var projection query.find[2] final-value first-value filter-value)
        values ([]Value [out-first out-second out-third])
        [key key-ok] (row-values-dedupe-key values)]
    (when (and key-ok (set.contains? seen^ key))
      (delete key)
      (return true))
    (when key-ok
      (set.add! seen^ key))
    (query-relation-builder-add-column-row-with-values! builder ([]Relation-Column []) 0 values)))

(defn source-query-relation-from-multi-hop-builder [attrs: [dynamic]string, builder: Query-Relation-Builder] -> Query-Relation
  (let [attr-sources (make [dynamic]string 0 (count attrs))]
    (for [_ attrs]
      (arr.push! attr-sources ""))
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: builder.tuples
                     typed-columns: builder.typed-columns
                     typed-rows: builder.typed-rows
                     has-typed-columns: builder.typed-ok})))

(defn append-db-read-source-multi-hop-ref-chain-final-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, hop2-entity: u64, first-value: Value, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source hop2-entity projection.final-value-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (append-db-read-source-multi-hop-ref-chain-row! rows query projection stream.current.v first-value filter-value)
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-multi-hop-ref-chain-hop2-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, hop1-entity: u64, first-value: Value, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source hop1-entity projection.hop2-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-final-rows! rows source query projection stream.current.v.entity first-value filter-value)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return false append-error))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-multi-hop-ref-chain-hop1-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, first-entity: u64, first-value: Value, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.hop1-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-hop2-rows! rows source query projection stream.current.v.entity first-value filter-value)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return false append-error))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-multi-hop-ref-chain-first-value-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, first-entity: u64, filter-value: Value] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.first-value-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-hop1-rows! rows source query projection first-entity stream.current.v filter-value)]
        (when (not append-ok)
          (delete-source-index-datom-stream stream)
          (return false append-error)))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-db-read-source-multi-hop-ref-chain-first-entity-rows! [rows: ^[dynamic]Result-Row, source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, first-entity: u64] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source first-entity projection.filter-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (and (= stream.current.a projection.filter-attr)
                 (predicate-pair-matches? projection.filter-op stream.current.v projection.filter-value))
        (let [[append-ok append-error] (append-db-read-source-multi-hop-ref-chain-first-value-rows! rows source query projection first-entity stream.current.v)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return false append-error))))
      (let [[load-ok load-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not load-ok)
          (delete-source-index-datom-stream stream)
          (return false load-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn delete-source-multi-hop-ref-chain-links [links: [dynamic]Source-Multi-Hop-Ref-Chain-Link]
  (for [link links]
    (delete-owned-value link.filter-value)
    (when link.has-first-value
      (delete-owned-value link.first-value)))
  (delete links))

(defn append-source-multi-hop-ref-chain-link! [heads: ^map[u64]int, links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link, entity: u64, filter-value: Value, first-value: Value, has-first-value: bool]
  (let [[head found] (mmap.get heads^ entity)
        next (if found head -1)
        index (count links^)]
    (arr.push! links^ (Source-Multi-Hop-Ref-Chain-Link {filter-value: filter-value
                                                         first-value: first-value
                                                         has-first-value: has-first-value
                                                         next: next}))
    (mmap.assoc! heads^ entity index)))

(defn append-source-multi-hop-ref-chain-filter-links! [source: DB-Read-Source, projection: Source-Multi-Hop-Ref-Chain-Projection, first-entities: (ptr (map u64 (struct {}))), heads: ^map[u64]int, links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.filter-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (and (set.contains? first-entities^ stream.current.e)
                 (predicate-pair-matches? projection.filter-op stream.current.v projection.filter-value))
        (append-source-multi-hop-ref-chain-link! heads links stream.current.e (value-owned stream.current.v) (value-nil) false))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-source-multi-hop-ref-chain-first-value-links! [source: DB-Read-Source, projection: Source-Multi-Hop-Ref-Chain-Projection, filter-heads: ^map[u64]int, filter-links: []Source-Multi-Hop-Ref-Chain-Link, heads: ^map[u64]int, links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-index-datom-stream source projection.first-value-attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (let [[head found] (mmap.get filter-heads^ stream.current.e)]
        (when found
          (let [index head]
            (while (>= index 0)
              (append-source-multi-hop-ref-chain-link! heads links stream.current.e (value-owned filter-links[index].filter-value) (value-owned stream.current.v) true)
              (set! index filter-links[index].next)))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-source-multi-hop-ref-chain-propagated-links! [source: DB-Read-Source, attr: string, parent-heads: ^map[u64]int, parent-links: []Source-Multi-Hop-Ref-Chain-Link, child-heads: ^map[u64]int, child-links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-index-datom-stream source attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[head found] (mmap.get parent-heads^ stream.current.e)]
          (when found
            (let [index head]
              (while (>= index 0)
                (append-source-multi-hop-ref-chain-link! child-heads child-links stream.current.v.entity (value-owned parent-links[index].filter-value) (value-owned parent-links[index].first-value) true)
                (set! index parent-links[index].next))))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-source-multi-hop-ref-chain-reverse-propagated-links! [source: DB-Read-Source, attr: string, parent-heads: ^map[u64]int, parent-links: []Source-Multi-Hop-Ref-Chain-Link, child-heads: ^map[u64]int, child-links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link] -> [ok: bool, error: string]
  (let [[stream stream-ok stream-error] (source-index-datom-stream source attr)]
    (when (not stream-ok)
      (return false stream-error))
    (while stream.has-current
      (when (= stream.current.v.kind .Entity)
        (let [[head found] (mmap.get parent-heads^ stream.current.v.entity)]
          (when found
            (let [index head]
              (while (>= index 0)
                (append-source-multi-hop-ref-chain-link! child-heads child-links stream.current.e (value-owned parent-links[index].filter-value) (value-owned parent-links[index].first-value) true)
                (set! index parent-links[index].next))))))
      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
        (when (not advance-ok)
          (delete-source-index-datom-stream stream)
          (return false advance-error))))
    (delete-source-index-datom-stream stream)
    (return true "")))

(defn append-source-multi-hop-ref-chain-first-value-links-from-frontier! [source: DB-Read-Source, attr: string, parent-entities: []u64, heads: ^map[u64]int, links: ^[dynamic]Source-Multi-Hop-Ref-Chain-Link] -> [ok: bool, error: string, scans: int, candidates: int]
  (let [scan-count 0
        candidate-count 0]
    (let [[frontier-stream frontier-ok frontier-used frontier-candidates frontier-error] (source-eavt-entity-attr-frontier-stream source parent-entities attr)]
      (when (not frontier-ok)
        (return false frontier-error scan-count candidate-count))
      (when frontier-used
        (when (> (count parent-entities) 0)
          (mut! scan-count += 1))
        (when (>= frontier-candidates 0)
          (mut! candidate-count += frontier-candidates))
        (while frontier-stream.has-current
          (when (< frontier-candidates 0)
            (mut! candidate-count += 1))
          (append-source-multi-hop-ref-chain-link! heads links frontier-stream.current.e (value-nil) (value-owned frontier-stream.current.v) true)
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr frontier-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream frontier-stream)
              (return false advance-error scan-count candidate-count))))
        (delete-source-index-datom-stream frontier-stream)
        (return true "" scan-count candidate-count)))
    (for [entity parent-entities]
      (mut! scan-count += 1)
      (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity attr)]
        (when (not stream-ok)
          (return false stream-error scan-count candidate-count))
        (while stream.has-current
          (mut! candidate-count += 1)
          (append-source-multi-hop-ref-chain-link! heads links entity (value-nil) (value-owned stream.current.v) true)
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false advance-error scan-count candidate-count))))
        (delete-source-index-datom-stream stream)))
    (return true "" scan-count candidate-count)))

