(defn db-read-source-query-has-one-scalar-input? [query: Query, name: string] -> bool
  (when (not (= (count query.inputs) 1))
    (return false))
  (when (not (= query.inputs[0] name))
    (return false))
  (if (> (count query.input-specs) 0)
    (and (= (count query.input-specs) 1)
         (= query.input-specs[0].kind .Scalar)
         (= query.input-specs[0].name name))
    true))

