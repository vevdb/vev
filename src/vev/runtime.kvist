  (Attr-Top-N-Aggregate-Plan {}))

(defn empty-missing-attr-projection-plan [] -> Missing-Attr-Projection-Plan
  (Missing-Attr-Projection-Plan {}))

(defn query-two-attr-entity-projection [query: Query] -> [projection: Two-Attr-Entity-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-two-attr-entity-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]]
    (when (or first.has-source
              second.has-source
              (not (= first.e.kind .Var))
              (not (= second.e.kind .Var))
              (not (= first.e.name second.e.name))
              (not (= first.a.kind .Value))
              (not (= second.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (not (= second.a.value.kind .Keyword))
              (not (= first.v.kind .Var))
              (not (= second.v.kind .Var))
              (= first.v.name second.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard)))
      (return (empty-two-attr-entity-projection) false))
    (when (not (or (and (= query.find[0] first.v.name)
                        (= query.find[1] second.v.name))
                   (and (= query.find[0] second.v.name)
                        (= query.find[1] first.v.name))))
      (return (empty-two-attr-entity-projection) false))
    (return (Two-Attr-Entity-Projection {first-attr: first.a.value.text
                                         first-var: first.v.name
                                         second-attr: second.a.value.text
                                         second-var: second.v.name})
            true)))

(defn db-read-source-query-entity-attr-value-projection [query: Query] -> [projection: Source-Entity-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-entity-value-projection) false))
  (let [clause-value query.clauses[0]]
    (when (or (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (not (= clause-value.v.kind .Var))
              (= clause-value.e.name clause-value.v.name)
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-entity-value-projection) false))
    (when (not (or (and (= query.find[0] clause-value.e.name)
                        (= query.find[1] clause-value.v.name))
                   (and (= query.find[0] clause-value.v.name)
                        (= query.find[1] clause-value.e.name))))
      (return (empty-source-entity-value-projection) false))
    (return (Source-Entity-Value-Projection {entity-var: clause-value.e.name
                                             attr: clause-value.a.value.text
                                             value-var: clause-value.v.name})
            true)))

(defn db-read-source-query-entity-attr-value-vars-projection [query: Query] -> [projection: Source-Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-entity-attr-value-projection) false))
  (let [clause-value query.clauses[0]]
    (when (or (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Var))
              (not (= clause-value.v.kind .Var))
              (= clause-value.e.name clause-value.a.name)
              (= clause-value.e.name clause-value.v.name)
              (= clause-value.a.name clause-value.v.name)
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-entity-attr-value-projection) false))
    (for [find-var query.find]
      (when (not (or (= find-var clause-value.e.name)
                     (= find-var clause-value.a.name)
                     (= find-var clause-value.v.name)))
        (return (empty-source-entity-attr-value-projection) false)))
    (return (Source-Entity-Attr-Value-Projection {entity-var: clause-value.e.name
                                                  attr-var: clause-value.a.name
                                                  value-var: clause-value.v.name})
            true)))

