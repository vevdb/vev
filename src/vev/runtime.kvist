(package vev)

(import core-strings "core:strings")
(import mmap "kvist:map")

(defn string-owned [text: string] -> string
  (let [[out err] (core-strings.clone text)]
    (if (= err nil)
      out
      "")))

(defn value-owned [value: Value] -> Value
  (case value.kind
    .String (value-string (string-owned value.text))
    .Keyword (value-keyword (string-owned value.text))
    .Symbol (value-symbol (string-owned value.text))
    .Vector
      (let [items (make [dynamic]Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (Value {kind: .Vector items: items}))
    .Map
      (let [items (make [dynamic]Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (Value {kind: .Map items: items}))
    :else value))

(defn tx-data-owned [data: Tx-Data] -> Tx-Data
  (Tx-Data {op: (string-owned data.op)
            e: data.e
            tempid: (string-owned data.tempid)
            has-tempid: data.has-tempid
            lookup-attr: (string-owned data.lookup-attr)
            lookup-value: (value-owned data.lookup-value)
            has-lookup-ref: data.has-lookup-ref
            ident: (string-owned data.ident)
            has-ident: data.has-ident
            a: (string-owned data.a)
            v: (value-owned data.v)
            expected: (value-owned data.expected)
            expected-lookup-attr: (string-owned data.expected-lookup-attr)
            expected-lookup-value: (value-owned data.expected-lookup-value)
            has-expected-lookup-ref: data.has-expected-lookup-ref
            value-tempid: (string-owned data.value-tempid)
            has-value-tempid: data.has-value-tempid
            value-lookup-attr: (string-owned data.value-lookup-attr)
            value-lookup-value: (value-owned data.value-lookup-value)
            has-value-lookup-ref: data.has-value-lookup-ref
            nested-map: (value-owned data.nested-map)
            nested-tempid: (string-owned data.nested-tempid)
            has-nested-map: data.has-nested-map
            from-map-collection: data.from-map-collection
            map-group: (string-owned data.map-group)}))

(defn tx-data-slice-owned [tx-data: []Tx-Data] -> [dynamic]Tx-Data
  (let [out (make [dynamic]Tx-Data 0 (count tx-data))]
    (for [data tx-data]
      (arr.push! out (tx-data-owned data)))
    out))


(defn query-with-rules [query: Query, rules: []Rule] -> Query
  (let [out query]
    (delete out.rules)
    (set! out.rules (arr.into [dynamic]Rule rules))
    (return out)))

(defn clone-query-shallow [query: Query] -> Query
  (let [find (arr.into [dynamic]string (slice query.find 0))
        with (arr.into [dynamic]string (slice query.with 0))
        inputs (arr.into [dynamic]string (slice query.inputs 0))
        collection-inputs (arr.into [dynamic]string (slice query.collection-inputs 0))
        tuple-inputs (arr.into [dynamic]Tuple-Input (slice query.tuple-inputs 0))
        relation-inputs (arr.into [dynamic]Relation-Input (slice query.relation-inputs 0))
        input-specs (arr.into [dynamic]Query-Input-Spec (slice query.input-specs 0))
        clauses (arr.into [dynamic]Clause (slice query.clauses 0))
        predicates (arr.into [dynamic]Predicate (slice query.predicates 0))
        function-clauses (arr.into [dynamic]Function-Clause (slice query.function-clauses 0))
        rules (arr.into [dynamic]Rule (slice query.rules 0))
        rule-calls (arr.into [dynamic]Rule-Call (slice query.rule-calls 0))
        get-elses (arr.into [dynamic]Get-Else (slice query.get-elses 0))
        get-somes (arr.into [dynamic]Get-Some (slice query.get-somes 0))
        grounds (arr.into [dynamic]Ground (slice query.grounds 0))
        not-groups (arr.into [dynamic]Not-Group (slice query.not-groups 0))
        or-groups (arr.into [dynamic]Or-Group (slice query.or-groups 0))
        where-steps (arr.into [dynamic]Query-Step (slice query.where-steps 0))
        pulls (arr.into [dynamic]Pull-Find (slice query.pulls 0))
        aggregates (arr.into [dynamic]Aggregate-Find (slice query.aggregates 0))]
    (Query {find: find
            with: with
            inputs: inputs
            collection-inputs: collection-inputs
            tuple-inputs: tuple-inputs
            relation-inputs: relation-inputs
            input-specs: input-specs
            has-rules-input: query.has-rules-input
            clauses: clauses
            predicates: predicates
            function-clauses: function-clauses
            rules: rules
            rule-calls: rule-calls
            get-elses: get-elses
            get-somes: get-somes
            grounds: grounds
            not-groups: not-groups
            or-groups: or-groups
            where-steps: where-steps
            pulls: pulls
            aggregates: aggregates})))

(defn query-copy-with-rules [query: Query, rules: []Rule] -> Query
  (query-with-rules (clone-query-shallow query) rules))

(defn clone-datoms [datoms: [dynamic]Datom] -> [dynamic]Datom
  (arr.into [dynamic]Datom (slice datoms 0)))

(defn db [conn: ^Conn] -> DB
  (build-db (clone-datoms conn^.db.datoms)))

(defn clone-tx-meta [meta: []Tx-Meta] -> [dynamic]Tx-Meta
  (arr.into [dynamic]Tx-Meta meta))

(defn clone-tx-report [report: Tx-Report] -> Tx-Report
  (let [before-datoms (clone-datoms report.db-before.datoms)
        after-datoms (clone-datoms report.db-after.datoms)
        tx-data (arr.into [dynamic]Datom (slice report.tx-data 0))
        tx-meta (clone-tx-meta (slice report.tx-meta 0))
        tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Tx-Report {ok: report.ok
                error: report.error
                db-before: (build-db before-datoms)
                db-after: (build-db after-datoms)
                tx-data: tx-data
                tx: report.tx
                tx-meta: tx-meta
                tempids: tempids})))

(defn listen! [conn: ^Conn, name: string, reports: ^[dynamic]Tx-Report] -> bool
  (for [listener index conn^.listeners]
    (when (= listener.name name)
      (set! conn^.listeners[index] (Tx-Listener {name: name reports: reports}))
      (return true)))
  (arr.push! conn^.listeners (Tx-Listener {name: name reports: reports}))
  true)

(defn unlisten! [conn: ^Conn, name: string] -> bool
  (for [listener index conn^.listeners]
    (when (= listener.name name)
      (arr.remove-ordered-at! conn^.listeners index)
      (return true)))
  false)

(defn notify-listeners! [conn: ^Conn, report: Tx-Report]
  (for [listener conn^.listeners]
    (arr.push! listener.reports^ (clone-tx-report report))))

(defn clone-binding [binding: Binding] -> Binding
  (let [items (arr.into [dynamic]Var-Binding (slice binding.items 0))]
    (Binding {items: items})))

(defn clone-bindings [bindings: []Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (arr.push! out (clone-binding binding)))
    out))

(defn binding-lookup [binding: Binding, name: string] -> [value: Value, ok: bool]
  (for [item binding.items]
    (when (= item.name name)
      (return item.value true)))
  (return (Value {}) false))

(defn binding-store! [binding: ^Binding, name: string, value: Value]
  (arr.push! binding^.items (Var-Binding {name: name value: value})))

(defn lookup-ref-value [attr: string, value: Value] -> Value
  (value-vector2 (value-keyword attr) value))

(defn value-lookup-ref-parts [value: Value] -> [attr: string, lookup-value: Value, ok: bool]
  (when (and (= value.kind .Vector)
             (= (count value.items) 2)
             (= value.items[0].kind .Keyword))
    (return value.items[0].text value.items[1] true))
  (return "" (Value {}) false))

(defn value-as-entity [db: DB, value: Value] -> [entity: Value, ok: bool]
  (cond
    (= value.kind .Entity)
      (return value true)
    (= value.kind .Int)
      (return (value-entity (u64 value.int-value)) true)
    (= value.kind .Keyword)
      (let [[entity found] (schema-entity-for-attr db value.text)]
        (if found
          (return (value-entity entity) true)
          (return (Value {}) false)))
    :else
      (let [[attr lookup-value lookup-ok] (value-lookup-ref-parts value)]
        (when lookup-ok
          (let [[entity found] (resolve-lookup-ref db attr lookup-value)]
            (if found
              (return (value-entity entity) true)
              (return (Value {}) false))))
        (return (Value {}) false))))

(defn lookup-ref-value-as-entity [db: DB, value: Value] -> [entity: Value, ok: bool]
  (let [[attr lookup-value lookup-ok] (value-lookup-ref-parts value)]
    (when lookup-ok
      (let [[entity found] (resolve-lookup-ref db attr lookup-value)]
        (if found
          (return (value-entity entity) true)
          (return (Value {}) false)))))
  (return (Value {}) false))

(defn entity-value-equal? [db: DB, left: Value, right: Value] -> bool
  (when (predicate-value-equal? left right)
    (return true))
  (let [[left-entity left-ok] (lookup-ref-value-as-entity db left)]
    (when left-ok
      (return (predicate-value-equal? left-entity right))))
  (let [[right-entity right-ok] (lookup-ref-value-as-entity db right)]
    (when right-ok
      (return (predicate-value-equal? left right-entity))))
  false)

(defn query-input-scalar-value [db: DB, input: Query-Input] -> [value: Value, ok: bool]
  (when input.has-lookup-ref
    (let [[_ lookup-ok] (resolve-lookup-ref db input.lookup-attr input.lookup-value)]
      (if lookup-ok
        (return (lookup-ref-value input.lookup-attr input.lookup-value) true)
        (return (Value {}) false))))
  (return input.value true))

(defn primary-relation-db-source-name [] -> string
  "__vev_primary_relation_db")

(defn query-source-input-name? [name: string] -> bool
  (or (strings.has_prefix name "$")
      (= name (primary-relation-db-source-name))))

(defn query-input-relation-source-vector [input: Query-Input] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Relation)
               (> input.width 0))
      (let [row_count (/ (count input.values) input.width)]
        (for [row 0..<row_count]
          (let [items (make [dynamic]Value)
                offset (* row input.width)]
            (for [index 0..<input.width]
              (arr.push! items input.values[(+ offset index)]))
            (arr.push! rows (value-vector (slice items 0)))))))
    (value-vector (slice rows 0))))

(defn query-input-source-value [input: Query-Input] -> [value: Value, ok: bool]
  (cond
    (= input.kind .Relation)
      (return (query-input-relation-source-vector input) true)
    (= input.kind .Collection)
      (return (value-vector input.values) true)
    (and (= input.kind .Scalar)
         (= input.value.kind .Map))
      (return (query-input-map-as-relation-vector input) true)
    (= input.kind .Scalar)
      (return input.value true)
    :else (return (Value {}) false)))

(defn query-input-bound-value [db: DB, name: string, input: Query-Input] -> [value: Value, ok: bool]
  (when (query-source-input-name? name)
    (return (query-input-source-value input)))
  (when (or (= input.kind .Scalar)
            (= input.kind .PullPattern))
    (return (query-input-scalar-value db input)))
  (return (Value {}) false))

(defn query-source-input-value? [input: Query-Input] -> bool
  (cond
    (= input.kind .Relation) true
    (= input.kind .Collection) true
    (and (= input.kind .Scalar)
         (= input.value.kind .Vector)) true
    (and (= input.kind .Scalar)
         (= input.value.kind .Map)) true
    :else false))

(defn binding-from-inputs [db: DB, names: []string, values: []Query-Input] -> [bindings: [dynamic]Binding]
  (let [binding (Binding {})
        out (make [dynamic]Binding)]
    (for [name index names]
      (when (< index (count values))
        (let [[value ok] (query-input-bound-value db name values[index])]
          (if ok
            (binding-store! (addr binding) name value)
            (return out)))))
    (arr.push! out binding)
    out))

(defn expand-scalar-input [db: DB, bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (let [[value ok] (query-input-bound-value db name input)]
      (when ok
        (for [binding bindings]
          (let [next (clone-binding binding)]
            (binding-store! (addr next) name value)
            (arr.push! out next)))))
    out))

(defn expand-collection-input [bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .Collection)
      (for [binding bindings]
        (for [value input.values]
          (let [next (clone-binding binding)]
            (binding-store! (addr next) name value)
            (arr.push! out next)))))
    out))

(defn expand-collection-lookup-ref-input [db: DB, bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .CollectionLookupRefs)
      (for [binding bindings]
        (for [value index input.lookup-values]
          (let [attr input.lookup-attrs[index]
                [_ ok] (resolve-lookup-ref db attr value)]
            (when ok
              (let [next (clone-binding binding)]
                (binding-store! (addr next) name (lookup-ref-value attr value))
                (arr.push! out next)))))))
    out))

(defn bind-input-pattern [binding: Binding, pattern: Input-Binding, value: Value] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (case pattern.kind
      .Ignore (arr.push! out (clone-binding binding))
      .Var (let [[next ok] (binding-with-value binding pattern.name value)]
             (when ok
               (arr.push! out next)))
      .Tuple (when (and (= value.kind .Vector)
                        (= (count pattern.items) (count value.items)))
               (let [current (make [dynamic]Binding)]
                 (arr.push! current (clone-binding binding))
                 (for [item index pattern.items]
                   (let [next-current (make [dynamic]Binding)]
                     (for [candidate current]
                       (let [bound (bind-input-pattern candidate item value.items[index])]
                         (for [bound-item bound]
                           (arr.push! next-current bound-item))))
                     (delete current)
                     (set! current next-current)))
                 (for [candidate current]
                   (arr.push! out candidate))))
      .Collection (when (and (= value.kind .Vector)
                             (= (count pattern.items) 1))
                    (for [item value.items]
                      (let [bound (bind-input-pattern binding pattern.items[0] item)]
                        (for [bound-item bound]
                          (arr.push! out bound-item)))))
      :else (do))
    out))

(defn query-input-relation-as-vector [input: Query-Input, width: int] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Relation)
               (= input.width width)
               (> width 0))
      (let [row_count (/ (count input.values) width)]
        (for [row 0..<row_count]
          (let [items (make [dynamic]Value)
                offset (* row width)]
            (for [index 0..<width]
              (arr.push! items input.values[(+ offset index)]))
            (arr.push! rows (value-vector (slice items 0)))))))
    (value-vector (slice rows 0))))

(defn query-input-map-as-relation-vector [input: Query-Input] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Scalar)
               (= input.value.kind .Map))
      (let [row_count (/ (count input.value.items) 2)]
        (for [row 0..<row_count]
          (let [offset (* row 2)]
            (arr.push! rows
              (value-vector
                ([]Value [input.value.items[offset]
                          input.value.items[(+ offset 1)]])))))))
    (value-vector (slice rows 0))))

(defn expand-tuple-input [bindings: []Binding, tuple: Tuple-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (not (= tuple.binding.kind .None))
      (let [tuple-value (value-vector (slice input.values 0))]
        (for [binding bindings]
          (let [bound (bind-input-pattern binding tuple.binding tuple-value)]
            (for [item bound]
              (arr.push! out item)))))
      (return out))
    (when (= (count tuple.vars) (count input.values))
      (for [binding bindings]
        (let [next (clone-binding binding)]
          (for [name index tuple.vars]
            (when (not (= name ""))
              (binding-store! (addr next) name input.values[index])))
          (arr.push! out next))))
    out))

(defn expand-relation-input [bindings: []Binding, relation: Relation-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        width (count relation.vars)]
    (when (not (= relation.binding.kind .None))
      (let [relation-value (cond
                             (= input.kind .Collection) (value-vector (slice input.values 0))
                             (= input.kind .Relation) (query-input-relation-as-vector input width)
                             (and (= input.kind .Scalar) (= input.value.kind .Map)) (query-input-map-as-relation-vector input)
                             :else (Value {}))]
        (when (= relation-value.kind .Vector)
          (for [binding bindings]
            (let [bound (bind-input-pattern binding relation.binding relation-value)]
              (for [item bound]
                (arr.push! out item))))))
      (return out))
    (when (and (= input.kind .Relation)
               (= input.width width))
      (let [row_count (/ (count input.values) width)]
        (for [binding bindings]
          (for [row 0..<row_count]
            (let [next (clone-binding binding)
                  offset (* row width)]
              (for [name index relation.vars]
                (when (not (= name ""))
                  (binding-store! (addr next) name input.values[(+ offset index)])))
              (arr.push! out next))))))
    (when (and (= input.kind .Scalar)
               (= input.value.kind .Map)
               (= width 2))
      (let [row_count (/ (count input.value.items) 2)]
        (for [binding bindings]
          (for [row 0..<row_count]
            (let [next (clone-binding binding)
                  offset (* row 2)]
              (when (not (= relation.vars[0] ""))
                (binding-store! (addr next) relation.vars[0] input.value.items[offset]))
              (when (not (= relation.vars[1] ""))
                (binding-store! (addr next) relation.vars[1] input.value.items[(+ offset 1)]))
              (arr.push! out next))))))
    out))

(defn bindings-from-inputs-in-order [db: DB, query: Query, inputs: []Query-Input] -> [dynamic]Binding
  (let [binding (Binding {})
        bindings (make [dynamic]Binding)]
    (arr.push! bindings binding)
    (for [spec index query.input-specs]
      (when (< index (count inputs))
        (let [next-bindings (make [dynamic]Binding)]
          (cond
            (= spec.kind .Scalar)
              (set! next-bindings (expand-scalar-input db (slice bindings 0) spec.name inputs[index]))
            (= spec.kind .Collection)
              (if (= inputs[index].kind .CollectionLookupRefs)
                (set! next-bindings (expand-collection-lookup-ref-input db (slice bindings 0) spec.name inputs[index]))
                (set! next-bindings (expand-collection-input (slice bindings 0) spec.name inputs[index])))
            (= spec.kind .Tuple)
              (set! next-bindings (expand-tuple-input (slice bindings 0) spec.tuple inputs[index]))
            (= spec.kind .Relation)
              (set! next-bindings (expand-relation-input (slice bindings 0) spec.relation inputs[index]))
            (= spec.kind .Ignore)
              (set! next-bindings (clone-bindings (slice bindings 0))))
          (delete bindings)
          (set! bindings next-bindings))))
    bindings))

(defn bindings-from-inputs [db: DB, query: Query, inputs: []Query-Input] -> [dynamic]Binding
  (when (> (count query.input-specs) 0)
    (return (bindings-from-inputs-in-order db query inputs)))
  (let [bindings (binding-from-inputs db (slice query.inputs 0) inputs)
        collection-offset (count query.inputs)
        tuple-offset (+ collection-offset (count query.collection-inputs))
        relation-offset (+ tuple-offset (count query.tuple-inputs))]
    (for [name index query.collection-inputs]
      (let [input-index (+ collection-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (make [dynamic]Binding)]
            (if (= inputs[input-index].kind .CollectionLookupRefs)
              (set! next-bindings (expand-collection-lookup-ref-input db (slice bindings 0) name inputs[input-index]))
              (set! next-bindings (expand-collection-input (slice bindings 0) name inputs[input-index])))
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [tuple index query.tuple-inputs]
      (let [input-index (+ tuple-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-tuple-input (slice bindings 0) tuple inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [relation index query.relation-inputs]
      (let [input-index (+ relation-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-relation-input (slice bindings 0) relation inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    bindings))

(defn match-term? [term: Term, actual: Value, binding: ^Binding] -> bool
  (case term.kind
    .Value (value-equal? term.value actual)
    .Wildcard true
    .Var (let [[existing ok] (binding-lookup binding^ term.name)]
           (if ok
             (predicate-value-equal? existing actual)
             (do
               (binding-store! binding term.name actual)
               true)))
    :else false))

(defn resolve-term [term: Term, binding: Binding] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (binding-lookup binding term.name))
    :else (return (Value {}) false)))

(defn resolve-entity-term [db: DB, term: Term, binding: Binding] -> [value: Value, ok: bool]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
      (return (value-entity entity) lookup-ok)))
  (let [[resolved resolved-ok] (resolve-term term binding)]
    (when (not resolved-ok)
      (return resolved false))
    (let [[entity entity-ok] (value-as-entity db resolved)]
      (when entity-ok
        (return entity true)))
    (when (= resolved.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db resolved.text)]
        (return (value-entity entity) ident-ok)))
    (when (= resolved.kind .Int)
      (return (value-entity (u64 resolved.int-value)) true))
    (return resolved true)))

(defn predicate-pair-matches? [op: string, left: Value, right: Value] -> bool
  (cond
    (= op "=") (predicate-value-equal? left right)
    (or (= op "!=") (= op "not=")) (not (predicate-value-equal? left right))
    (= op ">") (value-less? right left)
    (= op "<") (value-less? left right)
    (= op ">=") (not (value-less? left right))
    (= op "<=") (not (value-less? right left))
    :else false))

(defn query-var-name? [name: string] -> bool
  (strings.has_prefix name "?"))

(defn query-op-value-name [value: Value] -> [name: string, ok: bool]
  (when (= value.kind .Keyword)
    (if (strings.has_prefix value.text ":")
      (return (slice value.text 1) true)
      (return value.text true)))
  (when (= value.kind .String)
    (return value.text true))
  (return "" false))

(defn query-op-name [op: string, binding: Binding] -> [name: string, ok: bool]
  (when (not (query-var-name? op))
    (return op true))
  (let [[value value-ok] (binding-lookup binding op)]
    (when (not value-ok)
      (return "" false))
    (query-op-value-name value)))

(defn query-fn [name: string, target: string] -> Native-Query-Fn
  (Native-Query-Fn {name: name target: target}))

(defn query-predicate-fn [name: string, f: fn [args: []Value] -> bool] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-predicate-callback: true predicate-callback: f}))

(defn query-db-predicate-fn [name: string, f: fn [db: DB, args: []Value] -> bool] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-db-predicate-callback: true db-predicate-callback: f}))

(defn native-query-function-result [value: Value] -> Native-Query-Function-Result
  (Native-Query-Function-Result {ok: true value: value}))

(defn native-query-function-none [] -> Native-Query-Function-Result
  (Native-Query-Function-Result {ok: false}))

(defn query-value-fn [name: string, f: fn [args: []Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-function-callback: true function-callback: f}))

(defn query-aggregate-fn [name: string, f: fn [values: []Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-aggregate-callback: true aggregate-callback: f}))

(defn pull-xform-fn [name: string, f: fn [value: Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-pull-xform-callback: true pull-xform-callback: f}))

(defn query-fn-index [registry: []Native-Query-Fn, name: string] -> [index: int, ok: bool]
  (for [entry index registry]
    (when (= entry.name name)
      (return index true)))
  (return 0 false))

(defn query-fn-supported? [registry: []Native-Query-Fn, op: string] -> bool
  (when (query-var-name? op)
    (return true))
  (let [[_ ok] (query-fn-index registry op)]
    ok))

(defn query-fn-target [registry: []Native-Query-Fn, op: string] -> [target: string, ok: bool]
  (let [[index found] (query-fn-index registry op)]
    (when (not found)
      (return "" false))
    (return registry[index].target true)))

(defn resolve-query-call-args [terms: []Term, binding: Binding] -> [out: [dynamic]Value, ok: bool]
  (let [args (make [dynamic]Value 0 (count terms))]
    (for [term terms]
      (let [[value value-ok] (resolve-term term binding)]
        (when (not value-ok)
          (return args false))
        (arr.push! args value)))
    (return args true)))

(defn re-find-matches? [pattern: Value, text: Value] -> bool
  (when (not (and (= pattern.kind .String)
                  (= text.kind .String)))
    (return false))
  (let [[iter err] (regex.create_iterator text.text pattern.text)]
    (when (!= err nil)
      (return false))
    (defer (regex.destroy iter))
    (let [[_ _ ok] (regex.match (addr iter))]
      ok)))

(defn re-find-value [pattern: Value, text: Value] -> [value: Value, ok: bool]
  (when (not (and (= pattern.kind .String)
                  (= text.kind .String)))
    (return (Value {}) false))
  (let [[iter err] (regex.create_iterator text.text pattern.text)]
    (when (!= err nil)
      (return (Value {}) false))
    (defer (regex.destroy iter))
    (let [[capture _ ok] (regex.match (addr iter))]
      (when (and ok (> (count capture.groups) 0))
        (return (value-string capture.groups[0]) true))))
  (return (Value {}) false))

(defn value-str [value: Value] -> [text: string, ok: bool]
  (case value.kind
    .String (return value.text true)
    .Keyword (return value.text true)
    .Int (return (fmt.tprintf "%d" value.int-value) true)
    .Float (return (fmt.tprintf "%v" value.float-value) true)
    .Bool (if value.bool-value
            (return "true" true)
            (return "false" true))
    .Entity (return (fmt.tprintf "%d" value.entity) true)
    .Nil (return "" true)
    :else (return "" false)))

(defn primitive-value-dedupe-key [value: Value] -> [key: string, ok: bool]
  (case value.kind
    .Entity (return (fmt.tprintf "e:%d" value.entity) true)
    .String (return (fmt.tprintf "s:%s" value.text) true)
    .Int (return (fmt.tprintf "i:%d" value.int-value) true)
    .Float (return (fmt.tprintf "f:%v" value.float-value) true)
    .Bool (if value.bool-value
            (return "b:true" true)
            (return "b:false" true))
    .Keyword (return (fmt.tprintf "k:%s" value.text) true)
    .Symbol (return (fmt.tprintf "y:%s" value.text) true)
    .Nil (return "n:" true)
    :else (return "" false)))

(defn row-values-dedupe-key [values: []Value] -> [key: string, ok: bool]
  (when (= (count values) 1)
    (return (primitive-value-dedupe-key values[0])))
  (let [parts (make [dynamic]string 0 (count values))]
    (defer (delete parts))
    (for [value values]
      (let [[part part-ok] (primitive-value-dedupe-key value)]
        (when (not part-ok)
          (return "" false))
        (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part))))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn two-primitive-values-dedupe-key [first: Value, second: Value] -> [key: string, ok: bool]
  (cond
    (and (= first.kind .String) (= second.kind .Int))
      (return (fmt.tprintf "si:%d:%s:%d" (count first.text) first.text second.int-value) true)
    (and (= first.kind .Int) (= second.kind .String))
      (return (fmt.tprintf "is:%d:%d:%s" first.int-value (count second.text) second.text) true)
    (and (= first.kind .String) (= second.kind .String))
      (return (fmt.tprintf "ss:%d:%s:%d:%s" (count first.text) first.text (count second.text) second.text) true)
    (and (= first.kind .Int) (= second.kind .Int))
      (return (fmt.tprintf "ii:%d:%d" first.int-value second.int-value) true)
    :else
      (let [values ([]Value [first second])]
        (row-values-dedupe-key values))))

(defn sort-strings! [values: ^[dynamic]string]
  (for [i (arr.range 1 (count values^))]
    (let [item values^[i]
          j i]
      (while (and (> j 0)
                  (string-less? item values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] item))))

(defn binding-dedupe-key [binding: Binding] -> [key: string, ok: bool]
  (let [parts (make [dynamic]string 0 (count binding.items))]
    (defer (delete parts))
    (for [item binding.items]
      (let [[value-key value-ok] (primitive-value-dedupe-key item.value)]
        (when (not value-ok)
          (return "" false))
        (arr.push! parts (fmt.tprintf "%d:%s=%d:%s;" (count item.name) item.name (count value-key) value-key))))
    (sort-strings! (addr parts))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn predicate-matches? [predicate: Predicate, binding: Binding] -> bool
  (let [[op op-ok] (query-op-name predicate.op binding)]
    (when (not op-ok)
      (return false))
  (when (and (or (= op "true?")
                 (= op "false?")
                 (= op "nil?")
                 (= op "some?")
                 (= op "not")
                 (= op "empty?"))
             (= (count predicate.terms) 1))
    (let [[value value-ok] (resolve-term predicate.terms[0] binding)]
      (when (not value-ok)
        (return false))
      (cond
        (= op "true?") (return (and (= value.kind .Bool) value.bool-value))
        (= op "false?") (return (and (= value.kind .Bool) (not value.bool-value)))
        (= op "nil?") (return (= value.kind .Nil))
        (= op "some?") (return (not (= value.kind .Nil)))
        (= op "not") (return (or (= value.kind .Nil)
                                           (and (= value.kind .Bool) (not value.bool-value))))
        (= op "empty?") (return (and (= value.kind .Vector) (= (count value.items) 0))))))
  (when (and (or (= op "even?")
                 (= op "odd?")
                 (= op "zero?")
                 (= op "pos?")
                 (= op "neg?"))
             (= (count predicate.terms) 1))
    (let [[value value-ok] (resolve-term predicate.terms[0] binding)]
      (when (not value-ok)
        (return false))
      (when (= value.kind .Int)
        (cond
          (= op "even?") (return (= (% value.int-value 2) 0))
          (= op "odd?") (return (not (= (% value.int-value 2) 0)))
          (= op "zero?") (return (= value.int-value 0))
          (= op "pos?") (return (> value.int-value 0))
          (= op "neg?") (return (< value.int-value 0))))
      (when (= value.kind .Entity)
        (cond
          (= op "even?") (return (= (% value.entity 2) 0))
          (= op "odd?") (return (not (= (% value.entity 2) 0)))
          (= op "zero?") (return (= value.entity 0))
          (= op "pos?") (return (> value.entity 0))
          (= op "neg?") (return false)))
      (return false)))
  (when (and (= op "re-find")
             (= (count predicate.terms) 2))
    (let [[pattern pattern-ok] (resolve-term predicate.terms[0] binding)
          [text text-ok] (resolve-term predicate.terms[1] binding)]
      (return (and pattern-ok text-ok (re-find-matches? pattern text)))))
  (when (and (or (= op "contains?")
                 (= op "clojure.string/includes?")
                 (= op "clojure.string/starts-with?")
                 (= op "clojure.string/ends-with?"))
             (= (count predicate.terms) 2))
    (let [[left left-ok] (resolve-term predicate.terms[0] binding)
          [right right-ok] (resolve-term predicate.terms[1] binding)]
      (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
        (return false))
      (cond
        (or (= op "contains?") (= op "clojure.string/includes?"))
          (return (strings.contains left.text right.text))
        (= op "clojure.string/starts-with?")
          (return (strings.has_prefix left.text right.text))
        (= op "clojure.string/ends-with?")
          (return (strings.has_suffix left.text right.text)))))
  (when (< (count predicate.terms) 2)
    (return false))
  (for [index (arr.range 0 (- (count predicate.terms) 1))]
    (let [[left left-ok] (resolve-term predicate.terms[index] binding)
          [right right-ok] (resolve-term predicate.terms[(+ index 1)] binding)]
      (when (not (and left-ok right-ok))
        (return false))
      (when (not (predicate-pair-matches? op left right))
        (return false))))
  true))

(defn predicate-matches-with-db-and-fns? [db: DB, predicate: Predicate, binding: Binding, registry: []Native-Query-Fn] -> bool
  (when (predicate-matches? predicate binding)
    (return true))
  (let [[op op-ok] (query-op-name predicate.op binding)]
    (when (not op-ok)
      (return false))
    (let [[index found] (query-fn-index registry op)]
      (when (not found)
        (return false))
      (let [entry registry[index]]
        (when entry.has-predicate-callback
          (let [[args args-ok] (resolve-query-call-args predicate.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return false))
            (return (entry.predicate-callback (slice args 0)))))
        (when entry.has-db-predicate-callback
          (let [[args args-ok] (resolve-query-call-args predicate.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return false))
            (return (entry.db-predicate-callback db (slice args 0)))))
        (when (> (count entry.target) 0)
          (return (predicate-matches? (Predicate {op: entry.target terms: predicate.terms}) binding)))
        (return false)))))

(defn predicate-matches-with-fns? [predicate: Predicate, binding: Binding, registry: []Native-Query-Fn] -> bool
  (predicate-matches-with-db-and-fns? (DB {}) predicate binding registry))

(defn map-get-value [map-value: Value, key: Value] -> [value: Value, ok: bool]
  (when (not (= map-value.kind .Map))
    (return (Value {}) false))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (when (value-equal? map-value.items[index] key)
        (return map-value.items[(+ index 1)] true))
      (set! index (+ index 2))))
  (return (Value {}) false))

(defn apply-function-op [function: Function-Clause, binding: Binding] -> [value: Value, ok: bool]
  (let [[op op-ok] (query-op-name function.op binding)]
    (when (not op-ok)
      (return (Value {}) false))
  (when (and (= op "count")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .String))
        (return (value-int (i64 (count input.text))) true))
      (return (Value {}) false)))
  (when (and (or (= op "identity")
                 (= op "ground"))
             (= (count function.terms) 1))
    (return (resolve-term function.terms[0] binding)))
  (when (and (= op "inc")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Int))
        (return (value-int (+ input.int-value 1)) true))
      (return (Value {}) false)))
  (when (and (= op "dec")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Int))
        (return (value-int (- input.int-value 1)) true))
      (return (Value {}) false)))
  (when (and (= op "range")
             (or (= (count function.terms) 1)
                 (= (count function.terms) 2)
                 (= (count function.terms) 3)))
    (let [start: i64 0
          end: i64 0
          step: i64 1]
      (if (= (count function.terms) 1)
        (let [[end-value end-ok] (resolve-term function.terms[0] binding)]
          (when (not (and end-ok (= end-value.kind .Int)))
            (return (Value {}) false))
          (set! end end-value.int-value))
        (do
          (let [[start-value start-ok] (resolve-term function.terms[0] binding)
                [end-value end-ok] (resolve-term function.terms[1] binding)]
            (when (not (and start-ok end-ok (= start-value.kind .Int) (= end-value.kind .Int)))
              (return (Value {}) false))
            (set! start start-value.int-value)
            (set! end end-value.int-value))
          (when (= (count function.terms) 3)
            (let [[step-value step-ok] (resolve-term function.terms[2] binding)]
              (when (not (and step-ok (= step-value.kind .Int) (not (= step-value.int-value 0))))
                (return (Value {}) false))
              (set! step step-value.int-value)))))
      (let [items (make [dynamic]Value)]
        (if (> step 0)
          (while (< start end)
            (arr.push! items (value-int start))
            (set! start (+ start step)))
          (while (> start end)
            (arr.push! items (value-int start))
            (set! start (+ start step))))
        (let [out (value-vector (slice items 0))]
          (delete items)
          (return out true)))))
  (when (and (= op "name")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (not input-ok)
        (return (Value {}) false))
      (when (= input.kind .String)
        (return input true))
      (when (= input.kind .Keyword)
        (let [slash (slash-index input.text)]
          (if (= slash -1)
            (return (value-string (slice input.text 1)) true)
            (return (value-string (slice input.text (+ slash 1))) true))))
      (return (Value {}) false)))
  (when (and (= op "subs")
             (or (= (count function.terms) 2)
                 (= (count function.terms) 3)))
    (let [[input input-ok] (resolve-term function.terms[0] binding)
          [start start-ok] (resolve-term function.terms[1] binding)]
      (when (not (and input-ok start-ok (= input.kind .String) (= start.kind .Int)))
        (return (Value {}) false))
      (if (= (count function.terms) 2)
        (let [[part ok] (strings.substring_from input.text (int start.int-value))]
          (when ok
            (return (value-string part) true)))
        (let [[end end-ok] (resolve-term function.terms[2] binding)]
          (when (and end-ok (= end.kind .Int))
            (let [[part ok] (strings.substring input.text (int start.int-value) (int end.int-value))]
              (when ok
                (return (value-string part) true))))))
      (return (Value {}) false)))
  (when (and (= op "re-pattern")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .String))
        (let [[compiled err] (regex.create input.text)]
          (when (= err nil)
            (regex.destroy compiled)
            (return input true))))
      (return (Value {}) false)))
  (when (and (= op "re-find")
             (= (count function.terms) 2))
    (let [[pattern pattern-ok] (resolve-term function.terms[0] binding)
          [text text-ok] (resolve-term function.terms[1] binding)]
      (when (and pattern-ok text-ok)
        (return (re-find-value pattern text)))
      (return (Value {}) false)))
  (when (= op "str")
    (let [parts (make [dynamic]string 0 (count function.terms))]
      (defer (delete parts))
      (for [term function.terms]
        (let [[value value-ok] (resolve-term term binding)]
          (when (not value-ok)
            (return (Value {}) false))
          (let [[part part-ok] (value-str value)]
            (when (not part-ok)
              (return (Value {}) false))
            (arr.push! parts part))))
      (return (value-string (strings.concatenate (slice parts 0))) true)))
  (when (and (= op "keyword")
             (or (= (count function.terms) 1)
                 (= (count function.terms) 2)))
    (if (= (count function.terms) 1)
      (let [[input input-ok] (resolve-term function.terms[0] binding)]
        (when (not input-ok)
          (return (Value {}) false))
        (when (= input.kind .Keyword)
          (return input true))
        (when (= input.kind .String)
          (if (strings.has_prefix input.text ":")
            (return (value-keyword input.text) true)
            (return (value-keyword (strings.concatenate ([]string [":" input.text]))) true)))
        (return (Value {}) false))
      (let [[namespace namespace-ok] (resolve-term function.terms[0] binding)
            [name name-ok] (resolve-term function.terms[1] binding)]
        (when (not (and namespace-ok name-ok (= namespace.kind .String) (= name.kind .String)))
          (return (Value {}) false))
        (return
          (value-keyword (strings.concatenate ([]string [":" namespace.text "/" name.text])))
          true))))
  (when (and (or (= op "first")
                 (= op "second"))
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)
          index (if (= op "first") 0 1)]
      (when (and input-ok
                 (= input.kind .Vector)
                 (< index (count input.items)))
        (return input.items[index] true))
      (return (Value {}) false)))
  (when (or (= op "vector")
            (= op "tuple"))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-vector (slice items 0)) true)))
  (when (and (= op "untuple")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Vector))
        (return input true))
      (return (Value {}) false)))
  (when (= op "hash-map")
    (when (not (= (% (count function.terms) 2) 0))
      (return (Value {}) false))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-map (slice items 0)) true)))
  (when (and (= op "get")
             (= (count function.terms) 2))
    (let [[map-value map-ok] (resolve-term function.terms[0] binding)
          [key key-ok] (resolve-term function.terms[1] binding)]
      (when (and map-ok key-ok)
        (return (map-get-value map-value key)))
      (return (Value {}) false)))
  (when (and (or (= op "contains?")
                 (= op "clojure.string/includes?")
                 (= op "clojure.string/starts-with?")
                 (= op "clojure.string/ends-with?"))
             (= (count function.terms) 2))
    (let [[left left-ok] (resolve-term function.terms[0] binding)
          [right right-ok] (resolve-term function.terms[1] binding)]
      (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
        (return (Value {}) false))
      (cond
        (or (= op "contains?") (= op "clojure.string/includes?"))
          (return (value-bool (strings.contains left.text right.text)) true)
        (= op "clojure.string/starts-with?")
          (return (value-bool (strings.has_prefix left.text right.text)) true)
        (= op "clojure.string/ends-with?")
          (return (value-bool (strings.has_suffix left.text right.text)) true))))
  (when (or (= op "+")
            (= op "-")
            (= op "*")
            (= op "/")
            (= op "quot")
            (= op "rem")
            (= op "mod")
            (= op "min")
            (= op "max"))
    (when (= (count function.terms) 0)
      (return (Value {}) false))
    (let [[first-value first-ok] (resolve-term function.terms[0] binding)
          result first-value.int-value]
      (when (not (and first-ok (= first-value.kind .Int)))
        (return (Value {}) false))
      (for [term (slice function.terms 1)]
        (let [[next next-ok] (resolve-term term binding)]
          (when (not (and next-ok (= next.kind .Int)))
            (return (Value {}) false))
          (cond
            (= op "+") (set! result (+ result next.int-value))
            (= op "-") (set! result (- result next.int-value))
            (= op "*") (set! result (* result next.int-value))
            (= op "/") (do
              (when (= next.int-value 0)
                (return (Value {}) false))
              (set! result (/ result next.int-value)))
            (= op "quot") (do
              (when (= next.int-value 0)
                (return (Value {}) false))
              (set! result (/ result next.int-value)))
            (= op "rem") (do
              (when (= next.int-value 0)
                (return (Value {}) false))
              (set! result (% result next.int-value)))
            (= op "mod") (do
              (when (= next.int-value 0)
                (return (Value {}) false))
              (let [m (% result next.int-value)]
                (if (and (not (= m 0))
                         (or (and (< m 0) (> next.int-value 0))
                             (and (> m 0) (< next.int-value 0))))
                  (set! result (+ m next.int-value))
                  (set! result m))))
            (= op "min") (when (< next.int-value result)
              (set! result next.int-value))
            (= op "max") (when (> next.int-value result)
              (set! result next.int-value)))))
      (return (value-int result) true)))
  (when (and (= op "compare")
             (= (count function.terms) 2))
    (let [[left left-ok] (resolve-term function.terms[0] binding)
          [right right-ok] (resolve-term function.terms[1] binding)]
      (when (and left-ok right-ok)
        (return (value-int (i64 (value-compare left right))) true))
      (return (Value {}) false)))
  (return (Value {}) false)))

(defn apply-function-op-with-fns [function: Function-Clause, binding: Binding, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[builtin builtin-ok] (apply-function-op function binding)]
    (when builtin-ok
      (return builtin true)))
  (let [[op op-ok] (query-op-name function.op binding)]
    (when (not op-ok)
      (return (Value {}) false))
    (let [[index found] (query-fn-index registry op)]
      (when (not found)
        (return (Value {}) false))
      (let [entry registry[index]]
        (when entry.has-function-callback
          (let [[args args-ok] (resolve-query-call-args function.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return (Value {}) false))
            (let [result (entry.function-callback (slice args 0))]
              (return result.value result.ok))))
        (when (> (count entry.target) 0)
          (return (apply-function-op (Function-Clause {op: entry.target
                                                       terms: function.terms
                                                       out: ""
                                                       out-vars: ([]string [])
                                                       out-binding: (Input-Binding {})
                                                       is-tuple: false})
                    binding)))
        (return (Value {}) false)))))

(defn apply-function-clause [binding: Binding, function: Function-Clause] -> [out: Binding, ok: bool]
  (let [[value value-ok] (apply-function-op function binding)]
    (when (not value-ok)
      (return binding false))
    (when (not (= function.out-binding.kind .None))
      (let [bound (bind-input-pattern binding function.out-binding value)]
        (when (= (count bound) 1)
          (return bound[0] true))
        (return binding false)))
    (when function.is-tuple
      (when (not (= value.kind .Vector))
        (return binding false))
      (when (not (= (count value.items) (count function.out-vars)))
        (return binding false))
      (let [next (clone-binding binding)]
        (for [name index function.out-vars]
          (when (not (= name "_"))
            (let [[bound bound-ok] (binding-with-value next name value.items[index])]
              (when (not bound-ok)
                (return binding false))
              (set! next bound))))
        (return next true)))
    (let [next (clone-binding binding)
          [existing exists] (binding-lookup next function.out)]
      (if exists
        (return next (predicate-value-equal? existing value))
        (do
          (binding-store! (addr next) function.out value)
          (return next true))))))

(defn apply-function-clause-with-fns [binding: Binding, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Binding, ok: bool]
  (let [[value value-ok] (apply-function-op-with-fns function binding registry)]
    (when (not value-ok)
      (return binding false))
    (when (not (= function.out-binding.kind .None))
      (let [bound (bind-input-pattern binding function.out-binding value)]
        (when (= (count bound) 1)
          (return bound[0] true))
        (return binding false)))
    (when function.is-tuple
      (when (not (= value.kind .Vector))
        (return binding false))
      (when (not (= (count value.items) (count function.out-vars)))
        (return binding false))
      (let [next (clone-binding binding)]
        (for [name index function.out-vars]
          (when (not (= name "_"))
            (let [[bound bound-ok] (binding-with-value next name value.items[index])]
              (when (not bound-ok)
                (return binding false))
              (set! next bound))))
        (return next true)))
    (let [next (clone-binding binding)
          [existing exists] (binding-lookup next function.out)]
      (if exists
        (return next (predicate-value-equal? existing value))
        (do
          (binding-store! (addr next) function.out value)
          (return next true))))))

(defn datom-current-at? [db: DB, index: int] -> bool
  (let [current (slice db.current 0)
        found (int-lower-bound current index)]
    (and (< found (count current))
         (= current[found] index))))

(defn all-datoms-current? [db: DB] -> bool
  (= (count db.current) (count db.datoms)))

(defn index-arg-value [db: DB, arg: Index-Arg] -> [value: Value, ok: bool]
  (when arg.has-lookup-ref
    (let [[entity found] (resolve-lookup-ref db arg.lookup-attr arg.lookup-value)]
      (when found
        (return (value-entity entity) true))
      (return (Value {}) false)))
  (return arg.value true))

(defn validate-index-lookup-refs [db: DB, args: []Index-Arg] -> [ok: bool, error: string]
  (for [arg args]
    (when arg.has-lookup-ref
      (let [[_ found lookup-error] (resolve-lookup-ref-checked db arg.lookup-attr arg.lookup-value)]
        (when (not found)
          (return false lookup-error)))))
  (return true ""))

(defn resolve-index-args [db: DB, args: []Index-Arg] -> [values: [dynamic]Value, ok: bool]
  (let [resolved (make [dynamic]Value)]
    (for [arg args]
      (let [[value ok] (index-arg-value db arg)]
        (when (not ok)
          (return resolved false))
        (arr.push! resolved value)))
    (return resolved true)))

(defn datom-index-position-value [datom: Datom, order: string, position: int] -> Value
  (if (= order ":eavt")
    (if (= position 0)
      (value-entity datom.e)
      (if (= position 1)
        (value-keyword datom.a)
        (if (= position 2)
          datom.v
          (Value {}))))
    (if (= order ":aevt")
      (if (= position 0)
        (value-keyword datom.a)
        (if (= position 1)
          (value-entity datom.e)
          (if (= position 2)
            datom.v
            (Value {}))))
      (if (= order ":avet")
        (if (= position 0)
          (value-keyword datom.a)
          (if (= position 1)
            datom.v
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))
        (if (= position 0)
          datom.v
          (if (= position 1)
            (value-keyword datom.a)
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))))))

(defn index-position-equal? [actual: Value, expected: Value] -> bool
  (predicate-value-equal? actual expected))

(defn index-position-compare [actual: Value, expected: Value] -> int
  (if (and (= actual.kind .Entity) (= expected.kind .Int))
    (let [right (u64 expected.int-value)]
      (if (< actual.entity right)
        -1
        (if (> actual.entity right) 1 0)))
    (if (and (= actual.kind .Keyword)
             (or (= expected.kind .Keyword) (= expected.kind .String)))
      (strings.compare actual.text expected.text)
      (value-compare actual expected))))

(defn datom-matches-index-values? [datom: Datom, order: string, values: []Value] -> bool
  (for [value position values]
    (when (not (index-position-equal? (datom-index-position-value datom order position) value))
      (return false)))
  true)

(defn datom-index-compare-values [datom: Datom, order: string, values: []Value] -> int
  (for [value position values]
    (let [compare (index-position-compare (datom-index-position-value datom order position) value)]
      (when (not (= compare 0))
        (return compare))))
  0)

(defn public-avet-attr? [db: DB, attr: string] -> bool
  (when (not (db-has-schema? db))
    (return true))
  (let [tuple-attrs (schema-tuple-attrs db attr)
        visible (or (schema-indexed? db attr)
                    (schema-unique? db attr)
                    (schema-ref? db attr)
                    (> (count tuple-attrs) 0))]
    (delete tuple-attrs)
    visible))

(defn public-index-datom-visible? [db: DB, order: string, datom: Datom] -> bool
  (if (= order ":avet")
    (public-avet-attr? db datom.a)
    true))

(defn index-arg-attr [db: DB, arg: Index-Arg] -> [attr: string, ok: bool]
  (let [[value value-ok] (index-arg-value db arg)]
    (when (not value-ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true))
    (return "" false)))

(defn validate-public-index-args [db: DB, order: string, args: []Index-Arg] -> [ok: bool, error: string]
  (let [[lookup-ok lookup-error] (validate-index-lookup-refs db args)]
    (when (not lookup-ok)
      (return false lookup-error)))
  (when (not (= order ":avet"))
    (return true ""))
  (when (= (count args) 0)
    (return true ""))
  (let [[attr attr-ok] (index-arg-attr db args[0])]
    (when (not attr-ok)
      (return false "invalid index attr"))
    (when (not (public-avet-attr? db attr))
      (return false (fmt.tprintf "Attribute %s should be marked as :db/index true" attr))))
  (return true ""))

(defn append-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (let [low (lower-bound-index-values db indexes order values)
        high (upper-bound-index-values db indexes order values)]
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (and (public-index-datom-visible? db order datom)
                       (datom-matches-index-values? datom order values))
              (arr.push! out^ datom))))))))

(defn append-seek-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (let [low (lower-bound-index-values db indexes order values)]
    (for [i (arr.range low (count indexes))]
      (let [datom-index indexes[i]]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (public-index-datom-visible? db order datom)
              (arr.push! out^ datom))))))))

(defn append-rseek-index-datoms! [out: ^[dynamic]Datom, db: DB, order: string, indexes: []int, values: []Value]
  (let [i (upper-bound-index-values db indexes order values)]
    (while (> i 0)
      (set! i (- i 1))
      (let [datom-index indexes[i]]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (public-index-datom-visible? db order datom)
              (arr.push! out^ datom))))))))

(defn append-index-range-datoms! [out: ^[dynamic]Datom, db: DB, attr: string, start-value: Value, has-start: bool, end-value: Value, has-end: bool]
  (let [indexes (slice db.avet 0)
        lower-values (make [dynamic]Value)
        upper-values (make [dynamic]Value)]
    (defer (delete lower-values))
    (defer (delete upper-values))
    (arr.push! lower-values (value-keyword attr))
    (arr.push! upper-values (value-keyword attr))
    (when has-start
      (arr.push! lower-values start-value))
    (when has-end
      (arr.push! upper-values end-value))
    (let [low (lower-bound-index-values db indexes ":avet" (slice lower-values 0))
          high (if has-end
                 (upper-bound-index-values db indexes ":avet" (slice upper-values 0))
                 (upper-bound-index-values db indexes ":avet" ([]Value [(value-keyword attr)])))]
      (for [i (arr.range low high)]
        (let [datom-index indexes[i]]
          (when (datom-current-at? db datom-index)
            (let [datom db.datoms[datom-index]]
              (when (and (= datom.a attr)
                         (public-index-datom-visible? db ":avet" datom))
                (arr.push! out^ datom)))))))))

(defn datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (datoms-with-args db order args)})))

(defn seek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-seek-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-seek-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-seek-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-seek-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn seek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (seek-datoms-with-args db order args)})))

(defn rseek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (if (= order ":eavt")
      (append-rseek-index-datoms! (addr out) db order (slice db.eavt 0) (slice values 0))
      (if (= order ":aevt")
        (append-rseek-index-datoms! (addr out) db order (slice db.aevt 0) (slice values 0))
        (if (= order ":avet")
          (append-rseek-index-datoms! (addr out) db order (slice db.avet 0) (slice values 0))
          (append-rseek-index-datoms! (addr out) db order (slice db.vaet 0) (slice values 0)))))
    out))

(defn rseek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [[valid error] (validate-public-index-args db order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (rseek-datoms-with-args db order args)})))

(defn find-datom-with-args [db: DB, order: string, args: []Index-Arg] -> Datom-Result
  (let [found (datoms-with-args db order args)]
    (defer (delete found))
    (when (> (count found) 0)
      (return (Datom-Result {found: true datom: found[0]})))
    (Datom-Result {})))

(defn index-range-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        start-value (Value {})
        end-value (Value {})]
    (when has-start
      (let [[value ok] (index-arg-value db start)]
        (when (not ok)
          (return out))
        (set! start-value value)))
    (when has-end
      (let [[value ok] (index-arg-value db end)]
        (when (not ok)
          (return out))
        (set! end-value value)))
    (append-index-range-datoms! (addr out) db attr start-value has-start end-value has-end)
    out))

(defn index-range-checked-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> Datoms-Result
  (when (not (public-avet-attr? db attr))
    (return (Datoms-Result {ok: false
                            error: (fmt.tprintf "Attribute %s should be marked as :db/index true" attr)
                            datoms: (make [dynamic]Datom)})))
  (when has-start
    (let [[start-ok start-error] (validate-index-lookup-refs db ([]Index-Arg [start]))]
      (when (not start-ok)
        (return (Datoms-Result {ok: false error: start-error datoms: (make [dynamic]Datom)})))))
  (when has-end
    (let [[end-ok end-error] (validate-index-lookup-refs db ([]Index-Arg [end]))]
      (when (not end-ok)
        (return (Datoms-Result {ok: false error: end-error datoms: (make [dynamic]Datom)})))))
  (Datoms-Result {ok: true error: "" datoms: (index-range-with-args db attr start has-start end has-end)}))

(defn u64-contains? [items: []u64, value: u64] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn append-retract-entity-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, seen: ^[dynamic]u64]
  (when (u64-contains? (slice seen^ 0) entity)
    (return))
  (arr.push! seen^ entity)
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" entity "" (Value {}))
        high (upper-bound-index db indexes "eavt" entity "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db datom.a))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity datom.a datom.v))))))
  (let [ref-value (value-entity entity)
        indexes (slice db.vaet 0)
        low (lower-bound-index db indexes "vaet" 0 "" ref-value)
        high (upper-bound-index db indexes "vaet" 0 "" ref-value)]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (push-tx-op-once! ops (tx-retract datom.e datom.a datom.v)))))))

(defn append-retract-entity-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (append-retract-entity-ops-seen! ops db entity (addr seen))))

(defn append-retract-attr-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string, seen: ^[dynamic]u64]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db attr))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity attr datom.v)))))))

(defn append-retract-attr-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen entity)
    (append-retract-attr-ops-seen! ops db entity attr (addr seen))))

(defn schema-entity-for-attr [db: DB, attr: string] -> [e: u64, ok: bool]
  (let [value (value-keyword attr)
        indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 ":db/ident" value)
        high (upper-bound-index db indexes "avet" 0 ":db/ident" value)]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return db.datoms[datom-index].e true))))
  (return 0 false))

(defn db-has-schema? [db: DB] -> bool
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn schema-keyword [db: DB, attr: string, schema-attr: string] -> [value: string, ok: bool]
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return "" false))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Keyword))
            (return datom.v.text true))))))
  (return "" false))

(defn schema-bool? [db: DB, attr: string, schema-attr: string] -> bool
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return false))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e schema-attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Bool))
            (return datom.v.bool-value))))))
  false)

(defn schema-ident-for-entity [db: DB, entity: u64] -> [attr: string, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity ":db/ident" (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword))
          (return datom.v.text true)))))
  (return "" false))

(defn schema-has-attr? [items: []Schema-Attr, attr: string] -> bool
  (for [item items]
    (when (= item.attr attr)
      (return true)))
  false)

(defn schema-has-bool-property? [db: DB, entity: u64, schema-attr: string] -> [value: bool, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity schema-attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Bool))
          (return datom.v.bool-value true)))))
  (return false false))

(defn schema-keyword-property [db: DB, entity: u64, schema-attr: string] -> [value: string, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity schema-attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword))
          (return datom.v.text true)))))
  (return "" false))

(defn schema-tuple-attrs-for-entity [db: DB, entity: u64] -> [dynamic]string
  (let [out (make [dynamic]string)
        indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity ":db/tupleAttrs" (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity ":db/tupleAttrs" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Vector))
          (for [item datom.v.items]
            (when (= item.kind .Keyword)
              (arr.push! out item.text))))))
    out))

(defn schema-attr-for-entity [db: DB, entity: u64, attr: string] -> Schema-Attr
  (let [[value-type has-value-type] (schema-keyword-property db entity ":db/valueType")
        [cardinality has-cardinality] (schema-keyword-property db entity ":db/cardinality")
        [unique has-unique] (schema-keyword-property db entity ":db/unique")
        [indexed has-indexed] (schema-has-bool-property? db entity ":db/index")
        [component has-component] (schema-has-bool-property? db entity ":db/isComponent")
        tuple-attrs (schema-tuple-attrs-for-entity db entity)
        has-tuple-attrs (> (count tuple-attrs) 0)
        inferred-value-type value-type
        inferred-has-value-type has-value-type
        inferred-cardinality cardinality
        inferred-has-cardinality has-cardinality]
    (when has-tuple-attrs
      (when (not inferred-has-value-type)
        (set! inferred-value-type ":db.type/tuple")
        (set! inferred-has-value-type true))
      (when (not inferred-has-cardinality)
        (set! inferred-cardinality ":db.cardinality/one")
        (set! inferred-has-cardinality true)))
    (Schema-Attr {attr: attr
                  value-type: inferred-value-type
                  has-value-type: inferred-has-value-type
                  cardinality: inferred-cardinality
                  has-cardinality: inferred-has-cardinality
                  unique: unique
                  has-unique: has-unique
                  indexed: indexed
                  has-indexed: has-indexed
                  component: component
                  has-component: has-component
                  tuple-attrs: tuple-attrs
                  has-tuple-attrs: has-tuple-attrs})))

(defn db-schema [db: DB] -> [dynamic]Schema-Attr
  (let [out (make [dynamic]Schema-Attr)
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (not (schema-has-attr? (slice out 0) datom.v.text)))
          (arr.push! out (schema-attr-for-entity db datom.e datom.v.text)))))
    out))

(defn delete-schema [schema: [dynamic]Schema-Attr]
  (for [item schema]
    (delete item.tuple-attrs))
  (delete schema))

(defn schema-tuple-attrs [db: DB, attr: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        [schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return out))
    (let [indexes (slice db.eavt 0)
          low (lower-bound-index db indexes "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))
          high (upper-bound-index db indexes "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Vector))
            (for [item datom.v.items]
              (when (= item.kind .Keyword)
                (arr.push! out item.text)))))))
    out))

(defn tuple-schema-contains? [schema: Tuple-Schema, attr: string] -> bool
  (for [component schema.attrs]
    (when (= component attr)
      (return true)))
  false)

(defn tuple-schemas-containing [db: DB, attr: string] -> [dynamic]Tuple-Schema
  (let [out (make [dynamic]Tuple-Schema)
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[tuple-attr ident-ok] (schema-ident-for-entity db datom.e)]
            (when ident-ok
              (let [attrs (schema-tuple-attrs db tuple-attr)
                    schema (Tuple-Schema {attr: tuple-attr attrs: attrs})]
                (if (tuple-schema-contains? schema attr)
                  (arr.push! out schema)
                  (delete attrs))))))))
    out))

(defn schema-indexed? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/index"))

(defn schema-ref? [db: DB, attr: string] -> bool
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (and has-type (= schema-type ":db.type/ref"))))

(defn schema-ref-target? [db: DB, attr: string] -> bool
  (if (reverse-attr? attr)
    (let [forward (forward-attr-for-reverse attr)]
      (defer (delete forward))
      (schema-ref? db forward))
    (schema-ref? db attr)))

(defn schema-component? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/isComponent"))

(defn value-matches-schema-type? [value: Value, schema-type: string] -> bool
  (cond
    (= schema-type ":db.type/string") (= value.kind .String)
    (= schema-type ":db.type/long") (= value.kind .Int)
    (= schema-type ":db.type/boolean") (= value.kind .Bool)
    (= schema-type ":db.type/ref") (= value.kind .Entity)
    (= schema-type ":db.type/keyword") (= value.kind .Keyword)
    (= schema-type ":db.type/symbol") (= value.kind .Symbol)
    (= schema-type ":db.type/tuple") (= value.kind .Vector)
    :else true))

(defn valid-tuple-attrs-value? [db: DB, value: Value] -> bool
  (when (not (= value.kind .Vector))
    (return false))
  (when (= (count value.items) 0)
    (return false))
  (for [item value.items]
    (when (not (= item.kind .Keyword))
      (return false))
    (when (not (schema-cardinality-one? db item.text))
      (return false))
    (let [nested (schema-tuple-attrs db item.text)]
      (defer (delete nested))
      (when (> (count nested) 0)
        (return false))))
  true)

(defn valid-tuple-attr-target? [db: DB, schema-e: u64] -> bool
  (let [[attr attr-ok] (schema-ident-for-entity db schema-e)]
    (when (not attr-ok)
      (return true))
    (schema-cardinality-one? db attr)))

(defn unique-conflict? [db: DB, op: Tx-Op] -> bool
  (let [indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 op.a op.v)
        high (upper-bound-index db indexes "avet" 0 op.a op.v)]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.e op.e)))
          (return true)))))
  false)

(defn schema-unique? [db: DB, attr: string] -> bool
  (let [[unique has-unique] (schema-keyword db attr ":db/unique")]
    (and has-unique
         (or (= unique ":db.unique/identity")
             (= unique ":db.unique/value")))))

(defn schema-unique-identity? [db: DB, attr: string] -> bool
  (let [[unique has-unique] (schema-keyword db attr ":db/unique")]
    (and has-unique
         (= unique ":db.unique/identity"))))

(defn schema-cardinality-one? [db: DB, attr: string] -> bool
  (let [[cardinality has-cardinality] (schema-keyword db attr ":db/cardinality")]
    (if (and has-cardinality
             (= cardinality ":db.cardinality/many"))
      false
      true)))

(defn schema-cardinality-many? [db: DB, attr: string] -> bool
  (let [[cardinality has-cardinality] (schema-keyword db attr ":db/cardinality")]
    (and has-cardinality
         (= cardinality ":db.cardinality/many"))))

(defn tx-op-cardinality-one? [db: DB, op: Tx-Op] -> bool
  (let [[cardinality has-cardinality] (schema-keyword db op.a ":db/cardinality")]
    (when (and has-cardinality
               (= cardinality ":db.cardinality/many"))
      (return false))
    true))

(defn resolve-ref-component-value [db: DB, value: Value] -> [resolved: Value, ok: bool, error: string]
  (cond
    (= value.kind .Entity) (return value true "")
    (= value.kind .Int) (return (value-entity (u64 value.int-value)) true "")
    (= value.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db value.text)]
        (if ident-ok
          (return (value-entity entity) true "")
          (return value false "ident not found")))
    (and (= value.kind .Vector)
         (= (count value.items) 2)
         (= value.items[0].kind .Keyword))
      (let [[entity entity-ok lookup-error] (resolve-lookup-ref-checked db value.items[0].text value.items[1])]
        (if entity-ok
          (return (value-entity entity) true "")
          (return value false lookup-error)))
    :else (return value true "")))

(defn resolve-tuple-value [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (when (not (= value.kind .Vector))
    (return value true ""))
  (let [tuple-attrs (schema-tuple-attrs db attr)]
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return value true ""))
    (when (not (= (count tuple-attrs) (count value.items)))
      (return value true ""))
    (let [items (make [dynamic]Value 0 (count value.items))]
      (defer (delete items))
      (for [item index value.items]
        (let [component-attr tuple-attrs[index]]
          (if (schema-ref? db component-attr)
            (let [[resolved resolved-ok resolved-error] (resolve-ref-component-value db item)]
              (when (not resolved-ok)
                (return value false resolved-error))
              (arr.push! items resolved))
            (arr.push! items item))))
      (return (value-vector (slice items 0)) true ""))))

(defn resolve-lookup-ref [db: DB, attr: string, value: Value] -> [e: u64, ok: bool]
  (when (not (schema-unique? db attr))
    (return 0 false))
  (let [lookup-value value
        [resolved resolved-ok _] (resolve-tuple-value db attr value)]
    (when (not resolved-ok)
      (return 0 false))
    (set! lookup-value resolved)
    (let [indexes (slice db.avet 0)
          low (lower-bound-index db indexes "avet" 0 attr lookup-value)
          high (upper-bound-index db indexes "avet" 0 attr lookup-value)]
      (for [datom-index (slice indexes low high)]
        (when (datom-current-at? db datom-index)
          (return db.datoms[datom-index].e true)))))
  (return 0 false))

(defn resolve-lookup-ref-checked [db: DB, attr: string, value: Value] -> [e: u64, ok: bool, error: string]
  (when (not (schema-unique? db attr))
    (return 0 false "lookup ref attribute must be unique"))
  (let [[entity found] (resolve-lookup-ref db attr value)]
    (if found
      (return entity true "")
      (return 0 false "lookup ref not found"))))

(defn current-value-exists? [db: DB, entity: u64, attr: string, value: Value] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v value))
          (return true)))))
  false)

(defn current-attr-exists? [db: DB, entity: u64, attr: string] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn cas-expected-matches? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (if (= expected.kind .Nil)
    (not (current-attr-exists? db entity attr))
    (current-value-exists? db entity attr expected)))

(defn value-debug-str [value: Value] -> string
  (when (= value.kind .Nil)
    (return "nil"))
  (let [[text ok] (value-str value)]
    (if ok text "<value>")))

(defn current-cas-value-str [db: DB, entity: u64, attr: string] -> string
  (let [parts (make [dynamic]string) :defer
        indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (arr.push! parts (value-debug-str datom.v)))))
    (when (= (count parts) 0)
      (return "nil"))
    (when (= (count parts) 1)
      (return parts[0]))
    (let [[joined _] (core-strings.join (slice parts 0) " ")]
      (core-strings.concatenate ([]string ["(" joined ")"])))))

(defn cas-failed-error [db: DB, entity: u64, attr: string, expected: Value] -> string
  (fmt.tprintf ":db.fn/cas failed on datom [%d %s %s], expected %s"
               entity
               attr
               (current-cas-value-str db entity attr)
               (value-debug-str expected)))

(defn max-entity-id [] -> u64
  (u64 2147483647))

(defn entity-id-valid? [entity: u64] -> bool
  (<= entity (max-entity-id)))

(defn validate-entity-id [entity: u64] -> [ok: bool, error: string]
  (if (entity-id-valid? entity)
    (return true "")
    (return false "entity id exceeds supported range")))

(defn resolve-tx-value [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (when (schema-ref-target? db attr)
    (return (resolve-ref-component-value db value)))
  (resolve-tuple-value db attr value))

(defn value-lookup-ref-vector [attr: string, value: Value] -> Value
  (value-vector ([]Value [(value-keyword attr) value])))

(defn resolve-cas-expected [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has-expected-lookup-ref
    (when (not (schema-ref? db data.a))
      (return (value-lookup-ref-vector data.expected-lookup-attr data.expected-lookup-value) true ""))
    (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked db data.expected-lookup-attr data.expected-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.expected false lookup-error))))
  (resolve-tx-value db data.a data.expected))

(defn resolve-tx-data-value [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has-value-lookup-ref
    (when (not (schema-ref-target? db data.a))
      (return (value-lookup-ref-vector data.value-lookup-attr data.value-lookup-value) true ""))
    (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked db data.value-lookup-attr data.value-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.v false lookup-error))))
  (resolve-tx-value db data.a data.v))

(defn tx-data-has-tempid? [db: DB, tx-data: []Tx-Data, tempid: string] -> bool
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid)
               (not (and (should-split-map-collection? db data)
                         (= (count data.v.items) 0))))
      (return true)))
  false)

(defn ref-string-value? [db: DB, attr: string, value: Value] -> bool
  (when (not (= value.kind .String))
    (return false))
  (schema-ref-target? db attr))

(defn ref-negative-int-value? [db: DB, attr: string, value: Value] -> bool
  (when (not (= value.kind .Int))
    (return false))
  (and (schema-ref-target? db attr)
       (< value.int-value 0)))

(defn ref-tempid-value-text [value: Value] -> string
  (case value.kind
    .String value.text
    .Int (fmt.tprintf "%d" value.int-value)
    :else ""))

(defn tempid-tuple-component-value [db: DB, tx-data: []Tx-Data, tempid: string, attr: string] -> [value: Value, ok: bool]
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid)
               (= data.op ":db/add")
               (= data.a attr))
      (let [[value value-ok _] (resolve-tx-data-value db data)]
        (return value value-ok))))
  (return (Value {}) false))

(defn tuple-schema-already-seen? [schemas: []string, attr: string] -> bool
  (for [schema-attr schemas]
    (when (= schema-attr attr)
      (return true)))
  false)

(defn tempid-tuple-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false
        seen (make [dynamic]string)]
    (defer (delete seen))
    (for [data tx-data]
      (when (not (and data.has-tempid
                      (= data.tempid tempid)
                      (= data.op ":db/add")))
        (continue))
      (let [schemas (tuple-schemas-containing db data.a)]
        (defer (delete schemas))
        (for [schema schemas]
          (defer (delete schema.attrs))
          (when (not (schema-unique-identity? db schema.attr))
            (continue))
          (when (tuple-schema-already-seen? (slice seen 0) schema.attr)
            (continue))
          (arr.push! seen schema.attr)
          (let [items (make [dynamic]Value 0 (count schema.attrs))
                complete true]
            (for [component schema.attrs]
              (let [[value value-ok] (tempid-tuple-component-value db tx-data tempid component)]
                (if value-ok
                  (arr.push! items value)
                  (set! complete false))))
            (when complete
              (let [tuple-value (value-vector (slice items 0))
                    [entity entity-ok] (resolve-lookup-ref db schema.attr tuple-value)]
                (when entity-ok
                  (when (and has-found (not (= found entity)))
                    (delete items)
                    (return found false true))
                  (set! found entity)
                  (set! has-found true))))
            (delete items)))))
    (return found has-found false)))

(defn tempid-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false]
    (for [data tx-data]
      (when (and data.has-tempid
                 (= data.tempid tempid)
                 (= data.op ":db/add")
                 (schema-unique-identity? db data.a))
        (let [[value value-ok _] (resolve-tx-data-value db data)]
          (when value-ok
            (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
              (when entity-ok
                (when (and has-found (not (= found entity)))
                  (return found false true))
                (set! found entity)
                (set! has-found true)))))))
    (let [[tuple-e tuple-ok tuple-conflict] (tempid-tuple-upsert-entity db tx-data tempid)]
      (when tuple-conflict
        (return found false true))
      (when tuple-ok
        (when (and has-found (not (= found tuple-e)))
          (return found false true))
        (set! found tuple-e)
        (set! has-found true)))
    (return found has-found false)))

(defn current-tx-upsert-conflict? [db: DB, data: Tx-Data, current-tx-e: u64] -> bool
  (when (not (and (= data.op ":db/add")
                  (schema-unique-identity? db data.a)))
    (return false))
  (let [[value value-ok _] (resolve-tx-data-value db data)]
    (when (not value-ok)
      (return false))
    (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
      (and entity-ok (not (= entity current-tx-e))))))

(defn remap-resolved-tempids! [tempids: ^[dynamic]Tempid, from: u64, to: u64]
  (when (= from to)
    (return))
  (for [entry index tempids^]
    (when (= entry.e from)
      (set! tempids^[index] (Tempid {tempid: entry.tempid e: to})))))

(defn remap-resolved-ops! [ops: ^[dynamic]Tx-Op, from: u64, to: u64]
  (when (= from to)
    (return))
  (for [op index ops^]
    (let [next op]
      (when (= next.e from)
        (set! next.e to))
      (when (and (= next.v.kind .Entity)
                 (= next.v.entity from))
        (set! next.v (value-entity to)))
      (set! ops^[index] next))))

(defn remap-resolved-tempid-entity! [ops: ^[dynamic]Tx-Op, tempids: ^[dynamic]Tempid, from: u64, to: u64]
  (remap-resolved-ops! ops from to)
  (remap-resolved-tempids! tempids from to))

(defn tempid-existing-upsert-target [db: DB, data: Tx-Data, existing: u64] -> [target: u64, ok: bool, conflict: bool]
  (when (not (and (= data.op ":db/add")
                  (schema-unique-identity? db data.a)))
    (return existing false false))
  (let [[value value-ok _] (resolve-tx-data-value db data)]
    (when (not value-ok)
      (return existing false false))
    (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
      (when (not entity-ok)
        (return existing false false))
      (when (= entity existing)
        (return existing false false))
      (return entity true false))))

(defn db-with-resolved-ops [db: DB, ops: []Tx-Op] -> DB
  (let [datoms (clone-datoms db.datoms)]
    (for [op ops]
      (arr.push! datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (build-db datoms)))

(defn latest-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))
        latest-index -1
        latest (Value {})]
    (for [datom-index (slice indexes low high)]
      (when (and (datom-current-at? db datom-index)
                 (> datom-index latest-index))
        (set! latest-index datom-index)
        (set! latest db.datoms[datom-index].v)))
    (return latest (>= latest-index 0))))

(defn eavt-ea-prefix-compare-direct [db: DB, datom-index: int, entity: u64, attr: string] -> int
  (let [datom db.datoms[datom-index]]
    (if (< datom.e entity)
      -1
      (if (> datom.e entity)
        1
        (strings.compare datom.a attr)))))

(defn lower-bound-eavt-ea-direct [db: DB, indexes: []int, entity: u64, attr: string] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (eavt-ea-prefix-compare-direct db indexes[mid] entity attr)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn current-cardinality-one-int-value-fast [db: DB, entity: u64, attr: string] -> [value: i64, ok: bool]
  (let [indexes (slice db.eavt 0)
        index-pos (lower-bound-eavt-ea-direct db indexes entity attr)]
    (when (>= index-pos (count indexes))
      (return 0 false))
    (let [datom-index indexes[index-pos]
          datom db.datoms[datom-index]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (= datom.v.kind .Int)
                 (datom-current-at? db datom-index))
        (return datom.v.int-value true))
      (return 0 false))))

(defn cardinality-one-int-value-fast-all-current [db: DB, entity: u64, attr: string] -> [value: i64, ok: bool]
  (let [indexes (slice db.eavt 0)
        index-pos (lower-bound-eavt-ea-direct db indexes entity attr)]
    (when (>= index-pos (count indexes))
      (return 0 false))
    (let [datom db.datoms[indexes[index-pos]]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (= datom.v.kind .Int))
        (return datom.v.int-value true))
      (return 0 false))))

(defn current-cardinality-one-value-fast [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        index-pos (lower-bound-eavt-ea-direct db indexes entity attr)]
    (when (>= index-pos (count indexes))
      (return (Value {}) false))
    (let [datom-index indexes[index-pos]
          datom db.datoms[datom-index]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (datom-current-at? db datom-index))
        (return datom.v true))
      (return (Value {}) false))))

(defn cardinality-one-value-fast-all-current [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        index-pos (lower-bound-eavt-ea-direct db indexes entity attr)]
    (when (>= index-pos (count indexes))
      (return (Value {}) false))
    (let [datom db.datoms[indexes[index-pos]]]
      (when (and (= datom.e entity)
                 (= datom.a attr))
        (return datom.v true))
      (return (Value {}) false))))

(defn current-cardinality-one-value-matches-fast? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (let [[value ok] (current-cardinality-one-value-fast db entity attr)]
    (and ok (value-equal? value expected))))

(defn cardinality-one-value-matches-fast-all-current? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (let [[value ok] (cardinality-one-value-fast-all-current db entity attr)]
    (and ok (value-equal? value expected))))

(defn tuple-value-for-entity [db: DB, entity: u64, attrs: []string] -> [value: Value, ok: bool]
  (let [items (make [dynamic]Value 0 (count attrs))
        any false]
    (for [attr attrs]
      (let [[value found] (latest-attr-value db entity attr)]
        (if found
          (do
            (set! any true)
            (arr.push! items value))
          (arr.push! items (value-nil)))))
    (when (not any)
      (delete items)
      (return (Value {}) false))
    (let [out (value-vector (slice items 0))]
      (delete items)
      (return out true))))

(defn remove-derived-tuple-adds! [ops: ^[dynamic]Tx-Op, entity: u64, attr: string, map-group: string]
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [op ops^[index]]
        (when (and op.derived
                   (= op.kind .Add)
                   (= op.e entity)
                   (= op.a attr)
                   (not (= op.map-group ""))
                   (= op.map-group map-group))
          (arr.remove-ordered-at! ops^ index))
        (set! index (- index 1))))))

(defn append-tuple-maintenance-ops! [out: ^[dynamic]Tx-Op, db: DB, op: Tx-Op]
  (when (= op.a ":db/tupleAttrs")
    (return))
  (let [schemas (tuple-schemas-containing db op.a)]
    (defer (delete schemas))
    (for [schema schemas]
      (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice schema.attrs 0))]
        (if has-value
          (do
            (remove-derived-tuple-adds! out op.e schema.attr op.map-group)
            (let [derived (tx-add-derived op.e schema.attr tuple-value)]
              (set! derived.map-group op.map-group)
              (arr.push! out^ derived)))
          (append-retract-attr-ops! out db op.e schema.attr)))
      (delete schema.attrs))))

(defn direct-tuple-add-matches? [db: DB, op: Tx-Op] -> bool
  (when (not (= op.kind .Add))
    (return false))
  (let [tuple-attrs (schema-tuple-attrs db op.a)]
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return false))
    (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice tuple-attrs 0))]
      (and has-value (value-equal? tuple-value op.v)))))

(defn db-has-tuple-schema? [db: DB] -> bool
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (= datom.v.text ":db.type/tuple"))
          (return true)))))
  false)

(defn op-modifies-tuple-schema? [op: Tx-Op] -> bool
  (and (= op.kind .Add)
       (or (= op.a ":db/tupleAttrs")
           (and (= op.a ":db/valueType")
                (= op.v.kind .Keyword)
                (= op.v.text ":db.type/tuple")))))

(defn ops-modify-tuple-schema? [ops: []Tx-Op] -> bool
  (for [op ops]
    (when (op-modifies-tuple-schema? op)
      (return true)))
  false)

(defn expand-tuple-ops [db: DB, ops: []Tx-Op] -> [dynamic]Tx-Op
  (when (and (not (db-has-tuple-schema? db))
             (not (ops-modify-tuple-schema? ops)))
    (return (arr.into [dynamic]Tx-Op ops)))
  (let [out (make [dynamic]Tx-Op 0 (count ops))
        whole-tx-db (db-with-resolved-ops db ops)]
    (for [op ops]
      (let [direct-tuple-matches (or (direct-tuple-add-matches? whole-tx-db op)
                                     (and op.tuple-identity
                                          (direct-tuple-add-matches? db op)))]
        (when direct-tuple-matches
          (continue)))
      (arr.push! out op)
      (let [scratch (db-with-resolved-ops db (slice out 0))]
        (append-tuple-maintenance-ops! (addr out) scratch op)
        (delete-owned-db scratch)))
    (delete-owned-db whole-tx-db)
    out))

(defn lookup-ref-vector-value? [value: Value] -> bool
  (and (= value.kind .Vector)
       (= (count value.items) 2)
       (= value.items[0].kind .Keyword)))

(defn tx-map-db-id [map-value: Value] -> [value: Value, ok: bool]
  (when (not (= map-value.kind .Map))
    (return (Value {}) false))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (when (and (= map-value.items[index].kind .Keyword)
                 (= map-value.items[index].text ":db/id"))
        (return map-value.items[(+ index 1)] true))
      (set! index (+ index 2))))
  (return (Value {}) false))

(defn nested-entity-ref-data [map-value: Value, generated-tempid: string] -> [data: Tx-Data, ok: bool, error: string]
  (let [[id-value has-id] (tx-map-db-id map-value)]
    (when (not has-id)
      (return (Tx-Data {tempid: generated-tempid has-tempid: true}) true ""))
    (case id-value.kind
      .Entity (return (Tx-Data {e: id-value.entity}) true "")
      .Int (if (< id-value.int-value 0)
             (return (Tx-Data {tempid: (fmt.tprintf "%d" id-value.int-value) has-tempid: true}) true "")
             (return (Tx-Data {e: (u64 id-value.int-value)}) true ""))
      .String (return (Tx-Data {tempid: id-value.text has-tempid: true}) true "")
      .Keyword (return (Tx-Data {ident: id-value.text has-ident: true}) true "")
      .Vector
        (if (lookup-ref-vector-value? id-value)
          (return (Tx-Data {lookup-attr: id-value.items[0].text
                            lookup-value: id-value.items[1]
                            has-lookup-ref: true}) true "")
          (return (Tx-Data {}) false "nested map :db/id vector must be a lookup ref"))
      :else (return (Tx-Data {}) false "nested map :db/id must be int, entity, tempid string, ident keyword, or lookup ref"))))

(defn tx-add-from-entity-data [entity: Tx-Data, attr: string, value: Value] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid entity.tempid attr value)
    entity.has-lookup-ref (add-lookup-ref entity.lookup-attr entity.lookup-value attr value)
    entity.has-ident (add-ident entity.ident attr value)
    :else (add entity.e attr value)))

(defn tx-add-value-tempid-from-entity-data [entity: Tx-Data, attr: string, value-tempid: string] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-value-tempid entity.tempid attr value-tempid)
    entity.has-lookup-ref (add-lookup-ref-value-tempid entity.lookup-attr entity.lookup-value attr value-tempid)
    entity.has-ident (add-ident-value-tempid entity.ident attr value-tempid)
    :else (add-value-tempid entity.e attr value-tempid)))

(defn tx-add-value-lookup-from-entity-data [entity: Tx-Data, attr: string, lookup-attr: string, lookup-value: Value] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-value-lookup-ref entity.tempid attr lookup-attr lookup-value)
    entity.has-lookup-ref (Tx-Data {op: ":db/add"
                                    lookup-attr: entity.lookup-attr
                                    lookup-value: entity.lookup-value
                                    has-lookup-ref: true
                                    a: attr
                                    value-lookup-attr: lookup-attr
                                    value-lookup-value: lookup-value
                                    has-value-lookup-ref: true})
    entity.has-ident (Tx-Data {op: ":db/add"
                               ident: entity.ident
                               has-ident: true
                               a: attr
                               value-lookup-attr: lookup-attr
                               value-lookup-value: lookup-value
                               has-value-lookup-ref: true})
    :else (add-value-lookup-ref entity.e attr lookup-attr lookup-value)))

(defn tx-add-nested-map-from-entity-data [entity: Tx-Data, attr: string, nested-map: Value, nested-tempid: string] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-nested-map entity.tempid attr nested-map nested-tempid)
    entity.has-lookup-ref (add-lookup-ref-nested-map entity.lookup-attr entity.lookup-value attr nested-map nested-tempid)
    entity.has-ident (add-ident-nested-map entity.ident attr nested-map nested-tempid)
    :else (add-nested-map entity.e attr nested-map nested-tempid)))

(defn tx-op-with-map-group [op: Tx-Op, map-group: string] -> Tx-Op
  (let [out op]
    (set! out.map-group map-group)
    out))

(defn append-nested-map-value-tx! [pending: ^[dynamic]Tx-Data, entity: Tx-Data, attr: string, value: Value, seed: string]
  (if (= value.kind .Vector)
    (if (lookup-ref-vector-value? value)
      (arr.push! pending^ (tx-data-with-map-group (tx-add-value-lookup-from-entity-data entity attr value.items[0].text value.items[1]) entity.map-group))
      (for [item value.items]
        (append-nested-map-value-tx! pending entity attr item seed)))
    (if (= value.kind .Map)
      (arr.push! pending^ (tx-data-with-map-group (tx-add-nested-map-from-entity-data entity attr value (fmt.tprintf "%s_%d" seed (count pending^))) entity.map-group))
      (arr.push! pending^ (tx-data-with-map-group (tx-add-from-entity-data entity attr value) entity.map-group)))))

(defn append-nested-map-tx! [pending: ^[dynamic]Tx-Data, entity: Tx-Data, map-value: Value, seed: string] -> [ok: bool, error: string]
  (when (not (= map-value.kind .Map))
    (return false "nested tx value must be a map"))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (let [key map-value.items[index]
            value map-value.items[(+ index 1)]]
        (when (not (= key.kind .Keyword))
          (return false "nested tx map attributes must be keywords"))
        (when (not (= key.text ":db/id"))
          (append-nested-map-value-tx! pending entity key.text value seed)))
      (set! index (+ index 2))))
  (return true ""))

(defn tx-entity-ref-from-data [data: Tx-Data] -> Tx-Data
  (Tx-Data {e: data.e
            tempid: data.tempid
            has-tempid: data.has-tempid
            lookup-attr: data.lookup-attr
            lookup-value: data.lookup-value
            has-lookup-ref: data.has-lookup-ref
            ident: data.ident
            has-ident: data.has-ident
            map-group: data.map-group}))

(defn append-map-collection-items! [pending: ^[dynamic]Tx-Data, data: Tx-Data, db: DB]
  (when (not (= data.v.kind .Vector))
    (return))
  (let [entity (tx-entity-ref-from-data data)
        ref-attr (schema-ref-target? db data.a)]
    (for [item index data.v.items]
      (if (and ref-attr (lookup-ref-vector-value? item))
        (arr.push! pending^ (tx-data-with-map-group (tx-add-value-lookup-from-entity-data entity data.a item.items[0].text item.items[1]) data.map-group))
        (if (and ref-attr (= item.kind .Map))
          (arr.push! pending^ (tx-data-with-map-group (tx-add-nested-map-from-entity-data entity data.a item (fmt.tprintf "vev_tx_map_%d" (+ (count pending^) index))) data.map-group))
          (arr.push! pending^ (tx-data-with-map-group (tx-add-from-entity-data entity data.a item) data.map-group)))))))

(defn should-split-map-collection? [db: DB, data: Tx-Data] -> bool
  (when (not (and data.from-map-collection
                  (= data.op ":db/add")
                  (= data.v.kind .Vector)))
    (return false))
  (if (reverse-attr? data.a)
    (let [schema-attr (forward-attr-for-reverse data.a)]
      (defer (delete schema-attr))
      (let [tuple-attrs (schema-tuple-attrs db schema-attr)]
        (defer (delete tuple-attrs))
        (when (> (count tuple-attrs) 0)
          (return false)))
      (return (not (schema-cardinality-one? db schema-attr)))))
  (let [tuple-attrs (schema-tuple-attrs db data.a)]
    (defer (delete tuple-attrs))
    (when (> (count tuple-attrs) 0)
      (return false)))
  (not (schema-cardinality-one? db data.a)))

(defn tx-data-op-known? [op: string] -> bool
  (or (= op ":db/add")
      (= op ":db/retract")
      (= op ":db/retractAttr")
      (= op ":db/retractEntity")
      (= op ":db.fn/cas")
      (= op ":db/cas")))

(defn tx-data-op-needs-attr? [op: string] -> bool
  (not (= op ":db/retractEntity")))

(defn attr-name-valid? [attr: string] -> bool
  (and (strings.has_prefix attr ":")
       (> (count attr) 1)))

(defn validate-tx-data-item [data: Tx-Data] -> [ok: bool, error: string]
  (when (not (tx-data-op-known? data.op))
    (return false "unknown tx op"))
  (when (and data.has-tempid
             (not (= data.op ":db/add")))
    (return false "tempids not allowed outside add"))
  (when (and (tx-data-op-needs-attr? data.op)
             (not (attr-name-valid? data.a)))
    (return false "bad entity attribute"))
  (when (and data.has-lookup-ref
             (not (attr-name-valid? data.lookup-attr)))
    (return false "bad lookup attribute"))
  (when (and data.has-expected-lookup-ref
             (not (attr-name-valid? data.expected-lookup-attr)))
    (return false "bad lookup attribute"))
  (when (and data.has-value-lookup-ref
             (not (attr-name-valid? data.value-lookup-attr)))
    (return false "bad lookup attribute"))
  (return true ""))

(defn tx-data-modifies-validation-schema? [data: Tx-Data] -> bool
  (or (= data.a ":db/ident")
      (= data.a ":db/valueType")
      (= data.a ":db/cardinality")
      (= data.a ":db/unique")
      (= data.a ":db/tupleAttrs")
      (= data.a ":db/index")
      (= data.a ":db/isComponent")))

(defn direct-tx-data-item? [db: DB, data: Tx-Data] -> bool
  (when (not (or (= data.op ":db/add")
                 (= data.op ":db/retract")))
    (return false))
  (when (or data.has-tempid
            data.has-lookup-ref
            data.has-ident
            data.has-expected-lookup-ref
            data.has-value-tempid
            data.has-value-lookup-ref
            data.has-nested-map
            data.from-map-collection
            (tx-data-modifies-validation-schema? data)
            (current-tx-value? data.v)
            (ref-string-value? db data.a data.v)
            (ref-negative-int-value? db data.a data.v)
            (schema-unique? db data.a)
            (reverse-attr? data.a))
    (return false))
  true)

(defn direct-tx-data? [db: DB, tx-data: []Tx-Data] -> bool
  (when (db-has-tuple-schema? db)
    (return false))
  (for [data tx-data]
    (when (not (direct-tx-data-item? db data))
      (return false)))
  true)

(defn resolve-direct-tx-data-for-tx [db: DB, tx-data: []Tx-Data] -> Resolved-Tx
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)]
    (for [data tx-data]
      (let [[shape-ok shape-error] (validate-tx-data-item data)]
        (when (not shape-ok)
          (return (Resolved-Tx {ok: false
                                error: shape-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids}))))
      (let [[value value-ok value-error] (resolve-tx-value db data.a data.v)]
        (when (not value-ok)
          (return (Resolved-Tx {ok: false
                                error: value-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (if (= data.op ":db/retract")
          (arr.push! resolved-ops (tx-retract data.e data.a value))
          (arr.push! resolved-ops (tx-add data.e data.a value)))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn resolve-tx-data-for-tx [db: DB, tx-data: []Tx-Data, tx: u64] -> Resolved-Tx
  (when (direct-tx-data? db tx-data)
    (return (resolve-direct-tx-data-for-tx db tx-data)))
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)
        pending (arr.into [dynamic]Tx-Data tx-data)
        next-e (next-entity-id (slice db.datoms 0))
        current-tx-e tx
        current-tx-reserved false
        data-index 0]
    (defer (delete pending))
    (for [data pending]
      (when (and (not data.has-tempid)
                 (not data.has-lookup-ref)
                 (not data.has-ident)
                 (>= data.e next-e))
        (set! next-e (+ data.e 1))))
    (while (< data-index (count pending))
      (let [data pending[data-index]
            current-db (db-with-resolved-ops db (slice resolved-ops 0))
            e data.e
            skip-data false]
        (set! data-index (+ data-index 1))
        (let [[shape-ok shape-error] (validate-tx-data-item data)]
          (when (not shape-ok)
            (return (Resolved-Tx {ok: false
                                  error: shape-error
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids}))))
        (when data.has-tempid
          (if (current-tx-tempid? data.tempid)
            (do
              (when (not current-tx-reserved)
                (set! current-tx-reserved true))
              (set! e current-tx-e)
              (ensure-tempid! (addr resolved-tempids) data.tempid current-tx-e)
              (when (current-tx-upsert-conflict? current-db data current-tx-e)
                (return (Resolved-Tx {ok: false
                                      error: "conflicting upsert"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))
              (when (= data.op ":db/add")
                (arr.push! resolved-meta (Tx-Meta {a: data.a v: data.v}))))
          (let [[existing ok] (tempid-lookup (slice resolved-tempids 0) data.tempid)]
            (if ok
              (let [[target target-ok _] (tempid-existing-upsert-target current-db data existing)]
                (if target-ok
                  (if (entity-exists? db existing)
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids}))
                    (do
                      (remap-resolved-tempid-entity! (addr resolved-ops) (addr resolved-tempids) existing target)
                      (set! e target)))
                  (set! e existing)))
              (do
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db (slice pending 0) data.tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (set! e upsert-e)
                    (do
                      (set! e next-e)
                      (set! next-e (+ next-e 1)))))
                (arr.push! resolved-tempids (Tempid {tempid: data.tempid e: e})))))))
        (when data.has-lookup-ref
          (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked current-db data.lookup-attr data.lookup-value)]
            (if lookup-ok
              (set! e lookup-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: lookup-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
                (if (= lookup-error "lookup ref not found")
                  (set! skip-data true)
                  (return (Resolved-Tx {ok: false
                                        error: lookup-error
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids})))))))
        (when skip-data
          (continue))
        (when (should-split-map-collection? current-db data)
          (append-map-collection-items! (addr pending) data current-db)
          (continue))
        (when (and (reverse-attr? data.a)
                   (not (schema-ref-target? current-db data.a)))
          (return (Resolved-Tx {ok: false
                                error: "reverse attribute requires ref schema"
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (when data.has-ident
          (let [[ident-e ident-ok] (schema-entity-for-attr current-db data.ident)]
            (if ident-ok
              (set! e ident-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: "ident not found"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
                (set! skip-data true)))))
        (when skip-data
          (continue))
        (when data.has-nested-map
          (if (schema-ref-target? current-db data.a)
            (let [[nested-entity nested-ok nested-error] (nested-entity-ref-data data.nested-map data.nested-tempid)]
              (when (not nested-ok)
                (return (Resolved-Tx {ok: false
                                      error: nested-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))
              (let [[children-ok children-error] (append-nested-map-tx! (addr pending) nested-entity data.nested-map data.nested-tempid)]
                (when (not children-ok)
                  (return (Resolved-Tx {ok: false
                                        error: children-error
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids}))))
              (set! data.has-nested-map false)
              (let [nested-assigned false]
                (when nested-entity.has-tempid
                  (set! data.has-value-tempid true)
                  (set! data.value-tempid nested-entity.tempid)
                  (set! nested-assigned true))
                (when (and (not nested-assigned) nested-entity.has-lookup-ref)
                  (set! data.has-value-lookup-ref true)
                  (set! data.value-lookup-attr nested-entity.lookup-attr)
                  (set! data.value-lookup-value nested-entity.lookup-value)
                  (set! nested-assigned true))
                (when (and (not nested-assigned) nested-entity.has-ident)
                  (set! data.v (value-keyword nested-entity.ident))
                  (set! nested-assigned true))
                (when (not nested-assigned)
                  (set! data.v (value-entity nested-entity.e)))))
            (do
              (set! data.v data.nested-map)
              (set! data.has-nested-map false))))
        (when (or (= data.op ":db/retract")
                  (= data.op ":db/retractAttr"))
          (let [tuple-attrs (schema-tuple-attrs current-db data.a) :defer]
            (when (> (count tuple-attrs) 0)
              (return (Resolved-Tx {ok: false
                                    error: "cannot modify tuple attrs directly"
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))))
        (when (and (= data.op ":db/add")
                   (not data.has-tempid)
                   (not data.has-lookup-ref)
                   (not data.has-ident)
                   (schema-unique-identity? current-db data.a))
          (let [[identity-value identity-ok _] (resolve-tx-data-value current-db data)]
            (when identity-ok
              (let [[identity-e identity-found] (resolve-lookup-ref current-db data.a identity-value)]
                (when (and identity-found (not (= identity-e e)))
                  (return (Resolved-Tx {ok: false
                                        error: "conflicting upsert"
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids})))))))
        (when (= data.op ":db/retractEntity")
          (append-retract-entity-ops! (addr resolved-ops) current-db e)
          (continue))
        (when (= data.op ":db/retractAttr")
          (append-retract-attr-ops! (addr resolved-ops) current-db e data.a)
          (continue))
        (when (= data.op ":db.fn/cas")
          (let [[expected expected-ok expected-error] (resolve-cas-expected current-db data)]
            (when (not expected-ok)
              (return (Resolved-Tx {ok: false
                                    error: expected-error
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))
            (when (not (cas-expected-matches? current-db e data.a expected))
              (return (Resolved-Tx {ok: false
                                    error: (cas-failed-error current-db e data.a expected)
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))))
        (let [v data.v
              value-ok true
              value-error ""]
          (when (and (not (current-tx-value? v))
                     (not (ref-negative-int-value? current-db data.a v)))
            (let [[resolved resolved-ok resolved-error] (resolve-tx-value current-db data.a data.v)]
              (set! v resolved)
              (set! value-ok resolved-ok)
              (set! value-error resolved-error)))
          (when data.has-value-lookup-ref
            (if (not (schema-ref-target? current-db data.a))
              (set! v (value-lookup-ref-vector data.value-lookup-attr data.value-lookup-value))
              (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked current-db data.value-lookup-attr data.value-lookup-value)]
                (if lookup-ok
                  (set! v (value-entity lookup-e))
                  (if (and (= data.op ":db/retract")
                           (= lookup-error "lookup ref not found"))
                    (set! skip-data true)
                    (return (Resolved-Tx {ok: false
                                          error: lookup-error
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))))))
          (when skip-data
            (continue))
          (when (current-tx-value? v)
            (let [current-tx-tempid v.text]
              (when (not current-tx-reserved)
                (set! current-tx-reserved true))
              (set! v (value-entity current-tx-e))
              (ensure-tempid! (addr resolved-tempids) current-tx-tempid current-tx-e)))
          (when (or data.has-value-tempid
                    (ref-string-value? current-db data.a v)
                    (ref-negative-int-value? current-db data.a v))
            (let [value-tempid data.value-tempid]
              (when (not data.has-value-tempid)
                (set! value-tempid (ref-tempid-value-text v)))
              (if (current-tx-tempid? value-tempid)
                (do
                  (when (not current-tx-reserved)
                    (set! current-tx-reserved true))
                  (set! v (value-entity current-tx-e))
                  (ensure-tempid! (addr resolved-tempids) value-tempid current-tx-e))
              (if (not (tx-data-has-tempid? current-db (slice pending 0) value-tempid))
                (return (Resolved-Tx {ok: false
                                      error: "tempid used only as value"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
              (let [[existing ok] (tempid-lookup (slice resolved-tempids 0) value-tempid)]
              (if ok
                (set! v (value-entity existing))
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db (slice pending 0) value-tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (do
                      (set! v (value-entity upsert-e))
                      (arr.push! resolved-tempids (Tempid {tempid: value-tempid e: upsert-e})))
                    (do
                      (set! v (value-entity next-e))
                      (arr.push! resolved-tempids (Tempid {tempid: value-tempid e: next-e}))
                      (set! next-e (+ next-e 1)))))))))))
          (when (not value-ok)
            (return (Resolved-Tx {ok: false
                                  error: value-error
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids})))
        (if (reverse-attr? data.a)
          (if (= v.kind .Entity)
            (let [forward-attr (forward-attr-for-reverse data.a)]
              (if (= data.op ":db/retract")
                (arr.push! resolved-ops (tx-op-with-map-group (tx-retract v.entity forward-attr (value-entity e)) data.map-group))
                (arr.push! resolved-ops (tx-op-with-map-group (tx-add v.entity forward-attr (value-entity e)) data.map-group))))
            (return (Resolved-Tx {ok: false
                                  error: "reverse ref value must resolve to entity"
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids})))
          (if (= data.op ":db/retract")
            (arr.push! resolved-ops (tx-op-with-map-group (tx-retract e data.a v) data.map-group))
            (let [op (tx-add e data.a v)]
              (when data.has-tempid
                (set! op.tuple-identity true))
              (set! op.map-group data.map-group)
              (arr.push! resolved-ops op)))))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn validate-add-op [db: DB, op: Tx-Op] -> [ok: bool, error: string]
  (when (= op.v.kind .Nil)
    (return false "cannot store nil"))
  (when (and (= op.a ":db/tupleAttrs")
             (not (and (valid-tuple-attr-target? db op.e)
                       (valid-tuple-attrs-value? db op.v))))
    (return false "invalid tuple schema"))
  (when (not op.derived)
    (let [tuple-attrs (schema-tuple-attrs db op.a)]
      (defer (delete tuple-attrs))
      (when (> (count tuple-attrs) 0)
        (return false "cannot modify tuple attrs directly"))))
  (let [[schema-type has-type] (schema-keyword db op.a ":db/valueType")]
    (when (and has-type (not (value-matches-schema-type? op.v schema-type)))
      (return false "schema value type mismatch")))
  (let [[unique has-unique] (schema-keyword db op.a ":db/unique")]
    (when (and has-unique
               (or (= unique ":db.unique/identity")
                   (= unique ":db.unique/value"))
               (unique-conflict? db op))
      (return false "schema unique conflict")))
  (return true ""))

(defn validate-op-entity-ids [op: Tx-Op] -> [ok: bool, error: string]
  (let [[entity-ok entity-error] (validate-entity-id op.e)]
    (when (not entity-ok)
      (return false entity-error)))
  (when (= op.v.kind .Entity)
    (let [[value-ok value-error] (validate-entity-id op.v.entity)]
      (when (not value-ok)
        (return false value-error))))
  (return true ""))

(defn op-modifies-validation-schema? [op: Tx-Op] -> bool
  (or (= op.a ":db/ident")
      (= op.a ":db/valueType")
      (= op.a ":db/cardinality")
      (= op.a ":db/unique")
      (= op.a ":db/tupleAttrs")
      (= op.a ":db/index")
      (= op.a ":db/isComponent")))

(defn ops-require-incremental-validation? [before: DB, ops: []Tx-Op] -> bool
  (for [op ops]
    (when (op-modifies-validation-schema? op)
      (return true))
    (when (and (= op.kind .Add)
               (schema-unique? before op.a))
      (return true)))
  false)

(defn validate-final-schema [scratch-datoms: []Datom] -> [ok: bool, error: string]
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-tuple-schema scratch)]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-ident-values scratch)]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-schema-keyword-values scratch ":db/valueType")]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-schema-keyword-values scratch ":db/cardinality")]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-schema-keyword-values scratch ":db/unique")]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-schema-bool-values scratch ":db/index")]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-schema-bool-values scratch ":db/isComponent")]
    (when (not ok)
      (return false error)))
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [ok error] (validate-component-schema scratch)]
    (when (not ok)
      (return false error)))
  (return true ""))

(defn validate-ops-batch-against-before [before: DB, ops: []Tx-Op] -> [ok: bool, error: string]
  (let [scratch-datoms (clone-datoms before.datoms)]
    (defer (delete scratch-datoms))
    (for [op ops]
      (let [[entity-ok entity-error] (validate-op-entity-ids op)]
        (when (not entity-ok)
          (return false entity-error)))
      (when (= op.kind .Add)
        (let [[ok error] (validate-add-op before op)]
          (when (not ok)
            (return false error))))
      (arr.push! scratch-datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (validate-final-schema (slice scratch-datoms 0))))

(defn validate-tuple-schema [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/valueType" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (= datom.v.text ":db.type/tuple"))
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when attr-ok
              (let [tuple-attrs (schema-tuple-attrs db attr)]
                (defer (delete tuple-attrs))
                (when (= (count tuple-attrs) 0)
                  (return false "invalid tuple schema")))))))))
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when attr-ok
              (when (not (valid-tuple-attr-target? db datom.e))
                (return false "invalid tuple schema"))
              (when (not (valid-tuple-attrs-value? db datom.v))
                (return false "invalid tuple schema"))
              (let [[value-type has-value-type] (schema-keyword db attr ":db/valueType")]
                (when (and has-value-type (not (= value-type ":db.type/tuple")))
                  (return false "invalid tuple schema")))))))))
  (return true ""))

(defn validate-schema-bool-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Bool)))
          (return false "schema boolean value must be boolean")))))
  (return true ""))

(defn validate-ident-values [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/ident" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Keyword)))
          (return false ":db/ident value must be keyword")))))
  (return true ""))

(defn valid-schema-keyword-value? [schema-attr: string, value: string] -> bool
  (cond
    (= schema-attr ":db/valueType")
      (or (= value ":db.type/string")
          (= value ":db.type/long")
          (= value ":db.type/boolean")
          (= value ":db.type/ref")
          (= value ":db.type/keyword")
          (= value ":db.type/symbol")
          (= value ":db.type/tuple"))
    (= schema-attr ":db/cardinality")
      (or (= value ":db.cardinality/one")
          (= value ":db.cardinality/many"))
    (= schema-attr ":db/unique")
      (or (= value ":db.unique/identity")
          (= value ":db.unique/value"))
    :else true))

(defn validate-schema-keyword-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 schema-attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (or (not (= datom.v.kind .Keyword))
                       (not (valid-schema-keyword-value? schema-attr datom.v.text))))
          (return false "invalid schema keyword value")))))
  (return true ""))

(defn validate-component-schema [db: DB] -> [ok: bool, error: string]
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 ":db/isComponent" (Value {}))
        high (upper-bound-index db indexes "aevt" 0 ":db/isComponent" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Bool)
                   datom.v.bool-value)
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when (and attr-ok (not (schema-ref? db attr)))
              (return false "invalid component schema")))))))
  (return true ""))

(defn validate-ops [before: DB, ops: []Tx-Op] -> [ok: bool, error: string]
  (when (not (ops-require-incremental-validation? before ops))
    (return (validate-ops-batch-against-before before ops)))
  (let [scratch-datoms (clone-datoms before.datoms)]
    (defer (delete scratch-datoms))
    (for [op ops]
      (let [[entity-ok entity-error] (validate-op-entity-ids op)]
        (when (not entity-ok)
          (return false entity-error)))
      (when (= op.kind .Add)
        (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
              scratch (build-db scratch-owned)
              [ok error] (validate-add-op scratch op)]
          (when (not ok)
            (return false error))))
      (arr.push! scratch-datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (validate-final-schema (slice scratch-datoms 0))))

(defn failed-tx-report [db: DB, error: string] -> Tx-Report
  (Tx-Report {ok: false
              error: error
              db-before: db
              db-after: db
              tx-data: (make [dynamic]Datom)
              tx: 0
              tx-meta: (make [dynamic]Tx-Meta)
              tempids: (make [dynamic]Tempid)}))

(defn reset-conn-with-meta [conn: ^Conn, next-db: DB, tx-meta: []Tx-Meta] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        after (build-db (clone-datom-slice (slice next-db.datoms 0)))
        diff (db-diff before after)
        tx conn^.next-tx
        tx-data (make [dynamic]Datom 0 (+ (count diff.only-left) (count diff.only-right)))]
    (for [datom diff.only-left]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: false})))
    (for [datom diff.only-right]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: true})))
    (delete diff.only-left)
    (delete diff.only-right)
    (delete diff.both)
    (set! conn^.db after)
    (set! conn^.next-tx (+ conn^.next-tx 1))
    (let [report (Tx-Report {ok: true
                             error: ""
                             db-before: before
                             db-after: after
                             tx-data: tx-data
                             tx: tx
                             tx-meta: (clone-tx-meta tx-meta)
                             tempids: (make [dynamic]Tempid)})]
      (notify-listeners! conn report)
      report)))

(defn reset-conn [conn: ^Conn, next-db: DB] -> Tx-Report
  (reset-conn-with-meta conn next-db ([]Tx-Meta [])))

(defn tx-fn-ok [tx-data: []Tx-Data] -> Tx-Fn-Result
  (let [owned (tx-data-slice-owned tx-data)]
    (Tx-Fn-Result {ok: true
                   error: ""
                   tx-data: owned})))

(defn tx-fn-error [error: string] -> Tx-Fn-Result
  (let [empty (make [dynamic]Tx-Data)]
    (Tx-Fn-Result {ok: false
                   error: error
                   tx-data: empty})))

(defn tx-fn-string [ident: string, f: fn [db: DB, arg: string] -> Tx-Fn-Result] -> Tx-Fn-String
  (Tx-Fn-String {ident: ident f: f}))

(defn tx-fn-values [ident: string, f: fn [db: DB, args: []Value] -> Tx-Fn-Result] -> Tx-Fn-String
  (Tx-Fn-String {ident: ident has-values-fn: true values-f: f}))

(defn tx-fn-string-index [registry: []Tx-Fn-String, ident: string] -> [index: int, ok: bool]
  (for [entry index registry]
    (when (= entry.ident ident)
      (return index true)))
  (return 0 false))

(defn current-log-attr-exists? [datoms: []Datom, entity: u64, attr: string] -> bool
  (for [datom index datoms]
    (when (and (= datom.e entity)
               (= datom.a attr)
               (datom-current-in-log? datoms index))
      (return true)))
  false)

(defn current-db-attr-exists? [db: DB, entity: u64, attr: string] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn entity-attr-key [entity: u64, attr: string] -> string
  (fmt.tprintf "%d:%d:%s" entity (count attr) attr))

(defn entity-attr-seen? [seen: (ptr (map string bool)), entity: u64, attr: string] -> bool
  (let [key (entity-attr-key entity attr)
        [_ found] (mmap.get seen^ key)]
    found))

(defn mark-entity-attr-seen! [seen: (ptr (map string bool)), entity: u64, attr: string]
  (let [key (entity-attr-key entity attr)]
    (mmap.assoc! seen^ key true)))

(defn append-cardinality-one-retractions! [before: DB, seen-ea: (ptr (map string bool)), after-datoms: ^[dynamic]Datom, tx-data: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (when (not (= op.kind .Add))
    (return))
  (when (not (or (current-db-attr-exists? before op.e op.a)
                 (entity-attr-seen? seen-ea op.e op.a)))
    (return))
  (let [current (build-db (clone-datoms after-datoms^))]
    (when (not (tx-op-cardinality-one? current op))
      (return))
    (let [indexes (slice current.eavt 0)
          low (lower-bound-index current indexes "eavt-ea" op.e op.a (Value {}))
          high (upper-bound-index current indexes "eavt-ea" op.e op.a (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom current.datoms[datom-index]]
          (when (and (datom-current-at? current datom-index)
                     (not (value-equal? datom.v op.v)))
            (let [retract (Datom {e: datom.e
                                  a: datom.a
                                  v: datom.v
                                  tx: tx
                             added: false})]
              (arr.push! after-datoms^ retract)
              (arr.push! tx-data^ retract))))))))

(defn current-op-value-exists-in-log? [datoms: []Datom, op: Tx-Op] -> bool
  (for [datom index datoms]
    (when (and (= datom.e op.e)
               (= datom.a op.a)
               (value-equal? datom.v op.v)
               (datom-current-in-log? datoms index))
      (return true)))
  false)

(defn transact-ops-with-tempids [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta, tempids: [dynamic]Tempid] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        expanded-ops (expand-tuple-ops before ops)
        after-datoms (clone-datoms conn^.db.datoms)
        tx-data (make [dynamic]Datom 0 (count expanded-ops))
        seen-ea (make (map string bool))
        tx conn^.next-tx]
    (defer (delete seen-ea))
    (let [[valid error] (validate-ops before (slice expanded-ops 0))]
      (when (not valid)
        (delete expanded-ops)
        (delete tempids)
        (return (failed-tx-report before error))))
    (for [op expanded-ops]
      (let [apply-op (or (= op.kind .Add)
                         (current-op-value-exists-in-log? (slice after-datoms 0) op))]
        (when apply-op
          (append-cardinality-one-retractions! before (addr seen-ea) (addr after-datoms) (addr tx-data) op tx)
          (let [datom (Datom {e: op.e
                              a: op.a
                              v: op.v
                              tx: tx
                              added: (= op.kind .Add)})]
            (arr.push! after-datoms datom)
            (arr.push! tx-data datom)))
        (when (= op.kind .Add)
          (mark-entity-attr-seen! (addr seen-ea) op.e op.a))))
    (delete expanded-ops)
    (let [after (build-db after-datoms)]
      (set! conn^.db after)
      (set! conn^.next-tx (+ conn^.next-tx 1))
      (let [report-tempids (arr.into [dynamic]Tempid (slice tempids 0))]
        (delete tempids)
        (let [[_ has-current-tx] (tempid-lookup (slice report-tempids 0) ":db/current-tx")]
        (when (not has-current-tx)
          (arr.push! report-tempids (Tempid {tempid: ":db/current-tx" e: tx}))))
        (let [report (Tx-Report {db-before: before
                                 db-after: after
                                 ok: true
                                 error: ""
                                 tx-data: tx-data
                                 tx: tx
                                 tx-meta: (clone-tx-meta tx-meta)
                                 tempids: report-tempids})]
          (notify-listeners! conn report)
          report)))))

(defn transact-with-meta [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta] -> Tx-Report
  (transact-ops-with-tempids conn ops tx-meta (make [dynamic]Tempid)))

(defn transact-ops [conn: ^Conn, ops: []Tx-Op] -> Tx-Report
  (transact-with-meta conn ops ([]Tx-Meta [])))

(defn transact-tx-data [conn: ^Conn, tx-data: []Tx-Data] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        resolved (resolve-tx-data-for-tx before tx-data conn^.next-tx)]
    (when (not resolved.ok)
      (delete resolved.ops)
      (delete resolved.tx-meta)
      (delete resolved.tempids)
      (return (failed-tx-report before resolved.error)))
    (let [report (transact-ops-with-tempids conn (slice resolved.ops 0) (slice resolved.tx-meta 0) resolved.tempids)]
      (delete resolved.ops)
      (delete resolved.tx-meta)
      report)))

(defn with-tx-data [db: DB, tx-data: []Tx-Data] -> Tx-Report
  (let [conn (conn-from-db db)]
    (transact-tx-data (addr conn) tx-data)))

(defn db-with-tx-data [db: DB, tx-data: []Tx-Data] -> DB
  (let [report (with-tx-data db tx-data)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn with-ops [db: DB, ops: []Tx-Op] -> Tx-Report
  (let [conn (conn-from-db db)]
    (transact-ops (addr conn) ops)))

(defn db-with-ops [db: DB, ops: []Tx-Op] -> DB
  (let [report (with-ops db ops)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn db-with-datoms [db: DB, datoms: []Datom] -> DB
  (let [out (clone-datoms db.datoms)]
    (for [datom datoms]
      (arr.push! out datom))
    (build-db out)))

(defn next-tx-after-datoms [current-next-tx: u64, datoms: []Datom] -> u64
  (let [candidate (+ (max-tx datoms) 1)]
    (if (> candidate current-next-tx)
      candidate
      current-next-tx)))

(defn report-tx-for-datoms [fallback: u64, datoms: []Datom] -> u64
  (let [tx (max-tx datoms)]
    (if (> tx 0) tx fallback)))

(defn with-datoms [db: DB, datoms: []Datom] -> Tx-Report
  (let [before (build-db (clone-datoms db.datoms))
        out (clone-datoms db.datoms)]
    (for [datom datoms]
      (arr.push! out datom))
    (let [after (build-db out)
          tx-data (arr.into [dynamic]Datom datoms)]
      (Tx-Report {ok: true
                  error: ""
                  db-before: before
                  db-after: after
                  tx-data: tx-data
                  tx: (report-tx-for-datoms (+ (max-tx (slice db.datoms 0)) 1) datoms)
                  tx-meta: (make [dynamic]Tx-Meta)
                  tempids: (make [dynamic]Tempid)}))))

(defn transact-datoms [conn: ^Conn, datoms: []Datom] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        out (clone-datoms conn^.db.datoms)]
    (for [datom datoms]
      (arr.push! out datom))
    (let [after (build-db out)
          tx-data (arr.into [dynamic]Datom datoms)
          tx (report-tx-for-datoms conn^.next-tx datoms)]
      (set! conn^.db after)
      (set! conn^.next-tx (next-tx-after-datoms conn^.next-tx (slice conn^.db.datoms 0)))
      (let [report (Tx-Report {ok: true
                               error: ""
                               db-before: before
                               db-after: after
                               tx-data: tx-data
                               tx: tx
                               tx-meta: (make [dynamic]Tx-Meta)
                               tempids: (make [dynamic]Tempid)})]
        (notify-listeners! conn report)
        report))))

(defn delete-owned-db [db: DB]
  (delete db.current)
  (delete db.eavt)
  (delete db.aevt)
  (delete db.avet)
  (delete db.vaet)
  (delete db.datoms))

(defn serializable [db: DB] -> Serializable-DB
  (Serializable-DB {datoms: (clone-datom-slice (slice db.datoms 0))}))

(defn from-serializable [data: Serializable-DB] -> DB
  (init-db (slice data.datoms 0)))

(defn delete-serializable [data: Serializable-DB]
  (delete data.datoms))

(defn append-resolved-tx! [ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, resolved: Resolved-Tx]
  (for [op resolved.ops]
    (arr.push! ops^ op))
  (for [meta resolved.tx-meta]
    (arr.push! tx-meta^ meta))
  (for [tempid resolved.tempids]
    (arr.push! tempids^ tempid)))

(defn resolve-tx-segment! [base: DB, tx: u64, ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, segment: ^[dynamic]Tx-Data] -> [ok: bool, error: string]
  (when (= (count segment^) 0)
    (return true ""))
  (let [current-db (db-with-resolved-ops base (slice ops^ 0))
        resolved (resolve-tx-data-for-tx current-db (slice segment^ 0) tx)]
    (delete-owned-db current-db)
    (when (not resolved.ok)
      (delete resolved.ops)
      (delete resolved.tx-meta)
      (delete resolved.tempids)
      (return false resolved.error))
    (append-resolved-tx! ops tx-meta tempids resolved)
    (delete resolved.ops)
    (delete resolved.tx-meta)
    (delete resolved.tempids)
    (delete segment^)
    (set! segment^ (make [dynamic]Tx-Data))
    (return true "")))

(defn failed-registered-tx [before: DB, ops: [dynamic]Tx-Op, tx-meta: [dynamic]Tx-Meta, tempids: [dynamic]Tempid, segment: [dynamic]Tx-Data, error: string] -> Tx-Report
  (delete ops)
  (delete tx-meta)
  (delete tempids)
  (delete segment)
  (failed-tx-report before error))

(defn call-registered-tx-fn [entry: Tx-Fn-String, db: DB, data: Tx-Data] -> Tx-Fn-Result
  (when (= data.v.kind .Vector)
    (when entry.has-values-fn
      (return (entry.values-f db (slice data.v.items 0))))
    (when (and (= (count data.v.items) 1)
               (= data.v.items[0].kind .String))
      (return (entry.f db data.v.items[0].text)))
    (return (tx-fn-error "transaction fn expects one string argument")))
  (when entry.has-values-fn
    (return (entry.values-f db ([]Value [data.v]))))
  (when (= data.v.kind .String)
    (return (entry.f db data.v.text)))
  (tx-fn-error "transaction fn expects one string argument"))

(defn transact-tx-data-with-string-fns [conn: ^Conn, tx-data: []Tx-Data, registry: []Tx-Fn-String] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        tx conn^.next-tx
        ops (make [dynamic]Tx-Op)
        tx-meta (make [dynamic]Tx-Meta)
        tempids (make [dynamic]Tempid)
        segment (make [dynamic]Tx-Data)]
    (for [data tx-data]
      (if (= data.op ":db.fn/call-ident")
        (do
          (let [[segment-ok segment-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
            (when (not segment-ok)
              (return (failed-registered-tx before ops tx-meta tempids segment segment-error))))
          (let [current-db (db-with-resolved-ops before (slice ops 0))
                [_ fn-entity-ok] (schema-entity-for-attr current-db data.ident)
                [fn-index fn-ok] (tx-fn-string-index registry data.ident)]
            (when (not fn-entity-ok)
              (delete-owned-db current-db)
              (return (failed-registered-tx before ops tx-meta tempids segment "transaction fn not found")))
            (when (not fn-ok)
              (delete-owned-db current-db)
              (return (failed-registered-tx before ops tx-meta tempids segment "transaction fn not registered")))
            (let [result (call-registered-tx-fn registry[fn-index] current-db data)]
              (delete-owned-db current-db)
              (when (not result.ok)
                (delete result.tx-data)
                (return (failed-registered-tx before ops tx-meta tempids segment result.error)))
              (let [[result-ok result-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr result.tx-data))]
                (delete result.tx-data)
                (when (not result-ok)
                  (return (failed-registered-tx before ops tx-meta tempids segment result-error)))))))
        (arr.push! segment data)))
    (let [[tail-ok tail-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
      (when (not tail-ok)
        (return (failed-registered-tx before ops tx-meta tempids segment tail-error))))
    (delete segment)
    (let [report (transact-ops-with-tempids conn (slice ops 0) (slice tx-meta 0) tempids)]
      (delete ops)
      (delete tx-meta)
      report)))

(defn transact-fn [conn: ^Conn, f: (fn [db: DB] -> Tx-Fn-Result)] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        result (f before)]
    (defer (delete result.tx-data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (transact-tx-data conn (slice result.tx-data 0))))

(defn transact-fn-string [conn: ^Conn, f: (fn [db: DB, arg: string] -> Tx-Fn-Result), arg: string] -> Tx-Report
  (let [before (build-db (clone-datoms conn^.db.datoms))
        result (f before arg)]
    (defer (delete result.tx-data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (transact-tx-data conn (slice result.tx-data 0))))

(defn match-entity-term? [db: DB, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .Var)
    (let [[existing exists] (binding-lookup binding^ term.name)]
      (if exists
        (return (entity-value-equal? db existing actual))
        (do
          (binding-store! binding term.name actual)
          (return true)))))
  (let [[resolved resolved-ok] (resolve-entity-term db term binding^)]
    (when resolved-ok
      (return (value-equal? resolved actual))))
  (match-term? term actual binding))

(defn ref-entity-literal [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool]
  (let [[schema-type has-type] (schema-keyword db attr ":db/valueType")]
    (when (and has-type (= schema-type ":db.type/ref"))
      (if (= value.kind .Int)
        (return (value-entity (u64 value.int-value)) true)
        (when (= value.kind .Keyword)
          (let [[entity ok] (schema-entity-for-attr db value.text)]
            (when ok
              (return (value-entity entity) true)))))))
  (return value false))

(defn match-clause-value-term? [db: DB, attr: string, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
      (return (and lookup-ok (value-equal? (value-entity entity) actual)))))
  (when (= term.kind .Var)
    (let [[existing exists] (binding-lookup binding^ term.name)]
      (if exists
        (return (entity-value-equal? db existing actual))
        (do
          (binding-store! binding term.name actual)
          (return true)))))
  (when (= term.kind .Value)
    (let [[resolved ok] (ref-entity-literal db attr term.value)]
      (when ok
        (return (value-equal? resolved actual)))))
  (match-term? term actual binding))

(defn datom-tx-value [datom: Datom] -> Value
  (value-entity datom.tx))

(defn datom-op-value [datom: Datom] -> Value
  (if datom.added
    (value-keyword ":db/add")
    (value-keyword ":db/retract")))

(defn datom-value [datom: Datom] -> Value
  (value-map
    ([]Value [(value-keyword ":e") (value-entity datom.e)
              (value-keyword ":a") (value-keyword datom.a)
              (value-keyword ":v") datom.v
              (value-keyword ":tx") (datom-tx-value datom)
              (value-keyword ":op") (datom-op-value datom)
              (value-keyword ":added") (value-bool datom.added)])))

(defn datoms-value [datoms: []Datom] -> Value
  (let [items (make [dynamic]Value 0 (count datoms))]
    (defer (delete items))
    (for [datom datoms]
      (arr.push! items (datom-value datom)))
    (value-vector (slice items 0))))

(defn tx-meta-value [meta: Tx-Meta] -> Value
  (value-map
    ([]Value [(value-keyword ":a") (value-keyword meta.a)
              (value-keyword ":v") meta.v])))

(defn tx-metas-value [metas: []Tx-Meta] -> Value
  (let [items (make [dynamic]Value 0 (count metas))]
    (defer (delete items))
    (for [meta metas]
      (arr.push! items (tx-meta-value meta)))
    (value-vector (slice items 0))))

(defn tempid-key-value [tempid: string] -> Value
  (if (strings.has_prefix tempid ":")
    (value-keyword tempid)
    (value-string tempid)))

(defn tempids-value [tempids: []Tempid] -> Value
  (let [items (make [dynamic]Value 0 (* (count tempids) 2))]
    (defer (delete items))
    (for [tempid tempids]
      (arr.push! items (tempid-key-value tempid.tempid))
      (arr.push! items (value-entity tempid.e)))
    (value-map (slice items 0))))

(defn tx-report-value [report: Tx-Report] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool report.ok)
              (value-keyword ":error") (value-string report.error)
              (value-keyword ":tx") (if report.ok (value-entity report.tx) (value-nil))
              (value-keyword ":tx-data") (datoms-value (slice report.tx-data 0))
              (value-keyword ":tempids") (tempids-value (slice report.tempids 0))
              (value-keyword ":tx-meta") (tx-metas-value (slice report.tx-meta 0))])))

(defn omitted-term? [term: Term] -> bool
  (and (= term.kind .Value)
       (= term.value.kind .Nil)))

(defn match-optional-datom-term? [term: Term, actual: Value, binding: ^Binding] -> bool
  (if (omitted-term? term)
    true
    (match-term? term actual binding)))

(defn datom-tx-op-terms-match? [datom: Datom, clause: Clause, binding: ^Binding] -> bool
  (and (match-optional-datom-term? clause.tx-term (datom-tx-value datom) binding)
       (match-optional-datom-term? clause.op-term (datom-op-value datom) binding)))

(defn datom-clause-matches? [db: DB, datom: Datom, clause: Clause, binding: ^Binding] -> bool
  (when (and (= clause.a.kind .Value)
             (= clause.a.value.kind .Keyword)
             (reverse-attr? clause.a.value.text))
    (when (not (= datom.v.kind .Entity))
      (return false))
    (let [forward-attr (forward-attr-for-reverse clause.a.value.text) :defer]
      (return
        (and (= datom.a forward-attr)
             (match-entity-term? db clause.e (value-entity datom.v.entity) binding)
             (match-entity-term? db clause.v (value-entity datom.e) binding)
             (datom-tx-op-terms-match? datom clause binding)))))
  (and (match-entity-term? db clause.e (value-entity datom.e) binding)
       (match-term? clause.a (value-keyword datom.a) binding)
       (match-clause-value-term? db datom.a clause.v datom.v binding)
       (datom-tx-op-terms-match? datom clause binding)))

(defn candidate-index-matches? [datom: Datom,
                                e-value: Value, e-ok: bool,
                                a-value: Value, a-ok: bool,
                                v-value: Value, v-ok: bool] -> bool
  (when e-ok
    (when (not (and (= e-value.kind .Entity)
                    (= datom.e e-value.entity)))
      (return false)))
  (when a-ok
    (when (not (and (= a-value.kind .Keyword)
                    (= datom.a a-value.text)))
      (return false)))
  (when v-ok
    (when (not (value-equal? datom.v v-value))
      (return false)))
  true)

(defn clause-selectivity-score [clause: Clause, binding: Binding] -> int
  (let [[ignored-e e-bound] (resolve-term clause.e binding)
        e-ok (or (= clause.e.kind .LookupRef) e-bound)
        [a-value a-ok] (resolve-term clause.a binding)
        [_ v-ok] (resolve-term clause.v binding)]
    (when (and a-ok (not (= a-value.kind .Keyword)))
      (return 0))
    (if (and e-ok a-ok)
      1
      (if (and a-ok v-ok)
        2
        (if e-ok
          3
          (if a-ok
            4
            (if v-ok 5 6)))))))

(defn best-clause-index [clauses: []Clause, binding: Binding] -> int
  (let [best 0
        best-score (clause-selectivity-score clauses[0] binding)]
    (for [i (arr.range 1 (count clauses))]
      (let [score (clause-selectivity-score clauses[i] binding)]
        (when (< score best-score)
          (set! best i)
          (set! best-score score))))
    best))

(defn relation-source-row-matches? [clause: Clause, row: Value, binding: ^Binding] -> bool
  (when (and (= clause.source-width 1)
             (not (= row.kind .Vector)))
    (return (match-term? clause.e row binding)))
  (when (not (= row.kind .Vector))
    (return false))
  (when (not (= (count row.items) clause.source-width))
    (return false))
  (when (= clause.source-width 1)
    (return (match-term? clause.e row.items[0] binding)))
  (when (= clause.source-width 2)
    (return
      (and (match-term? clause.e row.items[0] binding)
           (match-term? clause.a row.items[1] binding))))
  (when (not (and (match-term? clause.e row.items[0] binding)
                  (match-term? clause.a row.items[1] binding)
                  (match-term? clause.v row.items[2] binding)))
    (return false))
  (when (= clause.source-width 3)
    (return true))
  (when (not (match-term? clause.tx-term row.items[3] binding))
    (return false))
  (when (= clause.source-width 4)
    (return true))
  (match-term? clause.op-term row.items[4] binding))

(defn bindings-after-relation-source-clause [clause: Clause, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        [source source-ok] (binding-lookup binding clause.source)]
    (when (not (and source-ok (= source.kind .Vector)))
      (return out))
    (for [row source.items]
      (let [next (clone-binding binding)]
        (when (relation-source-row-matches? clause row (addr next))
          (arr.push! out next))))
    out))

(defn source-db-lookup [db: DB, sources: []DB-Source, name: string] -> [source-db: DB, ok: bool]
  (when (= name "$")
    (return db true))
  (for [source sources]
    (when (= source.name name)
      (return source.db true)))
  (return db false))

(defn unsourced-clause [clause: Clause] -> Clause
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           tx-term: (term-wildcard)
           op-term: (term-wildcard)
           source: ""
           has-source: false
           source-width: 0}))

(defn append-bindings-after-clause! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding]
  (when clause-value.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause-value binding)]
      (defer (delete source-bindings))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (let [candidates (clause-candidate-indexes db clause-value binding)]
    (defer (delete candidates))
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [next (clone-binding binding)]
            (when (datom-clause-matches? db datom clause-value (addr next))
              (arr.push! out^ next))))))))

(defn append-bindings-after-clause-profiled! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding, stats: ^Query-Stats]
  (set! stats^.clauses (+ stats^.clauses 1))
  (when clause-value.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause-value binding)]
      (defer (delete source-bindings))
      (set! stats^.clause-candidates (+ stats^.clause-candidates (count source-bindings)))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (let [candidates (clause-candidate-indexes db clause-value binding)]
    (defer (delete candidates))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (count candidates)))
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [next (clone-binding binding)]
            (when (datom-clause-matches? db datom clause-value (addr next))
              (arr.push! out^ next))))))))

(defn append-bindings-after-clause-with-sources! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding]
  (when clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause! out source-db (unsourced-clause clause-value) binding)
        (return))))
  (append-bindings-after-clause! out db clause-value binding))

(defn append-bindings-after-clause-with-sources-profiled! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding, stats: ^Query-Stats]
  (when clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause-profiled! out source-db (unsourced-clause clause-value) binding stats)
        (return))))
  (append-bindings-after-clause-profiled! out db clause-value binding stats))

(defn clause-candidate-indexes [db: DB, clause: Clause, binding: Binding] -> [dynamic]int
  (let [[e-value e-ok] (resolve-entity-term db clause.e binding)
        [a-value a-ok] (resolve-term clause.a binding)
        [v-value v-ok] (resolve-term clause.v binding)
        source: []int (slice db.eavt 0)
        out (make [dynamic]int)]
    (when (= clause.v.kind .LookupRef)
      (let [[lookup-entity lookup-ok] (resolve-lookup-ref db clause.v.lookup-attr clause.v.lookup-value)]
        (when lookup-ok
          (set! v-value (value-entity lookup-entity))
          (set! v-ok true))))
    (when v-ok
      (let [[entity entity-ok] (lookup-ref-value-as-entity db v-value)]
        (when entity-ok
          (set! v-value entity))))
    (when (and a-ok v-ok (= a-value.kind .Keyword))
      (let [[resolved resolved-ok] (ref-entity-literal db a-value.text v-value)]
        (when resolved-ok
          (set! v-value resolved))))
    (when (and a-ok
               (= a-value.kind .Keyword)
               (reverse-attr? a-value.text))
      (let [forward-attr (forward-attr-for-reverse a-value.text) :defer]
        (let [[source-entity source-ok] (resolve-entity-term db clause.v binding)]
          (when source-ok
            (set! v-value source-entity)
            (set! v-ok true)))
        (when (and e-ok (not (= e-value.kind .Entity)))
          (return out))
        (when (and v-ok (not (= v-value.kind .Entity)))
          (return out))
        (if e-ok
          (let [indexes (slice db.vaet 0)
                ref-value (value-entity e-value.entity)
                low (lower-bound-index db indexes "vaet" 0 "" ref-value)
                high (upper-bound-index db indexes "vaet" 0 "" ref-value)]
            (set! source (slice indexes low high)))
          (if v-ok
            (let [indexes (slice db.eavt 0)
                  low (lower-bound-index db indexes "eavt-ea" v-value.entity forward-attr (Value {}))
                  high (upper-bound-index db indexes "eavt-ea" v-value.entity forward-attr (Value {}))]
              (set! source (slice indexes low high)))
            (let [indexes (slice db.aevt 0)
                  low (lower-bound-index db indexes "aevt" 0 forward-attr (Value {}))
                  high (upper-bound-index db indexes "aevt" 0 forward-attr (Value {}))]
              (set! source (slice indexes low high)))))
        (for [datom-index source]
          (let [datom db.datoms[datom-index]]
            (when (and (= datom.a forward-attr)
                       (= datom.v.kind .Entity))
              (arr.push! out datom-index))))
        (return out)))
    (if (and e-ok a-ok)
      (do
        (when (not (and (= e-value.kind .Entity)
                        (= a-value.kind .Keyword)))
          (return out))
        (let [indexes (slice db.eavt 0)
              low (lower-bound-index db indexes "eavt-ea" e-value.entity a-value.text (Value {}))
              high (upper-bound-index db indexes "eavt-ea" e-value.entity a-value.text (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (and a-ok v-ok))
      (do
        (when (not (= a-value.kind .Keyword))
          (return out))
        (let [indexes (slice db.avet 0)
              low (lower-bound-index db indexes "avet" 0 a-value.text v-value)
              high (upper-bound-index db indexes "avet" 0 a-value.text v-value)]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) e-ok)
      (do
        (when (not (= e-value.kind .Entity))
          (return out))
        (let [indexes (slice db.eavt 0)
              low (lower-bound-index db indexes "eavt" e-value.entity "" (Value {}))
              high (upper-bound-index db indexes "eavt" e-value.entity "" (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) (not e-ok) a-ok)
      (do
        (when (not (= a-value.kind .Keyword))
          (return out))
        (let [indexes (slice db.aevt 0)
              low (lower-bound-index db indexes "aevt" 0 a-value.text (Value {}))
              high (upper-bound-index db indexes "aevt" 0 a-value.text (Value {}))]
          (set! source (slice indexes low high)))))
    (if (and (not (and e-ok a-ok)) (not (and a-ok v-ok)) (not e-ok) (not a-ok) v-ok)
      (let [indexes (slice db.vaet 0)
            low (lower-bound-index db indexes "vaet" 0 "" v-value)
            high (upper-bound-index db indexes "vaet" 0 "" v-value)]
        (set! source (slice indexes low high))))
    (for [datom-index source]
      (let [datom db.datoms[datom-index]]
        (when (candidate-index-matches? datom e-value e-ok a-value a-ok v-value v-ok)
          (arr.push! out datom-index))))
    out))

(defn binding-matches-clause? [db: DB, clause: Clause, binding: Binding] -> bool
  (when clause.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause binding) :defer]
      (return (> (count source-bindings) 0))))
  (let [candidates (clause-candidate-indexes db clause binding) :defer]
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [candidate (clone-binding binding)]
            (when (datom-clause-matches? db datom clause (addr candidate))
              (return true)))))))
  false)

(defn bindings-after-clause-group-with-sources-and-fns [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings ([dynamic]Binding [binding])]
    (for [clause group.clauses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (append-bindings-after-clause-with-sources! (addr next-bindings) db sources clause candidate-binding))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    (for [not-group group.not-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (when (not (binding-matches-not-group-with-sources-and-fns? db sources not-group candidate-binding registry))
            (arr.push! next-bindings candidate-binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    bindings))

(defn bindings-after-clause-group-with-sources [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-clause-group-with-sources-and-fns db sources group binding ([]Native-Query-Fn [])))

(defn bindings-after-clause-group [db: DB, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-clause-group-with-sources db ([]DB-Source []) group binding))

(defn project-binding [binding: Binding, names: []string] -> Binding
  (let [out (Binding {})]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (when ok
          (binding-store! (addr out) name value))))
    out))

(defn merge-binding [base: Binding, extra: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding base)]
    (for [item extra.items]
      (let [[existing exists] (binding-lookup out item.name)]
        (if exists
          (when (not (value-equal? existing item.value))
            (return out false))
          (binding-store! (addr out) item.name item.value))))
    (return out true)))

(defn binding-with-value [binding: Binding, name: string, value: Value] -> [next: Binding, ok: bool]
  (let [out (clone-binding binding)
        [existing exists] (binding-lookup out name)]
    (if exists
      (return out (value-equal? existing value))
      (do
        (binding-store! (addr out) name value)
        (return out true)))))

(defn apply-get-else [db: DB, binding: Binding, clause: Get-Else] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (let [[value value-ok] (pull-attr-value db entity.entity clause.a)]
      (if value-ok
        (binding-with-value binding clause.out value)
        (binding-with-value binding clause.out clause.default-value)))))

(defn apply-get-some [db: DB, binding: Binding, clause: Get-Some] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (for [attr clause.attrs]
      (let [[value value-ok] (pull-attr-value db entity.entity attr)]
        (when value-ok
          (let [[with-attr attr-ok] (binding-with-value binding clause.out-attr (value-keyword attr))]
            (when (not attr-ok)
              (return with-attr false))
            (return (binding-with-value with-attr clause.out-value value))))))
    (return binding false)))

(defn ground-bind-values [binding: Binding, vars: []string, values: []Value] -> [next: Binding, ok: bool]
  (when (not (= (count vars) (count values)))
    (return binding false))
  (let [bound-binding (clone-binding binding)]
    (for [name index vars]
      (when (not (= name ""))
        (let [[bound bound-ok] (binding-with-value bound-binding name values[index])]
          (when (not bound-ok)
            (return binding false))
          (set! bound-binding bound))))
    (return bound-binding true)))

(defn apply-ground [bindings: []Binding, ground: Ground] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[source source-ok] (resolve-term ground.source binding)]
        (when source-ok
          (if (not (= ground.binding.kind .None))
            (do
              (let [bound (bind-input-pattern binding ground.binding source)]
                (for [item bound]
                  (arr.push! out item))))
            (if ground.is-tuple
            (when (= source.kind .Vector)
              (let [[next ok] (ground-bind-values binding ground.tuple-vars (slice source.items 0))]
                (when ok
                  (arr.push! out next))))
            (if ground.is-relation
              (when (= source.kind .Vector)
                (for [row source.items]
                  (when (and (= row.kind .Vector)
                             (= (count row.items) ground.width))
                    (let [[next ok] (ground-bind-values binding ground.tuple-vars (slice row.items 0))]
                      (when ok
                        (arr.push! out next))))))
              (if ground.is-collection
                (when (= source.kind .Vector)
                  (for [value source.items]
                    (let [[next ok] (binding-with-value binding ground.out value)]
                      (when ok
                        (arr.push! out next)))))
                (if (= ground.out "")
                  (arr.push! out binding)
                  (let [[next ok] (binding-with-value binding ground.out source)]
                    (when ok
                      (arr.push! out next)))))))))))
    out))

(defn bindings-after-function-with-fns [bindings: []Binding, function: Function-Clause, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (if (not (= function.out-binding.kind .None))
        (let [[value value-ok] (apply-function-op-with-fns function binding registry)]
          (when value-ok
            (let [bound (bind-input-pattern binding function.out-binding value)]
              (for [item bound]
                (arr.push! out item)))))
        (let [[next ok] (apply-function-clause-with-fns binding function registry)]
          (when ok
            (arr.push! out next)))))
    out))

(defn bindings-after-function [bindings: []Binding, function: Function-Clause] -> [dynamic]Binding
  (bindings-after-function-with-fns bindings function ([]Native-Query-Fn [])))

(defn bindings-after-predicate-with-db-and-fns [db: DB, bindings: []Binding, predicate: Predicate, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (when (predicate-matches-with-db-and-fns? db predicate binding registry)
        (arr.push! out binding)))
    out))

(defn bindings-after-predicate-with-fns [bindings: []Binding, predicate: Predicate, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-predicate-with-db-and-fns (DB {}) bindings predicate registry))

(defn bindings-after-predicate [bindings: []Binding, predicate: Predicate] -> [dynamic]Binding
  (bindings-after-predicate-with-fns bindings predicate ([]Native-Query-Fn [])))

(defn relation-source-width-for-clause [clause: Clause] -> int
  (when (> clause.source-width 0)
    (return clause.source-width))
  (if (= clause.v.kind .Wildcard)
    2
    (if (not (= clause.op-term.kind .Wildcard))
      5
      (if (not (= clause.tx-term.kind .Wildcard))
        4
        3))))

(defn rule-clause-with-source [clause: Clause, source: string, has-source: bool] -> Clause
  (when (or (not has-source) clause.has-source)
    (return clause))
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           tx-term: clause.tx-term
           op-term: clause.op-term
           source: source
           has-source: true
           source-width: (relation-source-width-for-clause clause)}))

(defn rule-clauses-with-source [clauses: []Clause, source: string, has-source: bool] -> [dynamic]Clause
  (let [out (make [dynamic]Clause 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (rule-clause-with-source clause source has-source)))
    out))

(defn bind-rule-source [outer: Binding, initial: Binding, source: string, has-source: bool] -> [binding: Binding, ok: bool]
  (when (not has-source)
    (return initial true))
  (let [[source-value source-ok] (binding-lookup outer source)]
    (when (not source-ok)
      (return initial false))
    (let [next (clone-binding initial)]
      (binding-store! (addr next) source source-value)
      (return next true))))

(defn binding-equal? [left: Binding, right: Binding] -> bool
  (when (not (= (count left.items) (count right.items)))
    (return false))
  (for [item left.items]
    (let [[right-value right-ok] (binding-lookup right item.name)]
      (when (not (and right-ok (value-equal? item.value right-value)))
        (return false))))
  true)

(defn binding-exists? [bindings: []Binding, binding: Binding] -> bool
  (for [existing bindings]
    (when (binding-equal? existing binding)
      (return true)))
  false)

(defn append-unique-binding! [out: ^[dynamic]Binding, seen: (ptr (map string bool)), binding: Binding] -> bool
  (let [[key key-ok] (binding-dedupe-key binding)]
    (when key-ok
      (let [[_ already-seen] (mmap.get seen^ key)]
        (when already-seen
          (return false))
        (mmap.assoc! seen^ key true)
        (arr.push! out^ binding)
        (return true)))
    (when (not (binding-exists? (slice out^ 0) binding))
      (arr.push! out^ binding)
      (return true))
    false))

(defn unique-bindings [bindings: []Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding 0 (count bindings))
        seen (make (map string bool))]
    (defer (delete seen))
    (for [binding bindings]
      (discard (append-unique-binding! (addr out) (addr seen) binding)))
    out))

(defn query-stats-observe-bindings! [stats: ^Query-Stats, count-value: int]
  (when (> count-value stats^.max-intermediate-bindings)
    (set! stats^.max-intermediate-bindings count-value)))

(defn term-var-name? [term: Term, name: string] -> bool
  (and (= term.kind .Var)
       (= term.name name)))

(defn term-wildcard? [term: Term] -> bool
  (= term.kind .Wildcard))

(defn clause-attr-keyword [clause: Clause] -> [attr: string, ok: bool]
  (when (and (= clause.a.kind .Value)
             (= clause.a.value.kind .Keyword))
    (return clause.a.value.text true))
  (return "" false))

(defn rule-has-only-plain-clauses-and-calls? [rule: Rule] -> bool
  (and (= (count rule.predicates) 0)
       (= (count rule.function-clauses) 0)
       (= (count rule.get-elses) 0)
       (= (count rule.get-somes) 0)
       (= (count rule.grounds) 0)
       (= (count rule.not-groups) 0)
       (= (count rule.or-groups) 0)))

(defstruct Linear-Transitive-Plan {
  attr: string
  filters: [dynamic]Clause
})

(defn delete-linear-transitive-plan [plan: Linear-Transitive-Plan]
  (delete plan.filters))

(defn linear-transitive-filter-clause? [clause: Clause, node-var: string] -> bool
  (and (not clause.has-source)
       (term-wildcard? clause.tx-term)
       (term-wildcard? clause.op-term)
       (term-var-name? clause.e node-var)
       (= clause.a.kind .Value)
       (= clause.a.value.kind .Keyword)
       (= clause.v.kind .Value)))

(defn linear-transitive-filter-same? [left: Clause, right: Clause] -> bool
  (and (= left.a.value.text right.a.value.text)
       (value-equal? left.v.value right.v.value)))

(defn linear-transitive-filter-exists? [filters: []Clause, filter: Clause] -> bool
  (for [existing filters]
    (when (linear-transitive-filter-same? existing filter)
      (return true)))
  false)

(defn linear-transitive-filters-same? [left: []Clause, right: []Clause] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [filter left]
    (when (not (linear-transitive-filter-exists? right filter))
      (return false)))
  true)

(defn linear-transitive-edge-and-filters [rule: Rule, from-var: string, to-var: string] -> [attr: string, filters: [dynamic]Clause, ok: bool]
  (let [out-filters (make [dynamic]Clause)
        attr ""
        found-edge false]
    (for [rule-clause rule.clauses]
      (let [[clause-attr clause-attr-ok] (clause-attr-keyword rule-clause)]
        (if (and clause-attr-ok
                 (term-var-name? rule-clause.e from-var)
                 (term-var-name? rule-clause.v to-var))
          (do
            (when found-edge
              (delete out-filters)
              (return "" (make [dynamic]Clause) false))
            (set! attr clause-attr)
            (set! found-edge true))
          (if (linear-transitive-filter-clause? rule-clause to-var)
            (arr.push! out-filters rule-clause)
            (do
              (delete out-filters)
              (return "" (make [dynamic]Clause) false))))))
    (return attr out-filters found-edge)))

(defn empty-linear-transitive-plan [] -> Linear-Transitive-Plan
  (Linear-Transitive-Plan {filters: (make [dynamic]Clause)}))

(defn linear-transitive-rule-plan [rules: []Rule, name: string] -> [plan: Linear-Transitive-Plan, ok: bool]
  (let [found-base false
        found-recursive false
        attr ""
        filters (make [dynamic]Clause)]
    (for [rule rules]
      (when (= rule.name name)
        (when (not (and (= (count rule.params) 2)
                        (rule-has-only-plain-clauses-and-calls? rule)))
          (delete filters)
          (return (empty-linear-transitive-plan) false))
        (when (= (count rule.rule-calls) 0)
          (let [[base-attr base-filters base-ok] (linear-transitive-edge-and-filters rule rule.params[0] rule.params[1])]
            (when (or (not base-ok)
                      found-base
                      (and (> (count attr) 0) (not (= attr base-attr))))
              (delete filters)
              (delete base-filters)
              (return (empty-linear-transitive-plan) false))
            (set! attr base-attr)
            (delete filters)
            (set! filters base-filters)
            (set! found-base true)))
        (when (> (count rule.rule-calls) 0)
          (when (not (= (count rule.rule-calls) 1))
            (delete filters)
            (return (empty-linear-transitive-plan) false))
          (let [recursive-call rule.rule-calls[0]]
            (when (not (and (= recursive-call.name name)
                            (= (count recursive-call.args) 2)
                            (= recursive-call.args[0].kind .Var)
                            (term-var-name? recursive-call.args[1] rule.params[1])))
              (delete filters)
              (return (empty-linear-transitive-plan) false))
            (let [mid-var recursive-call.args[0].name]
              (let [[recursive-attr recursive-filters recursive-ok] (linear-transitive-edge-and-filters rule rule.params[0] mid-var)]
                (when (or (not recursive-ok)
                          (and (> (count attr) 0) (not (= attr recursive-attr)))
                          (and found-base (not (linear-transitive-filters-same? (slice filters 0) (slice recursive-filters 0)))))
                  (delete filters)
                  (delete recursive-filters)
                  (return (empty-linear-transitive-plan) false))
                (when (not found-base)
                  (delete filters)
                  (set! filters (arr.into [dynamic]Clause (slice recursive-filters 0))))
                (set! attr recursive-attr)
                (delete recursive-filters)
                (set! found-recursive true)))))))
    (return (Linear-Transitive-Plan {attr: attr filters: filters}) (and found-base found-recursive))))

(defn linear-transitive-rule-attr [rules: []Rule, name: string] -> [attr: string, ok: bool]
  (let [[plan plan-ok] (linear-transitive-rule-plan rules name)]
    (defer (delete-linear-transitive-plan plan))
    (return plan.attr plan-ok)))

(defstruct Alternating-Transitive-Plan {
  left-name: string
  left-attr: string
  right-name: string
  right-attr: string
})

(defn empty-alternating-transitive-plan [] -> Alternating-Transitive-Plan
  (Alternating-Transitive-Plan {}))

(defn alternating-base-rule-attr [rule: Rule] -> [attr: string, ok: bool]
  (when (not (and (= (count rule.params) 2)
                  (rule-has-only-plain-clauses-and-calls? rule)
                  (= (count rule.rule-calls) 0)
                  (= (count rule.clauses) 1)))
    (return "" false))
  (let [rule-clause rule.clauses[0]
        [attr attr-ok] (clause-attr-keyword rule-clause)]
    (return attr
      (and attr-ok
           (not rule-clause.has-source)
           (term-wildcard? rule-clause.tx-term)
           (term-wildcard? rule-clause.op-term)
           (term-var-name? rule-clause.e rule.params[0])
           (term-var-name? rule-clause.v rule.params[1])))))

(defn alternating-recursive-rule-shape [rule: Rule] -> [attr: string, next-name: string, ok: bool]
  (when (not (and (= (count rule.params) 2)
                  (rule-has-only-plain-clauses-and-calls? rule)
                  (= (count rule.rule-calls) 1)
                  (= (count rule.clauses) 1)))
    (return "" "" false))
  (let [call rule.rule-calls[0]]
    (when (not (and (= (count call.args) 2)
                    (= call.args[0].kind .Var)
                    (= call.args[1].kind .Var)
                    (= call.args[1].name rule.params[1])))
      (return "" "" false))
    (let [mid-var call.args[0].name
          rule-clause rule.clauses[0]
          [attr attr-ok] (clause-attr-keyword rule-clause)]
      (return attr call.name
        (and attr-ok
             (not call.has-source)
             (not rule-clause.has-source)
             (term-wildcard? rule-clause.tx-term)
             (term-wildcard? rule-clause.op-term)
             (term-var-name? rule-clause.e rule.params[0])
             (term-var-name? rule-clause.v mid-var))))))

(defn alternating-rule-shape [rules: []Rule, name: string] -> [attr: string, next-name: string, ok: bool]
  (let [attr ""
        next-rule-name ""
        found-base false
        found-recursive false]
    (for [rule rules]
      (when (= rule.name name)
        (let [branch-ok false]
        (let [[base-attr base-ok] (alternating-base-rule-attr rule)]
          (when base-ok
            (set! branch-ok true)
            (when (or found-base
                      (and (> (count attr) 0) (not (= attr base-attr))))
              (return "" "" false))
            (set! attr base-attr)
            (set! found-base true)))
        (let [[recursive-attr recursive-next recursive-ok] (alternating-recursive-rule-shape rule)]
          (when recursive-ok
            (set! branch-ok true)
            (when (or found-recursive
                      (and (> (count attr) 0) (not (= attr recursive-attr))))
              (return "" "" false))
            (set! attr recursive-attr)
            (set! next-rule-name recursive-next)
            (set! found-recursive true)))
        (when (not branch-ok)
          (return "" "" false)))))
    (return attr next-rule-name (and found-base found-recursive))))

(defn alternating-transitive-rule-plan [rules: []Rule, name: string] -> [plan: Alternating-Transitive-Plan, ok: bool]
  (let [[left-attr right-name left-ok] (alternating-rule-shape rules name)]
    (when (not left-ok)
      (return (empty-alternating-transitive-plan) false))
    (let [[right-attr next-name right-ok] (alternating-rule-shape rules right-name)]
      (when (not (and right-ok (= next-name name) (not (= name right-name))))
        (return (empty-alternating-transitive-plan) false))
      (return (Alternating-Transitive-Plan {left-name: name
                                            left-attr: left-attr
                                            right-name: right-name
                                            right-attr: right-attr})
              true))))

(defn first-rule-by-name [rules: []Rule, name: string] -> [rule: Rule, ok: bool]
  (for [rule rules]
    (when (= rule.name name)
      (return rule true)))
  (return (Rule {}) false))

(defn append-transitive-targets! [out: ^[dynamic]u64, db: DB, attr: string, start: u64]
  (let [expanded (make (map u64 bool))
        emitted (make (map u64 bool))
        frontier (make [dynamic]u64)
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            edge-clause (clause (term-value (value-entity current)) attr (term-wildcard))
            candidates (clause-candidate-indexes db edge-clause (Binding {})) :defer]
        (set! frontier-index (+ frontier-index 1))
        (let [[_ already-expanded] (mmap.get expanded current)]
          (when (not already-expanded)
            (mmap.assoc! expanded current true)
            (for [datom-index candidates]
              (let [datom db.datoms[datom-index]]
                (when (and (datom-current-at? db datom-index)
                           (= datom.v.kind .Entity))
                  (let [[_ already-emitted] (mmap.get emitted datom.v.entity)
                        [_ target-expanded] (mmap.get expanded datom.v.entity)]
                    (when (not already-emitted)
                      (mmap.assoc! emitted datom.v.entity true)
                      (arr.push! out^ datom.v.entity))
                    (when (not target-expanded)
                      (arr.push! frontier datom.v.entity))))))))))))

(defn append-transitive-starts! [out: ^[dynamic]u64, db: DB, attr: string]
  (let [seen (make (map u64 bool))
        attr-clause (clause (term-wildcard) attr (term-wildcard))
        candidates (clause-candidate-indexes db attr-clause (Binding {}))]
    (defer (delete seen))
    (defer (delete candidates))
    (for [datom-index candidates]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[_ found] (mmap.get seen datom.e)]
            (when (not found)
              (mmap.assoc! seen datom.e true)
              (arr.push! out^ datom.e))))))))

(defn append-transitive-sources! [out: ^[dynamic]u64, db: DB, attr: string, target: u64]
  (let [expanded (make (map u64 bool))
        emitted (make (map u64 bool))
        frontier (make [dynamic]u64)
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier target)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            edge-clause (clause (term-wildcard) attr (term-value (value-entity current)))
            candidates (clause-candidate-indexes db edge-clause (Binding {})) :defer]
        (set! frontier-index (+ frontier-index 1))
        (let [[_ already-expanded] (mmap.get expanded current)]
          (when (not already-expanded)
            (mmap.assoc! expanded current true)
            (for [datom-index candidates]
              (let [datom db.datoms[datom-index]]
                (when (datom-current-at? db datom-index)
                  (let [[_ already-emitted] (mmap.get emitted datom.e)
                        [_ source-expanded] (mmap.get expanded datom.e)]
                    (when (not already-emitted)
                      (mmap.assoc! emitted datom.e true)
                      (arr.push! out^ datom.e))
                    (when (not source-expanded)
                      (arr.push! frontier datom.e))))))))))))

(defn u64-slice-contains? [items: []u64, value: u64] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn transitive-adjacency-max-entity [adjacency: []Transitive-Adjacency] -> u64
  (let [max-entity: u64 0]
    (for [entry adjacency]
      (when (> entry.entity max-entity)
        (set! max-entity entry.entity))
      (for [target entry.targets]
        (when (> target max-entity)
          (set! max-entity target))))
    max-entity))

(defn transitive-adjacency-use-dense-seen? [adjacency: []Transitive-Adjacency] -> [max-entity: u64, ok: bool]
  (let [max-value (transitive-adjacency-max-entity adjacency)
        adjacency-count (count adjacency)]
    (return max-value
      (and (> adjacency-count 0)
           (< max-value 1000000)
           (<= (int max-value) (* adjacency-count 8))))))

(defn make-bool-dense-index [size: int] -> [dynamic]bool
  (let [out (make [dynamic]bool 0 size)]
    (for [_ (arr.range 0 size)]
      (arr.push! out false))
    out))

(defstruct Transitive-Adjacency {
  entity: u64
  targets: [dynamic]u64
})

(defstruct Transitive-Adjacency-Index {
  items: [dynamic]Transitive-Adjacency
  index: map[u64]int
})

(defn transitive-adjacency-index [lookup: map[u64]int, entity: u64] -> [index: int, ok: bool]
  (mmap.get lookup entity))

(defn append-transitive-adjacency-edge! [out: ^[dynamic]Transitive-Adjacency, index: (ptr (map u64 int)), source: u64, target: u64]
  (let [[adjacency-index found] (transitive-adjacency-index index^ source)]
    (if found
      (arr.push! out^[adjacency-index].targets target)
      (let [targets (make [dynamic]u64 0 4)]
        (arr.push! targets target)
        (mmap.assoc! index^ source (count out^))
        (arr.push! out^ (Transitive-Adjacency {entity: source targets: targets}))))))

(defn entity-matches-transitive-filter? [db: DB, entity: u64, filter: Clause] -> bool
  (let [indexes (slice db.eavt 0)
        attr filter.a.value.text
        expected filter.v.value
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v expected))
          (return true))))
    false))

(defn entity-matches-transitive-filters? [db: DB, entity: u64, filters: []Clause] -> bool
  (for [filter filters]
    (when (not (entity-matches-transitive-filter? db entity filter))
      (return false)))
  true)

(defn transitive-adjacency-from-db-with-filters [db: DB, attr: string, filters: []Clause] -> Transitive-Adjacency-Index
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 attr (Value {}))
        out (make [dynamic]Transitive-Adjacency 0 (- high low))
        index (make (map u64 int))]
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (entity-matches-transitive-filters? db datom.v.entity filters))
          (append-transitive-adjacency-edge! (addr out) (addr index) datom.e datom.v.entity))))
    (Transitive-Adjacency-Index {items: out index: index})))

(defn transitive-adjacency-from-db [db: DB, attr: string] -> Transitive-Adjacency-Index
  (transitive-adjacency-from-db-with-filters db attr ([]Clause [])))

(defn transitive-reverse-adjacency-from-db-with-filters [db: DB, attr: string, filters: []Clause] -> Transitive-Adjacency-Index
  (let [indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 attr (Value {}))
        out (make [dynamic]Transitive-Adjacency 0 (- high low))
        index (make (map u64 int))]
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (entity-matches-transitive-filters? db datom.v.entity filters))
          (append-transitive-adjacency-edge! (addr out) (addr index) datom.v.entity datom.e))))
    (Transitive-Adjacency-Index {items: out index: index})))

(defn transitive-reverse-adjacency-from-db [db: DB, attr: string] -> Transitive-Adjacency-Index
  (transitive-reverse-adjacency-from-db-with-filters db attr ([]Clause [])))

(defn delete-transitive-adjacency [adjacency: Transitive-Adjacency-Index]
  (for [item adjacency.items]
    (delete item.targets))
  (delete adjacency.items)
  (delete adjacency.index))

(defn append-transitive-targets-with-adjacency! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64]
  (let [expanded (make [dynamic]u64 0 (count adjacency))
        emitted (make [dynamic]u64 0 (count adjacency))
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (u64-slice-contains? (slice expanded 0) current)]
          (when (and (not already-expanded) has-edges)
            (arr.push! expanded current)
            (for [target-entity adjacency[adj-index].targets]
              (let [already-emitted (u64-slice-contains? (slice emitted 0) target-entity)
                    target-expanded (u64-slice-contains? (slice expanded 0) target-entity)]
                (when (not already-emitted)
                  (arr.push! emitted target-entity)
                  (arr.push! out^ target-entity))
                (when (not target-expanded)
                  (arr.push! frontier target-entity))))))))))

(defn append-transitive-targets-with-dense-adjacency! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64, max-entity: u64]
  (let [dense-size (+ (int max-entity) 1)
        expanded (make-bool-dense-index dense-size)
        emitted (make-bool-dense-index dense-size)
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)
            current-index (int current)]
        (set! frontier-index (+ frontier-index 1))
        (when (and has-edges
                   (< current-index dense-size)
                   (not expanded[current-index]))
          (set! expanded[current-index] true)
          (for [target-entity adjacency[adj-index].targets]
            (let [target-index (int target-entity)]
              (when (< target-index dense-size)
                (when (not emitted[target-index])
                  (set! emitted[target-index] true)
                  (arr.push! out^ target-entity))
                (when (not expanded[target-index])
                  (arr.push! frontier target-entity))))))))))

(defn append-transitive-targets-fast! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64]
  (let [[max-entity use-dense] (transitive-adjacency-use-dense-seen? adjacency)]
    (if use-dense
      (append-transitive-targets-with-dense-adjacency! out adjacency adjacency-index start max-entity)
      (append-transitive-targets-with-adjacency! out adjacency adjacency-index start))))

(defstruct Alternating-Frontier-State {
  entity: u64
  use-left: bool
})

(defn alternating-state-expanded? [left-expanded: []u64, right-expanded: []u64, entity: u64, use-left: bool] -> bool
  (if use-left
    (u64-slice-contains? left-expanded entity)
    (u64-slice-contains? right-expanded entity)))

(defn mark-alternating-state-expanded! [left-expanded: ^[dynamic]u64, right-expanded: ^[dynamic]u64, entity: u64, use-left: bool]
  (if use-left
    (arr.push! left-expanded^ entity)
    (arr.push! right-expanded^ entity)))

(defn append-alternating-targets! [out: ^[dynamic]u64, left-adjacency: Transitive-Adjacency-Index, right-adjacency: Transitive-Adjacency-Index, start: u64]
  (let [left-expanded (make [dynamic]u64)
        right-expanded (make [dynamic]u64)
        emitted (make [dynamic]u64)
        frontier (make [dynamic]Alternating-Frontier-State)
        frontier-index 0]
    (defer (delete left-expanded))
    (defer (delete right-expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier (Alternating-Frontier-State {entity: start use-left: true}))
    (while (< frontier-index (count frontier))
      (let [state frontier[frontier-index]]
        (set! frontier-index (+ frontier-index 1))
        (when (not (alternating-state-expanded? (slice left-expanded 0) (slice right-expanded 0) state.entity state.use-left))
          (mark-alternating-state-expanded! (addr left-expanded) (addr right-expanded) state.entity state.use-left)
          (let [adjacency (if state.use-left left-adjacency right-adjacency)
                [adj-index has-edges] (transitive-adjacency-index adjacency.index state.entity)]
            (when has-edges
              (for [target-entity adjacency.items[adj-index].targets]
                (when (not (u64-slice-contains? (slice emitted 0) target-entity))
                  (arr.push! emitted target-entity)
                  (arr.push! out^ target-entity))
                (when (not (alternating-state-expanded? (slice left-expanded 0) (slice right-expanded 0) target-entity (not state.use-left)))
                  (arr.push! frontier (Alternating-Frontier-State {entity: target-entity use-left: (not state.use-left)})))))))))))

(defn append-linear-transitive-direct-result! [out: ^[dynamic]Binding, call: Rule-Call, binding: Binding, rule: Rule, start-entity: u64, target-entity: u64]
  (when (and (= (count binding.items) 0)
             (= (count rule.params) 2)
             (= (count call.args) 2)
             (= call.args[0].kind .Var)
             (= call.args[1].kind .Var)
             (not (= call.args[0].name call.args[1].name)))
    (let [items (make [dynamic]Var-Binding 0 2)]
      (arr.push! items (Var-Binding {name: call.args[0].name value: (value-entity start-entity)}))
      (arr.push! items (Var-Binding {name: call.args[1].name value: (value-entity target-entity)}))
      (arr.push! out^ (Binding {items: items}))
      (return)))
  (let [result (clone-binding binding)
        start-value (value-entity start-entity)
        target-value (value-entity target-entity)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [value (if (= param rule.params[0]) start-value target-value)
                [existing exists] (binding-lookup result arg.name)]
            (if exists
              (when (not (value-equal? existing value))
                (return))
              (binding-store! (addr result) arg.name value))))))
    (arr.push! out^ result)))

(defn append-linear-transitive-unbound-from-start-adjacency! [out: ^[dynamic]Binding, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, call: Rule-Call, binding: Binding, rule: Rule, start-entity: u64]
  (let [expanded (make [dynamic]u64 0 (count adjacency))
        emitted (make [dynamic]u64 0 (count adjacency))
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start-entity)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (u64-slice-contains? (slice expanded 0) current)]
          (when (and (not already-expanded) has-edges)
            (arr.push! expanded current)
            (for [target-entity adjacency[adj-index].targets]
              (let [already-emitted (u64-slice-contains? (slice emitted 0) target-entity)
                    target-expanded (u64-slice-contains? (slice expanded 0) target-entity)]
                (when (not already-emitted)
                  (arr.push! emitted target-entity)
                  (append-linear-transitive-direct-result! out call binding rule start-entity target-entity))
                (when (not target-expanded)
                  (arr.push! frontier target-entity))))))))))

(defn transitive-target-matches? [db: DB, target: Value, target-ok: bool, entity: u64] -> bool
  (when (not target-ok)
    (return true))
  (let [[target-entity target-entity-ok] (value-as-entity db target)]
    (and target-entity-ok (= target-entity.entity entity))))

(defn append-linear-transitive-target-result! [out: ^[dynamic]Binding, db: DB, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64, target: Value, target-ok: bool, target-entity: u64]
  (when (not (transitive-target-matches? db target target-ok target-entity))
    (return))
  (let [[_ start-bound] (binding-lookup initial rule.params[0])
        with-start initial
        with-start-ok true]
    (when (not start-bound)
      (let [[bound bound-ok] (binding-with-value initial rule.params[0] (value-entity start-entity))]
        (set! with-start bound)
        (set! with-start-ok bound-ok)))
    (when (not with-start-ok)
      (return))
    (let [[_ target-bound] (binding-lookup with-start rule.params[1])
          result with-start
          result-ok true]
      (when (not target-bound)
        (let [[bound bound-ok] (binding-with-value with-start rule.params[1] (value-entity target-entity))]
          (set! result bound)
          (set! result-ok bound-ok)))
      (when (not result-ok)
        (return))
      (let [[merged merged-ok] (merge-rule-output binding call rule result)]
        (when merged-ok
          (arr.push! out^ merged))))))

(defn append-linear-transitive-from-start! [out: ^[dynamic]Binding, db: DB, attr: string, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64]
  (let [[target target-ok] (binding-lookup initial rule.params[1])
        targets (make [dynamic]u64)]
    (defer (delete targets))
    (append-transitive-targets! (addr targets) db attr start-entity)
    (for [target-entity targets]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target target-ok target-entity))))

(defn append-linear-transitive-from-start-adjacency! [out: ^[dynamic]Binding, db: DB, adjacency: Transitive-Adjacency-Index, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64]
  (let [[target target-ok] (binding-lookup initial rule.params[1])
        targets (make [dynamic]u64)]
    (defer (delete targets))
    (append-transitive-targets-fast! (addr targets) (slice adjacency.items 0) adjacency.index start-entity)
    (for [target-entity targets]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target target-ok target-entity))))

(defn append-linear-transitive-from-all-starts! [out: ^[dynamic]Binding, db: DB, plan: Linear-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding]
  (let [adjacency (transitive-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0))]
    (defer (delete-transitive-adjacency adjacency))
    (for [entry adjacency.items]
      (append-linear-transitive-unbound-from-start-adjacency! out (slice adjacency.items 0) adjacency.index call binding rule entry.entity))))

(defn append-linear-transitive-to-target! [out: ^[dynamic]Binding, db: DB, attr: string, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, target-entity: u64]
  (let [starts (make [dynamic]u64)
        target-value (value-entity target-entity)]
    (defer (delete starts))
    (append-transitive-sources! (addr starts) db attr target-entity)
    (for [start-entity starts]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target-value true target-entity))))

(defn append-linear-transitive-to-target-adjacency! [out: ^[dynamic]Binding, db: DB, adjacency: Transitive-Adjacency-Index, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, target-entity: u64]
  (let [starts (make [dynamic]u64)
        target-value (value-entity target-entity)]
    (defer (delete starts))
    (append-transitive-targets-fast! (addr starts) (slice adjacency.items 0) adjacency.index target-entity)
    (for [start-entity starts]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target-value true target-entity))))

(defn append-linear-transitive-results! [out: ^[dynamic]Binding, db: DB, plan: Linear-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule]
  (let [[initial initial-ok] (bind-rule-args binding call rule)]
    (when (not initial-ok)
      (return))
    (let [[start start-ok] (binding-lookup initial rule.params[0])]
      (if start-ok
        (let [[start-entity start-entity-ok] (value-as-entity db start)]
          (when (not start-entity-ok)
            (return))
          (let [adjacency (transitive-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0))]
            (defer (delete-transitive-adjacency adjacency))
            (append-linear-transitive-from-start-adjacency! out db adjacency call binding rule initial start-entity.entity)))
        (let [[target target-ok] (binding-lookup initial rule.params[1])]
          (if target-ok
            (let [[target-entity target-entity-ok] (value-as-entity db target)]
              (when target-entity-ok
                (let [adjacency (transitive-reverse-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0))]
                  (defer (delete-transitive-adjacency adjacency))
                  (append-linear-transitive-to-target-adjacency! out db adjacency call binding rule initial target-entity.entity))))
            (append-linear-transitive-from-all-starts! out db plan call binding rule initial)))))))

(defn bindings-after-linear-transitive-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)
        [plan plan-ok] (linear-transitive-rule-plan rules call.name)]
    (defer (delete-linear-transitive-plan plan))
    (when (not plan-ok)
      (return result-bindings false))
    (for [rule rules]
      (when (= rule.name call.name)
        (append-linear-transitive-results! (addr result-bindings) db plan call binding rule)
        (return result-bindings true)))
    (return result-bindings true)))

(defn append-alternating-transitive-results! [out: ^[dynamic]Binding, db: DB, plan: Alternating-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule]
  (let [[initial initial-ok] (bind-rule-args binding call rule)]
    (when (not initial-ok)
      (return))
    (let [[start start-ok] (binding-lookup initial rule.params[0])]
      (when (not start-ok)
        (return))
      (let [[start-entity start-entity-ok] (value-as-entity db start)]
        (when (not start-entity-ok)
          (return))
        (let [left-adjacency (transitive-adjacency-from-db db plan.left-attr)
              right-adjacency (transitive-adjacency-from-db db plan.right-attr)
              targets (make [dynamic]u64)]
          (defer (delete-transitive-adjacency left-adjacency))
          (defer (delete-transitive-adjacency right-adjacency))
          (defer (delete targets))
          (append-alternating-targets! (addr targets) left-adjacency right-adjacency start-entity.entity)
          (let [[target target-ok] (binding-lookup initial rule.params[1])]
            (for [target-entity targets]
              (append-linear-transitive-target-result! out db call binding rule initial start-entity.entity target target-ok target-entity))))))))

(defn bindings-after-alternating-transitive-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)
        [plan plan-ok] (alternating-transitive-rule-plan rules call.name)]
    (when (not plan-ok)
      (return result-bindings false))
    (let [[rule rule-ok] (first-rule-by-name rules call.name)]
      (when (not rule-ok)
        (return result-bindings false))
      (append-alternating-transitive-results! (addr result-bindings) db plan call binding rule)
      (return result-bindings true))))

(defn bindings-after-rule-step-depth-with-fns [db: DB, rules: []Rule, rule: Rule, bindings: []Binding, step: Query-Step, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)
            clause (rule-clause-with-source rule.clauses[step.index] source has-source)]
        (for [binding bindings]
          (append-bindings-after-clause! (addr out) db clause binding))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call rule.rule-calls[step.index]]
        (for [binding bindings]
          (let [next-source (if call.has-source call.source source)
                next-has-source (or call.has-source has-source)
                rule-bindings (bindings-after-rule-call-depth-with-fns db rules call binding (- depth 1) next-source next-has-source registry)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)
    .Ground
      (apply-ground bindings rule.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings rule.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings rule.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings rule.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings rule.predicates[step.index] registry)
    .Or
      (let [out (make [dynamic]Binding)
            group (if has-source (relation-db-or-group rule.or-groups[step.index] source) rule.or-groups[step.index])]
        (defer (when has-source (delete group.branches)))
        (for [binding bindings]
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-sources-and-fns db ([]DB-Source []) group branch binding registry)]
              (for [branch-binding branch-bindings]
                (arr.push! out branch-binding))
              (delete branch-bindings))))
        out)
    :else
      (let [out (make [dynamic]Binding)
            group (if has-source (relation-db-not-group rule.not-groups[step.index] source) rule.not-groups[step.index])]
        (defer (when has-source
          (delete group.clauses)
          (delete group.not-groups)
          (delete group.join-vars)))
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-sources-and-fns? db ([]DB-Source []) group binding registry))
            (arr.push! out binding)))
        out)))

(defn bindings-after-rule-step-depth [db: DB, rules: []Rule, rule: Rule, bindings: []Binding, step: Query-Step, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-step-depth-with-fns db rules rule bindings step depth source has-source ([]Native-Query-Fn [])))

(defn bindings-after-rule-body-ordered-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings (make [dynamic]Binding)]
    (arr.push! bindings initial)
    (for [step rule.body-steps]
      (let [next-raw (bindings-after-rule-step-depth-with-fns db rules rule (slice bindings 0) step depth source has-source registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)
        (when (= (count bindings) 0)
          (return bindings))))
    bindings))

(defn bindings-after-rule-body-ordered-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-ordered-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn bindings-after-rule-body-grouped-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [clauses (rule-clauses-with-source rule.clauses source has-source)
        group (not-group-simple (slice clauses 0))
        initial-bindings (bindings-after-clause-group-with-sources-and-fns db ([]DB-Source []) group initial registry)
        bindings (unique-bindings (slice initial-bindings 0))]
    (delete initial-bindings)
    (delete clauses)
    (for [call rule.rule-calls]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [next-source (if call.has-source call.source source)
                next-has-source (or call.has-source has-source)
                rule-bindings (bindings-after-rule-call-depth-with-fns db rules call binding (- depth 1) next-source next-has-source registry)]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (let [next (unique-bindings (slice next-bindings 0))]
          (delete next-bindings)
          (delete bindings)
          (set! bindings next))))
    (for [ground rule.grounds]
      (let [next-raw (apply-ground (slice bindings 0) ground)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [get-else rule.get-elses]
      (let [next-raw (bindings-after-get-else-step db (slice bindings 0) get-else)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [get-some rule.get-somes]
      (let [next-raw (bindings-after-get-some-step db (slice bindings 0) get-some)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [function rule.function-clauses]
      (let [next-raw (bindings-after-function-with-fns (slice bindings 0) function registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [predicate rule.predicates]
      (let [next-raw (bindings-after-predicate-with-db-and-fns db (slice bindings 0) predicate registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    bindings))

(defn bindings-after-rule-body-grouped-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-grouped-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn bindings-after-rule-body-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (if (> (count rule.body-steps) 0)
    (bindings-after-rule-body-ordered-depth-with-fns db rules rule initial depth source has-source registry)
    (bindings-after-rule-body-grouped-depth-with-fns db rules rule initial depth source has-source registry)))

(defn bindings-after-rule-body-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn bind-rule-args [outer: Binding, call: Rule-Call, rule: Rule] -> [binding: Binding, ok: bool]
  (let [out (Binding {})]
    (when (not (= (count call.args) (count rule.params)))
      (return out false))
    (for [param index rule.params]
      (let [arg call.args[index]]
        (case arg.kind
          .Var (let [[value value-ok] (binding-lookup outer arg.name)]
                 (when (and (< index rule.required-param-count)
                            (not value-ok))
                   (return out false))
                 (when value-ok
                   (let [[next bind-ok] (binding-with-value out param value)]
                     (when (not bind-ok)
                       (return next false))
                     (set! out next))))
          .Value (let [[next bind-ok] (binding-with-value out param arg.value)]
                   (when (not bind-ok)
                     (return next false))
                   (set! out next))
          .Wildcard (do)
          :else (return out false))))
    (return out true)))

(defn merge-rule-output [outer: Binding, call: Rule-Call, rule: Rule, result: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding outer)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [[value value-ok] (binding-lookup result param)]
            (when value-ok
              (let [[existing exists] (binding-lookup out arg.name)]
                (if exists
                  (when (not (value-equal? existing value))
                    (return out false))
                  (binding-store! (addr out) arg.name value))))))))
    (return out true)))

(defn bindings-after-rule-call-depth-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (<= depth 0)
      (return out))
    (for [rule rules]
      (when (= rule.name call.name)
        (let [[initial ok] (bind-rule-args binding call rule)]
          (when ok
            (let [[source-initial source-ok] (bind-rule-source binding initial source has-source)]
              (when source-ok
                (let [results (bindings-after-rule-body-depth-with-fns db rules rule source-initial depth source has-source registry)]
                  (for [result results]
                    (let [[merged merged-ok] (merge-rule-output binding call rule result)]
                      (when merged-ok
                        (arr.push! out merged))))
                  (delete results))))))))
    out))

(defn bindings-after-rule-call-depth [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-call-depth-with-fns db rules call binding depth source has-source ([]Native-Query-Fn [])))

(defn matching-rules-are-leaves? [rules: []Rule, call: Rule-Call] -> bool
  (let [matched false]
    (for [rule rules]
      (when (= rule.name call.name)
        (set! matched true)
        (when (> (count rule.rule-calls) 0)
          (return false))))
    matched))

(defn bindings-after-rule-call-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [[optimized optimized-ok] (bindings-after-linear-transitive-rule-call db rules call binding)]
    (when optimized-ok
      (return optimized))
    (delete optimized))
  (let [[optimized optimized-ok] (bindings-after-alternating-transitive-rule-call db rules call binding)]
    (when optimized-ok
      (return optimized))
    (delete optimized))
  (when (matching-rules-are-leaves? rules call)
    (let [candidates (bindings-after-rule-call-depth-with-fns db rules call binding 1 call.source call.has-source registry)
          out (unique-bindings (slice candidates 0))]
      (delete candidates)
      (return out)))
  (let [out (make [dynamic]Binding)
        seen (make (map string bool))
        depth 1
        min-depth (+ (count rules) 1)
        changed true]
    (defer (delete seen))
    (while (or changed (<= depth min-depth))
      (set! changed false)
      (let [candidates (bindings-after-rule-call-depth-with-fns db rules call binding depth call.source call.has-source registry)]
        (defer (delete candidates))
        (for [candidate candidates]
          (when (append-unique-binding! (addr out) (addr seen) candidate)
            (set! changed true))))
      (set! depth (+ depth 1)))
    out))

(defn bindings-after-rule-call-profiled-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (set! stats^.rule-calls (+ stats^.rule-calls 1))
  (let [[optimized optimized-ok] (bindings-after-linear-transitive-rule-call db rules call binding)]
    (when optimized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count optimized))
      (return optimized))
    (delete optimized))
  (let [[optimized optimized-ok] (bindings-after-alternating-transitive-rule-call db rules call binding)]
    (when optimized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count optimized))
      (return optimized))
    (delete optimized))
  (when (matching-rules-are-leaves? rules call)
    (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
    (let [out (bindings-after-rule-call-with-fns db rules call binding registry)]
      (query-stats-observe-bindings! stats (count out))
      (return out)))
  (let [out (make [dynamic]Binding)
        seen (make (map string bool))
        depth 1
        min-depth (+ (count rules) 1)
        changed true]
    (defer (delete seen))
    (while (or changed (<= depth min-depth))
      (set! changed false)
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (let [candidates (bindings-after-rule-call-depth-with-fns db rules call binding depth call.source call.has-source registry)]
        (defer (delete candidates))
        (for [candidate candidates]
          (when (append-unique-binding! (addr out) (addr seen) candidate)
            (set! changed true))))
      (query-stats-observe-bindings! stats (count out))
      (set! depth (+ depth 1)))
    out))

(defn bindings-after-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (bindings-after-rule-call-with-fns db rules call binding ([]Native-Query-Fn [])))

(defn query-can-trust-unique-bindings? [query: Query] -> bool
  (when (not (and (= (count query.with) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .RuleCall)))
    (return false))
  (let [call query.rule-calls[query.where-steps[0].index]
        [_ ok] (linear-transitive-rule-attr (slice query.rules 0) call.name)]
    ok))

(defn bindings-after-or-branch-with-sources-and-fns [db: DB, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [initial (clone-binding binding)]
    (when group.has-join
      (set! initial (project-binding binding group.join-vars))
      (for [branch-clause branch.clauses]
        (let [has-source branch-clause.has-source]
          (when has-source
          (let [[source source-ok] (binding-lookup binding branch-clause.source)]
            (when source-ok
              (binding-store! (addr initial) branch-clause.source source)))))))
  (let [branch-bindings (bindings-after-clause-group-with-sources-and-fns db sources branch initial registry) :defer
        out (make [dynamic]Binding)]
    (for [branch-binding branch-bindings]
      (let [branch-output (if group.has-join (project-binding branch-binding group.join-vars) branch-binding)
            [merged ok] (merge-binding binding branch-output)]
        (when ok
          (arr.push! out merged))))
    out)))

(defn bindings-after-or-branch-with-sources [db: DB, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-or-branch-with-sources-and-fns db sources group branch binding ([]Native-Query-Fn [])))

(defn bindings-after-or-branch [db: DB, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-or-branch-with-sources db ([]DB-Source []) group branch binding))

(defn binding-matches-not-group-with-sources-and-fns? [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> bool
  (let [initial (clone-binding binding)]
    (when group.has-join
      (delete initial.items)
      (set! initial (project-binding binding group.join-vars)))
  (let [bindings ([dynamic]Binding [initial])]
    (for [clause group.clauses]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (append-bindings-after-clause-with-sources! (addr next-bindings) db sources clause candidate-binding))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (delete bindings)
          (return false))))
    (for [not-group group.not-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (for [candidate-binding bindings]
          (when (not (binding-matches-not-group-with-sources-and-fns? db sources not-group candidate-binding registry))
            (arr.push! next-bindings candidate-binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (delete bindings)
          (return false))))
    (let [matched (> (count bindings) 0)]
      (delete bindings)
      (return matched)))))

(defn binding-matches-not-group-with-sources? [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> bool
  (binding-matches-not-group-with-sources-and-fns? db sources group binding ([]Native-Query-Fn [])))

(defn binding-matches-not-group? [db: DB, group: Not-Group, binding: Binding] -> bool
  (binding-matches-not-group-with-sources? db ([]DB-Source []) group binding))

(defn query-expected-input-count [query-value: Query] -> int
  (if (> (count query-value.input-specs) 0)
    (count query-value.input-specs)
    (+ (count query-value.inputs)
       (count query-value.collection-inputs)
       (count query-value.tuple-inputs)
       (count query-value.relation-inputs))))

(defn query-source-input? [query-value: Query, source: string] -> bool
  (for [input query-value.inputs]
    (when (= input source)
      (return true)))
  (for [spec query-value.input-specs]
    (when (and (= spec.kind .Scalar)
               (= spec.name source))
      (return true)))
  false)

(defn query-source-db? [sources: []DB-Source, source: string] -> bool
  (for [item sources]
    (when (= item.name source)
      (return true)))
  false)

(defn query-source-known? [query-value: Query, sources: []DB-Source, source: string] -> bool
  (or (= source "$")
      (query-source-input? query-value source)
      (query-source-db? sources source)))

(defn validate-query-clause-source [query-value: Query, sources: []DB-Source, source: string] -> [ok: bool, error: string]
  (if (query-source-known? query-value sources source)
    (return true "")
    (return false (fmt.tprintf "unknown query source: %s" source))))

(defn validate-query-not-group-sources [query-value: Query, sources: []DB-Source, group: Not-Group] -> [ok: bool, error: string]
  (for [item group.clauses]
    (if item.has-source
      (let [[ok error] (validate-query-clause-source query-value sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [child group.not-groups]
    (let [[ok error] (validate-query-not-group-sources query-value sources child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-or-group-sources [query-value: Query, sources: []DB-Source, group: Or-Group] -> [ok: bool, error: string]
  (for [branch group.branches]
    (let [[ok error] (validate-query-not-group-sources query-value sources branch)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn query-input-index-for-source [query-value: Query, source: string] -> [index: int, ok: bool]
  (when (> (count query-value.input-specs) 0)
    (for [spec index query-value.input-specs]
      (when (and (= spec.kind .Scalar)
                 (= spec.name source))
        (return index true)))
    (return -1 false))
  (for [name index query-value.inputs]
    (when (= name source)
      (return index true)))
  (return -1 false))

(defn validate-source-input-value [query-value: Query, inputs: []Query-Input, sources: []DB-Source, source: string] -> [ok: bool, error: string]
  (when (or (= source "$") (query-source-db? sources source))
    (return true ""))
  (let [[index found] (query-input-index-for-source query-value source)]
    (when (not found)
      (return true ""))
    (when (>= index (count inputs))
      (return true ""))
    (let [input inputs[index]]
      (if (query-source-input-value? input)
        (return true "")
        (return false (fmt.tprintf "query source is not a collection: %s" source))))))

(defn validate-not-group-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, group: Not-Group] -> [ok: bool, error: string]
  (for [item group.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [child group.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, group: Or-Group] -> [ok: bool, error: string]
  (for [branch group.branches]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources branch)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-rule-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, rule: Rule] -> [ok: bool, error: string]
  (for [item rule.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [call rule.rule-calls]
    (when call.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources call.source)]
        (when (not ok)
          (return false error)))))
  (for [group rule.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [group rule.or-groups]
    (let [[ok error] (validate-or-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (for [item query-value.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [call query-value.rule-calls]
    (when call.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources call.source)]
        (when (not ok)
          (return false error)))))
  (for [group query-value.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [group query-value.or-groups]
    (let [[ok error] (validate-or-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [rule query-value.rules]
    (let [[ok error] (validate-rule-source-input-values query-value inputs sources rule)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-collection-input [input: Query-Input, name: string] -> [ok: bool, error: string]
  (if (or (= input.kind .Collection)
          (= input.kind .CollectionLookupRefs))
    (return true "")
    (return false (fmt.tprintf "cannot bind query input to collection %s" name))))

(defn validate-query-tuple-input [input: Query-Input, tuple: Tuple-Input] -> [ok: bool, error: string]
  (when (not (= input.kind .Collection))
    (return false "cannot bind query input to tuple"))
  (when (< (count input.values) (count tuple.vars))
    (return false "not enough values to bind tuple input"))
  (return true ""))

(defn validate-query-relation-input [input: Query-Input, relation: Relation-Input] -> [ok: bool, error: string]
  (when (= input.kind .Collection)
    (return true ""))
  (when (and (= input.kind .Scalar)
             (= input.value.kind .Map)
             (or (not (= relation.binding.kind .None))
                 (= (count relation.vars) 2)))
    (return true ""))
  (when (not (= input.kind .Relation))
    (return false "cannot bind query input to relation"))
  (when (not (= input.width (count relation.vars)))
    (return false "query relation input width mismatch"))
  (return true ""))

(defn validate-query-input-spec-value [spec: Query-Input-Spec, input: Query-Input] -> [ok: bool, error: string]
  (case spec.kind
    .Scalar (if (or (= input.kind .Scalar)
                    (= input.kind .PullPattern)
                    (and (query-source-input-name? spec.name)
                         (query-source-input-value? input)))
              (return true "")
              (return false (fmt.tprintf "cannot bind query input to scalar %s" spec.name)))
    .Collection (validate-query-collection-input input spec.name)
    .Tuple (validate-query-tuple-input input spec.tuple)
    .Relation (validate-query-relation-input input spec.relation)
    .Ignore (return true "")
    :else (return true "")))

(defn append-legacy-query-input-specs! [out: ^[dynamic]Query-Input-Spec, query-value: Query]
  (for [name query-value.inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Scalar name: name})))
  (for [name query-value.collection-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Collection name: name})))
  (for [tuple query-value.tuple-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Tuple tuple: tuple})))
  (for [relation query-value.relation-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Relation relation: relation}))))

(defn validate-query-input-values [query-value: Query, inputs: []Query-Input] -> [ok: bool, error: string]
  (let [specs (make [dynamic]Query-Input-Spec) :defer]
    (if (> (count query-value.input-specs) 0)
      (for [spec query-value.input-specs]
        (arr.push! specs spec))
      (append-legacy-query-input-specs! (addr specs) query-value))
    (for [spec index specs]
      (when (< index (count inputs))
        (let [[ok error] (validate-query-input-spec-value spec inputs[index])]
          (when (not ok)
            (return false error)))))
    (return true "")))

(defn query-clause-db [db: DB, sources: []DB-Source, clause-value: Clause] -> [clause-db: DB, ok: bool]
  (if clause-value.has-source
    (source-db-lookup db sources clause-value.source)
    (return db true)))

(defn validate-inline-lookup-ref-term [db: DB, term: Term] -> [ok: bool, error: string]
  (when (= term.kind .LookupRef)
    (let [[_ found lookup-error] (resolve-lookup-ref-checked db term.lookup-attr term.lookup-value)]
      (when (not found)
        (return false lookup-error))))
  (return true ""))

(defn validate-query-clause-inline-lookup-refs [db: DB, sources: []DB-Source, clause-value: Clause] -> [ok: bool, error: string]
  (let [[clause-db db-ok] (query-clause-db db sources clause-value)]
    (when (not db-ok)
      (return true ""))
    (let [[e-ok e-error] (validate-inline-lookup-ref-term clause-db clause-value.e)]
      (when (not e-ok)
        (return false e-error)))
    (let [[v-ok v-error] (validate-inline-lookup-ref-term clause-db clause-value.v)]
      (when (not v-ok)
        (return false v-error))))
  (return true ""))

(defn validate-not-group-inline-lookup-refs [db: DB, sources: []DB-Source, group: Not-Group] -> [ok: bool, error: string]
  (for [item group.clauses]
    (let [[ok error] (validate-query-clause-inline-lookup-refs db sources item)]
      (when (not ok)
        (return false error))))
  (for [child group.not-groups]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-inline-lookup-refs [db: DB, sources: []DB-Source, group: Or-Group] -> [ok: bool, error: string]
  (for [branch group.branches]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources branch)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-inline-lookup-refs [db: DB, query-value: Query, sources: []DB-Source] -> [ok: bool, error: string]
  (for [item query-value.clauses]
    (let [[ok error] (validate-query-clause-inline-lookup-refs db sources item)]
      (when (not ok)
        (return false error))))
  (for [group query-value.not-groups]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources group)]
      (when (not ok)
        (return false error))))
  (for [group query-value.or-groups]
    (let [[ok error] (validate-or-group-inline-lookup-refs db sources group)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn string-slice-contains? [items: []string, value: string] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn append-var-once! [vars: ^[dynamic]string, name: string]
  (when (= name "")
    (return))
  (when (not (string-slice-contains? (slice vars^ 0) name))
    (arr.push! vars^ name)))

(defn append-term-var! [vars: ^[dynamic]string, term: Term]
  (when (= term.kind .Var)
    (append-var-once! vars term.name)))

(defn append-input-binding-vars! [vars: ^[dynamic]string, binding: Input-Binding]
  (let [names (input-binding-vars binding) :defer]
    (for [name names]
      (append-var-once! vars name))))

(defn append-query-input-vars! [vars: ^[dynamic]string, query-value: Query]
  (for [name query-value.inputs]
    (append-var-once! vars name))
  (for [name query-value.collection-inputs]
    (append-var-once! vars name))
  (for [tuple query-value.tuple-inputs]
    (for [name tuple.vars]
      (append-var-once! vars name))
    (append-input-binding-vars! vars tuple.binding))
  (for [relation query-value.relation-inputs]
    (for [name relation.vars]
      (append-var-once! vars name))
    (append-input-binding-vars! vars relation.binding))
  (for [spec query-value.input-specs]
    (case spec.kind
      .Scalar (append-var-once! vars spec.name)
      .Collection (append-var-once! vars spec.name)
      .Tuple (do
        (for [name spec.tuple.vars]
          (append-var-once! vars name))
        (append-input-binding-vars! vars spec.tuple.binding))
      .Relation (do
        (for [name spec.relation.vars]
          (append-var-once! vars name))
        (append-input-binding-vars! vars spec.relation.binding))
      .Ignore (do)
      :else (do))))

(defn append-clause-vars! [vars: ^[dynamic]string, clause: Clause]
  (append-term-var! vars clause.e)
  (append-term-var! vars clause.a)
  (append-term-var! vars clause.v)
  (append-term-var! vars clause.tx-term)
  (append-term-var! vars clause.op-term))

(defn append-not-group-vars! [vars: ^[dynamic]string, group: Not-Group]
  (for [clause group.clauses]
    (append-clause-vars! vars clause))
  (for [child group.not-groups]
    (append-not-group-vars! vars child))
  (for [name group.join-vars]
    (append-var-once! vars name)))

(defn append-or-group-vars! [vars: ^[dynamic]string, group: Or-Group]
  (for [branch group.branches]
    (append-not-group-vars! vars branch))
  (for [name group.join-vars]
    (append-var-once! vars name)))

(defn append-rule-call-vars! [vars: ^[dynamic]string, call: Rule-Call]
  (for [arg call.args]
    (append-term-var! vars arg)))

(defn append-ground-output-vars! [vars: ^[dynamic]string, ground: Ground]
  (append-var-once! vars ground.out)
  (for [name ground.tuple-vars]
    (append-var-once! vars name))
  (append-input-binding-vars! vars ground.binding))

(defn append-function-output-vars! [vars: ^[dynamic]string, function: Function-Clause]
  (append-var-once! vars function.out)
  (for [name function.out-vars]
    (append-var-once! vars name))
  (append-input-binding-vars! vars function.out-binding))

(defn append-predicate-vars! [vars: ^[dynamic]string, predicate: Predicate]
  (when (query-var-name? predicate.op)
    (append-var-once! vars predicate.op))
  (for [term predicate.terms]
    (append-term-var! vars term)))

(defn append-function-vars! [vars: ^[dynamic]string, function: Function-Clause]
  (when (query-var-name? function.op)
    (append-var-once! vars function.op))
  (for [term function.terms]
    (append-term-var! vars term))
  (append-function-output-vars! vars function))

(defn append-get-else-vars! [vars: ^[dynamic]string, clause: Get-Else]
  (append-term-var! vars clause.e)
  (append-var-once! vars clause.out))

(defn append-get-some-vars! [vars: ^[dynamic]string, clause: Get-Some]
  (append-term-var! vars clause.e)
  (append-var-once! vars clause.out-attr)
  (append-var-once! vars clause.out-value))

(defn append-find-vars! [vars: ^[dynamic]string, query-value: Query]
  (for [name query-value.find]
    (append-var-once! vars name))
  (for [pull-find query-value.pulls]
    (append-var-once! vars pull-find.var)
    (when pull-find.has-pattern-var
      (append-var-once! vars pull-find.pattern-var)))
  (for [aggregate query-value.aggregates]
    (append-var-once! vars aggregate.var)
    (for [arg aggregate.args]
      (append-term-var! vars arg))
    (when aggregate.has-function-var
      (append-var-once! vars aggregate.function-var))
    (when aggregate.has-limit-var
      (append-var-once! vars aggregate.limit-var))))

(defn query-var-list-text [vars: []string] -> string
  (let [inner (make [dynamic]string) :defer]
    (for [name vars]
      (arr.push! inner name))
    (let [[joined _] (core-strings.join (slice inner 0) " ")]
      (core-strings.concatenate ([]string ["[" joined "]"])))))

(defn query-potential-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-query-input-vars! (addr vars) query-value)
    (for [clause query-value.clauses]
      (append-clause-vars! (addr vars) clause))
    (for [call query-value.rule-calls]
      (append-rule-call-vars! (addr vars) call))
    (for [predicate query-value.predicates]
      (append-predicate-vars! (addr vars) predicate))
    (for [function query-value.function-clauses]
      (append-function-vars! (addr vars) function))
    (for [get-else query-value.get-elses]
      (append-get-else-vars! (addr vars) get-else))
    (for [get-some query-value.get-somes]
      (append-get-some-vars! (addr vars) get-some))
    (for [ground query-value.grounds]
      (append-ground-output-vars! (addr vars) ground))
    (for [group query-value.not-groups]
      (append-not-group-vars! (addr vars) group))
    (for [group query-value.or-groups]
      (append-or-group-vars! (addr vars) group))
    vars))

(defn query-positive-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-query-input-vars! (addr vars) query-value)
    (for [clause query-value.clauses]
      (append-clause-vars! (addr vars) clause))
    (for [call query-value.rule-calls]
      (append-rule-call-vars! (addr vars) call))
    (for [ground query-value.grounds]
      (append-ground-output-vars! (addr vars) ground))
    (for [get-else query-value.get-elses]
      (append-get-else-vars! (addr vars) get-else))
    (for [get-some query-value.get-somes]
      (append-get-some-vars! (addr vars) get-some))
    (for [function query-value.function-clauses]
      (append-function-output-vars! (addr vars) function))
    vars))

(defn query-input-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-query-input-vars! (addr vars) query-value)
    vars))

(defn append-query-input-vars-raw! [vars: ^[dynamic]string, query-value: Query]
  (when (> (count query-value.input-specs) 0)
    (for [spec query-value.input-specs]
      (case spec.kind
        .Scalar (when (not (= spec.name ""))
                  (arr.push! vars^ spec.name))
        .Collection (when (not (= spec.name ""))
                      (arr.push! vars^ spec.name))
        .Tuple (for [name spec.tuple.vars]
                 (when (not (= name ""))
                   (arr.push! vars^ name)))
        .Relation (for [name spec.relation.vars]
                    (when (not (= name ""))
                      (arr.push! vars^ name)))
        .Ignore (do)
        :else (do)))
    (return))
  (for [name query-value.inputs]
    (when (not (= name ""))
      (arr.push! vars^ name)))
  (for [name query-value.collection-inputs]
    (when (not (= name ""))
      (arr.push! vars^ name)))
  (for [tuple query-value.tuple-inputs]
    (for [name tuple.vars]
      (when (not (= name ""))
        (arr.push! vars^ name))))
  (for [relation query-value.relation-inputs]
    (for [name relation.vars]
      (when (not (= name ""))
        (arr.push! vars^ name))))
  (do))

(defn query-input-vars-raw [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-query-input-vars-raw! (addr vars) query-value)
    vars))

(defn query-find-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-find-vars! (addr vars) query-value)
    vars))

(defn validate-query-parser-vars [query-value: Query] -> [ok: bool, error: string]
  (let [find-vars (query-find-vars query-value) :defer
        available (query-potential-vars query-value) :defer
        unknown (make [dynamic]string) :defer]
    (for [name find-vars]
      (when (not (string-slice-contains? (slice available 0) name))
        (append-var-once! (addr unknown) name)))
    (for [name query-value.with]
      (when (not (string-slice-contains? (slice available 0) name))
        (append-var-once! (addr unknown) name)))
    (when (> (count unknown) 0)
      (let [vars-text (query-var-list-text (slice unknown 0)) :defer]
        (return false (fmt.tprintf "Query for unknown vars: %s" vars-text))))
    (for [name find-vars]
      (when (string-slice-contains? (slice query-value.with 0) name)
        (return false (fmt.tprintf ":find and :with should not use same variables: %s" name)))))
  (let [input-vars (query-input-vars-raw query-value) :defer]
    (when (string-slice-has-duplicate? (slice input-vars 0))
      (return false "Vars used in :in should be distinct")))
  (when (string-slice-has-duplicate? (slice query-value.with 0))
    (return false "Vars used in :with should be distinct"))
  (when (and (> (count query-value.rule-calls) 0)
             (not query-value.has-rules-input))
    (return false "Missing rules var '%' in :in"))
  (return true ""))

(defn string-slices-intersect? [left: []string, right: []string] -> bool
  (for [item left]
    (when (string-slice-contains? right item)
      (return true)))
  false)

(defn append-unbound-vars! [out: ^[dynamic]string, vars: []string, available: []string]
  (for [name vars]
    (when (not (string-slice-contains? available name))
      (append-var-once! out name))))

(defn string-slices-same-set? [left: []string, right: []string] -> bool
  (for [item left]
    (when (not (string-slice-contains? right item))
      (return false)))
  (for [item right]
    (when (not (string-slice-contains? left item))
      (return false)))
  true)

(defn validate-not-group-bindings [available: []string, group: Not-Group] -> [ok: bool, error: string]
  (let [vars (make [dynamic]string) :defer]
    (append-not-group-vars! (addr vars) group)
    (when (and (> (count vars) 0)
               (not (string-slices-intersect? (slice vars 0) available)))
      (return false (fmt.tprintf "insufficient bindings for not: %s" vars[0])))
    (when group.has-join
      (for [name group.join-vars]
        (when (not (string-slice-contains? available name))
          (return false (fmt.tprintf "insufficient bindings for not-join: %s" name)))))
    (for [child group.not-groups]
      (let [[ok error] (validate-not-group-bindings available child)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn or-branch-unbound-vars [branch: Not-Group, available: []string, join-vars: []string] -> [dynamic]string
  (let [branch-vars (make [dynamic]string) :defer
        blocked (arr.into [dynamic]string available) :defer
        out (make [dynamic]string)]
    (for [name join-vars]
      (append-var-once! (addr blocked) name))
    (append-not-group-vars! (addr branch-vars) branch)
    (append-unbound-vars! (addr out) (slice branch-vars 0) (slice blocked 0))
    out))

(defn validate-or-branch-child-not-bindings [available: []string, branch: Not-Group] -> [ok: bool, error: string]
  (for [child branch.not-groups]
    (let [[ok error] (validate-not-group-bindings available child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-bindings [available: []string, group: Or-Group] -> [ok: bool, error: string]
  (when (= (count group.branches) 0)
    (return false "or requires at least one branch"))
  (let [join-vars (if group.has-join (slice group.join-vars 0) ([]string []))
        expected (or-branch-unbound-vars group.branches[0] available join-vars)]
    (defer (delete expected))
    (for [branch index group.branches]
      (let [vars (or-branch-unbound-vars branch available join-vars)]
        (defer (delete vars))
        (when (and (not group.has-join)
                   (not (string-slices-same-set? (slice expected 0) (slice vars 0))))
          (return false "or branches must use same vars"))
        (let [[ok error] (validate-or-branch-child-not-bindings available branch)]
          (when (not ok)
            (return false error)))))
    (when group.has-join
      (for [name group.join-vars]
        (for [branch group.branches]
          (let [branch-vars (make [dynamic]string) :defer]
            (append-not-group-vars! (addr branch-vars) branch)
            (when (and (not (string-slice-contains? available name))
                       (not (string-slice-contains? (slice branch-vars 0) name)))
              (return false (fmt.tprintf "or-join branch missing join var: %s" name))))))))
  (return true ""))

(defn validate-query-not-or-bindings [query-value: Query] -> [ok: bool, error: string]
  (let [available (query-positive-vars query-value)
        input-vars (query-input-vars query-value)]
    (defer (delete available))
    (defer (delete input-vars))
    (for [group query-value.not-groups]
      (let [[ok error] (validate-not-group-bindings (slice available 0) group)]
        (when (not ok)
          (return false error))))
    (for [group query-value.or-groups]
      (let [[ok error] (validate-or-group-bindings (slice input-vars 0) group)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn append-query-step-output-vars! [available: ^[dynamic]string, query-value: Query, step: Query-Step]
  (case step.kind
    .Clause (append-clause-vars! available query-value.clauses[step.index])
    .RuleCall (append-rule-call-vars! available query-value.rule-calls[step.index])
    .Ground (append-ground-output-vars! available query-value.grounds[step.index])
    .Function (append-function-output-vars! available query-value.function-clauses[step.index])
    .Or (if query-value.or-groups[step.index].has-join
          (for [name query-value.or-groups[step.index].join-vars]
            (append-var-once! available name))
          (append-or-group-vars! available query-value.or-groups[step.index]))
    :else (do)))

(defn predicate-op-supported-with-fns? [op: string, registry: []Native-Query-Fn] -> bool
  (or (predicate-op-supported? op)
      (query-fn-supported? registry op)))

(defn function-op-supported-with-fns? [op: string, registry: []Native-Query-Fn] -> bool
  (or (function-op-supported? op)
      (query-fn-supported? registry op)))

(defn validate-query-ordered-step-with-fns [available: ^[dynamic]string, query-value: Query, step: Query-Step, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (case step.kind
    .Predicate (let [predicate query-value.predicates[step.index]]
                 (when (not (predicate-op-supported-with-fns? predicate.op registry))
                   (return false (fmt.tprintf "unknown query predicate: %s" predicate.op)))
                 (when (and (query-var-name? predicate.op)
                            (not (string-slice-contains? (slice available^ 0) predicate.op)))
                   (return false (fmt.tprintf "insufficient bindings for %s: %s" predicate.op predicate.op)))
                 (let [[ok error] (validate-term-vars-bound (slice available^ 0) predicate.terms predicate.op)]
                   (when (not ok)
                     (return false error))))
    .Function (let [function query-value.function-clauses[step.index]]
                (when (not (function-op-supported-with-fns? function.op registry))
                  (return false (fmt.tprintf "unknown query function: %s" function.op)))
                (when (and (query-var-name? function.op)
                           (not (string-slice-contains? (slice available^ 0) function.op)))
                  (return false (fmt.tprintf "insufficient bindings for %s: %s" function.op function.op)))
                (let [[ok error] (validate-term-vars-bound (slice available^ 0) function.terms function.op)]
                  (when (not ok)
                    (return false error))))
    .Not (let [[ok error] (validate-not-group-bindings (slice available^ 0) query-value.not-groups[step.index])]
           (when (not ok)
             (return false error)))
    .Or (let [[ok error] (validate-or-group-bindings (slice available^ 0) query-value.or-groups[step.index])]
          (when (not ok)
            (return false error)))
    .RuleCall (let [call query-value.rule-calls[step.index]
                    [ok error] (validate-rule-call-required-bindings (slice available^ 0) (slice query-value.rules 0) call)]
                (when (not ok)
                  (return false error)))
    :else (do))
  (append-query-step-output-vars! available query-value step)
  (return true ""))

(defn validate-query-ordered-step [available: ^[dynamic]string, query-value: Query, step: Query-Step] -> [ok: bool, error: string]
  (validate-query-ordered-step-with-fns available query-value step ([]Native-Query-Fn [])))

(defn validate-query-ordered-bindings-with-fns [query-value: Query, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [available (query-input-vars query-value)]
    (defer (delete available))
    (for [step query-value.where-steps]
      (let [[ok error] (validate-query-ordered-step-with-fns (addr available) query-value step registry)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn validate-query-ordered-bindings [query-value: Query] -> [ok: bool, error: string]
  (validate-query-ordered-bindings-with-fns query-value ([]Native-Query-Fn [])))

(defn predicate-op-supported? [op: string] -> bool
  (or (query-var-name? op)
      (= op "=")
      (= op "!=")
      (= op "not=")
      (= op ">")
      (= op "<")
      (= op ">=")
      (= op "<=")
      (= op "true?")
      (= op "false?")
      (= op "nil?")
      (= op "some?")
      (= op "not")
      (= op "empty?")
      (= op "even?")
      (= op "odd?")
      (= op "zero?")
      (= op "pos?")
      (= op "neg?")
      (= op "re-find")
      (= op "contains?")
      (= op "clojure.string/includes?")
      (= op "clojure.string/starts-with?")
      (= op "clojure.string/ends-with?")))

(defn function-op-supported? [op: string] -> bool
  (or (query-var-name? op)
      (= op "count")
      (= op "identity")
      (= op "ground")
      (= op "inc")
      (= op "dec")
      (= op "range")
      (= op "name")
      (= op "subs")
      (= op "re-pattern")
      (= op "re-find")
      (= op "str")
      (= op "keyword")
      (= op "first")
      (= op "second")
      (= op "vector")
      (= op "tuple")
      (= op "untuple")
      (= op "hash-map")
      (= op "get")
      (= op "contains?")
      (= op "clojure.string/includes?")
      (= op "clojure.string/starts-with?")
      (= op "clojure.string/ends-with?")
      (= op "+")
      (= op "-")
      (= op "*")
      (= op "/")
      (= op "quot")
      (= op "rem")
      (= op "mod")
      (= op "min")
      (= op "max")
      (= op "compare")))

(defn validate-term-vars-bound [available: []string, terms: []Term, ctx: string] -> [ok: bool, error: string]
  (for [term terms]
    (when (and (= term.kind .Var)
               (not (string-slice-contains? available term.name)))
      (return false (fmt.tprintf "insufficient bindings for %s: %s" ctx term.name))))
  (return true ""))

(defn validate-query-predicates-and-functions-with-fns [query-value: Query, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [available (query-potential-vars query-value)]
    (defer (delete available))
    (for [function query-value.function-clauses]
      (when (not (function-op-supported-with-fns? function.op registry))
        (return false (fmt.tprintf "unknown query function: %s" function.op)))
      (when (and (query-var-name? function.op)
                 (not (string-slice-contains? (slice available 0) function.op)))
        (return false (fmt.tprintf "insufficient bindings for %s: %s" function.op function.op)))
      (let [[ok error] (validate-term-vars-bound (slice available 0) function.terms function.op)]
        (when (not ok)
          (return false error)))
      (append-function-output-vars! (addr available) function))
    (for [predicate query-value.predicates]
      (when (not (predicate-op-supported-with-fns? predicate.op registry))
        (return false (fmt.tprintf "unknown query predicate: %s" predicate.op)))
      (when (and (query-var-name? predicate.op)
                 (not (string-slice-contains? (slice available 0) predicate.op)))
        (return false (fmt.tprintf "insufficient bindings for %s: %s" predicate.op predicate.op)))
      (let [[ok error] (validate-term-vars-bound (slice available 0) predicate.terms predicate.op)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn validate-query-predicates-and-functions [query-value: Query] -> [ok: bool, error: string]
  (validate-query-predicates-and-functions-with-fns query-value ([]Native-Query-Fn [])))

(defn validate-query-get-elses [query-value: Query] -> [ok: bool, error: string]
  (for [get-else query-value.get-elses]
    (when (= get-else.default-value.kind .Nil)
      (return false "get-else: nil default value is not supported")))
  (for [rule query-value.rules]
    (for [get-else rule.get-elses]
      (when (= get-else.default-value.kind .Nil)
        (return false "get-else: nil default value is not supported"))))
  (return true ""))

(defn validate-query-sources [query-value: Query, sources: []DB-Source] -> [ok: bool, error: string]
  (for [item query-value.clauses]
    (if item.has-source
      (let [[ok error] (validate-query-clause-source query-value sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [item query-value.rule-calls]
    (if item.has-source
      (let [[ok error] (validate-query-clause-source query-value sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [item query-value.pulls]
    (if item.has-source
      (let [[ok error] (validate-query-clause-source query-value sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [group query-value.not-groups]
    (let [[ok error] (validate-query-not-group-sources query-value sources group)]
      (when (not ok)
        (return false error))))
  (for [group query-value.or-groups]
    (let [[ok error] (validate-query-or-group-sources query-value sources group)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn rule-param-valid? [name: string] -> bool
  (strings.has_prefix name "?"))

(defn rule-call-matches-rule? [call: Rule-Call, rule: Rule] -> bool
  (and (= call.name rule.name)
       (= (count call.args) (count rule.params))))

(defn string-slice-has-duplicate? [items: []string] -> bool
  (for [item index items]
    (for [other-index (arr.range (+ index 1) (count items))]
      (when (= item items[other-index])
        (return true))))
  false)

(defn validate-rule-call-known [rules: []Rule, call: Rule-Call] -> [ok: bool, error: string]
  (let [name-found false]
    (for [rule rules]
      (when (= call.name rule.name)
        (set! name-found true)
        (when (rule-call-matches-rule? call rule)
          (return true ""))))
    (if name-found
      (return false (fmt.tprintf "wrong arity for rule: %s" call.name))
      (return false (fmt.tprintf "unknown rule: %s" call.name)))))

(defn validate-rule-definition [rules: []Rule, rule: Rule] -> [ok: bool, error: string]
  (when (= (count rule.body-steps) 0)
    (return false "Rule branch should have clauses"))
  (when (string-slice-has-duplicate? (slice rule.params 0))
    (return false "Rule variables should be distinct"))
  (for [other rules]
    (when (= other.name rule.name)
      (when (or (not (= other.required-param-count rule.required-param-count))
                (not (= (count other.params) (count rule.params))))
        (return false (fmt.tprintf "Arity mismatch for rule: %s" rule.name)))))
  (for [param rule.params]
    (when (not (rule-param-valid? param))
      (return false (fmt.tprintf "rule params must be variables: %s" param))))
  (for [call rule.rule-calls]
    (let [[ok error] (validate-rule-call-known rules call)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-rule-call-required-bindings [available: []string, rules: []Rule, call: Rule-Call] -> [ok: bool, error: string]
  (for [rule rules]
    (when (rule-call-matches-rule? call rule)
      (for [index (arr.range 0 rule.required-param-count)]
        (let [arg call.args[index]]
          (when (= arg.kind .Wildcard)
            (return false (fmt.tprintf "insufficient bindings for rule: %s" call.name)))
          (when (and (= arg.kind .Var)
                     (not (string-slice-contains? available arg.name)))
            (return false (fmt.tprintf "insufficient bindings for rule: %s" arg.name)))))))
  (return true ""))

(defn validate-query-rules [query-value: Query] -> [ok: bool, error: string]
  (for [rule query-value.rules]
    (let [[ok error] (validate-rule-definition (slice query-value.rules 0) rule)]
      (when (not ok)
        (return false error))))
  (for [call query-value.rule-calls]
    (let [[ok error] (validate-rule-call-known (slice query-value.rules 0) call)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-pull-patterns [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (for [pull-find query-value.pulls]
    (let [[pull-db pull-db-ok] (pull-db-for-find db sources pull-find)]
      (when (not pull-db-ok)
        (return false "unknown pull source"))
      (let [[pattern pattern-ok] (pull-find-pattern query-value inputs pull-find)]
        (when (not pattern-ok)
          (return false "pull pattern input must be a pull pattern"))
        (let [[pattern-valid pattern-error] (validate-pull-pattern pull-db pattern)]
          (when (not pattern-valid)
            (return false pattern-error))))))
  (return true ""))

(defn validate-query-call-with-fns [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [expected (query-expected-input-count query-value)
        provided (count inputs)]
    (when (not (= expected provided))
      (return false (fmt.tprintf "wrong number of query inputs: expected %d, got %d" expected provided))))
  (let [[parser-ok parser-error] (validate-query-parser-vars query-value)]
    (when (not parser-ok)
      (return false parser-error)))
  (let [[source-ok source-error] (validate-query-sources query-value sources)]
    (when (not source-ok)
      (return false source-error)))
  (let [[source-input-ok source-input-error] (validate-query-source-input-values query-value inputs sources)]
    (when (not source-input-ok)
      (return false source-input-error)))
  (let [[input-ok input-error] (validate-query-input-values query-value inputs)]
    (when (not input-ok)
      (return false input-error)))
  (let [[pull-ok pull-error] (validate-query-pull-patterns db query-value inputs sources)]
    (when (not pull-ok)
      (return false pull-error)))
  (let [[lookup-ok lookup-error] (validate-query-inline-lookup-refs db query-value sources)]
    (when (not lookup-ok)
      (return false lookup-error)))
  (let [[rules-ok rules-error] (validate-query-rules query-value)]
    (when (not rules-ok)
      (return false rules-error)))
  (if (> (count query-value.where-steps) 0)
    (do
      (let [[get-else-ok get-else-error] (validate-query-get-elses query-value)]
        (when (not get-else-ok)
          (return false get-else-error)))
      (validate-query-ordered-bindings-with-fns query-value registry))
    (do
      (let [[get-else-ok get-else-error] (validate-query-get-elses query-value)]
        (when (not get-else-ok)
          (return false get-else-error)))
      (let [[binding-ok binding-error] (validate-query-not-or-bindings query-value)]
        (when (not binding-ok)
          (return false binding-error)))
      (validate-query-predicates-and-functions-with-fns query-value registry))))

(defn validate-query-call [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (validate-query-call-with-fns db query-value inputs sources ([]Native-Query-Fn [])))

(defn aggregate-initial-value [aggregate: Aggregate-Find] -> Value
  (if (or (= aggregate.op "count")
          (= aggregate.op "count-distinct")
          (= aggregate.op "sum")
          (= aggregate.op "avg")
          (= aggregate.op "median")
          (= aggregate.op "variance")
          (= aggregate.op "stddev"))
    (value-int 0)
    (Value {})))

(defn sort-i64! [values: ^[dynamic]i64]
  // ponytail: insertion sort is enough for current aggregate tests; replace if aggregate benches care.
  (for [i (arr.range 1 (count values^))]
    (let [current values^[i]
          j i]
      (while (and (> j 0)
                  (< current values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] current))))

(defn sort-values! [values: ^[dynamic]Value]
  (for [i (arr.range 1 (count values^))]
    (let [current values^[i]
          j i]
      (while (and (> j 0)
                  (value-less? current values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] current))))

(defn top-n-values [values: []Value, limit: int, max?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (let [take-count (min limit (count sorted))
          start (if max? (- (count sorted) take-count) 0)]
      (for [index (arr.range start (+ start take-count))]
        (arr.push! out sorted[index]))
      (Value {kind: .Vector items: out}))))

(defn sorted-values-vector [values: []Value, descending?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (if descending?
      (let [index (count sorted)]
        (while (> index 0)
          (set! index (- index 1))
          (arr.push! out sorted[index])))
      (for [value sorted]
        (arr.push! out value)))
    (Value {kind: .Vector items: out})))

(defn median-int [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sorted (arr.into [dynamic]i64 values)]
    (defer (delete sorted))
    (sort-i64! (addr sorted))
    (let [mid (/ (count sorted) 2)]
      (if (= (% (count sorted) 2) 1)
        (value-int sorted[mid])
        (value-int (/ (+ sorted[(- mid 1)] sorted[mid]) 2))))))

(defn variance-int [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sum: i64 0]
    (for [value values]
      (set! sum (+ sum value)))
    (let [mean (/ sum (i64 (count values)))
          squared: i64 0]
      (for [value values]
        (let [diff (- value mean)]
          (set! squared (+ squared (* diff diff)))))
      (value-int (/ squared (i64 (count values)))))))

(defn stddev-float [values: []i64] -> Value
  (let [variance (variance-int values)]
    (value-float (math.sqrt (f64 variance.int-value)))))

(defn aggregate-function-name [binding: Binding, aggregate: Aggregate-Find] -> [name: string, ok: bool]
  (when (not aggregate.has-function-var)
    (return "" false))
  (let [[value ok] (binding-lookup binding aggregate.function-var)]
    (when (not ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true)))
  (return "" false))

(defn apply-named-aggregate [name: string, values: []Value] -> [value: Value, ok: bool]
  (cond
    (or (= name "sort-reverse")
        (= name ":sort-reverse")) (return (sorted-values-vector values true) true)
    (or (= name "sort")
        (= name ":sort")) (return (sorted-values-vector values false) true)
    :else (return (Value {}) false)))

(defn apply-named-aggregate-with-fns [name: string, values: []Value, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[builtin builtin-ok] (apply-named-aggregate name values)]
    (when builtin-ok
      (return builtin true)))
  (let [[index found] (query-fn-index registry name)]
    (when (not found)
      (return (Value {}) false))
    (let [entry registry[index]]
      (when entry.has-aggregate-callback
        (let [result (entry.aggregate-callback values)]
          (return result.value result.ok)))
      (when (> (count entry.target) 0)
        (return (apply-named-aggregate entry.target values)))))
  (return (Value {}) false))

(defn apply-aggregate-value [current: Value, aggregate: Aggregate-Find, value: Value] -> Value
  (when (or (= aggregate.op "count")
            (= aggregate.op "count-distinct"))
    (return (value-int (+ current.int-value 1))))
  (when (or (= aggregate.op "sum")
            (= aggregate.op "avg"))
    (when (= value.kind .Int)
      (if (= current.kind .Float)
        (return (value-float (+ current.float-value (f64 value.int-value))))
        (return (value-int (+ current.int-value value.int-value)))))
    (when (= value.kind .Float)
      (if (= current.kind .Float)
        (return (value-float (+ current.float-value value.float-value)))
        (return (value-float (+ (f64 current.int-value) value.float-value))))))
  (when (= current.kind .Nil)
    (return value))
  (if (= aggregate.op "min")
    (if (value-less? value current) value current)
    (if (= aggregate.op "max")
      (if (value-less? current value) value current)
      current)))

(defn binding-values-for-vars [binding: Binding, names: []string] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value 0 (count names))]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-key-values [binding: Binding, query: Query, aggregate: Aggregate-Find] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query.find]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (for [name query.with]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (if (> (count aggregate.args) 0)
      (for [arg aggregate.args]
        (let [[value ok] (resolve-term arg binding)]
          (if ok
            (arr.push! out value)
            (return out false))))
      (let [[value ok] (binding-lookup binding aggregate.var)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-key-row [values: []Value] -> Result-Row
  (let [stored (arr.into [dynamic]Value values)
        pulls (make [dynamic]Pull-Result)]
    (Result-Row {values: stored pulls: pulls})))

(defn aggregate-value-for-group-with-fns [bindings: []Binding, query: Query, aggregate: Aggregate-Find, group-values: []Value, registry: []Native-Query-Fn] -> Value
  (let [current (aggregate-initial-value aggregate)
        avg-count: i64 0
        resolved-limit aggregate.limit
        aggregate-ints (make [dynamic]i64)
        aggregate-values (make [dynamic]Value)
        distinct-values (make [dynamic]Value)
        seen-keys (make [dynamic]Result-Row)
        custom-name ""
        custom-name-ok false]
    (defer (delete aggregate-ints))
    (defer (delete aggregate-values))
    (defer (delete distinct-values))
    (defer (delete seen-keys))
    (for [binding bindings]
      (let [[binding-group ok] (binding-values-for-vars binding (slice query.find 0))]
        (when (and ok (values-equal? (slice binding-group 0) group-values))
          (when aggregate.has-limit-var
            (let [[limit-value limit-ok] (binding-lookup binding aggregate.limit-var)]
              (when (and limit-ok (= limit-value.kind .Int))
                (set! resolved-limit (int limit-value.int-value)))))
          (let [[key key-ok] (aggregate-key-values binding query aggregate)]
            (when (and key-ok (not (row-values-exist? (slice seen-keys 0) (slice key 0))))
              (arr.push! seen-keys (aggregate-key-row (slice key 0)))
              (let [[value has-value] (binding-lookup binding aggregate.var)]
                (when has-value
                  (if (= aggregate.op "count")
                    (set! current.int-value (+ current.int-value 1))
                    (if (= aggregate.op "count-distinct")
                      (when (not (value-exists? (slice distinct-values 0) value))
                        (arr.push! distinct-values value))
                      (do
                        (when (and (or (= aggregate.op "median")
                                       (= aggregate.op "variance")
                                       (= aggregate.op "stddev"))
                                   (= value.kind .Int))
                          (arr.push! aggregate-ints value.int-value))
                        (when (and (or aggregate.has-limit aggregate.has-limit-var)
                                   (or (= aggregate.op "min")
                                       (= aggregate.op "max")))
                          (arr.push! aggregate-values value))
                        (when (= aggregate.op "aggregate")
                          (arr.push! aggregate-values value)
                          (when (not custom-name-ok)
                            (let [[name name-ok] (aggregate-function-name binding aggregate)]
                              (when name-ok
                                (set! custom-name name)
                                (set! custom-name-ok true)))))
                        (when (and (= aggregate.op "avg")
                                   (or (= value.kind .Int)
                                       (= value.kind .Float)))
                          (set! avg-count (+ avg-count 1)))
                        (set! current (apply-aggregate-value current aggregate value))))))))))))
    (when (= aggregate.op "count-distinct")
      (return (value-int (i64 (count distinct-values)))))
    (when (and (or aggregate.has-limit aggregate.has-limit-var)
               (or (= aggregate.op "min")
                   (= aggregate.op "max")))
      (return (top-n-values (slice aggregate-values 0) resolved-limit (= aggregate.op "max"))))
    (when (and (= aggregate.op "avg") (> avg-count 0))
      (if (= current.kind .Float)
        (return (value-float (/ current.float-value (f64 avg-count))))
        (if (= (% current.int-value avg-count) 0)
          (return (value-int (/ current.int-value avg-count)))
          (return (value-float (/ (f64 current.int-value) (f64 avg-count)))))))
    (when (= aggregate.op "median")
      (return (median-int (slice aggregate-ints 0))))
    (when (= aggregate.op "variance")
      (return (variance-int (slice aggregate-ints 0))))
    (when (= aggregate.op "stddev")
      (return (stddev-float (slice aggregate-ints 0))))
    (when (= aggregate.op "aggregate")
      (let [[value ok] (apply-named-aggregate-with-fns custom-name (slice aggregate-values 0) registry)]
        (when ok
          (return value))))
    current))

(defn aggregate-value-for-group [bindings: []Binding, query: Query, aggregate: Aggregate-Find, group-values: []Value] -> Value
  (aggregate-value-for-group-with-fns bindings query aggregate group-values ([]Native-Query-Fn [])))

(defn pull-pattern-input [query: Query, inputs: []Query-Input, name: string] -> [pattern: []Pull-Spec, ok: bool]
  (for [input-name index query.inputs]
    (when (= input-name name)
      (when (and (< index (count inputs))
                 (= inputs[index].kind .PullPattern))
        (return inputs[index].pattern true))
      (return ([]Pull-Spec []) false)))
  (return ([]Pull-Spec []) false))

(defn pull-find-pattern [query: Query, inputs: []Query-Input, pull-find: Pull-Find] -> [pattern: []Pull-Spec, ok: bool]
  (if pull-find.has-pattern-var
    (pull-pattern-input query inputs pull-find.pattern-var)
    (return pull-find.pattern true)))

(defn pull-db-for-find [db: DB, sources: []DB-Source, pull-find: Pull-Find] -> [pull-db: DB, ok: bool]
  (if pull-find.has-source
    (source-db-lookup db sources pull-find.source)
    (return db true)))

(defn pull-entity-from-value [db: DB, value: Value] -> [entity: u64, ok: bool]
  (cond
    (= value.kind .Entity) (return value.entity true)
    (= value.kind .Int) (return (u64 value.int-value) true)
    (= value.kind .Keyword)
      (schema-entity-for-attr db value.text)
    (and (= value.kind .Vector)
         (= (count value.items) 2)
         (= value.items[0].kind .Keyword))
      (resolve-lookup-ref db value.items[0].text value.items[1])
    :else (return 0 false)))

(defn pulls-for-binding-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, binding: Binding, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (let [out (make [dynamic]Pull-Result 0 (count query.pulls))]
    (for [pull-find query.pulls]
      (let [[entity-value ok] (binding-lookup binding pull-find.var)]
        (if ok
          (let [[pattern pattern-ok] (pull-find-pattern query inputs pull-find)
                [pull-db pull-db-ok] (pull-db-for-find db sources pull-find)
                entity: u64 0
                entity-ok false]
            (when pull-db-ok
              (let [[resolved resolved-ok] (pull-entity-from-value pull-db entity-value)]
                (set! entity resolved)
                (set! entity-ok resolved-ok)))
            (if (and pattern-ok pull-db-ok)
              (if entity-ok
                (arr.push! out (pull-pattern-spec-with-fns pull-db entity pattern registry))
                (return out false))
              (return out false)))
          (return out false))))
    (return out true)))

(defn pulls-for-binding-with-sources [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (pulls-for-binding-with-sources-and-fns db sources query inputs binding ([]Native-Query-Fn [])))

(defn pulls-for-binding [db: DB, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (pulls-for-binding-with-sources db ([]DB-Source []) query inputs binding))

(defn append-aggregate-rows-with-sources-and-fns! [rows: ^[dynamic]Result-Row, db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn]
  (for [binding bindings]
    (let [[group-values ok] (binding-values-for-vars binding (slice query.find 0))]
      (when ok
        (when (not (row-value-prefix-exists? (slice rows^ 0) (slice group-values 0)))
          (let [values (arr.into [dynamic]Value (slice group-values 0))
                [pulls pulls-ok] (pulls-for-binding-with-sources-and-fns db sources query inputs binding registry)]
            (when (not pulls-ok)
              (delete pulls)
              (return))
            (for [aggregate query.aggregates]
              (arr.push! values (aggregate-initial-value aggregate)))
            (arr.push! rows^ (Result-Row {values: values pulls: pulls})))))))
  (for [row rows^]
    (for [aggregate index query.aggregates]
      (set! row.values[(+ (count query.find) index)]
        (aggregate-value-for-group-with-fns bindings query aggregate (slice row.values 0 (count query.find)) registry)))))

(defn append-aggregate-rows-with-sources! [rows: ^[dynamic]Result-Row, db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding]
  (append-aggregate-rows-with-sources-and-fns! rows db sources query inputs bindings ([]Native-Query-Fn [])))

(defn append-aggregate-rows! [rows: ^[dynamic]Result-Row, db: DB, query: Query, inputs: []Query-Input, bindings: []Binding]
  (append-aggregate-rows-with-sources! rows db ([]DB-Source []) query inputs bindings))

(defn result-rows-for-bindings-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn] -> [dynamic]Result-Row
  (let [rows (make [dynamic]Result-Row 0 (count bindings))
        seen (make (map string bool))
        seen-entities (make (map u64 bool))
        seen-ints (make (map i64 bool))
        seen-strings (make (map string bool))
        seen-keywords (make (map string bool))
        seen-symbols (make (map string bool))
        seen-nil false
        seen-true false
        seen-false false
        trust-unique-bindings (query-can-trust-unique-bindings? query)]
    (defer (delete seen))
    (defer (delete seen-entities))
    (defer (delete seen-ints))
    (defer (delete seen-strings))
    (defer (delete seen-keywords))
    (defer (delete seen-symbols))
    (for [binding bindings]
      (let [values (make [dynamic]Value 0 (count query.find))
            dedupe-values (make [dynamic]Value)
            [pulls pulls-ok] (pulls-for-binding-with-sources-and-fns db sources query inputs binding registry)
            complete true]
        (when (not pulls-ok)
          (set! complete false))
        (for [name query.find]
          (let [[value ok] (binding-lookup binding name)]
            (if ok
              (do
                (arr.push! values value)
                (arr.push! dedupe-values value))
              (set! complete false))))
        (for [name query.with]
          (let [[value ok] (binding-lookup binding name)]
            (if ok
              (arr.push! dedupe-values value)
              (set! complete false))))
        (when complete
          (if (or (> (count pulls) 0) trust-unique-bindings)
            (arr.push! rows (Result-Row {values: values pulls: pulls}))
            (if (= (count dedupe-values) 1)
              (let [dedupe-value dedupe-values[0]]
                (case dedupe-value.kind
                  .Entity (let [[_ already-seen] (mmap.get seen-entities dedupe-value.entity)]
                            (when (not already-seen)
                              (mmap.assoc! seen-entities dedupe-value.entity true)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Int (let [[_ already-seen] (mmap.get seen-ints dedupe-value.int-value)]
                         (when (not already-seen)
                           (mmap.assoc! seen-ints dedupe-value.int-value true)
                           (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .String (let [[_ already-seen] (mmap.get seen-strings dedupe-value.text)]
                            (when (not already-seen)
                              (mmap.assoc! seen-strings dedupe-value.text true)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Keyword (let [[_ already-seen] (mmap.get seen-keywords dedupe-value.text)]
                             (when (not already-seen)
                               (mmap.assoc! seen-keywords dedupe-value.text true)
                               (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Symbol (let [[_ already-seen] (mmap.get seen-symbols dedupe-value.text)]
                            (when (not already-seen)
                              (mmap.assoc! seen-symbols dedupe-value.text true)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Bool (if dedupe-value.bool-value
                          (when (not seen-true)
                            (set! seen-true true)
                            (arr.push! rows (Result-Row {values: values pulls: pulls})))
                          (when (not seen-false)
                            (set! seen-false true)
                            (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Nil (when (not seen-nil)
                         (set! seen-nil true)
                         (arr.push! rows (Result-Row {values: values pulls: pulls})))
                  :else (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                          (arr.push! rows (Result-Row {values: values pulls: pulls})))))
              (let [[key key-ok] (row-values-dedupe-key (slice dedupe-values 0))]
                (if key-ok
                  (let [[_ already-seen] (mmap.get seen key)]
                    (when (not already-seen)
                      (mmap.assoc! seen key true)
                      (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                    (arr.push! rows (Result-Row {values: values pulls: pulls}))))))))))
    rows))

(defn bindings-after-rule-call-step [db: DB, rules: []Rule, bindings: []Binding, call: Rule-Call] -> [dynamic]Binding
  (bindings-after-rule-call-step-with-fns db rules bindings call ([]Native-Query-Fn [])))

(defn bindings-after-rule-call-step-with-fns [db: DB, rules: []Rule, bindings: []Binding, call: Rule-Call, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [rule-bindings (bindings-after-rule-call-with-fns db rules call binding registry)]
        (for [rule-binding rule-bindings]
          (arr.push! out rule-binding))
        (delete rule-bindings)))
    out))

(defn bindings-after-get-else-step [db: DB, bindings: []Binding, get-else: Get-Else] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[next ok] (apply-get-else db binding get-else)]
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-get-some-step [db: DB, bindings: []Binding, get-some: Get-Some] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[next ok] (apply-get-some db binding get-some)]
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-or-group-step-with-fns [db: DB, sources: []DB-Source, bindings: []Binding, group: Or-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (for [branch group.branches]
        (let [branch-bindings (bindings-after-or-branch-with-sources-and-fns db sources group branch binding registry)]
          (for [branch-binding branch-bindings]
            (arr.push! out branch-binding))
          (delete branch-bindings))))
    out))

(defn bindings-after-or-group-step [db: DB, sources: []DB-Source, bindings: []Binding, group: Or-Group] -> [dynamic]Binding
  (bindings-after-or-group-step-with-fns db sources bindings group ([]Native-Query-Fn [])))

(defn bindings-after-not-group-step-with-fns [db: DB, sources: []DB-Source, bindings: []Binding, group: Not-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (when (not (binding-matches-not-group-with-sources-and-fns? db sources group binding registry))
        (arr.push! out binding)))
    out))

(defn bindings-after-not-group-step [db: DB, sources: []DB-Source, bindings: []Binding, group: Not-Group] -> [dynamic]Binding
  (bindings-after-not-group-step-with-fns db sources bindings group ([]Native-Query-Fn [])))

(defn bindings-after-query-step-with-fns [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step, registry: []Native-Query-Fn] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources! (addr out) db sources query^.clauses[step.index] binding))
        out)
    .RuleCall
      (bindings-after-rule-call-step-with-fns db (slice query^.rules 0) bindings query^.rule-calls[step.index] registry)
    .Ground
      (apply-ground bindings query^.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings query^.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings query^.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings query^.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings query^.predicates[step.index] registry)
    .Or
      (bindings-after-or-group-step-with-fns db sources bindings query^.or-groups[step.index] registry)
    :else
      (bindings-after-not-group-step-with-fns db sources bindings query^.not-groups[step.index] registry)))

(defn bindings-after-query-step [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step] -> [dynamic]Binding
  (bindings-after-query-step-with-fns db sources query bindings step ([]Native-Query-Fn [])))

(defn bindings-after-query-step-profiled-with-fns [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (set! stats^.steps (+ stats^.steps 1))
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources-profiled! (addr out) db sources query^.clauses[step.index] binding stats))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call query^.rule-calls[step.index]]
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-profiled-with-fns db (slice query^.rules 0) call binding registry stats)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)
    .Ground
      (apply-ground bindings query^.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings query^.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings query^.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings query^.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings query^.predicates[step.index] registry)
    .Or
      (bindings-after-or-group-step-with-fns db sources bindings query^.or-groups[step.index] registry)
    :else
      (bindings-after-not-group-step-with-fns db sources bindings query^.not-groups[step.index] registry)))

(defn bindings-after-planned-clauses-profiled [db: DB, sources: []DB-Source, bindings: []Binding, clauses: []Clause, stats: ^Query-Stats] -> [dynamic]Binding
  (let [current (arr.into [dynamic]Binding bindings)
        remaining (arr.into [dynamic]Clause clauses)]
    (defer (delete remaining))
    (while (and (> (count current) 0) (> (count remaining) 0))
      (let [clause-index (best-clause-index (slice remaining 0) current[0])
            clause remaining[clause-index]
            next (make [dynamic]Binding)]
        (set! stats^.steps (+ stats^.steps 1))
        (for [binding current]
          (append-bindings-after-clause-with-sources-profiled! (addr next) db sources clause binding stats))
        (delete current)
        (set! current next)
        (query-stats-observe-bindings! stats (count current))
        (arr.remove-ordered-at! remaining clause-index)))
    current))

(defn bindings-after-ordered-where-with-fns [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings (bindings-from-inputs db query^ inputs)]
    (for [step query^.where-steps]
      (let [next-bindings (bindings-after-query-step-with-fns db sources query (slice bindings 0) step registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    (return bindings)))

(defn bindings-after-ordered-where [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input] -> [dynamic]Binding
  (bindings-after-ordered-where-with-fns db sources query inputs ([]Native-Query-Fn [])))

(defn bindings-after-ordered-where-profiled-with-fns [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (let [bindings (bindings-from-inputs db query^ inputs)
        step-index 0]
    (set! stats^.input-bindings (count bindings))
    (query-stats-observe-bindings! stats (count bindings))
    (while (< step-index (count query^.where-steps))
      (let [step query^.where-steps[step-index]]
        (if (= step.kind .Clause)
          (let [clauses (make [dynamic]Clause)]
            (while (and (< step-index (count query^.where-steps))
                        (= query^.where-steps[step-index].kind .Clause))
              (arr.push! clauses query^.clauses[query^.where-steps[step-index].index])
              (set! step-index (+ step-index 1)))
            (let [next-bindings (bindings-after-planned-clauses-profiled db sources (slice bindings 0) (slice clauses 0) stats)]
              (delete clauses)
              (delete bindings)
              (set! bindings next-bindings)))
          (do
            (let [next-bindings (bindings-after-query-step-profiled-with-fns db sources query (slice bindings 0) step registry stats)]
              (delete bindings)
              (set! bindings next-bindings)
              (query-stats-observe-bindings! stats (count bindings)))
            (set! step-index (+ step-index 1)))))
      (when (= (count bindings) 0)
        (return bindings)))
    (return bindings)))

(defn profiled-result-set [result: Result-Set, stats: Query-Stats] -> Profiled-Result-Set
  (Profiled-Result-Set {result: result stats: stats}))

(defn query-single-attr-value-distinct-clause [query: Query] -> [clause-value: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 1)
                    (= query.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [candidate-clause query.clauses[0]]
      (when (or candidate-clause.has-source
                (not (= candidate-clause.a.kind .Value))
                (not (= candidate-clause.a.value.kind .Keyword))
                (not (= candidate-clause.v.kind .Var))
                (not (= candidate-clause.v.name query.find[0]))
                (not (or (= candidate-clause.e.kind .Wildcard)
                         (= candidate-clause.e.kind .Var))))
        (return empty-clause false))
      (return candidate-clause true))))

(defn append-distinct-single-value-row! [rows: ^[dynamic]Result-Row, value: Value]
  (let [values (make [dynamic]Value 0 1)
        pulls (make [dynamic]Pull-Result)]
    (arr.push! values value)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn append-two-value-row! [rows: ^[dynamic]Result-Row, first: Value, second: Value]
  (let [values (make [dynamic]Value 0 2)
        pulls (make [dynamic]Pull-Result)]
    (arr.push! values first)
    (arr.push! values second)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn append-three-value-row! [rows: ^[dynamic]Result-Row, first: Value, second: Value, third: Value]
  (let [values (make [dynamic]Value 0 3)
        pulls (make [dynamic]Pull-Result)]
    (arr.push! values first)
    (arr.push! values second)
    (arr.push! values third)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn query-single-entity-by-attr-value-clause [db: DB, query: Query] -> [clause-value: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 1)
                    (= query.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [candidate-clause query.clauses[0]]
      (when (or candidate-clause.has-source
                (not (= candidate-clause.e.kind .Var))
                (not (= candidate-clause.e.name query.find[0]))
                (not (= candidate-clause.a.kind .Value))
                (not (= candidate-clause.a.value.kind .Keyword))
                (tx-data-modifies-validation-schema? (Tx-Data {a: candidate-clause.a.value.text}))
                (schema-ref-target? db candidate-clause.a.value.text)
                (not (= candidate-clause.v.kind .Value))
                (not (= candidate-clause.tx-term.kind .Wildcard))
                (not (= candidate-clause.op-term.kind .Wildcard)))
        (return empty-clause false))
      (return candidate-clause true))))

(defn append-entity-row! [rows: ^[dynamic]Result-Row, entity: u64]
  (append-distinct-single-value-row! rows (value-entity entity)))

(defn q-single-entity-by-attr-value-profiled [db: DB, clause-value: Clause, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        attr clause-value.a.value.text
        value clause-value.v.value
        indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 attr value)
        high (upper-bound-index db indexes "avet" 0 attr value)
        rows (make [dynamic]Result-Row 0 (- high low))
        all-current (all-datoms-current? db)]
    (set! out-stats.steps 1)
    (set! out-stats.clauses 1)
    (set! out-stats.clause-candidates (- high low))
    (set! out-stats.max-intermediate-bindings (- high low))
    (if all-current
      (for [i (arr.range low high)]
        (let [datom db.datoms[indexes[i]]]
          (append-entity-row! (addr rows) datom.e)))
      (let [seen (make (map u64 bool))]
        (defer (delete seen))
        (for [i (arr.range low high)]
          (let [datom-index indexes[i]
                datom db.datoms[datom-index]]
            (when (datom-current-at? db datom-index)
              (let [[_ already-seen] (mmap.get seen datom.e)]
                (when (not already-seen)
                  (mmap.assoc! seen datom.e true)
                  (append-entity-row! (addr rows) datom.e))))))))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-query-entity-column [db: DB, query: Query, inputs: []Query-Input] -> [entities: [dynamic]u64, ok: bool]
  (let [out (make [dynamic]u64)]
    (when (> (count inputs) 0)
      (return out false))
    (let [[clause-value clause-ok] (query-single-entity-by-attr-value-clause db query)]
      (when (not clause-ok)
        (return out false))
      (let [attr clause-value.a.value.text
            value clause-value.v.value
            indexes (slice db.avet 0)
            low (lower-bound-index db indexes "avet" 0 attr value)
            high (upper-bound-index db indexes "avet" 0 attr value)
            all-current (all-datoms-current? db)]
        (if all-current
          (for [i (arr.range low high)]
            (arr.push! out db.datoms[indexes[i]].e))
          (let [seen (make (map u64 bool))]
            (defer (delete seen))
            (for [i (arr.range low high)]
              (let [datom-index indexes[i]
                    datom db.datoms[datom-index]]
                (when (datom-current-at? db datom-index)
                  (let [[_ already-seen] (mmap.get seen datom.e)]
                    (when (not already-seen)
                      (mmap.assoc! seen datom.e true)
                      (arr.push! out datom.e)))))))))
      (return out true))))

(defstruct Distinct-Attr-Value {
  first-e: u64
  value: Value
})

(defn distinct-attr-value-less? [left: Distinct-Attr-Value, right: Distinct-Attr-Value] -> bool
  (if (not (= left.first-e right.first-e))
    (< left.first-e right.first-e)
    (value-less? left.value right.value)))

(defn sort-distinct-attr-values! [values: ^[dynamic]Distinct-Attr-Value]
  (for [i (arr.range 1 (count values^))]
    (let [item values^[i]
          j i]
      (while (and (> j 0)
                  (distinct-attr-value-less? item values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] item))))

(defn q-single-attr-value-distinct-profiled [db: DB, clause-value: Clause, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        attr clause-value.a.value.text
        indexes (slice db.avet 0)
        attr-prefix ([]Value [(value-keyword attr)])
        low (lower-bound-index-values db indexes "avet" attr-prefix)
        high (upper-bound-index-values db indexes "avet" attr-prefix)
        distinct-values (make [dynamic]Distinct-Attr-Value)
        all-current (all-datoms-current? db)]
    (defer (delete distinct-values))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 1)
    (set! out-stats.clause-candidates (- high low))
    (set! out-stats.max-intermediate-bindings (- high low))
    (let [i low]
      (while (< i high)
        (let [first-index indexes[i]
              datom db.datoms[first-index]
              value datom.v]
          (if all-current
            (do
              (while (and (< i high)
                          (value-equal? db.datoms[indexes[i]].v value))
                (set! i (+ i 1)))
              (arr.push! distinct-values (Distinct-Attr-Value {first-e: datom.e value: value})))
            (let [first-current-e: u64 0
                  first-current-value (Value {})
                  has-current false]
              (while (and (< i high)
                          (value-equal? db.datoms[indexes[i]].v value))
                (let [candidate-index indexes[i]
                      candidate db.datoms[candidate-index]]
                  (when (and (datom-current-at? db candidate-index)
                             (not has-current))
                    (set! first-current-e candidate.e)
                    (set! first-current-value candidate.v)
                    (set! has-current true)))
                (set! i (+ i 1)))
              (when has-current
                (arr.push! distinct-values (Distinct-Attr-Value {first-e: first-current-e value: first-current-value})))))))
    (sort-distinct-attr-values! (addr distinct-values))
    (let [rows (make [dynamic]Result-Row 0 (count distinct-values))]
      (for [item distinct-values]
        (append-distinct-single-value-row! (addr rows) item.value))
      (set! out-stats.output-rows (count rows))
      (profiled-result-set (result-set-ok rows) out-stats)))))

(defstruct Two-Attr-Entity-Projection {
  first-attr: string
  first-var: string
  second-attr: string
  second-var: string
})

(defstruct Entity-Attr-Value-Projection {
  entity-var: string
  filter-attr: string
  filter-value: Value
  value-attr: string
  value-var: string
})

(defstruct Entity-Int-Pair {
  entity: u64
  value: i64
})

(defstruct Entity-Int-Pair-Columns {
  entities: [dynamic]u64
  values: [dynamic]i64
})

(defstruct Entity-String-Int-Triples {
  entities: [dynamic]u64
  strings: [dynamic]string
  ints: [dynamic]i64
})

(defstruct Entity-Int-Pair-Filter {
  attr: string
  value: Value
})

(defstruct Entity-Int-Pair-Plan {
  entity-var: string
  value-var: string
  value-attr: string
  filters: [dynamic]Entity-Int-Pair-Filter
})

(defstruct Entity-Two-Value-Plan {
  entity-var: string
  first-var: string
  first-attr: string
  second-var: string
  second-attr: string
  filters: [dynamic]Entity-Int-Pair-Filter
})

(defstruct Entity-Int-Threshold-Plan {
  entity-var: string
  value-var: string
  value-attr: string
  threshold: i64
})

(defn empty-two-attr-entity-projection [] -> Two-Attr-Entity-Projection
  (Two-Attr-Entity-Projection {}))

(defn empty-entity-attr-value-projection [] -> Entity-Attr-Value-Projection
  (Entity-Attr-Value-Projection {}))

(defn empty-entity-int-pair-plan [] -> Entity-Int-Pair-Plan
  (Entity-Int-Pair-Plan {filters: (make [dynamic]Entity-Int-Pair-Filter)}))

(defn empty-entity-int-pair-columns [] -> Entity-Int-Pair-Columns
  (Entity-Int-Pair-Columns {entities: (make [dynamic]u64)
                            values: (make [dynamic]i64)}))

(defn delete-entity-int-pair-columns [columns: Entity-Int-Pair-Columns]
  (delete columns.entities)
  (delete columns.values))

(defn append-entity-int-pair-column! [columns: ^Entity-Int-Pair-Columns, entity: u64, value: i64]
  (arr.push! columns^.entities entity)
  (arr.push! columns^.values value))

(defn empty-entity-string-int-triples [] -> Entity-String-Int-Triples
  (Entity-String-Int-Triples {entities: (make [dynamic]u64)
                              strings: (make [dynamic]string)
                              ints: (make [dynamic]i64)}))

(defn delete-entity-string-int-triples [columns: Entity-String-Int-Triples]
  (delete columns.entities)
  (delete columns.strings)
  (delete columns.ints))

(defn append-entity-string-int-triple! [columns: ^Entity-String-Int-Triples, entity: u64, text: string, value: i64]
  (arr.push! columns^.entities entity)
  (arr.push! columns^.strings text)
  (arr.push! columns^.ints value))

(defn empty-entity-two-value-plan [] -> Entity-Two-Value-Plan
  (Entity-Two-Value-Plan {filters: (make [dynamic]Entity-Int-Pair-Filter)}))

(defn empty-entity-int-threshold-plan [] -> Entity-Int-Threshold-Plan
  (Entity-Int-Threshold-Plan {}))

(defn query-two-attr-entity-projection [query: Query] -> [projection: Two-Attr-Entity-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-two-attr-entity-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]]
    (when (or first.has-source
              second.has-source
              (not (= first.e.kind .Var))
              (not (= second.e.kind .Var))
              (not (= first.e.name second.e.name))
              (not (= first.a.kind .Value))
              (not (= second.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (not (= second.a.value.kind .Keyword))
              (not (= first.v.kind .Var))
              (not (= second.v.kind .Var))
              (= first.v.name second.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard)))
      (return (empty-two-attr-entity-projection) false))
    (when (not (or (and (= query.find[0] first.v.name)
                        (= query.find[1] second.v.name))
                   (and (= query.find[0] second.v.name)
                        (= query.find[1] first.v.name))))
      (return (empty-two-attr-entity-projection) false))
    (return (Two-Attr-Entity-Projection {first-attr: first.a.value.text
                                         first-var: first.v.name
                                         second-attr: second.a.value.text
                                         second-var: second.v.name})
            true)))

(defn query-entity-attr-value-projection [db: DB, query: Query] -> [projection: Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-entity-attr-value-projection) false))
  (let [left query.clauses[0]
        right query.clauses[1]]
    (when (or left.has-source
              right.has-source
              (not (= left.e.kind .Var))
              (not (= right.e.kind .Var))
              (not (= left.e.name right.e.name))
              (not (= left.a.kind .Value))
              (not (= right.a.kind .Value))
              (not (= left.a.value.kind .Keyword))
              (not (= right.a.value.kind .Keyword))
              (not (= left.tx-term.kind .Wildcard))
              (not (= right.tx-term.kind .Wildcard))
              (not (= left.op-term.kind .Wildcard))
              (not (= right.op-term.kind .Wildcard)))
      (return (empty-entity-attr-value-projection) false))
    (let [filter-clause (if (= left.v.kind .Value) left right)
          value-clause (if (= left.v.kind .Value) right left)]
      (when (or (not (= filter-clause.v.kind .Value))
                (not (= value-clause.v.kind .Var))
                (tx-data-modifies-validation-schema? (Tx-Data {a: filter-clause.a.value.text}))
                (schema-ref-target? db filter-clause.a.value.text)
                (not (or (and (= query.find[0] filter-clause.e.name)
                              (= query.find[1] value-clause.v.name))
                         (and (= query.find[0] value-clause.v.name)
                              (= query.find[1] filter-clause.e.name)))))
        (return (empty-entity-attr-value-projection) false))
      (return (Entity-Attr-Value-Projection {entity-var: filter-clause.e.name
                                             filter-attr: filter-clause.a.value.text
                                             filter-value: filter-clause.v.value
                                             value-attr: value-clause.a.value.text
                                             value-var: value-clause.v.name})
              true))))

(defn query-entity-int-pair-plan [db: DB, query: Query] -> [plan: Entity-Int-Pair-Plan, ok: bool]
  (let [out (empty-entity-int-pair-plan)]
    (when (not (and (= (count query.find) 2)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 2)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false)))
    (let [entity-var query.find[0]
          value-var query.find[1]
          value-clause-found false
          value-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.e.name entity-var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard))
                  (not (schema-cardinality-one? db item.a.value.text)))
          (return out false))
        (if (= item.v.kind .Var)
          (do
            (when (or value-clause-found
                      (not (= item.v.name value-var)))
              (return out false))
            (set! value-clause-found true)
            (set! value-attr item.a.value.text))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false))))
      (when (or (not value-clause-found)
                (= (count out.filters) 0))
        (return out false))
      (set! out.entity-var entity-var)
      (set! out.value-var value-var)
      (set! out.value-attr value-attr)
      (return out true))))

(defn query-entity-two-value-plan [db: DB, query: Query] -> [plan: Entity-Two-Value-Plan, ok: bool]
  (let [out (empty-entity-two-value-plan)]
    (when (not (and (= (count query.find) 3)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 3)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false)))
    (let [entity-var query.find[0]
          first-var query.find[1]
          second-var query.find[2]
          first-found false
          second-found false
          first-attr ""
          second-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.e.name entity-var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard))
                  (not (schema-cardinality-one? db item.a.value.text)))
          (return out false))
        (if (= item.v.kind .Var)
          (cond
            (= item.v.name first-var)
              (do
                (when first-found
                  (return out false))
                (set! first-found true)
                (set! first-attr item.a.value.text))
            (= item.v.name second-var)
              (do
                (when second-found
                  (return out false))
                (set! second-found true)
                (set! second-attr item.a.value.text))
            :else (return out false))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false))))
      (when (or (not first-found)
                (not second-found)
                (= (count out.filters) 0)
                (not (all-datoms-current? db)))
        (return out false))
      (set! out.entity-var entity-var)
      (set! out.first-var first-var)
      (set! out.first-attr first-attr)
      (set! out.second-var second-var)
      (set! out.second-attr second-attr)
      (return out true))))

(defn query-input-by-name-scalar-value [query: Query, inputs: []Query-Input, name: string] -> [value: Value, ok: bool]
  (for [input-name index (slice query.inputs 0)]
    (when (= input-name name)
      (when (>= index (count inputs))
        (return (Value {}) false))
      (let [input inputs[index]]
        (when (= input.kind .Scalar)
          (return input.value true))
        (return (Value {}) false))))
  (return (Value {}) false))

(defn query-threshold-term-int [query: Query, inputs: []Query-Input, term: Term] -> [value: i64, ok: bool]
  (when (= term.kind .Value)
    (when (= term.value.kind .Int)
      (return term.value.int-value true))
    (return 0 false))
  (when (= term.kind .Var)
    (let [[input-value input-ok] (query-input-by-name-scalar-value query inputs term.name)]
      (when (and input-ok (= input-value.kind .Int))
        (return input-value.int-value true))))
  (return 0 false))

(defn query-entity-int-threshold-plan [db: DB, query: Query, inputs: []Query-Input] -> [plan: Entity-Int-Threshold-Plan, ok: bool]
  (let [out (empty-entity-int-threshold-plan)]
    (when (not (and (= (count query.find) 2)
                    (= (count query.with) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.predicates) 1)
                    (= (count query.where-steps) 2)))
      (return out false))
    (when (not (and (= query.where-steps[0].kind .Clause)
                    (= query.where-steps[1].kind .Predicate)))
      (return out false))
    (let [entity-var query.find[0]
          value-var query.find[1]
          query-clause query.clauses[0]
          predicate query.predicates[0]]
      (when (or query-clause.has-source
                (not (= query-clause.e.kind .Var))
                (not (= query-clause.e.name entity-var))
                (not (= query-clause.a.kind .Value))
                (not (= query-clause.a.value.kind .Keyword))
                (not (= query-clause.v.kind .Var))
                (not (= query-clause.v.name value-var))
                (not (= query-clause.tx-term.kind .Wildcard))
                (not (= query-clause.op-term.kind .Wildcard))
                (not (schema-cardinality-one? db query-clause.a.value.text))
                (not (= predicate.op ">"))
                (not (= (count predicate.terms) 2))
                (not (= predicate.terms[0].kind .Var))
                (not (= predicate.terms[0].name value-var)))
        (return out false))
      (let [[threshold threshold-ok] (query-threshold-term-int query inputs predicate.terms[1])]
        (when (not threshold-ok)
          (return out false))
        (set! out.entity-var entity-var)
        (set! out.value-var value-var)
        (set! out.value-attr query-clause.a.value.text)
        (set! out.threshold threshold)
        (return out true)))))

(defn q-query-entity-int-threshold-pair-columns [db: DB, plan: Entity-Int-Threshold-Plan] -> Entity-Int-Pair-Columns
  (let [out (empty-entity-int-pair-columns)
        indexes (slice db.avet 0)
        low (lower-bound-index db indexes "avet" 0 plan.value-attr (value-int plan.threshold))
        attr-prefix ([]Value [(value-keyword plan.value-attr)])
        high (upper-bound-index-values db indexes "avet" attr-prefix)
        all-current (all-datoms-current? db)]
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]
            datom db.datoms[datom-index]]
        (when (and (or all-current (datom-current-at? db datom-index))
                   (= datom.a plan.value-attr)
                   (= datom.v.kind .Int)
                   (> datom.v.int-value plan.threshold))
          (append-entity-int-pair-column! (addr out) datom.e datom.v.int-value))))
    out))

(defn append-two-attr-projection-row! [rows: ^[dynamic]Result-Row, seen: (ptr (map string bool)), query: Query, projection: Two-Attr-Entity-Projection, first-value-source: Value, second-value-source: Value]
  (let [first-value (if (= query.find[0] projection.first-var) first-value-source second-value-source)
        second-value (if (= query.find[1] projection.second-var) second-value-source first-value-source)
        [key key-ok] (two-primitive-values-dedupe-key first-value second-value)]
    (if key-ok
      (let [[_ already-seen] (mmap.get seen^ key)]
        (when (not already-seen)
          (mmap.assoc! seen^ key true)
          (append-two-value-row! rows first-value second-value)))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-two-value-row! rows first-value second-value))))))

(defn current-entity-attr-values [db: DB, attr: string, stats: ^Query-Stats] -> (map u64 Value)
  (let [out (make (map u64 Value))
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 attr (Value {}))]
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (for [i (arr.range low high)]
      (let [datom-index indexes[i]
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (mmap.assoc! out datom.e datom.v))))
    out))

(defn append-two-attr-entity-projection-cardinality-one! [rows: ^[dynamic]Result-Row, seen: (ptr (map string bool)), db: DB, query: Query, projection: Two-Attr-Entity-Projection, stats: ^Query-Stats]
  (let [second-values (current-entity-attr-values db projection.second-attr stats)
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 projection.first-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 projection.first-attr (Value {}))]
    (defer (delete second-values))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (for [i (arr.range low high)]
      (let [first-index indexes[i]
            first-datom db.datoms[first-index]]
        (when (datom-current-at? db first-index)
          (let [[second-value has-second] (mmap.get second-values first-datom.e)]
            (when has-second
              (append-two-attr-projection-row! rows seen query projection first-datom.v second-value))))))))

(defn q-two-attr-entity-projection-profiled [db: DB, query: Query, projection: Two-Attr-Entity-Projection, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        rows (make [dynamic]Result-Row)
        seen (make (map string bool))
        indexes (slice db.aevt 0)
        low (lower-bound-index db indexes "aevt" 0 projection.first-attr (Value {}))
        high (upper-bound-index db indexes "aevt" 0 projection.first-attr (Value {}))]
    (defer (delete seen))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 2)
    (if (schema-cardinality-one? db projection.second-attr)
      (append-two-attr-entity-projection-cardinality-one! (addr rows) (addr seen) db query projection (addr out-stats))
      (for [i (arr.range low high)]
        (let [first-index indexes[i]
              first-datom db.datoms[first-index]]
          (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
          (when (datom-current-at? db first-index)
            (let [entity-indexes (slice db.eavt 0)
                  second-low (lower-bound-index db entity-indexes "eavt-ea" first-datom.e projection.second-attr (Value {}))
                  second-high (upper-bound-index db entity-indexes "eavt-ea" first-datom.e projection.second-attr (Value {}))]
              (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- second-high second-low)))
              (for [j (arr.range second-low second-high)]
                (let [second-index entity-indexes[j]
                      second-datom db.datoms[second-index]]
                  (when (datom-current-at? db second-index)
                    (append-two-attr-projection-row! (addr rows) (addr seen) query projection first-datom.v second-datom.v)))))))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn append-entity-attr-value-projection-row! [rows: ^[dynamic]Result-Row, seen: (ptr (map string bool)), query: Query, projection: Entity-Attr-Value-Projection, entity: u64, value: Value]
  (let [entity-value (value-entity entity)
        first-value (if (= query.find[0] projection.entity-var) entity-value value)
        second-value (if (= query.find[1] projection.value-var) value entity-value)
        [key key-ok] (two-primitive-values-dedupe-key first-value second-value)]
    (if key-ok
      (let [[_ already-seen] (mmap.get seen^ key)]
        (when (not already-seen)
          (mmap.assoc! seen^ key true)
          (append-two-value-row! rows first-value second-value)))
      (let [dedupe-values ([]Value [first-value second-value])]
        (when (not (row-values-exist? (slice rows^ 0) dedupe-values))
          (append-two-value-row! rows first-value second-value))))))

(defn append-entity-attr-value-projection-row-raw! [rows: ^[dynamic]Result-Row, query: Query, projection: Entity-Attr-Value-Projection, entity: u64, value: Value]
  (let [entity-value (value-entity entity)
        first-value (if (= query.find[0] projection.entity-var) entity-value value)
        second-value (if (= query.find[1] projection.value-var) value entity-value)]
    (append-two-value-row! rows first-value second-value)))

(defn q-entity-attr-value-projection-profiled [db: DB, query: Query, projection: Entity-Attr-Value-Projection, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        rows (make [dynamic]Result-Row)
        seen (make (map string bool))
        filter-indexes (slice db.avet 0)
        low (lower-bound-index db filter-indexes "avet" 0 projection.filter-attr projection.filter-value)
        high (upper-bound-index db filter-indexes "avet" 0 projection.filter-attr projection.filter-value)
        dedupe-required (not (and (all-datoms-current? db)
                                  (schema-cardinality-one? db projection.filter-attr)
                                  (schema-cardinality-one? db projection.value-attr)))]
    (defer (delete seen))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 2)
    (set! out-stats.clause-candidates (- high low))
    (for [i (arr.range low high)]
      (let [filter-index filter-indexes[i]
            filter-datom db.datoms[filter-index]]
        (when (datom-current-at? db filter-index)
          (let [entity-indexes (slice db.eavt 0)
                value-low (lower-bound-index db entity-indexes "eavt-ea" filter-datom.e projection.value-attr (Value {}))
                value-high (upper-bound-index db entity-indexes "eavt-ea" filter-datom.e projection.value-attr (Value {}))]
            (set! out-stats.clause-candidates (+ out-stats.clause-candidates (- value-high value-low)))
            (for [j (arr.range value-low value-high)]
              (let [value-index entity-indexes[j]
                    value-datom db.datoms[value-index]]
                (when (datom-current-at? db value-index)
                  (if dedupe-required
                    (append-entity-attr-value-projection-row! (addr rows) (addr seen) query projection filter-datom.e value-datom.v)
                    (append-entity-attr-value-projection-row-raw! (addr rows) query projection filter-datom.e value-datom.v)))))))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-query-entity-int-pair-columns [db: DB, query: Query, inputs: []Query-Input] -> [columns: Entity-Int-Pair-Columns, ok: bool]
  (let [out (empty-entity-int-pair-columns)]
    (let [[threshold-plan threshold-ok] (query-entity-int-threshold-plan db query inputs)]
      (when threshold-ok
        (delete-entity-int-pair-columns out)
        (return (q-query-entity-int-threshold-pair-columns db threshold-plan) true)))
    (when (> (count inputs) 0)
      (return out false))
    (let [[plan plan-ok] (query-entity-int-pair-plan db query)]
      (when (not plan-ok)
        (delete plan.filters)
        (return out false))
      (let [filter-indexes (slice db.avet 0)
            best-filter-index 0
            best-low 0
            best-high 0]
        (for [filter-i (arr.range 0 (count plan.filters))]
          (let [filter plan.filters[filter-i]
                low (lower-bound-index db filter-indexes "avet" 0 filter.attr filter.value)
                high (upper-bound-index db filter-indexes "avet" 0 filter.attr filter.value)]
            (when (or (= filter-i 0)
                      (< (- high low) (- best-high best-low)))
              (set! best-filter-index filter-i)
              (set! best-low low)
              (set! best-high high))))
        (when (= (count plan.filters) 0)
          (delete plan.filters)
          (return out false))
        (let [direct-value-lookup (all-datoms-current? db)]
          (for [i (arr.range best-low best-high)]
            (let [filter-datom-index filter-indexes[i]
                  filter-datom db.datoms[filter-datom-index]]
              (when (or direct-value-lookup (datom-current-at? db filter-datom-index))
                (let [filters-match true]
                  (for [filter-i (arr.range 0 (count plan.filters))]
                    (when (not (= filter-i best-filter-index))
                      (let [filter plan.filters[filter-i]]
                        (if direct-value-lookup
                          (when (not (cardinality-one-value-matches-fast-all-current? db filter-datom.e filter.attr filter.value))
                            (set! filters-match false))
                          (let [[filter-value filter-ok] (latest-attr-value db filter-datom.e filter.attr)]
                            (when (not (and filter-ok (value-equal? filter-value filter.value)))
                              (set! filters-match false)))))))
                  (when filters-match
                    (if direct-value-lookup
                      (let [[int-value int-ok] (cardinality-one-int-value-fast-all-current db filter-datom.e plan.value-attr)]
                        (when int-ok
                          (append-entity-int-pair-column! (addr out) filter-datom.e int-value)))
                      (let [[value value-ok] (latest-attr-value db filter-datom.e plan.value-attr)]
                        (when (and value-ok (= value.kind .Int))
                          (append-entity-int-pair-column! (addr out) filter-datom.e value.int-value))))))))))
        (delete plan.filters)
        (return out true)))))

(defn q-entity-two-value-plan-profiled [db: DB, query: Query, plan: Entity-Two-Value-Plan, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        rows (make [dynamic]Result-Row)
        filter-indexes (slice db.avet 0)
        best-filter-index 0
        best-low 0
        best-high 0
        all-current (all-datoms-current? db)]
    (defer (delete plan.filters))
    (for [filter-i (arr.range 0 (count plan.filters))]
      (let [filter plan.filters[filter-i]
            low (lower-bound-index db filter-indexes "avet" 0 filter.attr filter.value)
            high (upper-bound-index db filter-indexes "avet" 0 filter.attr filter.value)]
        (when (or (= filter-i 0)
                  (< (- high low) (- best-high best-low)))
          (set! best-filter-index filter-i)
          (set! best-low low)
          (set! best-high high))))
    (set! out-stats.steps 1)
    (set! out-stats.clauses (count query.clauses))
    (set! out-stats.clause-candidates (- best-high best-low))
    (for [i (arr.range best-low best-high)]
      (let [filter-datom-index filter-indexes[i]
            filter-datom db.datoms[filter-datom-index]]
        (when (or all-current (datom-current-at? db filter-datom-index))
          (let [filters-match true]
            (for [filter-i (arr.range 0 (count plan.filters))]
              (when (not (= filter-i best-filter-index))
                (let [filter plan.filters[filter-i]]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 1))
                  (if all-current
                    (when (not (cardinality-one-value-matches-fast-all-current? db filter-datom.e filter.attr filter.value))
                      (set! filters-match false))
                    (when (not (current-cardinality-one-value-matches-fast? db filter-datom.e filter.attr filter.value))
                      (set! filters-match false))))))
            (when filters-match
              (if all-current
                (let [[first-value first-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.first-attr)
                      [second-value second-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.second-attr)]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 2))
                  (when (and first-ok second-ok)
                    (append-three-value-row! (addr rows) (value-entity filter-datom.e) first-value second-value)))
                (let [[first-value first-ok] (current-cardinality-one-value-fast db filter-datom.e plan.first-attr)
                      [second-value second-ok] (current-cardinality-one-value-fast db filter-datom.e plan.second-attr)]
                  (set! out-stats.clause-candidates (+ out-stats.clause-candidates 2))
                  (when (and first-ok second-ok)
                    (append-three-value-row! (addr rows) (value-entity filter-datom.e) first-value second-value)))))))))
    (set! out-stats.max-intermediate-bindings (count rows))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-query-entity-string-int-triples [db: DB, query: Query, inputs: []Query-Input] -> [columns: Entity-String-Int-Triples, ok: bool]
  (let [out (empty-entity-string-int-triples)]
    (when (> (count inputs) 0)
      (return out false))
    (let [[plan plan-ok] (query-entity-two-value-plan db query)]
      (when (not plan-ok)
        (delete plan.filters)
        (return out false))
      (let [filter-indexes (slice db.avet 0)
            best-filter-index 0
            best-low 0
            best-high 0]
        (for [filter-i (arr.range 0 (count plan.filters))]
          (let [filter plan.filters[filter-i]
                low (lower-bound-index db filter-indexes "avet" 0 filter.attr filter.value)
                high (upper-bound-index db filter-indexes "avet" 0 filter.attr filter.value)]
            (when (or (= filter-i 0)
                      (< (- high low) (- best-high best-low)))
              (set! best-filter-index filter-i)
              (set! best-low low)
              (set! best-high high))))
        (for [i (arr.range best-low best-high)]
          (let [filter-datom-index filter-indexes[i]
                filter-datom db.datoms[filter-datom-index]]
            (let [filters-match true]
              (for [filter-i (arr.range 0 (count plan.filters))]
                (when (not (= filter-i best-filter-index))
                  (let [filter plan.filters[filter-i]]
                    (when (not (cardinality-one-value-matches-fast-all-current? db filter-datom.e filter.attr filter.value))
                      (set! filters-match false)))))
              (when filters-match
                (let [[first-value first-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.first-attr)
                      [second-value second-ok] (cardinality-one-value-fast-all-current db filter-datom.e plan.second-attr)]
                  (when (and first-ok
                             second-ok
                             (= first-value.kind .String)
                             (= second-value.kind .Int))
                    (append-entity-string-int-triple! (addr out) filter-datom.e first-value.text second-value.int-value)))))))
        (delete plan.filters)
        (return out true)))))

(defn q-query-profiled-with-sources-and-fns [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> Profiled-Result-Set
  (let [stats (query-stats-empty)
        [valid error] (validate-query-call-with-fns db query inputs sources registry)]
    (when (not valid)
      (return (profiled-result-set (result-set-error error) stats)))
  (let [[distinct-clause distinct-ok] (query-single-attr-value-distinct-clause query)]
    (when distinct-ok
      (return (q-single-attr-value-distinct-profiled db distinct-clause stats))))
  (let [[entity-clause entity-ok] (query-single-entity-by-attr-value-clause db query)]
    (when entity-ok
      (return (q-single-entity-by-attr-value-profiled db entity-clause stats))))
  (let [[entity-value-projection entity-value-ok] (query-entity-attr-value-projection db query)]
    (when entity-value-ok
      (return (q-entity-attr-value-projection-profiled db query entity-value-projection stats))))
  (let [[entity-two-plan entity-two-ok] (query-entity-two-value-plan db query)]
    (when entity-two-ok
      (return (q-entity-two-value-plan-profiled db query entity-two-plan stats)))
    (delete entity-two-plan.filters))
  (let [[projection projection-ok] (query-two-attr-entity-projection query)]
    (when projection-ok
      (return (q-two-attr-entity-projection-profiled db query projection stats))))
  (when (> (count query.where-steps) 0)
    (let [ordered-query query
          bindings (bindings-after-ordered-where-profiled-with-fns db sources (addr ordered-query) inputs registry (addr stats))]
      (when (> (count query.aggregates) 0)
        (let [rows (make [dynamic]Result-Row)]
          (if (= (count query.find) 0)
            (let [values (make [dynamic]Value 0 (count query.aggregates))
                  pulls (make [dynamic]Pull-Result)]
              (for [aggregate query.aggregates]
                (arr.push! values (aggregate-value-for-group-with-fns (slice bindings 0) query aggregate ([]Value []) registry)))
              (arr.push! rows (Result-Row {values: values pulls: pulls})))
            (append-aggregate-rows-with-sources-and-fns! (addr rows) db sources query inputs (slice bindings 0) registry))
          (delete bindings)
          (set! stats.output-rows (count rows))
          (return (profiled-result-set (result-set-ok rows) stats))))
      (let [rows (result-rows-for-bindings-with-sources-and-fns db sources query inputs (slice bindings 0) registry)]
        (delete bindings)
        (set! stats.output-rows (count rows))
        (return (profiled-result-set (result-set-ok rows) stats)))))
  (let [bindings (bindings-from-inputs db query inputs)
        remaining (arr.into [dynamic]Clause (slice query.clauses 0))]
    (set! stats.input-bindings (count bindings))
    (query-stats-observe-bindings! (addr stats) (count bindings))
    (defer (delete remaining))
    (while (and (> (count bindings) 0) (> (count remaining) 0))
      (let [clause-index (best-clause-index (slice remaining 0) bindings[0])
            clause remaining[clause-index]
            next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (append-bindings-after-clause-with-sources-profiled! (addr next-bindings) db sources clause binding (addr stats)))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))
        (arr.remove-ordered-at! remaining clause-index)))
    (for [call query.rule-calls]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-profiled-with-fns db (slice query.rules 0) call binding registry (addr stats))]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [ground query.grounds]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (apply-ground (slice bindings 0) ground)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [get-else query.get-elses]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [[next ok] (apply-get-else db binding get-else)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [get-some query.get-somes]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (let [[next ok] (apply-get-some db binding get-some)]
            (when ok
              (arr.push! next-bindings next))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [function query.function-clauses]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (bindings-after-function-with-fns (slice bindings 0) function registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [predicate query.predicates]
      (set! stats.steps (+ stats.steps 1))
      (let [next-bindings (bindings-after-predicate-with-db-and-fns db (slice bindings 0) predicate registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [group query.or-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-sources-and-fns db sources group branch binding registry)]
              (for [branch-binding branch-bindings]
                (arr.push! next-bindings branch-binding))
              (delete branch-bindings))))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (for [not-group query.not-groups]
      (let [next-bindings (make [dynamic]Binding)]
        (set! stats.steps (+ stats.steps 1))
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-sources-and-fns? db sources not-group binding registry))
            (arr.push! next-bindings binding)))
        (delete bindings)
        (set! bindings next-bindings)
        (query-stats-observe-bindings! (addr stats) (count bindings))))
    (when (> (count query.aggregates) 0)
      (let [rows (make [dynamic]Result-Row)]
        (if (= (count query.find) 0)
          (let [values (make [dynamic]Value 0 (count query.aggregates))
                pulls (make [dynamic]Pull-Result)]
            (for [aggregate query.aggregates]
              (arr.push! values (aggregate-value-for-group-with-fns (slice bindings 0) query aggregate ([]Value []) registry)))
            (arr.push! rows (Result-Row {values: values pulls: pulls})))
          (append-aggregate-rows-with-sources-and-fns! (addr rows) db sources query inputs (slice bindings 0) registry))
        (delete bindings)
        (set! stats.output-rows (count rows))
        (return (profiled-result-set (result-set-ok rows) stats))))
    (let [rows (result-rows-for-bindings-with-sources-and-fns db sources query inputs (slice bindings 0) registry)]
      (delete bindings)
      (set! stats.output-rows (count rows))
      (profiled-result-set (result-set-ok rows) stats)))))

(defn q-query-with-sources-and-fns [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> Result-Set
  (q-query-profiled-with-sources-and-fns db query inputs sources registry).result)

(defn q-query-with-sources [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source] -> Result-Set
  (q-query-with-sources-and-fns db query inputs sources ([]Native-Query-Fn [])))

(defn q-query-with-inputs-and-fns [db: DB, query: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (q-query-with-sources-and-fns db query inputs ([]DB-Source []) registry))

(defn q-query-with-fns [db: DB, query: Query, registry: []Native-Query-Fn] -> Result-Set
  (q-query-with-inputs-and-fns db query ([]Query-Input []) registry))

(defn relation-db-not-group [group: Not-Group, source: string] -> Not-Group
  (let [clauses (rule-clauses-with-source (slice group.clauses 0) source true) :defer
        child-groups (make [dynamic]Not-Group) :defer]
    (for [child group.not-groups]
      (arr.push! child-groups (relation-db-not-group child source)))
    (if group.has-join
      (not-join-group (slice group.join-vars 0) (slice clauses 0) (slice child-groups 0))
      (not-group (slice clauses 0) (slice child-groups 0)))))

(defn relation-db-or-group [group: Or-Group, source: string] -> Or-Group
  (let [branches (make [dynamic]Not-Group) :defer]
    (for [branch group.branches]
      (arr.push! branches (relation-db-not-group branch source)))
    (if group.has-join
      (or-join-group (slice group.join-vars 0) (slice branches 0))
      (or-group (slice branches 0)))))

(defn relation-db-rule [rule: Rule, source: string] -> Rule
  (let [clauses (rule-clauses-with-source (slice rule.clauses 0) source true) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer]
    (for [group rule.not-groups]
      (arr.push! not-groups (relation-db-not-group group source)))
    (for [group rule.or-groups]
      (arr.push! or-groups (relation-db-or-group group source)))
    (let [params (arr.into [dynamic]string (slice rule.params 0))
          owned-clauses (arr.into [dynamic]Clause (slice clauses 0))
          predicates (arr.into [dynamic]Predicate (slice rule.predicates 0))
          function-clauses (arr.into [dynamic]Function-Clause (slice rule.function-clauses 0))
          get-elses (arr.into [dynamic]Get-Else (slice rule.get-elses 0))
          get-somes (arr.into [dynamic]Get-Some (slice rule.get-somes 0))
          grounds (arr.into [dynamic]Ground (slice rule.grounds 0))
          rule-calls (arr.into [dynamic]Rule-Call (slice rule.rule-calls 0))
          owned-not-groups (arr.into [dynamic]Not-Group (slice not-groups 0))
          owned-or-groups (arr.into [dynamic]Or-Group (slice or-groups 0))
          body-steps (arr.into [dynamic]Query-Step (slice rule.body-steps 0))]
      (Rule {name: rule.name
             required-param-count: rule.required-param-count
             params: params
             clauses: owned-clauses
             predicates: predicates
             function-clauses: function-clauses
             get-elses: get-elses
             get-somes: get-somes
             grounds: grounds
             rule-calls: rule-calls
             not-groups: owned-not-groups
             or-groups: owned-or-groups
             body-steps: body-steps}))))

(defn relation-db-rule-call [call: Rule-Call, source: string] -> Rule-Call
  (when call.has-source
    (return call))
  (Rule-Call {name: call.name
              source: source
              has-source: true
              args: call.args}))

(defn relation-db-rule-calls [calls: []Rule-Call, source: string] -> [dynamic]Rule-Call
  (let [out (make [dynamic]Rule-Call 0 (count calls))]
    (for [call calls]
      (arr.push! out (relation-db-rule-call call source)))
    out))

(defn relation-db-inputs [query-value: Query, source: string] -> [dynamic]string
  (let [out (make [dynamic]string 0 (+ (count query-value.inputs) 1))]
    (for [input query-value.inputs]
      (when (not (= input "$"))
        (arr.push! out input)))
    (arr.push! out source)
    out))

(defn relation-db-query [query-value: Query, source: string] -> Query
  (let [inputs (relation-db-inputs query-value source) :defer
        clauses (rule-clauses-with-source (slice query-value.clauses 0) source true) :defer
        rule-calls (relation-db-rule-calls (slice query-value.rule-calls 0) source) :defer
        rules (make [dynamic]Rule) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer]
    (for [rule query-value.rules]
      (arr.push! rules (relation-db-rule rule source)))
    (for [group query-value.not-groups]
      (arr.push! not-groups (relation-db-not-group group source)))
    (for [group query-value.or-groups]
      (arr.push! or-groups (relation-db-or-group group source)))
    (query-with-rules-input
      (query (slice query-value.find 0)
             (slice query-value.with 0)
             (slice inputs 0)
             (slice query-value.collection-inputs 0)
             (slice query-value.tuple-inputs 0)
             (slice query-value.relation-inputs 0)
             (slice clauses 0)
             (slice query-value.predicates 0)
             (slice query-value.function-clauses 0)
             (slice rules 0)
             (slice rule-calls 0)
             (slice query-value.get-elses 0)
             (slice query-value.get-somes 0)
             (slice query-value.grounds 0)
             (slice not-groups 0)
             (slice or-groups 0)
             (slice query-value.pulls 0)
             (slice query-value.aggregates 0))
      query-value.has-rules-input)))

(defn q-query-relation-db-with-fns [rows: Value, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (let [source (primary-relation-db-source-name)
        relation-query (relation-db-query query-value source)
        relation-inputs (arr.into [dynamic]Query-Input inputs) :defer
        empty-datoms (make [dynamic]Datom)
        empty (build-db empty-datoms)]
    (if (= rows.kind .Map)
      (arr.push! relation-inputs (query-input-map-relation rows))
      (arr.push! relation-inputs (query-input-scalar rows)))
    (let [result (q-query-with-sources-and-fns empty relation-query (slice relation-inputs 0) ([]DB-Source []) registry)]
      (delete empty-datoms)
      (delete empty.current)
      (delete empty.eavt)
      (delete empty.aevt)
      (delete empty.avet)
      (delete empty.vaet)
      result)))

(defn q-query-relation-db [rows: Value, query-value: Query, inputs: []Query-Input] -> Result-Set
  (q-query-relation-db-with-fns rows query-value inputs ([]Native-Query-Fn [])))

(defn q-query-with-inputs [db: DB, query: Query, inputs: []Query-Input] -> Result-Set
  (q-query-with-sources db query inputs ([]DB-Source [])))

(defn q-query [db: DB, query: Query] -> Result-Set
  (q-query-with-inputs db query ([]Query-Input [])))

(defn result-scalar [result: Result-Set] -> [value: Value, ok: bool]
  (when (= (count result.rows) 0)
    (return (Value {}) false))
  (when (not (= (count result.rows[0].values) 1))
    (return (Value {}) false))
  (return result.rows[0].values[0] true))

(defn result-collection [result: Result-Set] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) 1)
        (arr.push! out row.values[0])))
    out))

(defn result-tuple [result: Result-Set] -> [dynamic]Value
  (if (> (count result.rows) 0)
    (arr.into [dynamic]Value (slice result.rows[0].values 0))
    (make [dynamic]Value)))

(defn result-pull-scalar [result: Result-Set] -> [pull: Pull-Result, ok: bool]
  (when (= (count result.rows) 0)
    (return (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}) false))
  (when (not (= (count result.rows[0].pulls) 1))
    (return (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}) false))
  (return result.rows[0].pulls[0] true))

(defn result-pull-collection [result: Result-Set] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.pulls) 1)
        (arr.push! out row.pulls[0])))
    out))

(defn pull-render-attr-key [pulled: Pull-Attr] -> Value
  (case pulled.key-kind
    .Keyword (value-keyword pulled.a)
    .Symbol (value-symbol pulled.a)
    .String (value-string pulled.a)
    :else (value-keyword pulled.a)))

(defn pull-render-ref-id-map [entity: u64] -> Value
  (value-map ([]Value [(value-keyword ":db/id") (value-entity entity)])))

(defn pull-render-attr-value [db: DB, pulled: Pull-Attr] -> Value
  (if (> (count pulled.attrs) 0)
    (pull-render-attrs-map db (slice pulled.attrs 0))
    (if (and (= pulled.v.kind .Entity)
             (not (= pulled.a ":db/id")))
      (pull-render-ref-id-map pulled.v.entity)
      pulled.v)))

(defn pull-render-attr-is-many? [db: DB, pulled: Pull-Attr, count-for-attr: int] -> bool
  (when (> count-for-attr 1)
    (return true))
  (when (reverse-attr? pulled.a)
    (let [forward (forward-attr-for-reverse pulled.a) :defer]
      (return (not (schema-component? db forward)))))
  (schema-cardinality-many? db pulled.a))

(defn pull-render-append-key-value! [items: ^[dynamic]Value, key: string, value: Value]
  (arr.push! items^ (value-keyword key))
  (arr.push! items^ value))

(defn pull-render-append-attr-value! [items: ^[dynamic]Value, pulled: Pull-Attr, value: Value]
  (arr.push! items^ (pull-render-attr-key pulled))
  (arr.push! items^ value))

(defn pull-render-group-values [db: DB, attrs: []Pull-Attr, attr-name: string] -> [dynamic]Value
  (let [values (make [dynamic]Value)]
    (for [pulled attrs]
      (when (= pulled.a attr-name)
        (arr.push! values (pull-render-attr-value db pulled))))
    values))

(defn pull-render-attrs-map [db: DB, attrs: []Pull-Attr] -> Value
  (let [items (make [dynamic]Value)
        i 0]
    (while (< i (count attrs))
      (let [pulled attrs[i]
            seen false
            key (pull-render-attr-key pulled)
            j 0]
        (while (< j (count items))
          (when (and (= (% j 2) 0)
                     (value-equal? items[j] key))
            (set! seen true))
          (set! j (+ j 1)))
        (when (not seen)
          (let [values (pull-render-group-values db attrs pulled.a)
                rendered (if (pull-render-attr-is-many? db pulled (count values))
                           (value-vector (slice values 0))
                           values[0])]
            (pull-render-append-attr-value! (addr items) pulled rendered)
            (delete values))))
      (set! i (+ i 1)))
    (let [result (value-map (slice items 0))]
      (delete items)
      result)))

(defn pull-result-value [db: DB, result: Pull-Result] -> Value
  (if (= (count result.attrs) 0)
    (value-nil)
    (pull-render-attrs-map db (slice result.attrs 0))))

(defn pull-many-result-values [db: DB, results: []Pull-Result] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (count results))]
    (for [result results]
      (arr.push! out (pull-result-value db result)))
    out))

(defn pull-many-results-value [db: DB, results: []Pull-Result] -> Value
  (let [items (pull-many-result-values db results)]
    (defer (delete items))
    (value-vector (slice items 0))))

(defn result-row-value [db: DB, row: Result-Row] -> Value
  (let [values (value-vector (slice row.values 0))
        pulls (pull-many-results-value db (slice row.pulls 0))]
    (value-map
      ([]Value [(value-keyword ":values") values
                (value-keyword ":pulls") pulls]))))

(defn result-rows-value [db: DB, rows: []Result-Row] -> Value
  (let [items (make [dynamic]Value 0 (count rows))]
    (defer (delete items))
    (for [row rows]
      (arr.push! items (result-row-value db row)))
    (value-vector (slice items 0))))

(defn result-set-value [db: DB, result: Result-Set] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool result.ok)
              (value-keyword ":error") (value-string result.error)
              (value-keyword ":rows") (result-rows-value db (slice result.rows 0))])))

(defn query-stats-value [stats: Query-Stats] -> Value
  (value-map
    ([]Value [(value-keyword ":input-bindings") (value-int (i64 stats.input-bindings))
              (value-keyword ":steps") (value-int (i64 stats.steps))
              (value-keyword ":clauses") (value-int (i64 stats.clauses))
              (value-keyword ":clause-candidates") (value-int (i64 stats.clause-candidates))
              (value-keyword ":rule-calls") (value-int (i64 stats.rule-calls))
              (value-keyword ":rule-iterations") (value-int (i64 stats.rule-iterations))
              (value-keyword ":max-intermediate-bindings") (value-int (i64 stats.max-intermediate-bindings))
              (value-keyword ":output-rows") (value-int (i64 stats.output-rows))])))

(defn profiled-result-set-value [db: DB, profiled: Profiled-Result-Set] -> Value
  (value-map
    ([]Value [(value-keyword ":result") (result-set-value db profiled.result)
              (value-keyword ":stats") (query-stats-value profiled.stats)])))

(defn result-row-tuple [result: Result-Set] -> Result-Row
  (if (> (count result.rows) 0)
    (let [values (arr.into [dynamic]Value (slice result.rows[0].values 0))
          pulls (arr.into [dynamic]Pull-Result (slice result.rows[0].pulls 0))]
      (Result-Row {values: values pulls: pulls}))
    (Result-Row {values: (make [dynamic]Value)
                 pulls: (make [dynamic]Pull-Result)})))

(defn result-keys [result: Result-Set, kind: Key-Kind, keys: []string] -> [dynamic]Keyed-Row
  (let [out (make [dynamic]Keyed-Row 0 (count result.rows))]
    (for [row result.rows]
      (when (= (count row.values) (count keys))
        (let [items (make [dynamic]Keyed-Value 0 (count keys))]
          (for [key index keys]
            (arr.push! items (Keyed-Value {kind: kind key: key value: row.values[index]})))
          (arr.push! out (Keyed-Row {items: items})))))
    out))

(defn q-strings [db: DB, query: Query] -> [dynamic]string
  (let [result (q-query db query)
        out (make [dynamic]string 0 (count result.rows))]
    (for [row result.rows]
      (when (and (= (count row.values) 1)
                 (= row.values[0].kind .String))
        (arr.push! out row.values[0].text)))
    out))

(defn reverse-attr? [attr: string] -> bool
  (when (strings.has_prefix attr ":_")
    (return true))
  (for [_ index attr]
    (when (and (< (+ index 2) (count attr))
               (= (slice attr index (+ index 2)) "/_"))
      (return true)))
  false)

(defn forward-attr-for-reverse [attr: string] -> string
  (when (strings.has_prefix attr ":_")
    (return (strings.concatenate ([]string [":" (slice attr 2)]))))
  (for [_ index attr]
    (when (and (< (+ index 2) (count attr))
               (= (slice attr index (+ index 2)) "/_"))
      (return (strings.concatenate ([]string [(slice attr 0 (+ index 1))
                                              (slice attr (+ index 2))])))))
  attr)

(defn validate-pull-spec-schema [db: DB, spec: Pull-Spec] -> [ok: bool, error: string]
  (when (or (= spec.a "*")
            (= spec.a ":db/id"))
    (return true ""))
  (let [has-schema (db-has-schema? db)
        reverse? (reverse-attr? spec.a)
        attr (if reverse?
               (forward-attr-for-reverse spec.a)
               spec.a)]
    (defer (when reverse? (delete attr)))
    (when (and has-schema
               reverse?
               (not (schema-ref? db attr)))
      (return false (fmt.tprintf "pull reverse attr must be ref: %s" spec.a)))
    (when (and has-schema
               spec.has-limit
               (not (schema-cardinality-many? db attr)))
      (return false (fmt.tprintf "pull limit attr must be cardinality many: %s" spec.a)))
    (when (and has-schema
               (or (> (count spec.pattern) 0)
                   spec.has-recursion)
               (not (schema-ref? db attr)))
      (return false (fmt.tprintf "pull nested attr must be ref: %s" spec.a)))
    (for [child spec.pattern]
      (let [[child-ok child-error] (validate-pull-spec-schema db child)]
        (when (not child-ok)
          (return false child-error)))))
  (return true ""))

(defn validate-pull-pattern [db: DB, pattern: []Pull-Spec] -> [ok: bool, error: string]
  (for [spec pattern]
    (let [[spec-ok spec-error] (validate-pull-spec-schema db spec)]
      (when (not spec-ok)
        (return false spec-error))))
  (return true ""))

(defn pull-output-has-attr? [out: [dynamic]Pull-Attr, attr: string] -> bool
  (for [pulled out]
    (when (= pulled.a attr)
      (return true)))
  false)

(defn pull-spec-output-index [pattern: []Pull-Spec, spec: Pull-Spec] -> [index: int, ok: bool]
  (let [attr (pull-output-attr spec)]
    (for [existing index pattern]
      (when (and (not (= existing.a "*"))
                 (= (pull-output-attr existing) attr))
        (return index true))))
  (return 0 false))

(defn normalize-pull-pattern [pattern: []Pull-Spec] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec 0 (count pattern))]
    (for [spec pattern]
      (if (= spec.a "*")
        (arr.push! out spec)
        (let [[index exists] (pull-spec-output-index (slice out 0) spec)]
          (if exists
            (set! out[index] spec)
            (arr.push! out spec)))))
    out))

(defn pull-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (return datom.v true)))))
  (return (Value {}) false))

(defn pull-attr-entity-target [db: DB, entity: u64, attr: string] -> [target: u64, ok: bool, many: bool]
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity attr (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity attr (Value {}))
        found-target: u64 0
        found false]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity))
          (when found
            (return found-target true true))
          (set! found-target datom.v.entity)
          (set! found true))))
    (return found-target found false)))

(defn pull-limit [spec: Pull-Spec] -> int
  (if (= spec.limit -1)
    2147483647
    (if (> spec.limit 0) spec.limit 1000)))

(defn pull-id-attrs [entity: u64] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (arr.push! out (Pull-Attr {a: ":db/id"
                               v: (value-entity entity)
                               attrs: (make [dynamic]Pull-Attr)}))
    out))

(defn pull-seen-counts [seen: []u64] -> map[u64]int
  (let [out (make (map u64 int) (count seen))]
    (for [entity seen]
      (let [[count found] (mmap.get out entity)]
        (if found
          (mmap.assoc! out entity (+ count 1))
          (mmap.assoc! out entity 1))))
    out))

(defn pull-seen-count [counts: (ptr (map u64 int)), entity: u64] -> int
  (let [[count found] (mmap.get counts^ entity)]
    (if found count 0)))

(defn pull-seen-contains? [counts: (ptr (map u64 int)), entity: u64] -> bool
  (> (pull-seen-count counts entity) 0))

(defn pull-seen-push! [counts: (ptr (map u64 int)), entity: u64]
  (mmap.assoc! counts^ entity (+ (pull-seen-count counts entity) 1)))

(defn pull-seen-pop! [counts: (ptr (map u64 int)), entity: u64]
  (let [count (pull-seen-count counts entity)]
    (when (<= count 1)
      (mmap.dissoc! counts^ entity)
      (return))
    (mmap.assoc! counts^ entity (- count 1))))

(defn pull-child-pattern-normalized-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [seen-count (count seen^)]
    (arr.push! seen^ entity)
    (pull-seen-push! seen-counts entity)
    (let [pulled (pull-pattern-spec-seen-with-fns db entity pattern root seen seen-counts registry)]
      (pull-seen-pop! seen-counts entity)
      (arr.remove-unordered-at! seen^ seen-count)
      pulled.attrs)))

(defn pull-child-pattern-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [normalized (normalize-pull-pattern pattern) :defer]
    (pull-child-pattern-normalized-mut-with-fns db entity (slice normalized 0) (slice normalized 0) seen seen-counts registry)))

(defn pull-child-pattern-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [child-seen (arr.into [dynamic]u64 seen)
        seen-counts (pull-seen-counts seen)]
    (defer (delete child-seen))
    (defer (delete seen-counts))
    (pull-child-pattern-mut-with-fns db entity pattern root (addr child-seen) (addr seen-counts) registry)))

(defn pull-child-pattern [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (pull-child-pattern-with-fns db entity pattern root seen ([]Native-Query-Fn [])))

(defn pull-child-recursion-mut-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (if (pull-seen-contains? seen-counts entity)
    (pull-id-attrs entity)
    (pull-child-pattern-normalized-mut-with-fns db entity pattern pattern seen seen-counts registry)))

(defn pull-child-recursion-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, seen: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [child-seen (arr.into [dynamic]u64 seen)
        seen-counts (pull-seen-counts seen)]
    (defer (delete child-seen))
    (defer (delete seen-counts))
    (pull-child-recursion-mut-with-fns db entity pattern (addr child-seen) (addr seen-counts) registry)))

(defn pull-child-recursion [db: DB, entity: u64, pattern: []Pull-Spec, seen: []u64] -> [dynamic]Pull-Attr
  (pull-child-recursion-with-fns db entity pattern seen ([]Native-Query-Fn [])))

(defn pull-include-ref-result? [spec: Pull-Spec, children: []Pull-Attr] -> bool
  (or (= (count spec.pattern) 0)
      (> (count children) 0)))

(defn pull-reverse-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> bool
  (let [forward-attr (forward-attr-for-reverse spec.a) :defer
        ref-value (value-entity entity)
        indexes (slice db.vaet 0)
        low (lower-bound-index db indexes "vaet" 0 "" ref-value)
        high (upper-bound-index db indexes "vaet" 0 "" ref-value)
        limit (pull-limit spec)
        seen 0
        found false]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? db datom-index))
          (let [children (make [dynamic]Pull-Attr)]
            (when (> (count spec.pattern) 0)
              (set! children (pull-child-pattern-mut-with-fns db datom.e spec.pattern spec.pattern seen-entities seen-counts registry)))
            (when (and (= (count spec.pattern) 0)
                       spec.has-recursion
                       (not (= spec.recursion-depth 0)))
              (if (pull-unbounded-recursion-depth? spec.recursion-depth)
                (set! children (pull-child-recursion-mut-with-fns db datom.e root seen-entities seen-counts registry))
                (let [pattern (pull-recursion-pattern root spec.a)]
                  (defer (delete pattern))
                  (set! children (pull-child-recursion-mut-with-fns db datom.e (slice pattern 0) seen-entities seen-counts registry)))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^
                  (pull-spec-transform-attr-with-fns
                    spec
                    (pull-attr-from-spec spec (value-entity datom.e) children)
                    registry))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-reverse-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-reverse-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-wildcard-seen! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, seen: ^[dynamic]u64]
  (when (not (pull-output-has-attr? out^ ":db/id"))
    (arr.push! out^ (Pull-Attr {a: ":db/id"
                                v: (value-entity entity)
                                attrs: (make [dynamic]Pull-Attr)})))
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" entity "" (Value {}))
        high (upper-bound-index db indexes "eavt" entity "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (not (pull-output-has-attr? out^ datom.a))
            (let [children (make [dynamic]Pull-Attr)]
              (when (and (= datom.v.kind .Entity)
                         (schema-component? db datom.a))
                (set! children (pull-component-attrs db datom.v.entity seen)))
              (arr.push! out^ (Pull-Attr {a: datom.a
                                          v: datom.v
                                          attrs: children})))))))))

(defn pull-component-attrs [db: DB, entity: u64, seen: ^[dynamic]u64] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (if (u64-contains? (slice seen^ 0) entity)
      (arr.push! out (Pull-Attr {a: ":db/id"
                                 v: (value-entity entity)
                                 attrs: (make [dynamic]Pull-Attr)}))
      (do
        (arr.push! seen^ entity)
        (pull-wildcard-seen! (addr out) db entity seen)))
    out))

(defn pull-wildcard! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64]
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen entity)
    (pull-wildcard-seen! out db entity (addr seen))))

(defn pull-component-children [db: DB, parent: u64, child: u64] -> [dynamic]Pull-Attr
  (let [seen (make [dynamic]u64)]
    (defer (delete seen))
    (arr.push! seen parent)
    (pull-component-attrs db child (addr seen))))

(defn pull-output-attr [spec: Pull-Spec] -> string
  (if spec.has-alias spec.alias spec.a))

(defn pull-output-key-kind [spec: Pull-Spec] -> Key-Kind
  (if spec.has-alias spec.alias-kind .Keyword))

(defn pull-attr-from-spec [spec: Pull-Spec, value: Value, attrs: [dynamic]Pull-Attr] -> Pull-Attr
  (Pull-Attr {a: (pull-output-attr spec)
              key-kind: (pull-output-key-kind spec)
              v: value
              attrs: attrs}))

(defn pull-next-recursion-depth [depth: int] -> int
  (- depth 1))

(defn pull-unbounded-recursion-depth? [depth: int] -> bool
  (= depth 2147483647))

(defn pull-simple-unbounded-forward-recursion-spec [pattern: []Pull-Spec] -> [spec: Pull-Spec, ok: bool]
  (let [candidate (Pull-Spec {})
        found false]
    (for [spec index pattern]
      (if (and spec.has-recursion
               (pull-unbounded-recursion-depth? spec.recursion-depth)
               (= (count spec.pattern) 0)
               (not (reverse-attr? spec.a)))
        (do
          (when (or found (not (= index (- (count pattern) 1))))
            (return (Pull-Spec {}) false))
          (set! candidate spec)
          (set! found true))
        (when (or spec.has-recursion
                  (> (count spec.pattern) 0)
                  (= spec.a "*"))
          (return (Pull-Spec {}) false))))
    (return candidate found)))

(defn pull-flat-pattern-except-attr-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, attr: string, seen: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [dynamic]Pull-Attr
  (let [out (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (when (not (= spec.a attr))
        (pull-spec-attr-with-fns! (addr out) db entity spec pattern seen seen-counts registry)))
    out))

(defn pull-pattern-simple-unbounded-forward-chain-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, spec: Pull-Spec, registry: []Native-Query-Fn] -> [result: Pull-Result, ok: bool]
  (let [path (make [dynamic]u64)
        seen-counts (make (map u64 int))
        cycle false]
    (arr.push! path entity)
    (pull-seen-push! (addr seen-counts) entity)
    (while true
      (let [current path[(- (count path) 1)]
            [target found many] (pull-attr-entity-target db current spec.a)]
        (when many
          (delete path)
          (delete seen-counts)
          (return (Pull-Result {e: entity attrs: (make [dynamic]Pull-Attr)}) false))
        (when (not found)
          (break))
        (arr.push! path target)
        (when (pull-seen-contains? (addr seen-counts) target)
          (set! cycle true)
          (break))
        (pull-seen-push! (addr seen-counts) target)))
    (let [build-seen (make [dynamic]u64)
          build-counts (make (map u64 int))
          last-entity path[(- (count path) 1)]
          child-attrs (if cycle
                        (pull-id-attrs last-entity)
                        (pull-flat-pattern-except-attr-with-fns db last-entity pattern spec.a (addr build-seen) (addr build-counts) registry))
          i (- (count path) 2)]
      (while (>= i 0)
        (let [parent path[i]
              child path[(+ i 1)]
              attrs (pull-flat-pattern-except-attr-with-fns db parent pattern spec.a (addr build-seen) (addr build-counts) registry)]
          (arr.push! attrs
            (pull-spec-transform-attr-with-fns
              spec
              (pull-attr-from-spec spec (value-entity child) child-attrs)
              registry))
          (set! child-attrs attrs)
          (set! i (- i 1))))
      (let [built-result (Pull-Result {e: entity attrs: child-attrs})]
        (delete build-seen)
        (delete build-counts)
        (delete path)
        (delete seen-counts)
        (return built-result true)))))

(defn pull-spec-decrement-recursion [spec: Pull-Spec, attr: string] -> Pull-Spec
  (if (and spec.has-recursion
           (= spec.a attr)
           (not (= spec.recursion-depth 0)))
    (Pull-Spec {a: spec.a
                pattern: spec.pattern
                limit: spec.limit
                has-limit: spec.has-limit
                has-default: spec.has-default
                default-value: spec.default-value
                has-alias: spec.has-alias
                alias: spec.alias
                alias-kind: spec.alias-kind
                has-xform: spec.has-xform
                xform: spec.xform
                has-recursion: true
                recursion-depth: (pull-next-recursion-depth spec.recursion-depth)})
    spec))

(defn pull-recursion-pattern [root: []Pull-Spec, attr: string] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec)]
    (for [spec root]
      (arr.push! out (pull-spec-decrement-recursion spec attr)))
    out))

(defn pull-attr-child-value [children: []Pull-Attr, attr: string] -> [value: Value, ok: bool]
  (for [child children]
    (when (= child.a attr)
      (return child.v true)))
  (return (Value {}) false))

(defn pull-spec-transform-attr-with-fns [spec: Pull-Spec, attr: Pull-Attr, registry: []Native-Query-Fn] -> Pull-Attr
  (when (not spec.has-xform)
    (return attr))
  (when (= spec.xform "vector")
    (return (Pull-Attr {a: attr.a
                        key-kind: attr.key-kind
                        v: (value-vector ([]Value [attr.v]))
                        attrs: (make [dynamic]Pull-Attr)})))
  (when (= spec.xform "name")
    (let [[name name-ok] (pull-attr-child-value (slice attr.attrs 0) ":name")]
      (when name-ok
        (delete attr.attrs)
        (return (Pull-Attr {a: attr.a
                            key-kind: attr.key-kind
                            v: name
                            attrs: (make [dynamic]Pull-Attr)})))))
  (let [[index found] (query-fn-index registry spec.xform)]
    (when found
      (let [entry registry[index]]
        (when entry.has-pull-xform-callback
          (let [result (entry.pull-xform-callback attr.v)]
            (when result.ok
              (delete attr.attrs)
              (return (Pull-Attr {a: attr.a
                                  key-kind: attr.key-kind
                                  v: result.value
                                  attrs: (make [dynamic]Pull-Attr)}))))))))
  attr)

(defn pull-spec-transform-attr [spec: Pull-Spec, attr: Pull-Attr] -> Pull-Attr
  (pull-spec-transform-attr-with-fns spec attr ([]Native-Query-Fn [])))

(defn pull-spec-missing-attr-with-fns [spec: Pull-Spec, registry: []Native-Query-Fn] -> Pull-Attr
  (if spec.has-default
    (pull-attr-from-spec spec spec.default-value (make [dynamic]Pull-Attr))
    (pull-spec-transform-attr-with-fns
      spec
      (pull-attr-from-spec spec (value-nil) (make [dynamic]Pull-Attr))
      registry)))

(defn pull-spec-missing-attr [spec: Pull-Spec] -> Pull-Attr
  (pull-spec-missing-attr-with-fns spec ([]Native-Query-Fn [])))

(defn pull-forward-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        limit (pull-limit spec)
        seen 0
        found false]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [children (make [dynamic]Pull-Attr)]
            (when (= datom.v.kind .Entity)
              (if (> (count spec.pattern) 0)
                (set! children (pull-child-pattern-mut-with-fns db datom.v.entity spec.pattern spec.pattern seen-entities seen-counts registry))
                (if (and spec.has-recursion (not (= spec.recursion-depth 0)))
                  (if (pull-unbounded-recursion-depth? spec.recursion-depth)
                    (set! children (pull-child-recursion-mut-with-fns db datom.v.entity root seen-entities seen-counts registry))
                    (let [pattern (pull-recursion-pattern root spec.a)]
                      (defer (delete pattern))
                      (set! children (pull-child-recursion-mut-with-fns db datom.v.entity (slice pattern 0) seen-entities seen-counts registry))))
                  (when (schema-component? db datom.a)
                    (set! children (pull-component-children db entity datom.v.entity))))))
            (if (pull-include-ref-result? spec (slice children 0))
              (do
                (arr.push! out^
                  (pull-spec-transform-attr-with-fns
                    spec
                    (pull-attr-from-spec spec datom.v children)
                    registry))
                (set! found true)
                (set! seen (+ seen 1))
                (when (>= seen limit)
                  (return found)))
              (delete children))))))
    found))

(defn pull-forward-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> bool
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-forward-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-spec-attr-with-fns! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn]
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (when (= spec.a "*")
    (pull-wildcard! out db entity)
    (return))
  (when (= spec.a ":db/id")
    (when (not (pull-output-has-attr? out^ (pull-output-attr spec)))
      (arr.push! out^
        (pull-spec-transform-attr-with-fns
          spec
          (pull-attr-from-spec spec (value-entity entity) (make [dynamic]Pull-Attr))
          registry)))
    (return))
  (when (reverse-attr? spec.a)
    (let [found (pull-reverse-attr-with-fns! out db entity spec root seen-entities seen-counts registry)]
      (when (and (not found) (or spec.has-default spec.has-xform))
        (arr.push! out^ (pull-spec-missing-attr-with-fns spec registry))))
    (return))
  (let [found (pull-forward-attr-with-fns! out db entity spec root seen-entities seen-counts registry)]
    (when (and (not found) (or spec.has-default spec.has-xform))
      (arr.push! out^ (pull-spec-missing-attr-with-fns spec registry)))))

(defn pull-spec-attr! [out: ^[dynamic]Pull-Attr, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-spec-attr-with-fns! out db entity spec root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-pattern-spec-seen-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: ^[dynamic]u64, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> Pull-Result
  (let [out (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (pull-spec-attr-with-fns! (addr out) db entity spec root seen-entities seen-counts registry))
    (Pull-Result {e: entity attrs: out})))

(defn pull-pattern-spec-seen [db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: []u64] -> Pull-Result
  (let [seen (arr.into [dynamic]u64 seen-entities)
        seen-counts (pull-seen-counts seen-entities)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (pull-pattern-spec-seen-with-fns db entity pattern root (addr seen) (addr seen-counts) ([]Native-Query-Fn []))))

(defn pull-pattern-spec-with-fns [db: DB, entity: u64, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [seen (make [dynamic]u64)
        seen-counts (make (map u64 int))
        normalized (normalize-pull-pattern pattern)]
    (defer (delete seen))
    (defer (delete seen-counts))
    (defer (delete normalized))
    (let [[chain-spec chain-ok] (pull-simple-unbounded-forward-recursion-spec (slice normalized 0))]
      (when chain-ok
        (let [[chain chain-built] (pull-pattern-simple-unbounded-forward-chain-with-fns db entity (slice normalized 0) chain-spec registry)]
          (when chain-built
            (return chain)))))
    (arr.push! seen entity)
    (pull-seen-push! (addr seen-counts) entity)
    (pull-pattern-spec-seen-with-fns db entity (slice normalized 0) (slice normalized 0) (addr seen) (addr seen-counts) registry)))

(defn pull-pattern-spec [db: DB, entity: u64, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-spec-with-fns db entity pattern ([]Native-Query-Fn [])))

(defn pull-pattern-lookup-ref-with-fns [db: DB, attr: string, value: Value, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [[entity ok] (resolve-lookup-ref db attr value)]
    (if ok
      (pull-pattern-spec-with-fns db entity pattern registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-pattern-lookup-ref [db: DB, attr: string, value: Value, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-lookup-ref-with-fns db attr value pattern ([]Native-Query-Fn [])))

(defn pull-pattern-ident-with-fns [db: DB, ident: string, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> Pull-Result
  (let [[entity ok] (schema-entity-for-attr db ident)]
    (if ok
      (pull-pattern-spec-with-fns db entity pattern registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-pattern-ident [db: DB, ident: string, pattern: []Pull-Spec] -> Pull-Result
  (pull-pattern-ident-with-fns db ident pattern ([]Native-Query-Fn [])))

(defn pull-visit-attr [entity: u64, attr: string] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/attr"
               has-e: true
               e: entity
               a: attr
               has-v: false}))

(defn pull-visit-wildcard [entity: u64] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/wildcard"
               has-e: true
               e: entity
               a: ""
               has-v: false}))

(defn pull-visit-reverse [attr: string, entity: u64] -> Pull-Visit
  (Pull-Visit {kind: ":db.pull/reverse"
               has-e: false
               e: 0
               a: attr
               has-v: true
               v-entity: entity}))

(defn string-seen? [items: []string, value: string] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn trace-pull-wildcard! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64]
  (arr.push! visits^ (pull-visit-wildcard entity))
  (let [seen-attrs (make [dynamic]string) :defer
        indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" entity "" (Value {}))
        high (upper-bound-index db indexes "eavt" entity "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (string-seen? (slice seen-attrs 0) datom.a)))
          (arr.push! seen-attrs datom.a)
          (arr.push! visits^ (pull-visit-attr entity datom.a)))))))

(defn trace-pull-reverse-refs! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (arr.push! visits^ (pull-visit-reverse (forward-attr-for-reverse spec.a) entity))
  (when (and (= (count spec.pattern) 0)
             (not spec.has-recursion))
    (return))
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (let [forward-attr (forward-attr-for-reverse spec.a) :defer
        ref-value (value-entity entity)
        indexes (slice db.vaet 0)
        low (lower-bound-index db indexes "vaet" 0 "" ref-value)
        high (upper-bound-index db indexes "vaet" 0 "" ref-value)
        limit (pull-limit spec)
        seen 0]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (= datom.a forward-attr)
                   (datom-current-at? db datom-index)
                   (< seen limit))
          (if (> (count spec.pattern) 0)
            (trace-pull-pattern! visits db datom.e spec.pattern spec.pattern seen-entities)
            (when spec.has-recursion
              (let [pattern (pull-recursion-pattern root spec.a)]
                (defer (delete pattern))
                (trace-pull-pattern! visits db datom.e (slice pattern 0) (slice pattern 0) seen-entities))))
          (set! seen (+ seen 1)))))))

(defn trace-pull-forward-refs! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (arr.push! visits^ (pull-visit-attr entity spec.a))
  (when (and (= (count spec.pattern) 0)
             (not spec.has-recursion))
    (return))
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        high (upper-bound-index db indexes "eavt-ea" entity spec.a (Value {}))
        limit (pull-limit spec)
        seen 0]
    (for [datom-index (slice indexes low high)]
      (let [datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (< seen limit))
          (if (> (count spec.pattern) 0)
            (trace-pull-pattern! visits db datom.v.entity spec.pattern spec.pattern seen-entities)
            (when spec.has-recursion
              (let [pattern (pull-recursion-pattern root spec.a)]
                (defer (delete pattern))
                (trace-pull-pattern! visits db datom.v.entity (slice pattern 0) (slice pattern 0) seen-entities))))
          (set! seen (+ seen 1)))))))

(defn trace-pull-spec! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, spec: Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (when (and spec.has-recursion (<= spec.recursion-depth 0))
    (return))
  (when (= spec.a "*")
    (trace-pull-wildcard! visits db entity)
    (return))
  (when (= spec.a ":db/id")
    (return))
  (if (reverse-attr? spec.a)
    (trace-pull-reverse-refs! visits db entity spec root seen-entities)
    (trace-pull-forward-refs! visits db entity spec root seen-entities)))

(defn trace-pull-pattern! [visits: ^[dynamic]Pull-Visit, db: DB, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-entities: []u64]
  (when (u64-contains? seen-entities entity)
    (return))
  (let [child-seen (arr.into [dynamic]u64 seen-entities) :defer]
    (arr.push! child-seen entity)
    (let [normalized (normalize-pull-pattern pattern) :defer]
      (for [spec normalized]
        (trace-pull-spec! visits db entity spec root (slice child-seen 0))))))

(defn pull-visits-pattern-spec [db: DB, entity: u64, pattern: []Pull-Spec] -> [dynamic]Pull-Visit
  (let [visits (make [dynamic]Pull-Visit)
        seen (make [dynamic]u64) :defer
        normalized (normalize-pull-pattern pattern) :defer]
    (trace-pull-pattern! (addr visits) db entity (slice normalized 0) (slice normalized 0) (slice seen 0))
    visits))

(defn pull-pattern-spec-traced [db: DB, entity: u64, pattern: []Pull-Spec] -> [result: Pull-Result, visits: [dynamic]Pull-Visit]
  (let [pulled (pull-pattern-spec db entity pattern)
        trace (pull-visits-pattern-spec db entity pattern)]
    (return pulled trace)))

(defn entity-exists? [db: DB, e: u64] -> bool
  (let [indexes (slice db.eavt 0)
        low (lower-bound-index db indexes "eavt" e "" (Value {}))
        high (upper-bound-index db indexes "eavt" e "" (Value {}))]
    (for [datom-index (slice indexes low high)]
      (when (datom-current-at? db datom-index)
        (return true))))
  false)

(defn db-entity [db: DB, e: u64] -> Entity
  (Entity {db: db e: e found: (entity-exists? db e)}))

(defn entity-lookup-ref [db: DB, attr: string, value: Value] -> Entity
  (let [[e ok] (resolve-lookup-ref db attr value)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-ident [db: DB, ident: string] -> Entity
  (let [[e ok] (schema-entity-for-attr db ident)]
    (if ok
      (db-entity db e)
      (Entity {db: db e: 0 found: false}))))

(defn entity-id [entity: Entity] -> u64
  entity.e)

(defn entity-db [entity: Entity] -> DB
  entity.db)

(defn entity-forward-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [indexes (slice entity.db.eavt 0)
          low (lower-bound-index entity.db indexes "eavt-ea" entity.e attr (Value {}))
          high (upper-bound-index entity.db indexes "eavt-ea" entity.e attr (Value {}))]
      (for [datom-index (slice indexes low high)]
        (let [datom entity.db.datoms[datom-index]]
          (when (datom-current-at? entity.db datom-index)
            (arr.push! out datom.v)))))
    out))

(defn entity-reverse-values [entity: Entity, attr: string] -> [dynamic]Value
  (let [out (make [dynamic]Value)]
    (when (not entity.found)
      (return out))
    (let [forward-attr (forward-attr-for-reverse attr)
          ref-value (value-entity entity.e)
          indexes (slice entity.db.vaet 0)
          low (lower-bound-index entity.db indexes "vaet" 0 "" ref-value)
          high (upper-bound-index entity.db indexes "vaet" 0 "" ref-value)]
      (for [datom-index (slice indexes low high)]
        (let [datom entity.db.datoms[datom-index]]
          (when (and (= datom.a forward-attr)
                     (datom-current-at? entity.db datom-index))
            (arr.push! out (value-entity datom.e))))))
    out))

(defn entity-values [entity: Entity, attr: string] -> [dynamic]Value
  (if (reverse-attr? attr)
    (entity-reverse-values entity attr)
    (entity-forward-values entity attr)))

(defn entity-get [entity: Entity, attr: string] -> Value
  (when (= attr ":db/id")
    (when entity.found
      (return (value-entity entity.e)))
    (return (value-nil)))
  (let [values (entity-values entity attr)]
    (defer (delete values))
    (if (> (count values) 0)
      values[0]
      (value-nil))))

(defn entity-get-kw [entity: Entity, attr: keyword] -> Value
  (entity-get entity (keyword-text attr)))

(defn entity-contains? [entity: Entity, attr: string] -> bool
  (when (= attr ":db/id")
    (return entity.found))
  (let [values (entity-values entity attr)]
    (defer (delete values))
    (> (count values) 0)))

(defn entity-refs [entity: Entity, attr: string] -> [dynamic]Entity
  (let [out (make [dynamic]Entity)
        values (entity-values entity attr)]
    (defer (delete values))
    (for [value values]
      (when (= value.kind .Entity)
        (let [ref (db-entity entity.db value.entity)]
          (when ref.found
            (arr.push! out ref)))))
    out))

(defn entity-ref [entity: Entity, attr: string] -> Entity
  (let [refs (entity-refs entity attr)]
    (defer (delete refs))
    (if (> (count refs) 0)
      refs[0]
      (Entity {db: entity.db e: 0 found: false}))))

(defn entity-ref-kw [entity: Entity, attr: keyword] -> Entity
  (entity-ref entity (keyword-text attr)))

(defn touch [entity: Entity] -> Pull-Result
  (if entity.found
    (pull-pattern-spec entity.db entity.e ([]Pull-Spec [(flat-pull-spec "*")]))
    (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))

(defn flat-pull-spec [attr: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: ([]Pull-Spec [])}))

(defn flat-pull-spec-kw [attr: keyword] -> Pull-Spec
  (flat-pull-spec (keyword-text attr)))

(defn pull-alias-key-kind [alias: string] -> Key-Kind
  (if (strings.has_prefix alias ":")
    .Keyword
    .String))

(defn pull-spec [attr: string, pattern: []Pull-Spec] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: pattern}))

(defn pull-spec-kw [attr: keyword, pattern: []Pull-Spec] -> Pull-Spec
  (pull-spec (keyword-text attr) pattern))

(defn query-input-pull-pattern [pattern: []Pull-Spec] -> Query-Input
  (Query-Input {kind: .PullPattern pattern: pattern}))

(defn pull-spec-recursion [attr: string, depth: int] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: ([]Pull-Spec [])
              has-recursion: true
              recursion-depth: depth}))

(defn pull-spec-recursion-kw [attr: keyword, depth: int] -> Pull-Spec
  (pull-spec-recursion (keyword-text attr) depth))

(defn pull-spec-limit [attr: string, pattern: []Pull-Spec, limit: int] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: limit
              has-limit: true
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: pattern}))

(defn pull-spec-limit-kw [attr: keyword, pattern: []Pull-Spec, limit: int] -> Pull-Spec
  (pull-spec-limit (keyword-text attr) pattern limit))

(defn pull-spec-limit-as [attr: string, pattern: []Pull-Spec, limit: int, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: limit
              has-limit: true
              has-default: false
              default-value: (Value {})
              has-alias: true
              alias: alias
              alias-kind: (pull-alias-key-kind alias)
              has-xform: false
              xform: ""
              pattern: pattern}))

(defn pull-spec-default [attr: string, default-value: Value] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: true
              default-value: default-value
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: false
              xform: ""
              pattern: ([]Pull-Spec [])}))

(defn pull-spec-default-kw [attr: keyword, default-value: Value] -> Pull-Spec
  (pull-spec-default (keyword-text attr) default-value))

(defn pull-spec-as [attr: string, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: true
              alias: alias
              alias-kind: (pull-alias-key-kind alias)
              has-xform: false
              xform: ""
              pattern: ([]Pull-Spec [])}))

(defn pull-spec-default-as [attr: string, default-value: Value, alias: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: true
              default-value: default-value
              has-alias: true
              alias: alias
              alias-kind: (pull-alias-key-kind alias)
              has-xform: false
              xform: ""
              pattern: ([]Pull-Spec [])}))

(defn pull-spec-xform [attr: string, pattern: []Pull-Spec, xform: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: false
              default-value: (Value {})
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: true
              xform: xform
              pattern: pattern}))

(defn pull-spec-default-xform [attr: string, default-value: Value, xform: string] -> Pull-Spec
  (Pull-Spec {a: attr
              limit: 0
              has-limit: false
              has-default: true
              default-value: default-value
              has-alias: false
              alias: ""
              alias-kind: .Keyword
              has-xform: true
              xform: xform
              pattern: ([]Pull-Spec [])}))

(defn pull-pattern [db: DB, entity: u64, attrs: []string] -> Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-pattern-spec db entity (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn pull-many-pattern-spec-with-fns [db: DB, entities: []u64, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count entities))]
    (for [entity entities]
      (arr.push! out (pull-pattern-spec-with-fns db entity pattern registry)))
    out))

(defn pull-many-pattern-spec [db: DB, entities: []u64, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (pull-many-pattern-spec-with-fns db entities pattern ([]Native-Query-Fn [])))

(defn pull-many-pattern-lookup-refs-with-fns [db: DB, attrs: []string, values: []Value, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (let [out (make [dynamic]Pull-Result 0 (count values))]
    (for [value index values]
      (let [[entity ok] (resolve-lookup-ref db attrs[index] value)]
        (if ok
          (arr.push! out (pull-pattern-spec-with-fns db entity pattern registry))
          (arr.push! out (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))))
    out))

(defn pull-many-pattern-lookup-refs [db: DB, attrs: []string, values: []Value, pattern: []Pull-Spec] -> [dynamic]Pull-Result
  (pull-many-pattern-lookup-refs-with-fns db attrs values pattern ([]Native-Query-Fn [])))

(defn pull-many-pattern [db: DB, entities: []u64, attrs: []string] -> [dynamic]Pull-Result
  (let [pattern (make [dynamic]Pull-Spec 0 (count attrs))]
    (for [attr attrs]
      (arr.push! pattern (flat-pull-spec attr)))
    (let [pulled (pull-many-pattern-spec db entities (slice pattern 0))]
      (delete pattern)
      pulled)))

(defn query-name-by-email [email: string] -> Query
  (query ([]string ["name"])
    ([]string [])
    ([]string [])
    ([]string [])
    ([]Tuple-Input [])
    ([]Relation-Input [])
    ([]Clause
      [(clause (term-var "e") ":user/email" (term-string email))
       (clause (term-var "e") ":user/name" (term-var "name"))])
    ([]Predicate [])
    ([]Function-Clause [])
    ([]Rule [])
    ([]Rule-Call [])
    ([]Get-Else [])
    ([]Get-Some [])
    ([]Ground [])
    ([]Not-Group [])
    ([]Or-Group [])
    ([]Pull-Find [])
    ([]Aggregate-Find [])))

(defn seed-people [conn: ^Conn] -> Tx-Report
  (transact conn
    [[:db/add 1 :user/email "ada@example.com"]
     [:db/add 1 :user/name "Ada"]
     [:db/add 1 :user/age 37]
     [:db/add 1 :user/active true]
     [:db/add 1 :user/friend (value-entity 2)]
     [:db/add 2 :user/email "grace@example.com"]
     [:db/add 2 :user/name "Grace"]
     [:db/add 2 :user/age 41]
     [:db/add 2 :user/active false]]))
