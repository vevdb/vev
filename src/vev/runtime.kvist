        (when (> (count parent-entities) 0)
          (mut! scan-count += 1))
        (when (>= frontier-candidates 0)
          (mut! candidate-count += frontier-candidates))
        (while frontier-stream.has-current
          (when (< frontier-candidates 0)
            (mut! candidate-count += 1))
          (let [child frontier-stream.current.e
                already-seen (set.contains? child-seen^ child)]
            (when (not already-seen)
              (set.add! child-seen^ child)
              (arr.push! child-entities^ child)))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr frontier-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream frontier-stream)
              (return false advance-error scan-count candidate-count))))
        (delete-source-index-datom-stream frontier-stream)
        (return true "" scan-count candidate-count)))
    (for [parent parent-entities]
      (mut! scan-count += 1)
      (let [[stream stream-ok stream-error] (source-vaet-entity-attr-stream source parent attr)]
        (when (not stream-ok)
          (return false stream-error scan-count candidate-count))
        (while stream.has-current
          (mut! candidate-count += 1)
          (let [child stream.current.e
                already-seen (set.contains? child-seen^ child)]
            (when (not already-seen)
              (set.add! child-seen^ child)
              (arr.push! child-entities^ child)))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false advance-error scan-count candidate-count))))
        (delete-source-index-datom-stream stream)))
    (return true "" scan-count candidate-count)))

(defn q-db-read-source-multi-hop-ref-chain-projection-batched [source: DB-Read-Source, query: Query, projection: Source-Multi-Hop-Ref-Chain-Projection, inputs: []Query-Input] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        [anchor-value anchor-value-ok anchor-value-error] (db-read-source-multi-hop-ref-chain-anchor-value source projection inputs)]
    (when (not anchor-value-ok)
      (return (result-set-error anchor-value-error)))
      (let [anchor-entities (set.empty u64) :defer
          anchor-entity-list (make [dynamic]u64) :defer
          first-entities (set.empty u64) :defer
