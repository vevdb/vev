(defn db-read-source-query-fixed-entity-attr-value-projection [query: Query] -> [projection: Source-Fixed-Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-fixed-entity-attr-value-projection) false))
  (let [clause-value query.clauses[0]
        [entity entity-ok] (query-entity-term-literal clause-value.e)]
    (when (or (not entity-ok)
              (not (= clause-value.a.kind .Var))
              (not (= clause-value.v.kind .Var))
              (= clause-value.a.name clause-value.v.name)
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-fixed-entity-attr-value-projection) false))
    (when (not (or (and (= query.find[0] clause-value.a.name)
                        (= query.find[1] clause-value.v.name))
                   (and (= query.find[0] clause-value.v.name)
                        (= query.find[1] clause-value.a.name))))
      (return (empty-source-fixed-entity-attr-value-projection) false))
    (return (Source-Fixed-Entity-Attr-Value-Projection {entity: entity
                                                        attr-var: clause-value.a.name
                                                        value-var: clause-value.v.name})
            true)))

(defn db-read-source-query-fixed-entity-two-attr-projection [query: Query] -> [projection: Source-Fixed-Entity-Two-Attr-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-source-fixed-entity-two-attr-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]
        [first-entity first-entity-ok] (query-entity-term-literal first.e)
        [second-entity second-entity-ok] (query-entity-term-literal second.e)]
    (when (or (not first-entity-ok)
              (not second-entity-ok)
              (not (= first-entity second-entity))
              (not (= first.has-source second.has-source))
              (and first.has-source (not (= first.source second.source)))
              (not (= first.a.kind .Value))
              (not (= second.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (not (= second.a.value.kind .Keyword))
              (not (= first.v.kind .Var))
              (not (= second.v.kind .Var))
              (= first.v.name second.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard)))
      (return (empty-source-fixed-entity-two-attr-projection) false))
    (when (not (or (and (= query.find[0] first.v.name)
                        (= query.find[1] second.v.name))
                   (and (= query.find[0] second.v.name)
                        (= query.find[1] first.v.name))))
      (return (empty-source-fixed-entity-two-attr-projection) false))
    (return (Source-Fixed-Entity-Two-Attr-Projection {entity: first-entity
                                                      first-attr: first.a.value.text
                                                      first-var: first.v.name
                                                      second-attr: second.a.value.text
                                                      second-var: second.v.name})
            true)))

(defn query-find-three-vars? [query: Query, first-var: string, second-var: string, third-var: string] -> bool
  (when (not (= (count query.find) 3))
    (return false))
  (let [has-first false
        has-second false
        has-third false]
  (for [find-var query.find]
    (when (not (or (= find-var first-var)
                   (= find-var second-var)
                   (= find-var third-var)))
      (return false))
    (when (= find-var first-var)
      (set! has-first true))
    (when (= find-var second-var)
      (set! has-second true))
    (when (= find-var third-var)
      (set! has-third true)))
  (and has-first has-second has-third)))

(defn db-read-source-query-three-attr-entity-projection [query: Query] -> [projection: Source-Three-Attr-Entity-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 3)
                  (= (count query.where-steps) 3)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)
                  (= query.where-steps[2].kind .Clause)))
    (return (empty-source-three-attr-entity-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]
        third query.clauses[2]]
    (when (or (not (= first.has-source second.has-source))
              (not (= first.has-source third.has-source))
              (and first.has-source
                   (or (not (= first.source second.source))
                       (not (= first.source third.source))))
              (not (= first.e.kind .Var))
              (not (= second.e.kind .Var))
              (not (= third.e.kind .Var))
              (not (= first.e.name second.e.name))
              (not (= first.e.name third.e.name))
              (not (= first.a.kind .Value))
              (not (= second.a.kind .Value))
              (not (= third.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (not (= second.a.value.kind .Keyword))
              (not (= third.a.value.kind .Keyword))
              (reverse-attr? first.a.value.text)
              (reverse-attr? second.a.value.text)
              (reverse-attr? third.a.value.text)
              (not (= first.v.kind .Var))
              (not (= second.v.kind .Var))
              (not (= third.v.kind .Var))
              (= first.v.name second.v.name)
              (= first.v.name third.v.name)
              (= second.v.name third.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= third.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard))
              (not (= third.op-term.kind .Wildcard))
              (not (query-find-three-vars? query first.v.name second.v.name third.v.name)))
      (return (empty-source-three-attr-entity-projection) false))
    (return (Source-Three-Attr-Entity-Projection {entity-var: first.e.name
                                                  first-attr: first.a.value.text
                                                  first-var: first.v.name
                                                  second-attr: second.a.value.text
                                                  second-var: second.v.name
                                                  third-attr: third.a.value.text
                                                  third-var: third.v.name})
            true)))

(defn query-find-vars-match-clause-value-vars? [query: Query] -> bool
  (when (not (= (count query.find) (count query.clauses)))
    (return false))
  (for [find-var query.find]
    (let [found false]
      (for [clause-value query.clauses]
        (when (and (= clause-value.v.kind .Var)
                   (= clause-value.v.name find-var))
          (set! found true)))
      (when (not found)
        (return false))))
  (for [clause-value query.clauses]
    (let [found false]
      (for [find-var query.find]
        (when (and (= clause-value.v.kind .Var)
                   (= clause-value.v.name find-var))
          (set! found true)))
      (when (not found)
        (return false))))
  true)

(defn query-clause-value-var-unique-before? [query: Query, index: int] -> bool
  (let [name query.clauses[index].v.name
        i 0]
    (while (< i index)
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name name))
        (return false))
      (set! i (+ i 1)))
    true))

(defn db-read-source-query-star-attr-entity-projection? [query: Query] -> bool
  (when (not (and (>= (count query.find) 4)
                  (= (count query.find) (count query.clauses))
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) (count query.where-steps))))
    (return false))
  (let [first query.clauses[0]
        i 0]
    (when (not (and (= first.e.kind .Var)
                    (= first.a.kind .Value)
                    (= first.a.value.kind .Keyword)
                    (not (reverse-attr? first.a.value.text))
                    (= first.v.kind .Var)
                    (= first.tx-term.kind .Wildcard)
                    (= first.op-term.kind .Wildcard)))
      (return false))
    (while (< i (count query.clauses))
      (let [clause-value query.clauses[i]]
        (when (or (not (= query.where-steps[i].kind .Clause))
                  (not (= query.where-steps[i].index i))
                  (not (= clause-value.has-source first.has-source))
                  (and first.has-source
                       (not (= clause-value.source first.source)))
                  (not (= clause-value.e.kind .Var))
                  (not (= clause-value.e.name first.e.name))
                  (not (= clause-value.a.kind .Value))
                  (not (= clause-value.a.value.kind .Keyword))
                  (reverse-attr? clause-value.a.value.text)
                  (not (= clause-value.v.kind .Var))
                  (not (query-clause-value-var-unique-before? query i))
                  (not (= clause-value.tx-term.kind .Wildcard))
                  (not (= clause-value.op-term.kind .Wildcard)))
          (return false)))
      (set! i (+ i 1)))
    (query-find-vars-match-clause-value-vars? query)))

(defn db-read-source-query-fixed-entity-ref-attr-projection [query: Query] -> [projection: Source-Fixed-Entity-Ref-Attr-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-source-fixed-entity-ref-attr-projection) false))
  (let [first query.clauses[0]
        second query.clauses[1]
        [entity entity-ok] (query-entity-term-literal first.e)]
    (when (or (not entity-ok)
              (not (= first.has-source second.has-source))
              (and first.has-source (not (= first.source second.source)))
              (not (= first.a.kind .Value))
              (not (= first.a.value.kind .Keyword))
              (reverse-attr? first.a.value.text)
              (not (= first.v.kind .Var))
              (not (= second.e.kind .Var))
              (not (= second.e.name first.v.name))
              (not (= second.a.kind .Value))
              (not (= second.a.value.kind .Keyword))
              (reverse-attr? second.a.value.text)
              (not (= second.v.kind .Var))
              (not (= second.v.name query.find[0]))
              (= first.v.name second.v.name)
              (not (= first.tx-term.kind .Wildcard))
              (not (= second.tx-term.kind .Wildcard))
              (not (= first.op-term.kind .Wildcard))
              (not (= second.op-term.kind .Wildcard)))
      (return (empty-source-fixed-entity-ref-attr-projection) false))
    (return (Source-Fixed-Entity-Ref-Attr-Projection {entity: entity
                                                      ref-attr: first.a.value.text
                                                      ref-var: first.v.name
                                                      value-attr: second.a.value.text
                                                      value-var: second.v.name})
            true)))

(defn db-read-source-query-value-ref-attr-projection [query: Query] -> [projection: Source-Value-Ref-Attr-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 3)
                  (= (count query.where-steps) 3)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)
                  (= query.where-steps[2].kind .Clause)))
    (return (empty-source-value-ref-attr-projection) false))
  (let [anchor query.clauses[0]
        ref query.clauses[1]
        value-clause query.clauses[2]]
    (when (or (not (= anchor.has-source ref.has-source))
              (not (= anchor.has-source value-clause.has-source))
              (and anchor.has-source
                   (or (not (= anchor.source ref.source))
                       (not (= anchor.source value-clause.source))))
              (not (= anchor.e.kind .Var))
              (not (= anchor.a.kind .Value))
              (not (= anchor.a.value.kind .Keyword))
              (reverse-attr? anchor.a.value.text)
              (not (or (= anchor.v.kind .Value)
                       (and (= anchor.v.kind .Var)
                            (db-read-source-query-has-one-scalar-input? query anchor.v.name))))
              (not (= ref.e.kind .Var))
              (not (= ref.a.kind .Value))
              (not (= ref.a.value.kind .Keyword))
              (reverse-attr? ref.a.value.text)
              (not (= ref.v.kind .Var))
              (not (= ref.v.name anchor.e.name))
              (not (= value-clause.e.kind .Var))
              (not (= value-clause.e.name ref.e.name))
              (not (= value-clause.a.kind .Value))
              (not (= value-clause.a.value.kind .Keyword))
              (reverse-attr? value-clause.a.value.text)
              (not (= value-clause.v.kind .Var))
              (not (= value-clause.v.name query.find[0]))
              (= anchor.e.name ref.e.name)
              (= anchor.e.name value-clause.v.name)
              (= ref.e.name value-clause.v.name)
              (not (= anchor.tx-term.kind .Wildcard))
              (not (= ref.tx-term.kind .Wildcard))
              (not (= value-clause.tx-term.kind .Wildcard))
              (not (= anchor.op-term.kind .Wildcard))
              (not (= ref.op-term.kind .Wildcard))
              (not (= value-clause.op-term.kind .Wildcard)))
      (return (empty-source-value-ref-attr-projection) false))
    (return (Source-Value-Ref-Attr-Projection {anchor-var: anchor.e.name
                                               anchor-attr: anchor.a.value.text
                                               anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                               anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                               has-anchor-input: (= anchor.v.kind .Var)
                                               ref-entity-var: ref.e.name
                                               ref-attr: ref.a.value.text
                                               value-attr: value-clause.a.value.text
                                               value-var: value-clause.v.name})
            true)))

(defn query-value-ref-star-find-var-known? [query: Query, ref-entity-var: string, find-var: string] -> bool
  (let [i 2]
    (when (= find-var ref-entity-var)
      (return true))
    (while (< i (count query.clauses))
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name find-var))
        (return true))
      (set! i (+ i 1)))
    false))

(defn query-value-ref-star-clause-value-var-unique-before? [query: Query, index: int] -> bool
  (let [name query.clauses[index].v.name
        i 2]
    (while (< i index)
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name name))
        (return false))
      (set! i (+ i 1)))
    true))

(defn db-read-source-query-value-ref-star-projection [query: Query] -> [projection: Source-Value-Ref-Star-Projection, ok: bool]
  (when (not (and (>= (count query.find) 2)
                  (>= (count query.clauses) 4)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.where-steps) (count query.clauses))
                  (query-find-vars-unique? query)))
    (return (empty-source-value-ref-star-projection) false))
  (for [step query.where-steps]
    (when (not (= step.kind .Clause))
      (return (empty-source-value-ref-star-projection) false)))
  (let [anchor query.clauses[0]
        ref query.clauses[1]
        i 2]
    (when (or (not (= anchor.e.kind .Var))
              (not (= anchor.a.kind .Value))
              (not (= anchor.a.value.kind .Keyword))
              (reverse-attr? anchor.a.value.text)
              (not (or (= anchor.v.kind .Value)
                       (and (= anchor.v.kind .Var)
                            (db-read-source-query-has-one-scalar-input? query anchor.v.name))))
              (not (= ref.e.kind .Var))
              (not (= ref.a.kind .Value))
              (not (= ref.a.value.kind .Keyword))
              (reverse-attr? ref.a.value.text)
              (not (= ref.v.kind .Var))
              (not (= ref.v.name anchor.e.name))
              (= anchor.e.name ref.e.name)
              (not (= anchor.tx-term.kind .Wildcard))
              (not (= anchor.op-term.kind .Wildcard))
              (not (= ref.tx-term.kind .Wildcard))
              (not (= ref.op-term.kind .Wildcard)))
      (return (empty-source-value-ref-star-projection) false))
    (while (< i (count query.clauses))
      (let [clause-value query.clauses[i]]
        (when (or (not (= anchor.has-source clause-value.has-source))
                  (and anchor.has-source
                       (not (= anchor.source clause-value.source)))
                  (not (= clause-value.e.kind .Var))
                  (not (= clause-value.e.name ref.e.name))
                  (not (= clause-value.a.kind .Value))
                  (not (= clause-value.a.value.kind .Keyword))
                  (reverse-attr? clause-value.a.value.text)
                  (not (= clause-value.v.kind .Var))
                  (not (query-value-ref-star-clause-value-var-unique-before? query i))
                  (not (= clause-value.tx-term.kind .Wildcard))
                  (not (= clause-value.op-term.kind .Wildcard)))
          (return (empty-source-value-ref-star-projection) false)))
      (set! i (+ i 1)))
    (when (or (not (= anchor.has-source ref.has-source))
              (and anchor.has-source
                   (not (= anchor.source ref.source))))
      (return (empty-source-value-ref-star-projection) false))
    (for [find-var query.find]
      (when (not (query-value-ref-star-find-var-known? query ref.e.name find-var))
        (return (empty-source-value-ref-star-projection) false)))
    (return (Source-Value-Ref-Star-Projection {anchor-var: anchor.e.name
                                               anchor-attr: anchor.a.value.text
                                               anchor-value: anchor.v.value
                                               anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                               has-anchor-input: (= anchor.v.kind .Var)
                                               ref-entity-var: ref.e.name
                                               ref-attr: ref.a.value.text})
            true)))

(defn source-clause-fixed-forward-attr? [clause-value: Clause] -> bool
  (and (= clause-value.a.kind .Value)
       (= clause-value.a.value.kind .Keyword)
       (not (reverse-attr? clause-value.a.value.text))
       (= clause-value.tx-term.kind .Wildcard)
       (= clause-value.op-term.kind .Wildcard)))

(defn source-clause-same-source? [base: Clause, candidate: Clause] -> bool
  (and (= base.has-source candidate.has-source)
       (or (not base.has-source)
           (= base.source candidate.source))))

(defn source-query-find-has-var? [query: Query, name: string] -> bool
  (for [find-var query.find]
    (when (= find-var name)
      (return true)))
  false)

(defn source-clause-entity-var? [clause-value: Clause, name: string] -> bool
  (and (= clause-value.e.kind .Var)
       (= clause-value.e.name name)))

(defn source-multi-hop-anchor-clause? [query: Query, clause-value: Clause] -> bool
  (and (source-clause-fixed-forward-attr? clause-value)
       (= clause-value.e.kind .Var)
       (or (= clause-value.v.kind .Value)
           (and (= clause-value.v.kind .Var)
                (db-read-source-query-has-one-scalar-input? query clause-value.v.name)))))

(defn source-multi-hop-clauses-compatible? [query: Query, anchor: Clause] -> bool
  (for [clause-value query.clauses]
    (when (or (not (source-clause-same-source? anchor clause-value))
              (not (source-clause-fixed-forward-attr? clause-value)))
      (return false)))
  true)

(defn db-read-source-query-multi-hop-ref-chain-projection-any-order [query: Query] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 7)
                  (= (count query.where-steps) 8)
                  (query-find-vars-unique? query)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (and (= step.kind .Predicate)
                        (= step.index 0))))
      (return (empty-source-multi-hop-ref-chain-projection) false)))
  (let [anchor-index 0]
    (while (< anchor-index (count query.clauses))
      (let [anchor query.clauses[anchor-index]]
        (when (and (source-multi-hop-anchor-clause? query anchor)
                   (source-multi-hop-clauses-compatible? query anchor))
          (let [reverse-index 0]
            (while (< reverse-index (count query.clauses))
              (let [reverse-ref query.clauses[reverse-index]]
                (when (and (not (= reverse-index anchor-index))
                           (= reverse-ref.e.kind .Var)
                           (= reverse-ref.v.kind .Var)
                           (= reverse-ref.v.name anchor.e.name)
                           (not (= reverse-ref.e.name anchor.e.name)))
                  (let [filter-index 0]
                    (while (< filter-index (count query.clauses))
                      (let [filter-clause query.clauses[filter-index]]
                        (when (and (not (= filter-index anchor-index))
                                   (not (= filter-index reverse-index))
                                   (source-clause-entity-var? filter-clause reverse-ref.e.name)
                                   (= filter-clause.v.kind .Var))
                          (let [[filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
                            (when filter-ok
                              (let [hop1-index 0]
                            (while (< hop1-index (count query.clauses))
                              (let [hop1 query.clauses[hop1-index]]
                                (when (and (not (= hop1-index anchor-index))
                                           (not (= hop1-index reverse-index))
                                           (not (= hop1-index filter-index))
                                           (source-clause-entity-var? hop1 reverse-ref.e.name)
                                           (= hop1.v.kind .Var)
                                           (not (= hop1.v.name filter-clause.v.name)))
                                  (let [hop2-index 0]
                                    (while (< hop2-index (count query.clauses))
                                      (let [hop2 query.clauses[hop2-index]]
                                        (when (and (not (= hop2-index anchor-index))
                                                   (not (= hop2-index reverse-index))
                                                   (not (= hop2-index filter-index))
                                                   (not (= hop2-index hop1-index))
                                                   (source-clause-entity-var? hop2 hop1.v.name)
                                                   (= hop2.v.kind .Var)
                                                   (not (= hop2.v.name hop1.v.name)))
                                          (let [first-value-index 0]
                                            (while (< first-value-index (count query.clauses))
                                              (let [first-value query.clauses[first-value-index]]
                                                (when (and (not (= first-value-index anchor-index))
                                                           (not (= first-value-index reverse-index))
                                                           (not (= first-value-index filter-index))
                                                           (not (= first-value-index hop1-index))
                                                           (not (= first-value-index hop2-index))
                                                           (source-clause-entity-var? first-value reverse-ref.e.name)
                                                           (= first-value.v.kind .Var)
                                                           (not (= first-value.v.name filter-clause.v.name))
                                                           (not (= first-value.v.name hop1.v.name))
                                                           (not (= first-value.v.name hop2.v.name))
                                                           (source-query-find-has-var? query first-value.v.name))
                                                  (let [final-value-index 0]
                                                    (while (< final-value-index (count query.clauses))
                                                      (let [final-value query.clauses[final-value-index]]
                                                        (when (and (not (= final-value-index anchor-index))
                                                                   (not (= final-value-index reverse-index))
                                                                   (not (= final-value-index filter-index))
                                                                   (not (= final-value-index hop1-index))
                                                                   (not (= final-value-index hop2-index))
                                                                   (not (= final-value-index first-value-index))
                                                                   (source-clause-entity-var? final-value hop2.v.name)
                                                                   (= final-value.v.kind .Var)
                                                                   (not (= final-value.v.name filter-clause.v.name))
                                                                   (not (= final-value.v.name first-value.v.name))
                                                                   (source-query-find-has-var? query final-value.v.name)
                                                                   (query-find-three-vars? query first-value.v.name filter-clause.v.name final-value.v.name))
                                                          (return (Source-Multi-Hop-Ref-Chain-Projection {anchor-var: anchor.e.name
                                                                                                          anchor-attr: anchor.a.value.text
                                                                                                          anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                                                                          anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                                                                          has-anchor-input: (= anchor.v.kind .Var)
                                                                                                          first-entity-var: reverse-ref.e.name
                                                                                                          reverse-ref-attr: reverse-ref.a.value.text
                                                                                                          filter-attr: filter-clause.a.value.text
                                                                                                          filter-var: filter-clause.v.name
                                                                                                          filter-op: filter-op
                                                                                                          filter-value: filter-value
                                                                                                          first-value-attr: first-value.a.value.text
                                                                                                          first-value-var: first-value.v.name
                                                                                                          hop1-attr: hop1.a.value.text
                                                                                                          hop1-var: hop1.v.name
                                                                                                          hop2-attr: hop2.a.value.text
                                                                                                          hop2-var: hop2.v.name
                                                                                                          final-value-attr: final-value.a.value.text
                                                                                                          final-value-var: final-value.v.name})
                                                                  true)))
                                                        (set! final-value-index (+ final-value-index 1))))))
                                                (set! first-value-index (+ first-value-index 1))))))
                                        (set! hop2-index (+ hop2-index 1))))))
                                (set! hop1-index (+ hop1-index 1)))))))
                        (set! filter-index (+ filter-index 1))))))
                (set! reverse-index (+ reverse-index 1))))))
        (set! anchor-index (+ anchor-index 1))))
    (return (empty-source-multi-hop-ref-chain-projection) false)))

(defn db-read-source-query-multi-hop-ref-chain-projection [query: Query] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 7)
                  (= (count query.where-steps) 8)
                  (query-find-vars-unique? query)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (and (= step.kind .Predicate)
                        (= step.index 0))))
      (return (empty-source-multi-hop-ref-chain-projection) false)))
  (let [anchor query.clauses[0]
        reverse-ref query.clauses[1]
        filter-clause query.clauses[2]
        first-value query.clauses[3]
        hop1 query.clauses[4]
        hop2 query.clauses[5]
        final-value query.clauses[6]
        [filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
    (when (not filter-ok)
      (return (empty-source-multi-hop-ref-chain-projection) false))
    (for [clause-value query.clauses]
      (when (or (not (= anchor.has-source clause-value.has-source))
                (and anchor.has-source
                     (not (= anchor.source clause-value.source)))
                (not (source-clause-fixed-forward-attr? clause-value)))
        (return (empty-source-multi-hop-ref-chain-projection) false)))
    (when (or (not (= anchor.e.kind .Var))
              (not (or (= anchor.v.kind .Value)
                       (and (= anchor.v.kind .Var)
                            (db-read-source-query-has-one-scalar-input? query anchor.v.name))))
              (not (= reverse-ref.e.kind .Var))
              (not (= reverse-ref.v.kind .Var))
              (not (= reverse-ref.v.name anchor.e.name))
              (= reverse-ref.e.name anchor.e.name)
              (not (= filter-clause.e.kind .Var))
              (not (= filter-clause.e.name reverse-ref.e.name))
              (not (= filter-clause.v.kind .Var))
              (not (= first-value.e.kind .Var))
              (not (= first-value.e.name reverse-ref.e.name))
              (not (= first-value.v.kind .Var))
              (not (= hop1.e.kind .Var))
              (not (= hop1.e.name reverse-ref.e.name))
              (not (= hop1.v.kind .Var))
              (not (= hop2.e.kind .Var))
              (not (= hop2.e.name hop1.v.name))
              (not (= hop2.v.kind .Var))
              (not (= final-value.e.kind .Var))
              (not (= final-value.e.name hop2.v.name))
              (not (= final-value.v.kind .Var))
              (= filter-clause.v.name first-value.v.name)
              (= filter-clause.v.name final-value.v.name)
              (= first-value.v.name final-value.v.name)
              (= hop1.v.name hop2.v.name))
      (return (empty-source-multi-hop-ref-chain-projection) false))
    (for [find-var query.find]
      (when (not (or (= find-var filter-clause.v.name)
                     (= find-var first-value.v.name)
                     (= find-var final-value.v.name)))
        (return (empty-source-multi-hop-ref-chain-projection) false)))
    (return (Source-Multi-Hop-Ref-Chain-Projection {anchor-var: anchor.e.name
                                                    anchor-attr: anchor.a.value.text
                                                    anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                    anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                    has-anchor-input: (= anchor.v.kind .Var)
                                                    first-entity-var: reverse-ref.e.name
                                                    reverse-ref-attr: reverse-ref.a.value.text
                                                    filter-attr: filter-clause.a.value.text
                                                    filter-var: filter-clause.v.name
                                                    filter-op: filter-op
                                                    filter-value: filter-value
                                                    first-value-attr: first-value.a.value.text
                                                    first-value-var: first-value.v.name
                                                    hop1-attr: hop1.a.value.text
                                                    hop1-var: hop1.v.name
                                                    hop2-attr: hop2.a.value.text
                                                    hop2-var: hop2.v.name
                                                    final-value-attr: final-value.a.value.text
                                                    final-value-var: final-value.v.name})
            true)))

(defn source-final-filter-ref-chain-projection-from-candidates [query: Query, anchor: Clause, reverse-ref: Clause, first-value: Clause, hop1: Clause, hop2: Clause, filter-clause: Clause, final-value: Clause] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (let [[filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] filter-clause.v.name)]
    (when (not filter-ok)
      (return (empty-source-multi-hop-ref-chain-projection) false))
    (when (or (not (source-multi-hop-anchor-clause? query anchor))
              (not (source-clause-same-source? anchor reverse-ref))
              (not (source-clause-same-source? anchor first-value))
              (not (source-clause-same-source? anchor hop1))
              (not (source-clause-same-source? anchor hop2))
              (not (source-clause-same-source? anchor filter-clause))
              (not (source-clause-same-source? anchor final-value))
              (not (source-clause-fixed-forward-attr? reverse-ref))
              (not (source-clause-fixed-forward-attr? first-value))
              (not (source-clause-fixed-forward-attr? hop1))
              (not (source-clause-fixed-forward-attr? hop2))
              (not (source-clause-fixed-forward-attr? filter-clause))
              (not (source-clause-fixed-forward-attr? final-value))
              (not (= reverse-ref.e.kind .Var))
              (not (= reverse-ref.v.kind .Var))
              (not (= reverse-ref.v.name anchor.e.name))
              (= reverse-ref.e.name anchor.e.name)
              (not (source-clause-entity-var? first-value reverse-ref.e.name))
              (not (= first-value.v.kind .Var))
              (not (source-query-find-has-var? query first-value.v.name))
              (not (= hop1.e.kind .Var))
              (not (= hop1.v.kind .Var))
              (not (= hop1.v.name reverse-ref.e.name))
              (not (= hop2.e.kind .Var))
              (not (= hop2.v.kind .Var))
              (not (= hop2.v.name hop1.e.name))
              (not (source-clause-entity-var? filter-clause hop2.e.name))
              (not (= filter-clause.v.kind .Var))
              (not (source-query-find-has-var? query filter-clause.v.name))
              (not (source-clause-entity-var? final-value hop2.e.name))
              (not (= final-value.v.kind .Var))
              (not (source-query-find-has-var? query final-value.v.name))
              (= first-value.v.name filter-clause.v.name)
              (= first-value.v.name final-value.v.name)
              (= filter-clause.v.name final-value.v.name)
              (not (query-find-three-vars? query first-value.v.name final-value.v.name filter-clause.v.name)))
      (return (empty-source-multi-hop-ref-chain-projection) false))
    (return (Source-Multi-Hop-Ref-Chain-Projection {anchor-var: anchor.e.name
                                                    anchor-attr: anchor.a.value.text
                                                    anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                    anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                    has-anchor-input: (= anchor.v.kind .Var)
                                                    first-entity-var: reverse-ref.e.name
                                                    reverse-ref-attr: reverse-ref.a.value.text
                                                    filter-attr: filter-clause.a.value.text
                                                    filter-var: filter-clause.v.name
                                                    filter-op: filter-op
                                                    filter-value: filter-value
                                                    first-value-attr: first-value.a.value.text
                                                    first-value-var: first-value.v.name
                                                    hop1-attr: hop1.a.value.text
                                                    hop1-var: hop1.e.name
                                                    hop2-attr: hop2.a.value.text
                                                    hop2-var: hop2.e.name
                                                    final-value-attr: final-value.a.value.text
                                                    final-value-var: final-value.v.name})
            true)))

(defn source-two-final-value-ref-chain-projection-from-candidates [query: Query, anchor: Clause, reverse-ref: Clause, first-value: Clause, hop1: Clause, hop2: Clause, final-value: Clause, second-final-value: Clause] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (when (or (not (source-multi-hop-anchor-clause? query anchor))
            (not (source-clause-same-source? anchor reverse-ref))
            (not (source-clause-same-source? anchor first-value))
            (not (source-clause-same-source? anchor hop1))
            (not (source-clause-same-source? anchor hop2))
            (not (source-clause-same-source? anchor final-value))
            (not (source-clause-same-source? anchor second-final-value))
            (not (source-clause-fixed-forward-attr? reverse-ref))
            (not (source-clause-fixed-forward-attr? first-value))
            (not (source-clause-fixed-forward-attr? hop1))
            (not (source-clause-fixed-forward-attr? hop2))
            (not (source-clause-fixed-forward-attr? final-value))
            (not (source-clause-fixed-forward-attr? second-final-value))
            (not (= reverse-ref.e.kind .Var))
            (not (= reverse-ref.v.kind .Var))
            (not (= reverse-ref.v.name anchor.e.name))
            (= reverse-ref.e.name anchor.e.name)
            (not (source-clause-entity-var? first-value reverse-ref.e.name))
            (not (= first-value.v.kind .Var))
            (not (source-query-find-has-var? query first-value.v.name))
            (not (= hop1.e.kind .Var))
            (not (= hop1.v.kind .Var))
            (not (= hop1.v.name reverse-ref.e.name))
            (not (= hop2.e.kind .Var))
            (not (= hop2.v.kind .Var))
            (not (= hop2.v.name hop1.e.name))
            (not (source-clause-entity-var? final-value hop2.e.name))
            (not (= final-value.v.kind .Var))
            (not (source-query-find-has-var? query final-value.v.name))
            (not (source-clause-entity-var? second-final-value hop2.e.name))
            (not (= second-final-value.v.kind .Var))
            (not (source-query-find-has-var? query second-final-value.v.name))
            (= first-value.v.name final-value.v.name)
            (= first-value.v.name second-final-value.v.name)
            (= final-value.v.name second-final-value.v.name)
            (not (query-find-three-vars? query first-value.v.name final-value.v.name second-final-value.v.name)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (return (Source-Multi-Hop-Ref-Chain-Projection {anchor-var: anchor.e.name
                                                  anchor-attr: anchor.a.value.text
                                                  anchor-value: (if (= anchor.v.kind .Value) anchor.v.value (value-nil))
                                                  anchor-input-name: (if (= anchor.v.kind .Var) anchor.v.name "")
                                                  has-anchor-input: (= anchor.v.kind .Var)
                                                  first-entity-var: reverse-ref.e.name
                                                  reverse-ref-attr: reverse-ref.a.value.text
                                                  filter-attr: second-final-value.a.value.text
                                                  filter-var: second-final-value.v.name
                                                  filter-op: ""
                                                  filter-value: (value-nil)
                                                  first-value-attr: first-value.a.value.text
                                                  first-value-var: first-value.v.name
                                                  hop1-attr: hop1.a.value.text
                                                  hop1-var: hop1.e.name
                                                  hop2-attr: hop2.a.value.text
                                                  hop2-var: hop2.e.name
                                                  final-value-attr: final-value.a.value.text
                                                  final-value-var: final-value.v.name})
          true))

(defn db-read-source-query-multi-hop-ref-chain-two-final-values-projection-ordered [query: Query] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 7)
                  (= (count query.where-steps) 7)
                  (query-find-vars-unique? query)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (when (not (and (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].kind .Clause)
                  (= query.where-steps[1].index 1)
                  (= query.where-steps[2].kind .Clause)
                  (= query.where-steps[2].index 2)
                  (= query.where-steps[3].kind .Clause)
                  (= query.where-steps[3].index 3)
                  (= query.where-steps[4].kind .Clause)
                  (= query.where-steps[4].index 4)
                  (= query.where-steps[5].kind .Clause)
                  (= query.where-steps[5].index 5)
                  (= query.where-steps[6].kind .Clause)
                  (= query.where-steps[6].index 6)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (source-two-final-value-ref-chain-projection-from-candidates
    query
    query.clauses[0]
    query.clauses[1]
    query.clauses[2]
    query.clauses[3]
    query.clauses[4]
    query.clauses[5]
    query.clauses[6]))

(defn db-read-source-query-multi-hop-ref-chain-final-filter-projection-ordered [query: Query] -> [projection: Source-Multi-Hop-Ref-Chain-Projection, ok: bool]
  (when (not (and (= (count query.find) 3)
