          (return (result-set-error hop2-error))))
      (let [[final-stream final-ok final-error] (source-index-datom-stream source projection.final-value-attr)]
        (when (not final-ok)
          (delete-result-rows-owned-values rows)
          (return (result-set-error final-error)))
        (while final-stream.has-current
          (let [[head found] (mmap.get hop2-heads final-stream.current.e)]
            (when found
              (let [index head]
                (while (>= index 0)
                  (append-db-read-source-multi-hop-ref-chain-row! (addr rows) query projection final-stream.current.v hop2-links[index].first-value hop2-links[index].filter-value)
                  (set! index hop2-links[index].next)))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr final-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream final-stream)
              (delete-result-rows-owned-values rows)
              (return (result-set-error advance-error)))))
        (delete-source-index-datom-stream final-stream))
      (result-set-ok rows))))

