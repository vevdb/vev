(package vev)

(import core-strings "core:strings")
(import rand "core:math/rand")
(import mmap "kvist:map")
(import set "kvist:set")

(defn string-owned [text: string] -> string
  (let [[out err] (core-strings.clone text)]
    (if (= err nil)
      out
      "")))

(defn current-instant [] -> Value
  (value-instant (/ (time.to-unix-nanoseconds (time.now)) 1000000)))

(defn instant-text [unix-millis: i64] -> string
  (let [[datetime ok] (time.time-to-datetime (time.unix 0 (* unix-millis 1000000)))]
    (when (not ok)
      (return ""))
    (fmt.tprintf "%04d-%02d-%02dT%02d:%02d:%02d.%03dZ"
                 datetime.year
                 datetime.month
                 datetime.day
                 datetime.hour
                 datetime.minute
                 datetime.second
                 (/ datetime.nano 1000000))))

(defn instant-from-text [text: string] -> [value: Value, ok: bool]
  (let [normalized text]
    (when (= (count text) 10)
      (set! normalized (fmt.tprintf "%sT00:00:00Z" text)))
    (let [[parsed consumed] (time.iso8601-to-time-utc normalized)]
      (return (value-instant (/ (time.to-unix-nanoseconds parsed) 1000000))
              (= consumed (count normalized))))))

(defn string-clojure-count [text: string] -> int
  (let [out 0
        index 0
        size (count text)]
    (while (< index size)
      (let [raw (int text[index])
            byte (if (< raw 0) (+ raw 256) raw)]
        (cond
          (< byte 0x80)
          (do
            (set! out (+ out 1))
            (set! index (+ index 1)))

          (< byte 0xC0)
          (set! index (+ index 1))

          (< byte 0xE0)
          (do
            (set! out (+ out 1))
            (set! index (+ index 2)))

          (< byte 0xF0)
          (do
            (set! out (+ out 1))
            (set! index (+ index 3)))

          :else
          (do
            (set! out (+ out 2))
            (set! index (+ index 4))))))
    out))

(defn value-owned [value: Value] -> Value
  (case value.kind
    .String (value-string (string-owned value.text))
    .Keyword (value-keyword (string-owned value.text))
    .Symbol (value-symbol (string-owned value.text))
    .Uuid (value-uuid (string-owned value.text))
    .Vector
      (let [items (make [dynamic]Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (value-vector-owned items))
    .Map
      (let [items (make [dynamic]Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (value-map-owned items))
    .Set
      (let [items (make [dynamic]Value 0 (count value.items))]
        (for [item value.items]
          (arr.push! items (value-owned item)))
        (value-set-owned items))
     value))

(defn datom-owned [datom: Datom] -> Datom
  (Datom {e: datom.e
          a: (string-owned datom.a)
          v: (value-owned datom.v)
          tx: datom.tx
          added: datom.added}))

(defn delete-owned-datom [datom: Datom]
  (delete datom.a)
  (delete-owned-value datom.v))

(defn delete-owned-datoms [datoms: [dynamic]Datom]
  (for [datom datoms]
    (delete-owned-datom datom))
  (delete datoms))

(defn delete-resolved-tx [resolved: Resolved-Tx]
  (for [op resolved.ops]
    (when op.owned-attr
      (delete op.a))
    (when op.owned-value
      (delete-owned-value op.v)))
  (delete resolved.ops)
  (delete resolved.tx-meta)
  (delete resolved.tempids))

(defn delete-resolved-tx-after-tempids-moved [resolved: Resolved-Tx]
  (for [op resolved.ops]
    (when op.owned-attr
      (delete op.a))
    (when op.owned-value
      (delete-owned-value op.v)))
  (delete resolved.ops)
  (delete resolved.tx-meta))

(defn delete-owned-value [value: Value]
  (case value.kind
    .String (delete value.text)
    .Keyword (delete value.text)
    .Symbol (delete value.text)
    .Uuid (delete value.text)
    .Vector
      (do
        (for [item value.items]
          (delete-owned-value item))
        (delete value.items))
    .Map
      (do
        (for [item value.items]
          (delete-owned-value item))
        (delete value.items))
    .Set
      (do
        (for [item value.items]
          (delete-owned-value item))
        (delete value.items))
     (do)))

(defn delete-owned-pull-spec [spec: Pull-Spec]
  (delete spec.a)
  (when spec.has-default
    (delete-owned-value spec.default-value))
  (when spec.has-alias
    (delete spec.alias))
  (when spec.has-xform
    (delete spec.xform))
  (for [child spec.pattern]
    (delete-owned-pull-spec child))
  (delete spec.pattern))

(defn delete-owned-query-input [input: Query-Input]
  (case input.kind
    .Scalar
      (do
        (delete-owned-value input.value)
        (when input.has-lookup-ref
          (delete input.lookup-attr)
          (delete-owned-value input.lookup-value)))
    .Collection
      (do
        (for [value input.values]
          (delete-owned-value value))
        (delete input.values))
    .Relation
      (do
        (for [value input.values]
          (delete-owned-value value))
        (delete input.values))
    .CollectionLookupRefs
      (do
        (for [attr input.lookup-attrs]
          (delete attr))
        (for [value input.lookup-values]
          (delete-owned-value value))
        (delete input.lookup-attrs)
        (delete input.lookup-values))
    .PullPattern
      (do
        (for [spec input.pattern]
          (delete-owned-pull-spec spec))
        (delete input.pattern))
    (do)))

(defn delete-owned-query-inputs [inputs: [dynamic]Query-Input]
  (for [input inputs]
    (delete-owned-query-input input))
  (delete inputs))

(defn delete-value-containers-shallow [value: Value]
  (case value.kind
    .Vector
      (do
        (for [item value.items]
          (delete-value-containers-shallow item))
        (delete value.items))
    .Map
      (do
        (for [item value.items]
          (delete-value-containers-shallow item))
        (delete value.items))
     (do)))

(defn tx-data-owned [data: Tx-Data] -> Tx-Data
  (Tx-Data {op: (string-owned data.op)
            e: data.e
            tempid: (string-owned data.tempid)
            has-tempid: data.has-tempid
            lookup-attr: (string-owned data.lookup-attr)
            lookup-value: (value-owned data.lookup-value)
            has-lookup-ref: data.has-lookup-ref
            ident: (string-owned data.ident)
            has-ident: data.has-ident
            a: (string-owned data.a)
            v: (value-owned data.v)
            expected: (value-owned data.expected)
            expected-lookup-attr: (string-owned data.expected-lookup-attr)
            expected-lookup-value: (value-owned data.expected-lookup-value)
            has-expected-lookup-ref: data.has-expected-lookup-ref
            value-tempid: (string-owned data.value-tempid)
            has-value-tempid: data.has-value-tempid
            value-lookup-attr: (string-owned data.value-lookup-attr)
            value-lookup-value: (value-owned data.value-lookup-value)
            has-value-lookup-ref: data.has-value-lookup-ref
            nested-map: (value-owned data.nested-map)
            nested-tempid: (string-owned data.nested-tempid)
            has-nested-map: data.has-nested-map
            from-map-collection: data.from-map-collection
            map-group: (string-owned data.map-group)}))

(defn tx-data-slice-owned [tx-data: []Tx-Data] -> [dynamic]Tx-Data
  (let [out (make [dynamic]Tx-Data 0 (count tx-data))]
    (for [data tx-data]
      (arr.push! out (tx-data-owned data)))
    out))

(defn delete-owned-tx-data-item [data: Tx-Data]
  (delete data.op)
  (delete data.tempid)
  (delete data.lookup-attr)
  (delete-owned-value data.lookup-value)
  (delete data.ident)
  (delete data.a)
  (delete-owned-value data.v)
  (delete-owned-value data.expected)
  (delete data.expected-lookup-attr)
  (delete-owned-value data.expected-lookup-value)
  (delete data.value-tempid)
  (delete data.value-lookup-attr)
  (delete-owned-value data.value-lookup-value)
  (delete-owned-value data.nested-map)
  (delete data.nested-tempid)
  (delete data.map-group))

(defn delete-owned-tx-data [tx-data: [dynamic]Tx-Data]
  (for [data tx-data]
    (delete-owned-tx-data-item data))
  (delete tx-data))

(defn get-some-owned [clause: Get-Some] -> Get-Some
  (let [out (Get-Some {source: clause.source
                       has-source: clause.has-source
                       e: clause.e
                       attrs: (make [dynamic]string 0 (count clause.attrs))
                       out-attr: clause.out-attr
                       out-value: clause.out-value})]
    (for [attr clause.attrs]
      (arr.push! out.attrs attr))
    out))

(defn get-some-slice-owned [clauses: []Get-Some] -> [dynamic]Get-Some
  (let [out (make [dynamic]Get-Some 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (get-some-owned clause)))
    out))

(defn delete-get-some [clause: Get-Some]
  (delete clause.attrs))

(defn delete-get-somes [clauses: [dynamic]Get-Some]
  (for [clause clauses]
    (delete-get-some clause))
  (delete clauses))


(defn query-with-rules [query: Query, rules: []Rule] -> Query
  (let [out query]
    (delete out.rules)
    (delete-rule-call-plans out.rule-call-plans)
    (let [owned-rules (arr.into [dynamic]Rule rules)]
      (set! out.rules owned-rules))
    (set! out.rule-call-plans (make [dynamic]Rule-Call-Plan))
    (return out)))

(defn clone-query-shallow [query: Query] -> Query
  (let [find (arr.into [dynamic]string (slice query.find 0))
        with (arr.into [dynamic]string (slice query.with 0))
        inputs (arr.into [dynamic]string (slice query.inputs 0))
        collection-inputs (arr.into [dynamic]string (slice query.collection-inputs 0))
        tuple-inputs (arr.into [dynamic]Tuple-Input (slice query.tuple-inputs 0))
        relation-inputs (arr.into [dynamic]Relation-Input (slice query.relation-inputs 0))
        input-specs (arr.into [dynamic]Query-Input-Spec (slice query.input-specs 0))
        clauses (arr.into [dynamic]Clause (slice query.clauses 0))
        predicates (arr.into [dynamic]Predicate (slice query.predicates 0))
        function-clauses (arr.into [dynamic]Function-Clause (slice query.function-clauses 0))
        rules (arr.into [dynamic]Rule (slice query.rules 0))
        rule-calls (arr.into [dynamic]Rule-Call (slice query.rule-calls 0))
        rule-call-plans (clone-rule-call-plans (slice query.rule-call-plans 0))
        get-elses (arr.into [dynamic]Get-Else (slice query.get-elses 0))
        get-somes (get-some-slice-owned (slice query.get-somes 0))
        grounds (arr.into [dynamic]Ground (slice query.grounds 0))
        not-groups (arr.into [dynamic]Not-Group (slice query.not-groups 0))
        or-groups (arr.into [dynamic]Or-Group (slice query.or-groups 0))
        where-steps (arr.into [dynamic]Query-Step (slice query.where-steps 0))
        pulls (arr.into [dynamic]Pull-Find (slice query.pulls 0))
        aggregates (arr.into [dynamic]Aggregate-Find (slice query.aggregates 0))
        return-map-keys (arr.into [dynamic]string (slice query.return-map-keys 0))]
    (Query {find: find
            with: with
            inputs: inputs
            collection-inputs: collection-inputs
            tuple-inputs: tuple-inputs
            relation-inputs: relation-inputs
            input-specs: input-specs
            has-default-source-input: query.has-default-source-input
            has-rules-input: query.has-rules-input
            clauses: clauses
            predicates: predicates
            function-clauses: function-clauses
            rules: rules
            rule-calls: rule-calls
            rule-call-plans: rule-call-plans
            get-elses: get-elses
            get-somes: get-somes
            grounds: grounds
            not-groups: not-groups
            or-groups: or-groups
            where-steps: where-steps
            pulls: pulls
            aggregates: aggregates
            has-return-map: query.has-return-map
            return-map-marker: query.return-map-marker
            return-map-keys: return-map-keys})))

(defn query-copy-with-rules [query: Query, rules: []Rule] -> Query
  (query-with-rules (clone-query-shallow query) rules))

(defn delete-query-shallow [query: Query]
  (delete query.find)
  (delete query.with)
  (delete query.inputs)
  (delete query.collection-inputs)
  (delete query.tuple-inputs)
  (delete query.relation-inputs)
  (delete query.input-specs)
  (delete query.clauses)
  (delete query.predicates)
  (delete query.function-clauses)
  (delete query.rules)
  (delete query.rule-calls)
  (delete-rule-call-plans query.rule-call-plans)
  (delete query.get-elses)
  (delete-get-somes query.get-somes)
  (delete query.grounds)
  (delete query.not-groups)
  (delete query.or-groups)
  (delete query.where-steps)
  (delete query.pulls)
  (delete query.aggregates)
  (delete query.return-map-keys))

(defn delete-not-group-containers [group: Not-Group]
  (for [nested group.not-groups]
    (delete-not-group-containers nested))
  (delete group.clauses)
  (delete group.predicates)
  (delete group.function-clauses)
  (delete group.get-elses)
  (delete-get-somes group.get-somes)
  (delete group.grounds)
  (delete group.rule-calls)
  (delete group.not-groups)
  (delete group.steps)
  (delete group.join-vars))

(defn delete-or-group-containers [group: Or-Group]
  (for [branch group.branches]
    (delete-not-group-containers branch))
  (delete group.branches)
  (delete group.join-vars))

(defn delete-prepared-query-shallow [prepared: Prepared-Query]
  (for [predicate prepared.query.predicates]
    (delete predicate.terms))
  (for [function prepared.query.function-clauses]
    (delete function.terms)
    (delete function.out-vars)
    (delete-input-binding-shallow function.out-binding))
  (for [group prepared.query.not-groups]
    (delete-not-group-containers group))
  (for [group prepared.query.or-groups]
    (delete-or-group-containers group))
  (for [aggregate prepared.query.aggregates]
    (delete aggregate.args))
  (delete-query-shallow prepared.query)
  (when prepared.owns-source
    (data.release prepared.source-owner))
  (when prepared.owns-rules-source
    (data.release prepared.rules-source-owner)))

(defn delete-input-binding-shallow [binding: Input-Binding]
  (for [item binding.items]
    (delete-input-binding-shallow item))
  (delete binding.items))

(defn delete-prepared-binding-shallow [prepared: Prepared-Binding]
  (delete-input-binding-shallow prepared.binding)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-prepared-in-shallow [prepared: Prepared-In]
  (for [binding prepared.bindings]
    (delete-input-binding-shallow binding))
  (delete prepared.bindings)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-prepared-with-shallow [prepared: Prepared-With]
  (delete prepared.vars)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-prepared-clause-shallow [prepared: Prepared-Clause]
  (delete prepared.clauses)
  (delete prepared.predicates)
  (delete prepared.function-clauses)
  (delete prepared.rule-calls)
  (delete prepared.get-elses)
  (delete-get-somes prepared.get-somes)
  (delete prepared.grounds)
  (delete prepared.not-groups)
  (delete prepared.or-groups)
  (delete prepared.where-steps)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-prepared-rules-shallow [prepared: Prepared-Rules]
  (delete prepared.rules)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-pull-spec-containers-shallow [specs: []Pull-Spec]
  (for [spec specs]
    (delete-pull-spec-containers-shallow (slice spec.pattern 0))
    (delete spec.pattern)))

(defn delete-prepared-pull-pattern-shallow [prepared: Prepared-Pull-Pattern]
  (delete-pull-spec-containers-shallow (slice prepared.pattern 0))
  (delete prepared.pattern)
  (when prepared.owns-source
    (data.release prepared.source-owner)))

(defn delete-prepared-tx-data-shallow [prepared: Prepared-Tx-Data]
  (delete-owned-tx-data prepared.tx-data))

(defn delete-tx-report-shallow [report: Tx-Report]
  (when report.ok
    (delete-owned-db report.db-before)
    (delete-owned-db report.db-after))
  (delete report.error)
  (delete report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids)
  (delete-tx-publish-plan report.publish-plan))

(defn delete-live-tx-report-shallow [report: Tx-Report]
  (when report.ok
    (delete-owned-db report.db-before))
  (delete report.error)
  (delete report.tx-data)
  (delete report.tx-meta)
  (delete report.tempids)
  (delete-tx-publish-plan report.publish-plan))

(defn clone-datoms [datoms: [dynamic]Datom] -> [dynamic]Datom
  (arr.into [dynamic]Datom (slice datoms 0)))

(defn db [conn: ^Conn] -> DB
  (clone-db conn^.db))

(defn clone-tx-meta [meta: []Tx-Meta] -> [dynamic]Tx-Meta
  (arr.into [dynamic]Tx-Meta meta))

(defn clone-tx-report [report: Tx-Report] -> Tx-Report
  (let [tx-data (arr.into [dynamic]Datom (slice report.tx-data 0))
        tx-meta (clone-tx-meta (slice report.tx-meta 0))
        tempids (arr.into [dynamic]Tempid (slice report.tempids 0))]
    (Tx-Report {ok: report.ok
                error: (string-owned report.error)
                db-before: (clone-db report.db-before)
                db-after: (clone-db report.db-after)
                tx-data: tx-data
                tx: report.tx
                tx-meta: tx-meta
                tempids: tempids
                datom-start-index: report.datom-start-index
                append-only: report.append-only
                new-entities-after-existing: report.new-entities-after-existing
                publish-plan: (clone-tx-publish-plan report.publish-plan)})))

(defn listen! [conn: ^Conn, name: string, reports: ^[dynamic]Tx-Report] -> bool
  (for [listener index conn^.listeners]
    (when (= listener.name name)
      (set! conn^.listeners[index] (Tx-Listener {name: name reports: reports}))
      (return true)))
  (arr.push! conn^.listeners (Tx-Listener {name: name reports: reports}))
  true)

(defn unlisten! [conn: ^Conn, name: string] -> bool
  (for [listener index conn^.listeners]
    (when (= listener.name name)
      (arr.remove-ordered-at! conn^.listeners index)
      (return true)))
  false)

(defn notify-listeners! [conn: ^Conn, report: Tx-Report]
  (for [listener conn^.listeners]
    (arr.push! listener.reports^ (clone-tx-report report))))

(defn clone-binding [binding: Binding] -> Binding
  (let [items (arr.into [dynamic]Var-Binding (slice binding.items 0))]
    (Binding {items: items})))

(defn clone-bindings [bindings: []Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (arr.push! out (clone-binding binding)))
    out))

(defn binding-lookup [binding: Binding, name: string] -> [value: Value, ok: bool]
  (for [item binding.items]
    (when (= item.name name)
      (return item.value true)))
  (return (Value {}) false))

(defn binding-store! [binding: ^Binding, name: string, value: Value]
  (arr.push! binding^.items (Var-Binding {name: name value: value})))

(defn append-var-binding-attr! [attrs: ^[dynamic]string, attr-sources: ^[dynamic]string, name: string, source: string]
  (when (= name "")
    (return))
  (when (not (string-slice-contains? (slice attrs^ 0) name))
    (arr.push! attrs^ name)
    (arr.push! attr-sources^ source)))

(defn append-clause-term-var-attr! [attrs: ^[dynamic]string, attr-sources: ^[dynamic]string, term: Term, source: string]
  (when (= term.kind .Var)
    (append-var-binding-attr! attrs attr-sources term.name source)))

(defn clause-output-attrs [clause-value: Clause, source: string] -> [attrs: [dynamic]string, attr-sources: [dynamic]string]
  (let [out-attrs (make [dynamic]string)
        out-sources (make [dynamic]string)]
    (append-clause-term-var-attr! (addr out-attrs) (addr out-sources) clause-value.e source)
    (append-clause-term-var-attr! (addr out-attrs) (addr out-sources) clause-value.a source)
    (append-clause-term-var-attr! (addr out-attrs) (addr out-sources) clause-value.v source)
    (append-clause-term-var-attr! (addr out-attrs) (addr out-sources) clause-value.tx-term source)
    (append-clause-term-var-attr! (addr out-attrs) (addr out-sources) clause-value.op-term source)
    (return out-attrs out-sources)))

(defn query-relation-attr-index [attrs: []string] -> map[string]int
  (let [index (make (map string int))]
    (for [attr attr-index attrs]
      (mmap.assoc! index attr attr-index))
    index))

(defn query-relation-attr-index-lookup [rel: Query-Relation, name: string] -> [index: int, ok: bool]
  (mmap.get rel.attr-index name))

(defn query-relation-has-attr? [rel: Query-Relation, name: string] -> bool
  (let [[_ found] (query-relation-attr-index-lookup rel name)]
    found))

(defn query-relation-row-count [rel: Query-Relation] -> int
  (if rel.has-typed-columns
    rel.typed-rows
    (count rel.tuples)))

(defn query-relation-empty [] -> Query-Relation
  (Query-Relation {attrs: (make [dynamic]string)
                   attr-sources: (make [dynamic]string)
                   attr-index: (make (map string int))
                   tuples: (make [dynamic]Binding)
                   typed-columns: (make [dynamic]Relation-Column)}))

(defn query-relation-singleton [] -> Query-Relation
  (Query-Relation {attrs: (make [dynamic]string)
                   attr-sources: (make [dynamic]string)
                   attr-index: (make (map string int))
                   tuples: (make [dynamic]Binding)
                   typed-columns: (make [dynamic]Relation-Column)
                   typed-rows: 1
                   has-typed-columns: true}))

(defn query-relation-from-bindings [bindings: []Binding] -> Query-Relation
  (query-relation-from-bindings-with-source bindings ""))

(defn typed-columns-from-relation-bindings [attrs: []string, tuples: []Binding] -> [columns: [dynamic]Relation-Column, rows: int, ok: bool]
  (let [out-columns (relation-columns-for-attrs attrs)
        out-rows 0]
    (for [tuple tuples]
      (if (binding-can-add-to-relation-columns? attrs (slice out-columns 0) tuple)
        (do
          (add-binding-to-relation-columns! attrs (addr out-columns) tuple)
          (set! out-rows (+ out-rows 1)))
        (do
          (delete-relation-columns out-columns)
          (return (make [dynamic]Relation-Column) 0 false))))
    (return out-columns out-rows true)))

(defstruct Query-Relation-Builder {
  tuples: [dynamic]Binding
  typed-columns: [dynamic]Relation-Column
  typed-rows: int
  typed-ok: bool
})

(defn query-relation-builder [attrs: []string] -> Query-Relation-Builder
  (Query-Relation-Builder {tuples: (make [dynamic]Binding)
                           typed-columns: (relation-columns-for-attrs attrs)
                           typed-rows: 0
                           typed-ok: true}))

(defn query-relation-builder-with-capacity [attrs: []string, row-capacity: int] -> Query-Relation-Builder
  (Query-Relation-Builder {tuples: (make [dynamic]Binding 0 row-capacity)
                           typed-columns: (relation-columns-for-attrs-with-capacity attrs row-capacity)
                           typed-rows: 0
                           typed-ok: true}))

(defn delete-query-relation-builder [builder: Query-Relation-Builder]
  (delete builder.tuples)
  (delete-relation-columns builder.typed-columns))

(defn query-relation-builder-add-binding! [builder: ^Query-Relation-Builder, attrs: []string, binding: Binding, keep-tuple: bool] -> bool
  (when builder^.typed-ok
    (if (binding-can-add-to-relation-columns? attrs (slice builder^.typed-columns 0) binding)
      (do
        (add-binding-to-relation-columns! attrs (addr builder^.typed-columns) binding)
        (set! builder^.typed-rows (+ builder^.typed-rows 1)))
      (return false)))
  (if keep-tuple
    (arr.push! builder^.tuples binding)
    (delete binding.items))
  true)

(defn query-relation-builder-add-column-row! [builder: ^Query-Relation-Builder, columns: []Relation-Column, row: int] -> bool
  (when (not (add-relation-column-row! (addr builder^.typed-columns) columns row))
    (return false))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-builder-can-add-column-row-with-values? [builder: Query-Relation-Builder, columns: []Relation-Column, row: int, values: []Value] -> bool
  (for [column index columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  (for [value index values]
    (let [column-index (+ (count columns) index)]
      (when (not (relation-column-can-add? builder.typed-columns[column-index] value))
        (return false))))
  true)

;; Values passed here are borrowed. relation-column-add! clones text and
;; compound values into the builder's owned columns.
(defn query-relation-builder-add-column-row-with-values! [builder: ^Query-Relation-Builder, columns: []Relation-Column, row: int, values: []Value] -> bool
  (when (not (query-relation-builder-can-add-column-row-with-values? builder^ columns row values))
    (return false))
  (for [column index columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (for [value index values]
    (discard (relation-column-add! (addr builder^.typed-columns[(+ (count columns) index)]) value)))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-builder-add-two-borrowed-values! [builder: ^Query-Relation-Builder, first-value: Value, second-value: Value] -> bool
  (when (< (count builder^.typed-columns) 2)
    (return false))
  (when (not (relation-column-can-add? builder^.typed-columns[0] first-value))
    (return false))
  (when (not (relation-column-can-add? builder^.typed-columns[1] second-value))
    (return false))
  (discard (relation-column-add! (addr builder^.typed-columns[0]) first-value))
  (discard (relation-column-add! (addr builder^.typed-columns[1]) second-value))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn attr-position [attrs: []string, name: string] -> [index: int, ok: bool]
  (for [attr index attrs]
    (when (= attr name)
      (return index true)))
  (return 0 false))

(defn query-relation-builder-can-add-column-row-with-output-value? [builder: Query-Relation-Builder, attrs: []string, columns: []Relation-Column, row: int, output-name: string, output-value: Value] -> bool
  (for [column index columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  (let [[output-index output-index-ok] (attr-position attrs output-name)]
    (when (not output-index-ok)
      (return false))
    (when (< output-index (count columns))
      (let [[existing existing-ok] (typed-relation-column-value columns[output-index] row)]
        (return (and existing-ok (predicate-value-equal? existing output-value)))))
    (relation-column-can-add? builder.typed-columns[output-index] output-value)))

(defn query-relation-builder-add-column-row-with-output-value! [builder: ^Query-Relation-Builder, attrs: []string, columns: []Relation-Column, row: int, output-name: string, output-value: Value] -> bool
  (when (not (query-relation-builder-can-add-column-row-with-output-value? builder^ attrs columns row output-name output-value))
    (return false))
  (for [column index columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (when (>= (count attrs) (count columns))
    (let [[output-index _] (attr-position attrs output-name)]
      (when (>= output-index (count columns))
        (discard (relation-column-add! (addr builder^.typed-columns[output-index]) output-value)))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-builder-can-add-column-row-with-two-output-values? [builder: Query-Relation-Builder, attrs: []string, columns: []Relation-Column, row: int, first-name: string, first-value: Value, second-name: string, second-value: Value] -> bool
  (for [column index columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  (let [[first-index first-index-ok] (attr-position attrs first-name)
        [second-index second-index-ok] (attr-position attrs second-name)]
    (when (not (and first-index-ok second-index-ok))
      (return false))
    (when (and (>= first-index (count columns))
               (not (relation-column-can-add? builder.typed-columns[first-index] first-value)))
      (return false))
    (when (and (>= second-index (count columns))
               (not (relation-column-can-add? builder.typed-columns[second-index] second-value)))
      (return false))
    true))

(defn query-relation-builder-add-column-row-with-two-output-values! [builder: ^Query-Relation-Builder, attrs: []string, columns: []Relation-Column, row: int, first-name: string, first-value: Value, second-name: string, second-value: Value] -> bool
  (when (not (query-relation-builder-can-add-column-row-with-two-output-values? builder^ attrs columns row first-name first-value second-name second-value))
    (return false))
  (for [column index columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (let [[first-index _] (attr-position attrs first-name)
        [second-index _] (attr-position attrs second-name)]
    (when (>= first-index (count columns))
      (discard (relation-column-add! (addr builder^.typed-columns[first-index]) first-value)))
    (when (>= second-index (count columns))
      (discard (relation-column-add! (addr builder^.typed-columns[second-index]) second-value))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-builder-add-relation-row-by-attrs! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int] -> bool
  (when (not rel.has-typed-columns)
    (return false))
  (for [name index attrs]
    (let [[value value-ok] (query-relation-typed-row-value rel row name)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder^.typed-columns[index] value)))
        (return false))))
  (for [name index attrs]
    (let [[value _] (query-relation-typed-row-value rel row name)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-from-bindings-with-source [bindings: []Binding, source: string] -> Query-Relation
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        tuples (make [dynamic]Binding 0 (count bindings))]
    (for [binding bindings]
      (for [item binding.items]
        (when (not (string-slice-contains? (slice attrs 0) item.name))
          (arr.push! attrs item.name)
          (arr.push! attr-sources source)))
      (arr.push! tuples (clone-binding binding)))
    (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: tuples
                     typed-columns: typed-columns
                     typed-rows: typed-rows
                     has-typed-columns: typed-ok}))))

(defn query-relation-from-bindings-inheriting-sources [bindings: []Binding, parent: Query-Relation] -> Query-Relation
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        tuples (make [dynamic]Binding 0 (count bindings))]
    (for [binding bindings]
      (for [item binding.items]
        (when (not (string-slice-contains? (slice attrs 0) item.name))
          (let [[source source-ok] (relation-attr-source parent item.name)]
            (arr.push! attrs item.name)
            (if source-ok
              (arr.push! attr-sources source)
              (arr.push! attr-sources "")))))
      (arr.push! tuples (clone-binding binding)))
    (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: tuples
                     typed-columns: typed-columns
                     typed-rows: typed-rows
                     has-typed-columns: typed-ok}))))

(defn delete-query-relation [rel: Query-Relation]
  (delete rel.attrs)
  (delete rel.attr-sources)
  (delete rel.attr-index)
  (delete-relation-columns rel.typed-columns)
  (delete rel.tuples))

(defn relation-column-empty [] -> Relation-Column
  (Relation-Column {entities: (make [dynamic]u64)
                    texts: (make [dynamic]string)
                    ints: (make [dynamic]i64)
                    floats: (make [dynamic]f64)
                    bools: (make [dynamic]bool)
                    values: (make [dynamic]Value)}))

(defn relation-column-empty-with-capacity [row-capacity: int] -> Relation-Column
  (Relation-Column {entities: (make [dynamic]u64 0 row-capacity)
                    texts: (make [dynamic]string 0 row-capacity)
                    ints: (make [dynamic]i64 0 row-capacity)
                    floats: (make [dynamic]f64 0 row-capacity)
                    bools: (make [dynamic]bool 0 row-capacity)
                    values: (make [dynamic]Value 0 row-capacity)}))

(defn delete-relation-column [column: Relation-Column]
  (if (= column.kind .Mixed)
    (for [value column.values]
      (delete-owned-value value))
    (for [text column.texts]
      (delete text)))
  (delete column.entities)
  (delete column.texts)
  (delete column.ints)
  (delete column.floats)
  (delete column.bools)
  (delete column.values))

(defn delete-relation-columns [columns: [dynamic]Relation-Column]
  (for [column columns]
    (delete-relation-column column))
  (delete columns))

(defn clone-relation-column [column: Relation-Column] -> Relation-Column
  (let [entities (arr.into [dynamic]u64 (slice column.entities 0))
        texts (make [dynamic]string 0 (count column.texts))
        ints (arr.into [dynamic]i64 (slice column.ints 0))
        floats (arr.into [dynamic]f64 (slice column.floats 0))
        bools (arr.into [dynamic]bool (slice column.bools 0))
        values (make [dynamic]Value 0 (count column.values))]
    (for [text column.texts]
      (arr.push! texts (string-owned text)))
    (if (= column.kind .Mixed)
      (for [value column.values]
        (arr.push! values (value-owned value)))
      (for [value column.values]
        (arr.push! values value)))
    (Relation-Column {kind: column.kind
                      has-kind: column.has-kind
                      entities: entities
                      texts: texts
                      ints: ints
                      floats: floats
                      bools: bools
                      values: values})))

(defn clone-relation-columns [columns: []Relation-Column] -> [dynamic]Relation-Column
  (let [out (make [dynamic]Relation-Column 0 (count columns))]
    (for [column columns]
      (arr.push! out (clone-relation-column column)))
    out))

(defn typed-relation-empty [] -> Typed-Relation
  (Typed-Relation {attrs: (make [dynamic]string)
                   attr-sources: (make [dynamic]string)
                   attr-index: (make (map string int))
                   columns: (make [dynamic]Relation-Column)}))

(defn delete-typed-relation [rel: Typed-Relation]
  (delete rel.attrs)
  (delete rel.attr-sources)
  (delete rel.attr-index)
  (for [column rel.columns]
    (delete-relation-column column))
  (delete rel.columns))

(defn value-relation-column-kind [value: Value] -> [kind: Relation-Column-Kind, ok: bool]
  (case value.kind
    .Nil (return .Nil true)
    .Entity (return .Entity true)
    .String (return .String true)
    .Int (return .Int true)
    .Float (return .Float true)
    .Bool (return .Bool true)
    .Keyword (return .Keyword true)
    .Symbol (return .Symbol true)
    .Uuid (return .Uuid true)
    .Instant (return .Instant true)
     (return .Nil false)))

(defn relation-column-row-count [column: Relation-Column] -> int
  (when (not column.has-kind)
    (return 0))
  (case column.kind
    .Nil 0
    .Entity (count column.entities)
    .String (count column.texts)
    .Int (count column.ints)
    .Float (count column.floats)
    .Bool (count column.bools)
    .Keyword (count column.texts)
    .Symbol (count column.texts)
    .Uuid (count column.texts)
    .Mixed (count column.values)
    .Instant (count column.ints)
     0))

(defn relation-column-append-existing-values! [out: ^[dynamic]Value, column: Relation-Column]
  (case column.kind
    .Nil
      (discard column)
    .Entity
      (for [item column.entities]
        (arr.push! out^ (value-entity item)))
    .String
      (for [item column.texts]
        (arr.push! out^ (value-string item)))
    .Int
      (for [item column.ints]
        (arr.push! out^ (value-int item)))
    .Float
      (for [item column.floats]
        (arr.push! out^ (value-float item)))
    .Bool
      (for [item column.bools]
        (arr.push! out^ (value-bool item)))
    .Keyword
      (for [item column.texts]
        (arr.push! out^ (value-keyword item)))
    .Symbol
      (for [item column.texts]
        (arr.push! out^ (value-symbol item)))
    .Uuid
      (for [item column.texts]
        (arr.push! out^ (value-uuid item)))
    .Instant
      (for [item column.ints]
        (arr.push! out^ (value-instant item)))
    .Mixed
      (for [item column.values]
        (arr.push! out^ item))
    (discard column)))

(defn relation-column-convert-to-mixed! [column: ^Relation-Column]
  (let [row-count (relation-column-row-count column^)
        values (make [dynamic]Value 0 row-count)]
    (for [row (arr.range row-count)]
      (let [[value value-ok] (typed-relation-column-value column^ row)]
        (when value-ok
          (arr.push! values (value-owned value)))))
    (for [text column^.texts]
      (delete text))
    (delete column^.entities)
    (delete column^.texts)
    (delete column^.ints)
    (delete column^.floats)
    (delete column^.bools)
    (delete column^.values)
    (set! column^.entities (make [dynamic]u64))
    (set! column^.texts (make [dynamic]string))
    (set! column^.ints (make [dynamic]i64))
    (set! column^.floats (make [dynamic]f64))
    (set! column^.bools (make [dynamic]bool))
    (set! column^.values values)
    (set! column^.kind .Mixed)
    (set! column^.has-kind true)))

(defn relation-column-mixed-cell-value [value: Value] -> Value
  (value-owned value))

(defn relation-column-add! [column: ^Relation-Column, value: Value] -> bool
  (let [[kind kind-ok] (value-relation-column-kind value)]
    (when (not kind-ok)
      (when (not column^.has-kind)
        (set! column^.kind .Mixed)
        (set! column^.has-kind true))
      (when (not (= column^.kind .Mixed))
        (relation-column-convert-to-mixed! column))
      (arr.push! column^.values (relation-column-mixed-cell-value value))
      (return true))
    (if column^.has-kind
      (when (not (= column^.kind kind))
        (when (not (= column^.kind .Mixed))
          (relation-column-convert-to-mixed! column))
        (arr.push! column^.values (relation-column-mixed-cell-value value))
        (return true))
      (do
        (set! column^.kind kind)
        (set! column^.has-kind true)))
    (case kind
      .Nil (discard kind)
      .Entity (arr.push! column^.entities value.entity)
      .String (arr.push! column^.texts (string-owned value.text))
      .Int (arr.push! column^.ints value.int-value)
      .Float (arr.push! column^.floats value.float-value)
      .Bool (arr.push! column^.bools value.bool-value)
      .Keyword (arr.push! column^.texts (string-owned value.text))
      .Symbol (arr.push! column^.texts (string-owned value.text))
      .Uuid (arr.push! column^.texts (string-owned value.text))
      .Instant (arr.push! column^.ints value.int-value)
      .Mixed (arr.push! column^.values value)
      (do))
    true))

(defn relation-column-can-add? [column: Relation-Column, value: Value] -> bool
  (let [[kind kind-ok] (value-relation-column-kind value)]
    (when (not kind-ok)
      (return true))
    (when (not column.has-kind)
      (return true))
    (when (= column.kind kind)
      (return true))
    true))

(defn relation-columns-for-attrs [attrs: []string] -> [dynamic]Relation-Column
  (let [columns (make [dynamic]Relation-Column 0 (count attrs))]
    (for [_ attrs]
      (arr.push! columns (relation-column-empty)))
    columns))

(defn relation-columns-for-attrs-with-capacity [attrs: []string, row-capacity: int] -> [dynamic]Relation-Column
  (let [columns (make [dynamic]Relation-Column 0 (count attrs))]
    (for [_ attrs]
      (arr.push! columns (relation-column-empty-with-capacity row-capacity)))
    columns))

(defn binding-can-add-to-relation-columns? [attrs: []string, columns: []Relation-Column, binding: Binding] -> bool
  (for [attr index attrs]
    (let [[value value-ok] (binding-lookup binding attr)]
      (when (or (not value-ok)
                (not (relation-column-can-add? columns[index] value)))
        (return false))))
  true)

(defn add-binding-to-relation-columns! [attrs: []string, columns: ^[dynamic]Relation-Column, binding: Binding]
  (for [attr index attrs]
    (let [[value _] (binding-lookup binding attr)]
      (discard (relation-column-add! (addr columns^[index]) value)))))

(defn typed-relation-attr-index [rel: Typed-Relation, name: string] -> [index: int, ok: bool]
  (mmap.get rel.attr-index name))

(defn typed-relation-from-query-relation [rel: Query-Relation] -> [typed: Typed-Relation, ok: bool]
  (when rel.has-typed-columns
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          attr-index (query-relation-attr-index (slice rel.attrs 0))
          columns (clone-relation-columns (slice rel.typed-columns 0))]
      (return (Typed-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: attr-index
                               columns: columns
                               rows: rel.typed-rows}) true)))
  (let [out (typed-relation-empty)]
    (set! out.rows (count rel.tuples))
    (for [attr index rel.attrs]
      (arr.push! out.attrs attr)
      (arr.push! out.attr-sources rel.attr-sources[index])
      (mmap.assoc! out.attr-index attr index)
      (let [column (relation-column-empty)]
        (for [tuple rel.tuples]
          (let [[value value-ok] (binding-lookup tuple attr)]
            (when (or (not value-ok)
                      (not (relation-column-add! (addr column) value)))
              (delete-relation-column column)
              (delete-typed-relation out)
              (return (typed-relation-empty) false))))
        (arr.push! out.columns column)))
    (return out true)))

(defn relation-attr-source [rel: Query-Relation, name: string] -> [source: string, ok: bool]
  (let [[index found] (query-relation-attr-index-lookup rel name)]
    (if found
      (return rel.attr-sources[index] true)
      (return "" false))))

(defn relation-common-attrs [left: Query-Relation, right: Query-Relation] -> [dynamic]string
  (let [out (make [dynamic]string)]
    (for [name left.attrs]
      (when (query-relation-has-attr? right name)
        (arr.push! out name)))
    out))

(defn db-for-relation-source [db: DB, sources: []DB-Source, source: string] -> DB
  (when (> (count source) 0)
    (let [[source-db found] (source-db-lookup db sources source)]
      (when found
        (return source-db))))
  db)

(defn relation-entity-values-equal? [db: DB, sources: []DB-Source, left-rel: Query-Relation, right-rel: Query-Relation, name: string, left-value: Value, right-value: Value] -> bool
  (let [[left-source left-source-ok] (relation-attr-source left-rel name)
        [right-source right-source-ok] (relation-attr-source right-rel name)
        left-effective-source (if (and left-source-ok (> (count left-source) 0))
                                left-source
                                (if right-source-ok right-source ""))
        right-effective-source (if (and right-source-ok (> (count right-source) 0))
                                 right-source
                                 (if left-source-ok left-source ""))
        left-db (db-for-relation-source db sources left-effective-source)
        right-db (db-for-relation-source db sources right-effective-source)]
    (when (predicate-value-equal? left-value right-value)
      (return true))
    (let [[left-entity left-ok] (value-as-entity left-db left-value)]
      (when left-ok
        (return (predicate-value-equal? left-entity right-value))))
    (let [[right-entity right-ok] (value-as-entity right-db right-value)]
      (when right-ok
        (return (predicate-value-equal? left-value right-entity))))
    false))

(defn binding-agrees-on-attrs? [db: DB, sources: []DB-Source, left-rel: Query-Relation, right-rel: Query-Relation, left: Binding, right: Binding, attrs: []string] -> bool
  (for [name attrs]
    (let [[left-value left-ok] (binding-lookup left name)
          [right-value right-ok] (binding-lookup right name)]
      (when (not (and left-ok right-ok (relation-entity-values-equal? db sources left-rel right-rel name left-value right-value)))
        (return false))))
  true)

(defn merge-relation-binding [db: DB, sources: []DB-Source, base-rel: Query-Relation, extra-rel: Query-Relation, base: Binding, extra: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding base)]
    (for [item extra.items]
      (let [[existing exists] (binding-lookup out item.name)]
        (if exists
          (when (not (relation-entity-values-equal? db sources base-rel extra-rel item.name existing item.value))
            (return out false))
          (binding-store! (addr out) item.name item.value))))
    (return out true)))

(defn merge-relation-binding-known-common [base-rel: Query-Relation, base: Binding, extra: Binding] -> Binding
  (let [out (clone-binding base)]
    (for [item extra.items]
      (when (not (query-relation-has-attr? base-rel item.name))
        (binding-store! (addr out) item.name item.value)))
    out))

(defn query-relation-product [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation] -> Query-Relation
  (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
        attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
        left-bindings (query-relation-materialized-bindings left)
        right-bindings (query-relation-materialized-bindings right)
        tuples (make [dynamic]Binding 0 (* (count left-bindings) (count right-bindings)))]
    (for [name index right.attrs]
      (arr.push! attrs name)
      (arr.push! attr-sources right.attr-sources[index]))
    (for [left-tuple left-bindings]
      (for [right-tuple right-bindings]
        (let [[merged ok] (merge-relation-binding db sources left right left-tuple right-tuple)]
          (when ok
            (arr.push! tuples merged)))))
    (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
      (delete left-bindings)
      (delete right-bindings)
      (Query-Relation {attrs: attrs
                       attr-sources: attr-sources
                       attr-index: (query-relation-attr-index (slice attrs 0))
                       tuples: tuples
                       typed-columns: typed-columns
                       typed-rows: typed-rows
                       has-typed-columns: typed-ok}))))

(defn primitive-value-join-key [value: Value] -> [key: string, ok: bool]
  (case value.kind
    .Entity (return (fmt.tprintf "n:%d" value.entity) true)
    .Int (return (fmt.tprintf "n:%d" value.int-value) true)
     (primitive-value-dedupe-key value)))

(defn binding-primitive-join-key [binding: Binding, name: string] -> [key: string, ok: bool]
  (let [[value found] (binding-lookup binding name)]
    (when (not found)
      (return "" false))
    (primitive-value-join-key value)))

(defn binding-primitive-join-key-many [binding: Binding, names: []string] -> [key: string, ok: bool]
  (when (= (count names) 1)
    (return (binding-primitive-join-key binding names[0])))
  (let [parts (make [dynamic]string 0 (count names)) :defer]
    (for [name names]
      (let [[value found] (binding-lookup binding name)]
        (when (not found)
          (return "" false))
        (let [[part part-ok] (primitive-value-join-key value)]
          (when (not part-ok)
            (return "" false))
          (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part)))))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn typed-relation-column-row-key [column: Relation-Column, row: int] -> [key: string, ok: bool]
  (when (not column.has-kind)
    (return "" false))
  (case column.kind
    .Nil (return "n:" true)
    .Entity (return (fmt.tprintf "e:%d" column.entities[row]) true)
    .String (return (fmt.tprintf "s:%s" column.texts[row]) true)
    .Int (return (fmt.tprintf "i:%d" column.ints[row]) true)
    .Float (return (fmt.tprintf "f:%v" column.floats[row]) true)
    .Bool (if column.bools[row]
            (return "b:true" true)
            (return "b:false" true))
    .Keyword (return (fmt.tprintf "k:%s" column.texts[row]) true)
    .Symbol (return (fmt.tprintf "y:%s" column.texts[row]) true)
    .Uuid (return (fmt.tprintf "u:%s" column.texts[row]) true)
    .Instant (return (fmt.tprintf "t:%d" column.ints[row]) true)
    .Mixed (primitive-value-dedupe-key column.values[row])
    (return "" false))
  (return "" false))

(defn typed-relation-column-row-join-key [column: Relation-Column, row: int] -> [key: string, ok: bool]
  (when (not column.has-kind)
    (return "" false))
  (case column.kind
    .Entity (return (fmt.tprintf "n:%d" column.entities[row]) true)
    .Int (return (fmt.tprintf "n:%d" column.ints[row]) true)
     (typed-relation-column-row-key column row)))

(defn relation-column-kinds-join-compatible? [left: Relation-Column-Kind, right: Relation-Column-Kind] -> bool
  (or (= left right)
      (= left .Mixed)
      (= right .Mixed)
      (and (or (= left .Entity) (= left .Int))
           (or (= right .Entity) (= right .Int)))))

(defn relation-column-kinds-may-entity-coerce? [left: Relation-Column-Kind, right: Relation-Column-Kind] -> bool
  (and (not (= left right))
       (or (= left .Entity)
           (= right .Entity))))

(defn typed-relations-compatible-common? [left: Typed-Relation, right: Typed-Relation, common: []string] -> bool
  (for [name common]
    (let [[left-index left-ok] (typed-relation-attr-index left name)
          [right-index right-ok] (typed-relation-attr-index right name)]
      (when (not (and left-ok right-ok))
        (return false))
      (when (not (relation-column-kinds-join-compatible? left.columns[left-index].kind right.columns[right-index].kind))
        (return false))))
  true)

(defn typed-relation-row-join-key [rel: Typed-Relation, row: int, common: []string] -> [key: string, ok: bool]
  (when (= (count common) 1)
    (let [[column-index column-ok] (typed-relation-attr-index rel common[0])]
      (when (not column-ok)
        (return "" false))
      (return (typed-relation-column-row-join-key rel.columns[column-index] row))))
  (let [parts (make [dynamic]string 0 (count common)) :defer]
    (for [name common]
      (let [[column-index column-ok] (typed-relation-attr-index rel name)]
        (when (not column-ok)
          (return "" false))
        (let [[part part-ok] (typed-relation-column-row-join-key rel.columns[column-index] row)]
          (when (not part-ok)
            (return "" false))
          (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part)))))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn typed-relation-column-value [column: Relation-Column, row: int] -> [value: Value, ok: bool]
  (when (not column.has-kind)
    (return (Value {}) false))
  (case column.kind
    .Nil (return (value-nil) true)
    .Entity (return (value-entity column.entities[row]) true)
    .String (return (value-string column.texts[row]) true)
    .Int (return (value-int column.ints[row]) true)
    .Float (return (value-float column.floats[row]) true)
    .Bool (return (value-bool column.bools[row]) true)
    .Keyword (return (value-keyword column.texts[row]) true)
    .Symbol (return (value-symbol column.texts[row]) true)
    .Uuid (return (value-uuid column.texts[row]) true)
    .Instant (return (value-instant column.ints[row]) true)
    .Mixed (return column.values[row] true)
    (return (Value {}) false))
  (return (Value {}) false))

(defn binding-from-query-relation-typed-row [rel: Query-Relation, row: int] -> [binding: Binding, ok: bool]
  (let [out (Binding {items: (make [dynamic]Var-Binding 0 (count rel.attrs))})]
    (for [attr index rel.attrs]
      (let [[value value-ok] (typed-relation-column-value rel.typed-columns[index] row)]
        (when (not value-ok)
          (delete out.items)
          (return (Binding {}) false))
        (binding-store! (addr out) attr (value-owned value))))
    (return out true)))

(defn query-relation-materialized-bindings [rel: Query-Relation] -> [dynamic]Binding
  (when (> (count rel.tuples) 0)
    (let [owned (make [dynamic]Binding 0 (count rel.tuples))]
      (for [binding rel.tuples]
        (arr.push! owned (db-read-source-clone-binding-owned binding)))
      (return owned)))
  (let [out (make [dynamic]Binding 0 (query-relation-row-count rel))]
    (when rel.has-typed-columns
      (let [row 0]
        (while (< row rel.typed-rows)
          (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
            (when binding-ok
              (arr.push! out binding)))
          (set! row (+ row 1)))))
    out))

(defn query-relation-typed-layout-compatible? [left: Query-Relation, right: Query-Relation] -> bool
  (when (not (and left.has-typed-columns right.has-typed-columns))
    (return false))
  (when (or (not (= (count left.attrs) (count right.attrs)))
            (not (= (count left.attr-sources) (count right.attr-sources)))
            (not (= (count left.typed-columns) (count right.typed-columns))))
    (return false))
  (for [attr index left.attrs]
    (when (or (not (= attr right.attrs[index]))
              (not (= left.attr-sources[index] right.attr-sources[index])))
      (return false))
    (let [left-column left.typed-columns[index]
          right-column right.typed-columns[index]]
      (when (and left-column.has-kind
                 right-column.has-kind
                 (not (= left-column.kind right-column.kind)))
        (return false))))
  true)

(defn query-relation-empty-typed-like [rel: Query-Relation] -> Query-Relation
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        attr-index (query-relation-attr-index (slice rel.attrs 0))
        tuples (make [dynamic]Binding)
        typed-columns (relation-columns-for-attrs (slice rel.attrs 0))]
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: attr-index
                     tuples: tuples
                     typed-columns: typed-columns
                     typed-rows: 0
                     has-typed-columns: true})))

(defn query-relation-single-typed-row [rel: Query-Relation, row: int] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            (< row 0)
            (>= row rel.typed-rows))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))]
    (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
      (delete attrs)
      (delete attr-sources)
      (delete-query-relation-builder builder)
      (return (query-relation-empty) false))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: builder.typed-ok}) true)))

(defn query-relation-single-typed-row-projected [rel: Query-Relation, row: int, names: []string] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            (< row 0)
            (>= row rel.typed-rows))
    (return (query-relation-empty) false))
  (let [attrs (make [dynamic]string 0 (count names))
        attr-sources (make [dynamic]string 0 (count names))]
    (for [name names]
      (let [[index found] (mmap.get rel.attr-index name)]
        (when found
          (arr.push! attrs name)
          (arr.push! attr-sources rel.attr-sources[index]))))
    (let [builder (query-relation-builder (slice attrs 0))]
      (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) rel row))
        (delete attrs)
        (delete attr-sources)
        (delete-query-relation-builder builder)
        (return (query-relation-empty) false))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-project-typed [rel: Query-Relation, names: []string] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (make [dynamic]string 0 (count names))
        attr-sources (make [dynamic]string 0 (count names))]
    (for [name names]
      (let [[index found] (mmap.get rel.attr-index name)]
        (when (not found)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false))
        (arr.push! attrs name)
        (arr.push! attr-sources rel.attr-sources[index])))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) rel row))
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-append-typed-rows! [out: ^Query-Relation, rel: Query-Relation] -> bool
  (when (not (query-relation-typed-layout-compatible? out^ rel))
    (return false))
  (let [row 0]
    (while (< row rel.typed-rows)
      (when (not (add-relation-column-row! (addr out^.typed-columns) (slice rel.typed-columns 0) row))
        (return false))
      (set! out^.typed-rows (+ out^.typed-rows 1))
      (set! row (+ row 1))))
  true)

(defn query-relation-append-typed-rows-unique! [out: ^Query-Relation, rel: Query-Relation, seen: (ptr (map string (struct {})))] -> bool
  (when (not (query-relation-typed-layout-compatible? out^ rel))
    (return false))
  (let [row 0]
    (while (< row rel.typed-rows)
      (let [[key key-ok] (query-relation-row-join-key rel row (slice rel.attrs 0))]
        (when (not key-ok)
          (return false))
        (when (not (set.contains? seen^ key))
          (set.add! seen^ key)
          (when (not (add-relation-column-row! (addr out^.typed-columns) (slice rel.typed-columns 0) row))
            (return false))
          (set! out^.typed-rows (+ out^.typed-rows 1))))
      (set! row (+ row 1))))
  true)

(defn query-relation-flush-typed-accumulator! [out-bindings: ^[dynamic]Binding, out-rel: ^Query-Relation, has-out-rel: ^bool, out-rel-typed: ^bool]
  (when has-out-rel^
    (let [materialized (query-relation-materialized-bindings out-rel^) :defer]
      (for [binding materialized]
        (arr.push! out-bindings^ binding)))
    (delete-query-relation out-rel^)
    (set! out-rel^ (query-relation-empty))
    (set! has-out-rel^ false)
    (set! out-rel-typed^ false)))

(defn query-relation-accumulate-typed-unique! [out-bindings: ^[dynamic]Binding, out-rel: ^Query-Relation, has-out-rel: ^bool, out-rel-typed: ^bool, seen: (ptr (map string (struct {}))), rel: Query-Relation] -> bool
  (when (not (and out-rel-typed^ rel.has-typed-columns))
    (return false))
  (if has-out-rel^
    (when (query-relation-append-typed-rows-unique! out-rel rel seen)
      (return true))
    (do
      (delete-query-relation out-rel^)
      (set! out-rel^ (query-relation-empty-typed-like rel))
      (set! has-out-rel^ true)
      (when (query-relation-append-typed-rows-unique! out-rel rel seen)
        (return true))))
  (query-relation-flush-typed-accumulator! out-bindings out-rel has-out-rel out-rel-typed)
  false)

(defn query-relation-accumulate-typed! [out-bindings: ^[dynamic]Binding, out-rel: ^Query-Relation, has-out-rel: ^bool, out-rel-typed: ^bool, rel: Query-Relation] -> bool
  (when (not (and out-rel-typed^ rel.has-typed-columns))
    (return false))
  (if has-out-rel^
    (when (query-relation-append-typed-rows! out-rel rel)
      (return true))
    (do
      (delete-query-relation out-rel^)
      (set! out-rel^ (query-relation-empty-typed-like rel))
      (set! has-out-rel^ true)
      (when (query-relation-append-typed-rows! out-rel rel)
        (return true))))
  (query-relation-flush-typed-accumulator! out-bindings out-rel has-out-rel out-rel-typed)
  false)

(defn query-relations-compatible-common? [left: Query-Relation, right: Query-Relation, common: []string] -> bool
  (when (not (and left.has-typed-columns right.has-typed-columns))
    (return false))
  (for [name common]
    (let [[left-index left-ok] (query-relation-attr-index-lookup left name)
          [right-index right-ok] (query-relation-attr-index-lookup right name)]
      (when (not (and left-ok right-ok))
        (return false))
      (when (not (relation-column-kinds-join-compatible? left.typed-columns[left-index].kind right.typed-columns[right-index].kind))
        (return false))))
  true)

(defn query-relation-row-join-key [rel: Query-Relation, row: int, common: []string] -> [key: string, ok: bool]
  (when (not rel.has-typed-columns)
    (return "" false))
  (when (= (count common) 1)
    (let [[column-index column-ok] (query-relation-attr-index-lookup rel common[0])]
      (when (not column-ok)
        (return "" false))
      (return (typed-relation-column-row-join-key rel.typed-columns[column-index] row))))
  (let [parts (make [dynamic]string 0 (count common)) :defer]
    (for [name common]
      (let [[column-index column-ok] (query-relation-attr-index-lookup rel name)]
        (when (not column-ok)
          (return "" false))
        (let [[part part-ok] (typed-relation-column-row-join-key rel.typed-columns[column-index] row)]
          (when (not part-ok)
            (return "" false))
          (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part)))))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn relation-column-row-number-join-key [column: Relation-Column, row: int] -> [key: u64, ok: bool]
  (when (not column.has-kind)
    (return 0 false))
  (case column.kind
    .Entity (return column.entities[row] true)
    .Int (if (< column.ints[row] 0)
           (return 0 false)
           (return (u64 column.ints[row]) true))
    .Mixed
      (let [value column.values[row]]
        (case value.kind
          .Entity (return value.entity true)
          .Int (if (< value.int-value 0)
                 (return 0 false)
                 (return (u64 value.int-value) true))
           (return 0 false)))
     (return 0 false)))

(defstruct Entity-Relation-Row-Ref {
  entity: u64
  row: int
})

(defn entity-relation-row-ref-less? [left: Entity-Relation-Row-Ref, right: Entity-Relation-Row-Ref] -> bool
  (or (< left.entity right.entity)
      (and (= left.entity right.entity)
           (< left.row right.row))))

(defn swap-entity-relation-row-refs! [refs: ^[dynamic]Entity-Relation-Row-Ref, left: int, right: int]
  (let [temp refs^[left]]
    (set! refs^[left] refs^[right])
    (set! refs^[right] temp)))

(defn sift-down-entity-relation-row-refs! [refs: ^[dynamic]Entity-Relation-Row-Ref, start: int, end: int]
  (let [root start]
    (while true
      (let [child (+ (* root 2) 1)]
        (when (> child end)
          (return))
        (let [swap-index root]
          (when (entity-relation-row-ref-less? refs^[swap-index] refs^[child])
            (set! swap-index child))
          (when (and (<= (+ child 1) end)
                     (entity-relation-row-ref-less? refs^[swap-index] refs^[(+ child 1)]))
            (set! swap-index (+ child 1)))
          (when (= swap-index root)
            (return))
          (swap-entity-relation-row-refs! refs root swap-index)
          (set! root swap-index))))))

(defn sort-entity-relation-row-refs! [refs: ^[dynamic]Entity-Relation-Row-Ref]
  (when (< (count refs^) 2)
    (return))
  (let [start (/ (- (count refs^) 2) 2)]
    (while (>= start 0)
      (sift-down-entity-relation-row-refs! refs start (- (count refs^) 1))
      (set! start (- start 1))))
  (let [end (- (count refs^) 1)]
    (while (> end 0)
      (swap-entity-relation-row-refs! refs 0 end)
      (set! end (- end 1))
      (sift-down-entity-relation-row-refs! refs 0 end))))

(defn sorted-entity-row-refs-from-relation-column [column: Relation-Column, rows: int] -> [refs: [dynamic]Entity-Relation-Row-Ref, ok: bool]
  (let [out (make [dynamic]Entity-Relation-Row-Ref 0 rows)
        row 0]
    (while (< row rows)
      (let [[entity entity-ok] (relation-column-row-number-join-key column row)]
        (when (not entity-ok)
          (delete out)
          (return (make [dynamic]Entity-Relation-Row-Ref) false))
        (arr.push! out (Entity-Relation-Row-Ref {entity: entity row: row})))
      (set! row (+ row 1)))
    (sort-entity-relation-row-refs! (addr out))
    (return out true)))

(defstruct Value-Relation-Row-Ref {
  value: Value
  row: int
})

(defn delete-value-relation-row-refs [refs: [dynamic]Value-Relation-Row-Ref]
  (for [ref refs]
    (delete-owned-value ref.value))
  (delete refs))

(defn value-relation-row-ref-less? [left: Value-Relation-Row-Ref, right: Value-Relation-Row-Ref] -> bool
  (let [compare (index-position-compare left.value right.value)]
    (or (< compare 0)
        (and (= compare 0)
             (< left.row right.row)))))

(defn swap-value-relation-row-refs! [refs: ^[dynamic]Value-Relation-Row-Ref, left: int, right: int]
  (let [temp refs^[left]]
    (set! refs^[left] refs^[right])
    (set! refs^[right] temp)))

(defn sift-down-value-relation-row-refs! [refs: ^[dynamic]Value-Relation-Row-Ref, start: int, end: int]
  (let [root start]
    (while true
      (let [child (+ (* root 2) 1)]
        (when (> child end)
          (return))
        (let [swap-index root]
          (when (value-relation-row-ref-less? refs^[swap-index] refs^[child])
            (set! swap-index child))
          (when (and (<= (+ child 1) end)
                     (value-relation-row-ref-less? refs^[swap-index] refs^[(+ child 1)]))
            (set! swap-index (+ child 1)))
          (when (= swap-index root)
            (return))
          (swap-value-relation-row-refs! refs root swap-index)
          (set! root swap-index))))))

(defn sort-value-relation-row-refs! [refs: ^[dynamic]Value-Relation-Row-Ref]
  (when (< (count refs^) 2)
    (return))
  (let [start (/ (- (count refs^) 2) 2)]
    (while (>= start 0)
      (sift-down-value-relation-row-refs! refs start (- (count refs^) 1))
      (set! start (- start 1))))
  (let [end (- (count refs^) 1)]
    (while (> end 0)
      (swap-value-relation-row-refs! refs 0 end)
      (set! end (- end 1))
      (sift-down-value-relation-row-refs! refs 0 end))))

(defn sorted-value-row-refs-from-relation-column-for-source-attr [source: DB-Read-Source, attr: string, column: Relation-Column, rows: int] -> [refs: [dynamic]Value-Relation-Row-Ref, ok: bool, error: string]
  (let [out (make [dynamic]Value-Relation-Row-Ref 0 rows)
        row 0]
    (while (< row rows)
      (let [[value value-ok] (typed-relation-column-value column row)]
        (when (not value-ok)
          (delete-value-relation-row-refs out)
          (return (make [dynamic]Value-Relation-Row-Ref) false ""))
        (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-clause-value-for-attr source attr value)]
          (when (not resolved-ok)
            (when (not (= resolved-error ""))
              (delete-value-relation-row-refs out)
              (return (make [dynamic]Value-Relation-Row-Ref) false resolved-error)))
          (when resolved-ok
            (arr.push! out (Value-Relation-Row-Ref {value: (value-owned resolved) row: row})))))
      (set! row (+ row 1)))
    (sort-value-relation-row-refs! (addr out))
    (return out true "")))

(defn add-relation-column-row! [out: ^[dynamic]Relation-Column, columns: []Relation-Column, row: int] -> bool
  (for [column index columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-add! (addr out^[index]) value)))
        (return false))))
  true)

(defn relation-column-row-compatible? [out: Relation-Column, column: Relation-Column, row: int] -> bool
  (let [[value value-ok] (typed-relation-column-value column row)]
    (and value-ok (relation-column-can-add? out value))))

(defn relation-column-row-add-checked! [out: ^Relation-Column, column: Relation-Column, row: int]
  (let [[value _] (typed-relation-column-value column row)]
    (discard (relation-column-add! out value))))

(defn typed-relation-row-value [rel: Typed-Relation, row: int, name: string] -> [value: Value, ok: bool]
  (let [[column-index column-ok] (typed-relation-attr-index rel name)]
    (when (not column-ok)
      (return (Value {}) false))
    (typed-relation-column-value rel.columns[column-index] row)))

(defn query-relation-typed-row-value [rel: Query-Relation, row: int, name: string] -> [value: Value, ok: bool]
  (when (not rel.has-typed-columns)
    (return (Value {}) false))
  (let [[column-index column-ok] (query-relation-attr-index-lookup rel name)]
    (when (not column-ok)
      (return (Value {}) false))
    (typed-relation-column-value rel.typed-columns[column-index] row)))

(defn query-relation-resolve-typed-term [rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (query-relation-typed-row-value rel row term.name))
     (return (Value {}) false)))

(defn query-relation-resolve-typed-entity-term [db: DB, rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
      (return (value-entity entity) lookup-ok)))
  (let [[resolved resolved-ok] (query-relation-resolve-typed-term rel row term)]
    (when (not resolved-ok)
      (return resolved false))
    (let [[entity entity-ok] (value-as-entity db resolved)]
      (when entity-ok
        (return entity true)))
    (when (= resolved.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db resolved.text)]
        (return (value-entity entity) ident-ok)))
    (when (= resolved.kind .Int)
      (return (value-entity (u64 resolved.int-value)) true))
    (return resolved true)))

(defn query-relation-typed-entity-term-needs-semantic-match? [rel: Query-Relation, row: int, term: Term] -> bool
  (when (not (= term.kind .Var))
    (return false))
  (let [[value value-ok] (query-relation-typed-row-value rel row term.name)]
    (when (not value-ok)
      (return false))
    (not (or (= value.kind .Entity)
             (= value.kind .Int)))))

(defn query-relation-typed-entity-var-column-needs-semantic-match? [rel: Query-Relation, name: string] -> bool
  (let [[column-index column-ok] (query-relation-attr-index-lookup rel name)]
    (when (not column-ok)
      (return false))
    (let [column rel.typed-columns[column-index]]
      (when (not column.has-kind)
        (return true))
      (not (or (= column.kind .Entity)
               (= column.kind .Int))))))

(defn query-relation-resolve-typed-entity-scan-term [db: DB, rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool]
  (when (query-relation-typed-entity-term-needs-semantic-match? rel row term)
    (return (Value {}) false))
  (query-relation-resolve-typed-entity-term db rel row term))

(defn query-relation-typed-row-var-agrees? [rel: Query-Relation, row: int, name: string, value: Value] -> bool
  (let [[existing existing-ok] (query-relation-typed-row-value rel row name)]
    (if existing-ok
      (predicate-value-equal? existing value)
      true)))

(defstruct Relation-Column-Source {
  side: int
  index: int
})

(defn relation-column-sources-for-join [left: Typed-Relation, right: Typed-Relation, attrs: []string] -> [sources: [dynamic]Relation-Column-Source, ok: bool]
  (let [out (make [dynamic]Relation-Column-Source 0 (count attrs))]
    (for [attr attrs]
      (let [[left-index left-ok] (typed-relation-attr-index left attr)]
        (if left-ok
          (arr.push! out (Relation-Column-Source {side: 0 index: left-index}))
          (let [[right-index right-ok] (typed-relation-attr-index right attr)]
            (when (not right-ok)
              (delete out)
              (return (make [dynamic]Relation-Column-Source) false))
            (arr.push! out (Relation-Column-Source {side: 1 index: right-index}))))))
    (return out true)))

(defn query-relation-column-sources-for-join [left: Query-Relation, right: Query-Relation, attrs: []string] -> [sources: [dynamic]Relation-Column-Source, ok: bool]
  (let [out (make [dynamic]Relation-Column-Source 0 (count attrs))]
    (for [attr attrs]
      (let [[left-index left-ok] (query-relation-attr-index-lookup left attr)]
        (if left-ok
          (arr.push! out (Relation-Column-Source {side: 0 index: left-index}))
          (let [[right-index right-ok] (query-relation-attr-index-lookup right attr)]
            (when (not right-ok)
              (delete out)
              (return (make [dynamic]Relation-Column-Source) false))
            (arr.push! out (Relation-Column-Source {side: 1 index: right-index}))))))
    (return out true)))

(defn add-typed-joined-column-row! [out: ^[dynamic]Relation-Column, sources: []Relation-Column-Source, left: Typed-Relation, left-row: int, right: Typed-Relation, right-row: int] -> bool
  (for [source out-index sources]
    (let [column (if (= source.side 0)
                   left.columns[source.index]
                   right.columns[source.index])
          row (if (= source.side 0) left-row right-row)]
      (when (not (relation-column-row-compatible? out^[out-index] column row))
        (return false))))
  (for [source out-index sources]
    (let [column (if (= source.side 0)
                   left.columns[source.index]
                   right.columns[source.index])
          row (if (= source.side 0) left-row right-row)]
      (relation-column-row-add-checked! (addr out^[out-index]) column row)))
  true)

(defn add-query-joined-column-row! [out: ^[dynamic]Relation-Column, sources: []Relation-Column-Source, left: Query-Relation, left-row: int, right: Query-Relation, right-row: int] -> bool
  (for [source out-index sources]
    (let [column (if (= source.side 0)
                   left.typed-columns[source.index]
                   right.typed-columns[source.index])
          row (if (= source.side 0) left-row right-row)]
      (when (not (relation-column-row-compatible? out^[out-index] column row))
        (return false))))
  (for [source out-index sources]
    (let [column (if (= source.side 0)
                   left.typed-columns[source.index]
                   right.typed-columns[source.index])
          row (if (= source.side 0) left-row right-row)]
      (relation-column-row-add-checked! (addr out^[out-index]) column row)))
  true)

(defn query-relation-product-typed-borrowed [left: Query-Relation, right: Query-Relation] -> [rel: Query-Relation, ok: bool]
  (when (not (and left.has-typed-columns right.has-typed-columns))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
        attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
        tuples (make [dynamic]Binding)]
    (for [name index right.attrs]
      (arr.push! attrs name)
      (arr.push! attr-sources right.attr-sources[index]))
    (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
          [column-sources column-sources-ok] (query-relation-column-sources-for-join left right (slice attrs 0))
          typed-rows 0]
      (when (not column-sources-ok)
        (delete attrs)
        (delete attr-sources)
        (delete tuples)
        (delete-relation-columns typed-columns)
        (return (query-relation-empty) false))
      (let [left-row 0]
        (while (< left-row left.typed-rows)
          (let [right-row 0]
            (while (< right-row right.typed-rows)
              (when (not (add-query-joined-column-row! (addr typed-columns) (slice column-sources 0) left left-row right right-row))
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (set! typed-rows (+ typed-rows 1))
              (set! right-row (+ right-row 1))))
          (set! left-row (+ left-row 1))))
      (delete column-sources)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: tuples
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-product-typed [left: Query-Relation, right: Query-Relation] -> [rel: Query-Relation, ok: bool]
  (let [[borrowed borrowed-ok] (query-relation-product-typed-borrowed left right)]
    (when borrowed-ok
      (return borrowed true))
    (delete-query-relation borrowed))
  (let [[left-typed left-ok] (typed-relation-from-query-relation left)]
    (when (not left-ok)
      (return (query-relation-empty) false))
    (defer (delete-typed-relation left-typed))
    (let [[right-typed right-ok] (typed-relation-from-query-relation right)]
      (when (not right-ok)
        (return (query-relation-empty) false))
      (defer (delete-typed-relation right-typed))
      (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
            attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
            tuples (make [dynamic]Binding)]
        (for [name index right.attrs]
          (arr.push! attrs name)
          (arr.push! attr-sources right.attr-sources[index]))
        (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
              [column-sources column-sources-ok] (relation-column-sources-for-join left-typed right-typed (slice attrs 0))
              typed-rows 0]
          (when (not column-sources-ok)
            (delete attrs)
            (delete attr-sources)
            (delete tuples)
            (delete-relation-columns typed-columns)
            (return (query-relation-empty) false))
          (let [left-row 0]
            (while (< left-row left-typed.rows)
              (let [right-row 0]
                (while (< right-row right-typed.rows)
                  (when (not (add-typed-joined-column-row! (addr typed-columns) (slice column-sources 0) left-typed left-row right-typed right-row))
                    (delete attrs)
                    (delete attr-sources)
                    (delete tuples)
                    (delete-relation-columns typed-columns)
                    (delete column-sources)
                    (return (query-relation-empty) false))
                  (set! typed-rows (+ typed-rows 1))
                  (set! right-row (+ right-row 1))))
              (set! left-row (+ left-row 1))))
          (delete column-sources)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: tuples
                                   typed-columns: typed-columns
                                   typed-rows: typed-rows
                                   has-typed-columns: true}) true))))))

(defn typed-relation-indexes-for-vars [rel: Typed-Relation, names: []string] -> [indexes: [dynamic]int, ok: bool]
  (let [out (make [dynamic]int 0 (count names))]
    (for [name names]
      (let [[index index-ok] (typed-relation-attr-index rel name)]
        (when (not index-ok)
          (delete out)
          (return (make [dynamic]int) false))
        (arr.push! out index)))
    (return out true)))

(defn query-relation-indexes-for-vars [rel: Query-Relation, names: []string] -> [indexes: [dynamic]int, ok: bool]
  (let [out (make [dynamic]int 0 (count names))]
    (for [name names]
      (let [[index index-ok] (query-relation-attr-index-lookup rel name)]
        (when (not index-ok)
          (delete out)
          (return (make [dynamic]int) false))
        (arr.push! out index)))
    (return out true)))

(defn typed-flat-result-plan-empty [] -> Typed-Flat-Result-Plan
  (Typed-Flat-Result-Plan {ok: false
                           find-indexes: (make [dynamic]int)
                           with-indexes: (make [dynamic]int)
                           column-kinds: (make [dynamic]Relation-Column-Kind)
                           rows: 0}))

(defn delete-typed-flat-result-plan [plan: Typed-Flat-Result-Plan]
  (delete plan.find-indexes)
  (delete plan.with-indexes)
  (delete plan.column-kinds))

(defstruct Resolved-Typed-Flat-Materialization {
  ok: bool
  plan: Typed-Flat-Result-Plan
  trust-unique-bindings: bool
})

(defstruct Typed-Flat-Materialization-Cursor {
  row: int
  seen: (map string (struct {}))
})

(defstruct Typed-Materialized-Batch {
  ok: bool
  names: [dynamic]string
  sources: [dynamic]string
  columns: [dynamic]Relation-Column
  value-columns: [dynamic]bool
  rows: int
  owns-values: bool
})

(defn resolved-typed-flat-materialization-empty [] -> Resolved-Typed-Flat-Materialization
  (Resolved-Typed-Flat-Materialization {ok: false
                                        plan: (typed-flat-result-plan-empty)
                                        trust-unique-bindings: false}))

(defn delete-resolved-typed-flat-materialization [resolved: Resolved-Typed-Flat-Materialization]
  (delete-typed-flat-result-plan resolved.plan))

(defn typed-flat-materialization-cursor [resolved: Resolved-Typed-Flat-Materialization] -> Typed-Flat-Materialization-Cursor
  (discard resolved)
  (Typed-Flat-Materialization-Cursor {row: 0
                                      seen: (set.empty string)}))

(defn delete-typed-flat-materialization-cursor [cursor: Typed-Flat-Materialization-Cursor]
  (for [key cursor.seen]
    (delete key))
  (delete cursor.seen))

(defn typed-materialized-batch-empty [] -> Typed-Materialized-Batch
  (Typed-Materialized-Batch {ok: false
                             names: (make [dynamic]string)
                             sources: (make [dynamic]string)
                             columns: (make [dynamic]Relation-Column)
                             value-columns: (make [dynamic]bool)
                             rows: 0
                             owns-values: false}))

(defn delete-typed-materialized-batch [batch: Typed-Materialized-Batch]
  (discard batch.owns-values)
  (delete batch.names)
  (delete batch.sources)
  (delete batch.value-columns)
  (delete-relation-columns batch.columns))

(defn delete-typed-materialized-batch-parts [names: [dynamic]string, sources: [dynamic]string, columns: [dynamic]Relation-Column, value-columns: [dynamic]bool, owns-values: bool]
  (delete-typed-materialized-batch
    (Typed-Materialized-Batch {ok: false
                               names: names
                               sources: sources
                               columns: columns
                               value-columns: value-columns
                               rows: 0
                               owns-values: owns-values})))

(defn relation-column-add-owned-value-cell! [column: ^Relation-Column, value: Value] -> bool
  (when (not column^.has-kind)
    (set! column^.kind .Mixed)
    (set! column^.has-kind true))
  (when (not (= column^.kind .Mixed))
    (return false))
  (arr.push! column^.values value)
  true)

(defn materialized-value-can-stay-primitive? [value: Value] -> bool
  (or (= value.kind .Entity)
      (= value.kind .Int)
      (= value.kind .Float)
      (= value.kind .Bool)))

(defn typed-materialized-batch-append-borrowed-value! [columns: ^[dynamic]Relation-Column, value-columns: []bool, output-column: int, value: Value] -> bool
  (when (or (< output-column 0)
            (>= output-column (count columns^))
            (>= output-column (count value-columns)))
    (return false))
  (if value-columns[output-column]
    (let [owned (value-owned value)]
      (when (not (relation-column-add-owned-value-cell! (addr columns^[output-column]) owned))
        (delete-owned-value owned)
        (return false))
      true)
    (relation-column-add! (addr columns^[output-column]) value)))

(defn typed-materialized-batch-append-owned-value! [columns: ^[dynamic]Relation-Column, value-columns: []bool, output-column: int, value: Value] -> bool
  (when (or (< output-column 0)
            (>= output-column (count columns^))
            (>= output-column (count value-columns))
            (not value-columns[output-column]))
    (delete-owned-value value)
    (return false))
  (when (not (relation-column-add-owned-value-cell! (addr columns^[output-column]) value))
    (delete-owned-value value)
    (return false))
  true)

(defn typed-materialized-batch-add-output-column! [names: ^[dynamic]string, sources: ^[dynamic]string, columns: ^[dynamic]Relation-Column, value-columns: ^[dynamic]bool, name: string, source: string, value-column: bool]
  (arr.push! names^ name)
  (arr.push! sources^ source)
  (arr.push! columns^ (relation-column-empty))
  (arr.push! value-columns^ value-column))

(defn typed-materialized-batch-add-typed-output-column! [names: ^[dynamic]string, sources: ^[dynamic]string, columns: ^[dynamic]Relation-Column, value-columns: ^[dynamic]bool, name: string, source: string, kind: Relation-Column-Kind]
  (let [column (relation-column-empty)]
    (set! column.kind kind)
    (set! column.has-kind true)
    (arr.push! names^ name)
    (arr.push! sources^ source)
    (arr.push! columns^ column)
    (arr.push! value-columns^ false)))

(defn typed-materialized-output-kind-needs-value-column? [kind: Relation-Column-Kind] -> bool
  (= kind .Mixed))

(defn typed-flat-result-plan-from-result-columns [rel: Query-Relation, result-shape: Physical-Result-Shape, result-columns: []Physical-Result-Column] -> Typed-Flat-Result-Plan
  (when (not (and rel.has-typed-columns
                  (physical-result-shape-flat-primitive? result-shape)
                  (> (count result-columns) 0)))
    (return (typed-flat-result-plan-empty)))
  (let [find-indexes (make [dynamic]int 0 result-shape.find-count)
        with-indexes (make [dynamic]int 0 result-shape.with-count)]
    (for [column result-columns]
      (case column.kind
        .ValueResultColumn
          (let [[index index-ok] (query-relation-attr-index-lookup rel column.var-name)]
            (when (not index-ok)
              (delete find-indexes)
              (delete with-indexes)
              (return (typed-flat-result-plan-empty)))
            (arr.push! find-indexes index))
        .WithDedupeColumn
          (let [[index index-ok] (query-relation-attr-index-lookup rel column.var-name)]
            (when (not index-ok)
              (delete find-indexes)
              (delete with-indexes)
              (return (typed-flat-result-plan-empty)))
            (arr.push! with-indexes index))
        .PullResultColumn
          (do
            (delete find-indexes)
            (delete with-indexes)
            (return (typed-flat-result-plan-empty)))
        .AggregateResultColumn
          (do
            (delete find-indexes)
            (delete with-indexes)
            (return (typed-flat-result-plan-empty)))

          (do
            (delete find-indexes)
            (delete with-indexes)
            (return (typed-flat-result-plan-empty)))))
    (when (not (and (= (count find-indexes) result-shape.find-count)
                    (= (count with-indexes) result-shape.with-count)))
      (delete find-indexes)
      (delete with-indexes)
      (return (typed-flat-result-plan-empty)))
    (let [column-kinds (make [dynamic]Relation-Column-Kind 0 (count find-indexes))]
      (for [column-index find-indexes]
        (let [column rel.typed-columns[column-index]]
          (when (not column.has-kind)
            (delete find-indexes)
            (delete with-indexes)
            (delete column-kinds)
            (return (typed-flat-result-plan-empty)))
          (arr.push! column-kinds column.kind)))
      (Typed-Flat-Result-Plan {ok: true
                               find-indexes: find-indexes
                               with-indexes: with-indexes
                               column-kinds: column-kinds
                               rows: rel.typed-rows}))))

(defn typed-flat-result-plan-from-materialization [rel: Query-Relation, materialization: Physical-Materialization-Plan] -> Typed-Flat-Result-Plan
  (typed-flat-result-plan-from-result-columns rel materialization.shape (slice materialization.columns 0)))

(defn resolve-typed-flat-materialization [rel: Query-Relation, materialization: Physical-Materialization-Plan] -> Resolved-Typed-Flat-Materialization
  (let [plan (typed-flat-result-plan-from-materialization rel materialization)]
    (when (not plan.ok)
      (return (Resolved-Typed-Flat-Materialization {ok: false
                                                    plan: plan
                                                    trust-unique-bindings: false})))
    (Resolved-Typed-Flat-Materialization {ok: true
                                          plan: plan
                                          trust-unique-bindings: materialization.trust-unique-bindings})))

(defn resolved-typed-flat-materialization-row-count [resolved: Resolved-Typed-Flat-Materialization] -> int
  (if resolved.ok resolved.plan.rows 0))

(defn resolved-typed-flat-materialization-column-count [resolved: Resolved-Typed-Flat-Materialization] -> int
  (if resolved.ok (count resolved.plan.find-indexes) 0))

(defn resolved-typed-flat-materialization-output-column-index [resolved: Resolved-Typed-Flat-Materialization, output-column: int] -> [index: int, ok: bool]
  (when (or (not resolved.ok)
            (< output-column 0)
            (>= output-column (count resolved.plan.find-indexes)))
    (return -1 false))
  (return resolved.plan.find-indexes[output-column] true))

(defn resolved-typed-flat-materialization-output-column-kind [rel: Query-Relation, resolved: Resolved-Typed-Flat-Materialization, output-column: int] -> [kind: Relation-Column-Kind, ok: bool]
  (let [[column-index column-ok] (resolved-typed-flat-materialization-output-column-index resolved output-column)]
    (when (or (not column-ok)
              (< column-index 0)
              (>= column-index (count rel.typed-columns)))
      (return .Nil false))
    (let [column rel.typed-columns[column-index]]
      (when (not column.has-kind)
        (return .Nil false))
      (return column.kind true))))

(defn resolved-typed-flat-materialization-output-cell-value [rel: Query-Relation, resolved: Resolved-Typed-Flat-Materialization, row: int, output-column: int] -> [value: Value, ok: bool]
  (when (or (not resolved.ok)
            (< row 0)
            (>= row resolved.plan.rows))
    (return (Value {}) false))
  (let [[column-index column-ok] (resolved-typed-flat-materialization-output-column-index resolved output-column)]
    (when (not column-ok)
      (return (Value {}) false))
    (typed-relation-column-value rel.typed-columns[column-index] row)))

(defn materialize-typed-flat-batch [rel: Query-Relation, resolved: Resolved-Typed-Flat-Materialization] -> Typed-Materialized-Batch
  (when (not resolved.ok)
    (return (typed-materialized-batch-empty)))
  (let [column-count (resolved-typed-flat-materialization-column-count resolved)
        names (make [dynamic]string 0 column-count)
        sources (make [dynamic]string 0 column-count)
        columns (make [dynamic]Relation-Column 0 column-count)
        value-columns (make [dynamic]bool 0 column-count)
        cursor (typed-flat-materialization-cursor resolved)
        owns-values false
        rows 0]
    (defer (delete-typed-flat-materialization-cursor cursor))
    (for [output-column (arr.range 0 column-count)]
      (let [[column-index column-index-ok] (resolved-typed-flat-materialization-output-column-index resolved output-column)
            [kind kind-ok] (resolved-typed-flat-materialization-output-column-kind rel resolved output-column)]
        (when (not (and column-index-ok kind-ok))
          (delete-typed-materialized-batch-parts names sources columns value-columns owns-values)
          (return (typed-materialized-batch-empty)))
        (if (typed-materialized-output-kind-needs-value-column? kind)
          (do
            (typed-materialized-batch-add-output-column! (addr names) (addr sources) (addr columns) (addr value-columns) rel.attrs[column-index] rel.attr-sources[column-index] true)
            (set! owns-values true))
          (typed-materialized-batch-add-typed-output-column! (addr names) (addr sources) (addr columns) (addr value-columns) rel.attrs[column-index] rel.attr-sources[column-index] kind))))
    (while true
      (let [[row found row-ok] (typed-flat-materialization-cursor-next! (addr cursor) rel resolved)]
        (when (not row-ok)
          (delete-typed-materialized-batch-parts names sources columns value-columns owns-values)
          (return (typed-materialized-batch-empty)))
        (when (not found)
          (break))
        (for [output-column (arr.range 0 column-count)]
          (let [[value value-ok] (resolved-typed-flat-materialization-output-cell-value rel resolved row output-column)]
            (when (or (not value-ok)
                      (not (typed-materialized-batch-append-borrowed-value! (addr columns) (slice value-columns 0) output-column value)))
              (delete-typed-materialized-batch-parts names sources columns value-columns owns-values)
              (return (typed-materialized-batch-empty)))))
        (set! rows (+ rows 1))))
    (Typed-Materialized-Batch {ok: true
                               names: names
                               sources: sources
                               columns: columns
                               value-columns: value-columns
                               rows: rows
                               owns-values: owns-values})))

(defstruct Materialized-Pull-Column {
  pull-find: Pull-Find
  source: DB-Read-Source
  pattern: []Pull-Spec
})

(defn materialized-pull-columns-for-query [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input] -> [columns: [dynamic]Materialized-Pull-Column, ok: bool, error: string]
  (let [out (make [dynamic]Materialized-Pull-Column 0 (count query-value.pulls))]
    (for [pull-find query-value.pulls]
      (let [[pull-source pull-source-ok pull-source-error] (db-read-source-pull-find-source source sources pull-find)]
        (when (not pull-source-ok)
          (delete out)
          (return (make [dynamic]Materialized-Pull-Column) false pull-source-error))
        (let [[pattern pattern-ok] (db-read-source-pull-find-pattern query-value inputs pull-find)]
          (when (not pattern-ok)
            (delete out)
            (return (make [dynamic]Materialized-Pull-Column) false "pull pattern input must be a pull pattern"))
          (arr.push! out (Materialized-Pull-Column {pull-find: pull-find
                                                    source: pull-source
                                                    pattern: pattern})))))
    (return out true "")))

(defn materialize-source-typed-pull-batch [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [batch: Typed-Materialized-Batch, ok: bool, error: string]
  (when (or (not rel.has-typed-columns)
            (= (count query-value.pulls) 0)
            (> (count query-value.aggregates) 0))
    (return (typed-materialized-batch-empty) false "typed pull materialization expects typed relation with pulls and no aggregates"))
  (let [[find-indexes find-ok] (query-relation-indexes-for-vars rel (slice query-value.find 0))]
    (when (not find-ok)
      (delete find-indexes)
      (return (typed-materialized-batch-empty) false "find var is not bound"))
    (defer (delete find-indexes))
    (let [column-count (+ (count query-value.find) (count query-value.pulls))
          names (make [dynamic]string 0 column-count)
          sources-out (make [dynamic]string 0 column-count)
          columns (make [dynamic]Relation-Column 0 column-count)
          value-columns (make [dynamic]bool 0 column-count)
          [pull-columns pull-columns-ok pull-columns-error] (materialized-pull-columns-for-query source sources query-value inputs)]
      (when (not pull-columns-ok)
        (delete names)
        (delete sources-out)
        (delete value-columns)
        (delete-relation-columns columns)
        (delete pull-columns)
        (return (typed-materialized-batch-empty) false pull-columns-error))
      (defer (delete pull-columns))
      (for [column-index find-indexes]
        (typed-materialized-batch-add-output-column! (addr names) (addr sources-out) (addr columns) (addr value-columns) rel.attrs[column-index] rel.attr-sources[column-index] false))
      (for [pull-column pull-columns]
        (typed-materialized-batch-add-output-column! (addr names) (addr sources-out) (addr columns) (addr value-columns) (strings.concatenate ([]string ["(pull " pull-column.pull-find.var ")"])) pull-column.pull-find.source true))
      (for [row (arr.range 0 rel.typed-rows)]
        (for [column-index find-position find-indexes]
          (let [[value value-ok] (typed-relation-column-value rel.typed-columns[column-index] row)]
            (when (or (not value-ok)
                      (not (typed-materialized-batch-append-borrowed-value! (addr columns) (slice value-columns 0) find-position value)))
              (delete names)
              (delete sources-out)
              (delete value-columns)
                (delete-relation-columns columns)
                (return (typed-materialized-batch-empty) false "find var value missing"))))
        (let [first-pull-column (count find-indexes)]
          (for [pull-column pull-index pull-columns]
            (let [[entity-value entity-value-ok] (query-relation-typed-row-value rel row pull-column.pull-find.var)]
                (when (not entity-value-ok)
                  (delete names)
                  (delete sources-out)
                  (delete value-columns)
                  (delete-relation-columns columns)
                  (return (typed-materialized-batch-empty) false "pull entity var is not bound"))
                (let [[entity entity-ok] (db-read-source-pull-entity entity-value)]
                  (when (not entity-ok)
                    (delete names)
                    (delete sources-out)
                    (delete value-columns)
                    (delete-relation-columns columns)
                    (return (typed-materialized-batch-empty) false "pull entity value must be an entity id"))
                  (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-column.source entity pull-column.pattern registry)]
                      (when (not pull-ok)
                        (delete-pull-result-owned-values pull)
                        (delete names)
                        (delete sources-out)
                        (delete value-columns)
                        (delete-relation-columns columns)
                        (return (typed-materialized-batch-empty) false pull-error))
                      (let [[rendered rendered-ok rendered-error] (db-read-source-pull-result-value pull-column.source pull)]
                        (delete-pull-result-owned-values pull)
                        (when (not rendered-ok)
                          (delete names)
                          (delete sources-out)
                          (delete value-columns)
                          (delete-relation-columns columns)
                          (return (typed-materialized-batch-empty) false rendered-error))
                        (when (not (typed-materialized-batch-append-owned-value! (addr columns) (slice value-columns 0) (+ first-pull-column pull-index) rendered))
                          (delete names)
                          (delete sources-out)
                          (delete value-columns)
                          (delete-relation-columns columns)
                          (return (typed-materialized-batch-empty) false "pull result column could not accept value")))))))))
      (return (Typed-Materialized-Batch {ok: true
                                         names: names
                                         sources: sources-out
                                         columns: columns
                                         value-columns: value-columns
                                         rows: rel.typed-rows
                                         owns-values: true})
              true
              ""))))

(defn typed-materialized-batch-cell-value [batch: Typed-Materialized-Batch, row: int, output-column: int] -> [value: Value, ok: bool]
  (when (or (not batch.ok)
            (< row 0)
            (>= row batch.rows)
            (< output-column 0)
            (>= output-column (count batch.columns)))
    (return (Value {}) false))
  (typed-relation-column-value batch.columns[output-column] row))

(defn result-rows-for-typed-materialized-batch [batch: Typed-Materialized-Batch] -> [rows: [dynamic]Result-Row, ok: bool, error: string]
  (when (not batch.ok)
    (return (make [dynamic]Result-Row) false "typed materialized batch expected"))
  (let [out (make [dynamic]Result-Row 0 batch.rows)]
    (for [row (arr.range 0 batch.rows)]
      (let [values (make [dynamic]Value 0 (count batch.columns))]
        (for [output-column (arr.range 0 (count batch.columns))]
          (let [[value value-ok] (typed-materialized-batch-cell-value batch row output-column)]
            (when (not value-ok)
              (delete values)
              (delete-result-rows-owned-values out)
              (return (make [dynamic]Result-Row) false "typed materialized batch cell could not be read"))
            (arr.push! values (value-owned value))))
        (arr.push! out (Result-Row {values: values
                                    pulls: (make [dynamic]Pull-Result)}))))
    (return out true "")))

(defn query-typed-flat-result-plan-from-physical-plan [query: Query, rel: Query-Relation, plan: Physical-Plan] -> Typed-Flat-Result-Plan
  (typed-flat-result-plan-from-materialization rel plan.materialization))

(defn query-typed-flat-result-plan [query: Query, rel: Query-Relation] -> Typed-Flat-Result-Plan
  (let [materialization (physical-materialization-plan-from-query query)]
    (defer (delete-physical-materialization-plan materialization))
    (typed-flat-result-plan-from-materialization rel materialization)))

(defn typed-flat-result-plan-for-output-relation [rel: Query-Relation] -> Typed-Flat-Result-Plan
  (when (not rel.has-typed-columns)
    (return (typed-flat-result-plan-empty)))
  (let [find-indexes (make [dynamic]int 0 (count rel.typed-columns))
        with-indexes (make [dynamic]int)
        column-kinds (make [dynamic]Relation-Column-Kind 0 (count rel.typed-columns))]
    (for [column index rel.typed-columns]
      (when (not column.has-kind)
        (delete find-indexes)
        (delete with-indexes)
        (delete column-kinds)
        (return (typed-flat-result-plan-empty)))
      (arr.push! find-indexes index)
      (arr.push! column-kinds column.kind))
    (Typed-Flat-Result-Plan {ok: true
                             find-indexes: find-indexes
                             with-indexes: with-indexes
                             column-kinds: column-kinds
                             rows: rel.typed-rows})))

(defn pulls-for-typed-row-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, rel: Query-Relation, row: int, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (let [out (make [dynamic]Pull-Result 0 (count query.pulls))]
    (for [pull-find query.pulls]
      (let [[entity-value entity-value-ok] (query-relation-typed-row-value rel row pull-find.var)]
        (when (not entity-value-ok)
          (return out false))
        (let [[pattern pattern-ok] (pull-find-pattern query inputs pull-find)
              [pull-db pull-db-ok] (pull-db-for-find db sources pull-find)
              entity: u64 0
              entity-ok false]
          (when pull-db-ok
            (let [[resolved resolved-ok] (pull-entity-from-value pull-db entity-value)]
              (set! entity resolved)
              (set! entity-ok resolved-ok)))
          (if (and pattern-ok pull-db-ok entity-ok)
            (arr.push! out (pull-pattern-spec-with-fns pull-db entity pattern registry))
            (return out false)))))
    (return out true)))

(defn result-rows-for-typed-flat-relation-with-materialization [query: Query, rel: Query-Relation, materialization: Physical-Materialization-Plan] -> [rows: [dynamic]Result-Row, ok: bool]
  (discard query)
  (let [resolved (resolve-typed-flat-materialization rel materialization)]
    (when (not resolved.ok)
      (delete-resolved-typed-flat-materialization resolved)
      (return (make [dynamic]Result-Row) false))
    (defer (delete-resolved-typed-flat-materialization resolved))
    (let [batch (materialize-typed-flat-batch rel resolved)]
      (when (not batch.ok)
        (delete-typed-materialized-batch batch)
        (return (make [dynamic]Result-Row) false))
      (defer (delete-typed-materialized-batch batch))
      (let [[out-rows rows-ok _] (result-rows-for-typed-materialized-batch batch)]
        (return out-rows rows-ok)))))

(defn result-rows-for-typed-flat-relation [query: Query, rel: Query-Relation] -> [rows: [dynamic]Result-Row, ok: bool]
  (let [materialization (physical-materialization-plan-from-query query)]
    (defer (delete-physical-materialization-plan materialization))
    (result-rows-for-typed-flat-relation-with-materialization query rel materialization)))

(defn typed-flat-result-row-dedupe-key [rel: Query-Relation, plan: Typed-Flat-Result-Plan, row: int] -> [key: string, ok: bool]
  (let [dedupe-values (make [dynamic]Value)]
    (defer (delete dedupe-values))
    (for [column-index plan.find-indexes]
      (let [[value value-ok] (typed-relation-column-value rel.typed-columns[column-index] row)]
        (when (not value-ok)
          (return "" false))
        (arr.push! dedupe-values value)))
    (for [column-index plan.with-indexes]
      (let [[value value-ok] (typed-relation-column-value rel.typed-columns[column-index] row)]
        (when (not value-ok)
          (return "" false))
        (arr.push! dedupe-values value)))
    (let [[dedupe-key key-ok] (row-values-dedupe-key (slice dedupe-values 0))]
      (if key-ok
        (return dedupe-key true)
        (return "" false)))))

(defn resolved-typed-flat-materialization-row-visible? [rel: Query-Relation, resolved: Resolved-Typed-Flat-Materialization, row: int, seen: (ptr (map string (struct {})))] -> [visible: bool, ok: bool]
  (when resolved.trust-unique-bindings
    (return true true))
  (let [[key key-ok] (typed-flat-result-row-dedupe-key rel resolved.plan row)]
    (when (not key-ok)
      (return false false))
    (when (set.contains? seen^ key)
      (delete key)
      (return false true))
    (set.add! seen^ key)
    (return true true)))

(defn typed-flat-materialization-cursor-next! [cursor: ^Typed-Flat-Materialization-Cursor, rel: Query-Relation, resolved: Resolved-Typed-Flat-Materialization] -> [row: int, found: bool, ok: bool]
  (let [row-count (resolved-typed-flat-materialization-row-count resolved)]
    (while (< cursor^.row row-count)
      (let [row cursor^.row]
        (set! cursor^.row (+ cursor^.row 1))
        (let [[visible visible-ok] (resolved-typed-flat-materialization-row-visible? rel resolved row (addr cursor^.seen))]
          (when (not visible-ok)
            (return -1 false false))
          (when visible
            (return row true true)))))
    (return -1 false true)))

(defn typed-flat-result-row-visible? [rel: Query-Relation, materialization: Physical-Materialization-Plan, plan: Typed-Flat-Result-Plan, row: int, seen: (ptr (map string (struct {})))] -> [visible: bool, ok: bool]
  (resolved-typed-flat-materialization-row-visible?
    rel
    (Resolved-Typed-Flat-Materialization {ok: plan.ok
                                          plan: plan
                                          trust-unique-bindings: materialization.trust-unique-bindings})
    row
    seen))

(defn typed-flat-result-row-count [query: Query, rel: Query-Relation] -> [row-count: int, ok: bool]
  (when (not rel.has-typed-columns)
    (return 0 false))
  (let [materialization (physical-materialization-plan-from-query query)]
    (defer (delete-physical-materialization-plan materialization))
    (let [resolved (resolve-typed-flat-materialization rel materialization)]
      (when (not resolved.ok)
        (delete-resolved-typed-flat-materialization resolved)
        (return 0 false))
      (defer (delete-resolved-typed-flat-materialization resolved))
      (when resolved.trust-unique-bindings
        (return (resolved-typed-flat-materialization-row-count resolved) true))
      (let [cursor (typed-flat-materialization-cursor resolved)
            out 0]
        (defer (delete-typed-flat-materialization-cursor cursor))
        (while true
          (let [[_row found row-ok] (typed-flat-materialization-cursor-next! (addr cursor) rel resolved)]
            (discard _row)
            (when (not row-ok)
              (return 0 false))
            (when (not found)
              (break))
            (set! out (+ out 1))))
        (return out true)))))

(defn result-rows-for-typed-relation-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (when (not rel.has-typed-columns)
    (return (make [dynamic]Result-Row) false))
  (when (query-physical-result-shape-flat-primitive? query)
    (let [[flat-rows flat-ok] (result-rows-for-typed-flat-relation query rel)]
      (when flat-ok
        (return flat-rows true))
      (delete-result-rows-shallow flat-rows)))
    (let [[find-indexes find-ok] (query-relation-indexes-for-vars rel (slice query.find 0))]
      (when (not find-ok)
        (return (make [dynamic]Result-Row) false))
      (defer (delete find-indexes))
      (let [[with-indexes with-ok] (query-relation-indexes-for-vars rel (slice query.with 0))]
        (when (not with-ok)
          (return (make [dynamic]Result-Row) false))
        (defer (delete with-indexes))
    (let [out (make [dynamic]Result-Row 0 rel.typed-rows)
          seen (set.empty string)
          trust-unique-bindings (query-can-trust-unique-bindings? query)]
      (defer (delete-owned-string-set seen))
      (for [row (arr.range 0 rel.typed-rows)]
        (let [values (make [dynamic]Value 0 (count query.find))
              [pulls pulls-ok] (pulls-for-typed-row-with-sources-and-fns db sources query inputs rel row registry)
              pushed false]
          (when (not pulls-ok)
            (delete values)
            (for [pull pulls]
              (delete-pull-result-shallow pull))
            (delete pulls)
            (return out false))
          (for [column-index find-indexes]
            (let [[value _] (typed-relation-column-value rel.typed-columns[column-index] row)]
              (arr.push! values value)))
          (if trust-unique-bindings
            (do
              (arr.push! out (Result-Row {values: values pulls: pulls}))
              (set! pushed true))
            (let [dedupe-values (make [dynamic]Value)]
              (for [value values]
                (arr.push! dedupe-values value))
              (for [column-index with-indexes]
                (let [[value _] (typed-relation-column-value rel.typed-columns[column-index] row)]
                  (arr.push! dedupe-values value)))
              (let [[key key-ok] (result-row-dedupe-key (slice dedupe-values 0) (slice pulls 0))]
                (if key-ok
                  (let [already-seen (set.contains? seen key)]
                    (when (not already-seen)
                      (set.add! seen key)
                      (arr.push! out (Result-Row {values: values pulls: pulls}))
                      (set! pushed true))
                    (when already-seen
                      (delete key)))
                  (when (not (row-values-exist? (slice out 0) (slice dedupe-values 0)))
                    (arr.push! out (Result-Row {values: values pulls: pulls}))
                    (set! pushed true))))
              (delete dedupe-values)))
          (when (not pushed)
            (delete values)
            (for [pull pulls]
              (delete-pull-result-shallow pull))
            (delete pulls))))
      (return out true)))))

(defn result-rows-for-typed-relation [query: Query, rel: Query-Relation] -> [rows: [dynamic]Result-Row, ok: bool]
  (result-rows-for-typed-relation-with-sources-and-fns (DB {}) ([]DB-Source []) query ([]Query-Input []) rel ([]Native-Query-Fn [])))

(defn db-read-source-pulls-for-typed-row-with-materialized-pull-columns-and-fns [pull-columns: []Materialized-Pull-Column, rel: Query-Relation, row: int, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool, error: string]
  (let [out (make [dynamic]Pull-Result 0 (count pull-columns))]
    (for [pull-column pull-columns]
      (let [[entity-value entity-value-ok] (query-relation-typed-row-value rel row pull-column.pull-find.var)]
        (when (not entity-value-ok)
          (for [existing out]
            (delete-pull-result-owned-values existing))
          (delete out)
          (return (make [dynamic]Pull-Result) false "pull entity var is not bound"))
        (let [[entity entity-ok] (db-read-source-pull-entity entity-value)]
          (when (not entity-ok)
            (for [existing out]
              (delete-pull-result-owned-values existing))
            (delete out)
            (return (make [dynamic]Pull-Result) false "pull entity value must be an entity id"))
          (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-column.source entity pull-column.pattern registry)]
            (when (not pull-ok)
              (for [existing out]
                (delete-pull-result-owned-values existing))
              (delete out)
              (return (make [dynamic]Pull-Result) false pull-error))
            (arr.push! out pull)))))
    (return out true "")))

(defn db-read-source-pulls-for-aggregate-row-with-materialized-pull-columns-and-fns [pull-columns: []Materialized-Pull-Column, group-vars: []string, row: Result-Row, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool, error: string]
  (let [out (make [dynamic]Pull-Result 0 (count pull-columns))]
    (for [pull-column pull-columns]
      (let [[entity-value entity-value-ok] (aggregate-row-value-for-var-in-vars group-vars row pull-column.pull-find.var)]
        (when (not entity-value-ok)
          (for [pull out]
            (delete-pull-result-owned-values pull))
          (delete out)
          (return (make [dynamic]Pull-Result) false "pull entity var is not grouped"))
        (let [[entity entity-ok] (db-read-source-pull-entity entity-value)]
          (when (not entity-ok)
            (for [pull out]
              (delete-pull-result-owned-values pull))
            (delete out)
            (return (make [dynamic]Pull-Result) false "pull entity value must be an entity id"))
          (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-column.source entity pull-column.pattern registry)]
            (when (not pull-ok)
              (delete-pull-result-owned-values pull)
              (for [existing out]
                (delete-pull-result-owned-values existing))
              (delete out)
              (return (make [dynamic]Pull-Result) false pull-error))
            (arr.push! out pull)))))
    (return out true "")))

(defn db-read-source-pull-aggregate-result-rows-for-typed-relation-with-sources-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool, error: string]
  (when (or (not rel.has-typed-columns)
            (= (count query-value.pulls) 0)
            (= (count query-value.aggregates) 0))
    (return (make [dynamic]Result-Row) false "typed pull+aggregate rows expected"))
  (let [group-vars (pull-aggregate-group-vars query-value) :defer
        [pull-columns pull-columns-ok pull-columns-error] (materialized-pull-columns-for-query source sources query-value inputs)
        [aggregate-rows aggregate-rows-ok] (aggregate-rows-for-typed-relation-one-pass-with-group-vars-and-fns query-value rel (slice group-vars 0) registry)]
    (when (not pull-columns-ok)
      (delete pull-columns)
      (delete-result-rows-owned-values aggregate-rows)
      (return (make [dynamic]Result-Row) false pull-columns-error))
    (defer (delete pull-columns))
    (when (not aggregate-rows-ok)
      (delete-result-rows-owned-values aggregate-rows)
      (return (make [dynamic]Result-Row) false "aggregate rows could not be rendered"))
    (let [out (make [dynamic]Result-Row 0 (count aggregate-rows))]
      (for [row aggregate-rows]
        (when (not (= (count row.values) (+ (count group-vars) (count query-value.aggregates))))
          (delete-result-rows-owned-values out)
          (delete-result-rows-owned-values aggregate-rows)
          (return (make [dynamic]Result-Row) false "aggregate row width did not match query output"))
        (let [values (make [dynamic]Value 0 (+ (count query-value.find) (count query-value.aggregates)))
              [pulls pulls-ok pulls-error] (db-read-source-pulls-for-aggregate-row-with-materialized-pull-columns-and-fns (slice pull-columns 0) (slice group-vars 0) row registry)]
          (when (not pulls-ok)
            (delete values)
            (delete-result-rows-owned-values out)
            (delete-result-rows-owned-values aggregate-rows)
            (return (make [dynamic]Result-Row) false pulls-error))
          (for [index (arr.range 0 (count query-value.find))]
            (arr.push! values (value-owned row.values[index])))
          (for [index (arr.range 0 (count query-value.aggregates))]
            (arr.push! values (value-owned row.values[(+ (count group-vars) index)])))
          (arr.push! out (Result-Row {values: values pulls: pulls}))))
      (delete-result-rows-owned-values aggregate-rows)
      (return out true ""))))

(defn db-read-source-result-rows-for-typed-relation-with-sources-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool, error: string]
  (when (not rel.has-typed-columns)
    (return (make [dynamic]Result-Row) false "typed relation expected"))
  (when (= (count query-value.pulls) 0)
    (let [materialization (physical-materialization-plan-from-query query-value)
          materialize-op (physical-materialize-op-from-materialization materialization)]
      (defer (delete-physical-materialization-plan materialization))
      (defer (delete materialize-op.referenced-vars))
      (defer (delete materialize-op.input-vars))
      (defer (delete materialize-op.output-vars))
      (when (physical-materialization-materializable? materialization)
        (let [[batch batch-ok batch-error] (db-read-source-apply-physical-materialize-op source sources query-value inputs rel materialize-op materialization registry)]
          (when batch-ok
            (let [[rows rows-ok rows-error] (result-rows-for-typed-materialized-batch batch)]
              (delete-typed-materialized-batch batch)
              (return rows rows-ok rows-error)))
          (discard batch-error)
          (delete-typed-materialized-batch batch)))))
  (when (and (> (count query-value.pulls) 0)
             (> (count query-value.aggregates) 0))
    (return (db-read-source-pull-aggregate-result-rows-for-typed-relation-with-sources-and-fns source sources query-value inputs rel registry)))
  (when (> (count query-value.aggregates) 0)
    (let [[rows rows-ok] (aggregate-rows-for-typed-relation-with-fns query-value rel registry)]
      (if rows-ok
        (return rows true "")
        (do
          (delete-result-rows-owned-values rows)
          (return (make [dynamic]Result-Row) false "typed aggregate rows could not be rendered")))))
  (let [[find-indexes find-ok] (query-relation-indexes-for-vars rel (slice query-value.find 0))]
    (when (not find-ok)
      (return (make [dynamic]Result-Row) false "find var is not bound"))
    (defer (delete find-indexes))
    (let [[with-indexes with-ok] (query-relation-indexes-for-vars rel (slice query-value.with 0))]
      (when (not with-ok)
        (return (make [dynamic]Result-Row) false "with var is not bound"))
      (defer (delete with-indexes))
      (let [[pull-columns pull-columns-ok pull-columns-error] (materialized-pull-columns-for-query source sources query-value inputs)]
        (when (not pull-columns-ok)
          (delete pull-columns)
          (return (make [dynamic]Result-Row) false pull-columns-error))
        (defer (delete pull-columns))
      (let [out (make [dynamic]Result-Row 0 rel.typed-rows)
            seen (set.empty string)
            trust-unique-bindings (query-can-trust-unique-bindings? query-value)]
        (defer (delete-owned-string-set seen))
        (for [row (arr.range 0 rel.typed-rows)]
          (let [values (make [dynamic]Value 0 (count query-value.find))
                dedupe-values (make [dynamic]Value)
                [pulls pulls-ok pulls-error] (db-read-source-pulls-for-typed-row-with-materialized-pull-columns-and-fns (slice pull-columns 0) rel row registry)
                pushed false]
            (when (not pulls-ok)
              (delete values)
              (delete dedupe-values)
              (for [pull pulls]
                (delete-pull-result-owned-values pull))
              (delete pulls)
              (delete-result-rows-owned-values out)
              (return (make [dynamic]Result-Row) false pulls-error))
            (for [column-index find-indexes]
              (let [[value value-ok] (typed-relation-column-value rel.typed-columns[column-index] row)]
                (when (not value-ok)
                  (delete values)
                  (delete dedupe-values)
                  (for [pull pulls]
                    (delete-pull-result-owned-values pull))
                  (delete pulls)
                  (delete-result-rows-owned-values out)
                  (return (make [dynamic]Result-Row) false "find var value missing"))
                (arr.push! values (value-owned value))
                (arr.push! dedupe-values value)))
            (for [column-index with-indexes]
              (let [[value value-ok] (typed-relation-column-value rel.typed-columns[column-index] row)]
                (when (not value-ok)
                  (delete values)
                  (delete dedupe-values)
                  (for [pull pulls]
                    (delete-pull-result-owned-values pull))
                  (delete pulls)
                  (delete-result-rows-owned-values out)
                  (return (make [dynamic]Result-Row) false "with var value missing"))
                (arr.push! dedupe-values value)))
            (if trust-unique-bindings
              (do
                (arr.push! out (Result-Row {values: values pulls: pulls}))
                (set! pushed true))
              (let [[key key-ok] (result-row-dedupe-key (slice dedupe-values 0) (slice pulls 0))]
                (if key-ok
                  (let [already-seen (set.contains? seen key)]
                    (when (not already-seen)
                      (set.add! seen key)
                      (arr.push! out (Result-Row {values: values pulls: pulls}))
                      (set! pushed true))
                    (when already-seen
                      (delete key)))
                  (when (not (row-values-exist? (slice out 0) (slice dedupe-values 0)))
                    (arr.push! out (Result-Row {values: values pulls: pulls}))
                    (set! pushed true)))))
            (delete dedupe-values)
            (when (not pushed)
              (for [value values]
                (delete-owned-value value))
              (delete values)
              (for [pull pulls]
                (delete-pull-result-owned-values pull))
              (delete pulls))))
        (return out true ""))))))

(defn query-relation-hash-join-typed-number [left: Query-Relation, right: Query-Relation, common: []string] -> [rel: Query-Relation, ok: bool]
  (when (not (and (= (count common) 1)
                  (query-relations-compatible-common? left right common)))
    (return (query-relation-empty) false))
  (let [[left-common-index left-common-ok] (query-relation-attr-index-lookup left common[0])
        [right-common-index right-common-ok] (query-relation-attr-index-lookup right common[0])]
    (when (not (and left-common-ok right-common-ok))
      (return (query-relation-empty) false))
    (when (not (and (= left.typed-columns[left-common-index].kind .Entity)
                    (= right.typed-columns[right-common-index].kind .Entity)))
      (return (query-relation-empty) false))
    (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
          attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
          tuples (make [dynamic]Binding)
          bucket-heads (make (map u64 int))
          next-indexes (make [dynamic]int right.typed-rows)]
      (arr.fill! next-indexes -1)
      (for [name index right.attrs]
        (when (not (query-relation-has-attr? left name))
          (arr.push! attrs name)
          (arr.push! attr-sources right.attr-sources[index])))
      (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
            [column-sources column-sources-ok] (query-relation-column-sources-for-join left right (slice attrs 0))
            typed-rows 0]
        (when (not column-sources-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete bucket-heads)
          (delete next-indexes)
          (delete-relation-columns typed-columns)
          (return (query-relation-empty) false))
        (let [right-row (- right.typed-rows 1)]
          (while (>= right-row 0)
            (let [[key key-ok] (relation-column-row-number-join-key right.typed-columns[right-common-index] right-row)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (set! next-indexes[right-row] head))
                (mmap.assoc! bucket-heads key right-row)))
            (dec! right-row)))
        (let [left-row 0]
          (while (< left-row left.typed-rows)
            (let [[key key-ok] (relation-column-row-number-join-key left.typed-columns[left-common-index] left-row)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (let [right-index head]
                    (while (>= right-index 0)
                      (when (not (add-query-joined-column-row! (addr typed-columns) (slice column-sources 0) left left-row right right-index))
                        (delete attrs)
                        (delete attr-sources)
                        (delete tuples)
                        (delete bucket-heads)
                        (delete next-indexes)
                        (delete-relation-columns typed-columns)
                        (delete column-sources)
                        (return (query-relation-empty) false))
                      (set! typed-rows (+ typed-rows 1))
                      (set! right-index next-indexes[right-index]))))))
            (set! left-row (+ left-row 1))))
        (delete bucket-heads)
        (delete next-indexes)
        (delete column-sources)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: tuples
                                 typed-columns: typed-columns
                                 typed-rows: typed-rows
                                 has-typed-columns: true}) true)))))

(defn query-relation-typed-rows-agree-on-common-from? [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, left-row: int, right-row: int, common: []string, start: int] -> bool
  (let [index start]
    (while (< index (count common))
      (let [name common[index]
            [left-value left-ok] (query-relation-typed-row-value left left-row name)
            [right-value right-ok] (query-relation-typed-row-value right right-row name)]
        (when (not (and left-ok right-ok (relation-entity-values-equal? db sources left right name left-value right-value)))
          (return false)))
      (set! index (+ index 1))))
  true)

(defn query-relation-typed-rows-agree-on-common? [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, left-row: int, right-row: int, common: []string] -> bool
  (query-relation-typed-rows-agree-on-common-from? db sources left right left-row right-row common 0))

(defn query-relation-typed-rows-agree-after-leading-common? [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, left-row: int, right-row: int, common: []string] -> bool
  (query-relation-typed-rows-agree-on-common-from? db sources left right left-row right-row common 1))

(defn query-relation-hash-join-typed-leading-number [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, common: []string] -> [rel: Query-Relation, ok: bool]
  (when (not (and (> (count common) 1)
                  (query-relations-compatible-common? left right common)))
    (return (query-relation-empty) false))
  (let [[left-common-index left-common-ok] (query-relation-attr-index-lookup left common[0])
        [right-common-index right-common-ok] (query-relation-attr-index-lookup right common[0])]
    (when (not (and left-common-ok right-common-ok))
      (return (query-relation-empty) false))
    (when (not (and (or (= left.typed-columns[left-common-index].kind .Entity)
                        (= left.typed-columns[left-common-index].kind .Int))
                    (or (= right.typed-columns[right-common-index].kind .Entity)
                        (= right.typed-columns[right-common-index].kind .Int))))
      (return (query-relation-empty) false))
    (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
          attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
          tuples (make [dynamic]Binding)
          bucket-heads (make (map u64 int))
          next-indexes (make [dynamic]int right.typed-rows)]
      (arr.fill! next-indexes -1)
      (for [name index right.attrs]
        (when (not (query-relation-has-attr? left name))
          (arr.push! attrs name)
          (arr.push! attr-sources right.attr-sources[index])))
      (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
            [column-sources column-sources-ok] (query-relation-column-sources-for-join left right (slice attrs 0))
            typed-rows 0]
        (when (not column-sources-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete bucket-heads)
          (delete next-indexes)
          (delete-relation-columns typed-columns)
          (return (query-relation-empty) false))
        (let [right-row (- right.typed-rows 1)]
          (while (>= right-row 0)
            (let [[key key-ok] (relation-column-row-number-join-key right.typed-columns[right-common-index] right-row)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (set! next-indexes[right-row] head))
                (mmap.assoc! bucket-heads key right-row)))
            (dec! right-row)))
        (let [left-row 0]
          (while (< left-row left.typed-rows)
            (let [[key key-ok] (relation-column-row-number-join-key left.typed-columns[left-common-index] left-row)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (let [right-index head]
                    (while (>= right-index 0)
                      (when (query-relation-typed-rows-agree-after-leading-common? db sources left right left-row right-index common)
                        (when (not (add-query-joined-column-row! (addr typed-columns) (slice column-sources 0) left left-row right right-index))
                          (delete attrs)
                          (delete attr-sources)
                          (delete tuples)
                          (delete bucket-heads)
                          (delete next-indexes)
                          (delete-relation-columns typed-columns)
                          (delete column-sources)
                          (return (query-relation-empty) false))
                        (set! typed-rows (+ typed-rows 1)))
                      (set! right-index next-indexes[right-index]))))))
            (set! left-row (+ left-row 1))))
        (delete bucket-heads)
        (delete next-indexes)
        (delete column-sources)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: tuples
                                 typed-columns: typed-columns
                                 typed-rows: typed-rows
                                 has-typed-columns: true}) true)))))

(defn query-relation-hash-join-typed-borrowed [left: Query-Relation, right: Query-Relation, common: []string] -> [rel: Query-Relation, ok: bool]
  (when (not (query-relations-compatible-common? left right common))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
        attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
        tuples (make [dynamic]Binding)
        bucket-heads (make (map string int))
        next-indexes (make [dynamic]int right.typed-rows)]
    (arr.fill! next-indexes -1)
    (for [name index right.attrs]
      (when (not (query-relation-has-attr? left name))
        (arr.push! attrs name)
        (arr.push! attr-sources right.attr-sources[index])))
    (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
          [column-sources column-sources-ok] (query-relation-column-sources-for-join left right (slice attrs 0))
          typed-rows 0]
      (when (not column-sources-ok)
        (delete attrs)
        (delete attr-sources)
        (delete tuples)
        (delete bucket-heads)
        (delete next-indexes)
        (delete-relation-columns typed-columns)
        (return (query-relation-empty) false))
      (let [right-row (- right.typed-rows 1)]
        (while (>= right-row 0)
          (let [[key key-ok] (query-relation-row-join-key right right-row common)]
            (when (not key-ok)
              (delete attrs)
              (delete attr-sources)
              (delete tuples)
              (delete bucket-heads)
              (delete next-indexes)
              (delete-relation-columns typed-columns)
              (delete column-sources)
              (return (query-relation-empty) false))
            (let [[head found] (mmap.get bucket-heads key)]
              (when found
                (set! next-indexes[right-row] head))
              (mmap.assoc! bucket-heads key right-row)))
          (dec! right-row)))
      (let [left-row 0]
        (while (< left-row left.typed-rows)
          (let [[key key-ok] (query-relation-row-join-key left left-row common)]
            (when (not key-ok)
              (delete attrs)
              (delete attr-sources)
              (delete tuples)
              (delete bucket-heads)
              (delete next-indexes)
              (delete-relation-columns typed-columns)
              (delete column-sources)
              (return (query-relation-empty) false))
            (let [[head found] (mmap.get bucket-heads key)]
              (when found
                (let [right-index head]
                  (while (>= right-index 0)
                    (when (not (add-query-joined-column-row! (addr typed-columns) (slice column-sources 0) left left-row right right-index))
                      (delete attrs)
                      (delete attr-sources)
                      (delete tuples)
                      (delete bucket-heads)
                      (delete next-indexes)
                      (delete-relation-columns typed-columns)
                      (delete column-sources)
                      (return (query-relation-empty) false))
                    (set! typed-rows (+ typed-rows 1))
                    (set! right-index next-indexes[right-index]))))))
          (set! left-row (+ left-row 1))))
      (delete bucket-heads)
      (delete next-indexes)
      (delete column-sources)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: tuples
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-hash-join-typed-primitive [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, common: []string] -> [rel: Query-Relation, ok: bool]
  (let [[number number-ok] (query-relation-hash-join-typed-number left right common)]
    (when number-ok
      (return number true))
    (delete-query-relation number))
  (let [[leading leading-ok] (query-relation-hash-join-typed-leading-number db sources left right common)]
    (when leading-ok
      (return leading true))
    (delete-query-relation leading))
  (let [[borrowed borrowed-ok] (query-relation-hash-join-typed-borrowed left right common)]
    (when borrowed-ok
      (return borrowed true))
    (delete-query-relation borrowed))
  (let [[left-typed left-ok] (typed-relation-from-query-relation left)]
    (when (not left-ok)
      (return (query-relation-empty) false))
    (defer (delete-typed-relation left-typed))
    (let [[right-typed right-ok] (typed-relation-from-query-relation right)]
      (when (not right-ok)
        (return (query-relation-empty) false))
      (defer (delete-typed-relation right-typed))
      (when (not (typed-relations-compatible-common? left-typed right-typed common))
        (return (query-relation-empty) false))
      (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
            attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
            tuples (make [dynamic]Binding)
            bucket-heads (make (map string int))
            next-indexes (make [dynamic]int right-typed.rows)]
        (arr.fill! next-indexes -1)
        (for [name index right.attrs]
          (when (not (query-relation-has-attr? left name))
            (arr.push! attrs name)
            (arr.push! attr-sources right.attr-sources[index])))
        (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
              [column-sources column-sources-ok] (relation-column-sources-for-join left-typed right-typed (slice attrs 0))
              typed-rows 0]
        (when (not column-sources-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete bucket-heads)
          (delete next-indexes)
          (delete-relation-columns typed-columns)
          (return (query-relation-empty) false))
        (let [right-row (- right-typed.rows 1)]
          (while (>= right-row 0)
            (let [[key key-ok] (typed-relation-row-join-key right-typed right-row common)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (set! next-indexes[right-row] head))
                (mmap.assoc! bucket-heads key right-row)))
            (dec! right-row)))
        (let [left-row 0]
          (while (< left-row left-typed.rows)
            (let [[key key-ok] (typed-relation-row-join-key left-typed left-row common)]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete tuples)
                (delete bucket-heads)
                (delete next-indexes)
                (delete-relation-columns typed-columns)
                (delete column-sources)
                (return (query-relation-empty) false))
              (let [[head found] (mmap.get bucket-heads key)]
                (when found
                  (let [right-index head]
                    (while (>= right-index 0)
                      (when (not (add-typed-joined-column-row! (addr typed-columns) (slice column-sources 0) left-typed left-row right-typed right-index))
                        (delete attrs)
                        (delete attr-sources)
                        (delete tuples)
                        (delete bucket-heads)
                        (delete next-indexes)
                        (delete-relation-columns typed-columns)
                        (delete column-sources)
                        (return (query-relation-empty) false))
                      (set! typed-rows (+ typed-rows 1))
                      (set! right-index next-indexes[right-index]))))))
            (set! left-row (+ left-row 1))))
        (delete bucket-heads)
        (delete next-indexes)
        (delete column-sources)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: tuples
                                 typed-columns: typed-columns
                                 typed-rows: typed-rows
                                 has-typed-columns: true}) true))))))

(defn query-relation-hash-join-primitive [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation, common: []string] -> [rel: Query-Relation, ok: bool]
  (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
        attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
        left-bindings (query-relation-materialized-bindings left)
        right-bindings (query-relation-materialized-bindings right)
        tuples (make [dynamic]Binding)
        bucket-heads (make (map string int))
        next-indexes (make [dynamic]int (count right-bindings))]
    (arr.fill! next-indexes -1)
    (for [name index right.attrs]
      (when (not (query-relation-has-attr? left name))
        (arr.push! attrs name)
        (arr.push! attr-sources right.attr-sources[index])))
    (let [right-index (- (count right-bindings) 1)]
      (while (>= right-index 0)
      (let [right-tuple right-bindings[right-index]
            [key key-ok] (binding-primitive-join-key-many right-tuple common)]
        (when (not key-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete bucket-heads)
          (delete next-indexes)
          (delete left-bindings)
          (delete right-bindings)
          (return (query-relation-empty) false))
        (let [[head found] (mmap.get bucket-heads key)]
          (when found
            (set! next-indexes[right-index] head))
          (mmap.assoc! bucket-heads key right-index)))
      (dec! right-index)))
    (for [left-tuple left-bindings]
      (let [[key key-ok] (binding-primitive-join-key-many left-tuple common)]
        (when (not key-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete bucket-heads)
          (delete next-indexes)
          (delete left-bindings)
          (delete right-bindings)
          (return (query-relation-empty) false))
        (let [[head found] (mmap.get bucket-heads key)]
          (when found
            (let [right-index head]
              (while (>= right-index 0)
                (let [right-tuple right-bindings[right-index]
                      [merged merge-ok] (merge-relation-binding db sources left right left-tuple right-tuple)]
                  (when merge-ok
                    (arr.push! tuples merged)))
                (set! right-index next-indexes[right-index])))))))
    (delete bucket-heads)
    (delete next-indexes)
    (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
      (delete left-bindings)
      (delete right-bindings)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: tuples
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: typed-ok}) true))))

(defn query-relation-empty-typed-join [left: Query-Relation, right: Query-Relation] -> Query-Relation
  (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
        attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))]
    (for [name index right.attrs]
      (when (not (string-slice-contains? (slice attrs 0) name))
        (arr.push! attrs name)
        (arr.push! attr-sources right.attr-sources[index])))
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: (make [dynamic]Binding)
                     typed-columns: (relation-columns-for-attrs (slice attrs 0))
                     typed-rows: 0
                     has-typed-columns: true})))

(defn query-relation-join-provably-empty? [left: Query-Relation, right: Query-Relation, common: []string] -> bool
  (when (not (and left.has-typed-columns right.has-typed-columns))
    (return false))
  (when (or (= left.typed-rows 0)
            (= right.typed-rows 0))
    (return true))
  (for [name common]
    (let [[left-index left-ok] (query-relation-attr-index-lookup left name)
          [right-index right-ok] (query-relation-attr-index-lookup right name)]
      (when (not (and left-ok right-ok))
        (return false))
      (let [left-column left.typed-columns[left-index]
            right-column right.typed-columns[right-index]]
        (when (and left-column.has-kind
                   right-column.has-kind
                   (not (relation-column-kinds-join-compatible? left-column.kind right-column.kind))
                   (not (relation-column-kinds-may-entity-coerce? left-column.kind right-column.kind)))
          (return true)))))
  false)

(defn query-relation-common-raw-key-safe? [left: Query-Relation, right: Query-Relation, common: []string] -> bool
  (when (not (and left.has-typed-columns right.has-typed-columns))
    (return true))
  (for [name common]
    (let [[left-index left-ok] (query-relation-attr-index-lookup left name)
          [right-index right-ok] (query-relation-attr-index-lookup right name)]
      (when (not (and left-ok right-ok))
        (return false))
      (let [left-column left.typed-columns[left-index]
            right-column right.typed-columns[right-index]]
        (when (not (and left-column.has-kind right-column.has-kind))
          (return false))
        (let [left-kind left-column.kind
              right-kind right-column.kind]
          (when (and (not (= left-kind right-kind))
                     (or (= left-kind .Entity)
                         (= right-kind .Entity)))
            (return false))))))
  true)

(defn query-relation-join [db: DB, sources: []DB-Source, left: Query-Relation, right: Query-Relation] -> Query-Relation
  (let [common (relation-common-attrs left right) :defer]
    (when (query-relation-join-provably-empty? left right (slice common 0))
      (return (query-relation-empty-typed-join left right)))
    (when (= (count common) 0)
      (let [[typed-product typed-product-ok] (query-relation-product-typed left right)]
        (when typed-product-ok
          (return typed-product))
        (delete-query-relation typed-product))
      (return (query-relation-product db sources left right)))
    (when (query-relation-common-raw-key-safe? left right (slice common 0))
      (let [[typed-hash-joined typed-hash-ok] (query-relation-hash-join-typed-primitive db sources left right (slice common 0))]
        (when typed-hash-ok
          (return typed-hash-joined))
        (delete-query-relation typed-hash-joined))
      (let [[hash-joined hash-ok] (query-relation-hash-join-primitive db sources left right (slice common 0))]
        (when hash-ok
          (return hash-joined))
        (delete-query-relation hash-joined)))
    (let [attrs (arr.into [dynamic]string (slice left.attrs 0))
          attr-sources (arr.into [dynamic]string (slice left.attr-sources 0))
          left-bindings (query-relation-materialized-bindings left)
          right-bindings (query-relation-materialized-bindings right)
          tuples (make [dynamic]Binding)]
      (for [name index right.attrs]
        (when (not (query-relation-has-attr? left name))
          (arr.push! attrs name)
          (arr.push! attr-sources right.attr-sources[index])))
      (for [left-tuple left-bindings]
        (for [right-tuple right-bindings]
          (when (binding-agrees-on-attrs? db sources left right left-tuple right-tuple (slice common 0))
            (let [[merged ok] (merge-relation-binding db sources left right left-tuple right-tuple)]
              (when ok
                (arr.push! tuples merged))))))
      (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
        (delete left-bindings)
        (delete right-bindings)
        (Query-Relation {attrs: attrs
                         attr-sources: attr-sources
                         attr-index: (query-relation-attr-index (slice attrs 0))
                         tuples: tuples
                         typed-columns: typed-columns
                         typed-rows: typed-rows
                         has-typed-columns: typed-ok})))))

(defn query-context-singleton [] -> Query-Context
  (let [rels (make [dynamic]Query-Relation)]
    (arr.push! rels (query-relation-singleton))
    (Query-Context {rels: rels})))

(defn delete-query-context [ctx: Query-Context]
  (for [rel ctx.rels]
    (delete-query-relation rel))
  (delete ctx.rels))

(defn delete-pull-attrs-shallow [attrs: [dynamic]Pull-Attr]
  (for [pulled attrs]
    (delete-pull-attrs-shallow pulled.attrs))
  (delete attrs))

(defn delete-pull-attrs-owned-values [attrs: [dynamic]Pull-Attr]
  (for [pulled attrs]
    (when pulled.a-owned
      (delete pulled.a))
    (delete-owned-value pulled.v)
    (delete-pull-attrs-owned-values pulled.attrs))
  (delete attrs))

(defn delete-pull-attr-shallow-owned-key [pulled: Pull-Attr]
  (when pulled.a-owned
    (delete pulled.a))
  (for [child pulled.attrs]
    (delete-pull-attr-shallow-owned-key child))
  (delete pulled.attrs))

(defn delete-pull-attr-owned-values [pulled: Pull-Attr]
  (when pulled.a-owned
    (delete pulled.a))
  (delete-owned-value pulled.v)
  (for [child pulled.attrs]
    (delete-pull-attr-owned-values child))
  (delete pulled.attrs))

(defn delete-pull-result-shallow [result: Pull-Result]
  (delete-pull-attrs-shallow result.attrs))

(defn delete-pull-result-owned-values [result: Pull-Result]
  (delete-pull-attrs-owned-values result.attrs))

(defn delete-result-rows-shallow [rows: [dynamic]Result-Row]
  (for [row rows]
    (delete row.values)
    (for [pull row.pulls]
      (delete-pull-result-shallow pull))
    (delete row.pulls))
  (delete rows))

(defn delete-result-set-shallow [result: Result-Set]
  (delete-result-rows-shallow result.rows))

(defn delete-result-rows-owned-values [rows: [dynamic]Result-Row]
  (for [row rows]
    (for [value row.values]
      (delete-owned-value value))
    (delete row.values)
    (for [pull row.pulls]
      (delete-pull-result-owned-values pull))
    (delete row.pulls))
  (delete rows))

(defn delete-result-set-owned-values [result: Result-Set]
  (delete-result-rows-owned-values result.rows))

(defn pull-attr-owned [pulled: Pull-Attr] -> Pull-Attr
  (let [children (make [dynamic]Pull-Attr 0 (count pulled.attrs))]
    (for [child pulled.attrs]
      (arr.push! children (pull-attr-owned child)))
    (Pull-Attr {a: (string-owned pulled.a)
                a-owned: true
                key-kind: pulled.key-kind
                v: (value-owned pulled.v)
                attrs: children
                has-explicit-pattern: pulled.has-explicit-pattern})))

(defn pull-result-owned [result: Pull-Result] -> Pull-Result
  (let [attrs (make [dynamic]Pull-Attr 0 (count result.attrs))]
    (for [pulled result.attrs]
      (arr.push! attrs (pull-attr-owned pulled)))
    (Pull-Result {e: result.e attrs: attrs})))

(defn result-row-owned [row: Result-Row] -> Result-Row
  (let [values (make [dynamic]Value 0 (count row.values))
        pulls (make [dynamic]Pull-Result 0 (count row.pulls))]
    (for [value row.values]
      (arr.push! values (value-owned value)))
    (for [pull row.pulls]
      (arr.push! pulls (pull-result-owned pull)))
    (Result-Row {values: values pulls: pulls})))

(defn result-set-owned [result: Result-Set] -> Result-Set
  (let [rows (make [dynamic]Result-Row 0 (count result.rows))]
    (for [row result.rows]
      (arr.push! rows (result-row-owned row)))
    (Result-Set {ok: result.ok error: result.error rows: rows})))

(defn query-result-shallow [result: Result-Set] -> Query-Result
  (Query-Result {result: result ownsValues: false}))

(defn query-result-owned-values [result: Result-Set] -> Query-Result
  (Query-Result {result: result ownsValues: true}))

(defn query-result-owns-values? [result: Query-Result] -> bool
  result.ownsValues)

(defn delete-query-result [result: Query-Result]
  (if (query-result-owns-values? result)
    (delete-result-set-owned-values result.result)
    (delete-result-set-shallow result.result)))

(defn delete-profiled-result-set-shallow [profiled: Profiled-Result-Set]
  (delete-result-set-shallow profiled.result))

(defn delete-profiled-result-set-owned-values [profiled: Profiled-Result-Set]
  (delete-result-set-owned-values profiled.result))

(defn lookup-ref-value [attr: string, value: Value] -> Value
  (value-vector2 (value-keyword attr) value))

(defn lookup-ref-value-owned [attr: string, value: Value] -> Value
  (let [items (make [dynamic]Value 0 2)]
    (arr.push! items (value-keyword (string-owned attr)))
    (arr.push! items (value-owned value))
    (value-vector-owned items)))

(defn value-lookup-ref-parts [value: Value] -> [attr: string, lookup-value: Value, ok: bool]
  (when (and (= value.kind .Vector)
             (= (count value.items) 2)
             (= value.items[0].kind .Keyword))
    (return value.items[0].text value.items[1] true))
  (return "" (Value {}) false))

(defn value-as-entity [db: DB, value: Value] -> [entity: Value, ok: bool]
  (cond
    (= value.kind .Entity)
      (return value true)
    (= value.kind .Int)
      (return (value-entity (u64 value.int-value)) true)
    (= value.kind .Keyword)
      (let [[entity found] (schema-entity-for-attr db value.text)]
        (if found
          (return (value-entity entity) true)
          (return (Value {}) false)))
    :else
      (let [[attr lookup-value lookup-ok] (value-lookup-ref-parts value)]
        (when lookup-ok
          (let [[entity found] (resolve-lookup-ref db attr lookup-value)]
            (if found
              (return (value-entity entity) true)
              (return (Value {}) false))))
        (return (Value {}) false))))

(defn lookup-ref-value-as-entity [db: DB, value: Value] -> [entity: Value, ok: bool]
  (let [[attr lookup-value lookup-ok] (value-lookup-ref-parts value)]
    (when lookup-ok
      (let [[entity found] (resolve-lookup-ref db attr lookup-value)]
        (if found
          (return (value-entity entity) true)
          (return (Value {}) false)))))
  (return (Value {}) false))

(defn entity-value-equal? [db: DB, left: Value, right: Value] -> bool
  (when (predicate-value-equal? left right)
    (return true))
  (let [[left-entity left-ok] (value-as-entity db left)]
    (when left-ok
      (return (predicate-value-equal? left-entity right))))
  (let [[right-entity right-ok] (value-as-entity db right)]
    (when right-ok
      (return (predicate-value-equal? left right-entity))))
  false)

(defn value-as-entity-id [value: Value] -> [entity: Value, ok: bool]
  (case value.kind
    .Entity (return value true)
    .Int (return (value-entity (u64 value.int-value)) true)
     (return (Value {}) false)))

(defn entity-id-value-equal? [left: Value, right: Value] -> bool
  (when (predicate-value-equal? left right)
    (return true))
  (let [[left-entity left-ok] (value-as-entity-id left)]
    (when left-ok
      (return (predicate-value-equal? left-entity right))))
  (let [[right-entity right-ok] (value-as-entity-id right)]
    (when right-ok
      (return (predicate-value-equal? left right-entity))))
  false)

(defn clause-value-equal? [db: DB, attr: string, expected: Value, actual: Value] -> bool
  (when (predicate-value-equal? expected actual)
    (return true))
  (when (schema-ref? db attr)
    (let [[resolved resolved-ok] (ref-entity-literal db attr expected)]
      (when resolved-ok
        (return (predicate-value-equal? resolved actual)))))
  false)

(defn pull-pattern-input-value [pattern: []Pull-Spec] -> Value
  (let [items (make [dynamic]Value 0 (count pattern)) :defer]
    (for [spec pattern]
      (arr.push! items (value-keyword spec.a)))
    (value-vector (slice items 0))))

(defn query-input-scalar-value [db: DB, input: Query-Input] -> [value: Value, ok: bool]
  (when (= input.kind .PullPattern)
    (return (pull-pattern-input-value (slice input.pattern 0)) true))
  (when input.has-lookup-ref
    (let [[_ lookup-ok] (resolve-lookup-ref db input.lookup-attr input.lookup-value)]
      (if lookup-ok
        (return (lookup-ref-value input.lookup-attr input.lookup-value) true)
        (return (Value {}) false))))
  (return input.value true))

(defn primary-relation-db-source-name [] -> string
  "__vev_primary_relation_db")

(defn query-source-input-name? [name: string] -> bool
  (or (strings.has_prefix name "$")
      (= name (primary-relation-db-source-name))))

(defn query-input-relation-source-vector [input: Query-Input] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Relation)
               (> input.width 0))
      (let [row_count (/ (count input.values) input.width)]
        (for [row 0..<row_count]
          (let [items (make [dynamic]Value)
                offset (* row input.width)]
            (for [index 0..<input.width]
              (arr.push! items input.values[(+ offset index)]))
            (arr.push! rows (value-vector (slice items 0)))))))
    (value-vector (slice rows 0))))

(defn query-input-source-value [input: Query-Input] -> [value: Value, ok: bool]
  (cond
    (= input.kind .Relation)
      (return (query-input-relation-source-vector input) true)
    (= input.kind .Collection)
      (return (value-vector input.values) true)
    (and (= input.kind .Scalar)
         (= input.value.kind .Map))
      (return (query-input-map-as-relation-vector input) true)
    (and (= input.kind .Scalar)
         (or (= input.value.kind .Vector)
             (= input.value.kind .Set)))
      (return input.value true)
    :else (return (Value {}) false)))

(defn query-input-source-value-owned [input: Query-Input] -> [value: Value, ok: bool]
  (cond
    (= input.kind .Relation)
      (let [rows (make [dynamic]Value)]
        (when (> input.width 0)
          (let [row_count (/ (count input.values) input.width)]
            (for [row 0..<row_count]
              (let [items (make [dynamic]Value 0 input.width)
                    offset (* row input.width)]
                (for [index 0..<input.width]
                  (arr.push! items (value-owned input.values[(+ offset index)])))
                (arr.push! rows (value-vector-owned items))))))
        (return (value-vector-owned rows) true))
    (= input.kind .Collection)
      (let [items (make [dynamic]Value 0 (count input.values))]
        (for [value input.values]
          (arr.push! items (value-owned value)))
        (return (value-vector-owned items) true))
    (and (= input.kind .Scalar)
         (= input.value.kind .Map))
      (let [rows (make [dynamic]Value 0 (/ (count input.value.items) 2))
            row_count (/ (count input.value.items) 2)]
        (for [row 0..<row_count]
          (let [offset (* row 2)
                items (make [dynamic]Value 0 2)]
            (arr.push! items (value-owned input.value.items[offset]))
            (arr.push! items (value-owned input.value.items[(+ offset 1)]))
            (arr.push! rows (value-vector-owned items))))
        (return (value-vector-owned rows) true))
    (and (= input.kind .Scalar)
         (or (= input.value.kind .Vector)
             (= input.value.kind .Set)))
      (return (value-owned input.value) true)
    :else (return (Value {}) false)))

(defn query-input-bound-value [db: DB, name: string, input: Query-Input] -> [value: Value, ok: bool]
  (when (query-source-input-name? name)
    (return (query-input-source-value input)))
  (when (or (= input.kind .Scalar)
            (= input.kind .PullPattern))
    (return (query-input-scalar-value db input)))
  (return (Value {}) false))

(defn db-read-source-query-input-scalar-value [source: DB-Read-Source, input: Query-Input] -> [value: Value, ok: bool, error: string]
  (when (= input.kind .PullPattern)
    (return (pull-pattern-input-value (slice input.pattern 0)) true ""))
  (when input.has-lookup-ref
    (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source input.lookup-attr input.lookup-value)]
      (if entity-ok
        (return (lookup-ref-value input.lookup-attr input.lookup-value) true "")
        (return (Value {}) false lookup-error))))
  (when (= input.kind .Scalar)
    (return input.value true ""))
  (return (Value {}) false "cannot bind non-scalar query input"))

(defn db-read-source-query-input-bound-value [source: DB-Read-Source, name: string, input: Query-Input] -> [value: Value, ok: bool, error: string]
  (when (query-source-input-name? name)
    (let [[source-value source-ok] (query-input-source-value input)]
      (if source-ok
        (return source-value true "")
        (return (Value {}) false "cannot bind query input as source"))))
  (when (or (= input.kind .Scalar)
            (= input.kind .PullPattern))
    (return (db-read-source-query-input-scalar-value source input)))
  (return (Value {}) false "cannot bind query input"))

(defn query-source-input-value? [input: Query-Input] -> bool
  (cond
    (= input.kind .Relation) true
    (= input.kind .Collection) true
    (and (= input.kind .Scalar)
         (= input.value.kind .Vector)) true
    (and (= input.kind .Scalar)
         (= input.value.kind .Set)) true
    (and (= input.kind .Scalar)
         (= input.value.kind .Map)) true
    :else false))

(defn binding-from-inputs [db: DB, names: []string, values: []Query-Input] -> [bindings: [dynamic]Binding]
  (let [binding (Binding {})
        out (make [dynamic]Binding)]
    (for [name index names]
      (when (< index (count values))
        (let [[value ok] (query-input-bound-value db name values[index])]
          (if ok
            (binding-store! (addr binding) name value)
            (return out)))))
    (arr.push! out binding)
    out))

(defn expand-scalar-input [db: DB, bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (let [[value ok] (query-input-bound-value db name input)]
      (when ok
        (for [binding bindings]
          (let [next (clone-binding binding)]
            (binding-store! (addr next) name value)
            (arr.push! out next)))))
    out))

(defn expand-collection-input [bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .Collection)
      (for [binding bindings]
        (for [value input.values]
          (let [next (clone-binding binding)]
            (binding-store! (addr next) name value)
            (arr.push! out next)))))
    out))

(defn expand-collection-lookup-ref-input [db: DB, bindings: []Binding, name: string, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (= input.kind .CollectionLookupRefs)
      (for [binding bindings]
        (for [value index input.lookup-values]
          (let [attr input.lookup-attrs[index]
                [_ ok] (resolve-lookup-ref db attr value)]
            (when ok
              (let [next (clone-binding binding)]
                (binding-store! (addr next) name (lookup-ref-value attr value))
                (arr.push! out next)))))))
    out))

(defn bind-input-pattern [binding: Binding, pattern: Input-Binding, value: Value] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (case pattern.kind
      .Ignore (arr.push! out (clone-binding binding))
      .Var (let [[next ok] (binding-with-value binding pattern.name value)]
             (when ok
               (arr.push! out next)))
      .Tuple (when (and (= value.kind .Vector)
                        (= (count pattern.items) (count value.items)))
               (let [current (make [dynamic]Binding)]
                 (arr.push! current (clone-binding binding))
                 (for [item index pattern.items]
                   (let [next-current (make [dynamic]Binding)]
                     (for [candidate current]
                       (let [bound (bind-input-pattern candidate item value.items[index])]
                         (for [bound-item bound]
                           (arr.push! next-current bound-item))))
                     (delete current)
                     (set! current next-current)))
                 (for [candidate current]
                   (arr.push! out candidate))))
      .Collection (when (and (or (= value.kind .Vector)
                                 (= value.kind .Set))
                             (= (count pattern.items) 1))
                    (for [item value.items]
                      (let [bound (bind-input-pattern binding pattern.items[0] item)]
                        (for [bound-item bound]
                          (arr.push! out bound-item)))))
       (do))
    out))

(defn query-input-relation-as-vector [input: Query-Input, width: int] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Relation)
               (= input.width width)
               (> width 0))
      (let [row_count (/ (count input.values) width)]
        (for [row 0..<row_count]
          (let [items (make [dynamic]Value)
                offset (* row width)]
            (for [index 0..<width]
              (arr.push! items input.values[(+ offset index)]))
            (arr.push! rows (value-vector (slice items 0)))))))
    (value-vector (slice rows 0))))

(defn query-input-map-as-relation-vector [input: Query-Input] -> Value
  (let [rows (make [dynamic]Value)]
    (when (and (= input.kind .Scalar)
               (= input.value.kind .Map))
      (let [row_count (/ (count input.value.items) 2)]
        (for [row 0..<row_count]
          (let [offset (* row 2)]
            (arr.push! rows
              (value-vector
                ([]Value [input.value.items[offset]
                          input.value.items[(+ offset 1)]])))))))
    (value-vector (slice rows 0))))

(defn expand-tuple-input [bindings: []Binding, tuple: Tuple-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (not (= tuple.binding.kind .None))
      (let [tuple-value (value-vector (slice input.values 0))]
        (for [binding bindings]
          (let [bound (bind-input-pattern binding tuple.binding tuple-value)]
            (for [item bound]
              (arr.push! out item)))))
      (return out))
    (when (= (count tuple.vars) (count input.values))
      (for [binding bindings]
        (let [next (clone-binding binding)]
          (for [name index tuple.vars]
            (when (not (= name ""))
              (binding-store! (addr next) name input.values[index])))
          (arr.push! out next))))
    out))

(defn expand-relation-input [bindings: []Binding, relation: Relation-Input, input: Query-Input] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        width (count relation.vars)]
    (when (not (= relation.binding.kind .None))
      (let [relation-value (cond
                             (= input.kind .Collection) (value-vector (slice input.values 0))
                             (= input.kind .Relation) (query-input-relation-as-vector input width)
                             (and (= input.kind .Scalar) (= input.value.kind .Map)) (query-input-map-as-relation-vector input)
                             :else (Value {}))]
        (when (= relation-value.kind .Vector)
          (for [binding bindings]
            (let [bound (bind-input-pattern binding relation.binding relation-value)]
              (for [item bound]
                (arr.push! out item))))))
      (return out))
    (when (and (= input.kind .Relation)
               (= input.width width))
      (let [row_count (/ (count input.values) width)]
        (for [binding bindings]
          (for [row 0..<row_count]
            (let [next (clone-binding binding)
                  offset (* row width)]
              (for [name index relation.vars]
                (when (not (= name ""))
                  (binding-store! (addr next) name input.values[(+ offset index)])))
              (arr.push! out next))))))
    (when (and (= input.kind .Scalar)
               (= input.value.kind .Map)
               (= width 2))
      (let [row_count (/ (count input.value.items) 2)]
        (for [binding bindings]
          (for [row 0..<row_count]
            (let [next (clone-binding binding)
                  offset (* row 2)]
              (when (not (= relation.vars[0] ""))
                (binding-store! (addr next) relation.vars[0] input.value.items[offset]))
              (when (not (= relation.vars[1] ""))
                (binding-store! (addr next) relation.vars[1] input.value.items[(+ offset 1)]))
              (arr.push! out next))))))
    out))

(defn bindings-from-inputs-in-order [db: DB, query: Query, inputs: []Query-Input] -> [dynamic]Binding
  (let [binding (Binding {})
        bindings (make [dynamic]Binding)]
    (arr.push! bindings binding)
    (for [spec index query.input-specs]
      (when (< index (count inputs))
        (let [next-bindings (make [dynamic]Binding)]
          (cond
            (= spec.kind .Scalar)
              (set! next-bindings (expand-scalar-input db (slice bindings 0) spec.name inputs[index]))
            (= spec.kind .Collection)
              (if (= inputs[index].kind .CollectionLookupRefs)
                (set! next-bindings (expand-collection-lookup-ref-input db (slice bindings 0) spec.name inputs[index]))
                (set! next-bindings (expand-collection-input (slice bindings 0) spec.name inputs[index])))
            (= spec.kind .Tuple)
              (set! next-bindings (expand-tuple-input (slice bindings 0) spec.tuple inputs[index]))
            (= spec.kind .Relation)
              (set! next-bindings (expand-relation-input (slice bindings 0) spec.relation inputs[index]))
            (= spec.kind .Ignore)
              (set! next-bindings (clone-bindings (slice bindings 0))))
          (delete bindings)
          (set! bindings next-bindings))))
    bindings))

(defn bindings-from-inputs [db: DB, query: Query, inputs: []Query-Input] -> [dynamic]Binding
  (when (> (count query.input-specs) 0)
    (return (bindings-from-inputs-in-order db query inputs)))
  (let [bindings (binding-from-inputs db (slice query.inputs 0) inputs)
        collection-offset (count query.inputs)
        tuple-offset (+ collection-offset (count query.collection-inputs))
        relation-offset (+ tuple-offset (count query.tuple-inputs))]
    (for [name index query.collection-inputs]
      (let [input-index (+ collection-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (make [dynamic]Binding)]
            (if (= inputs[input-index].kind .CollectionLookupRefs)
              (set! next-bindings (expand-collection-lookup-ref-input db (slice bindings 0) name inputs[input-index]))
              (set! next-bindings (expand-collection-input (slice bindings 0) name inputs[input-index])))
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [tuple index query.tuple-inputs]
      (let [input-index (+ tuple-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-tuple-input (slice bindings 0) tuple inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    (for [relation index query.relation-inputs]
      (let [input-index (+ relation-offset index)]
        (when (< input-index (count inputs))
          (let [next-bindings (expand-relation-input (slice bindings 0) relation inputs[input-index])]
            (delete bindings)
            (set! bindings next-bindings)))))
    bindings))

(defn query-relation-append-initial-input-values! [attrs: ^[dynamic]string, attr-sources: ^[dynamic]string, columns: ^[dynamic]Relation-Column, row-count: ^int, name: string, values: []Value] -> bool
  (when (or (query-source-input-name? name)
            (string-slice-contains? (slice attrs^ 0) name))
    (return false))
  (let [existing-rows row-count^
        value-count (count values)]
    (when (= value-count 0)
      (when (or (> existing-rows 1)
                (> (count columns^) 0))
        (return false)))
    (when (and (> value-count 1)
               (> existing-rows 1))
      (return false))
    (when (and (> value-count 1)
               (= existing-rows 1))
      (for [column index columns^]
        (let [[existing-value existing-ok] (typed-relation-column-value column 0)]
          (when (not existing-ok)
            (return false))
          (let [repeat-index 1]
            (while (< repeat-index value-count)
              (when (not (relation-column-add! (addr columns^[index]) existing-value))
                (return false))
              (set! repeat-index (+ repeat-index 1)))))))
    (let [input-column (relation-column-empty)]
      (let [row 0]
      (while (< row existing-rows)
        (for [value values]
          (when (not (relation-column-add! (addr input-column) value))
            (delete-relation-column input-column)
            (return false)))
        (set! row (+ row 1))))
      (arr.push! columns^ input-column))
    (arr.push! attrs^ name)
    (arr.push! attr-sources^ "")
    (set! row-count^ (* existing-rows (count values)))
    true))

(defn query-relation-append-initial-input-rows! [attrs: ^[dynamic]string, attr-sources: ^[dynamic]string, columns: ^[dynamic]Relation-Column, row-count: ^int, input-attrs: []string, values: []Value, width: int] -> bool
  (when (<= width 0)
    (return false))
  (when (not (= (% (count values) width) 0))
    (return false))
  (let [kept-attrs (make [dynamic]string) :defer]
    (for [name input-attrs]
      (when (not (= name ""))
        (when (or (query-source-input-name? name)
                  (string-slice-contains? (slice attrs^ 0) name)
                  (string-slice-contains? (slice kept-attrs 0) name))
          (return false))
        (arr.push! kept-attrs name)))
    (when (= (count kept-attrs) 0)
      (set! row-count^ (* row-count^ (/ (count values) width)))
      (return true))
    (let [old-attrs (arr.into [dynamic]string (slice attrs^ 0)) :defer
          old-sources (arr.into [dynamic]string (slice attr-sources^ 0)) :defer
          old-columns (clone-relation-columns (slice columns^ 0)) :defer
          old-row-count row-count^
          input-row-count (/ (count values) width)
          next-attrs (make [dynamic]string 0 (+ (count old-attrs) (count kept-attrs)))
          next-sources (make [dynamic]string 0 (+ (count old-sources) (count kept-attrs)))
          next-columns (make [dynamic]Relation-Column 0 (+ (count old-columns) (count kept-attrs)))]
      (for [name old-attrs]
        (arr.push! next-attrs name)
        (arr.push! next-columns (relation-column-empty)))
      (for [source old-sources]
        (arr.push! next-sources source))
      (for [name kept-attrs]
        (arr.push! next-attrs name)
        (arr.push! next-sources "")
        (arr.push! next-columns (relation-column-empty)))
      (let [old-row 0]
        (while (< old-row old-row-count)
          (let [input-row 0]
            (while (< input-row input-row-count)
              (let [row-values (make [dynamic]Value 0 (count next-columns)) :defer]
                (for [column old-columns]
                  (let [[value value-ok] (typed-relation-column-value column old-row)]
                    (when (not value-ok)
                      (delete next-attrs)
                      (delete next-sources)
                      (delete-relation-columns next-columns)
                      (return false))
                    (arr.push! row-values value)))
                (let [offset (* input-row width)]
                  (for [name index input-attrs]
                    (when (not (= name ""))
                      (arr.push! row-values values[(+ offset index)]))))
                (for [value column-index row-values]
                  (when (not (relation-column-add! (addr next-columns[column-index]) value))
                    (delete next-attrs)
                    (delete next-sources)
                    (delete-relation-columns next-columns)
                    (return false))))
            (set! input-row (+ input-row 1))))
          (set! old-row (+ old-row 1))))
      (delete attrs^)
      (delete attr-sources^)
      (delete-relation-columns columns^)
      (set! attrs^ next-attrs)
      (set! attr-sources^ next-sources)
      (set! columns^ next-columns)
      (set! row-count^ (* old-row-count input-row-count))
      true)))

(defn direct-row-input-binding? [binding: Input-Binding] -> bool
  (when (= binding.kind .None)
    (return true))
  (when (not (= binding.kind .Tuple))
    (return false))
  (for [item binding.items]
    (when (not (or (= item.kind .Var)
                   (= item.kind .Ignore)))
      (return false)))
  true)

(defn direct-relation-input-binding? [binding: Input-Binding] -> bool
  (when (= binding.kind .None)
    (return true))
  (and (= binding.kind .Collection)
       (= (count binding.items) 1)
       (direct-row-input-binding? binding.items[0])))

(defn query-relation-from-ordered-simple-inputs [db: DB, query: Query, inputs: []Query-Input] -> [rel: Query-Relation, binding-count: int, ok: bool]
  (when (= (count query.input-specs) 0)
    (return (query-relation-empty) 0 false))
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        columns (make [dynamic]Relation-Column)
        row-count 1]
    (for [spec index query.input-specs]
      (when (>= index (count inputs))
        (delete attrs)
        (delete attr-sources)
        (delete-relation-columns columns)
        (return (query-relation-empty) 0 false))
      (cond
        (= spec.kind .Ignore)
          (discard spec)
        (= spec.kind .Scalar)
          (if (query-source-input-name? spec.name)
            (discard spec)
            (let [[value value-ok] (query-input-bound-value db spec.name inputs[index])]
              (when (or (not value-ok)
                        (not (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.name ([]Value [value]))))
                (delete attrs)
                (delete attr-sources)
                (delete-relation-columns columns)
                (return (query-relation-empty) 0 false))))
        (= spec.kind .Collection)
          (do
            (when (not (= inputs[index].kind .Collection))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false))
            (when (not (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.name inputs[index].values))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false)))
        (= spec.kind .Tuple)
          (do
            (when (or (not (direct-row-input-binding? spec.tuple.binding))
                      (not (= inputs[index].kind .Collection))
                      (not (= (count spec.tuple.vars) (count inputs[index].values)))
                      (not (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.tuple.vars inputs[index].values (count spec.tuple.vars))))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false)))
        (= spec.kind .Relation)
          (do
            (when (or (not (direct-relation-input-binding? spec.relation.binding))
                      (not (cond
                         (and (= inputs[index].kind .Relation)
                              (= inputs[index].width (count spec.relation.vars)))
                           (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.relation.vars inputs[index].values inputs[index].width)
                         (and (= inputs[index].kind .Scalar)
                              (= inputs[index].value.kind .Map)
                              (= (count spec.relation.vars) 2))
                           (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.relation.vars inputs[index].value.items 2)
                         :else false)))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false)))
        :else
          (do
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: row-count
                             has-typed-columns: true}) row-count true)))

(defn query-relation-from-legacy-simple-inputs [db: DB, query: Query, inputs: []Query-Input] -> [rel: Query-Relation, binding-count: int, ok: bool]
  (when (> (count query.input-specs) 0)
    (return (query-relation-empty) 0 false))
  (when (and (= (count query.inputs) 0)
             (= (count query.collection-inputs) 0)
             (= (count query.tuple-inputs) 0)
             (= (count query.relation-inputs) 0))
    (return (query-relation-singleton) 1 true))
  (when (< (count inputs) (+ (count query.inputs) (count query.collection-inputs)))
    (return (query-relation-empty) 0 false))
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        columns (make [dynamic]Relation-Column)
        row-count 1]
    (for [name index query.inputs]
      (when (not (query-source-input-name? name))
        (let [[value value-ok] (query-input-bound-value db name inputs[index])]
          (when (or (not value-ok)
                    (not (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) name ([]Value [value]))))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false)))))
    (let [collection-offset (count query.inputs)]
      (for [name index query.collection-inputs]
        (let [input-index (+ collection-offset index)]
          (when (not (= inputs[input-index].kind .Collection))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false))
          (when (not (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) name inputs[input-index].values))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false)))))
    (let [tuple-offset (+ (count query.inputs) (count query.collection-inputs))]
      (for [tuple index query.tuple-inputs]
        (let [input-index (+ tuple-offset index)]
          (when (or (>= input-index (count inputs))
                    (not (= inputs[input-index].kind .Collection))
                    (not (= (count tuple.vars) (count inputs[input-index].values)))
                    (not (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) tuple.vars inputs[input-index].values (count tuple.vars))))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false)))))
    (let [relation-offset (+ (count query.inputs) (count query.collection-inputs) (count query.tuple-inputs))]
      (for [relation index query.relation-inputs]
        (let [input-index (+ relation-offset index)]
          (when (or (>= input-index (count inputs))
                    (not (cond
                           (and (= inputs[input-index].kind .Relation)
                                (= inputs[input-index].width (count relation.vars)))
                             (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) relation.vars inputs[input-index].values inputs[input-index].width)
                           (and (= inputs[input-index].kind .Scalar)
                                (= inputs[input-index].value.kind .Map)
                                (= (count relation.vars) 2))
                             (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) relation.vars inputs[input-index].value.items 2)
                           :else false)))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false)))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: row-count
                             has-typed-columns: true}) row-count true)))

(defn query-relation-initial-from-inputs [db: DB, query: Query, inputs: []Query-Input] -> [rel: Query-Relation, binding-count: int]
  (let [[ordered ordered-count ordered-ok] (query-relation-from-ordered-simple-inputs db query inputs)]
    (when ordered-ok
      (return ordered ordered-count))
    (delete-query-relation ordered))
  (let [[legacy legacy-count legacy-ok] (query-relation-from-legacy-simple-inputs db query inputs)]
    (when legacy-ok
      (return legacy legacy-count))
    (delete-query-relation legacy))
  (let [input-bindings (bindings-from-inputs db query inputs)
        out-count (count input-bindings)
        out (query-relation-from-bindings (slice input-bindings 0))]
    (delete input-bindings)
    (return out out-count)))

(defn match-term? [term: Term, actual: Value, binding: ^Binding] -> bool
  (case term.kind
    .Value (value-equal? term.value actual)
    .Wildcard true
    .Var (let [[existing ok] (binding-lookup binding^ term.name)]
           (if ok
             (predicate-value-equal? existing actual)
             (do
               (binding-store! binding term.name actual)
               true)))
     false))

(defn resolve-term [term: Term, binding: Binding] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (binding-lookup binding term.name))
     (return (Value {}) false)))

(defn resolve-entity-term [db: DB, term: Term, binding: Binding] -> [value: Value, ok: bool]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
      (return (value-entity entity) lookup-ok)))
  (let [[resolved resolved-ok] (resolve-term term binding)]
    (when (not resolved-ok)
      (return resolved false))
    (let [[entity entity-ok] (value-as-entity db resolved)]
      (when entity-ok
        (return entity true)))
    (when (= resolved.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db resolved.text)]
        (return (value-entity entity) ident-ok)))
    (when (= resolved.kind .Int)
      (return (value-entity (u64 resolved.int-value)) true))
    (return resolved true)))

(defn predicate-pair-matches? [op: string, left: Value, right: Value] -> bool
  (cond
    (= op "=") (predicate-value-equal? left right)
    (or (= op "!=") (= op "not=")) (not (predicate-value-equal? left right))
    (or (= op "contains?") (= op "clojure.string/includes?"))
      (and (= left.kind .String)
           (= right.kind .String)
           (strings.contains left.text right.text))
    (= op "clojure.string/starts-with?")
      (and (= left.kind .String)
           (= right.kind .String)
           (strings.has_prefix left.text right.text))
    (= op "clojure.string/ends-with?")
      (and (= left.kind .String)
           (= right.kind .String)
           (strings.has_suffix left.text right.text))
    (= op ">") (value-less? right left)
    (= op "<") (value-less? left right)
    (= op ">=") (not (value-less? left right))
    (= op "<=") (not (value-less? right left))
    :else false))

(defn query-var-name? [name: string] -> bool
  (strings.has_prefix name "?"))

(defn query-op-value-name [value: Value] -> [name: string, ok: bool]
  (when (= value.kind .Keyword)
    (if (strings.has_prefix value.text ":")
      (return (slice value.text 1) true)
      (return value.text true)))
  (when (= value.kind .String)
    (return value.text true))
  (return "" false))

(defn query-op-name [op: string, binding: Binding] -> [name: string, ok: bool]
  (when (not (query-var-name? op))
    (return op true))
  (let [[value value-ok] (binding-lookup binding op)]
    (when (not value-ok)
      (return "" false))
    (query-op-value-name value)))

(defn query-fn [name: string, target: string] -> Native-Query-Fn
  (Native-Query-Fn {name: name target: target}))

(defn query-predicate-fn [name: string, f: fn [args: []Value] -> bool] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-predicate-callback: true predicate-callback: f}))

(defn query-db-predicate-fn [name: string, f: fn [db: DB, args: []Value] -> bool] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-db-predicate-callback: true db-predicate-callback: f}))

(defn native-query-function-result [value: Value] -> Native-Query-Function-Result
  (Native-Query-Function-Result {ok: true value: value}))

(defn native-query-function-none [] -> Native-Query-Function-Result
  (Native-Query-Function-Result {ok: false}))

(defn query-value-fn [name: string, f: fn [args: []Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-function-callback: true function-callback: f}))

(defn query-aggregate-fn [name: string, f: fn [values: []Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-aggregate-callback: true aggregate-callback: f}))

(defn pull-xform-fn [name: string, f: fn [value: Value] -> Native-Query-Function-Result] -> Native-Query-Fn
  (Native-Query-Fn {name: name has-pull-xform-callback: true pull-xform-callback: f}))

(defn query-fn-index [registry: []Native-Query-Fn, name: string] -> [index: int, ok: bool]
  (for [entry index registry]
    (when (= entry.name name)
      (return index true)))
  (return 0 false))

(defn query-fn-supported? [registry: []Native-Query-Fn, op: string] -> bool
  (when (query-var-name? op)
    (return true))
  (let [[_ ok] (query-fn-index registry op)]
    ok))

(defn query-fn-target [registry: []Native-Query-Fn, op: string] -> [target: string, ok: bool]
  (let [[index found] (query-fn-index registry op)]
    (when (not found)
      (return "" false))
    (return registry[index].target true)))

(defn resolve-query-call-args [terms: []Term, binding: Binding] -> [out: [dynamic]Value, ok: bool]
  (let [args (make [dynamic]Value 0 (count terms))]
    (for [term terms]
      (let [[value value-ok] (resolve-term term binding)]
        (when (not value-ok)
          (return args false))
        (arr.push! args value)))
    (return args true)))

(defn re-find-matches? [pattern: Value, text: Value] -> bool
  (when (not (and (= pattern.kind .String)
                  (= text.kind .String)))
    (return false))
  (let [[iter err] (regex.create_iterator text.text pattern.text)]
    (when (!= err nil)
      (return false))
    (defer (regex.destroy iter))
    (let [[_ _ ok] (regex.match (addr iter))]
      ok)))

(defn re-find-value [pattern: Value, text: Value] -> [value: Value, ok: bool]
  (when (not (and (= pattern.kind .String)
                  (= text.kind .String)))
    (return (Value {}) false))
  (let [[iter err] (regex.create_iterator text.text pattern.text)]
    (when (!= err nil)
      (return (Value {}) false))
    (defer (regex.destroy iter))
    (let [[capture _ ok] (regex.match (addr iter))]
      (when (and ok (> (count capture.groups) 0))
        (return (value-string capture.groups[0]) true))))
  (return (Value {}) false))

(defn value-str [value: Value] -> [text: string, ok: bool]
  (case value.kind
    .String (return value.text true)
    .Keyword (return value.text true)
    .Uuid (return value.text true)
    .Instant (return (instant-text value.int-value) true)
    .Int (return (fmt.tprintf "%d" value.int-value) true)
    .Float (return (fmt.tprintf "%v" value.float-value) true)
    .Bool (if value.bool-value
            (return "true" true)
            (return "false" true))
    .Entity (return (fmt.tprintf "%d" value.entity) true)
    .Nil (return "" true)
     (return "" false)))

(defn primitive-value-dedupe-key [value: Value] -> [key: string, ok: bool]
  (case value.kind
    .Entity (return (fmt.tprintf "e:%d" value.entity) true)
    .String (return (fmt.tprintf "s:%s" value.text) true)
    .Int (return (fmt.tprintf "i:%d" value.int-value) true)
    .Float (return (fmt.tprintf "f:%v" value.float-value) true)
    .Bool (if value.bool-value
            (return "b:true" true)
            (return "b:false" true))
    .Keyword (return (fmt.tprintf "k:%s" value.text) true)
    .Symbol (return (fmt.tprintf "y:%s" value.text) true)
    .Uuid (return (fmt.tprintf "u:%s" value.text) true)
    .Instant (return (fmt.tprintf "t:%d" value.int-value) true)
    .Nil (return "n:" true)
    .Vector
      (let [parts (make [dynamic]string 0 (count value.items))]
        (defer (delete parts))
        (for [item value.items]
          (let [[part part-ok] (primitive-value-dedupe-key item)]
            (when (not part-ok)
              (return "" false))
            (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part))))
        (return (fmt.tprintf "v:%d:%s" (count value.items) (core-strings.concatenate (slice parts 0))) true))
    .Map
      (let [parts (make [dynamic]string 0 (count value.items))]
        (defer (delete parts))
        (for [item value.items]
          (let [[part part-ok] (primitive-value-dedupe-key item)]
            (when (not part-ok)
              (return "" false))
            (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part))))
        (return (fmt.tprintf "m:%d:%s" (count value.items) (core-strings.concatenate (slice parts 0))) true))
     (return "" false)))

(defn row-values-dedupe-key [values: []Value] -> [key: string, ok: bool]
  (when (= (count values) 1)
    (let [[key key-ok] (primitive-value-dedupe-key values[0])]
      (if key-ok
        (return (string-owned key) true)
        (return "" false))))
  (let [parts (make [dynamic]string 0 (count values))]
    (defer (delete parts))
    (for [value values]
      (let [[part part-ok] (primitive-value-dedupe-key value)]
        (when (not part-ok)
          (return "" false))
        (arr.push! parts (fmt.tprintf "%d:%s;" (count part) part))))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn delete-owned-string-set [values: (map string (struct {}))]
  (for [value values]
    (delete value))
  (delete values))

(defn pull-attrs-dedupe-key [attrs: []Pull-Attr] -> [key: string, ok: bool]
  (let [parts (make [dynamic]string 0 (count attrs))]
    (defer (delete parts))
    (for [pull-attr attrs]
      (let [[value-key value-ok] (primitive-value-dedupe-key pull-attr.v)]
        (when (not value-ok)
          (return "" false))
        (let [[child-key child-ok] (pull-attrs-dedupe-key (slice pull-attr.attrs 0))]
          (when (not child-ok)
            (return "" false))
          (arr.push! parts (fmt.tprintf "%d:%s:%d:%s:%d:%s;" (count pull-attr.a) pull-attr.a (count value-key) value-key (count child-key) child-key)))))
    (return (fmt.tprintf "pa:%d:%s" (count attrs) (core-strings.concatenate (slice parts 0))) true)))

(defn pull-result-dedupe-key [pull: Pull-Result] -> [key: string, ok: bool]
  (let [[attrs-key attrs-ok] (pull-attrs-dedupe-key (slice pull.attrs 0))]
    (if attrs-ok
      (return (fmt.tprintf "pr:%s" attrs-key) true)
      (return "" false))))

(defn result-row-dedupe-key [values: []Value, pulls: []Pull-Result] -> [key: string, ok: bool]
  (let [[values-key values-ok] (row-values-dedupe-key values)]
    (when (not values-ok)
      (return "" false))
    (let [pull-parts (make [dynamic]string 0 (count pulls))]
      (defer (delete pull-parts))
      (for [pull pulls]
        (let [[pull-key pull-ok] (pull-result-dedupe-key pull)]
          (when (not pull-ok)
            (return "" false))
          (arr.push! pull-parts (fmt.tprintf "%d:%s;" (count pull-key) pull-key))))
      (return (string-owned (fmt.tprintf "rv:%d:%s:rp:%d:%s" (count values-key) values-key (count pulls) (core-strings.concatenate (slice pull-parts 0)))) true))))

(defn two-primitive-values-dedupe-key [first: Value, second: Value] -> [key: string, ok: bool]
  (cond
    (and (= first.kind .String) (= second.kind .Int))
      (return (fmt.tprintf "si:%d:%s:%d" (count first.text) first.text second.int-value) true)
    (and (= first.kind .Int) (= second.kind .String))
      (return (fmt.tprintf "is:%d:%d:%s" first.int-value (count second.text) second.text) true)
    (and (= first.kind .String) (= second.kind .String))
      (return (fmt.tprintf "ss:%d:%s:%d:%s" (count first.text) first.text (count second.text) second.text) true)
    (and (= first.kind .Int) (= second.kind .Int))
      (return (fmt.tprintf "ii:%d:%d" first.int-value second.int-value) true)
    :else
      (let [values ([]Value [first second])]
        (row-values-dedupe-key values))))

(defstruct Two-Primitive-Seen {
  generic: (map string (struct {}))
  string-int: map[string]i64
  string-int-extra: (map string (struct {}))
  int-string: map[i64]string
  int-string-extra: (map string (struct {}))
})

(defn two-primitive-seen [] -> Two-Primitive-Seen
  (Two-Primitive-Seen {generic: (set.empty string)
                       string-int: (make (map string i64))
                       string-int-extra: (set.empty string)
                       int-string: (make (map i64 string))
                       int-string-extra: (set.empty string)}))

(defn delete-two-primitive-seen [seen: Two-Primitive-Seen]
  (delete seen.generic)
  (delete seen.string-int)
  (delete seen.string-int-extra)
  (delete seen.int-string)
  (delete seen.int-string-extra))

(defn two-value-seen-add [seen: ^Two-Primitive-Seen, first: Value, second: Value] -> [added: bool, ok: bool]
  (cond
    (and (= first.kind .String) (= second.kind .Int))
      (let [[existing found] (mmap.get seen^.string-int first.text)]
        (when (not found)
          (mmap.assoc! seen^.string-int first.text second.int-value)
          (return true true))
        (when (= existing second.int-value)
          (return false true))
        (let [[key key-ok] (two-primitive-values-dedupe-key first second)]
          (when (not key-ok)
            (return false false))
          (let [already-seen (set.contains? seen^.string-int-extra key)]
            (when already-seen
              (return false true))
            (set.add! seen^.string-int-extra key)
            (return true true))))
    (and (= first.kind .Int) (= second.kind .String))
      (let [[existing found] (mmap.get seen^.int-string first.int-value)]
        (when (not found)
          (mmap.assoc! seen^.int-string first.int-value second.text)
          (return true true))
        (when (= existing second.text)
          (return false true))
        (let [[key key-ok] (two-primitive-values-dedupe-key first second)]
          (when (not key-ok)
            (return false false))
          (let [already-seen (set.contains? seen^.int-string-extra key)]
            (when already-seen
              (return false true))
            (set.add! seen^.int-string-extra key)
            (return true true))))
    :else
      (let [[key key-ok] (two-primitive-values-dedupe-key first second)]
        (when (not key-ok)
          (return false false))
        (let [already-seen (set.contains? seen^.generic key)]
          (when already-seen
            (return false true))
          (set.add! seen^.generic key)
          (return true true)))))

(defn sort-strings! [values: ^[dynamic]string]
  (arr.sort! values^))

(defn binding-dedupe-key [binding: Binding] -> [key: string, ok: bool]
  (let [parts (make [dynamic]string 0 (count binding.items))]
    (defer (delete parts))
    (for [item binding.items]
      (let [[value-key value-ok] (primitive-value-dedupe-key item.value)]
        (when (not value-ok)
          (return "" false))
        (arr.push! parts (fmt.tprintf "%d:%s=%d:%s;" (count item.name) item.name (count value-key) value-key))))
    (sort-strings! (addr parts))
    (return (core-strings.concatenate (slice parts 0)) true)))

(defn value-slice-contains? [values: []Value, target: Value] -> bool
  (for [value values]
    (when (value-equal? value target)
      (return true)))
  false)

(defn predicate-matches? [predicate: Predicate, binding: Binding] -> bool
  (let [[op op-ok] (query-op-name predicate.op binding)]
    (when (not op-ok)
      (return false))
  (when (and (or (= op "true?")
                 (= op "false?")
                 (= op "nil?")
                 (= op "some?")
                 (= op "not")
                 (= op "empty?"))
             (= (count predicate.terms) 1))
    (let [[value value-ok] (resolve-term predicate.terms[0] binding)]
      (when (not value-ok)
        (return false))
      (cond
        (= op "true?") (return (and (= value.kind .Bool) value.bool-value))
        (= op "false?") (return (and (= value.kind .Bool) (not value.bool-value)))
        (= op "nil?") (return (= value.kind .Nil))
        (= op "some?") (return (not (= value.kind .Nil)))
        (= op "not") (return (or (= value.kind .Nil)
                                           (and (= value.kind .Bool) (not value.bool-value))))
        (= op "empty?") (return (and (= value.kind .Vector) (= (count value.items) 0))))))
  (when (and (or (= op "even?")
                 (= op "odd?")
                 (= op "zero?")
                 (= op "pos?")
                 (= op "neg?"))
             (= (count predicate.terms) 1))
    (let [[value value-ok] (resolve-term predicate.terms[0] binding)]
      (when (not value-ok)
        (return false))
      (when (= value.kind .Int)
        (cond
          (= op "even?") (return (= (% value.int-value 2) 0))
          (= op "odd?") (return (not (= (% value.int-value 2) 0)))
          (= op "zero?") (return (= value.int-value 0))
          (= op "pos?") (return (> value.int-value 0))
          (= op "neg?") (return (< value.int-value 0))))
      (when (= value.kind .Entity)
        (cond
          (= op "even?") (return (= (% value.entity 2) 0))
          (= op "odd?") (return (not (= (% value.entity 2) 0)))
          (= op "zero?") (return (= value.entity 0))
          (= op "pos?") (return (> value.entity 0))
          (= op "neg?") (return false)))
      (return false)))
  (when (and (= op "re-find")
             (= (count predicate.terms) 2))
    (let [[pattern pattern-ok] (resolve-term predicate.terms[0] binding)
          [text text-ok] (resolve-term predicate.terms[1] binding)]
      (return (and pattern-ok text-ok (re-find-matches? pattern text)))))
  (when (and (or (= op "contains?")
                 (= op "clojure.string/includes?")
                 (= op "clojure.string/starts-with?")
                 (= op "clojure.string/ends-with?"))
             (= (count predicate.terms) 2))
    (let [[left left-ok] (resolve-term predicate.terms[0] binding)
          [right right-ok] (resolve-term predicate.terms[1] binding)]
      (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
        (return false))
      (cond
        (or (= op "contains?") (= op "clojure.string/includes?"))
          (return (strings.contains left.text right.text))
        (= op "clojure.string/starts-with?")
          (return (strings.has_prefix left.text right.text))
        (= op "clojure.string/ends-with?")
          (return (strings.has_suffix left.text right.text)))))
  (when (< (count predicate.terms) 2)
    (return false))
  (let [index 0
        end (- (count predicate.terms) 1)]
    (while (< index end)
    (let [[left left-ok] (resolve-term predicate.terms[index] binding)
          [right right-ok] (resolve-term predicate.terms[(+ index 1)] binding)]
      (when (not (and left-ok right-ok))
        (return false))
      (when (not (predicate-pair-matches? op left right))
        (return false)))
    (set! index (+ index 1))))
  true))

(defn predicate-matches-with-db-and-fns? [db: DB, predicate: Predicate, binding: Binding, registry: []Native-Query-Fn] -> bool
  (when (predicate-matches? predicate binding)
    (return true))
  (let [[op op-ok] (query-op-name predicate.op binding)]
    (when (not op-ok)
      (return false))
    (let [[index found] (query-fn-index registry op)]
      (when (not found)
        (return false))
      (let [entry registry[index]]
        (when entry.has-predicate-callback
          (let [[args args-ok] (resolve-query-call-args predicate.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return false))
            (return (entry.predicate-callback (slice args 0)))))
        (when entry.has-db-predicate-callback
          (let [[args args-ok] (resolve-query-call-args predicate.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return false))
            (return (entry.db-predicate-callback db (slice args 0)))))
        (when (> (count entry.target) 0)
          (return (predicate-matches? (Predicate {op: entry.target terms: predicate.terms}) binding)))
        (return false)))))

(defn predicate-matches-with-fns? [predicate: Predicate, binding: Binding, registry: []Native-Query-Fn] -> bool
  (predicate-matches-with-db-and-fns? (DB {}) predicate binding registry))

(defn typed-predicate-op-name [predicate: Predicate, registry: []Native-Query-Fn] -> [op: string, ok: bool]
  (when (query-var-name? predicate.op)
    (return "" false))
  (when (predicate-op-supported? predicate.op)
    (return predicate.op true))
  (let [[index found] (query-fn-index registry predicate.op)]
    (when (not found)
      (return "" false))
    (let [entry registry[index]]
      (when (or entry.has-predicate-callback
                entry.has-db-predicate-callback
                (= (count entry.target) 0)
                (not (predicate-op-supported? entry.target)))
        (return "" false))
      (return entry.target true))))

(defn relation-column-row-predicate-equal? [left: Relation-Column, left-row: int, right: Relation-Column, right-row: int] -> [equal: bool, ok: bool]
  (when (not (and left.has-kind right.has-kind))
    (return false false))
  (when (and (or (= left.kind .Entity) (= left.kind .Int))
             (or (= right.kind .Entity) (= right.kind .Int)))
    (let [[left-key left-ok] (relation-column-row-number-join-key left left-row)
          [right-key right-ok] (relation-column-row-number-join-key right right-row)]
      (return (and left-ok right-ok (= left-key right-key)) (and left-ok right-ok))))
  (when (not (= left.kind right.kind))
    (return false true))
  (case left.kind
    .Nil (return true true)
    .Entity (return (= left.entities[left-row] right.entities[right-row]) true)
    .String (return (= left.texts[left-row] right.texts[right-row]) true)
    .Int (return (= left.ints[left-row] right.ints[right-row]) true)
    .Float (return (= left.floats[left-row] right.floats[right-row]) true)
    .Bool (return (= left.bools[left-row] right.bools[right-row]) true)
    .Keyword (return (= left.texts[left-row] right.texts[right-row]) true)
    .Symbol (return (= left.texts[left-row] right.texts[right-row]) true)
    .Uuid (return (= left.texts[left-row] right.texts[right-row]) true)
    .Instant (return (= left.ints[left-row] right.ints[right-row]) true)
    (return false false))
  (return false false))

(defn typed-var-pair-equality-predicate-matches? [rel: Query-Relation, row: int, op: string, left-name: string, right-name: string] -> [matched: bool, ok: bool]
  (when (not (or (= op "=") (= op "!=") (= op "not=")))
    (return false false))
  (let [[left-index left-ok] (query-relation-attr-index-lookup rel left-name)
        [right-index right-ok] (query-relation-attr-index-lookup rel right-name)]
    (when (not (and left-ok right-ok))
      (return false false))
    (let [[equal equal-ok] (relation-column-row-predicate-equal? rel.typed-columns[left-index] row rel.typed-columns[right-index] row)]
      (when (not equal-ok)
        (return false false))
      (if (= op "=")
        (return equal true)
        (return (not equal) true)))))

(defn typed-predicate-matches? [rel: Query-Relation, row: int, predicate: Predicate, registry: []Native-Query-Fn] -> [matched: bool, ok: bool]
  (let [[op op-ok] (typed-predicate-op-name predicate registry)]
    (when (not op-ok)
      (return false false))
    (when (and (= (count predicate.terms) 2)
               (= predicate.terms[0].kind .Var)
               (= predicate.terms[1].kind .Var))
      (let [[matched matched-ok] (typed-var-pair-equality-predicate-matches? rel row op predicate.terms[0].name predicate.terms[1].name)]
        (when matched-ok
          (return matched true))))
    (when (and (or (= op "true?")
                   (= op "false?")
                   (= op "nil?")
                   (= op "some?")
                   (= op "not")
                   (= op "empty?"))
               (= (count predicate.terms) 1))
      (let [[value value-ok] (query-relation-resolve-typed-term rel row predicate.terms[0])]
        (when (not value-ok)
          (return false true))
        (cond
          (= op "true?") (return (and (= value.kind .Bool) value.bool-value) true)
          (= op "false?") (return (and (= value.kind .Bool) (not value.bool-value)) true)
          (= op "nil?") (return (= value.kind .Nil) true)
          (= op "some?") (return (not (= value.kind .Nil)) true)
          (= op "not") (return (or (= value.kind .Nil)
                                    (and (= value.kind .Bool) (not value.bool-value))) true)
          (= op "empty?") (return (and (= value.kind .Vector) (= (count value.items) 0)) true))))
    (when (and (or (= op "even?")
                   (= op "odd?")
                   (= op "zero?")
                   (= op "pos?")
                   (= op "neg?"))
               (= (count predicate.terms) 1))
      (let [[value value-ok] (query-relation-resolve-typed-term rel row predicate.terms[0])]
        (when (not value-ok)
          (return false true))
        (when (= value.kind .Int)
          (cond
            (= op "even?") (return (= (% value.int-value 2) 0) true)
            (= op "odd?") (return (not (= (% value.int-value 2) 0)) true)
            (= op "zero?") (return (= value.int-value 0) true)
            (= op "pos?") (return (> value.int-value 0) true)
            (= op "neg?") (return (< value.int-value 0) true)))
        (when (= value.kind .Entity)
          (cond
            (= op "even?") (return (= (% value.entity 2) 0) true)
            (= op "odd?") (return (not (= (% value.entity 2) 0)) true)
            (= op "zero?") (return (= value.entity 0) true)
            (= op "pos?") (return (> value.entity 0) true)
            (= op "neg?") (return false true)))
        (return false true)))
    (when (and (= op "re-find")
               (= (count predicate.terms) 2))
      (let [[pattern pattern-ok] (query-relation-resolve-typed-term rel row predicate.terms[0])
            [text text-ok] (query-relation-resolve-typed-term rel row predicate.terms[1])]
        (return (and pattern-ok text-ok (re-find-matches? pattern text)) true)))
    (when (and (or (= op "contains?")
                   (= op "clojure.string/includes?")
                   (= op "clojure.string/starts-with?")
                   (= op "clojure.string/ends-with?"))
               (= (count predicate.terms) 2))
      (let [[left left-ok] (query-relation-resolve-typed-term rel row predicate.terms[0])
            [right right-ok] (query-relation-resolve-typed-term rel row predicate.terms[1])]
        (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
          (return false true))
        (cond
          (or (= op "contains?") (= op "clojure.string/includes?"))
            (return (strings.contains left.text right.text) true)
          (= op "clojure.string/starts-with?")
            (return (strings.has_prefix left.text right.text) true)
          (= op "clojure.string/ends-with?")
            (return (strings.has_suffix left.text right.text) true))))
    (when (< (count predicate.terms) 2)
      (return false true))
    (let [index 0
          end (- (count predicate.terms) 1)]
      (while (< index end)
        (let [[left left-ok] (query-relation-resolve-typed-term rel row predicate.terms[index])
              [right right-ok] (query-relation-resolve-typed-term rel row predicate.terms[(+ index 1)])]
          (when (not (and left-ok right-ok))
            (return false true))
          (when (not (predicate-pair-matches? op left right))
            (return false true)))
        (set! index (+ index 1))))
    (return true true)))

(defn typed-function-op-supported? [op: string] -> bool
  (or (= op "count")
      (= op "identity")
      (= op "ground")
      (= op "inc")
      (= op "dec")
      (= op "name")
      (= op "subs")
      (= op "re-pattern")
      (= op "re-find")
      (= op "str")
      (= op "keyword")
      (= op "first")
      (= op "second")
      (= op "vector")
      (= op "tuple")
      (= op "get")
      (= op "contains?")
      (= op "clojure.string/includes?")
      (= op "clojure.string/starts-with?")
      (= op "clojure.string/ends-with?")
      (= op "+")
      (= op "-")
      (= op "*")
      (= op "/")
      (= op "quot")
      (= op "rem")
      (= op "mod")
      (= op "min")
      (= op "max")
      (= op "compare")))

(defn source-function-op? [op: string] -> bool
  (or (= op "entid")
      (= op "datomic.api/entid")))

(defn function-clauses-have-source-function? [functions: []Function-Clause] -> bool
  (for [function functions]
    (when (source-function-op? function.op)
      (return true)))
  false)

(defn not-group-has-source-function? [group: Not-Group] -> bool
  (when (function-clauses-have-source-function? (slice group.function-clauses 0))
    (return true))
  (for [child group.not-groups]
    (when (not-group-has-source-function? child)
      (return true)))
  false)

(defn or-group-has-source-function? [group: Or-Group] -> bool
  (for [branch group.branches]
    (when (not-group-has-source-function? branch)
      (return true)))
  false)

(defn query-has-source-function? [query-value: Query] -> bool
  (when (function-clauses-have-source-function? (slice query-value.function-clauses 0))
    (return true))
  (for [rule query-value.rules]
    (when (function-clauses-have-source-function? (slice rule.function-clauses 0))
      (return true))
    (for [group rule.not-groups]
      (when (not-group-has-source-function? group)
        (return true)))
    (for [group rule.or-groups]
      (when (or-group-has-source-function? group)
        (return true))))
  (for [group query-value.not-groups]
    (when (not-group-has-source-function? group)
      (return true)))
  (for [group query-value.or-groups]
    (when (or-group-has-source-function? group)
      (return true)))
  false)

(defn source-default-token-term? [term: Term] -> bool
  (or (and (= term.kind .Var)
           (= term.name "$"))
      (and (= term.kind .Value)
           (= term.value.kind .Symbol)
           (= term.value.text "$"))))

(defn source-function-has-default-source-token? [function: Function-Clause] -> bool
  (and (> (count function.terms) 0)
       (source-default-token-term? function.terms[0])))

(defn typed-function-op-name [function: Function-Clause, registry: []Native-Query-Fn] -> [op: string, ok: bool]
  (when (query-var-name? function.op)
    (return "" false))
  (when (typed-function-op-supported? function.op)
    (return function.op true))
  (let [[index found] (query-fn-index registry function.op)]
    (when (not found)
      (return "" false))
    (let [entry registry[index]]
      (when (or entry.has-function-callback
                (= (count entry.target) 0)
                (not (typed-function-op-supported? entry.target)))
        (return "" false))
      (return entry.target true))))

(defn query-numeric-value? [value: Value] -> bool
  (or (= value.kind .Int) (= value.kind .Float)))

(defn query-numeric-value-f64 [value: Value] -> f64
  (if (= value.kind .Float)
    (return value.float-value)
    (return (f64 value.int-value))))

(defn apply-arithmetic-values [op: string, values: []Value] -> [value: Value, ok: bool]
  (when (= (count values) 0)
    (return (Value {}) false))
  (when (not (query-numeric-value? values[0]))
    (return (Value {}) false))
  (when (or (= op "quot") (= op "rem") (= op "mod"))
    (for [value values]
      (when (not (= value.kind .Int))
        (return (Value {}) false))))
  (let [float-mode (= values[0].kind .Float)
        int-result (if (= values[0].kind .Int) values[0].int-value (i64 0))
        float-result (query-numeric-value-f64 values[0])]
    (for [next (slice values 1)]
      (when (not (query-numeric-value? next))
        (return (Value {}) false))
      (when (and (not float-mode) (= next.kind .Float))
        (set! float-mode true)
        (set! float-result (f64 int-result)))
      (if float-mode
        (let [number (query-numeric-value-f64 next)]
          (cond
            (= op "+") (set! float-result (+ float-result number))
            (= op "-") (set! float-result (- float-result number))
            (= op "*") (set! float-result (* float-result number))
            (= op "/") (do
              (when (= number 0.0)
                (return (Value {}) false))
              (set! float-result (/ float-result number)))
            (= op "min") (when (< number float-result)
              (set! float-result number))
            (= op "max") (when (> number float-result)
              (set! float-result number))
            :else (return (Value {}) false)))
        (cond
          (= op "+") (set! int-result (+ int-result next.int-value))
          (= op "-") (set! int-result (- int-result next.int-value))
          (= op "*") (set! int-result (* int-result next.int-value))
          (= op "/") (do
            (when (= next.int-value 0)
              (return (Value {}) false))
            (set! int-result (/ int-result next.int-value)))
          (= op "quot") (do
            (when (= next.int-value 0)
              (return (Value {}) false))
            (set! int-result (/ int-result next.int-value)))
          (= op "rem") (do
            (when (= next.int-value 0)
              (return (Value {}) false))
            (set! int-result (% int-result next.int-value)))
          (= op "mod") (do
            (when (= next.int-value 0)
              (return (Value {}) false))
            (let [remainder (% int-result next.int-value)]
              (if (and (not (= remainder 0))
                       (or (and (< remainder 0) (> next.int-value 0))
                           (and (> remainder 0) (< next.int-value 0))))
                (set! int-result (+ remainder next.int-value))
                (set! int-result remainder))))
          (= op "min") (when (< next.int-value int-result)
            (set! int-result next.int-value))
          (= op "max") (when (> next.int-value int-result)
            (set! int-result next.int-value))
          :else (return (Value {}) false))))
    (if float-mode
      (return (value-float float-result) true)
      (return (value-int int-result) true))))

(defn typed-function-op-value [rel: Query-Relation, row: int, function: Function-Clause, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[op op-ok] (typed-function-op-name function registry)]
    (when (not op-ok)
      (return (Value {}) false))
    (when (and (= op "count")
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
        (when (and input-ok (= input.kind .String))
          (return (value-int (i64 (string-clojure-count input.text))) true))
        (return (Value {}) false)))
    (when (and (or (= op "identity")
                   (= op "ground"))
               (= (count function.terms) 1))
      (return (query-relation-resolve-typed-term rel row function.terms[0])))
    (when (and (= op "inc")
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
        (when (and input-ok (= input.kind .Int))
          (return (value-int (+ input.int-value 1)) true))
        (return (Value {}) false)))
    (when (and (= op "dec")
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
        (when (and input-ok (= input.kind .Int))
          (return (value-int (- input.int-value 1)) true))
        (return (Value {}) false)))
    (when (and (= op "name")
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
        (when (not input-ok)
          (return (Value {}) false))
        (when (= input.kind .String)
          (return input true))
        (when (= input.kind .Keyword)
          (let [slash (slash-index input.text)]
            (if (= slash -1)
              (return (value-string (slice input.text 1)) true)
              (return (value-string (slice input.text (+ slash 1))) true))))
        (return (Value {}) false)))
    (when (and (= op "subs")
               (or (= (count function.terms) 2)
                   (= (count function.terms) 3)))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            [start start-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
        (when (not (and input-ok start-ok (= input.kind .String) (= start.kind .Int)))
          (return (Value {}) false))
        (if (= (count function.terms) 2)
          (let [[part ok] (strings.substring_from input.text (int start.int-value))]
            (when ok
              (return (value-string part) true)))
          (let [[end end-ok] (query-relation-resolve-typed-term rel row function.terms[2])]
            (when (and end-ok (= end.kind .Int))
              (let [[part ok] (strings.substring input.text (int start.int-value) (int end.int-value))]
                (when ok
                  (return (value-string part) true))))))
        (return (Value {}) false)))
    (when (and (= op "re-pattern")
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
        (when (and input-ok (= input.kind .String))
          (let [[compiled err] (regex.create input.text)]
            (when (= err nil)
              (regex.destroy compiled)
              (return input true))))
        (return (Value {}) false)))
    (when (and (= op "re-find")
               (= (count function.terms) 2))
      (let [[pattern pattern-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            [text text-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
        (when (and pattern-ok text-ok)
          (return (re-find-value pattern text)))
        (return (Value {}) false)))
    (when (= op "str")
      (let [parts (make [dynamic]string 0 (count function.terms))]
        (defer (delete parts))
        (for [term function.terms]
          (let [[value value-ok] (query-relation-resolve-typed-term rel row term)]
            (when (not value-ok)
              (return (Value {}) false))
            (let [[part part-ok] (value-str value)]
              (when (not part-ok)
                (return (Value {}) false))
              (arr.push! parts part))))
        (return (value-string (strings.concatenate (slice parts 0))) true)))
    (when (and (= op "keyword")
               (or (= (count function.terms) 1)
                   (= (count function.terms) 2)))
      (if (= (count function.terms) 1)
        (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])]
          (when (not input-ok)
            (return (Value {}) false))
          (when (= input.kind .Keyword)
            (return input true))
          (when (= input.kind .String)
            (if (strings.has_prefix input.text ":")
              (return (value-keyword input.text) true)
              (return (value-keyword (strings.concatenate ([]string [":" input.text]))) true)))
          (return (Value {}) false))
        (let [[namespace namespace-ok] (query-relation-resolve-typed-term rel row function.terms[0])
              [name name-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
          (when (not (and namespace-ok name-ok (= namespace.kind .String) (= name.kind .String)))
            (return (Value {}) false))
          (return
            (value-keyword (strings.concatenate ([]string [":" namespace.text "/" name.text])))
            true))))
    (when (and (or (= op "first")
                   (= op "second"))
               (= (count function.terms) 1))
      (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            index (if (= op "first") 0 1)]
        (when (and input-ok
                   (= input.kind .Vector)
                   (< index (count input.items)))
          (return input.items[index] true))
        (return (Value {}) false)))
    (when (or (= op "vector")
              (= op "tuple"))
      (let [items (make [dynamic]Value 0 (count function.terms))]
        (for [term function.terms]
          (let [[value value-ok] (query-relation-resolve-typed-term rel row term)]
            (when (not value-ok)
              (delete items)
              (return (Value {}) false))
            (arr.push! items value)))
        (return (value-vector (slice items 0)) true)))
    (when (and (= op "get")
               (= (count function.terms) 2))
      (let [[map-value map-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            [key key-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
        (when (and map-ok key-ok)
          (return (map-get-value map-value key)))
        (return (Value {}) false)))
    (when (and (or (= op "contains?")
                   (= op "clojure.string/includes?")
                   (= op "clojure.string/starts-with?")
                   (= op "clojure.string/ends-with?"))
               (= (count function.terms) 2))
      (let [[left left-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            [right right-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
        (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
          (return (Value {}) false))
        (cond
          (or (= op "contains?") (= op "clojure.string/includes?"))
            (return (value-bool (strings.contains left.text right.text)) true)
          (= op "clojure.string/starts-with?")
            (return (value-bool (strings.has_prefix left.text right.text)) true)
          (= op "clojure.string/ends-with?")
            (return (value-bool (strings.has_suffix left.text right.text)) true))))
    (when (or (= op "+")
              (= op "-")
              (= op "*")
              (= op "/")
              (= op "quot")
              (= op "rem")
              (= op "mod")
              (= op "min")
              (= op "max"))
      (let [values (make [dynamic]Value 0 (count function.terms)) :defer]
        (for [term function.terms]
          (let [[value value-ok] (query-relation-resolve-typed-term rel row term)]
            (when (not value-ok)
              (return (Value {}) false))
            (arr.push! values value)))
        (return (apply-arithmetic-values op (slice values 0)))))
    (when (and (= op "compare")
               (= (count function.terms) 2))
      (let [[left left-ok] (query-relation-resolve-typed-term rel row function.terms[0])
            [right right-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
        (when (and left-ok right-ok)
          (return (value-int (i64 (value-compare left right))) true))
        (return (Value {}) false)))
    (return (Value {}) false)))

(defn db-read-source-typed-entid-value [source: DB-Read-Source, rel: Query-Relation, row: int, function: Function-Clause] -> [value: Value, ok: bool]
  (when (not (and (= (count function.terms) 2)
                  (source-function-has-default-source-token? function)))
    (return (Value {}) false))
  (let [[input input-ok] (query-relation-resolve-typed-term rel row function.terms[1])]
    (when (not input-ok)
      (return (Value {}) false))
    (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source input)]
      (when (not resolved-ok)
        (return (Value {}) false))
      (when (= resolved.kind .Entity)
        (return resolved true))
      (when (= resolved.kind .Int)
        (return (value-entity (u64 resolved.int-value)) true))
      (return (Value {}) false))))

(defn db-read-source-typed-function-op-value [source: DB-Read-Source, rel: Query-Relation, row: int, function: Function-Clause, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[op op-ok] (query-op-name function.op (Binding {}))]
    (when (and op-ok (source-function-op? op))
      (return (db-read-source-typed-entid-value source rel row function))))
  (typed-function-op-value rel row function registry))

(defn map-get-value [map-value: Value, key: Value] -> [value: Value, ok: bool]
  (when (not (= map-value.kind .Map))
    (return (Value {}) false))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (when (value-equal? map-value.items[index] key)
        (return map-value.items[(+ index 1)] true))
      (set! index (+ index 2))))
  (return (Value {}) false))

(defn apply-function-op [function: Function-Clause, binding: Binding] -> [value: Value, ok: bool]
  (let [[op op-ok] (query-op-name function.op binding)]
    (when (not op-ok)
      (return (Value {}) false))
  (when (and (= op "count")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .String))
        (return (value-int (i64 (string-clojure-count input.text))) true))
      (return (Value {}) false)))
  (when (and (or (= op "identity")
                 (= op "ground"))
             (= (count function.terms) 1))
    (return (resolve-term function.terms[0] binding)))
  (when (and (= op "inc")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Int))
        (return (value-int (+ input.int-value 1)) true))
      (return (Value {}) false)))
  (when (and (= op "dec")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Int))
        (return (value-int (- input.int-value 1)) true))
      (return (Value {}) false)))
  (when (and (= op "range")
             (or (= (count function.terms) 1)
                 (= (count function.terms) 2)
                 (= (count function.terms) 3)))
    (let [start: i64 0
          end: i64 0
          step: i64 1]
      (if (= (count function.terms) 1)
        (let [[end-value end-ok] (resolve-term function.terms[0] binding)]
          (when (not (and end-ok (= end-value.kind .Int)))
            (return (Value {}) false))
          (set! end end-value.int-value))
        (do
          (let [[start-value start-ok] (resolve-term function.terms[0] binding)
                [end-value end-ok] (resolve-term function.terms[1] binding)]
            (when (not (and start-ok end-ok (= start-value.kind .Int) (= end-value.kind .Int)))
              (return (Value {}) false))
            (set! start start-value.int-value)
            (set! end end-value.int-value))
          (when (= (count function.terms) 3)
            (let [[step-value step-ok] (resolve-term function.terms[2] binding)]
              (when (not (and step-ok (= step-value.kind .Int) (not (= step-value.int-value 0))))
                (return (Value {}) false))
              (set! step step-value.int-value)))))
      (let [items (make [dynamic]Value)]
        (if (> step 0)
          (while (< start end)
            (arr.push! items (value-int start))
            (set! start (+ start step)))
          (while (> start end)
            (arr.push! items (value-int start))
            (set! start (+ start step))))
        (let [out (value-vector (slice items 0))]
          (delete items)
          (return out true)))))
  (when (and (= op "name")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (not input-ok)
        (return (Value {}) false))
      (when (= input.kind .String)
        (return input true))
      (when (= input.kind .Keyword)
        (let [slash (slash-index input.text)]
          (if (= slash -1)
            (return (value-string (slice input.text 1)) true)
            (return (value-string (slice input.text (+ slash 1))) true))))
      (return (Value {}) false)))
  (when (and (= op "subs")
             (or (= (count function.terms) 2)
                 (= (count function.terms) 3)))
    (let [[input input-ok] (resolve-term function.terms[0] binding)
          [start start-ok] (resolve-term function.terms[1] binding)]
      (when (not (and input-ok start-ok (= input.kind .String) (= start.kind .Int)))
        (return (Value {}) false))
      (if (= (count function.terms) 2)
        (let [[part ok] (strings.substring_from input.text (int start.int-value))]
          (when ok
            (return (value-string part) true)))
        (let [[end end-ok] (resolve-term function.terms[2] binding)]
          (when (and end-ok (= end.kind .Int))
            (let [[part ok] (strings.substring input.text (int start.int-value) (int end.int-value))]
              (when ok
                (return (value-string part) true))))))
      (return (Value {}) false)))
  (when (and (= op "re-pattern")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .String))
        (let [[compiled err] (regex.create input.text)]
          (when (= err nil)
            (regex.destroy compiled)
            (return input true))))
      (return (Value {}) false)))
  (when (and (= op "re-find")
             (= (count function.terms) 2))
    (let [[pattern pattern-ok] (resolve-term function.terms[0] binding)
          [text text-ok] (resolve-term function.terms[1] binding)]
      (when (and pattern-ok text-ok)
        (return (re-find-value pattern text)))
      (return (Value {}) false)))
  (when (= op "str")
    (let [parts (make [dynamic]string 0 (count function.terms))]
      (defer (delete parts))
      (for [term function.terms]
        (let [[value value-ok] (resolve-term term binding)]
          (when (not value-ok)
            (return (Value {}) false))
          (let [[part part-ok] (value-str value)]
            (when (not part-ok)
              (return (Value {}) false))
            (arr.push! parts part))))
      (return (value-string (strings.concatenate (slice parts 0))) true)))
  (when (and (= op "keyword")
             (or (= (count function.terms) 1)
                 (= (count function.terms) 2)))
    (if (= (count function.terms) 1)
      (let [[input input-ok] (resolve-term function.terms[0] binding)]
        (when (not input-ok)
          (return (Value {}) false))
        (when (= input.kind .Keyword)
          (return input true))
        (when (= input.kind .String)
          (if (strings.has_prefix input.text ":")
            (return (value-keyword input.text) true)
            (return (value-keyword (strings.concatenate ([]string [":" input.text]))) true)))
        (return (Value {}) false))
      (let [[namespace namespace-ok] (resolve-term function.terms[0] binding)
            [name name-ok] (resolve-term function.terms[1] binding)]
        (when (not (and namespace-ok name-ok (= namespace.kind .String) (= name.kind .String)))
          (return (Value {}) false))
        (return
          (value-keyword (strings.concatenate ([]string [":" namespace.text "/" name.text])))
          true))))
  (when (and (or (= op "first")
                 (= op "second"))
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)
          index (if (= op "first") 0 1)]
      (when (and input-ok
                 (= input.kind .Vector)
                 (< index (count input.items)))
        (return input.items[index] true))
      (return (Value {}) false)))
  (when (or (= op "vector")
            (= op "tuple"))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-vector (slice items 0)) true)))
  (when (and (= op "untuple")
             (= (count function.terms) 1))
    (let [[input input-ok] (resolve-term function.terms[0] binding)]
      (when (and input-ok (= input.kind .Vector))
        (return input true))
      (return (Value {}) false)))
  (when (= op "hash-map")
    (when (not (= (% (count function.terms) 2) 0))
      (return (Value {}) false))
    (let [items (make [dynamic]Value 0 (count function.terms))]
      (for [term function.terms]
        (let [[value ok] (resolve-term term binding)]
          (when (not ok)
            (return (Value {}) false))
          (arr.push! items value)))
      (return (value-map (slice items 0)) true)))
  (when (and (= op "get")
             (= (count function.terms) 2))
    (let [[map-value map-ok] (resolve-term function.terms[0] binding)
          [key key-ok] (resolve-term function.terms[1] binding)]
      (when (and map-ok key-ok)
        (return (map-get-value map-value key)))
      (return (Value {}) false)))
  (when (and (or (= op "contains?")
                 (= op "clojure.string/includes?")
                 (= op "clojure.string/starts-with?")
                 (= op "clojure.string/ends-with?"))
             (= (count function.terms) 2))
    (let [[left left-ok] (resolve-term function.terms[0] binding)
          [right right-ok] (resolve-term function.terms[1] binding)]
      (when (not (and left-ok right-ok (= left.kind .String) (= right.kind .String)))
        (return (Value {}) false))
      (cond
        (or (= op "contains?") (= op "clojure.string/includes?"))
          (return (value-bool (strings.contains left.text right.text)) true)
        (= op "clojure.string/starts-with?")
          (return (value-bool (strings.has_prefix left.text right.text)) true)
        (= op "clojure.string/ends-with?")
          (return (value-bool (strings.has_suffix left.text right.text)) true))))
  (when (or (= op "+")
            (= op "-")
            (= op "*")
            (= op "/")
            (= op "quot")
            (= op "rem")
            (= op "mod")
            (= op "min")
            (= op "max"))
    (let [values (make [dynamic]Value 0 (count function.terms)) :defer]
      (for [term function.terms]
        (let [[value value-ok] (resolve-term term binding)]
          (when (not value-ok)
            (return (Value {}) false))
          (arr.push! values value)))
      (return (apply-arithmetic-values op (slice values 0)))))
  (when (and (= op "compare")
             (= (count function.terms) 2))
    (let [[left left-ok] (resolve-term function.terms[0] binding)
          [right right-ok] (resolve-term function.terms[1] binding)]
      (when (and left-ok right-ok)
        (return (value-int (i64 (value-compare left right))) true))
      (return (Value {}) false)))
  (return (Value {}) false)))

(defn apply-function-op-with-fns [function: Function-Clause, binding: Binding, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[builtin builtin-ok] (apply-function-op function binding)]
    (when builtin-ok
      (return builtin true)))
  (let [[op op-ok] (query-op-name function.op binding)]
    (when (not op-ok)
      (return (Value {}) false))
    (let [[index found] (query-fn-index registry op)]
      (when (not found)
        (return (Value {}) false))
      (let [entry registry[index]]
        (when entry.has-function-callback
          (let [[args args-ok] (resolve-query-call-args function.terms binding)]
            (defer (delete args))
            (when (not args-ok)
              (return (Value {}) false))
            (let [result (entry.function-callback (slice args 0))]
              (return result.value result.ok))))
        (when (> (count entry.target) 0)
          (return (apply-function-op (Function-Clause {op: entry.target
                                                       terms: function.terms
                                                       out: ""
                                                       out-vars: ([]string [])
                                                       out-binding: (Input-Binding {})
                                                       is-tuple: false})
                    binding)))
        (return (Value {}) false)))))

(defn apply-function-clause [binding: Binding, function: Function-Clause] -> [out: Binding, ok: bool]
  (let [[value value-ok] (apply-function-op function binding)]
    (when (not value-ok)
      (return binding false))
    (when (not (= function.out-binding.kind .None))
      (let [bound (bind-input-pattern binding function.out-binding value)]
        (when (= (count bound) 1)
          (return bound[0] true))
        (return binding false)))
    (when function.is-tuple
      (when (not (= value.kind .Vector))
        (return binding false))
      (when (not (= (count value.items) (count function.out-vars)))
        (return binding false))
      (let [next (clone-binding binding)]
        (for [name index function.out-vars]
          (when (not (= name "_"))
            (let [[bound bound-ok] (binding-with-value next name value.items[index])]
              (when (not bound-ok)
                (return binding false))
              (set! next bound))))
        (return next true)))
    (let [next (clone-binding binding)
          [existing exists] (binding-lookup next function.out)]
      (if exists
        (return next (predicate-value-equal? existing value))
        (do
          (binding-store! (addr next) function.out value)
          (return next true))))))

(defn apply-function-clause-with-fns [binding: Binding, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Binding, ok: bool]
  (let [[value value-ok] (apply-function-op-with-fns function binding registry)]
    (when (not value-ok)
      (return binding false))
    (when (not (= function.out-binding.kind .None))
      (let [bound (bind-input-pattern binding function.out-binding value)]
        (when (= (count bound) 1)
          (return bound[0] true))
        (return binding false)))
    (when function.is-tuple
      (when (not (= value.kind .Vector))
        (return binding false))
      (when (not (= (count value.items) (count function.out-vars)))
        (return binding false))
      (let [next (clone-binding binding)]
        (for [name index function.out-vars]
          (when (not (= name "_"))
            (let [[bound bound-ok] (binding-with-value next name value.items[index])]
              (when (not bound-ok)
                (return binding false))
              (set! next bound))))
        (return next true)))
    (let [next (clone-binding binding)
          [existing exists] (binding-lookup next function.out)]
      (if exists
        (return next (predicate-value-equal? existing value))
        (do
          (binding-store! (addr next) function.out value)
          (return next true))))))

(defn datom-current-at? [db: DB, index: int] -> bool
  (let [current (slice db.current 0)
        found (int-lower-bound current index)]
    (and (< found (count current))
         (= current[found] index))))

(defn all-datoms-current? [db: DB] -> bool
  (= (count db.current) (count db.datoms)))

(defn index-arg-value [db: DB, arg: Index-Arg] -> [value: Value, ok: bool]
  (when arg.has-lookup-ref
    (let [[entity found] (resolve-lookup-ref db arg.lookup-attr arg.lookup-value)]
      (when found
        (return (value-entity entity) true))
      (return (Value {}) false)))
  (return arg.value true))

(defn validate-index-lookup-refs [db: DB, args: []Index-Arg] -> [ok: bool, error: string]
  (for [arg args]
    (when arg.has-lookup-ref
      (let [[_ found lookup-error] (resolve-lookup-ref-checked db arg.lookup-attr arg.lookup-value)]
        (when (not found)
          (return false lookup-error)))))
  (return true ""))

(defn resolve-index-args [db: DB, args: []Index-Arg] -> [values: [dynamic]Value, ok: bool]
  (let [resolved (make [dynamic]Value)]
    (for [arg args]
      (let [[value ok] (index-arg-value db arg)]
        (when (not ok)
          (return resolved false))
        (arr.push! resolved value)))
    (return resolved true)))

(defenum Public-Index-Order [
  EAVT
  AEVT
  AVET
  VAET
])

(defn public-index-order [order: string] -> Public-Index-Order
  (cond
    (= order ":eavt") .EAVT
    (= order ":aevt") .AEVT
    (= order ":avet") .AVET
    :else .VAET))

(defn public-index-order-text [order: Public-Index-Order] -> string
  (cond
    (= order .EAVT) ":eavt"
    (= order .AEVT) ":aevt"
    (= order .AVET) ":avet"
    :else ":vaet"))

(defn db-index-slice [db: DB, order: Public-Index-Order] -> []int
  (cond
    (= order .EAVT) (slice db.eavt 0)
    (= order .AEVT) (slice db.aevt 0)
    (= order .AVET) (slice db.avet 0)
    :else (slice db.vaet 0)))

(defenum DB-Index-View-Kind [
  Resident
  SQLite-Cursor
  Shared-Int-Index
])

(defstruct DB-Index-View {
  kind: DB-Index-View-Kind
  order: Public-Index-Order
  indexes: []int
  sqlite-cursor: ^SQLite-Index-Cursor
  shared-index: ^Shared-Int-Index
})

(defenum DB-Read-Source-Kind [
  Resident
  Shared-Resident-Indexes
  Shared-Resident-Datoms-And-Indexes
  Shared-Tx-Ops-Overlay
  Shared-Datom-Overlay
  Shared-Datom-Log-Overlay
  SQLite-Snapshot
  SQLite-Tx-Ops-Overlay
  SQLite-Datom-Overlay
  SQLite-Datom-Log-Overlay
  Tx-Ops-Overlay
  Relation-Value
])

(defstruct DB-Read-Source {
  kind: DB-Read-Source-Kind
  db: ^DB
  filter-has-as-of: bool
  filter-as-of-tx: u64
  filter-has-since: bool
  filter-since-tx: u64
  filter-history: bool
  shared-datoms: ^Shared-Datom-Log
  shared-indexes: ^Shared-DB-Int-Indexes
  sqlite-snapshot: ^SQLite-DB-Snapshot
  overlay-base: ^DB-Read-Source
  overlay-ops: ^[dynamic]Tx-Op
  overlay-datoms: ^[dynamic]Datom
  overlay-log: ^Shared-Datom-Log
  overlay-tx: u64
  relation-value: ^Value
})

(defstruct DB-Read-Named-Source {
  name: string
  source: DB-Read-Source
})

(defn resident-db-read-source [db: ^DB] -> DB-Read-Source
  (DB-Read-Source {kind: .Resident db: db}))

(defn shared-resident-index-db-read-source [db: ^DB, indexes: ^Shared-DB-Int-Indexes] -> DB-Read-Source
  (DB-Read-Source {kind: .Shared-Resident-Indexes db: db shared-indexes: indexes}))

(defn shared-resident-db-read-source [datoms: ^Shared-Datom-Log, indexes: ^Shared-DB-Int-Indexes] -> DB-Read-Source
  (DB-Read-Source {kind: .Shared-Resident-Datoms-And-Indexes shared-datoms: datoms shared-indexes: indexes}))

(defn shared-db-snapshot-read-source [snapshot: ^Shared-DB-Snapshot] -> DB-Read-Source
  (shared-resident-db-read-source (addr snapshot^.datoms) (addr snapshot^.indexes)))

(defn sqlite-db-read-source [snapshot: ^SQLite-DB-Snapshot] -> DB-Read-Source
  (DB-Read-Source {kind: .SQLite-Snapshot sqlite-snapshot: snapshot}))

(defn tx-ops-overlay-db-read-source [base: ^DB-Read-Source, ops: ^[dynamic]Tx-Op, tx: u64] -> DB-Read-Source
  (DB-Read-Source {kind: .Tx-Ops-Overlay
                   overlay-base: base
                   overlay-ops: ops
                   overlay-tx: tx}))

(defn shared-tx-ops-overlay-db-read-source [datoms: ^Shared-Datom-Log, indexes: ^Shared-DB-Int-Indexes, ops: ^[dynamic]Tx-Op, tx: u64] -> DB-Read-Source
  (DB-Read-Source {kind: .Shared-Tx-Ops-Overlay
                   shared-datoms: datoms
                   shared-indexes: indexes
                   overlay-ops: ops
                   overlay-tx: tx}))

(defn sqlite-tx-ops-overlay-db-read-source [snapshot: ^SQLite-DB-Snapshot, ops: ^[dynamic]Tx-Op, tx: u64] -> DB-Read-Source
  (DB-Read-Source {kind: .SQLite-Tx-Ops-Overlay
                   sqlite-snapshot: snapshot
                   overlay-ops: ops
                   overlay-tx: tx}))

(defn shared-datom-overlay-db-read-source [datoms: ^Shared-Datom-Log, indexes: ^Shared-DB-Int-Indexes, overlay-datoms: ^[dynamic]Datom] -> DB-Read-Source
  (DB-Read-Source {kind: .Shared-Datom-Overlay
                   shared-datoms: datoms
                   shared-indexes: indexes
                   overlay-datoms: overlay-datoms}))

(defn shared-datom-log-overlay-db-read-source [datoms: ^Shared-Datom-Log, indexes: ^Shared-DB-Int-Indexes, overlay-log: ^Shared-Datom-Log] -> DB-Read-Source
  (DB-Read-Source {kind: .Shared-Datom-Log-Overlay
                   shared-datoms: datoms
                   shared-indexes: indexes
                   overlay-log: overlay-log}))

(defn sqlite-datom-overlay-db-read-source [snapshot: ^SQLite-DB-Snapshot, overlay-datoms: ^[dynamic]Datom] -> DB-Read-Source
  (DB-Read-Source {kind: .SQLite-Datom-Overlay
                   sqlite-snapshot: snapshot
                   overlay-datoms: overlay-datoms}))

(defn sqlite-datom-log-overlay-db-read-source [snapshot: ^SQLite-DB-Snapshot, overlay-log: ^Shared-Datom-Log] -> DB-Read-Source
  (DB-Read-Source {kind: .SQLite-Datom-Log-Overlay
                   sqlite-snapshot: snapshot
                   overlay-log: overlay-log}))

(defn relation-value-db-read-source [value: ^Value] -> DB-Read-Source
  (DB-Read-Source {kind: .Relation-Value relation-value: value}))

(defn db-read-source-has-inline-overlay? [source: DB-Read-Source] -> bool
  (or (= source.kind .Shared-Tx-Ops-Overlay)
      (= source.kind .SQLite-Tx-Ops-Overlay)
      (= source.kind .Shared-Datom-Overlay)
      (= source.kind .SQLite-Datom-Overlay)
      (= source.kind .Shared-Datom-Log-Overlay)
      (= source.kind .SQLite-Datom-Log-Overlay)))

(defn db-read-source-has-overlay? [source: DB-Read-Source] -> bool
  (or (= source.kind .Tx-Ops-Overlay)
      (db-read-source-has-inline-overlay? source)))

(defn db-read-named-source [name: string, source: DB-Read-Source] -> DB-Read-Named-Source
  (DB-Read-Named-Source {name: name source: source}))

(defn db-read-source-for-name [primary: DB-Read-Source, sources: []DB-Read-Named-Source, name: string] -> [source: DB-Read-Source, ok: bool, error: string]
  (when (not (query-source-input-name? name))
    (return (DB-Read-Source {}) false "SQLite DB snapshot source names must be $-prefixed"))
  (when (= name "$")
    (return primary true ""))
  (for [candidate sources]
    (when (= candidate.name name)
      (return candidate.source true "")))
  (return primary true ""))

(defn db-index-view [db: DB, order: Public-Index-Order] -> DB-Index-View
  (DB-Index-View {kind: .Resident
                  order: order
                  indexes: (db-index-slice db order)}))

(defn db-index-view-from-sqlite-cursor [order: Public-Index-Order, cursor: ^SQLite-Index-Cursor] -> DB-Index-View
  (DB-Index-View {kind: .SQLite-Cursor
                  order: order
                  sqlite-cursor: cursor}))

(defn db-index-view-from-shared-int-index [order: Public-Index-Order, index: ^Shared-Int-Index] -> DB-Index-View
  (DB-Index-View {kind: .Shared-Int-Index
                  order: order
                  shared-index: index}))

(defn shared-db-int-index-view [indexes: ^Shared-DB-Int-Indexes, order: Public-Index-Order] -> DB-Index-View
  (cond
    (= order .EAVT) (db-index-view-from-shared-int-index order (addr indexes^.eavt))
    (= order .AEVT) (db-index-view-from-shared-int-index order (addr indexes^.aevt))
    (= order .AVET) (db-index-view-from-shared-int-index order (addr indexes^.avet))
    :else (db-index-view-from-shared-int-index order (addr indexes^.vaet))))

(defn db-read-source-index-view [source: DB-Read-Source, order: Public-Index-Order] -> DB-Index-View
  (case source.kind
    .Resident (db-index-view source.db^ order)
    .Shared-Resident-Indexes (shared-db-int-index-view source.shared-indexes order)
    .Shared-Resident-Datoms-And-Indexes (shared-db-int-index-view source.shared-indexes order)
    .Shared-Tx-Ops-Overlay (shared-db-int-index-view source.shared-indexes order)
    .Shared-Datom-Overlay (shared-db-int-index-view source.shared-indexes order)
    .Shared-Datom-Log-Overlay (shared-db-int-index-view source.shared-indexes order)
    .SQLite-Snapshot (sqlite-db-snapshot-index-view source.sqlite-snapshot order)
    .SQLite-Tx-Ops-Overlay (sqlite-db-snapshot-index-view source.sqlite-snapshot order)
    .SQLite-Datom-Overlay (sqlite-db-snapshot-index-view source.sqlite-snapshot order)
    .SQLite-Datom-Log-Overlay (sqlite-db-snapshot-index-view source.sqlite-snapshot order)
    .Tx-Ops-Overlay (db-read-source-index-view source.overlay-base^ order)
     (DB-Index-View {})))

(defn db-read-source-eavt-entity-range [source: DB-Read-Source, entity: u64] -> [low: int, high: int, exists: bool, ok: bool, error: string]
  (let [view (db-read-source-index-view source .EAVT)
        values ([]Value [(value-entity entity)])
        [range-low range-low-ok range-low-error] (db-read-source-lower-bound-values source view values)]
    (when (not range-low-ok)
      (return 0 0 false false range-low-error))
    (let [[range-high range-high-ok range-high-error] (db-read-source-upper-bound-values source view values)]
      (when (not range-high-ok)
        (return 0 0 false false range-high-error))
      (return range-low range-high (> range-high range-low) true ""))))

(defn db-index-view-count [view: DB-Index-View] -> int
  (case view.kind
    .SQLite-Cursor (sqlite-index-cursor-count view.sqlite-cursor^)
    .Shared-Int-Index (shared-int-index-count view.shared-index^)
     (count view.indexes)))

(defn db-index-view-at [view: DB-Index-View, index: int] -> int
  (case view.kind
    .SQLite-Cursor
      (let [[entry ok _] (sqlite-index-cursor-at view.sqlite-cursor index)]
        (if ok entry 0))
    .Shared-Int-Index
      (let [[entry ok] (shared-int-index-at view.shared-index^ index)]
        (if ok entry 0))
     view.indexes[index]))

(defn db-read-source-datom-at-entry [source: DB-Read-Source, entry: int] -> [datom: Datom, ok: bool, error: string]
  (case source.kind
    .Resident
      (do
        (when (or (< entry 0)
                  (>= entry (count source.db^.datoms)))
          (return (Datom {}) false "resident datom index out of range"))
        (return (datom-owned source.db^.datoms[entry]) true ""))
    .Shared-Resident-Indexes
      (do
        (when (or (< entry 0)
                  (>= entry (count source.db^.datoms)))
          (return (Datom {}) false "shared resident datom index out of range"))
        (return (datom-owned source.db^.datoms[entry]) true ""))
    .Shared-Resident-Datoms-And-Indexes
      (let [[datom ok] (shared-datom-log-at source.shared-datoms^ entry)]
        (if ok
          (return datom true "")
          (return (Datom {}) false "shared datom log index out of range")))
    .Shared-Tx-Ops-Overlay
      (let [[datom ok] (shared-datom-log-at source.shared-datoms^ entry)]
        (if ok
          (return datom true "")
          (return (Datom {}) false "shared overlay datom log index out of range")))
    .Shared-Datom-Overlay
      (let [[datom ok] (shared-datom-log-at source.shared-datoms^ entry)]
        (if ok
          (return datom true "")
          (return (Datom {}) false "shared datom overlay log index out of range")))
    .Shared-Datom-Log-Overlay
      (let [[datom ok] (shared-datom-log-at source.shared-datoms^ entry)]
        (if ok
          (return datom true "")
          (return (Datom {}) false "shared datom log overlay log index out of range")))
    .SQLite-Snapshot
      (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)
    .SQLite-Tx-Ops-Overlay
      (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)
    .SQLite-Datom-Overlay
      (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)
    .SQLite-Datom-Log-Overlay
      (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)
     (return (Datom {}) false "unknown DB read source")))

(defn db-read-source-datom-unfiltered-current-at-entry? [source: DB-Read-Source, entry: int] -> [current: bool, ok: bool, error: string]
  (case source.kind
    .Resident
      (do
        (when (or (< entry 0)
                  (>= entry (count source.db^.datoms)))
          (return false false "resident datom index out of range"))
        (return (datom-current-at? source.db^ entry) true ""))
    .Shared-Resident-Indexes
      (do
        (when (or (< entry 0)
                  (>= entry (count source.db^.datoms)))
          (return false false "shared resident datom index out of range"))
        (return (shared-int-index-contains? source.shared-indexes^.current entry) true ""))
    .Shared-Resident-Datoms-And-Indexes
      (do
        (when (or (< entry 0)
                  (>= entry source.shared-datoms^.count))
          (return false false "shared datom log index out of range"))
        (return (shared-int-index-contains? source.shared-indexes^.current entry) true ""))
    .Shared-Tx-Ops-Overlay
      (do
        (when (or (< entry 0)
                  (>= entry source.shared-datoms^.count))
          (return false false "shared overlay datom log index out of range"))
        (return (shared-int-index-contains? source.shared-indexes^.current entry) true ""))
    .Shared-Datom-Overlay
      (do
        (when (or (< entry 0)
                  (>= entry source.shared-datoms^.count))
          (return false false "shared datom overlay log index out of range"))
        (return (shared-int-index-contains? source.shared-indexes^.current entry) true ""))
    .Shared-Datom-Log-Overlay
      (do
        (when (or (< entry 0)
                  (>= entry source.shared-datoms^.count))
          (return false false "shared datom log overlay log index out of range"))
        (return (shared-int-index-contains? source.shared-indexes^.current entry) true ""))
    .SQLite-Snapshot
      (do
        (when (not source.sqlite-snapshot^.has-retractions)
          (return true true ""))
      (let [[datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)]
        (when (not datom-ok)
          (return false false datom-error))
        (defer (delete-owned-datom datom))
        (when (not datom.added)
          (return false true ""))
        (let [[range-low range-high range-exists range-ok range-error] (db-read-source-eavt-entity-range source datom.e)]
          (when (not range-ok)
            (return false false range-error))
          (when (not range-exists)
            (return false true ""))
          (let [view (db-read-source-index-view source .EAVT)
                latest-tx: u64 0
                latest-added false
                found false]
            (for [pos (arr.range range-low range-high)]
              (let [candidate-entry (db-index-view-at view pos)
                    [candidate candidate-ok candidate-error] (db-read-source-datom-at-entry source candidate-entry)]
                (when (not candidate-ok)
                  (return false false candidate-error))
                (let [matches (and (= candidate.e datom.e)
                                   (= candidate.a datom.a)
                                   (value-equal? candidate.v datom.v))]
                  (when matches
                    (when (or (not found)
                              (> candidate.tx latest-tx))
                      (set! latest-tx candidate.tx)
                      (set! latest-added candidate.added)
                      (set! found true))))
                (delete-owned-datom candidate)))
            (return (and found latest-added (= latest-tx datom.tx)) true "")))))
    .SQLite-Tx-Ops-Overlay
      (let [[datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)]
        (when (not datom-ok)
          (return false false datom-error))
        (defer (delete-owned-datom datom))
        (when (not datom.added)
          (return false true ""))
        (let [[range-low range-high range-exists range-ok range-error] (db-read-source-eavt-entity-range source datom.e)]
          (when (not range-ok)
            (return false false range-error))
          (when (not range-exists)
            (return false true ""))
          (let [view (db-read-source-index-view source .EAVT)
                latest-tx: u64 0
                latest-added false
                found false]
            (for [pos (arr.range range-low range-high)]
              (let [candidate-entry (db-index-view-at view pos)
                    [candidate candidate-ok candidate-error] (db-read-source-datom-at-entry source candidate-entry)]
                (when (not candidate-ok)
                  (return false false candidate-error))
                (let [matches (and (= candidate.e datom.e)
                                   (= candidate.a datom.a)
                                   (value-equal? candidate.v datom.v))]
                  (when matches
                    (when (or (not found)
                              (> candidate.tx latest-tx))
                      (set! latest-tx candidate.tx)
                      (set! latest-added candidate.added)
                      (set! found true))))
                (delete-owned-datom candidate)))
            (return (and found latest-added (= latest-tx datom.tx)) true ""))))
    .SQLite-Datom-Overlay
      (let [[datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)]
        (when (not datom-ok)
          (return false false datom-error))
        (defer (delete-owned-datom datom))
        (when (not datom.added)
          (return false true ""))
        (let [[range-low range-high range-exists range-ok range-error] (db-read-source-eavt-entity-range source datom.e)]
          (when (not range-ok)
            (return false false range-error))
          (when (not range-exists)
            (return false true ""))
          (let [view (db-read-source-index-view source .EAVT)
                latest-tx: u64 0
                latest-added false
                found false]
            (for [pos (arr.range range-low range-high)]
              (let [candidate-entry (db-index-view-at view pos)
                    [candidate candidate-ok candidate-error] (db-read-source-datom-at-entry source candidate-entry)]
                (when (not candidate-ok)
                  (return false false candidate-error))
                (let [matches (and (= candidate.e datom.e)
                                   (= candidate.a datom.a)
                                   (value-equal? candidate.v datom.v))]
                  (when matches
                    (when (or (not found)
                              (> candidate.tx latest-tx))
                      (set! latest-tx candidate.tx)
                      (set! latest-added candidate.added)
                      (set! found true))))
                (delete-owned-datom candidate)))
            (return (and found latest-added (= latest-tx datom.tx)) true ""))))
    .SQLite-Datom-Log-Overlay
      (let [[datom datom-ok datom-error] (sqlite-db-snapshot-datom-at-log-index source.sqlite-snapshot entry)]
        (when (not datom-ok)
          (return false false datom-error))
        (defer (delete-owned-datom datom))
        (when (not datom.added)
          (return false true ""))
        (let [[range-low range-high range-exists range-ok range-error] (db-read-source-eavt-entity-range source datom.e)]
          (when (not range-ok)
            (return false false range-error))
          (when (not range-exists)
            (return false true ""))
          (let [view (db-read-source-index-view source .EAVT)
                latest-tx: u64 0
                latest-added false
                found false]
            (for [pos (arr.range range-low range-high)]
              (let [candidate-entry (db-index-view-at view pos)
                    [candidate candidate-ok candidate-error] (db-read-source-datom-at-entry source candidate-entry)]
                (when (not candidate-ok)
                  (return false false candidate-error))
                (let [matches (and (= candidate.e datom.e)
                                   (= candidate.a datom.a)
                                   (value-equal? candidate.v datom.v))]
                  (when matches
                    (when (or (not found)
                              (> candidate.tx latest-tx))
                      (set! latest-tx candidate.tx)
                      (set! latest-added candidate.added)
                      (set! found true))))
                (delete-owned-datom candidate)))
            (return (and found latest-added (= latest-tx datom.tx)) true ""))))
     (return false false "unknown DB read source")))

(defn db-read-source-datom-current-at-entry? [source: DB-Read-Source, entry: int] -> [current: bool, ok: bool, error: string]
  (when (or source.filter-has-as-of
            source.filter-has-since
            source.filter-history)
    (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
      (when (not datom-ok)
        (return false false datom-error))
      (defer (delete-owned-datom datom))
      (when (and source.filter-has-as-of
                 (> datom.tx source.filter-as-of-tx))
        (return false true ""))
      (when (and source.filter-has-since
                 (<= datom.tx source.filter-since-tx))
        (return false true ""))
      (when source.filter-history
        (return true true ""))
      (when source.filter-has-as-of
        (when (not datom.added)
          (return false true ""))
        (let [[range-low range-high range-exists range-ok range-error] (db-read-source-eavt-entity-range source datom.e)]
          (when (not range-ok)
            (return false false range-error))
          (when (not range-exists)
            (return false true ""))
          (let [view (db-read-source-index-view source .EAVT)
                latest-tx: u64 0
                latest-added false
                found false]
            (for [pos (arr.range range-low range-high)]
              (let [candidate-entry (db-index-view-at view pos)
                    [candidate candidate-ok candidate-error] (db-read-source-datom-at-entry source candidate-entry)]
                (when (not candidate-ok)
                  (return false false candidate-error))
                (let [matches (and (<= candidate.tx source.filter-as-of-tx)
                                   (= candidate.e datom.e)
                                   (= candidate.a datom.a)
                                   (value-equal? candidate.v datom.v))]
                  (when matches
                    (when (or (not found)
                              (> candidate.tx latest-tx))
                      (set! latest-tx candidate.tx)
                      (set! latest-added candidate.added)
                      (set! found true))))
                (delete-owned-datom candidate)))
            (return (and found latest-added (= latest-tx datom.tx)) true ""))))))
  (db-read-source-datom-unfiltered-current-at-entry? source entry))

(defn lower-bound-index-view-values [db: DB, view: DB-Index-View, values: []Value] -> int
  (let [order (public-index-order-text view.order)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            datom-index (db-index-view-at view mid)
            compare (datom-index-compare-values-core db.datoms[datom-index] order values)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn upper-bound-index-view-values [db: DB, view: DB-Index-View, values: []Value] -> int
  (let [order (public-index-order-text view.order)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            datom-index (db-index-view-at view mid)
            compare (datom-index-compare-values-core db.datoms[datom-index] order values)]
        (if (<= compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn lower-bound-index-view [db: DB, view: DB-Index-View, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            datom-index (db-index-view-at view mid)
            compare (datom-prefix-compare db order datom-index e a v)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn upper-bound-index-view [db: DB, view: DB-Index-View, order: string, e: u64, a: string, v: Value] -> int
  (let [low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            datom-index (db-index-view-at view mid)
            compare (datom-prefix-compare db order datom-index e a v)]
        (if (<= compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn datom-index-position-value [datom: Datom, order: string, position: int] -> Value
  (if (= order ":eavt")
    (if (= position 0)
      (value-entity datom.e)
      (if (= position 1)
        (value-keyword datom.a)
        (if (= position 2)
          datom.v
          (Value {}))))
    (if (= order ":aevt")
      (if (= position 0)
        (value-keyword datom.a)
        (if (= position 1)
          (value-entity datom.e)
          (if (= position 2)
            datom.v
            (Value {}))))
      (if (= order ":avet")
        (if (= position 0)
          (value-keyword datom.a)
          (if (= position 1)
            datom.v
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))
        (if (= position 0)
          datom.v
          (if (= position 1)
            (value-keyword datom.a)
            (if (= position 2)
              (value-entity datom.e)
              (Value {}))))))))

(defn index-position-equal? [actual: Value, expected: Value] -> bool
  (if (and (= actual.kind .Keyword)
           (or (= expected.kind .Keyword) (= expected.kind .String)))
    (= actual.text expected.text)
    (predicate-value-equal? actual expected)))

(defn index-position-compare [actual: Value, expected: Value] -> int
  (if (and (= actual.kind .Entity) (= expected.kind .Int))
    (let [right (u64 expected.int-value)]
      (if (< actual.entity right)
        -1
        (if (> actual.entity right) 1 0)))
    (if (and (= actual.kind .Keyword)
             (or (= expected.kind .Keyword) (= expected.kind .String)))
      (strings.compare actual.text expected.text)
      (value-compare actual expected))))

(defn datom-matches-index-values? [datom: Datom, order: string, values: []Value] -> bool
  (for [value position values]
    (when (not (index-position-equal? (datom-index-position-value datom order position) value))
      (return false)))
  true)

(defn datom-index-compare-values [datom: Datom, order: string, values: []Value] -> int
  (for [value position values]
    (let [compare (index-position-compare (datom-index-position-value datom order position) value)]
      (when (not (= compare 0))
        (return compare))))
  0)

(defn datom-index-compare-order [left: Datom, right: Datom, order: Public-Index-Order] -> int
  (let [order-text (public-index-order-text order)]
    (for [position (arr.range 0 3)]
      (let [compare (index-position-compare (datom-index-position-value left order-text position)
                                            (datom-index-position-value right order-text position))]
        (when (not (= compare 0))
          (return compare))))
    (cond
      (< left.tx right.tx) -1
      (> left.tx right.tx) 1
      (< left.e right.e) -1
      (> left.e right.e) 1
      :else 0)))

(defn datom-order-index-less? [datoms: []Datom, left-index: int, right-index: int, order: Public-Index-Order] -> bool
  (< (datom-index-compare-order datoms[left-index] datoms[right-index] order) 0))

(defn sorted-datom-order-indexes [datoms: []Datom, order: Public-Index-Order] -> [dynamic]int
  (let [indexes (make [dynamic]int 0 (count datoms))]
    (for [_ index datoms]
      (arr.push! indexes index))
    (let [i 1]
      (while (< i (count indexes))
        (let [current indexes[i]
              j i]
          (while (and (> j 0)
                      (datom-order-index-less? datoms current indexes[(- j 1)] order))
            (set! indexes[j] indexes[(- j 1)])
            (set! j (- j 1)))
          (set! indexes[j] current))
        (set! i (+ i 1))))
    indexes))

(defn db-read-source-lower-bound-values [source: DB-Read-Source, view: DB-Index-View, values: []Value] -> [position: int, ok: bool, error: string]
  (let [order (public-index-order-text view.order)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            entry (db-index-view-at view mid)
            [datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
        (when (not datom-ok)
          (return low false datom-error))
        (let [compare (datom-index-compare-values datom order values)]
          (delete-owned-datom datom)
          (if (< compare 0)
            (set! low (+ mid 1))
            (set! high mid)))))
    (return low true "")))

(defn db-read-source-upper-bound-values [source: DB-Read-Source, view: DB-Index-View, values: []Value] -> [position: int, ok: bool, error: string]
  (let [order (public-index-order-text view.order)
        low 0
        high (db-index-view-count view)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            entry (db-index-view-at view mid)
            [datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
        (when (not datom-ok)
          (return low false datom-error))
        (let [compare (datom-index-compare-values datom order values)]
          (delete-owned-datom datom)
          (if (<= compare 0)
            (set! low (+ mid 1))
            (set! high mid)))))
    (return low true "")))

(defn datom-same-fact? [datom: Datom, entity: u64, attr: string, value: Value] -> bool
  (and (= datom.e entity)
       (= datom.a attr)
       (value-equal? datom.v value)))

(defn remove-datom-fact! [datoms: ^[dynamic]Datom, entity: u64, attr: string, value: Value]
  (let [index (- (count datoms^) 1)]
    (while (>= index 0)
      (when (datom-same-fact? datoms^[index] entity attr value)
        (delete-owned-datom datoms^[index])
        (arr.remove-ordered-at! datoms^ index))
      (set! index (- index 1)))))

(defn tx-op-index-values-match? [op: Tx-Op, order: Public-Index-Order, values: []Value] -> bool
  (let [datom (Datom {e: op.e
                      a: op.a
                      v: op.v
                      tx: 0
                      added: (= op.kind .Add)})]
    (datom-matches-index-values? datom (public-index-order-text order) values)))

(defn append-owned-datom-from-tx-op! [out: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (let [datom (Datom {e: op.e
                      a: op.a
                      v: op.v
                      tx: tx
                      added: true})]
    (arr.push! out^ (datom-owned datom))))

(defn append-owned-log-datom-from-tx-op! [out: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (let [datom (Datom {e: op.e
                      a: op.a
                      v: op.v
                      tx: tx
                      added: (= op.kind .Add)})]
    (arr.push! out^ (datom-owned datom))))

(defn db-read-source-filter-allows-tx? [source: DB-Read-Source, tx: u64] -> bool
  (and (or (not source.filter-has-as-of)
           (<= tx source.filter-as-of-tx))
       (or (not source.filter-has-since)
           (> tx source.filter-since-tx))))

(defn db-read-source-apply-overlay-ops! [out: ^[dynamic]Datom, source: DB-Read-Source, order: Public-Index-Order, values: []Value]
  (when (db-read-source-filter-allows-tx? source source.overlay-tx)
    (for [op source.overlay-ops^]
      (when (tx-op-index-values-match? op order values)
        (if source.filter-history
          (append-owned-log-datom-from-tx-op! out op source.overlay-tx)
          (do
            (remove-datom-fact! out op.e op.a op.v)
            (when (= op.kind .Add)
              (append-owned-datom-from-tx-op! out op source.overlay-tx))))))))

(defn db-read-source-apply-overlay-datoms! [out: ^[dynamic]Datom, source: DB-Read-Source, order: Public-Index-Order, values: []Value]
  (let [order-text (public-index-order-text order)]
    (for [datom source.overlay-datoms^]
      (when (and (db-read-source-filter-allows-tx? source datom.tx)
                 (datom-matches-index-values? datom order-text values))
        (if source.filter-history
          (arr.push! out^ (datom-owned datom))
          (do
            (remove-datom-fact! out datom.e datom.a datom.v)
            (when datom.added
              (arr.push! out^ (datom-owned datom)))))))))

(defn db-read-source-apply-overlay-log! [out: ^[dynamic]Datom, source: DB-Read-Source, order: Public-Index-Order, values: []Value]
  (let [order-text (public-index-order-text order)
        index 0]
    (while (< index source.overlay-log^.count)
      (let [[datom datom-ok] (shared-datom-log-at source.overlay-log^ index)]
        (when datom-ok
          (if (and (db-read-source-filter-allows-tx? source datom.tx)
                   (datom-matches-index-values? datom order-text values))
            (do
              (if source.filter-history
                (arr.push! out^ datom)
                (do
                  (remove-datom-fact! out datom.e datom.a datom.v)
                  (if datom.added
                    (arr.push! out^ datom)
                    (delete-owned-datom datom)))))
            (delete-owned-datom datom))))
      (set! index (+ index 1)))))

(defn db-read-source-apply-inline-overlay! [out: ^[dynamic]Datom, source: DB-Read-Source, order: Public-Index-Order, values: []Value]
  (case source.kind
    .Shared-Datom-Overlay (db-read-source-apply-overlay-datoms! out source order values)
    .SQLite-Datom-Overlay (db-read-source-apply-overlay-datoms! out source order values)
    .Shared-Datom-Log-Overlay (db-read-source-apply-overlay-log! out source order values)
    .SQLite-Datom-Log-Overlay (db-read-source-apply-overlay-log! out source order values)
     (db-read-source-apply-overlay-ops! out source order values)))

(defn db-read-source-append-index-datoms! [out: ^[dynamic]Datom, source: DB-Read-Source, order: Public-Index-Order, values: []Value] -> [ok: bool, error: string]
  (when (= source.kind .Tx-Ops-Overlay)
    (let [[base-ok base-error] (db-read-source-append-index-datoms! out source.overlay-base^ order values)]
      (when (not base-ok)
        (return false base-error))
      (db-read-source-apply-overlay-ops! out source order values)
      (return true "")))
  (let [view (db-read-source-index-view source order)
        order-text (public-index-order-text order)]
    (when (and (not (db-read-source-has-inline-overlay? source))
               (sqlite-merge-index-view? view))
      (let [[stream stream-ok stream-error] (source-index-datom-stream-for-sqlite-sequential-values source order values view)]
        (when (not stream-ok)
          (return false stream-error))
        (while stream.has-current
          (arr.push! out^ (datom-owned stream.current))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (return false advance-error))))
        (delete-source-index-datom-stream stream)
        (return true "")))
    (let [[low low-ok low-error] (db-read-source-lower-bound-values source view values)]
    (when (not low-ok)
      (return false low-error))
    (let [[high high-ok high-error] (db-read-source-upper-bound-values source view values)]
      (when (not high-ok)
        (return false high-error))
      (for [pos (arr.range low high)]
        (let [entry (db-index-view-at view pos)
              [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
          (when (not current-ok)
            (return false current-error))
          (when current
            (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
              (when (not datom-ok)
                (return false datom-error))
              (if (datom-matches-index-values? datom order-text values)
                (arr.push! out^ datom)
                (delete-owned-datom datom)))))))
    (when (db-read-source-has-inline-overlay? source)
      (db-read-source-apply-inline-overlay! out source order values))
    (return true ""))))

(defn db-read-source-datoms-by-attr [source: DB-Read-Source, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [out (make [dynamic]Datom)
        values ([]Value [(value-keyword attr)])
        [scan-ok scan-error] (db-read-source-append-index-datoms! (addr out) source .AEVT values)]
    (if scan-ok
      (return out true "")
      (do
        (delete-owned-datoms out)
        (return (make [dynamic]Datom) false scan-error)))))

(defn db-read-source-materialize-db [source: DB-Read-Source] -> [db: DB, ok: bool, error: string]
  (when (= source.kind .Tx-Ops-Overlay)
    (let [[base base-ok base-error] (db-read-source-materialize-db source.overlay-base^)]
      (when (not base-ok)
        (return base false base-error))
      (let [out (clone-datoms base.datoms)]
        (delete-owned-db base)
        (for [op source.overlay-ops^]
          (append-owned-log-datom-from-tx-op! (addr out) op source.overlay-tx))
        (return (build-db out) true ""))))
  (let [out (make [dynamic]Datom)
        view (db-read-source-index-view source .EAVT)
        n (db-index-view-count view)]
    (for [entry (arr.range 0 n)]
      (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
        (when (not datom-ok)
          (delete-owned-datoms out)
          (return (build-db (make [dynamic]Datom)) false datom-error))
        (arr.push! out datom)))
    (when (db-read-source-has-inline-overlay? source)
      (case source.kind
        .Shared-Datom-Overlay
          (for [datom source.overlay-datoms^]
            (arr.push! out (datom-owned datom)))
        .SQLite-Datom-Overlay
          (for [datom source.overlay-datoms^]
            (arr.push! out (datom-owned datom)))
        .Shared-Datom-Log-Overlay
          (for [index (arr.range 0 source.overlay-log^.count)]
            (let [[datom datom-ok] (shared-datom-log-at source.overlay-log^ index)]
              (when datom-ok
                (arr.push! out datom))))
        .SQLite-Datom-Log-Overlay
          (for [index (arr.range 0 source.overlay-log^.count)]
            (let [[datom datom-ok] (shared-datom-log-at source.overlay-log^ index)]
              (when datom-ok
                (arr.push! out datom))))
         (for [op source.overlay-ops^]
           (append-owned-log-datom-from-tx-op! (addr out) op source.overlay-tx))))
    (return (build-db out) true "")))

(defn db-read-source-datoms-by-entity-attr [source: DB-Read-Source, entity: u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [out (make [dynamic]Datom)
        values ([]Value [(value-entity entity) (value-keyword attr)])
        [scan-ok scan-error] (db-read-source-append-index-datoms! (addr out) source .EAVT values)]
    (if scan-ok
      (return out true "")
      (do
        (delete-owned-datoms out)
        (return (make [dynamic]Datom) false scan-error)))))

(defn db-read-source-datoms-by-entity [source: DB-Read-Source, entity: u64] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (when (= source.kind .Tx-Ops-Overlay)
    (let [[out base-ok base-error] (db-read-source-datoms-by-entity source.overlay-base^ entity)]
      (when (not base-ok)
        (return out false base-error))
      (let [values ([]Value [(value-entity entity)])]
        (db-read-source-apply-overlay-ops! (addr out) source .EAVT values))
      (return out true "")))
  (let [out (make [dynamic]Datom)
        [low high exists range-ok range-error] (db-read-source-eavt-entity-range source entity)]
    (when (not range-ok)
      (delete-owned-datoms out)
      (return (make [dynamic]Datom) false range-error))
    (when (and (not exists)
               (not (db-read-source-has-inline-overlay? source)))
      (return out true ""))
    (when exists
      (let [view (db-read-source-index-view source .EAVT)]
        (for [pos (arr.range low high)]
          (let [entry (db-index-view-at view pos)
                [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
            (when (not current-ok)
              (delete-owned-datoms out)
              (return (make [dynamic]Datom) false current-error))
            (when current
              (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
                (when (not datom-ok)
                  (delete-owned-datoms out)
                  (return (make [dynamic]Datom) false datom-error))
                (arr.push! out datom)))))))
    (when (db-read-source-has-inline-overlay? source)
      (let [values ([]Value [(value-entity entity)])]
        (db-read-source-apply-inline-overlay! (addr out) source .EAVT values)))
    (return out true "")))

(defn db-read-source-eavt-entity-attr-position [source: DB-Read-Source, entity: u64, attr: string] -> [pos: int, exists: bool, ok: bool, error: string]
  (let [[low high range-exists range-ok range-error] (db-read-source-eavt-entity-range source entity)]
    (when (not range-ok)
      (return 0 false false range-error))
    (when (not range-exists)
      (return 0 false true ""))
    (let [view (db-read-source-index-view source .EAVT)
          i low]
      (while (< i high)
        (let [entry (db-index-view-at view i)]
          (if (and (= view.kind .SQLite-Cursor)
                   (= source.kind .SQLite-Snapshot)
                   (not source.sqlite-snapshot^.has-retractions))
            (let [[candidate-attr attr-ok attr-error] (sqlite-load-datom-attr-by-log-index-handle-stmt view.sqlite-cursor^.handle view.sqlite-cursor^.datom-stmt entry)]
              (when (not attr-ok)
                (return 0 false false attr-error))
              (let [compare (strings.compare candidate-attr attr)]
                (delete candidate-attr)
                (cond
                  (= compare 0) (return i true true "")
                  (> compare 0) (return 0 false true "")
                  :else (set! i (+ i 1)))))
            (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
              (when (not datom-ok)
                (return 0 false false datom-error))
              (let [compare (strings.compare datom.a attr)]
                (delete-owned-datom datom)
                (cond
                  (= compare 0) (return i true true "")
                  (> compare 0) (return 0 false true "")
                  :else (set! i (+ i 1))))))))
      (return 0 false true ""))))

(defn db-read-source-cardinality-one-value-fast-all-current [source: DB-Read-Source, entity: u64, attr: string] -> [value: Value, ok: bool, error: string]
  (when (db-read-source-has-overlay? source)
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
      (when (not datoms-ok)
        (return (Value {}) false datoms-error))
      (defer (delete-owned-datoms datoms))
      (when (= (count datoms) 0)
        (return (Value {}) false ""))
      (return (value-owned datoms[(- (count datoms) 1)].v) true "")))
  (let [[index-pos pos-exists pos-ok pos-error] (db-read-source-eavt-entity-attr-position source entity attr)]
    (when (not pos-ok)
      (return (Value {}) false pos-error))
    (when (not pos-exists)
      (return (Value {}) false ""))
    (let [view (db-read-source-index-view source .EAVT)
          entry (db-index-view-at view index-pos)
          sqlite-current-by-construction (and (= view.kind .SQLite-Cursor)
                                              (= source.kind .SQLite-Snapshot)
                                              (not source.sqlite-snapshot^.has-retractions))]
      (when (not sqlite-current-by-construction)
        (let [[current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
          (when (not current-ok)
            (return (Value {}) false current-error))
          (when (not current)
            ;; A cardinality-one replacement leaves the prior value in EAVT
            ;; as a retracted historical entry. The first entry for (e, a)
            ;; is therefore not necessarily the current value. Fall back to
            ;; the current-datom scan instead of treating the attribute as
            ;; absent; source-backed bind joins depend on this helper.
            (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
              (when (not datoms-ok)
                (return (Value {}) false datoms-error))
              (defer (delete-owned-datoms datoms))
              (when (= (count datoms) 0)
                (return (Value {}) false ""))
              (return (value-owned datoms[(- (count datoms) 1)].v) true "")))))
      (let [datom (Datom {})
            datom-ok false
            datom-error ""]
        (if sqlite-current-by-construction
          (let [[_same-entry cursor-datom cursor-ok cursor-error] (sqlite-index-cursor-entry-and-datom-at view.sqlite-cursor index-pos)]
            (discard _same-entry)
            (set! datom cursor-datom)
            (set! datom-ok cursor-ok)
            (set! datom-error cursor-error))
          (let [[loaded loaded-ok loaded-error] (db-read-source-datom-at-entry source entry)]
            (set! datom loaded)
            (set! datom-ok loaded-ok)
            (set! datom-error loaded-error)))
        (when (not datom-ok)
          (return (Value {}) false datom-error))
        (if (and (= datom.e entity)
                 (= datom.a attr))
          (let [out (value-owned datom.v)]
            (delete-owned-datom datom)
            (return out true ""))
          (do
            (delete-owned-datom datom)
            (return (Value {}) false "")))))))

(defn db-read-source-cardinality-one-int-value-fast-all-current [source: DB-Read-Source, entity: u64, attr: string] -> [value: i64, ok: bool, error: string]
  (let [[owned-value value-ok value-error] (db-read-source-cardinality-one-value-fast-all-current source entity attr)]
    (when (not value-ok)
      (return 0 false value-error))
    (defer (delete-owned-value owned-value))
    (if (= owned-value.kind .Int)
      (return owned-value.int-value true "")
      (return 0 false ""))))

(defn db-read-source-cardinality-one-value-matches-fast-all-current? [source: DB-Read-Source, entity: u64, attr: string, expected: Value] -> [matches: bool, ok: bool, error: string]
  (let [[value value-ok value-error] (db-read-source-cardinality-one-value-fast-all-current source entity attr)]
    (when (not value-ok)
      (return false (= value-error "") value-error))
    (defer (delete-owned-value value))
    (return (value-equal? value expected) true "")))

(defn db-read-source-datoms-by-reverse-entity-attr [source: DB-Read-Source, entity: u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [out (make [dynamic]Datom)
        values ([]Value [(value-entity entity) (value-keyword attr)])
        [scan-ok scan-error] (db-read-source-append-index-datoms! (addr out) source .VAET values)]
    (if scan-ok
      (return out true "")
      (do
        (delete-owned-datoms out)
        (return (make [dynamic]Datom) false scan-error)))))

(defn db-read-source-pull-attrs-value [source: DB-Read-Source, entity: u64, attrs: []string] -> [value: Value, ok: bool, error: string]
  (let [items (make [dynamic]Value)]
    (for [attr attrs]
      (if (= attr ":db/id")
        (do
          (arr.push! items (value-keyword (string-owned attr)))
          (arr.push! items (value-entity entity)))
        (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
          (when (not datoms-ok)
            (let [partial (value-map (slice items 0))]
              (delete items)
              (delete-owned-value partial))
            (return (Value {}) false datoms-error))
          (when (> (count datoms) 0)
            (arr.push! items (value-keyword (string-owned attr)))
            (if (= (count datoms) 1)
              (arr.push! items (value-owned datoms[0].v))
              (let [values (make [dynamic]Value 0 (count datoms))]
                (for [datom datoms]
                  (arr.push! values (value-owned datom.v)))
                (arr.push! items (value-vector (slice values 0)))
                (delete values))))
          (delete-owned-datoms datoms))))
    (let [out (value-map (slice items 0))]
      (delete items)
      (return out true ""))))

(defn db-read-source-schema-entity-for-attr [source: DB-Read-Source, attr: string] -> [entity: u64, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source ":db/ident")]
    (when (not datoms-ok)
      (return 0 false datoms-error))
    (for [datom datoms]
      (when (and (= datom.v.kind .Keyword)
                 (= datom.v.text attr))
        (let [entity datom.e]
          (delete-owned-datoms datoms)
          (return entity true ""))))
    (delete-owned-datoms datoms)
    (return 0 false "")))

(defn db-read-source-resolve-clause-value-for-attr [source: DB-Read-Source, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (let [[attr-is-ref ref-ok ref-error] (db-read-source-schema-ref? source attr)]
    (when (not ref-ok)
      (return value false ref-error))
    (if attr-is-ref
      (db-read-source-resolve-ref-component-value source value)
      (return value true ""))))

(defn db-read-source-append-attr-value-datoms! [out: ^[dynamic]Datom, source: DB-Read-Source, attr: string, value: Value] -> [ok: bool, error: string]
  (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-clause-value-for-attr source attr value)]
    (when (not resolved-ok)
      (return false resolved-error))
    (let [values ([]Value [(value-keyword attr) resolved])
          [scan-ok scan-error] (db-read-source-append-index-datoms! out source .AVET values)]
      (when (not scan-ok)
        (return false scan-error))
      (when (> (count out^) 0)
        (return true ""))
      (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source attr)]
        (when (not datoms-ok)
          (return false datoms-error))
        (for [datom datoms]
          (when (= (index-position-compare datom.v resolved) 0)
            (arr.push! out^ (datom-owned datom))))
        (delete-owned-datoms datoms)
        (return true "")))))

(defn db-read-source-schema-unique? [source: DB-Read-Source, attr: string] -> [unique: bool, ok: bool, error: string]
  (let [[schema-e schema-ok schema-error] (db-read-source-schema-entity-for-attr source attr)]
    (when (not schema-ok)
      (return false (= schema-error "") schema-error))
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source schema-e ":db/unique")]
      (when (not datoms-ok)
        (return false false datoms-error))
      (for [datom datoms]
        (when (and (= datom.v.kind .Keyword)
                   (or (= datom.v.text ":db.unique/identity")
                       (= datom.v.text ":db.unique/value")))
          (delete-owned-datoms datoms)
          (return true true "")))
      (delete-owned-datoms datoms)
      (return false true ""))))

(defn db-read-source-schema-keyword-property [source: DB-Read-Source, entity: u64, schema-attr: string] -> [value: string, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity schema-attr)]
    (when (not datoms-ok)
      (return "" false datoms-error))
    (for [datom datoms]
      (when (= datom.v.kind .Keyword)
        (let [out (string-owned datom.v.text)]
          (delete-owned-datoms datoms)
          (return out true ""))))
    (delete-owned-datoms datoms)
    (return "" false "")))

(defn db-read-source-schema-keyword [source: DB-Read-Source, attr: string, schema-attr: string] -> [value: string, ok: bool, error: string]
  (let [[schema-e schema-ok schema-error] (db-read-source-schema-entity-for-attr source attr)]
    (when (not schema-ok)
      (return "" false schema-error))
    (db-read-source-schema-keyword-property source schema-e schema-attr)))

(defn db-read-source-schema-bool-property [source: DB-Read-Source, entity: u64, schema-attr: string] -> [value: bool, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity schema-attr)]
    (when (not datoms-ok)
      (return false false datoms-error))
    (for [datom datoms]
      (when (= datom.v.kind .Bool)
        (let [out datom.v.bool-value]
          (delete-owned-datoms datoms)
          (return out true ""))))
    (delete-owned-datoms datoms)
    (return false false "")))

(defn db-read-source-schema-bool? [source: DB-Read-Source, attr: string, schema-attr: string] -> [value: bool, ok: bool, error: string]
  (let [[schema-e schema-ok schema-error] (db-read-source-schema-entity-for-attr source attr)]
    (when (not schema-ok)
      (return false (= schema-error "") schema-error))
    (let [[bool-value bool-ok bool-error] (db-read-source-schema-bool-property source schema-e schema-attr)]
      (if bool-ok
        (return bool-value true "")
        (return false (= bool-error "") bool-error)))))

(defn db-read-source-schema-cardinality-many? [source: DB-Read-Source, attr: string] -> [many: bool, ok: bool, error: string]
  (let [[cardinality cardinality-ok cardinality-error] (db-read-source-schema-keyword source attr ":db/cardinality")]
    (when (not cardinality-ok)
      (return false (= cardinality-error "") cardinality-error))
    (let [out (= cardinality ":db.cardinality/many")]
      (delete cardinality)
      (return out true ""))))

(defn db-read-source-schema-component? [source: DB-Read-Source, attr: string] -> [component: bool, ok: bool, error: string]
  (db-read-source-schema-bool? source attr ":db/isComponent"))

(defn db-read-source-schema-ref? [source: DB-Read-Source, attr: string] -> [ref: bool, ok: bool, error: string]
  (let [[value value-ok value-error] (db-read-source-schema-keyword source attr ":db/valueType")]
    (when (not value-ok)
      (when (= value-error "")
        (return false true ""))
      (return false false value-error))
    (let [out (= value ":db.type/ref")]
      (delete value)
      (return out true ""))))

(defn db-read-source-schema-value-type [source: DB-Read-Source, attr: string] -> [schema-type: string, has-type: bool, ok: bool, error: string]
  (let [[value value-ok value-error] (db-read-source-schema-keyword source attr ":db/valueType")]
    (when (not value-ok)
      (if (= value-error "")
        (return "" false true "")
        (return "" false false value-error)))
    (return value true true "")))

(defn db-read-source-schema-ident-for-entity [source: DB-Read-Source, entity: u64] -> [attr: string, ok: bool, error: string]
  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity ":db/ident")]
    (when (not datoms-ok)
      (return "" false datoms-error))
    (for [datom datoms]
      (when (= datom.v.kind .Keyword)
        (let [out (string-owned datom.v.text)]
          (delete-owned-datoms datoms)
          (return out true ""))))
    (delete-owned-datoms datoms)
    (return "" false "")))

(defn db-read-source-resolve-attribute-value [source: DB-Read-Source, value: Value] -> [resolved: Value, ok: bool, error: string]
  (cond
    (= value.kind .Keyword) (return value true "")
    (= value.kind .Entity)
      (let [[ident ident-ok ident-error] (db-read-source-schema-ident-for-entity source value.entity)]
        (if ident-ok
          (return (value-keyword ident) true "")
          (return (Value {}) false ident-error)))
    (and (= value.kind .Int) (>= value.int-value 0))
      (let [[ident ident-ok ident-error] (db-read-source-schema-ident-for-entity source (u64 value.int-value))]
        (if ident-ok
          (return (value-keyword ident) true "")
          (return (Value {}) false ident-error)))
    :else (return value true "")))

(defn db-read-source-schema-tuple-attrs [source: DB-Read-Source, attr: string] -> [attrs: [dynamic]string, ok: bool, error: string]
  (let [out (make [dynamic]string)
        [schema-e schema-ok schema-error] (db-read-source-schema-entity-for-attr source attr)]
    (when (not schema-ok)
      (return out (= schema-error "") schema-error))
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source schema-e ":db/tupleAttrs")]
      (when (not datoms-ok)
        (delete out)
        (return (make [dynamic]string) false datoms-error))
      (for [datom datoms]
        (when (= datom.v.kind .Vector)
          (for [item datom.v.items]
            (when (= item.kind .Keyword)
              (arr.push! out (string-owned item.text))))))
      (delete-owned-datoms datoms)
      (return out true ""))))

(defn db-read-source-tuple-schemas-containing [source: DB-Read-Source, attr: string] -> [schemas: [dynamic]Tuple-Schema, ok: bool, error: string]
  (let [out (make [dynamic]Tuple-Schema)
        [datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source ":db/tupleAttrs")]
    (when (not datoms-ok)
      (return out false datoms-error))
    (for [datom datoms]
      (let [[tuple-attr ident-ok ident-error] (db-read-source-schema-ident-for-entity source datom.e)]
        (when (not ident-ok)
          (when (not (= ident-error ""))
            (delete-owned-datoms datoms)
            (for [schema out]
              (delete schema.attr)
              (delete schema.attrs))
            (delete out)
            (return (make [dynamic]Tuple-Schema) false ident-error))
          (continue))
        (let [[attrs attrs-ok attrs-error] (db-read-source-schema-tuple-attrs source tuple-attr)]
          (when (not attrs-ok)
            (delete tuple-attr)
            (delete-owned-datoms datoms)
            (for [schema out]
              (delete schema.attr)
              (delete schema.attrs))
            (delete out)
            (return (make [dynamic]Tuple-Schema) false attrs-error))
          (let [schema (Tuple-Schema {attr: tuple-attr attrs: attrs})]
            (if (tuple-schema-contains? schema attr)
              (arr.push! out schema)
              (do
                (delete tuple-attr)
                (delete attrs)))))))
    (delete-owned-datoms datoms)
    (return out true "")))

(defn db-read-source-resolve-ref-component-value [source: DB-Read-Source, value: Value] -> [resolved: Value, ok: bool, error: string]
  (cond
    (= value.kind .Entity) (return value true "")
    (= value.kind .Int) (return (value-entity (u64 value.int-value)) true "")
    (= value.kind .Keyword)
      (let [[entity ident-ok ident-error] (db-read-source-schema-entity-for-attr source value.text)]
        (cond
          ident-ok (return (value-entity entity) true "")
          (not (= ident-error "")) (return value false ident-error)
          :else (return value false "ident not found")))
    (and (= value.kind .Vector)
         (= (count value.items) 2)
         (= value.items[0].kind .Keyword))
      (let [[entity entity-ok lookup-error] (db-read-source-resolve-lookup-ref source value.items[0].text value.items[1])]
        (if entity-ok
          (return (value-entity entity) true "")
          (return value false lookup-error)))
    :else (return value true "")))

(defn db-read-source-resolve-tuple-value [source: DB-Read-Source, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (when (not (= value.kind .Vector))
    (return value true ""))
  (let [[tuple-attrs tuple-ok tuple-error] (db-read-source-schema-tuple-attrs source attr)]
    (when (not tuple-ok)
      (return value false tuple-error))
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return value true ""))
    (when (not (= (count tuple-attrs) (count value.items)))
      (return value true ""))
    (let [items (make [dynamic]Value 0 (count value.items))]
      (defer (delete items))
      (for [item index value.items]
        (let [component-attr tuple-attrs[index]
              [component-ref component-ref-ok component-ref-error] (db-read-source-schema-ref? source component-attr)]
          (when (not component-ref-ok)
            (return value false component-ref-error))
          (if component-ref
            (let [[resolved-component resolved-ok resolved-error] (db-read-source-resolve-ref-component-value source item)]
              (when (not resolved-ok)
                (return value false resolved-error))
              (arr.push! items resolved-component))
            (arr.push! items item))))
      (return (value-vector (slice items 0)) true ""))))

(defn db-read-source-resolve-lookup-ref [source: DB-Read-Source, attr: string, value: Value] -> [entity: u64, ok: bool, error: string]
  (when (and (= attr ":db/ident")
             (= value.kind .Keyword))
    (return (db-read-source-schema-entity-for-attr source value.text)))
  (let [[unique unique-ok unique-error] (db-read-source-schema-unique? source attr)]
    (when (not unique-ok)
      (return 0 false unique-error))
    (when (not unique)
      (return 0 false "lookup ref attribute must be unique")))
  (let [[lookup-value resolved-ok resolved-error] (db-read-source-resolve-tuple-value source attr value)]
    (when (not resolved-ok)
      (return 0 false resolved-error))
  (let [out (make [dynamic]Datom)
        values ([]Value [(value-keyword attr) lookup-value])
        [scan-ok scan-error] (db-read-source-append-index-datoms! (addr out) source .AVET values)]
    (when (not scan-ok)
      (delete-owned-datoms out)
      (return 0 false scan-error))
    (when (> (count out) 0)
      (let [entity out[0].e]
        (delete-owned-datoms out)
        (return entity true "")))
    (delete-owned-datoms out)
    (return 0 false ""))))

(defn db-read-source-resolve-entity-term [source: DB-Read-Source, term: Term, binding: Binding] -> [value: Value, ok: bool, error: string]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok lookup-error] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
      (if lookup-ok
        (return (value-entity entity) true "")
        (return (Value {}) false lookup-error))))
  (let [[resolved resolved-ok] (db-read-source-term-resolved-value term binding)]
    (when (not resolved-ok)
      (return (Value {}) false ""))
    (let [[lookup-attr lookup-value lookup-ok] (value-lookup-ref-parts resolved)]
      (when lookup-ok
        (let [[entity lookup-found lookup-error] (db-read-source-resolve-lookup-ref source lookup-attr lookup-value)]
          (if lookup-found
            (return (value-entity entity) true "")
            (return (Value {}) false lookup-error)))))
    (cond
      (= resolved.kind .Entity) (return resolved true "")
      (= resolved.kind .Int) (return (value-entity (u64 resolved.int-value)) true "")
      (= resolved.kind .Keyword)
        (let [[entity ident-ok ident-error] (db-read-source-schema-entity-for-attr source resolved.text)]
          (cond
            ident-ok (return (value-entity entity) true "")
            (not (= ident-error "")) (return (Value {}) false ident-error)
            :else (return resolved false "")))
      :else (return resolved false ""))))

(defn db-read-source-pull-attr-value [source: DB-Read-Source, entity: u64, attr: string] -> [value: Value, ok: bool, error: string]
  (if (reverse-attr? attr)
    (let [forward (forward-attr-for-reverse attr) :defer
          [datoms datoms-ok datoms-error] (db-read-source-datoms-by-reverse-entity-attr source entity forward)]
      (when (not datoms-ok)
        (return (Value {}) false datoms-error))
      (when (> (count datoms) 0)
        (let [value (value-entity datoms[0].e)]
          (delete-owned-datoms datoms)
          (return value true "")))
      (delete-owned-datoms datoms)
      (return (Value {}) false ""))
    (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity attr)]
      (when (not datoms-ok)
        (return (Value {}) false datoms-error))
      (when (> (count datoms) 0)
        (let [value (value-owned datoms[0].v)]
          (delete-owned-datoms datoms)
          (return value true "")))
      (delete-owned-datoms datoms)
      (return (Value {}) false ""))))

(defn db-read-source-term-constant-value [term: Term] -> [value: Value, ok: bool]
  (if (= term.kind .Value)
    (return term.value true)
    (return (Value {}) false)))

(defn db-read-source-term-resolved-value [term: Term, binding: Binding] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (binding-lookup binding term.name)
     (return (Value {}) false)))

(defn db-read-source-query-relation-resolve-typed-term [rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (query-relation-typed-row-value rel row term.name))
     (return (Value {}) false)))

(defn db-read-source-query-relation-resolve-typed-entity-term [source: DB-Read-Source, rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool, error: string]
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok lookup-error] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
      (if lookup-ok
        (return (value-entity entity) true "")
        (return (Value {}) false lookup-error))))
  (let [[resolved resolved-ok] (db-read-source-query-relation-resolve-typed-term rel row term)]
    (when (not resolved-ok)
      (return (Value {}) false ""))
    (let [[lookup-attr lookup-value lookup-ok] (value-lookup-ref-parts resolved)]
      (when lookup-ok
        (let [[entity lookup-found lookup-error] (db-read-source-resolve-lookup-ref source lookup-attr lookup-value)]
          (if lookup-found
            (return (value-entity entity) true "")
            (return (Value {}) false lookup-error)))))
    (cond
      (= resolved.kind .Entity) (return resolved true "")
      (= resolved.kind .Int) (return (value-entity (u64 resolved.int-value)) true "")
      (= resolved.kind .Keyword)
        (let [[entity ident-ok ident-error] (db-read-source-schema-entity-for-attr source resolved.text)]
          (cond
            ident-ok (return (value-entity entity) true "")
            (not (= ident-error "")) (return (Value {}) false ident-error)
            :else (return resolved false "")))
      :else (return resolved false ""))))

(defn db-read-source-empty-clause-index-scan [source: DB-Read-Source] -> Clause-Index-Scan
  (Clause-Index-Scan {view: (db-read-source-index-view source .EAVT)
                      index: 0
                      high: 0
                      e-value: (Value {})
                      e-ok: false
                      a-value: (Value {})
                      a-ok: false
                      v-value: (Value {})
                      v-ok: false
                      reverse-attr: false
                      forward-attr: ""}))

(defn db-read-source-prefix-index-range [source: DB-Read-Source, order: Public-Index-Order, values: []Value] -> [view: DB-Index-View, low: int, high: int, ok: bool, error: string]
  (let [index-view (db-read-source-index-view source order)
        [lower lower-ok lower-error] (db-read-source-lower-bound-values source index-view values)]
    (when (not lower-ok)
      (return index-view 0 0 false lower-error))
    (let [[upper upper-ok upper-error] (db-read-source-upper-bound-values source index-view values)]
      (when (not upper-ok)
        (return index-view lower lower false upper-error))
      (return index-view lower upper true ""))))

(defn db-read-source-clause-index-range-from-physical-prefix [source: DB-Read-Source, range: Physical-Scan-Range, values: []Value] -> [view: DB-Index-View, low: int, high: int, ok: bool, error: string]
  (let [index-view (db-read-source-index-view source range.order)]
    (case range.kind
      .Full
        (return index-view 0 (db-index-view-count index-view) true "")
      .Entity
        (do
          (when (or (not (= (count values) 1))
                    (not (= values[0].kind .Entity)))
            (return index-view 0 0 false ""))
          (db-read-source-prefix-index-range source range.order values))
      .Attr
        (do
          (when (or (not (= (count values) 1))
                    (not (= values[0].kind .Keyword)))
            (return index-view 0 0 false ""))
          (db-read-source-prefix-index-range source range.order values))
      .Value
        (do
          (when (not (= (count values) 1))
            (return index-view 0 0 false ""))
          (db-read-source-prefix-index-range source range.order values))
      .EntityAttr
        (do
          (when (or (not (= (count values) 2))
                    (not (= values[0].kind .Entity))
                    (not (= values[1].kind .Keyword)))
            (return index-view 0 0 false ""))
          (db-read-source-prefix-index-range source range.order values))
      .AttrValue
        (do
          (when (or (not (= (count values) 2))
                    (not (= values[0].kind .Keyword)))
            (return index-view 0 0 false ""))
          (db-read-source-prefix-index-range source range.order values))

      (return index-view 0 0 false ""))))

(defn db-read-source-clause-index-scan-resolved [source: DB-Read-Source, clause: Clause, e-value-in: Value, e-ok: bool, a-value-in: Value, a-ok-in: bool, v-value-in: Value, v-ok-in: bool, reverse-source-value: Value, reverse-source-ok: bool] -> [scan: Clause-Index-Scan, ok: bool, error: string]
  (let [a-value a-value-in
        a-ok a-ok-in
        v-value v-value-in
        v-ok v-ok-in
        view (db-read-source-index-view source .EAVT)
        low 0
        high (db-index-view-count view)]
    (when a-ok
      (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-attribute-value source a-value)]
        (when (not resolved-ok)
          (return (db-read-source-empty-clause-index-scan source) (= resolved-error "") resolved-error))
        (set! a-value resolved)))
    (when (= clause.v.kind .LookupRef)
      (let [[lookup-entity lookup-ok lookup-error] (db-read-source-resolve-lookup-ref source clause.v.lookup-attr clause.v.lookup-value)]
        (when (not (= lookup-error ""))
          (return (db-read-source-empty-clause-index-scan source) false lookup-error))
        (when lookup-ok
          (set! v-value (value-entity lookup-entity))
          (set! v-ok true))))
    (when (and a-ok
               v-ok
               (= a-value.kind .Keyword))
      (let [[attr-is-ref ref-ok ref-error] (db-read-source-schema-ref? source a-value.text)]
        (when (not ref-ok)
          (return (db-read-source-empty-clause-index-scan source) false ref-error))
        (when attr-is-ref
          (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-ref-component-value source v-value)]
            (when (not resolved-ok)
              (return (db-read-source-empty-clause-index-scan source) false resolved-error))
            (set! v-value resolved)))))
    (when (and a-ok
               (= a-value.kind .Keyword)
               (reverse-attr? a-value.text))
      (let [forward-attr (forward-attr-for-reverse a-value.text) :defer]
        (when reverse-source-ok
          (set! v-value reverse-source-value)
          (set! v-ok true))
        (when (and e-ok (not (= e-value-in.kind .Entity)))
          (return (db-read-source-empty-clause-index-scan source) true ""))
        (when (and v-ok (not (= v-value.kind .Entity)))
          (return (db-read-source-empty-clause-index-scan source) true ""))
        (let [range (physical-reverse-scan-range-from-resolved-flags e-ok v-ok)]
          (case range.kind
            .Value
              (let [values ([]Value [(value-entity e-value-in.entity)])
                    [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
                (when (not range-ok)
                  (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))
            .EntityAttr
              (let [values ([]Value [(value-entity v-value.entity) (value-keyword forward-attr)])
                    [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
                (when (not range-ok)
                  (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))
            .Attr
              (let [values ([]Value [(value-keyword forward-attr)])
                    [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
                (when (not range-ok)
                  (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))

              (return (db-read-source-empty-clause-index-scan source) true "")))
        (return (Clause-Index-Scan {view: view
                                    index: low
                                    high: high
                                    e-value: e-value-in
                                    e-ok: e-ok
                                    a-value: a-value
                                    a-ok: a-ok
                                    v-value: v-value
                                    v-ok: v-ok
                                    reverse-attr: true
                                    forward-attr: (forward-attr-for-reverse a-value.text)}) true "")))
    (when (and v-ok
               (= clause.v.kind .Var)
               (= v-value.kind .Entity))
      (set! v-ok false))
    (let [range (physical-scan-range-from-resolved-flags e-ok a-ok v-ok)]
      (case range.kind
        .Full
          (do)
        .Entity
          (let [values ([]Value [e-value-in])
                [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
            (when (not range-ok)
              (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .Attr
          (let [values ([]Value [a-value])
                [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
            (when (not range-ok)
              (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .Value
          (let [values ([]Value [v-value])
                [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
            (when (not range-ok)
              (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .EntityAttr
          (let [values ([]Value [e-value-in a-value])
                [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
            (when (not range-ok)
              (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .AttrValue
          (let [values ([]Value [a-value v-value])
                [candidate-view candidate-low candidate-high range-ok range-error] (db-read-source-clause-index-range-from-physical-prefix source range values)]
            (when (not range-ok)
              (return (db-read-source-empty-clause-index-scan source) (= range-error "") range-error))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))

          (do)))
    (return (Clause-Index-Scan {view: view
                                index: low
                                high: high
                                e-value: e-value-in
                                e-ok: e-ok
                                a-value: a-value
                                a-ok: a-ok
                                v-value: v-value
                                v-ok: v-ok
                                reverse-attr: false
                                forward-attr: ""}) true "")))

(defn db-read-source-clause-index-scan [source: DB-Read-Source, clause: Clause, binding: Binding] -> [scan: Clause-Index-Scan, ok: bool, error: string]
  (let [[e-value e-ok e-error] (db-read-source-resolve-entity-term source clause.e binding)]
    (when (not (= e-error ""))
      (return (db-read-source-empty-clause-index-scan source) false e-error))
    (let [[a-value a-ok] (db-read-source-term-resolved-value clause.a binding)
          [v-value v-ok] (db-read-source-term-resolved-value clause.v binding)
          [reverse-source-value reverse-source-ok reverse-source-error] (db-read-source-resolve-entity-term source clause.v binding)]
      (when (not (= reverse-source-error ""))
        (return (db-read-source-empty-clause-index-scan source) false reverse-source-error))
      (db-read-source-clause-index-scan-resolved source clause e-value e-ok a-value a-ok v-value v-ok reverse-source-value reverse-source-ok))))

(defn db-read-source-clause-index-scan-typed-row [source: DB-Read-Source, rel: Query-Relation, row: int, clause: Clause] -> [scan: Clause-Index-Scan, ok: bool, error: string]
  (let [[e-value e-ok e-error] (db-read-source-query-relation-resolve-typed-entity-term source rel row clause.e)]
    (when (not (= e-error ""))
      (return (db-read-source-empty-clause-index-scan source) false e-error))
    (let [[a-value a-ok] (db-read-source-query-relation-resolve-typed-term rel row clause.a)
          [v-value v-ok] (db-read-source-query-relation-resolve-typed-term rel row clause.v)
          [reverse-source-value reverse-source-ok reverse-source-error] (db-read-source-query-relation-resolve-typed-entity-term source rel row clause.v)]
      (when (not (= reverse-source-error ""))
        (return (db-read-source-empty-clause-index-scan source) false reverse-source-error))
      (db-read-source-clause-index-scan-resolved source clause e-value e-ok a-value a-ok v-value v-ok reverse-source-value reverse-source-ok))))

(defn db-read-source-clause-candidates-for-binding [source: DB-Read-Source, clause-value: Clause, binding: Binding] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [[scan scan-ok scan-error] (db-read-source-clause-index-scan source clause-value binding)]
    (when (not scan-ok)
      (delete-clause-index-scan scan)
      (return (make [dynamic]Datom) false scan-error))
    (defer (delete-clause-index-scan scan))
    (when (= source.kind .Tx-Ops-Overlay)
      (let [[out base-ok base-error] (db-read-source-clause-candidates-for-binding source.overlay-base^ clause-value binding)]
        (when (not base-ok)
          (return out false base-error))
        (db-read-source-apply-overlay-ops-for-clause-scan! (addr out) source scan)
        (return out true "")))
    (let [out (make [dynamic]Datom)
          scan-index scan.index]
      (while (< scan-index scan.high)
        (let [entry (clause-index-scan-datom-index scan scan-index)
              [datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
          (when (not datom-ok)
            (delete-owned-datoms out)
            (return (make [dynamic]Datom) false datom-error))
          (if (db-read-source-clause-index-scan-candidate? scan datom)
            (let [[current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
              (when (not current-ok)
                (delete-owned-datom datom)
                (delete-owned-datoms out)
                (return (make [dynamic]Datom) false current-error))
              (if current
                (arr.push! out datom)
                (delete-owned-datom datom)))
            (delete-owned-datom datom)))
        (set! scan-index (+ scan-index 1)))
      (when (db-read-source-has-inline-overlay? source)
        (db-read-source-apply-inline-overlay-for-clause-scan! (addr out) source scan))
      (return out true ""))))

(defn db-read-source-clause-candidates [source: DB-Read-Source, clause-value: Clause] -> [datoms: [dynamic]Datom, ok: bool, error: string]
  (let [binding (Binding {items: (make [dynamic]Var-Binding)})
        [datoms datoms-ok datoms-error] (db-read-source-clause-candidates-for-binding source clause-value binding)]
    (delete binding.items)
    (return datoms datoms-ok datoms-error)))

(defn db-read-source-term-matches-datom-value? [term: Term, value: Value] -> bool
  (case term.kind
    .Value (predicate-value-equal? term.value value)
    .Wildcard true
    .Var true
     false))

(defn db-read-source-clause-datom-matches? [clause-value: Clause, datom: Datom] -> bool
  (and (db-read-source-term-matches-datom-value? clause-value.e (value-entity datom.e))
       (db-read-source-term-matches-datom-value? clause-value.a (value-keyword datom.a))
       (db-read-source-term-matches-datom-value? clause-value.v datom.v)))

(defn db-read-source-value-for-find-var [clause-value: Clause, datom: Datom, name: string] -> [value: Value, ok: bool]
  (cond
    (and (= clause-value.e.kind .Var) (= clause-value.e.name name)) (return (value-entity datom.e) true)
    (and (= clause-value.a.kind .Var) (= clause-value.a.name name)) (return (value-keyword (string-owned datom.a)) true)
    (and (= clause-value.v.kind .Var) (= clause-value.v.name name)) (return (value-owned datom.v) true)
    :else (return (Value {}) false)))

(defn db-read-source-clone-binding-owned [binding: Binding] -> Binding
  (let [items (make [dynamic]Var-Binding 0 (count binding.items))]
    (for [item binding.items]
      (arr.push! items (Var-Binding {name: item.name value: (value-owned item.value)})))
    (Binding {items: items})))

(defn db-read-source-delete-binding-owned [binding: Binding]
  (for [item binding.items]
    (delete-owned-value item.value))
  (delete binding.items))

(defn db-read-source-delete-bindings-owned [bindings: [dynamic]Binding]
  (for [binding bindings]
    (db-read-source-delete-binding-owned binding))
  (delete bindings))

(defn delete-bindings-shallow [bindings: [dynamic]Binding]
  (for [binding bindings]
    (delete binding.items))
  (delete bindings))

(defn db-read-source-project-binding-owned [binding: Binding, names: []string] -> Binding
  (let [items (make [dynamic]Var-Binding)]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (when ok
          (arr.push! items (Var-Binding {name: name value: (value-owned value)})))))
    (Binding {items: items})))

(defn db-read-source-merge-binding-owned [base: Binding, extra: Binding] -> [binding: Binding, ok: bool]
  (let [out (db-read-source-clone-binding-owned base)]
    (for [item extra.items]
      (let [[existing exists] (binding-lookup out item.name)]
        (if exists
          (when (not (predicate-value-equal? existing item.value))
            (db-read-source-delete-binding-owned out)
            (return (Binding {}) false))
          (binding-store! (addr out) item.name (value-owned item.value)))))
    (return out true)))

(defn db-read-source-binding-match-owned! [binding: ^Binding, term: Term, value: Value] -> bool
  (case term.kind
    .Value
      (let [matched (= (index-position-compare value term.value) 0)]
        (delete-owned-value value)
        matched)
    .Wildcard
      (do
        (delete-owned-value value)
        true)
    .Var
      (let [[existing exists] (binding-lookup binding^ term.name)]
        (if exists
          (let [matched (predicate-value-equal? existing value)]
            (delete-owned-value value)
            matched)
          (do
            (binding-store! binding term.name value)
            true)))

      (do
        (delete-owned-value value)
        false)))

(defn db-read-source-binding-match-clause-owned! [source: DB-Read-Source, binding: ^Binding, term: Term, value: Value] -> bool
  (cond
    (= term.kind .LookupRef)
      (let [[entity entity-ok _] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
        (let [matched (and entity-ok (= (index-position-compare value (value-entity entity)) 0))]
          (delete-owned-value value)
          matched))
    (and (= term.kind .Value)
         (= value.kind .Entity))
      (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source term.value)
            matched (and resolved-ok (= (index-position-compare value resolved) 0))]
        (delete-owned-value value)
        matched)
    (and (= term.kind .Var)
         (= value.kind .Entity))
      (let [[existing exists] (binding-lookup binding^ term.name)]
        (if exists
          (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source existing)
                matched (and resolved-ok (= (index-position-compare value resolved) 0))]
            (delete-owned-value value)
            matched)
          (do
            (binding-store! binding term.name value)
            true)))
    :else (db-read-source-binding-match-owned! binding term value)))

(defn db-read-source-binding-match-borrowed! [binding: ^Binding, term: Term, value: Value] -> bool
  (case term.kind
    .Value (= (index-position-compare value term.value) 0)
    .Wildcard true
    .Var
      (let [[existing exists] (binding-lookup binding^ term.name)]
        (if exists
          (predicate-value-equal? existing value)
          (do
            (binding-store! binding term.name (value-owned value))
            true)))
     false))

(defn db-read-source-binding-match-attr-borrowed! [source: DB-Read-Source, binding: ^Binding, term: Term, value: Value] -> bool
  (when (= term.kind .Value)
    (let [[resolved resolved-ok _] (db-read-source-resolve-attribute-value source term.value)]
      (return (and resolved-ok (= (index-position-compare value resolved) 0)))))
  (db-read-source-binding-match-borrowed! binding term value))

(defn db-read-source-binding-match-clause-borrowed! [source: DB-Read-Source, binding: ^Binding, term: Term, value: Value] -> bool
  (cond
    (= term.kind .LookupRef)
      (let [[entity entity-ok _] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
        (and entity-ok (= (index-position-compare value (value-entity entity)) 0)))
    (and (= term.kind .Value)
         (= value.kind .Entity))
      (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source term.value)]
        (and resolved-ok (= (index-position-compare value resolved) 0)))
    (and (= term.kind .Var)
         (= value.kind .Entity))
      (let [[existing exists] (binding-lookup binding^ term.name)]
        (if exists
          (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source existing)]
            (and resolved-ok (= (index-position-compare value resolved) 0)))
          (do
            (binding-store! binding term.name (value-owned value))
            true)))
    :else (db-read-source-binding-match-borrowed! binding term value)))

(defn db-read-source-binding-match-entity-borrowed! [source: DB-Read-Source, binding: ^Binding, term: Term, value: Value] -> bool
  (case term.kind
    .Value
      (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source term.value)]
        (and resolved-ok (= (index-position-compare value resolved) 0)))
    .LookupRef
      (let [[entity entity-ok _] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
        (and entity-ok (= (index-position-compare value (value-entity entity)) 0)))
    .Wildcard true
    .Var
      (let [[existing exists] (binding-lookup binding^ term.name)]
        (if exists
          (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source existing)]
            (and resolved-ok (= (index-position-compare value resolved) 0)))
          (do
            (binding-store! binding term.name (value-owned value))
            true)))
     false))

(defn db-read-source-clause-index-value-matches? [actual: Value, expected: Value] -> bool
  (= (index-position-compare actual expected) 0))

(defn db-read-source-clause-index-scan-candidate? [scan: Clause-Index-Scan, datom: Datom] -> bool
  (if scan.reverse-attr
    (and (= datom.a scan.forward-attr)
         (= datom.v.kind .Entity))
    (do
      (when scan.e-ok
        (when (not (db-read-source-clause-index-value-matches? (value-entity datom.e) scan.e-value))
          (return false)))
      (when scan.a-ok
        (when (not (db-read-source-clause-index-value-matches? (value-keyword datom.a) scan.a-value))
          (return false)))
      (when scan.v-ok
        (when (not (db-read-source-clause-index-value-matches? datom.v scan.v-value))
          (return false)))
      true)))

(defn db-read-source-apply-overlay-ops-for-clause-scan! [out: ^[dynamic]Datom, source: DB-Read-Source, scan: Clause-Index-Scan]
  (when (db-read-source-filter-allows-tx? source source.overlay-tx)
    (for [op source.overlay-ops^]
      (let [candidate (Datom {e: op.e
                              a: op.a
                              v: op.v
                              tx: source.overlay-tx
                              added: (= op.kind .Add)})]
        (when (db-read-source-clause-index-scan-candidate? scan candidate)
          (if source.filter-history
            (append-owned-log-datom-from-tx-op! out op source.overlay-tx)
            (do
              (remove-datom-fact! out op.e op.a op.v)
              (when (= op.kind .Add)
                (append-owned-datom-from-tx-op! out op source.overlay-tx)))))))))

(defn db-read-source-apply-overlay-datoms-for-clause-scan! [out: ^[dynamic]Datom, source: DB-Read-Source, scan: Clause-Index-Scan]
  (for [datom source.overlay-datoms^]
    (when (and (db-read-source-filter-allows-tx? source datom.tx)
               (db-read-source-clause-index-scan-candidate? scan datom))
      (if source.filter-history
        (arr.push! out^ (datom-owned datom))
        (do
          (remove-datom-fact! out datom.e datom.a datom.v)
          (when datom.added
            (arr.push! out^ (datom-owned datom))))))))

(defn db-read-source-apply-overlay-log-for-clause-scan! [out: ^[dynamic]Datom, source: DB-Read-Source, scan: Clause-Index-Scan]
  (for [index (arr.range 0 source.overlay-log^.count)]
    (let [[datom datom-ok] (shared-datom-log-at source.overlay-log^ index)]
      (when datom-ok
        (if (and (db-read-source-filter-allows-tx? source datom.tx)
                 (db-read-source-clause-index-scan-candidate? scan datom))
          (do
            (if source.filter-history
              (arr.push! out^ datom)
              (do
                (remove-datom-fact! out datom.e datom.a datom.v)
                (if datom.added
                  (arr.push! out^ datom)
                  (delete-owned-datom datom)))))
          (delete-owned-datom datom))))))

(defn db-read-source-apply-inline-overlay-for-clause-scan! [out: ^[dynamic]Datom, source: DB-Read-Source, scan: Clause-Index-Scan]
  (case source.kind
    .Shared-Datom-Overlay (db-read-source-apply-overlay-datoms-for-clause-scan! out source scan)
    .SQLite-Datom-Overlay (db-read-source-apply-overlay-datoms-for-clause-scan! out source scan)
    .Shared-Datom-Log-Overlay (db-read-source-apply-overlay-log-for-clause-scan! out source scan)
    .SQLite-Datom-Log-Overlay (db-read-source-apply-overlay-log-for-clause-scan! out source scan)
     (db-read-source-apply-overlay-ops-for-clause-scan! out source scan)))

(defn db-read-source-binding-match-optional-owned! [binding: ^Binding, term: Term, value: Value] -> bool
  (if (omitted-term? term)
    (do
      (delete-owned-value value)
      true)
    (db-read-source-binding-match-owned! binding term value)))

(defn db-read-source-binding-match-optional-borrowed! [binding: ^Binding, term: Term, value: Value] -> bool
  (if (omitted-term? term)
    true
    (db-read-source-binding-match-borrowed! binding term value)))

(defn db-read-source-source-row-term-matches! [binding: ^Binding, term: Term, actual: Value] -> bool
  (db-read-source-binding-match-borrowed! binding term actual))

(defn relation-source-width-for-clause [clause: Clause] -> int
  (when (> clause.source-width 0)
    (return clause.source-width))
  (if (= clause.v.kind .Wildcard)
    2
    (if (not (= clause.op-term.kind .Wildcard))
      5
      (if (not (= clause.tx-term.kind .Wildcard))
        4
        3))))

(defn clause-with-relation-source-width [clause: Clause] -> Clause
  (when (> clause.source-width 0)
    (return clause))
  (let [out clause]
    (set! out.source-width (relation-source-width-for-clause clause))
    out))

(defn db-read-source-source-row-matches? [clause: Clause, row: Value, binding: ^Binding] -> bool
  (when (and (= clause.source-width 1)
             (not (= row.kind .Vector)))
    (return (db-read-source-source-row-term-matches! binding clause.e row)))
  (when (not (= row.kind .Vector))
    (return false))
  (when (not (= (count row.items) clause.source-width))
    (return false))
  (when (= clause.source-width 1)
    (return (db-read-source-source-row-term-matches! binding clause.e row.items[0])))
  (when (= clause.source-width 2)
    (return
      (and (db-read-source-source-row-term-matches! binding clause.e row.items[0])
           (db-read-source-source-row-term-matches! binding clause.a row.items[1]))))
  (when (not (and (db-read-source-source-row-term-matches! binding clause.e row.items[0])
                  (db-read-source-source-row-term-matches! binding clause.a row.items[1])
                  (db-read-source-source-row-term-matches! binding clause.v row.items[2])))
    (return false))
  (when (= clause.source-width 3)
    (return true))
  (when (not (db-read-source-source-row-term-matches! binding clause.tx-term row.items[3]))
    (return false))
  (when (= clause.source-width 4)
    (return true))
  (db-read-source-source-row-term-matches! binding clause.op-term row.items[4]))

(defn db-read-source-bindings-after-relation-value-clause [source-value: Value, input-bindings: []Binding, clause-value: Clause] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        source-clause (clause-with-relation-source-width clause-value)]
    (when (not (= source-value.kind .Vector))
      (return out))
    (for [binding input-bindings]
      (for [row source-value.items]
        (let [next (db-read-source-clone-binding-owned binding)]
          (if (db-read-source-source-row-matches? source-clause row (addr next))
            (arr.push! out next)
            (db-read-source-delete-binding-owned next)))))
    out))

(defn db-read-source-binding-after-clause-datom [source: DB-Read-Source, binding: Binding, clause-value: Clause, datom: Datom] -> [out-binding: Binding, ok: bool]
  (let [candidate-binding (db-read-source-clone-binding-owned binding)]
    (when (and (= clause-value.a.kind .Value)
               (= clause-value.a.value.kind .Keyword)
               (reverse-attr? clause-value.a.value.text))
      (when (not (= datom.v.kind .Entity))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (when (not (db-read-source-binding-match-entity-borrowed! source (addr candidate-binding) clause-value.e (value-entity datom.v.entity)))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (when (not (db-read-source-binding-match-borrowed! (addr candidate-binding) clause-value.a (value-keyword clause-value.a.value.text)))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (when (not (db-read-source-binding-match-entity-borrowed! source (addr candidate-binding) clause-value.v (value-entity datom.e)))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (when (not (db-read-source-binding-match-optional-borrowed! (addr candidate-binding) clause-value.tx-term (datom-tx-value datom)))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (when (not (db-read-source-binding-match-optional-borrowed! (addr candidate-binding) clause-value.op-term (value-bool datom.added)))
        (db-read-source-delete-binding-owned candidate-binding)
        (return (Binding {}) false))
      (return candidate-binding true))
    (when (not (db-read-source-binding-match-entity-borrowed! source (addr candidate-binding) clause-value.e (value-entity datom.e)))
      (db-read-source-delete-binding-owned candidate-binding)
      (return (Binding {}) false))
    (when (not (db-read-source-binding-match-attr-borrowed! source (addr candidate-binding) clause-value.a (value-keyword datom.a)))
      (db-read-source-delete-binding-owned candidate-binding)
      (return (Binding {}) false))
    (when (not (db-read-source-binding-match-clause-borrowed! source (addr candidate-binding) clause-value.v datom.v))
      (db-read-source-delete-binding-owned candidate-binding)
      (return (Binding {}) false))
    (when (not (db-read-source-binding-match-optional-borrowed! (addr candidate-binding) clause-value.tx-term (datom-tx-value datom)))
      (db-read-source-delete-binding-owned candidate-binding)
      (return (Binding {}) false))
    (when (not (db-read-source-binding-match-optional-borrowed! (addr candidate-binding) clause-value.op-term (value-bool datom.added)))
      (db-read-source-delete-binding-owned candidate-binding)
      (return (Binding {}) false))
    (return candidate-binding true)))

(defn db-read-source-bindings-after-clause [source: DB-Read-Source, input-bindings: []Binding, clause-value: Clause] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (when (= source.kind .Relation-Value)
    (return (db-read-source-bindings-after-relation-value-clause source.relation-value^ input-bindings clause-value) true ""))
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (if (db-read-source-has-overlay? source)
        (let [[datoms datoms-ok datoms-error] (db-read-source-clause-candidates-for-binding source clause-value binding)]
          (when (not datoms-ok)
            (db-read-source-delete-bindings-owned out)
            (return (make [dynamic]Binding) false datoms-error))
          (for [datom datoms]
            (let [[next next-ok] (db-read-source-binding-after-clause-datom source binding clause-value datom)]
              (when next-ok
                (arr.push! out next))))
          (delete-owned-datoms datoms))
        (let [[stream stream-ok stream-error] (source-clause-datom-stream-for-binding source clause-value binding)]
          (when (not stream-ok)
            (db-read-source-delete-bindings-owned out)
            (return (make [dynamic]Binding) false stream-error))
          (while stream.has-current
            (let [[next next-ok] (db-read-source-binding-after-clause-datom source binding clause-value stream.current)]
              (when next-ok
                (arr.push! out next)))
            (let [[advance-ok advance-error] (advance-source-clause-datom-stream! source (addr stream))]
              (when (not advance-ok)
                (delete-source-clause-datom-stream stream)
                (db-read-source-delete-bindings-owned out)
                (return (make [dynamic]Binding) false advance-error))))
          (delete-source-clause-datom-stream stream))))
    (return out true "")))

(defn db-read-source-bindings-after-predicate [input-bindings: []Binding, predicate: Predicate] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (when (predicate-matches? predicate binding)
        (arr.push! out (db-read-source-clone-binding-owned binding))))
    out))

(defn db-read-source-binding-with-owned-value [binding: Binding, name: string, value: Value] -> [next: Binding, ok: bool]
  (let [out (db-read-source-clone-binding-owned binding)
        [existing exists] (binding-lookup out name)]
    (if exists
      (let [matched (predicate-value-equal? existing value)]
        (delete-owned-value value)
        (when (not matched)
          (db-read-source-delete-binding-owned out))
        (return out matched))
      (do
        (binding-store! (addr out) name value)
        (return out true)))))

(defn db-read-source-bind-input-pattern-owned [binding: Binding, pattern: Input-Binding, value: Value] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (case pattern.kind
      .Ignore (arr.push! out (db-read-source-clone-binding-owned binding))
      .None (arr.push! out (db-read-source-clone-binding-owned binding))
      .Var
        (let [owned-value (value-owned value)
              [next ok] (db-read-source-binding-with-owned-value binding pattern.name owned-value)]
          (when ok
            (arr.push! out next)))
      .Tuple
        (when (and (= value.kind .Vector)
                   (= (count pattern.items) (count value.items)))
          (let [current (make [dynamic]Binding)]
            (arr.push! current (db-read-source-clone-binding-owned binding))
            (for [item index pattern.items]
              (let [next-current (make [dynamic]Binding)]
                (for [candidate current]
                  (let [bound (db-read-source-bind-input-pattern-owned candidate item value.items[index])]
                    (for [bound-item bound]
                      (arr.push! next-current bound-item))
                    (delete bound))
                  (db-read-source-delete-binding-owned candidate))
                (delete current)
                (set! current next-current)))
            (for [candidate current]
              (arr.push! out candidate))
            (delete current)))
      .Collection
        (when (and (or (= value.kind .Vector)
                       (= value.kind .Set))
                   (= (count pattern.items) 1))
          (for [item value.items]
            (let [bound (db-read-source-bind-input-pattern-owned binding pattern.items[0] item)]
              (for [bound-item bound]
                (arr.push! out bound-item))
              (delete bound))))
       (do))
    out))

(defn db-read-source-bind-tuple-output [binding: Binding, names: []string, value: Value] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (and (= value.kind .Vector)
               (= (count value.items) (count names)))
      (let [current (make [dynamic]Binding)]
        (arr.push! current (db-read-source-clone-binding-owned binding))
        (for [name index names]
          (let [next-current (make [dynamic]Binding)]
            (for [candidate current]
              (if (= name "_")
                (arr.push! next-current (db-read-source-clone-binding-owned candidate))
                (let [owned-value (value-owned value.items[index])
                      [next ok] (db-read-source-binding-with-owned-value candidate name owned-value)]
                  (when ok
                    (arr.push! next-current next))))
              (db-read-source-delete-binding-owned candidate))
            (delete current)
            (set! current next-current)))
        (for [candidate current]
          (arr.push! out candidate))
        (delete current)))
    out))

(defn db-read-source-bindings-after-function [input-bindings: []Binding, function: Function-Clause] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (let [[value value-ok] (apply-function-op function binding)]
        (when value-ok
          (if (not (= function.out-binding.kind .None))
            (let [bound (db-read-source-bind-input-pattern-owned binding function.out-binding value)]
              (for [item bound]
                (arr.push! out item))
              (delete bound))
            (if function.is-tuple
              (let [bound (db-read-source-bind-tuple-output binding function.out-vars value)]
                (for [item bound]
                  (arr.push! out item))
                (delete bound))
              (let [owned-value (value-owned value)
                    [next next-ok] (db-read-source-binding-with-owned-value binding function.out owned-value)]
                (when next-ok
                  (arr.push! out next)))))
          (delete-value-containers-shallow value))))
    (return out true "")))

(defn db-read-source-entid-value [source: DB-Read-Source, binding: Binding, function: Function-Clause] -> [value: Value, ok: bool, error: string]
  (when (not (and (= (count function.terms) 2)
                  (source-function-has-default-source-token? function)))
    (return (Value {}) false "entid clauses must have shape [(entid $ value) ?out]"))
  (let [[input input-ok] (db-read-source-term-resolved-value function.terms[1] binding)]
    (when (not input-ok)
      (return (Value {}) false ""))
    (let [[resolved resolved-ok resolved-error] (db-read-source-resolve-ref-component-value source input)]
      (when (not resolved-ok)
        (return (Value {}) false resolved-error))
      (when (= resolved.kind .Entity)
        (return resolved true ""))
      (when (= resolved.kind .Int)
        (return (value-entity (u64 resolved.int-value)) true ""))
      (return (Value {}) false ""))))

(defn db-read-source-function-op-value [source: DB-Read-Source, binding: Binding, function: Function-Clause] -> [value: Value, ok: bool, error: string]
  (let [[op op-ok] (query-op-name function.op binding)]
    (when (not op-ok)
      (return (Value {}) false ""))
    (when (source-function-op? op)
      (return (db-read-source-entid-value source binding function))))
  (let [[applied applied-ok] (apply-function-op function binding)]
    (return applied applied-ok "")))

(defn db-read-source-bindings-after-function-with-source [source: DB-Read-Source, input-bindings: []Binding, function: Function-Clause] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (let [[value value-ok value-error] (db-read-source-function-op-value source binding function)]
        (when (not (= value-error ""))
          (db-read-source-delete-bindings-owned out)
          (return (make [dynamic]Binding) false value-error))
        (when value-ok
          (if (not (= function.out-binding.kind .None))
            (let [bound (db-read-source-bind-input-pattern-owned binding function.out-binding value)]
              (for [item bound]
                (arr.push! out item))
              (delete bound))
            (if function.is-tuple
              (let [bound (db-read-source-bind-tuple-output binding function.out-vars value)]
                (for [item bound]
                  (arr.push! out item))
                (delete bound))
              (let [owned-value (value-owned value)
                    [next next-ok] (db-read-source-binding-with-owned-value binding function.out owned-value)]
                (when next-ok
                  (arr.push! out next)))))
          (delete-value-containers-shallow value))))
    (return out true "")))

(defn fulltext-ascii-lower-char [ch: string] -> string
  (cond
    (= ch "A") "a"
    (= ch "B") "b"
    (= ch "C") "c"
    (= ch "D") "d"
    (= ch "E") "e"
    (= ch "F") "f"
    (= ch "G") "g"
    (= ch "H") "h"
    (= ch "I") "i"
    (= ch "J") "j"
    (= ch "K") "k"
    (= ch "L") "l"
    (= ch "M") "m"
    (= ch "N") "n"
    (= ch "O") "o"
    (= ch "P") "p"
    (= ch "Q") "q"
    (= ch "R") "r"
    (= ch "S") "s"
    (= ch "T") "t"
    (= ch "U") "u"
    (= ch "V") "v"
    (= ch "W") "w"
    (= ch "X") "x"
    (= ch "Y") "y"
    (= ch "Z") "z"
    :else ch))

(defn fulltext-ascii-equal? [left: string, right: string] -> bool
  (= (fulltext-ascii-lower-char left)
     (fulltext-ascii-lower-char right)))

(defn fulltext-slice-equal? [text: string, start: int, search: string] -> bool
  (let [index 0
        search-len (count search)]
    (while (< index search-len)
      (when (not (fulltext-ascii-equal?
                   (slice text (+ start index) (+ start index 1))
                   (slice search index (+ index 1))))
        (return false))
      (set! index (+ index 1)))
    true))

(defn fulltext-prefix-word? [search: string, text: string] -> bool
  (let [search-len (count search)]
    (and (>= (count text) search-len)
         (fulltext-slice-equal? text 0 search)
         (or (= (count text) search-len)
             (fulltext-boundary? text search-len)))))

(defn fulltext-exact? [search: string, text: string] -> bool
  (and (= (count search) (count text))
       (fulltext-slice-equal? text 0 search)))

(defn fulltext-score [search: string, text: string] -> f64
  (cond
    (fulltext-exact? search text) 1.0
    (fulltext-prefix-word? search text) 0.625
    :else 0.5))

(defn fulltext-boundary? [text: string, index: int] -> bool
  (when (or (< index 0)
            (>= index (count text)))
    (return true))
  (let [ch (slice text index (+ index 1))]
    (or (= ch " ")
        (= ch "\t")
        (= ch "\n")
        (= ch "\r")
        (= ch "-")
        (= ch "_")
        (= ch ".")
        (= ch ",")
        (= ch ":")
        (= ch ";")
        (= ch "'")
        (= ch "\"")
        (= ch "(")
        (= ch ")")
        (= ch "[")
        (= ch "]")
        (= ch "{")
        (= ch "}")
        (= ch "/"))))

(defn fulltext-matches? [search: string, text: string] -> bool
  (let [search-len (count search)
        text-len (count text)
        index 0]
    (when (= search-len 0)
      (return false))
    (while (<= (+ index search-len) text-len)
      (when (and (fulltext-slice-equal? text index search)
                 (fulltext-boundary? text (- index 1))
                 (fulltext-boundary? text (+ index search-len)))
        (return true))
      (set! index (+ index 1)))
    false))

(defn fulltext-source-name [function: Function-Clause] -> [name: string, ok: bool]
  (when (not (and (= function.op "fulltext")
                  (= (count function.terms) 3)))
    (return "" false))
  (let [term function.terms[0]]
    (when (and (= term.kind .Value)
               (= term.value.kind .Symbol)
               (query-source-input-name? term.value.text))
      (return term.value.text true)))
  (return "" false))

(defn fulltext-attr-from-term [term: Term] -> [attr: string, ok: bool]
  (when (= term.kind .Value)
    (cond
      (= term.value.kind .Keyword) (return term.value.text true)
      (= term.value.kind .String) (return term.value.text true)))
  (return "" false))

(defn fulltext-search-from-binding [function: Function-Clause, binding: Binding] -> [search: string, ok: bool]
  (let [[value value-ok] (db-read-source-term-resolved-value function.terms[2] binding)]
    (when (and value-ok
               (= value.kind .String))
      (return value.text true)))
  (return "" false))

(defn fulltext-search-from-typed-row [rel: Query-Relation, row: int, function: Function-Clause] -> [search: string, ok: bool]
  (let [[value value-ok] (db-read-source-query-relation-resolve-typed-term rel row function.terms[2])]
    (when (and value-ok
               (= value.kind .String))
      (return value.text true)))
  (return "" false))

(defn fulltext-output-width [binding: Input-Binding] -> int
  (let [row-binding (fulltext-output-row-binding binding)]
    (if (= row-binding.kind .Tuple)
      (count row-binding.items)
      4)))

(defn db-read-source-fulltext-row-value [datom: Datom, search: string, width: int] -> Value
  (let [items (make [dynamic]Value)]
    (arr.push! items (value-entity datom.e))
    (when (> width 1)
      (arr.push! items (value-owned datom.v)))
    (when (> width 2)
      (arr.push! items (value-entity datom.tx)))
    (when (> width 3)
      (arr.push! items (value-float (fulltext-score search datom.v.text))))
    (let [out (value-vector (slice items 0))]
      (delete items)
      out)))

(defn fulltext-output-row-binding [binding: Input-Binding] -> Input-Binding
  (if (and (= binding.kind .Collection)
           (= (count binding.items) 1))
    (return binding.items[0])
    (if (and (= binding.kind .Tuple)
             (= (count binding.items) 1)
             (= binding.items[0].kind .Tuple))
      (return binding.items[0])
      (return binding))))

(defn db-read-source-append-fulltext-row-bindings! [out: ^[dynamic]Binding, binding: Binding, function: Function-Clause, row-value: Value]
  (let [row-binding (fulltext-output-row-binding function.out-binding)
        bound (db-read-source-bind-input-pattern-owned binding row-binding row-value)]
    (for [item bound]
      (arr.push! out^ item))
    (delete bound)))

(defn db-read-source-bindings-after-fulltext-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, input-bindings: []Binding, function: Function-Clause] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [[source-name source-name-ok] (fulltext-source-name function)]
    (when (not source-name-ok)
      (return (make [dynamic]Binding) false "fulltext clauses must have shape [(fulltext $ :attr search) [[?e ?text ?tx ?score]]]"))
    (let [[read-source read-source-ok read-source-error] (db-read-source-for-name source sources source-name)]
      (when (not read-source-ok)
        (return (make [dynamic]Binding) false read-source-error))
      (let [[attr attr-ok] (fulltext-attr-from-term function.terms[1])]
        (when (not attr-ok)
          (return (make [dynamic]Binding) false "fulltext attr must be a keyword or string"))
        (let [out (make [dynamic]Binding)
              row-width (fulltext-output-width function.out-binding)
              [stream stream-ok stream-error] (source-index-datom-stream read-source attr)]
          (when (not stream-ok)
            (return out false stream-error))
          (while stream.has-current
            (when (= stream.current.v.kind .String)
              (for [binding input-bindings]
                (let [[search search-ok] (fulltext-search-from-binding function binding)]
                  (when (and search-ok
                             (fulltext-matches? search stream.current.v.text))
                    (let [row-value (db-read-source-fulltext-row-value stream.current search row-width)]
                      (db-read-source-append-fulltext-row-bindings! (addr out) binding function row-value)
                      (delete-owned-value row-value))))))
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! read-source (addr stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream stream)
                (db-read-source-delete-bindings-owned out)
                (return (make [dynamic]Binding) false advance-error))))
          (delete-source-index-datom-stream stream)
          (return out true ""))))))

(defn db-read-source-ground-source-owned [ground: Ground, binding: Binding] -> [value: Value, ok: bool]
  (case ground.source.kind
    .Value (return (value-owned ground.source.value) true)
    .Var
      (let [[value value-ok] (binding-lookup binding ground.source.name)]
        (if value-ok
          (return (value-owned value) true)
          (return (Value {}) false)))
     (return (Value {}) false)))

(defn db-read-source-ground-bind-values [binding: Binding, vars: []string, values: []Value] -> [next: Binding, ok: bool]
  (when (not (= (count vars) (count values)))
    (return (Binding {}) false))
  (let [current (db-read-source-clone-binding-owned binding)]
    (for [name index vars]
      (when (not (= name ""))
        (let [owned-value (value-owned values[index])
              [next next-ok] (db-read-source-binding-with-owned-value current name owned-value)]
          (db-read-source-delete-binding-owned current)
          (when (not next-ok)
            (return (Binding {}) false))
          (set! current next))))
    (return current true)))

(defn db-read-source-bindings-after-ground [input-bindings: []Binding, ground: Ground] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (let [[source source-ok] (db-read-source-ground-source-owned ground binding)]
        (when source-ok
          (cond
            (not (= ground.binding.kind .None))
              (let [bound (db-read-source-bind-input-pattern-owned binding ground.binding source)]
                (for [item bound]
                  (arr.push! out item))
                (delete bound))
            ground.is-tuple
              (when (= source.kind .Vector)
                (let [[next next-ok] (db-read-source-ground-bind-values binding ground.tuple-vars (slice source.items 0))]
                  (when next-ok
                    (arr.push! out next))))
            ground.is-relation
              (when (= source.kind .Vector)
                (for [row source.items]
                  (when (and (= row.kind .Vector)
                             (= (count row.items) ground.width))
                    (let [[next next-ok] (db-read-source-ground-bind-values binding ground.tuple-vars (slice row.items 0))]
                      (when next-ok
                        (arr.push! out next))))))
            ground.is-collection
              (when (or (= source.kind .Vector)
                        (= source.kind .Set))
                (for [value source.items]
                  (let [owned-value (value-owned value)
                        [next next-ok] (db-read-source-binding-with-owned-value binding ground.out owned-value)]
                    (when next-ok
                      (arr.push! out next)))))
            (= ground.out "")
              (arr.push! out (db-read-source-clone-binding-owned binding))
            :else
              (let [[next next-ok] (db-read-source-binding-with-owned-value binding ground.out (value-owned source))]
                (when next-ok
                  (arr.push! out next)))))
        (when source-ok
          (delete-owned-value source))))
    (return out true "")))

(defn db-read-source-apply-get-else [source: DB-Read-Source, binding: Binding, clause: Get-Else] -> [next: Binding, ok: bool, error: string]
  (let [[entity entity-ok entity-error] (db-read-source-resolve-entity-term source clause.e binding)]
    (when (not entity-ok)
      (return (Binding {}) false entity-error))
    (when (not (= entity.kind .Entity))
      (return (Binding {}) false ""))
    (let [[value value-ok value-error] (db-read-source-pull-attr-value source entity.entity clause.a)]
      (when (not (= value-error ""))
        (return (Binding {}) false value-error))
      (if value-ok
        (let [[next next-ok] (db-read-source-binding-with-owned-value binding clause.out value)]
          (return next next-ok ""))
        (let [[next next-ok] (db-read-source-binding-with-owned-value binding clause.out (value-owned clause.default-value))]
          (return next next-ok ""))))))

(defn db-read-source-for-get-else [source: DB-Read-Source, sources: []DB-Read-Named-Source, get-else: Get-Else] -> [read-source: DB-Read-Source, ok: bool, error: string]
  (if get-else.has-source
    (db-read-source-for-name source sources get-else.source)
    (return source true "")))

(defn db-read-source-bindings-after-get-else-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, input-bindings: []Binding, get-else: Get-Else] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [[read-source read-source-ok read-source-error] (db-read-source-for-get-else source sources get-else)]
    (when (not read-source-ok)
      (return (make [dynamic]Binding) false read-source-error))
    (let [out (make [dynamic]Binding)]
      (for [binding input-bindings]
        (let [[next next-ok next-error] (db-read-source-apply-get-else read-source binding get-else)]
          (when (not (= next-error ""))
            (db-read-source-delete-bindings-owned out)
            (return (make [dynamic]Binding) false next-error))
          (when next-ok
            (arr.push! out next))))
      (return out true ""))))

(defn db-read-source-bindings-after-get-else [source: DB-Read-Source, input-bindings: []Binding, get-else: Get-Else] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-get-else-with-sources source ([]DB-Read-Named-Source []) input-bindings get-else))

(defn db-read-source-apply-get-some [source: DB-Read-Source, binding: Binding, clause: Get-Some] -> [next: Binding, ok: bool, error: string]
  (let [[entity entity-ok entity-error] (db-read-source-resolve-entity-term source clause.e binding)]
    (when (not entity-ok)
      (return (Binding {}) false entity-error))
    (when (not (= entity.kind .Entity))
      (return (Binding {}) false ""))
    (for [attr clause.attrs]
      (let [[value value-ok value-error] (db-read-source-pull-attr-value source entity.entity attr)]
        (when (not (= value-error ""))
          (return (Binding {}) false value-error))
        (when value-ok
          (let [[with-attr attr-ok] (db-read-source-binding-with-owned-value binding clause.out-attr (value-keyword (string-owned attr)))]
            (if attr-ok
              (let [[next next-ok] (db-read-source-binding-with-owned-value with-attr clause.out-value value)]
                (return next next-ok ""))
              (delete-owned-value value))))))
    (return (Binding {}) false "")))

(defn db-read-source-for-get-some [source: DB-Read-Source, sources: []DB-Read-Named-Source, get-some: Get-Some] -> [read-source: DB-Read-Source, ok: bool, error: string]
  (if get-some.has-source
    (db-read-source-for-name source sources get-some.source)
    (return source true "")))

(defn db-read-source-bindings-after-get-some-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, input-bindings: []Binding, get-some: Get-Some] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [[read-source read-source-ok read-source-error] (db-read-source-for-get-some source sources get-some)]
    (when (not read-source-ok)
      (return (make [dynamic]Binding) false read-source-error))
    (let [out (make [dynamic]Binding)]
      (for [binding input-bindings]
        (let [[next next-ok next-error] (db-read-source-apply-get-some read-source binding get-some)]
          (when (not (= next-error ""))
            (db-read-source-delete-bindings-owned out)
            (return (make [dynamic]Binding) false next-error))
          (when next-ok
            (arr.push! out next))))
      (return out true ""))))

(defn db-read-source-bindings-after-get-some [source: DB-Read-Source, input-bindings: []Binding, get-some: Get-Some] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-get-some-with-sources source ([]DB-Read-Named-Source []) input-bindings get-some))

(defn db-read-source-not-group-step-bindings [source: DB-Read-Source, sources: []DB-Read-Named-Source, group: Not-Group, bindings: [dynamic]Binding, step: Query-Step] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (cond
    (= step.kind .Clause)
      (let [clause-value group.clauses[step.index]
            [clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
        (when (not source-clause-ok)
          (db-read-source-delete-bindings-owned bindings)
          (return (make [dynamic]Binding) false source-clause-error))
        (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
          (db-read-source-delete-bindings-owned bindings)
          (return next next-ok next-error)))
    (= step.kind .Predicate)
      (let [next (db-read-source-bindings-after-predicate (slice bindings 0) group.predicates[step.index])]
        (db-read-source-delete-bindings-owned bindings)
        (return next true ""))
    (= step.kind .Function)
      (let [function group.function-clauses[step.index]]
        (if (= function.op "fulltext")
          (let [[next next-ok next-error] (db-read-source-bindings-after-fulltext-with-sources source sources (slice bindings 0) function)]
            (db-read-source-delete-bindings-owned bindings)
            (return next next-ok next-error))
          (let [[next next-ok next-error] (db-read-source-bindings-after-function-with-source source (slice bindings 0) function)]
            (db-read-source-delete-bindings-owned bindings)
            (return next next-ok next-error))))
    (= step.kind .GetElse)
      (let [[next next-ok next-error] (db-read-source-bindings-after-get-else-with-sources source sources (slice bindings 0) group.get-elses[step.index])]
        (db-read-source-delete-bindings-owned bindings)
        (return next next-ok next-error))
    (= step.kind .GetSome)
      (let [[next next-ok next-error] (db-read-source-bindings-after-get-some-with-sources source sources (slice bindings 0) group.get-somes[step.index])]
        (db-read-source-delete-bindings-owned bindings)
        (return next next-ok next-error))
    (= step.kind .Not)
      (let [[next next-ok next-error] (db-read-source-bindings-after-not-group-with-sources source sources (slice bindings 0) group.not-groups[step.index])]
        (db-read-source-delete-bindings-owned bindings)
        (return next next-ok next-error))
    :else
      (do
        (db-read-source-delete-bindings-owned bindings)
        (return (make [dynamic]Binding) false "SQLite DB snapshot source currently supports branch groups with data, predicate, function, get-else, get-some, and not clauses only"))))

(defn db-read-source-bindings-after-branch-group-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, group: Not-Group, bindings: [dynamic]Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [current bindings]
    (if (> (count group.steps) 0)
      (do
        (for [step group.steps]
          (let [[next next-ok next-error] (db-read-source-not-group-step-bindings source sources group current step)]
            (when (not next-ok)
              (delete next)
              (return (make [dynamic]Binding) false next-error))
            (set! current next)
            (when (= (count current) 0)
              (return current true ""))))
        (return current true ""))
      (do
        (for [clause-value group.clauses]
          (let [[clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
            (when (not source-clause-ok)
              (db-read-source-delete-bindings-owned current)
              (return (make [dynamic]Binding) false source-clause-error))
            (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice current 0) source-clause)]
              (db-read-source-delete-bindings-owned current)
              (when (not next-ok)
                (return (make [dynamic]Binding) false next-error))
              (set! current next)
              (when (= (count current) 0)
                (return current true "")))))
        (return current true "")))))

(defn db-read-source-bindings-after-branch-group [source: DB-Read-Source, group: Not-Group, bindings: [dynamic]Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-branch-group-with-sources source ([]DB-Read-Named-Source []) group bindings))

(defn db-read-source-bindings-after-or-branch-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, group: Or-Group, branch: Not-Group, binding: Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [initial (make [dynamic]Binding)]
    (if group.has-join
      (arr.push! initial (db-read-source-project-binding-owned binding group.join-vars))
      (arr.push! initial (db-read-source-clone-binding-owned binding)))
    (let [[branch-bindings branch-ok branch-error] (db-read-source-bindings-after-branch-group-with-sources source sources branch initial)
          out (make [dynamic]Binding)]
      (when (not branch-ok)
        (delete out)
        (return branch-bindings false branch-error))
      (for [branch-binding branch-bindings]
        (if group.has-join
          (let [projected (db-read-source-project-binding-owned branch-binding group.join-vars)
                [merged merged-ok] (db-read-source-merge-binding-owned binding projected)]
            (db-read-source-delete-binding-owned projected)
            (when merged-ok
              (arr.push! out merged)))
          (let [[merged merged-ok] (db-read-source-merge-binding-owned binding branch-binding)]
            (when merged-ok
              (arr.push! out merged)))))
      (db-read-source-delete-bindings-owned branch-bindings)
      (return out true ""))))

(defn db-read-source-bindings-after-or-branch [source: DB-Read-Source, group: Or-Group, branch: Not-Group, binding: Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-or-branch-with-sources source ([]DB-Read-Named-Source []) group branch binding))

(defn db-read-source-bindings-after-or-group-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, input-bindings: []Binding, group: Or-Group] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (for [branch group.branches]
        (let [[branch-bindings branch-ok branch-error] (db-read-source-bindings-after-or-branch-with-sources source sources group branch binding)]
          (when (not branch-ok)
            (db-read-source-delete-bindings-owned out)
            (return branch-bindings false branch-error))
          (for [branch-binding branch-bindings]
              (arr.push! out branch-binding))
          (delete branch-bindings))))
    (return out true "")))

(defn db-read-source-bindings-after-or-group [source: DB-Read-Source, input-bindings: []Binding, group: Or-Group] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-or-group-with-sources source ([]DB-Read-Named-Source []) input-bindings group))

(defn db-read-source-not-group-matches-with-sources? [source: DB-Read-Source, sources: []DB-Read-Named-Source, group: Not-Group, binding: Binding] -> [matched: bool, ok: bool, error: string]
  (let [bindings (make [dynamic]Binding)]
    (arr.push! bindings (db-read-source-clone-binding-owned binding))
    (if (> (count group.steps) 0)
      (for [step group.steps]
        (let [[next next-ok next-error] (db-read-source-not-group-step-bindings source sources group bindings step)]
          (when (not next-ok)
            (delete next)
            (return false false next-error))
          (set! bindings next)
          (when (= (count bindings) 0)
            (delete bindings)
              (return false true ""))))
      (for [clause-value group.clauses]
        (let [[clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
          (when (not source-clause-ok)
            (db-read-source-delete-bindings-owned bindings)
            (return false false source-clause-error))
          (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return false false next-error))
            (set! bindings next)
            (when (= (count bindings) 0)
              (delete bindings)
              (return false true ""))))))
    (let [did-match (> (count bindings) 0)]
      (db-read-source-delete-bindings-owned bindings)
      (return did-match true ""))))

(defn db-read-source-not-group-matches? [source: DB-Read-Source, group: Not-Group, binding: Binding] -> [matched: bool, ok: bool, error: string]
  (db-read-source-not-group-matches-with-sources? source ([]DB-Read-Named-Source []) group binding))

(defn db-read-source-bindings-after-not-group-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, input-bindings: []Binding, group: Not-Group] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)]
    (for [binding input-bindings]
      (let [[matched matched-ok matched-error] (db-read-source-not-group-matches-with-sources? source sources group binding)]
        (when (not matched-ok)
          (db-read-source-delete-bindings-owned out)
          (return (make [dynamic]Binding) false matched-error))
        (when (not matched)
          (arr.push! out (db-read-source-clone-binding-owned binding)))))
    (return out true "")))

(defn db-read-source-bindings-after-not-group [source: DB-Read-Source, input-bindings: []Binding, group: Not-Group] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-not-group-with-sources source ([]DB-Read-Named-Source []) input-bindings group))

(defn db-read-source-query-input-specs [query-value: Query] -> [dynamic]Query-Input-Spec
  (let [out (make [dynamic]Query-Input-Spec)]
    (if (> (count query-value.input-specs) 0)
      (for [spec query-value.input-specs]
        (arr.push! out spec))
      (append-legacy-query-input-specs! (addr out) query-value))
    out))

(defn db-read-source-named-source-bound? [sources: []DB-Read-Named-Source, name: string] -> bool
  (for [candidate sources]
    (when (= candidate.name name)
      (return true)))
  false)

(defn db-read-source-input-source-index [query-value: Query, name: string] -> [index: int, ok: bool]
  (let [input-index 0
        specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (cond
        (= spec.kind .Ignore)
          (set! input-index (+ input-index 1))
        (and (= spec.kind .Scalar)
             (query-source-input-name? spec.name)
             (= spec.name "$"))
          (do)
        (and (= spec.kind .Scalar)
             (query-source-input-name? spec.name))
          (do
            (when (= spec.name name)
              (return input-index true))
            (set! input-index (+ input-index 1)))
        :else
          (set! input-index (+ input-index 1)))))
  (return -1 false))

(defn append-db-read-source-query-input-sources! [out: ^[dynamic]DB-Read-Named-Source, owned-values: ^[dynamic]Value, query-value: Query, inputs: []Query-Input] -> [ok: bool, error: string]
  (let [specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (when (and (= spec.kind .Scalar)
                 (query-source-input-name? spec.name)
                 (not (= spec.name "$"))
                 (not (db-read-source-named-source-bound? (slice out^ 0) spec.name)))
        (let [[input-index input-index-ok] (db-read-source-input-source-index query-value spec.name)]
          (when (not input-index-ok)
            (return false (fmt.tprintf "DB read source is not bound: %s" spec.name)))
          (when (>= input-index (count inputs))
            (return false (fmt.tprintf "DB read source is not bound: %s" spec.name)))
          (let [input inputs[input-index]
                [source-value source-value-ok] (query-input-source-value-owned input)]
            (when (not source-value-ok)
              (return false (fmt.tprintf "query source is not a collection: %s" spec.name)))
            (arr.push! owned-values^ source-value)
            (arr.push! out^
              (db-read-named-source
                spec.name
                (relation-value-db-read-source (addr owned-values^[(- (count owned-values^) 1)])))))))))
  (return true ""))

(defn db-read-source-query-source-inputs-bound? [query-value: Query, sources: []DB-Read-Named-Source] -> [ok: bool, error: string]
  (let [specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (when (and (= spec.kind .Scalar)
                 (query-source-input-name? spec.name)
                 (not (= spec.name "$"))
                 (not (db-read-source-named-source-bound? sources spec.name)))
        (return false (fmt.tprintf "DB read source is not bound: %s" spec.name)))))
  (return true ""))

(defn append-unknown-db-read-source! [out: ^[dynamic]string, sources: []DB-Read-Named-Source, name: string]
  (when (and (not (= name "$"))
             (not (db-read-source-named-source-bound? sources name)))
    (append-var-once! out name)))

(defn append-unknown-db-read-not-group-sources! [out: ^[dynamic]string, sources: []DB-Read-Named-Source, group: Not-Group]
  (for [clause-value group.clauses]
    (when clause-value.has-source
      (append-unknown-db-read-source! out sources clause-value.source)))
  (for [call group.rule-calls]
    (when call.has-source
      (append-unknown-db-read-source! out sources call.source)))
  (for [child group.not-groups]
    (append-unknown-db-read-not-group-sources! out sources child)))

(defn append-unknown-db-read-or-group-sources! [out: ^[dynamic]string, sources: []DB-Read-Named-Source, group: Or-Group]
  (for [branch group.branches]
    (append-unknown-db-read-not-group-sources! out sources branch)))

(defn validate-db-read-query-sources [query-value: Query, sources: []DB-Read-Named-Source] -> [ok: bool, error: string]
  (let [unknown (make [dynamic]string) :defer]
    (for [clause-value query-value.clauses]
      (when clause-value.has-source
        (append-unknown-db-read-source! (addr unknown) sources clause-value.source)))
    (for [call query-value.rule-calls]
      (when call.has-source
        (append-unknown-db-read-source! (addr unknown) sources call.source)))
    (for [pull-find query-value.pulls]
      (when pull-find.has-source
        (append-unknown-db-read-source! (addr unknown) sources pull-find.source)))
    (for [group query-value.not-groups]
      (append-unknown-db-read-not-group-sources! (addr unknown) sources group))
    (for [group query-value.or-groups]
      (append-unknown-db-read-or-group-sources! (addr unknown) sources group))
    (for [rule query-value.rules]
      (for [clause-value rule.clauses]
        (when clause-value.has-source
          (append-unknown-db-read-source! (addr unknown) sources clause-value.source)))
      (for [call rule.rule-calls]
        (when call.has-source
          (append-unknown-db-read-source! (addr unknown) sources call.source)))
      (for [group rule.not-groups]
        (append-unknown-db-read-not-group-sources! (addr unknown) sources group))
      (for [group rule.or-groups]
        (append-unknown-db-read-or-group-sources! (addr unknown) sources group)))
    (when (> (count unknown) 0)
      (let [vars-text (query-var-list-text (slice unknown 0)) :defer]
        (return false (fmt.tprintf "Where uses unknown source vars: %s" vars-text))))
    (return true "")))

(defn db-read-source-query-has-source-inputs? [query-value: Query] -> bool
  (let [specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (when (and (= spec.kind .Scalar)
                 (query-source-input-name? spec.name)
                 (not (= spec.name "$")))
        (return true))))
  false)

(defn db-read-source-input-pattern [query-value: Query, inputs: []Query-Input, name: string] -> [pattern: []Pull-Spec, ok: bool]
  (let [input-index 0
        specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (when (and (= spec.kind .Scalar)
                 (not (query-source-input-name? spec.name)))
        (when (= spec.name name)
          (when (and (< input-index (count inputs))
                     (= inputs[input-index].kind .PullPattern))
            (return (slice inputs[input-index].pattern 0) true))
          (return ([]Pull-Spec []) false))
        (set! input-index (+ input-index 1)))
      (when (and (= spec.kind .Scalar)
                 (query-source-input-name? spec.name)
                 (not (= spec.name "$")))
        (set! input-index (+ input-index 1)))))
  (return ([]Pull-Spec []) false))

(defn db-read-source-pull-find-pattern [query-value: Query, inputs: []Query-Input, pull-find: Pull-Find] -> [pattern: []Pull-Spec, ok: bool]
  (if pull-find.has-pattern-var
    (db-read-source-input-pattern query-value inputs pull-find.pattern-var)
    (return (slice pull-find.pattern 0) true)))

(defn db-read-source-bind-input-row-owned [binding: Binding, names: []string, values: []Value, offset: int, width: int] -> [dynamic]Binding
  (let [current (make [dynamic]Binding)]
    (arr.push! current (db-read-source-clone-binding-owned binding))
    (for [name index names]
      (let [next-current (make [dynamic]Binding)
            value-index (+ offset index)]
        (for [candidate current]
          (if (or (= name "_")
                  (>= index width)
                  (>= value-index (count values)))
            (arr.push! next-current (db-read-source-clone-binding-owned candidate))
            (let [[next next-ok] (db-read-source-binding-with-owned-value candidate name (value-owned values[value-index]))]
              (when next-ok
                (arr.push! next-current next))))
          (db-read-source-delete-binding-owned candidate))
        (delete current)
        (set! current next-current)))
    current))

(defn db-read-source-bind-input-values-owned [bindings: []Binding, name: string, values: []Value] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (for [value values]
        (let [[next next-ok] (db-read-source-binding-with-owned-value binding name (value-owned value))]
          (when next-ok
            (arr.push! out next)))))
    out))

(defn db-read-source-bind-input-lookup-refs-owned [source: DB-Read-Source, bindings: []Binding, name: string, input: Query-Input] -> [out: [dynamic]Binding, ok: bool, error: string]
  (let [result (make [dynamic]Binding)]
    (when (not (= input.kind .CollectionLookupRefs))
      (return result false "SQLite DB snapshot source collection query input must be a collection"))
    (when (not (= (count input.lookup-attrs) (count input.lookup-values)))
      (return result false "SQLite DB snapshot source lookup-ref collection input has mismatched attrs and values"))
    (for [binding bindings]
      (for [value index input.lookup-values]
        (let [attr input.lookup-attrs[index]
              [_ entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attr value)]
        (when (not entity-ok)
          (when (and (not (= lookup-error ""))
                     (not (= lookup-error "lookup ref not found")))
            (db-read-source-delete-bindings-owned result)
            (return (make [dynamic]Binding) false lookup-error)))
          (when entity-ok
            (let [[next next-ok] (db-read-source-binding-with-owned-value binding name (lookup-ref-value-owned attr value))]
              (when next-ok
                (arr.push! result next)))))))
    (return result true "")))

(defn query-input-lookup-ref-values-for-source [source: DB-Read-Source, input: Query-Input] -> [values: [dynamic]Value, ok: bool, error: string]
  (let [out (make [dynamic]Value)]
    (when (not (= input.kind .CollectionLookupRefs))
      (return out false "SQLite DB snapshot source collection query input must be a collection"))
    (when (not (= (count input.lookup-attrs) (count input.lookup-values)))
      (return out false "SQLite DB snapshot source lookup-ref collection input has mismatched attrs and values"))
    (for [value index input.lookup-values]
      (let [attr input.lookup-attrs[index]
            [_ entity-ok lookup-error] (db-read-source-resolve-lookup-ref source attr value)]
        (when (not entity-ok)
          (when (and (not (= lookup-error ""))
                     (not (= lookup-error "lookup ref not found")))
            (delete-owned-values-array out)
            (return (make [dynamic]Value) false lookup-error)))
        (when entity-ok
          (arr.push! out (lookup-ref-value-owned attr value)))))
    (return out true "")))

(defn query-relation-append-initial-lookup-ref-input-values! [source: DB-Read-Source, attrs: ^[dynamic]string, attr-sources: ^[dynamic]string, columns: ^[dynamic]Relation-Column, row-count: ^int, name: string, input: Query-Input] -> bool
  (let [[lookup-values lookup-ok _] (query-input-lookup-ref-values-for-source source input)]
    (when (not lookup-ok)
      (delete-owned-values-array lookup-values)
      (return false))
    (let [append-ok (query-relation-append-initial-input-values! attrs attr-sources columns row-count name (slice lookup-values 0))]
      (delete-owned-values-array lookup-values)
      append-ok)))

(defn db-read-source-bind-input-rows-owned [bindings: []Binding, names: []string, values: []Value, width: int] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (and (> width 0)
               (= (count names) width))
      (let [row-count (/ (count values) width)]
        (for [binding bindings]
          (for [row (arr.range 0 row-count)]
            (let [offset (* row width)
                  row-bindings (db-read-source-bind-input-row-owned binding names values offset width)]
              (for [row-binding row-bindings]
                (arr.push! out row-binding))
              (delete row-bindings))))))
    out))

(defn db-read-source-initial-bindings [source: DB-Read-Source, query-value: Query, inputs: []Query-Input] -> [bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)
        initial (Binding {items: (make [dynamic]Var-Binding)})
        specs (db-read-source-query-input-specs query-value) :defer
        input-index 0]
    (arr.push! out initial)
    (for [spec specs]
      (cond
        (= spec.kind .Ignore)
          (when (< input-index (count inputs))
            (set! input-index (+ input-index 1)))
        (and (= spec.kind .Scalar)
             (query-source-input-name? spec.name))
          (when (not (= spec.name "$"))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Scalar)
          (do
            (when (< input-index (count inputs))
              (let [input inputs[input-index]]
                (when (not (= input.kind .PullPattern))
                  (let [[value value-ok value-error] (db-read-source-query-input-bound-value source spec.name input)]
                    (when (not value-ok)
                      (db-read-source-delete-bindings-owned out)
                      (return (make [dynamic]Binding) false value-error))
                    (for [binding-index (arr.range 0 (count out))]
                      (binding-store! (addr out[binding-index]) spec.name (value-owned value)))))))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Collection)
          (do
            (when (>= input-index (count inputs))
              (db-read-source-delete-bindings-owned out)
              (return (make [dynamic]Binding) false "SQLite DB snapshot source collection query input must be a collection"))
            (let [input inputs[input-index]]
              (cond
                (= input.kind .Collection)
                  (let [next (db-read-source-bind-input-values-owned (slice out 0) spec.name input.values)]
                    (db-read-source-delete-bindings-owned out)
                    (set! out next))
                (= input.kind .CollectionLookupRefs)
                  (let [[next lookup-ok lookup-error] (db-read-source-bind-input-lookup-refs-owned source (slice out 0) spec.name input)]
                    (db-read-source-delete-bindings-owned out)
                    (when (not lookup-ok)
                      (db-read-source-delete-bindings-owned next)
                      (return (make [dynamic]Binding) false lookup-error))
                    (set! out next))
                :else
                  (do
                    (db-read-source-delete-bindings-owned out)
                    (return (make [dynamic]Binding) false "SQLite DB snapshot source collection query input must be a collection"))))
              (set! input-index (+ input-index 1)))
        (= spec.kind .Tuple)
          (do
            (when (or (>= input-index (count inputs))
                      (not (= inputs[input-index].kind .Collection))
                      (not (= (count spec.tuple.vars) (count inputs[input-index].values))))
              (db-read-source-delete-bindings-owned out)
              (return (make [dynamic]Binding) false "SQLite DB snapshot source tuple query input must match tuple arity"))
            (let [next (db-read-source-bind-input-rows-owned (slice out 0) spec.tuple.vars inputs[input-index].values (count spec.tuple.vars))]
              (db-read-source-delete-bindings-owned out)
              (set! out next)
              (set! input-index (+ input-index 1))))
        (= spec.kind .Relation)
          (do
            (when (>= input-index (count inputs))
              (db-read-source-delete-bindings-owned out)
              (return (make [dynamic]Binding) false "SQLite DB snapshot source relation query input is missing"))
            (let [input inputs[input-index]]
              (cond
                (and (= input.kind .Relation)
                     (= input.width (count spec.relation.vars)))
                  (let [next (db-read-source-bind-input-rows-owned (slice out 0) spec.relation.vars input.values input.width)]
                    (db-read-source-delete-bindings-owned out)
                    (set! out next))
                (and (= input.kind .Scalar)
                     (= input.value.kind .Map)
                     (= (count spec.relation.vars) 2))
                  (let [next (db-read-source-bind-input-rows-owned (slice out 0) spec.relation.vars input.value.items 2)]
                    (db-read-source-delete-bindings-owned out)
                    (set! out next))
                :else
                  (do
                    (db-read-source-delete-bindings-owned out)
                    (return (make [dynamic]Binding) false "SQLite DB snapshot source relation query input must match relation arity"))))
            (set! input-index (+ input-index 1)))
        :else
          (do
            (db-read-source-delete-bindings-owned out)
            (return (make [dynamic]Binding) false "SQLite DB snapshot source query input is unsupported"))))
    (return out true "")))

(defn db-read-source-pull-spec-supported? [spec: Pull-Spec, registry: []Native-Query-Fn] -> bool
  (when (and spec.has-xform
             (not (or (= spec.xform "vector")
                      (= spec.xform "name")
                      (query-fn-supported? registry spec.xform))))
    (return false))
  (cond
    (= spec.a "*") (= (count spec.pattern) 0)
    (= spec.a ":db/id") (= (count spec.pattern) 0)
    (reverse-attr? spec.a) true
    :else true))

(defn db-read-source-pull-default-attr [spec: Pull-Spec] -> Pull-Attr
  (Pull-Attr {a: (string-owned (pull-output-attr spec))
              a-owned: true
              key-kind: (pull-output-key-kind spec)
              v: (value-owned spec.default-value)
              attrs: (make [dynamic]Pull-Attr)}))

(defn db-read-source-pull-missing-attr [spec: Pull-Spec] -> Pull-Attr
  (if spec.has-default
    (db-read-source-pull-default-attr spec)
    (pull-spec-transform-attr
      spec
      (pull-attr-from-spec spec (value-nil) (make [dynamic]Pull-Attr)))))

(defn db-read-source-pull-entity [value: Value] -> [entity: u64, ok: bool]
  (cond
    (= value.kind .Entity) (return value.entity true)
    (= value.kind .Int) (return (u64 value.int-value) true)
    :else (return 0 false)))

(defn db-read-source-pull-missing-attr-with-fns [spec: Pull-Spec, registry: []Native-Query-Fn] -> Pull-Attr
  (if spec.has-default
    (db-read-source-pull-default-attr spec)
    (pull-spec-transform-attr-with-fns
      spec
      (pull-attr-from-spec spec (value-nil) (make [dynamic]Pull-Attr))
      registry)))

(defn db-read-source-pull-child-attrs-with-fns [source: DB-Read-Source, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [attrs: [dynamic]Pull-Attr, ok: bool, error: string]
  (when (pull-seen-contains? seen-counts entity)
    (return (pull-id-attrs entity) true ""))
  (pull-seen-push! seen-counts entity)
  (let [[child child-ok child-error] (db-read-source-pull-result-for-pattern-seen-with-fns source entity pattern root seen-counts registry)]
    (pull-seen-pop! seen-counts entity)
    (when (not child-ok)
      (return (make [dynamic]Pull-Attr) false child-error))
    (return child.attrs true "")))

(defn append-db-read-source-reverse-pull-datom! [attrs: ^[dynamic]Pull-Attr, source: DB-Read-Source, spec: Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn, datom: Datom, seen: ^int, limit: int] -> [ok: bool, error: string]
  (when (>= seen^ limit)
    (return true ""))
  (let [children (make [dynamic]Pull-Attr)]
    (when (> (count spec.pattern) 0)
      (let [[child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.e (slice spec.pattern 0) (slice spec.pattern 0) seen-counts registry)]
        (when (not child-ok)
          (delete-pull-attrs-owned-values children)
          (return false child-error))
        (delete children)
        (set! children child-attrs)))
    (when (and (= (count spec.pattern) 0)
               spec.has-recursion
               (not (= spec.recursion-depth 0)))
      (if (pull-unbounded-recursion-depth? spec.recursion-depth)
        (let [[child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.e root root seen-counts registry)]
          (when (not child-ok)
            (delete-pull-attrs-owned-values children)
            (return false child-error))
          (delete children)
          (set! children child-attrs))
        (let [rec-pattern (pull-recursion-pattern root spec.a) :defer
              [child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.e (slice rec-pattern 0) (slice rec-pattern 0) seen-counts registry)]
          (when (not child-ok)
            (delete-pull-attrs-owned-values children)
            (return false child-error))
          (delete children)
          (set! children child-attrs))))
    (if (pull-include-ref-result? spec (slice children 0))
      (do
        (set! seen^ (+ seen^ 1))
        (arr.push! attrs^
          (pull-spec-transform-attr-with-fns
            spec
            (Pull-Attr {a: (string-owned (pull-output-attr spec))
                        a-owned: true
                        key-kind: (pull-output-key-kind spec)
                        v: (value-entity datom.e)
                        attrs: children
                        has-explicit-pattern: (> (count spec.pattern) 0)})
            registry)))
      (delete-pull-attrs-owned-values children)))
  (return true ""))

(defn append-db-read-source-forward-pull-datom! [attrs: ^[dynamic]Pull-Attr, source: DB-Read-Source, spec: Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn, datom: Datom, seen: ^int, limit: int] -> [ok: bool, error: string]
  (when (>= seen^ limit)
    (return true ""))
  (let [children (make [dynamic]Pull-Attr)]
    (when (and (> (count spec.pattern) 0)
               (= datom.v.kind .Entity))
      (let [[child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.v.entity (slice spec.pattern 0) (slice spec.pattern 0) seen-counts registry)]
        (when (not child-ok)
          (delete-pull-attrs-owned-values children)
          (return false child-error))
        (delete children)
        (set! children child-attrs)))
    (when (and (= (count spec.pattern) 0)
               (= datom.v.kind .Entity)
               spec.has-recursion
               (not (= spec.recursion-depth 0)))
      (if (pull-unbounded-recursion-depth? spec.recursion-depth)
        (let [[child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.v.entity root root seen-counts registry)]
          (when (not child-ok)
            (delete-pull-attrs-owned-values children)
            (return false child-error))
          (delete children)
          (set! children child-attrs))
        (let [rec-pattern (pull-recursion-pattern root spec.a) :defer
              [child-attrs child-ok child-error] (db-read-source-pull-child-attrs-with-fns source datom.v.entity (slice rec-pattern 0) (slice rec-pattern 0) seen-counts registry)]
          (when (not child-ok)
            (delete-pull-attrs-owned-values children)
            (return false child-error))
          (delete children)
          (set! children child-attrs))))
    (if (pull-include-ref-result? spec (slice children 0))
      (do
        (set! seen^ (+ seen^ 1))
        (arr.push! attrs^
          (pull-spec-transform-attr-with-fns
            spec
            (Pull-Attr {a: (string-owned (pull-output-attr spec))
                        a-owned: true
                        key-kind: (pull-output-key-kind spec)
                        v: (value-owned datom.v)
                        attrs: children
                        has-explicit-pattern: (> (count spec.pattern) 0)})
            registry)))
      (delete-pull-attrs-owned-values children)))
  (return true ""))

(defn db-read-source-pull-result-for-pattern-seen-with-fns [source: DB-Read-Source, entity: u64, pattern: []Pull-Spec, root: []Pull-Spec, seen-counts: (ptr (map u64 int)), registry: []Native-Query-Fn] -> [result: Pull-Result, ok: bool, error: string]
  (let [attrs (make [dynamic]Pull-Attr)]
    (for [spec pattern]
      (if (and spec.has-recursion (<= spec.recursion-depth 0))
        (do)
        (do
          (when (not (db-read-source-pull-spec-supported? spec registry))
            (delete-pull-attrs-owned-values attrs)
            (return (Pull-Result {}) false "SQLite DB snapshot source currently supports forward, wildcard, reverse, nested, pattern-input, default, limit, recursion, and built-in xform pull attrs only"))
          (when (not (= spec.a "*"))
            (pull-remove-output-attr-owned-values! (addr attrs) (pull-output-attr spec)))
          (cond
            (= spec.a "*")
              (do
                (when (not (pull-output-has-attr? attrs ":db/id"))
                  (arr.push! attrs
                    (Pull-Attr {a: ":db/id"
                                key-kind: .Keyword
                                v: (value-entity entity)
                                attrs: (make [dynamic]Pull-Attr)})))
                (if (db-read-source-has-overlay? source)
                  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity source entity)]
                    (when (not datoms-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false datoms-error))
                    (for [datom datoms]
                      (when (not (pull-output-has-attr? attrs datom.a))
                        (arr.push! attrs
                          (Pull-Attr {a: (string-owned datom.a)
                                      a-owned: true
                                      key-kind: .Keyword
                                      v: (value-owned datom.v)
                                      attrs: (make [dynamic]Pull-Attr)}))))
                    (delete-owned-datoms datoms))
                  (let [[stream stream-ok stream-error] (source-eavt-entity-stream source entity)]
                    (when (not stream-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false stream-error))
                    (while stream.has-current
                      (when (not (pull-output-has-attr? attrs stream.current.a))
                        (arr.push! attrs
                          (Pull-Attr {a: (string-owned stream.current.a)
                                      a-owned: true
                                      key-kind: .Keyword
                                      v: (value-owned stream.current.v)
                                      attrs: (make [dynamic]Pull-Attr)})))
                      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                        (when (not advance-ok)
                          (delete-source-index-datom-stream stream)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false advance-error))))
                    (delete-source-index-datom-stream stream))))
            (= spec.a ":db/id")
              (arr.push! attrs
                (pull-spec-transform-attr-with-fns
                  spec
                  (Pull-Attr {a: (string-owned (pull-output-attr spec))
                              a-owned: true
                              key-kind: (pull-output-key-kind spec)
                              v: (value-entity entity)
                              attrs: (make [dynamic]Pull-Attr)})
                  registry))
            (reverse-attr? spec.a)
              (let [forward-attr (forward-attr-for-reverse spec.a) :defer
                    limit (pull-limit spec)
                    seen 0]
                (if (db-read-source-has-overlay? source)
                  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-reverse-entity-attr source entity forward-attr)]
                    (when (not datoms-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false datoms-error))
                    (for [datom datoms]
                      (let [[append-ok append-error] (append-db-read-source-reverse-pull-datom! (addr attrs) source spec root seen-counts registry datom (addr seen) limit)]
                        (when (not append-ok)
                          (delete-owned-datoms datoms)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false append-error))))
                    (delete-owned-datoms datoms))
                  (let [[stream stream-ok stream-error] (source-vaet-entity-attr-stream source entity forward-attr)]
                    (when (not stream-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false stream-error))
                    (while (and stream.has-current (< seen limit))
                      (let [[append-ok append-error] (append-db-read-source-reverse-pull-datom! (addr attrs) source spec root seen-counts registry stream.current (addr seen) limit)]
                        (when (not append-ok)
                          (delete-source-index-datom-stream stream)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false append-error)))
                      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                        (when (not advance-ok)
                          (delete-source-index-datom-stream stream)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false advance-error))))
                    (delete-source-index-datom-stream stream)))
                (when (and (= seen 0) (or spec.has-default spec.has-xform))
                  (arr.push! attrs (db-read-source-pull-missing-attr-with-fns spec registry))))
            :else
              (let [limit (pull-limit spec)
                    seen 0]
                (if (db-read-source-has-overlay? source)
                  (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-entity-attr source entity spec.a)]
                    (when (not datoms-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false datoms-error))
                    (for [datom datoms]
                      (let [[append-ok append-error] (append-db-read-source-forward-pull-datom! (addr attrs) source spec root seen-counts registry datom (addr seen) limit)]
                        (when (not append-ok)
                          (delete-owned-datoms datoms)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false append-error))))
                    (delete-owned-datoms datoms))
                  (let [[stream stream-ok stream-error] (source-eavt-entity-attr-stream source entity spec.a)]
                    (when (not stream-ok)
                      (delete-pull-attrs-owned-values attrs)
                      (return (Pull-Result {}) false stream-error))
                    (while (and stream.has-current (< seen limit))
                      (let [[append-ok append-error] (append-db-read-source-forward-pull-datom! (addr attrs) source spec root seen-counts registry stream.current (addr seen) limit)]
                        (when (not append-ok)
                          (delete-source-index-datom-stream stream)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false append-error)))
                      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                        (when (not advance-ok)
                          (delete-source-index-datom-stream stream)
                          (delete-pull-attrs-owned-values attrs)
                          (return (Pull-Result {}) false advance-error))))
                    (delete-source-index-datom-stream stream)))
                (when (and (= seen 0) (or spec.has-default spec.has-xform))
                  (arr.push! attrs (db-read-source-pull-missing-attr-with-fns spec registry))))))))
    (return (Pull-Result {e: entity attrs: attrs}) true "")))

(defn db-read-source-pull-result-for-pattern [source: DB-Read-Source, entity: u64, pattern: []Pull-Spec] -> [result: Pull-Result, ok: bool, error: string]
  (db-read-source-pull-result-for-pattern-with-fns source entity pattern ([]Native-Query-Fn [])))

(defn db-read-source-pull-result-for-pattern-with-fns [source: DB-Read-Source, entity: u64, pattern: []Pull-Spec, registry: []Native-Query-Fn] -> [result: Pull-Result, ok: bool, error: string]
  (let [seen-counts (make (map u64 int))]
    (defer (delete seen-counts))
    (pull-seen-push! (addr seen-counts) entity)
    (db-read-source-pull-result-for-pattern-seen-with-fns source entity pattern pattern (addr seen-counts) registry)))

(defn db-read-source-pull-find-source [primary: DB-Read-Source, sources: []DB-Read-Named-Source, pull-find: Pull-Find] -> [source: DB-Read-Source, ok: bool, error: string]
  (if pull-find.has-source
    (db-read-source-for-name primary sources pull-find.source)
    (return primary true "")))

(defn db-read-source-pulls-for-binding-with-sources-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, binding: Binding, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool, error: string]
  (let [out (make [dynamic]Pull-Result 0 (count query-value.pulls))]
    (for [pull-find query-value.pulls]
      (let [[pull-source pull-source-ok pull-source-error] (db-read-source-pull-find-source source sources pull-find)]
        (when (not pull-source-ok)
          (for [pull out]
            (delete-pull-result-owned-values pull))
          (delete out)
          (return (make [dynamic]Pull-Result) false pull-source-error))
      (let [[entity-value entity-value-ok] (binding-lookup binding pull-find.var)]
        (when (not entity-value-ok)
          (for [pull out]
            (delete-pull-result-owned-values pull))
          (delete out)
          (return (make [dynamic]Pull-Result) false "pull entity var is not bound"))
        (let [[entity entity-ok] (db-read-source-pull-entity entity-value)]
          (when (not entity-ok)
            (for [pull out]
              (delete-pull-result-owned-values pull))
            (delete out)
            (return (make [dynamic]Pull-Result) false "pull entity value must be an entity id"))
          (let [[pattern pattern-ok] (db-read-source-pull-find-pattern query-value inputs pull-find)]
            (when (not pattern-ok)
              (for [existing out]
                (delete-pull-result-owned-values existing))
              (delete out)
              (return (make [dynamic]Pull-Result) false "pull pattern input must be a pull pattern"))
            (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-source entity pattern registry)]
            (when (not pull-ok)
              (for [existing out]
                (delete-pull-result-owned-values existing))
              (delete out)
              (return (make [dynamic]Pull-Result) false pull-error))
            (arr.push! out pull)))))))
    (return out true "")))

(defn db-read-source-pulls-for-binding-with-fns [source: DB-Read-Source, query-value: Query, inputs: []Query-Input, binding: Binding, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool, error: string]
  (db-read-source-pulls-for-binding-with-sources-and-fns source ([]DB-Read-Named-Source []) query-value inputs binding registry))

(defn db-read-source-pulls-for-binding [source: DB-Read-Source, query-value: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool, error: string]
  (db-read-source-pulls-for-binding-with-fns source query-value inputs binding ([]Native-Query-Fn [])))

(defn db-read-source-aggregate-result-rows-for-bindings-with-sources-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        seen-groups (make [dynamic]Result-Row)]
    (defer (delete-result-rows-owned-values seen-groups))
    (when (= (count query-value.find) 0)
      (let [values (make [dynamic]Value 0 (count query-value.aggregates))
            pulls (make [dynamic]Pull-Result)]
        (for [aggregate query-value.aggregates]
          (arr.push! values (aggregate-value-for-group-with-fns bindings query-value aggregate ([]Value []) registry)))
        (arr.push! rows (Result-Row {values: values pulls: pulls}))
        (return (result-set-ok rows))))
    (for [binding bindings]
      (let [[group-values group-ok] (binding-values-for-vars binding (slice query-value.find 0))]
        (if (not group-ok)
          (delete group-values)
          (if (row-values-exist? (slice seen-groups 0) (slice group-values 0))
            (delete group-values)
            (do
              (arr.push! seen-groups (aggregate-owned-key-row (slice group-values 0)))
              (let [values (make [dynamic]Value 0 (+ (count query-value.find) (count query-value.aggregates)))
                    [pulls pulls-ok pulls-error] (db-read-source-pulls-for-binding-with-sources-and-fns source sources query-value inputs binding registry)]
                (when (not pulls-ok)
                  (delete group-values)
                  (delete values)
                  (for [pull pulls]
                    (delete-pull-result-owned-values pull))
                  (delete pulls)
                  (delete-result-rows-owned-values rows)
                  (return (result-set-error pulls-error)))
                (for [value group-values]
                  (arr.push! values (value-owned value)))
                (for [aggregate query-value.aggregates]
                  (arr.push! values (aggregate-value-for-group-with-fns bindings query-value aggregate (slice group-values 0) registry)))
                (delete group-values)
                (arr.push! rows (Result-Row {values: values pulls: pulls}))))))))
    (result-set-ok rows)))

(defn db-read-source-result-rows-for-bindings-with-sources-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn] -> Result-Set
  (when (> (count query-value.aggregates) 0)
    (return (db-read-source-aggregate-result-rows-for-bindings-with-sources-and-fns source sources query-value inputs bindings registry)))
  (let [rows (make [dynamic]Result-Row)
        seen (set.empty string)
        trust-unique-bindings (query-can-trust-unique-bindings? query-value)]
    (defer (delete-owned-string-set seen))
    (for [binding bindings]
      (let [values (make [dynamic]Value 0 (count query-value.find))
            dedupe-values (make [dynamic]Value)
            [pulls pulls-ok pulls-error] (db-read-source-pulls-for-binding-with-sources-and-fns source sources query-value inputs binding registry)
            row-ok true
            pushed false]
        (when (not pulls-ok)
          (for [value values]
            (delete-owned-value value))
          (delete values)
          (delete dedupe-values)
          (delete-result-rows-owned-values rows)
          (return (result-set-error pulls-error)))
        (for [name query-value.find]
          (let [[value value-ok] (binding-lookup binding name)]
            (if value-ok
              (do
                (arr.push! values (value-owned value))
                (arr.push! dedupe-values value))
              (set! row-ok false))))
        (for [name query-value.with]
          (let [[value value-ok] (binding-lookup binding name)]
            (if value-ok
              (arr.push! dedupe-values value)
              (set! row-ok false))))
        (if (not row-ok)
          (do
            (for [value values]
              (delete-owned-value value))
            (delete values)
            (delete dedupe-values)
            (for [pull pulls]
              (delete-pull-result-owned-values pull))
            (delete pulls))
          (do
            (if trust-unique-bindings
              (do
                (arr.push! rows (Result-Row {values: values pulls: pulls}))
                (set! pushed true))
              (let [[key key-ok] (result-row-dedupe-key (slice dedupe-values 0) (slice pulls 0))]
                (if key-ok
                  (let [already-seen (set.contains? seen key)]
                    (when (not already-seen)
                      (set.add! seen key)
                      (arr.push! rows (Result-Row {values: values pulls: pulls}))
                      (set! pushed true))
                    (when already-seen
                      (delete key)))
                  (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                    (arr.push! rows (Result-Row {values: values pulls: pulls}))
                    (set! pushed true)))))
            (delete dedupe-values)
            (when (not pushed)
              (for [value values]
                (delete-owned-value value))
              (delete values)
              (for [pull pulls]
                (delete-pull-result-owned-values pull))
              (delete pulls))))))
    (result-set-ok rows)))

(defn db-read-source-result-rows-for-bindings-with-fns [source: DB-Read-Source, query-value: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn] -> Result-Set
  (db-read-source-result-rows-for-bindings-with-sources-and-fns source ([]DB-Read-Named-Source []) query-value inputs bindings registry))

(defn db-read-source-result-rows-for-bindings [source: DB-Read-Source, query-value: Query, inputs: []Query-Input, bindings: []Binding] -> Result-Set
  (db-read-source-result-rows-for-bindings-with-fns source query-value inputs bindings ([]Native-Query-Fn [])))

(defn db-read-source-query-clause [clause-value: Clause] -> [clause: Clause, ok: bool, error: string]
  (if clause-value.has-source
    (if (query-source-input-name? clause-value.source)
      (return (unsourced-clause clause-value) true "")
      (return (Clause {}) false "SQLite DB snapshot source clauses must use $-prefixed source names"))
    (return clause-value true "")))

(defn db-read-source-query-clause-source [source: DB-Read-Source, sources: []DB-Read-Named-Source, clause-value: Clause] -> [clause-source: DB-Read-Source, clause: Clause, ok: bool, error: string]
  (if clause-value.has-source
    (let [[clause-source clause-source-ok clause-source-error] (db-read-source-for-name source sources clause-value.source)]
      (when (not clause-source-ok)
        (return (DB-Read-Source {}) (Clause {}) false clause-source-error))
      (return clause-source (unsourced-clause clause-value) true ""))
    (return source clause-value true "")))

(defn db-read-source-clause-binds-var? [clause: Clause, name: string] -> bool
  (or (and (= clause.e.kind .Var) (= clause.e.name name))
      (and (= clause.a.kind .Var) (= clause.a.name name))
      (and (= clause.v.kind .Var) (= clause.v.name name))))

(defn db-read-source-clause-term-supported-for-aggregate? [clause: Clause, term: Term] -> bool
  (case term.kind
    .Value true
    .Var (db-read-source-clause-binds-var? clause term.name)
     false))

(defn db-read-source-single-clause-aggregate-query [query-value: Query] -> [clause: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (= (count query-value.find) 0)
                    (= (count query-value.inputs) 0)
                    (= (count query-value.collection-inputs) 0)
                    (= (count query-value.tuple-inputs) 0)
                    (= (count query-value.relation-inputs) 0)
                    (= (count query-value.input-specs) 0)
                    (= (count query-value.pulls) 0)
                    (> (count query-value.aggregates) 0)
                    (= (count query-value.rules) 0)
                    (= (count query-value.rule-calls) 0)
                    (= (count query-value.predicates) 0)
                    (= (count query-value.function-clauses) 0)
                    (= (count query-value.get-elses) 0)
                    (= (count query-value.get-somes) 0)
                    (= (count query-value.grounds) 0)
                    (= (count query-value.not-groups) 0)
                    (= (count query-value.or-groups) 0)
                    (= (count query-value.clauses) 1)
                    (= (count query-value.where-steps) 1)
                    (= query-value.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [query-clause query-value.clauses[0]]
      (for [with-var query-value.with]
        (when (not (db-read-source-clause-binds-var? query-clause with-var))
          (return empty-clause false)))
      (for [aggregate query-value.aggregates]
        (when (or (not (or (= aggregate.op "count")
                           (= aggregate.op "count-distinct")
                           (= aggregate.op "distinct")
                           (= aggregate.op "min")
                           (= aggregate.op "max")
                           (= aggregate.op "rand")
                           (= aggregate.op "sample")))
                  (and (or (= aggregate.op "count")
                           (= aggregate.op "count-distinct")
                           (= aggregate.op "distinct"))
                       aggregate.has-limit)
                  (and (or (= aggregate.op "min")
                           (= aggregate.op "max")
                           (= aggregate.op "rand")
                           (= aggregate.op "sample"))
                       (and aggregate.has-limit
                            (<= aggregate.limit 0)))
                  (and (= aggregate.op "sample")
                       (not aggregate.has-limit))
                  aggregate.has-limit-var
                  aggregate.has-function-var
                  (not (db-read-source-clause-binds-var? query-clause aggregate.var)))
          (return empty-clause false))
        (for [arg aggregate.args]
          (when (not (db-read-source-clause-term-supported-for-aggregate? query-clause arg))
            (return empty-clause false))))
      (return query-clause true))))

(defn db-read-source-single-clause-grouped-aggregate-query [query-value: Query] -> [clause: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (> (count query-value.find) 0)
                    (= (count query-value.inputs) 0)
                    (= (count query-value.collection-inputs) 0)
                    (= (count query-value.tuple-inputs) 0)
                    (= (count query-value.relation-inputs) 0)
                    (= (count query-value.input-specs) 0)
                    (= (count query-value.pulls) 0)
                    (= (count query-value.aggregates) 1)
                    (= (count query-value.rules) 0)
                    (= (count query-value.rule-calls) 0)
                    (= (count query-value.predicates) 0)
                    (= (count query-value.function-clauses) 0)
                    (= (count query-value.get-elses) 0)
                    (= (count query-value.get-somes) 0)
                    (= (count query-value.grounds) 0)
                    (= (count query-value.not-groups) 0)
                    (= (count query-value.or-groups) 0)
                    (= (count query-value.clauses) 1)
                    (= (count query-value.where-steps) 1)
                    (= query-value.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [query-clause query-value.clauses[0]
          aggregate query-value.aggregates[0]]
      (when (or (not (or (= aggregate.op "count")
                         (= aggregate.op "count-distinct")
                         (= aggregate.op "distinct")
                         (= aggregate.op "min")
                         (= aggregate.op "max")
                         (= aggregate.op "rand")
                         (= aggregate.op "sample")
                         (= aggregate.op "sum")
                         (= aggregate.op "avg")))
                (and aggregate.has-limit
                     (not (or (= aggregate.op "min")
                              (= aggregate.op "max")
                              (= aggregate.op "rand")
                              (= aggregate.op "sample"))))
                (and aggregate.has-limit
                     (or (= aggregate.op "min")
                         (= aggregate.op "max")
                         (= aggregate.op "rand")
                         (= aggregate.op "sample"))
                     (<= aggregate.limit 0))
                (and (= aggregate.op "sample")
                     (not aggregate.has-limit))
                aggregate.has-limit-var
                aggregate.has-function-var
                (not (= query-clause.e.kind .Var))
                (not (= query-clause.a.kind .Value))
                (not (= query-clause.a.value.kind .Keyword))
                (not (= query-clause.v.kind .Var))
                (not (db-read-source-clause-binds-var? query-clause aggregate.var)))
        (return empty-clause false))
      (for [name query-value.find]
        (when (not (db-read-source-clause-binds-var? query-clause name))
          (return empty-clause false)))
      (for [with-var query-value.with]
        (when (not (db-read-source-clause-binds-var? query-clause with-var))
          (return empty-clause false)))
      (for [arg aggregate.args]
        (when (not (db-read-source-clause-term-supported-for-aggregate? query-clause arg))
          (return empty-clause false)))
      (return query-clause true))))

(defn db-read-source-datom-value-for-var-owned [clause: Clause, datom: Datom, name: string] -> [value: Value, ok: bool]
  (cond
    (and (= clause.e.kind .Var) (= clause.e.name name)) (return (value-entity datom.e) true)
    (and (= clause.a.kind .Var) (= clause.a.name name)) (return (value-keyword (string-owned datom.a)) true)
    (and (= clause.v.kind .Var) (= clause.v.name name)) (return (value-owned datom.v) true)
    :else (return (Value {}) false)))

(defn db-read-source-datom-term-value-owned [clause: Clause, datom: Datom, term: Term] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return (value-owned term.value) true)
    .Var (return (db-read-source-datom-value-for-var-owned clause datom term.name))
     (return (Value {}) false)))

(defn db-read-source-aggregate-key-values [clause: Clause, datom: Datom, query-value: Query, aggregate: Aggregate-Find] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query-value.with]
      (let [[value value-ok] (db-read-source-datom-value-for-var-owned clause datom name)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (if (> (count aggregate.args) 0)
      (for [arg aggregate.args]
        (let [[value value-ok] (db-read-source-datom-term-value-owned clause datom arg)]
          (if value-ok
            (arr.push! out value)
            (return out false))))
      (let [[value value-ok] (db-read-source-datom-value-for-var-owned clause datom aggregate.var)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn delete-owned-values-array [values: [dynamic]Value]
  (for [value values]
    (delete-owned-value value))
  (delete values))

(defn source-top-n-values-owned [values: []Value, limit: int, max?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (let [take-count (min limit (count sorted))]
      (if max?
        (let [index (count sorted)
              remaining take-count]
          (while (> remaining 0)
            (set! index (- index 1))
            (arr.push! out (value-owned sorted[index]))
            (set! remaining (- remaining 1))))
        (let [index 0]
          (while (< index take-count)
            (arr.push! out (value-owned sorted[index]))
            (set! index (+ index 1)))))
      (value-vector-owned out))))

(defn db-read-source-single-clause-aggregate-value [clause: Clause, datoms: []Datom, query-value: Query, aggregate: Aggregate-Find] -> Value
  (let [current (aggregate-initial-value aggregate)
        distinct-values (make [dynamic]Value)
        aggregate-values (make [dynamic]Value)
        seen-keys (make [dynamic]Result-Row)]
    (defer (delete-result-rows-owned-values seen-keys))
    (defer (delete-owned-values-array distinct-values))
    (defer (delete-owned-values-array aggregate-values))
    (for [datom datoms]
      (let [[key key-ok] (db-read-source-aggregate-key-values clause datom query-value aggregate)]
        (when key-ok
          (let [already-seen (row-values-exist? (slice seen-keys 0) (slice key 0))]
            (when already-seen
              (delete-owned-values-array key))
            (when (not already-seen)
              (arr.push! seen-keys (Result-Row {values: key pulls: (make [dynamic]Pull-Result)}))
              (if (= aggregate.op "count")
                (set! current.int-value (+ current.int-value 1))
                (let [[input-value input-ok] (db-read-source-datom-value-for-var-owned clause datom aggregate.var)]
                  (when input-ok
                    (cond
                      (or (= aggregate.op "count-distinct")
                          (= aggregate.op "distinct"))
                        (let [value-seen (value-exists? (slice distinct-values 0) input-value)]
                          (if value-seen
                            (delete-owned-value input-value)
                            (arr.push! distinct-values input-value)))
                      (or (= aggregate.op "min")
                          (= aggregate.op "max")
                          (numeric-aggregate-op? aggregate.op)
                          (= aggregate.op "rand")
                          (= aggregate.op "sample"))
                        (arr.push! aggregate-values input-value)
                      :else
                        (delete-owned-value input-value))))))))))
    (cond
      (= aggregate.op "count-distinct")
        (value-int (i64 (count distinct-values)))
      (= aggregate.op "distinct")
        (distinct-values-vector-owned (slice distinct-values 0))
      (and aggregate.has-limit
           (or (= aggregate.op "min")
               (= aggregate.op "max")))
        (source-top-n-values-owned (slice aggregate-values 0) aggregate.limit (= aggregate.op "max"))
      (and (= aggregate.op "rand") (not aggregate.has-limit))
        (random-value-owned (slice aggregate-values 0))
      (limited-selection-aggregate-op? aggregate.op)
        (selection-values-owned (slice aggregate-values 0) aggregate.limit aggregate.op)
      (= aggregate.op "median")
        (median-numeric (slice aggregate-values 0))
      (= aggregate.op "variance")
        (variance-numeric (slice aggregate-values 0))
      (= aggregate.op "stddev")
        (stddev-numeric (slice aggregate-values 0))
      (and (not aggregate.has-limit)
           (= aggregate.op "min")
           (> (count aggregate-values) 0))
        (do
          (sort-values! (addr aggregate-values))
          (value-owned aggregate-values[0]))
      (and (not aggregate.has-limit)
           (= aggregate.op "max")
           (> (count aggregate-values) 0))
        (do
          (sort-values! (addr aggregate-values))
          (value-owned aggregate-values[(- (count aggregate-values) 1)]))
      :else current)))

(defn db-read-source-aggregate-streamable? [source: DB-Read-Source] -> bool
  (or (= source.kind .Resident)
      (= source.kind .Shared-Resident-Indexes)
      (= source.kind .Shared-Resident-Datoms-And-Indexes)
      (= source.kind .SQLite-Snapshot)))

(defn db-read-source-single-clause-aggregate-value-streamed [source: DB-Read-Source, clause: Clause, query-value: Query, aggregate: Aggregate-Find] -> [value: Value, ok: bool, error: string]
  (when (not (db-read-source-aggregate-streamable? source))
    (return (Value {}) false ""))
  (let [binding (Binding {items: (make [dynamic]Var-Binding)})
        [scan scan-ok scan-error] (db-read-source-clause-index-scan source clause binding)]
    (delete binding.items)
    (when (not scan-ok)
      (delete-clause-index-scan scan)
      (return (Value {}) false scan-error))
    (defer (delete-clause-index-scan scan))
    (let [current (aggregate-initial-value aggregate)
          distinct-values (make [dynamic]Value)
          aggregate-values (make [dynamic]Value)
          seen-keys (make [dynamic]Result-Row)
          scan-index scan.index]
      (defer (delete-result-rows-owned-values seen-keys))
      (defer (delete-owned-values-array distinct-values))
      (defer (delete-owned-values-array aggregate-values))
      (while (< scan-index scan.high)
        (let [entry (clause-index-scan-datom-index scan scan-index)
              [datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
          (when (not datom-ok)
            (return (Value {}) false datom-error))
          (if (db-read-source-clause-index-scan-candidate? scan datom)
            (let [[current-datom current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
              (when (not current-ok)
                (delete-owned-datom datom)
                (return (Value {}) false current-error))
              (when current-datom
                (let [[key key-ok] (db-read-source-aggregate-key-values clause datom query-value aggregate)]
                  (when key-ok
                    (let [already-seen (row-values-exist? (slice seen-keys 0) (slice key 0))]
                      (when already-seen
                        (delete-owned-values-array key))
                      (when (not already-seen)
                        (arr.push! seen-keys (Result-Row {values: key pulls: (make [dynamic]Pull-Result)}))
                        (if (= aggregate.op "count")
                          (set! current.int-value (+ current.int-value 1))
                          (let [[input-value input-ok] (db-read-source-datom-value-for-var-owned clause datom aggregate.var)]
                            (when input-ok
                              (cond
                                (or (= aggregate.op "count-distinct")
                                    (= aggregate.op "distinct"))
                                  (let [value-seen (value-exists? (slice distinct-values 0) input-value)]
                                    (if value-seen
                                      (delete-owned-value input-value)
                                      (arr.push! distinct-values input-value)))
                                (or (= aggregate.op "min")
                                    (= aggregate.op "max")
                                    (numeric-aggregate-op? aggregate.op)
                                    (= aggregate.op "rand")
                                    (= aggregate.op "sample"))
                                  (arr.push! aggregate-values input-value)
                                :else
                                  (delete-owned-value input-value)))))))))))
              (delete-owned-datom datom))
            (delete-owned-datom datom))
        (set! scan-index (+ scan-index 1)))
      (cond
        (= aggregate.op "count-distinct")
          (return (value-int (i64 (count distinct-values))) true "")
        (= aggregate.op "distinct")
          (return (distinct-values-vector-owned (slice distinct-values 0)) true "")
        (and aggregate.has-limit
             (or (= aggregate.op "min")
                 (= aggregate.op "max")))
          (return (source-top-n-values-owned (slice aggregate-values 0) aggregate.limit (= aggregate.op "max")) true "")
        (and (= aggregate.op "rand") (not aggregate.has-limit))
          (return (random-value-owned (slice aggregate-values 0)) true "")
        (limited-selection-aggregate-op? aggregate.op)
          (return (selection-values-owned (slice aggregate-values 0) aggregate.limit aggregate.op) true "")
        (= aggregate.op "median")
          (return (median-numeric (slice aggregate-values 0)) true "")
        (= aggregate.op "variance")
          (return (variance-numeric (slice aggregate-values 0)) true "")
        (= aggregate.op "stddev")
          (return (stddev-numeric (slice aggregate-values 0)) true "")
        (and (not aggregate.has-limit)
             (= aggregate.op "min")
             (> (count aggregate-values) 0))
          (do
            (sort-values! (addr aggregate-values))
            (return (value-owned aggregate-values[0]) true ""))
        (and (not aggregate.has-limit)
             (= aggregate.op "max")
             (> (count aggregate-values) 0))
          (do
            (sort-values! (addr aggregate-values))
            (return (value-owned aggregate-values[(- (count aggregate-values) 1)]) true ""))
        :else
          (return current true "")))))

(defn q-db-read-source-single-clause-aggregates [source: DB-Read-Source, query-value: Query, clause-value: Clause] -> Result-Set
  (when (db-read-source-aggregate-streamable? source)
    (let [values (make [dynamic]Value 0 (count query-value.aggregates))
          rows (make [dynamic]Result-Row)
          pulls (make [dynamic]Pull-Result)]
      (for [aggregate query-value.aggregates]
        (let [[value value-ok value-error] (db-read-source-single-clause-aggregate-value-streamed source clause-value query-value aggregate)]
          (when (not value-ok)
            (delete-owned-values-array values)
            (delete pulls)
            (delete rows)
            (return (result-set-error value-error)))
          (arr.push! values value)))
      (arr.push! rows (Result-Row {values: values pulls: pulls}))
      (return (result-set-ok rows))))
  (let [[datoms datoms-ok datoms-error] (db-read-source-clause-candidates source clause-value)]
    (when (not datoms-ok)
      (return (result-set-error datoms-error)))
    (defer (delete-owned-datoms datoms))
      (let [values (make [dynamic]Value 0 (count query-value.aggregates))
          rows (make [dynamic]Result-Row)
          pulls (make [dynamic]Pull-Result)]
      (for [aggregate query-value.aggregates]
        (arr.push! values (db-read-source-single-clause-aggregate-value clause-value (slice datoms 0) query-value aggregate)))
      (arr.push! rows (Result-Row {values: values pulls: pulls}))
      (result-set-ok rows))))

(defn db-read-source-group-values-for-datom [clause: Clause, datom: Datom, names: []string] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value 0 (count names))]
    (for [name names]
      (let [[value value-ok] (db-read-source-datom-value-for-var-owned clause datom name)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn result-row-values-index [rows: []Result-Row, values: []Value] -> [index: int, ok: bool]
  (for [row index rows]
    (when (values-equal? (slice row.values 0) values)
      (return index true)))
  (return 0 false))

(defn values-owned-with-tail [prefix: []Value, tail: []Value] -> [dynamic]Value
  (let [out (make [dynamic]Value 0 (+ (count prefix) (count tail)))]
    (for [value prefix]
      (arr.push! out (value-owned value)))
    (for [value tail]
      (arr.push! out (value-owned value)))
    out))

(defn reduce-db-read-source-single-clause-grouped-aggregate-datom! [rows: ^[dynamic]Result-Row, aggregate-values: ^[dynamic]Value, avg-counts: ^[dynamic]i64, group-top-values: ^[dynamic]Result-Row, seen-keys: ^[dynamic]Result-Row, distinct-values: ^[dynamic]Result-Row, query-value: Query, clause-value: Clause, aggregate: Aggregate-Find, datom: Datom]
  (let [[group-values group-ok] (db-read-source-group-values-for-datom clause-value datom (slice query-value.find 0))]
    (if (not group-ok)
      (delete-owned-values-array group-values)
      (let [[key key-ok] (db-read-source-aggregate-key-values clause-value datom query-value aggregate)]
        (if (not key-ok)
          (do
            (delete-owned-values-array key)
            (delete-owned-values-array group-values))
          (let [aggregate-key (values-owned-with-tail (slice group-values 0) (slice key 0))
                already-seen (row-values-exist? (slice seen-keys^ 0) (slice aggregate-key 0))]
            (delete-owned-values-array key)
            (if already-seen
              (do
                (delete-owned-values-array aggregate-key)
                (delete-owned-values-array group-values))
              (do
                (arr.push! seen-keys^ (Result-Row {values: aggregate-key pulls: (make [dynamic]Pull-Result)}))
                (let [[group-index group-seen] (result-row-values-index (slice rows^ 0) (slice group-values 0))
                      actual-group-index group-index]
                  (when (not group-seen)
                    (set! actual-group-index (count rows^))
                    (arr.push! rows^ (Result-Row {values: group-values pulls: (make [dynamic]Pull-Result)}))
                    (arr.push! aggregate-values^ (aggregate-initial-value aggregate))
                    (arr.push! avg-counts^ 0)
                    (arr.push! group-top-values^ (Result-Row {values: (make [dynamic]Value) pulls: (make [dynamic]Pull-Result)})))
                  (when group-seen
                    (delete-owned-values-array group-values))
                  (if (or (= aggregate.op "count")
                          (= aggregate.op "count-distinct")
                          (= aggregate.op "distinct"))
                    (if (= aggregate.op "count")
                      (set! aggregate-values^[actual-group-index].int-value (+ aggregate-values^[actual-group-index].int-value 1))
                      (let [[input-value input-ok] (db-read-source-datom-value-for-var-owned clause-value datom aggregate.var)]
                        (if input-ok
                          (let [distinct-key (values-owned-with-tail (slice rows^[actual-group-index].values 0) ([]Value [input-value]))
                                distinct-seen (row-values-exist? (slice distinct-values^ 0) (slice distinct-key 0))]
                            (delete-owned-value input-value)
                            (if distinct-seen
                              (delete-owned-values-array distinct-key)
                              (do
                                (arr.push! distinct-values^ (Result-Row {values: distinct-key pulls: (make [dynamic]Pull-Result)}))
                                (if (= aggregate.op "count-distinct")
                                  (set! aggregate-values^[actual-group-index].int-value (+ aggregate-values^[actual-group-index].int-value 1))
                                  (arr.push! aggregate-values^[actual-group-index].items (value-owned input-value))))))
                          (delete-owned-value input-value))))
                    (let [[input-value input-ok] (db-read-source-datom-value-for-var-owned clause-value datom aggregate.var)]
                      (if input-ok
                        (cond
                          (= aggregate.op "sum")
                            (do
                              (set! aggregate-values^[actual-group-index] (apply-aggregate-value aggregate-values^[actual-group-index] aggregate input-value))
                              (delete-owned-value input-value))
                          (= aggregate.op "avg")
                            (do
                              (set! aggregate-values^[actual-group-index] (apply-aggregate-value aggregate-values^[actual-group-index] aggregate input-value))
                              (set! avg-counts^[actual-group-index] (+ avg-counts^[actual-group-index] 1))
                              (delete-owned-value input-value))
                          (= aggregate.op "min")
                            (if aggregate.has-limit
                              (arr.push! group-top-values^[actual-group-index].values input-value)
                              (if (= aggregate-values^[actual-group-index].kind .Nil)
                                (set! aggregate-values^[actual-group-index] input-value)
                                (if (value-less? input-value aggregate-values^[actual-group-index])
                                  (do
                                    (delete-owned-value aggregate-values^[actual-group-index])
                                    (set! aggregate-values^[actual-group-index] input-value))
                                  (delete-owned-value input-value))))
                          (= aggregate.op "max")
                            (if aggregate.has-limit
                              (arr.push! group-top-values^[actual-group-index].values input-value)
                              (if (= aggregate-values^[actual-group-index].kind .Nil)
                                (set! aggregate-values^[actual-group-index] input-value)
                                (if (value-less? aggregate-values^[actual-group-index] input-value)
                                  (do
                                    (delete-owned-value aggregate-values^[actual-group-index])
                                    (set! aggregate-values^[actual-group-index] input-value))
                                  (delete-owned-value input-value))))
                          (or (= aggregate.op "rand")
                              (numeric-aggregate-op? aggregate.op)
                              (= aggregate.op "sample"))
                            (arr.push! group-top-values^[actual-group-index].values input-value)
                          :else
                            (delete-owned-value input-value))
                        (delete-owned-value input-value)))))))))))))

(defn q-db-read-source-single-clause-grouped-aggregate [source: DB-Read-Source, query-value: Query, clause-value: Clause] -> Result-Set
  (let [rows (make [dynamic]Result-Row)
        aggregate-values (make [dynamic]Value)
        avg-counts (make [dynamic]i64)
        group-top-values (make [dynamic]Result-Row)
        seen-keys (make [dynamic]Result-Row)
        distinct-values (make [dynamic]Result-Row)
        aggregate query-value.aggregates[0]]
    (defer (delete-owned-values-array aggregate-values))
    (defer (delete avg-counts))
    (defer (delete-result-rows-owned-values seen-keys))
    (defer (delete-result-rows-owned-values distinct-values))
    (if (db-read-source-has-overlay? source)
      (let [[datoms datoms-ok datoms-error] (db-read-source-datoms-by-attr source clause-value.a.value.text)]
        (when (not datoms-ok)
          (delete-result-rows-owned-values rows)
          (delete-result-rows-owned-values group-top-values)
          (return (result-set-error datoms-error)))
        (defer (delete-owned-datoms datoms))
        (for [datom datoms]
          (reduce-db-read-source-single-clause-grouped-aggregate-datom! (addr rows) (addr aggregate-values) (addr avg-counts) (addr group-top-values) (addr seen-keys) (addr distinct-values) query-value clause-value aggregate datom)))
      (let [[stream stream-ok stream-error] (source-index-datom-stream source clause-value.a.value.text)]
        (when (not stream-ok)
          (delete-result-rows-owned-values rows)
          (delete-result-rows-owned-values group-top-values)
          (return (result-set-error stream-error)))
        (while stream.has-current
          (reduce-db-read-source-single-clause-grouped-aggregate-datom! (addr rows) (addr aggregate-values) (addr avg-counts) (addr group-top-values) (addr seen-keys) (addr distinct-values) query-value clause-value aggregate stream.current)
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream stream)
              (delete-result-rows-owned-values rows)
              (delete-result-rows-owned-values group-top-values)
              (return (result-set-error advance-error)))))
        (delete-source-index-datom-stream stream)))
    (for [aggregate-value index aggregate-values]
      (cond
        (= aggregate.op "distinct")
          (arr.push! rows[index].values (distinct-values-vector-owned (slice aggregate-value.items 0)))
        (and aggregate.has-limit
             (or (= aggregate.op "min")
                 (= aggregate.op "max")))
          (arr.push! rows[index].values (source-top-n-values-owned (slice group-top-values[index].values 0) aggregate.limit (= aggregate.op "max")))
        (and (= aggregate.op "rand") (not aggregate.has-limit))
          (arr.push! rows[index].values (random-value-owned (slice group-top-values[index].values 0)))
        (limited-selection-aggregate-op? aggregate.op)
          (arr.push! rows[index].values (selection-values-owned (slice group-top-values[index].values 0) aggregate.limit aggregate.op))
        (= aggregate.op "median")
          (arr.push! rows[index].values (median-numeric (slice group-top-values[index].values 0)))
        (= aggregate.op "variance")
          (arr.push! rows[index].values (variance-numeric (slice group-top-values[index].values 0)))
        (= aggregate.op "stddev")
          (arr.push! rows[index].values (stddev-numeric (slice group-top-values[index].values 0)))
        (and (= aggregate.op "avg") (> avg-counts[index] 0))
          (if (= aggregate-value.kind .Float)
            (arr.push! rows[index].values (value-float (/ aggregate-value.float-value (f64 avg-counts[index]))))
            (if (= (% aggregate-value.int-value avg-counts[index]) 0)
              (arr.push! rows[index].values (value-int (/ aggregate-value.int-value avg-counts[index])))
              (arr.push! rows[index].values (value-float (/ (f64 aggregate-value.int-value) (f64 avg-counts[index]))))))
        :else
          (arr.push! rows[index].values (value-owned aggregate-value))))
    (delete-result-rows-owned-values group-top-values)
    (return (result-set-ok rows))))

(defn db-read-source-attr-top-n-values [source: DB-Read-Source, plan: Attr-Top-N-Aggregate-Plan, aggregate: Aggregate-Find] -> [value: Value, ok: bool, error: string]
  (let [view (db-read-source-index-view source .AVET)
        attr-prefix ([]Value [(value-keyword plan.attr)])
        [low low-ok low-error] (db-read-source-lower-bound-values source view attr-prefix)]
    (when (not low-ok)
      (return (Value {}) false low-error))
    (let [[high high-ok high-error] (db-read-source-upper-bound-values source view attr-prefix)]
      (when (not high-ok)
        (return (Value {}) false high-error))
      (let [out (make [dynamic]Value)
            last-value (Value {})
            has-last false]
        (defer
          (when has-last
            (delete-owned-value last-value)))
        (if (= aggregate.op "max")
          (let [i high]
            (while (and (> i low)
                        (or (not aggregate.has-limit)
                            (< (count out) aggregate.limit)))
              (set! i (- i 1))
              (let [entry (db-index-view-at view i)
                    [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
                (when (not current-ok)
                  (delete-owned-values-array out)
                  (return (Value {}) false current-error))
                (when current
                  (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
                    (when (not datom-ok)
                      (delete-owned-values-array out)
                      (return (Value {}) false datom-error))
                    (when (not (and has-last (value-equal? datom.v last-value)))
                      (when (not aggregate.has-limit)
                        (let [value (value-owned datom.v)]
                          (delete-owned-datom datom)
                          (delete out)
                          (return value true "")))
                      (arr.push! out (value-owned datom.v))
                      (when has-last
                        (delete-owned-value last-value))
                      (set! last-value (value-owned datom.v))
                      (set! has-last true))
                    (delete-owned-datom datom))))))
          (let [i low]
            (while (and (< i high)
                        (or (not aggregate.has-limit)
                            (< (count out) aggregate.limit)))
              (let [entry (db-index-view-at view i)
                    [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
                (when (not current-ok)
                  (delete-owned-values-array out)
                  (return (Value {}) false current-error))
                (when current
                  (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
                    (when (not datom-ok)
                      (delete-owned-values-array out)
                      (return (Value {}) false datom-error))
                    (when (not (and has-last (value-equal? datom.v last-value)))
                      (when (not aggregate.has-limit)
                        (let [value (value-owned datom.v)]
                          (delete-owned-datom datom)
                          (delete out)
                          (return value true "")))
                      (arr.push! out (value-owned datom.v))
                      (when has-last
                        (delete-owned-value last-value))
                      (set! last-value (value-owned datom.v))
                      (set! has-last true))
                    (delete-owned-datom datom)))
                (set! i (+ i 1))))))
        (if aggregate.has-limit
          (return (value-vector-owned out) true "")
          (do
            (delete out)
            (return (Value {}) true "")))))))

(defn q-db-read-source-attr-top-n-aggregates [source: DB-Read-Source, query-value: Query, plan: Attr-Top-N-Aggregate-Plan] -> Result-Set
  (let [values (make [dynamic]Value 0 (count query-value.aggregates))
        rows (make [dynamic]Result-Row)
        pulls (make [dynamic]Pull-Result)]
    (for [aggregate query-value.aggregates]
      (let [[value value-ok value-error] (db-read-source-attr-top-n-values source plan aggregate)]
        (when (not value-ok)
          (delete-owned-values-array values)
          (delete pulls)
          (delete rows)
          (return (result-set-error value-error)))
        (arr.push! values value)))
    (arr.push! rows (Result-Row {values: values pulls: pulls}))
    (result-set-ok rows)))

(defn db-read-source-bind-rule-args [outer: Binding, call: Rule-Call, rule: Rule] -> [binding: Binding, ok: bool]
  (let [out (Binding {items: (make [dynamic]Var-Binding)})]
    (when (not (= (count call.args) (count rule.params)))
      (return out false))
    (for [param index rule.params]
      (let [arg call.args[index]]
        (case arg.kind
          .Var (let [[value value-ok] (binding-lookup outer arg.name)]
                 (when (and (< index rule.required-param-count)
                            (not value-ok))
                   (return out false))
                 (when value-ok
                   (let [[existing exists] (binding-lookup out param)]
                     (if exists
                       (when (not (predicate-value-equal? existing value))
                         (return out false))
                       (binding-store! (addr out) param (value-owned value))))))
          .Value (let [[existing exists] (binding-lookup out param)]
                   (if exists
                     (when (not (predicate-value-equal? existing arg.value))
                       (return out false))
                     (binding-store! (addr out) param (value-owned arg.value))))
          .Wildcard (do)
           (return out false))))
    (return out true)))

(defn db-read-source-merge-rule-output-owned [outer: Binding, call: Rule-Call, rule: Rule, result: Binding] -> [binding: Binding, ok: bool]
  (let [out (db-read-source-clone-binding-owned outer)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [[value value-ok] (binding-lookup result param)]
            (when value-ok
              (let [[existing exists] (binding-lookup out arg.name)]
                (if exists
                  (when (not (predicate-value-equal? existing value))
                    (db-read-source-delete-binding-owned out)
                    (return (Binding {}) false))
                  (binding-store! (addr out) arg.name (value-owned value)))))))))
    (return out true)))

(defn db-read-source-query-relation-from-attr-param-two-values-same-entity-rule [source: DB-Read-Source, rule: Rule, attr: string, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (let [attrs ([dynamic]string [rule.params[0] rule.params[1] rule.params[2]])
        attr-sources ([dynamic]string ["" "" ""])
        columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0
        seen (set.empty string)
        values (make [dynamic]Value)
        prefix ([]Value [(value-keyword attr)])
        [view low high range-ok range-error] (db-read-source-prefix-index-range source .AEVT prefix)
        current-entity: u64 0
        has-current false
        i low]
    (defer (delete seen))
    (when (not range-ok)
      (delete values)
      (delete-relation-columns columns)
      (delete attrs)
      (delete attr-sources)
      (return (query-relation-empty) false range-error))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (while (< i high)
      (let [entry (db-index-view-at view i)
            [current current-ok current-error] (db-read-source-datom-current-at-entry? source entry)]
        (when (not current-ok)
          (delete values)
          (delete-relation-columns columns)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false current-error))
        (when current
          (let [[datom datom-ok datom-error] (db-read-source-datom-at-entry source entry)]
            (when (not datom-ok)
              (delete values)
              (delete-relation-columns columns)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false datom-error))
            (when (and has-current (not (= datom.e current-entity)))
              (when (not (append-attr-param-two-values-group! (addr columns) (addr typed-rows) (addr seen) attr (slice values 0)))
                (delete-owned-datom datom)
                (delete-owned-values-array values)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false "failed to build attr-param same-entity rule relation"))
              (delete-owned-values-array values)
              (set! values (make [dynamic]Value)))
            (set! current-entity datom.e)
            (set! has-current true)
            (arr.push! values (value-owned datom.v))
            (delete-owned-datom datom)))
        (set! i (+ i 1))))
    (when has-current
      (when (not (append-attr-param-two-values-group! (addr columns) (addr typed-rows) (addr seen) attr (slice values 0)))
        (delete-owned-values-array values)
        (delete-relation-columns columns)
        (delete attrs)
        (delete attr-sources)
        (return (query-relation-empty) false "failed to build attr-param same-entity rule relation")))
    (delete-owned-values-array values)
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true "")))

(defn db-read-source-append-bound-attr-param-same-entity-value! [source: DB-Read-Source, columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), attr: string, bound-left: bool, bound-value: Value, maybe-other-bound: Value, has-other-bound: bool, stats: ^Query-Stats] -> [ok: bool, error: string]
  (let [matching (make [dynamic]Datom)]
    (defer (delete-owned-datoms matching))
    (let [[scan-ok scan-error] (db-read-source-append-attr-value-datoms! (addr matching) source attr bound-value)]
      (when (not scan-ok)
        (return false scan-error)))
    (mut! stats^.source-index-scans += 1)
    (mut! stats^.clause-candidates += (count matching))
    (for [match matching]
      (let [[siblings siblings-ok siblings-error] (db-read-source-datoms-by-entity-attr source match.e attr)]
        (when (not siblings-ok)
          (return false siblings-error))
        (mut! stats^.source-index-scans += 1)
        (mut! stats^.clause-candidates += (count siblings))
        (for [sibling siblings]
          (when (not (predicate-value-equal? sibling.v bound-value))
            (when (or (not has-other-bound)
                      (predicate-value-equal? sibling.v maybe-other-bound))
              (let [left-value (if bound-left bound-value sibling.v)
                    right-value (if bound-left sibling.v bound-value)]
                (when (not (append-attr-param-two-values-row! columns rows seen attr left-value right-value))
                  (delete-owned-datoms siblings)
                  (return false "failed to build bounded attr-param same-entity rule relation"))))))
        (delete-owned-datoms siblings))))
  (return true ""))

(defn db-read-source-query-relation-from-bound-attr-param-two-values-same-entity-rule [source: DB-Read-Source, rel: Query-Relation, rule: Rule, call: Rule-Call, attr: string, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, error: string]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false ""))
  (let [left-bound false
        right-bound false
        attrs ([dynamic]string [rule.params[0] rule.params[1] rule.params[2]])
        attr-sources ([dynamic]string ["" "" ""])
        columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0
        seen (set.empty string)
        row 0]
    (when (= call.args[1].kind .Var)
      (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[1].name)]
        (set! left-bound index-ok)))
    (when (= call.args[2].kind .Var)
      (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[2].name)]
        (set! right-bound index-ok)))
    (when (not (or left-bound right-bound))
      (delete-relation-columns columns)
      (delete attrs)
      (delete attr-sources)
      (return (query-relation-empty) false ""))
    (defer (delete seen))
    (while (< row rel.typed-rows)
      (let [left-value (Value {})
            left-ok false
            right-value (Value {})
            right-ok false]
        (when (and (= call.args[1].kind .Var) left-bound)
          (let [[value value-ok] (query-relation-typed-row-value rel row call.args[1].name)]
            (set! left-value value)
            (set! left-ok value-ok)))
        (when (and (= call.args[2].kind .Var) right-bound)
          (let [[value value-ok] (query-relation-typed-row-value rel row call.args[2].name)]
            (set! right-value value)
            (set! right-ok value-ok)))
        (if left-ok
          (let [[append-ok append-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr columns) (addr typed-rows) (addr seen) attr true left-value right-value right-ok stats)]
            (when (not append-ok)
              (delete-relation-columns columns)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false append-error)))
          (when right-ok
            (let [[append-ok append-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr columns) (addr typed-rows) (addr seen) attr false right-value left-value left-ok stats)]
              (when (not append-ok)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false append-error))))))
      (set! row (+ row 1)))
    (query-stats-observe-source-operator! stats)
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true "")))

(defn rule-call-arg-var-name? [call: Rule-Call, index: int, name: string] -> bool
  (and (< index (count call.args))
       (term-var-name? call.args[index] name)))

(defn rule-body-only-rule-calls-and-distinct-predicate? [rule: Rule] -> bool
  (when (or (> (count rule.clauses) 0)
            (> (count rule.function-clauses) 0)
            (> (count rule.get-elses) 0)
            (> (count rule.get-somes) 0)
            (> (count rule.grounds) 0)
            (> (count rule.not-groups) 0)
            (> (count rule.or-groups) 0)
            (> (count rule.predicates) 1))
    (return false))
  (when (= (count rule.predicates) 1)
    (let [predicate rule.predicates[0]]
      (when (not (or (= predicate.op "!=")
                     (= predicate.op "not=")))
        (return false))))
  true)

(defn direct-attr-param-derived-rule-base-name [rule: Rule] -> [base-name: string, ok: bool]
  (when (not (and (= (count rule.params) 3)
                  (= (count rule.rule-calls) 1)
                  (= (count rule.body-steps) 1)
                  (= rule.body-steps[0].kind .RuleCall)
                  (rule-body-only-rule-calls-and-distinct-predicate? rule)))
    (return "" false))
  (let [call rule.rule-calls[0]]
    (when (not (and (rule-call-arg-var-name? call 0 rule.params[0])
                    (rule-call-arg-var-name? call 1 rule.params[1])
                    (rule-call-arg-var-name? call 2 rule.params[2])))
      (return "" false))
    (return call.name true)))

(defn two-hop-attr-param-derived-rule-base-name [rule: Rule] -> [base-name: string, ok: bool]
  (when (not (and (= (count rule.params) 3)
                  (= (count rule.rule-calls) 2)
                  (rule-body-only-rule-calls-and-distinct-predicate? rule)))
    (return "" false))
  (let [left-call rule.rule-calls[0]
        right-call rule.rule-calls[1]]
    (when (not (= left-call.name right-call.name))
      (return "" false))
    (when (not (and (rule-call-arg-var-name? left-call 0 rule.params[0])
                    (rule-call-arg-var-name? left-call 1 rule.params[1])
                    (rule-call-arg-var-name? right-call 0 rule.params[0])
                    (rule-call-arg-var-name? right-call 2 rule.params[2])
                    (< 2 (count left-call.args))
                    (< 1 (count right-call.args))
                    (= left-call.args[2].kind .Var)
                    (= right-call.args[1].kind .Var)
                    (= left-call.args[2].name right-call.args[1].name)))
      (return "" false))
    (when (= (count rule.predicates) 1)
      (when (not (rule-attr-param-distinct-predicate? rule rule.params[1] rule.params[2]))
        (return "" false)))
    (return left-call.name true)))

(defn attr-param-two-values-same-entity-rule-shape? [rule: Rule] -> bool
  (when (not (and (= (count rule.params) 3)
                  (= (count rule.clauses) 2)
                  (= (count rule.rule-calls) 0)
                  (= (count rule.function-clauses) 0)
                  (= (count rule.get-elses) 0)
                  (= (count rule.get-somes) 0)
                  (= (count rule.grounds) 0)
                  (= (count rule.not-groups) 0)
                  (= (count rule.or-groups) 0)))
    (return false))
  (let [attr-param rule.params[0]
        left-param rule.params[1]
        right-param rule.params[2]
        first rule.clauses[0]
        second rule.clauses[1]]
    (when (not (rule-attr-param-distinct-predicate? rule left-param right-param))
      (return false))
    (when (not (and (= first.e.kind .Var)
                    (= second.e.kind .Var)
                    (= first.e.name second.e.name)))
      (return false))
    (let [entity-var first.e.name]
      (or (and (attr-param-two-values-clause? first entity-var attr-param left-param)
               (attr-param-two-values-clause? second entity-var attr-param right-param))
          (and (attr-param-two-values-clause? first entity-var attr-param right-param)
               (attr-param-two-values-clause? second entity-var attr-param left-param))))))

(defn two-hop-attr-param-derived-rule-shape [rules: []Rule, name: string] -> [direct-rule: Rule, hop-rule: Rule, base-rule: Rule, ok: bool]
  (let [found-direct false
        found-hop false
        direct (Rule {})
        hop (Rule {})
        base-name ""]
    (for [rule rules]
      (when (= rule.name name)
        (let [[candidate-base direct-ok] (direct-attr-param-derived-rule-base-name rule)]
          (when direct-ok
            (set! direct rule)
            (set! found-direct true)
            (set! base-name candidate-base)))
        (let [[candidate-base hop-ok] (two-hop-attr-param-derived-rule-base-name rule)]
          (when hop-ok
            (set! hop rule)
            (set! found-hop true)
            (set! base-name candidate-base)))))
    (when (not (and found-direct found-hop))
      (return direct hop (Rule {}) false))
    (for [rule rules]
      (when (= rule.name base-name)
        (when (attr-param-two-values-same-entity-rule-shape? rule)
          (return direct hop rule true))))
    (return direct hop (Rule {}) false)))

(defn append-attr-param-three-value-row! [columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), attr: string, left-value: Value, right-value: Value] -> bool
  (append-attr-param-two-values-row! columns rows seen attr left-value right-value))

(defn db-read-source-query-relation-from-two-hop-attr-param-rule-call [source: DB-Read-Source, rules: []Rule, call: Rule-Call, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (when (not (and (= (count call.args) 3)
                  (= call.args[0].kind .Value)
                  (= call.args[0].value.kind .Keyword)))
    (return (query-relation-empty) false ""))
  (let [[direct-rule _ base-rule shape-ok] (two-hop-attr-param-derived-rule-shape rules call.name)]
    (when (not shape-ok)
      (return (query-relation-empty) false ""))
    (let [attr call.args[0].value.text
          [base-rel base-ok base-error] (db-read-source-query-relation-from-attr-param-two-values-same-entity-rule source base-rule attr stats)]
      (when (not base-ok)
        (delete-query-relation base-rel)
        (return (query-relation-empty) false base-error))
      (let [attrs ([dynamic]string [direct-rule.params[0] direct-rule.params[1] direct-rule.params[2]])
            attr-sources ([dynamic]string ["" "" ""])
            columns (relation-columns-for-attrs (slice attrs 0))
            rows 0
            seen (set.empty string)
            left-values (make [dynamic]Value 0 base-rel.typed-rows)
            right-values (make [dynamic]Value 0 base-rel.typed-rows)]
        (defer (delete seen))
        (let [row 0]
          (while (< row base-rel.typed-rows)
            (let [[left-value left-ok] (typed-relation-column-value base-rel.typed-columns[1] row)
                  [right-value right-ok] (typed-relation-column-value base-rel.typed-columns[2] row)]
              (when (not (and left-ok right-ok))
                (delete-query-relation base-rel)
                (delete-owned-values-array left-values)
                (delete-owned-values-array right-values)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false "failed to read two-hop attr-param base relation"))
              (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr left-value right-value))
                (delete-query-relation base-rel)
                (delete-owned-values-array left-values)
                (delete-owned-values-array right-values)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false "failed to build two-hop attr-param relation"))
              (arr.push! left-values (value-owned left-value))
              (arr.push! right-values (value-owned right-value)))
            (set! row (+ row 1))))
        (let [left-index 0]
          (while (< left-index (count left-values))
            (let [right-index 0]
              (while (< right-index (count left-values))
                (when (and (predicate-value-equal? right-values[left-index] left-values[right-index])
                           (not (predicate-value-equal? left-values[left-index] right-values[right-index])))
                  (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr left-values[left-index] right-values[right-index]))
                    (delete-query-relation base-rel)
                    (delete-owned-values-array left-values)
                    (delete-owned-values-array right-values)
                    (delete-relation-columns columns)
                    (delete attrs)
                    (delete attr-sources)
                    (return (query-relation-empty) false "failed to build two-hop attr-param relation")))
                (set! right-index (+ right-index 1))))
            (set! left-index (+ left-index 1))))
        (delete-query-relation base-rel)
        (delete-owned-values-array left-values)
        (delete-owned-values-array right-values)
        (let [derived-rel (Query-Relation {attrs: attrs
                                           attr-sources: attr-sources
                                           attr-index: (query-relation-attr-index (slice attrs 0))
                                           tuples: (make [dynamic]Binding)
                                           typed-columns: columns
                                           typed-rows: rows
                                           has-typed-columns: true})
              [projected projected-ok] (query-relation-project-rule-call-params-typed derived-rel (slice direct-rule.params 0) call)]
          (delete-query-relation derived-rel)
          (return projected projected-ok ""))))))

(defn db-read-source-query-relation-append-reverse-derived-edge-from-left! [source: DB-Read-Source, columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), left-attr: string, right-attr: string, left-entity: u64, has-right: bool, right-value: Value] -> [ok: bool, error: string]
  (let [[middle-stream middle-ok middle-error] (source-vaet-entity-attr-stream source left-entity left-attr)]
    (when (not middle-ok)
      (return false middle-error))
    (while middle-stream.has-current
      (let [[right-stream right-ok right-error] (source-vaet-entity-attr-stream source middle-stream.current.e right-attr)]
        (when (not right-ok)
          (delete-source-index-datom-stream middle-stream)
          (return false right-error))
        (while right-stream.has-current
          (let [right-entity-value (value-entity right-stream.current.e)]
            (when (or (not has-right)
                      (predicate-value-equal? right-entity-value right-value))
              (when (not (append-two-param-relation-row! columns rows seen (value-entity left-entity) right-entity-value))
                (delete-source-index-datom-stream right-stream)
                (delete-source-index-datom-stream middle-stream)
                (return false "failed to build reverse derived-edge rule relation"))))
          (let [[advance-right-ok advance-right-error] (advance-source-index-datom-stream! source (addr right-stream))]
            (when (not advance-right-ok)
              (delete-source-index-datom-stream right-stream)
              (delete-source-index-datom-stream middle-stream)
              (return false advance-right-error))))
        (delete-source-index-datom-stream right-stream))
      (let [[advance-middle-ok advance-middle-error] (advance-source-index-datom-stream! source (addr middle-stream))]
        (when (not advance-middle-ok)
          (delete-source-index-datom-stream middle-stream)
          (return false advance-middle-error))))
    (delete-source-index-datom-stream middle-stream)
    (return true "")))

(defn db-read-source-query-relation-append-reverse-derived-edge-from-right! [source: DB-Read-Source, columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), left-attr: string, right-attr: string, right-entity: u64] -> [ok: bool, error: string]
  (let [[middle-stream middle-ok middle-error] (source-eavt-entity-attr-stream source right-entity right-attr)]
    (when (not middle-ok)
      (return false middle-error))
    (while middle-stream.has-current
      (let [[middle-entity middle-entity-ok] (value-as-db-entity middle-stream.current.v)]
        (when middle-entity-ok
          (let [[left-stream left-ok left-error] (source-eavt-entity-attr-stream source middle-entity left-attr)]
            (when (not left-ok)
              (delete-source-index-datom-stream middle-stream)
              (return false left-error))
            (while left-stream.has-current
              (let [[left-entity left-entity-ok] (value-as-db-entity left-stream.current.v)]
                (when left-entity-ok
                  (when (not (append-two-param-relation-row! columns rows seen (value-entity left-entity) (value-entity right-entity)))
                    (delete-source-index-datom-stream left-stream)
                    (delete-source-index-datom-stream middle-stream)
                    (return false "failed to build reverse derived-edge rule relation"))))
              (let [[advance-left-ok advance-left-error] (advance-source-index-datom-stream! source (addr left-stream))]
                (when (not advance-left-ok)
                  (delete-source-index-datom-stream left-stream)
                  (delete-source-index-datom-stream middle-stream)
                  (return false advance-left-error))))
            (delete-source-index-datom-stream left-stream))))
      (let [[advance-middle-ok advance-middle-error] (advance-source-index-datom-stream! source (addr middle-stream))]
        (when (not advance-middle-ok)
          (delete-source-index-datom-stream middle-stream)
          (return false advance-middle-error))))
    (delete-source-index-datom-stream middle-stream)
    (return true "")))

(defstruct Reverse-Derived-Left-Link {
  left: u64
  next: int
})

(defstruct Reverse-Derived-Row-Link {
  row: int
  next: int
})

(defn append-reverse-derived-left-link! [heads: ^map[u64]int, links: ^[dynamic]Reverse-Derived-Left-Link, middle: u64, left: u64]
  (let [[head found] (mmap.get heads^ middle)
        next (if found head -1)
        index (count links^)]
    (arr.push! links^ (Reverse-Derived-Left-Link {left: left
                                                   next: next}))
    (mmap.assoc! heads^ middle index)))

(defn append-reverse-derived-row-link! [heads: ^map[u64]int, links: ^[dynamic]Reverse-Derived-Row-Link, entity: u64, row: int]
  (let [[head found] (mmap.get heads^ entity)
        next (if found head -1)
        index (count links^)]
    (arr.push! links^ (Reverse-Derived-Row-Link {row: row
                                                  next: next}))
    (mmap.assoc! heads^ entity index)))

(defn query-relation-has-all-attrs? [rel: Query-Relation, attrs: []string] -> bool
  (for [attr attrs]
    (when (not (query-relation-has-attr? rel attr))
      (return false)))
  true)

(defn db-read-source-query-relation-append-reverse-derived-edge-from-left-frontier! [source: DB-Read-Source, columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), left-attr: string, right-attr: string, left-entities: []u64] -> [ok: bool, used: bool, error: string]
  (when (= (count left-entities) 0)
    (return true true ""))
  (let [middle-heads (make (map u64 int))
        middle-links (make [dynamic]Reverse-Derived-Left-Link)
        middle-seen (set.empty u64)
        middle-entities (make [dynamic]u64)]
    (let [[middle-stream middle-ok middle-used _middle-candidates middle-error] (source-vaet-entity-attr-frontier-stream source left-entities left-attr)]
      (when (not middle-ok)
        (delete middle-heads)
        (delete middle-links)
        (delete middle-seen)
        (delete middle-entities)
        (return false true middle-error))
      (when (not middle-used)
        (delete middle-heads)
        (delete middle-links)
        (delete middle-seen)
        (delete middle-entities)
        (return true false ""))
      (while middle-stream.has-current
        (when (= middle-stream.current.v.kind .Entity)
          (let [left-entity middle-stream.current.v.entity
                middle-entity middle-stream.current.e
                middle-new (not (set.contains? middle-seen middle-entity))]
            (when middle-new
              (set.add! middle-seen middle-entity)
              (arr.push! middle-entities middle-entity))
            (append-reverse-derived-left-link! (addr middle-heads) (addr middle-links) middle-entity left-entity)))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr middle-stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream middle-stream)
            (delete middle-heads)
            (delete middle-links)
            (delete middle-seen)
            (delete middle-entities)
            (return false true advance-error))))
      (delete-source-index-datom-stream middle-stream))
    (let [[right-stream right-ok right-used _right-candidates right-error] (source-vaet-entity-attr-frontier-stream source (slice middle-entities 0) right-attr)]
      (when (not right-ok)
        (delete middle-heads)
        (delete middle-links)
        (delete middle-seen)
        (delete middle-entities)
        (return false true right-error))
      (when (not right-used)
        (delete middle-heads)
        (delete middle-links)
        (delete middle-seen)
        (delete middle-entities)
        (return true false ""))
      (while right-stream.has-current
        (when (= right-stream.current.v.kind .Entity)
          (let [middle-entity right-stream.current.v.entity
                [head found] (mmap.get middle-heads middle-entity)]
            (when found
              (let [index head]
                (while (>= index 0)
                  (when (not (append-two-param-relation-row! columns rows seen (value-entity middle-links[index].left) (value-entity right-stream.current.e)))
                    (delete-source-index-datom-stream right-stream)
                    (delete middle-heads)
                    (delete middle-links)
                    (delete middle-seen)
                    (delete middle-entities)
                    (return false true "failed to build reverse derived-edge rule relation"))
                  (set! index middle-links[index].next))))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr right-stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream right-stream)
            (delete middle-heads)
            (delete middle-links)
            (delete middle-seen)
            (delete middle-entities)
            (return false true advance-error))))
      (delete-source-index-datom-stream right-stream))
    (delete middle-heads)
    (delete middle-links)
    (delete middle-seen)
    (delete middle-entities)
    (return true true "")))

(defn db-read-source-query-relation-from-bound-reverse-derived-edge-link-step [source: DB-Read-Source, rel: Query-Relation, call: Rule-Call, left-attr: string, right-attr: string] -> [out: Query-Relation, ok: bool, used: bool, error: string]
  (when (not (and rel.has-typed-columns
                  (= (count call.args) 2)
                  (= call.args[0].kind .Var)
                  (= call.args[1].kind .Var)
                  (query-relation-has-attr? rel call.args[0].name)
                  (not (query-relation-has-attr? rel call.args[1].name))))
    (return (query-relation-empty) false false ""))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (arr.push! attrs call.args[1].name)
    (arr.push! attr-sources "")
    (let [builder (query-relation-builder-with-capacity (slice attrs 0) rel.typed-rows)
          left-heads (make (map u64 int)) :defer
          left-links (make [dynamic]Reverse-Derived-Row-Link) :defer
          left-seen (set.empty u64) :defer
          left-entities (make [dynamic]u64) :defer
          row 0]
      (while (< row rel.typed-rows)
        (let [[left-value left-ok] (query-relation-typed-row-value rel row call.args[0].name)]
          (when left-ok
            (let [[left-entity left-entity-ok] (value-as-db-entity left-value)]
              (when left-entity-ok
                (append-reverse-derived-row-link! (addr left-heads) (addr left-links) left-entity row)
                (when (not (set.contains? left-seen left-entity))
                  (set.add! left-seen left-entity)
                  (arr.push! left-entities left-entity))))))
        (mut! row += 1))
      (when (= (count left-entities) 0)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true true ""))
      (let [middle-heads (make (map u64 int)) :defer
            middle-links (make [dynamic]Reverse-Derived-Row-Link) :defer
            middle-seen (set.empty u64) :defer
            middle-entities (make [dynamic]u64) :defer
            [middle-stream middle-ok middle-used _middle-candidates middle-error] (source-vaet-entity-attr-frontier-stream source (slice left-entities 0) left-attr)]
        (when (not middle-ok)
          (delete-query-relation-builder builder)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false true middle-error))
        (when (not middle-used)
          (delete-query-relation-builder builder)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false false ""))
        (while middle-stream.has-current
          (when (= middle-stream.current.v.kind .Entity)
            (let [left-entity middle-stream.current.v.entity
                  middle-entity middle-stream.current.e
                  [left-head left-found] (mmap.get left-heads left-entity)]
              (when left-found
                (when (not (set.contains? middle-seen middle-entity))
                  (set.add! middle-seen middle-entity)
                  (arr.push! middle-entities middle-entity))
                (let [left-index left-head]
                  (while (>= left-index 0)
                    (append-reverse-derived-row-link! (addr middle-heads) (addr middle-links) middle-entity left-links[left-index].row)
                    (set! left-index left-links[left-index].next))))))
          (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr middle-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream middle-stream)
              (delete-query-relation-builder builder)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false true advance-error))))
        (delete-source-index-datom-stream middle-stream)
        (let [[right-stream right-ok right-used _right-candidates right-error] (source-vaet-entity-attr-frontier-stream source (slice middle-entities 0) right-attr)]
          (when (not right-ok)
            (delete-query-relation-builder builder)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false true right-error))
          (when (not right-used)
            (delete-query-relation-builder builder)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false false ""))
          (while right-stream.has-current
            (when (= right-stream.current.v.kind .Entity)
              (let [middle-entity right-stream.current.v.entity
                    right-value (value-entity right-stream.current.e)
                    [middle-head middle-found] (mmap.get middle-heads middle-entity)]
                (when middle-found
                  (let [middle-index middle-head]
                    (while (>= middle-index 0)
                      (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) middle-links[middle-index].row call.args[1].name right-value))
                        (delete-source-index-datom-stream right-stream)
                        (delete-query-relation-builder builder)
                        (delete attrs)
                        (delete attr-sources)
                        (return (query-relation-empty) false true "failed to build bound reverse derived-edge rule relation"))
                      (set! middle-index middle-links[middle-index].next))))))
            (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr right-stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream right-stream)
                (delete-query-relation-builder builder)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false true advance-error))))
          (delete-source-index-datom-stream right-stream)))
      (let [raw (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok})
            deduped (query-relation-dedupe-step raw)]
        (delete-query-relation raw)
        (return deduped deduped.has-typed-columns true "")))))

(defn db-read-source-query-relation-from-reverse-derived-edge-rule-call [source: DB-Read-Source, rules: []Rule, call: Rule-Call, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool, error: string]
  (when (not (= (count call.args) 2))
    (return (query-relation-empty) false ""))
  (let [[rule left-attr right-attr shape-ok] (rule-two-hop-reverse-derived-edge rules call.name)]
    (when (not shape-ok)
      (return (query-relation-empty) false ""))
    (let [attrs ([dynamic]string [rule.params[0] rule.params[1]])
          attr-sources ([dynamic]string ["" ""])
          columns (relation-columns-for-attrs (slice attrs 0))
          rows 0
          seen (set.empty string)
          [left-stream left-ok left-error] (source-index-datom-stream source left-attr)]
      (defer (delete seen))
      (when (not left-ok)
        (delete-relation-columns columns)
        (delete attrs)
        (delete attr-sources)
        (return (query-relation-empty) false left-error))
      (while left-stream.has-current
        (let [[left-entity left-entity-ok] (value-as-db-entity left-stream.current.v)]
          (when left-entity-ok
            (let [[append-ok append-error] (db-read-source-query-relation-append-reverse-derived-edge-from-left! source (addr columns) (addr rows) (addr seen) left-attr right-attr left-entity false (Value {}))]
              (when (not append-ok)
                (delete-source-index-datom-stream left-stream)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false append-error)))))
        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr left-stream))]
          (when (not advance-ok)
            (delete-source-index-datom-stream left-stream)
            (delete-relation-columns columns)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false advance-error))))
      (delete-source-index-datom-stream left-stream)
      (query-stats-observe-source-operator! stats)
      (mut! stats^.clauses += 2)
      (mut! stats^.source-index-scans += 2)
      (let [derived-rel (Query-Relation {attrs: attrs
                                         attr-sources: attr-sources
                                         attr-index: (query-relation-attr-index (slice attrs 0))
                                         tuples: (make [dynamic]Binding)
                                         typed-columns: columns
                                         typed-rows: rows
                                         has-typed-columns: true})
            [projected projected-ok] (query-relation-project-rule-call-params-typed derived-rel (slice rule.params 0) call)]
        (delete-query-relation derived-rel)
        (return projected projected-ok "")))))

(defn db-read-source-query-relation-from-bound-reverse-derived-edge-rule-call [source: DB-Read-Source, rel: Query-Relation, rules: []Rule, call: Rule-Call, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, error: string]
  (when (not (and rel.has-typed-columns
                  (= (count call.args) 2)))
    (return (query-relation-empty) false ""))
  (let [[rule left-attr right-attr shape-ok] (rule-two-hop-reverse-derived-edge rules call.name)]
    (when (not shape-ok)
      (return (query-relation-empty) false ""))
    (let [left-bound false
          right-bound false]
      (when (= call.args[0].kind .Var)
        (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[0].name)]
          (set! left-bound index-ok)))
      (when (= call.args[1].kind .Var)
        (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[1].name)]
          (set! right-bound index-ok)))
      (when (not (or left-bound right-bound))
        (return (query-relation-empty) false ""))
      (when (and left-bound
                 (not right-bound))
        (let [[linked linked-ok linked-used linked-error] (db-read-source-query-relation-from-bound-reverse-derived-edge-link-step source rel call left-attr right-attr)]
          (when (not (= linked-error ""))
            (delete-query-relation linked)
            (return (query-relation-empty) false linked-error))
          (when linked-used
            (when linked-ok
              (query-stats-observe-source-operator! stats)
              (mut! stats^.clauses += 2)
              (mut! stats^.source-index-scans += 2)
              (return linked true ""))
            (delete-query-relation linked))))
      (let [attrs ([dynamic]string [rule.params[0] rule.params[1]])
            attr-sources ([dynamic]string ["" ""])
            columns (relation-columns-for-attrs (slice attrs 0))
            rows 0
            seen (set.empty string)
            row 0]
        (defer (delete seen))
        (when (and left-bound
                   (not right-bound)
                   (= call.args[0].kind .Var))
          (let [left-seen (set.empty u64) :defer
                left-entities (make [dynamic]u64) :defer
                collect-row 0]
            (while (< collect-row rel.typed-rows)
              (let [[left-value left-ok] (query-relation-typed-row-value rel collect-row call.args[0].name)]
                (when left-ok
                  (let [[left-entity left-entity-ok] (value-as-db-entity left-value)]
                    (when (and left-entity-ok
                               (not (set.contains? left-seen left-entity)))
                      (set.add! left-seen left-entity)
                      (arr.push! left-entities left-entity)))))
              (set! collect-row (+ collect-row 1)))
            (let [[frontier-ok frontier-used frontier-error] (db-read-source-query-relation-append-reverse-derived-edge-from-left-frontier! source (addr columns) (addr rows) (addr seen) left-attr right-attr (slice left-entities 0))]
              (when (not frontier-ok)
                (delete-relation-columns columns)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false frontier-error))
              (when frontier-used
                (set! row rel.typed-rows)))))
        (while (< row rel.typed-rows)
          (let [left-value (Value {})
                left-ok false
                right-value (Value {})
                right-ok false]
            (when (and left-bound (= call.args[0].kind .Var))
              (let [[value value-ok] (query-relation-typed-row-value rel row call.args[0].name)]
                (set! left-value value)
                (set! left-ok value-ok)))
            (when (and right-bound (= call.args[1].kind .Var))
              (let [[value value-ok] (query-relation-typed-row-value rel row call.args[1].name)]
                (set! right-value value)
                (set! right-ok value-ok)))
            (if left-ok
              (let [[left-entity left-entity-ok] (value-as-db-entity left-value)]
                (when left-entity-ok
                  (let [[append-ok append-error] (db-read-source-query-relation-append-reverse-derived-edge-from-left! source (addr columns) (addr rows) (addr seen) left-attr right-attr left-entity right-ok right-value)]
                    (when (not append-ok)
                      (delete-relation-columns columns)
                      (delete attrs)
                      (delete attr-sources)
                      (return (query-relation-empty) false append-error)))))
              (when right-ok
                (let [[right-entity right-entity-ok] (value-as-db-entity right-value)]
                  (when right-entity-ok
                    (let [[append-ok append-error] (db-read-source-query-relation-append-reverse-derived-edge-from-right! source (addr columns) (addr rows) (addr seen) left-attr right-attr right-entity)]
                      (when (not append-ok)
                        (delete-relation-columns columns)
                        (delete attrs)
                        (delete attr-sources)
                        (return (query-relation-empty) false append-error))))))))
          (set! row (+ row 1)))
        (query-stats-observe-source-operator! stats)
        (mut! stats^.clauses += 2)
        (mut! stats^.source-index-scans += 2)
        (let [derived-rel (Query-Relation {attrs: attrs
                                           attr-sources: attr-sources
                                           attr-index: (query-relation-attr-index (slice attrs 0))
                                           tuples: (make [dynamic]Binding)
                                           typed-columns: columns
                                           typed-rows: rows
                                           has-typed-columns: true})
              [projected projected-ok] (query-relation-project-rule-call-params-typed derived-rel (slice rule.params 0) call)]
          (delete-query-relation derived-rel)
          (return projected projected-ok ""))))))

(defn db-read-source-query-relation-from-bound-two-hop-attr-param-rule-call [source: DB-Read-Source, rel: Query-Relation, rules: []Rule, call: Rule-Call, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, error: string]
  (when (not (and rel.has-typed-columns
                  (= (count call.args) 3)
                  (= call.args[0].kind .Value)
                  (= call.args[0].value.kind .Keyword)))
    (return (query-relation-empty) false ""))
  (let [[direct-rule _ base-rule shape-ok] (two-hop-attr-param-derived-rule-shape rules call.name)]
    (when (not shape-ok)
      (return (query-relation-empty) false ""))
    (let [left-bound false
          right-bound false]
      (when (= call.args[1].kind .Var)
        (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[1].name)]
          (set! left-bound index-ok)))
      (when (= call.args[2].kind .Var)
        (let [[_ index-ok] (query-relation-attr-index-lookup rel call.args[2].name)]
          (set! right-bound index-ok)))
      (when (not (or left-bound right-bound))
        (return (query-relation-empty) false ""))
      (let [attr call.args[0].value.text
            attrs ([dynamic]string [direct-rule.params[0] direct-rule.params[1] direct-rule.params[2]])
            attr-sources ([dynamic]string ["" "" ""])
            columns (relation-columns-for-attrs (slice attrs 0))
            rows 0
            seen (set.empty string)
            row 0]
        (defer (delete seen))
        (while (< row rel.typed-rows)
          (let [left-value (Value {})
                left-ok false
                right-value (Value {})
                right-ok false]
            (when (and (= call.args[1].kind .Var) left-bound)
              (let [[value value-ok] (query-relation-typed-row-value rel row call.args[1].name)]
                (set! left-value value)
                (set! left-ok value-ok)))
            (when (and (= call.args[2].kind .Var) right-bound)
              (let [[value value-ok] (query-relation-typed-row-value rel row call.args[2].name)]
                (set! right-value value)
                (set! right-ok value-ok)))
            (when left-ok
              (let [first-columns (relation-columns-for-attrs (slice attrs 0))
                    first-rows 0
                    first-seen (set.empty string)
                    [first-ok first-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr first-columns) (addr first-rows) (addr first-seen) attr true left-value (Value {}) false stats)]
                (delete first-seen)
                (when (not first-ok)
                  (delete-relation-columns first-columns)
                  (delete-relation-columns columns)
                  (delete attrs)
                  (delete attr-sources)
                  (return (query-relation-empty) false first-error))
                (let [first-row 0]
                  (while (< first-row first-rows)
                    (let [[middle-value middle-ok] (typed-relation-column-value first-columns[2] first-row)]
                      (when middle-ok
                        (when (or (not right-ok)
                                  (predicate-value-equal? middle-value right-value))
                          (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr left-value middle-value))
                            (delete-relation-columns first-columns)
                            (delete-relation-columns columns)
                            (delete attrs)
                            (delete attr-sources)
                            (return (query-relation-empty) false "failed to build bounded two-hop attr-param relation")))
                        (let [second-columns (relation-columns-for-attrs (slice attrs 0))
                              second-rows 0
                              second-seen (set.empty string)
                              [second-ok second-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr second-columns) (addr second-rows) (addr second-seen) attr true middle-value right-value right-ok stats)]
                          (delete second-seen)
                          (when (not second-ok)
                            (delete-relation-columns second-columns)
                            (delete-relation-columns first-columns)
                            (delete-relation-columns columns)
                            (delete attrs)
                            (delete attr-sources)
                            (return (query-relation-empty) false second-error))
                          (let [second-row 0]
                            (while (< second-row second-rows)
                              (let [[candidate-value candidate-ok] (typed-relation-column-value second-columns[2] second-row)]
                                (when (and candidate-ok
                                           (not (predicate-value-equal? left-value candidate-value)))
                                  (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr left-value candidate-value))
                                    (delete-relation-columns second-columns)
                                    (delete-relation-columns first-columns)
                                    (delete-relation-columns columns)
                                    (delete attrs)
                                    (delete attr-sources)
                                    (return (query-relation-empty) false "failed to build bounded two-hop attr-param relation"))))
                              (set! second-row (+ second-row 1))))
                          (delete-relation-columns second-columns))))
                    (set! first-row (+ first-row 1))))
                (delete-relation-columns first-columns)))
            (when (and right-ok (not left-ok))
              (let [first-columns (relation-columns-for-attrs (slice attrs 0))
                    first-rows 0
                    first-seen (set.empty string)
                    [first-ok first-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr first-columns) (addr first-rows) (addr first-seen) attr false right-value (Value {}) false stats)]
                (delete first-seen)
                (when (not first-ok)
                  (delete-relation-columns first-columns)
                  (delete-relation-columns columns)
                  (delete attrs)
                  (delete attr-sources)
                  (return (query-relation-empty) false first-error))
                (let [first-row 0]
                  (while (< first-row first-rows)
                    (let [[middle-value middle-ok] (typed-relation-column-value first-columns[1] first-row)]
                      (when middle-ok
                        (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr middle-value right-value))
                          (delete-relation-columns first-columns)
                          (delete-relation-columns columns)
                          (delete attrs)
                          (delete attr-sources)
                          (return (query-relation-empty) false "failed to build bounded two-hop attr-param relation"))
                        (let [second-columns (relation-columns-for-attrs (slice attrs 0))
                              second-rows 0
                              second-seen (set.empty string)
                              [second-ok second-error] (db-read-source-append-bound-attr-param-same-entity-value! source (addr second-columns) (addr second-rows) (addr second-seen) attr false middle-value (Value {}) false stats)]
                          (delete second-seen)
                          (when (not second-ok)
                            (delete-relation-columns second-columns)
                            (delete-relation-columns first-columns)
                            (delete-relation-columns columns)
                            (delete attrs)
                            (delete attr-sources)
                            (return (query-relation-empty) false second-error))
                          (let [second-row 0]
                            (while (< second-row second-rows)
                              (let [[candidate-value candidate-ok] (typed-relation-column-value second-columns[1] second-row)]
                                (when (and candidate-ok
                                           (not (predicate-value-equal? candidate-value right-value)))
                                  (when (not (append-attr-param-three-value-row! (addr columns) (addr rows) (addr seen) attr candidate-value right-value))
                                    (delete-relation-columns second-columns)
                                    (delete-relation-columns first-columns)
                                    (delete-relation-columns columns)
                                    (delete attrs)
                                    (delete attr-sources)
                                    (return (query-relation-empty) false "failed to build bounded two-hop attr-param relation"))))
                              (set! second-row (+ second-row 1))))
                          (delete-relation-columns second-columns))))
                    (set! first-row (+ first-row 1))))
                (delete-relation-columns first-columns))))
          (set! row (+ row 1)))
        (query-stats-observe-source-operator! stats)
        (let [derived-rel (Query-Relation {attrs: attrs
                                           attr-sources: attr-sources
                                           attr-index: (query-relation-attr-index (slice attrs 0))
                                           tuples: (make [dynamic]Binding)
                                           typed-columns: columns
                                           typed-rows: rows
                                           has-typed-columns: true})
              [projected projected-ok] (query-relation-project-rule-call-params-typed derived-rel (slice direct-rule.params 0) call)]
          (delete-query-relation derived-rel)
          (return projected projected-ok ""))))))

(defn db-read-source-bindings-after-rule-body-with-sources-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rule: Rule, initial: Binding, depth: int] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (when (rule-body-planned-clause-call-predicate? rule)
    (return (db-read-source-bindings-after-rule-body-planned-clause-call-with-sources-depth source sources rules rule initial depth)))
  (let [bindings (make [dynamic]Binding)]
    (when (< depth 0)
      (db-read-source-delete-binding-owned initial)
      (return bindings true ""))
    (arr.push! bindings initial)
    (for [step rule.body-steps]
      (cond
        (= step.kind .Clause)
          (let [clause-value rule.clauses[step.index]
                [clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
            (when (not source-clause-ok)
              (db-read-source-delete-bindings-owned bindings)
              (return (make [dynamic]Binding) false source-clause-error))
            (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
              (db-read-source-delete-bindings-owned bindings)
              (when (not next-ok)
                (return (make [dynamic]Binding) false next-error))
              (set! bindings next)))
        (= step.kind .Predicate)
          (let [next (db-read-source-bindings-after-predicate (slice bindings 0) rule.predicates[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (set! bindings next))
        (= step.kind .Function)
          (let [function rule.function-clauses[step.index]]
            (if (= function.op "fulltext")
              (let [[next next-ok next-error] (db-read-source-bindings-after-fulltext-with-sources source sources (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (make [dynamic]Binding) false next-error))
                (set! bindings next))
              (let [[next next-ok next-error] (db-read-source-bindings-after-function (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (make [dynamic]Binding) false next-error))
                (set! bindings next))))
        (= step.kind .Ground)
          (let [[next next-ok next-error] (db-read-source-bindings-after-ground (slice bindings 0) rule.grounds[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (make [dynamic]Binding) false next-error))
            (set! bindings next))
        (= step.kind .GetElse)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-else-with-sources source sources (slice bindings 0) rule.get-elses[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (make [dynamic]Binding) false next-error))
            (set! bindings next))
        (= step.kind .GetSome)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-some-with-sources source sources (slice bindings 0) rule.get-somes[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (make [dynamic]Binding) false next-error))
            (set! bindings next))
        (= step.kind .Not)
          (let [[next next-ok next-error] (db-read-source-bindings-after-not-group-with-sources source sources (slice bindings 0) rule.not-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (make [dynamic]Binding) false next-error))
            (set! bindings next))
        (= step.kind .Or)
          (let [[next next-ok next-error] (db-read-source-bindings-after-or-group-with-sources source sources (slice bindings 0) rule.or-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (make [dynamic]Binding) false next-error))
            (set! bindings next))
        (= step.kind .RuleCall)
          (let [next (make [dynamic]Binding)]
            (for [binding bindings]
              (let [[rule-bindings rule-ok rule-error] (db-read-source-bindings-after-rule-call-with-sources-depth source sources rules rule.rule-calls[step.index] binding (- depth 1))]
                (when (not rule-ok)
                  (db-read-source-delete-bindings-owned next)
                  (db-read-source-delete-bindings-owned bindings)
                  (return (make [dynamic]Binding) false rule-error))
                (for [rule-binding rule-bindings]
                  (arr.push! next rule-binding))
                (delete rule-bindings)))
            (db-read-source-delete-bindings-owned bindings)
            (let [unique (unique-bindings (slice next 0))]
              (delete next)
              (set! bindings unique)))
        :else
          (do
            (db-read-source-delete-bindings-owned bindings)
            (return (make [dynamic]Binding) false "DB snapshot source rules currently support data, predicate, function, ground, get-else, get-some, not/or, and recursive rule-call body steps only"))))
    (return bindings true "")))

(defn db-read-source-clause-candidate-count-estimate [source: DB-Read-Source, sources: []DB-Read-Named-Source, clause-value: Clause, binding: Binding] -> [count-value: int, ok: bool, error: string]
  (let [[clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
    (when (not source-clause-ok)
      (return 0 false source-clause-error))
    (when (= clause-source.kind .Relation-Value)
      (if (= clause-source.relation-value^.kind .Vector)
        (return (count clause-source.relation-value^.items) true "")
        (return 0 true "")))
    (let [[scan scan-ok scan-error] (db-read-source-clause-index-scan clause-source source-clause binding)]
      (when (not scan-ok)
        (delete-clause-index-scan scan)
        (return 0 false scan-error))
      (let [out (- scan.high scan.index)]
        (delete-clause-index-scan scan)
        (return out true "")))))

(defn best-ready-db-read-source-rule-body-step-index-indexed [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rule-index: []Rule-Name-Index-Entry, rule: Rule, steps: []Query-Step, binding: Binding] -> [index: int, ok: bool, error: string]
  (let [best -1
        best-score 0
        best-unlocked-predicate-score -1
        best-count -1]
    (for [step step-index steps]
      (let [ready false
            score 0
            unlocked-predicate-score -1
            candidate-count -1]
        (cond
          (= step.kind .Clause)
            (do
              (set! ready true)
              (set! score (clause-selectivity-score rule.clauses[step.index] binding))
              (set! unlocked-predicate-score (best-rule-predicate-score-unlocked-by-clause rule steps binding rule.clauses[step.index]))
              (let [[count-value count-ok count-error] (db-read-source-clause-candidate-count-estimate source sources rule.clauses[step.index] binding)]
                (when (not count-ok)
                  (return 0 false count-error))
                (set! candidate-count count-value)))
          (= step.kind .Predicate)
            (let [available (binding-available-vars binding) :defer
                  predicate rule.predicates[step.index]]
              (when (predicate-ready-with-vars? predicate (slice available 0))
                (set! ready true)
                (set! score (predicate-selectivity-score predicate))
                (set! candidate-count 0)))
          (= step.kind .RuleCall)
            (let [call rule.rule-calls[step.index]]
              (when (rule-call-ready-for-binding-indexed? rules rule-index call binding)
                (set! ready true)
                (set! score (rule-call-selectivity-score call binding))
                (set! candidate-count 0))))
        (when ready
          (when (or (= best -1)
                    (< score best-score))
            (set! best step-index)
            (set! best-score score)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-count candidate-count))
          (when (and (not (= best step-index))
                     (= score best-score)
                     (>= unlocked-predicate-score 0)
                     (or (< best-unlocked-predicate-score 0)
                         (< unlocked-predicate-score best-unlocked-predicate-score)))
            (set! best step-index)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-count candidate-count))
          (when (and (not (= best step-index))
                     (= score best-score)
                     (= unlocked-predicate-score best-unlocked-predicate-score))
            (when (or (< best-count 0)
                      (< candidate-count best-count))
              (set! best step-index)
              (set! best-unlocked-predicate-score unlocked-predicate-score)
              (set! best-count candidate-count))))))
    (return best (>= best 0) "")))

(defn db-read-source-bindings-after-rule-call-typed-batch-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, call: Rule-Call, bindings: []Binding, depth: int] -> [out-bindings: [dynamic]Binding, handled: bool]
  (when (= (count bindings) 0)
    (return (make [dynamic]Binding) true))
  (let [rel (query-relation-from-bindings bindings)
        stats (query-stats-empty)]
    (defer (delete-query-relation rel))
    (when (not rel.has-typed-columns)
      (return (make [dynamic]Binding) false))
    (let [[next-rel next-ok] (db-read-source-query-relation-apply-rule-call-typed-depth source sources rules rel call ([]Native-Query-Fn []) (addr stats) depth)]
      (when (not next-ok)
        (delete-query-relation next-rel)
        (return (make [dynamic]Binding) false))
      (let [out (query-relation-materialized-bindings next-rel)]
        (delete-query-relation next-rel)
        (return out true)))))

(defn db-read-source-bindings-after-rule-body-planned-clause-call-with-sources-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rule: Rule, initial: Binding, depth: int] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [bindings (make [dynamic]Binding)
        remaining (arr.into [dynamic]Query-Step (slice rule.body-steps 0))
        rule-index (rule-name-index-build rules)]
    (defer (delete remaining))
    (defer (delete-rule-name-index rule-index))
    (when (< depth 0)
      (db-read-source-delete-binding-owned initial)
      (return bindings true ""))
    (arr.push! bindings initial)
    (while (and (> (count bindings) 0)
                (> (count remaining) 0))
      (let [[step-index step-ok step-error] (best-ready-db-read-source-rule-body-step-index-indexed source sources rules (slice rule-index 0) rule (slice remaining 0) bindings[0])]
        (when (not step-ok)
          (db-read-source-delete-bindings-owned bindings)
          (return (make [dynamic]Binding) false step-error))
        (let [step remaining[step-index]]
          (cond
            (= step.kind .Clause)
              (let [clause-value rule.clauses[step.index]
                    [clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
                (when (not source-clause-ok)
                  (db-read-source-delete-bindings-owned bindings)
                  (return (make [dynamic]Binding) false source-clause-error))
                (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
                  (db-read-source-delete-bindings-owned bindings)
                  (when (not next-ok)
                    (return (make [dynamic]Binding) false next-error))
                  (set! bindings next)))
            (= step.kind .RuleCall)
              (let [[batched batched-handled] (db-read-source-bindings-after-rule-call-typed-batch-depth source sources rules rule.rule-calls[step.index] (slice bindings 0) (- depth 1))]
                (if batched-handled
                  (do
                    (db-read-source-delete-bindings-owned bindings)
                    (set! bindings batched))
                  (do
                    (delete batched)
                    (let [next (make [dynamic]Binding)]
                      (for [binding bindings]
                        (let [[rule-bindings rule-ok rule-error] (db-read-source-bindings-after-rule-call-with-sources-depth source sources rules rule.rule-calls[step.index] binding (- depth 1))]
                          (when (not rule-ok)
                            (db-read-source-delete-bindings-owned next)
                            (db-read-source-delete-bindings-owned bindings)
                            (return (make [dynamic]Binding) false rule-error))
                          (for [rule-binding rule-bindings]
                            (arr.push! next rule-binding))
                          (delete rule-bindings)))
                      (db-read-source-delete-bindings-owned bindings)
                      (let [unique (unique-bindings (slice next 0))]
                        (delete next)
                        (set! bindings unique))))))
            (= step.kind .Predicate)
              (let [next (db-read-source-bindings-after-predicate (slice bindings 0) rule.predicates[step.index])]
                (db-read-source-delete-bindings-owned bindings)
                (set! bindings next))
            :else
              (do
                (db-read-source-delete-bindings-owned bindings)
                (return (make [dynamic]Binding) false "DB snapshot source planned rule bodies support data clauses, predicates, and recursive rule-call body steps only"))))
          (arr.remove-ordered-at! remaining step-index)))
    (return bindings true "")))

(defn db-read-source-bindings-after-rule-body-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, rule: Rule, initial: Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-rule-body-with-sources-depth source sources ([]Rule [rule]) rule initial 20))

(defn db-read-source-bindings-after-rule-call-with-sources-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, call: Rule-Call, binding: Binding, depth: int] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (let [out (make [dynamic]Binding)
        matched false]
    (when (< depth 0)
      (return out true ""))
    (let [[call-source local-call source-ok] (db-read-source-resolve-rule-call-source source sources call)]
      (when (not source-ok)
        (return out false (fmt.tprintf "DB read source is not bound: %s" call.source)))
    (for [rule rules]
      (when (= rule.name local-call.name)
        (set! matched true)
        (let [[initial initial-ok] (db-read-source-bind-rule-args binding local-call rule)]
          (if initial-ok
            (let [[body-bindings body-ok body-error] (db-read-source-bindings-after-rule-body-with-sources-depth call-source sources rules rule initial depth)]
              (when (not body-ok)
                (db-read-source-delete-bindings-owned out)
                (return (make [dynamic]Binding) false body-error))
              (for [body-binding body-bindings]
                (let [[merged merged-ok] (db-read-source-merge-rule-output-owned binding local-call rule body-binding)]
                  (when merged-ok
                    (arr.push! out merged))))
              (db-read-source-delete-bindings-owned body-bindings))
            (db-read-source-delete-binding-owned initial)))))
    (if matched
      (return out true "")
      (return out false (fmt.tprintf "Unknown rule: %s" local-call.name))))))

(defn db-read-source-bindings-after-rule-call-with-sources [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, call: Rule-Call, binding: Binding] -> [out-bindings: [dynamic]Binding, ok: bool, error: string]
  (db-read-source-bindings-after-rule-call-with-sources-depth source sources rules call binding 20))

(defn db-read-source-has-relation-value-source? [sources: []DB-Read-Named-Source] -> bool
  (for [candidate sources]
    (when (= candidate.source.kind .Relation-Value)
      (return true)))
  false)

(defn db-read-source-relation-value-source-for-clause [sources: []DB-Read-Named-Source, clause-value: Clause] -> [value: ^Value, ok: bool]
  (when (not clause-value.has-source)
    (return nil false))
  (for [candidate sources]
    (when (= candidate.name clause-value.source)
      (return candidate.source.relation-value (= candidate.source.kind .Relation-Value))))
  (return nil false))

(defn db-read-source-primary-source? [has-source: bool, source: string] -> bool
  (or (not has-source)
      (= source "$")))

(defn db-read-source-typed-db-source-bound? [sources: []DB-Read-Named-Source, has-source: bool, source: string] -> bool
  (when (db-read-source-primary-source? has-source source)
    (return true))
  (when (not (query-source-input-name? source))
    (return false))
  (for [candidate sources]
    (when (= candidate.name source)
      (return (not (= candidate.source.kind .Relation-Value)))))
  false)

(defn db-read-source-typed-clause-source-bound? [sources: []DB-Read-Named-Source, clause-value: Clause] -> bool
  (when (db-read-source-primary-source? clause-value.has-source clause-value.source)
    (return true))
  (when (not (query-source-input-name? clause-value.source))
    (return false))
  (for [candidate sources]
    (when (= candidate.name clause-value.source)
      (return true)))
  false)

(defn db-read-source-for-rule-call-source [primary: DB-Read-Source, sources: []DB-Read-Named-Source, source-name: string] -> [source: DB-Read-Source, ok: bool]
  (when (not (query-source-input-name? source-name))
    (return (DB-Read-Source {}) false))
  (when (= source-name "$")
    (return primary true))
  (for [candidate sources]
    (when (= candidate.name source-name)
      (return candidate.source true)))
  (return (DB-Read-Source {}) false))

(defn db-read-source-relation-value-typed-not-group? [sources: []DB-Read-Named-Source, rules: []Rule, group: Not-Group, registry: []Native-Query-Fn] -> bool
  (when (> (count group.not-groups) 0)
    (return false))
  (when (not (source-rule-calls-typed-eligible? rules (slice group.rule-calls 0) registry))
    (return false))
  (for [step group.steps]
    (cond
      (= step.kind .Clause)
        (when (not (db-read-source-typed-clause-source-bound? sources group.clauses[step.index]))
          (return false))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-typed-db-source-bound? sources group.get-elses[step.index].has-source group.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-typed-db-source-bound? sources group.get-somes[step.index].has-source group.get-somes[step.index].source))
          (return false))
      (= step.kind .RuleCall) (discard step)
      :else (return false)))
  true)

(defn db-read-source-relation-value-typed-or-group? [sources: []DB-Read-Named-Source, rules: []Rule, group: Or-Group, registry: []Native-Query-Fn] -> bool
  (when (= (count group.branches) 0)
    (return false))
  (for [branch group.branches]
    (when (not (db-read-source-relation-value-typed-not-group? sources rules branch registry))
      (return false)))
  true)

(defn db-read-source-primary-typed-branch-group? [rules: []Rule, group: Not-Group, registry: []Native-Query-Fn] -> bool
  (when (= (count group.steps) 0)
    (when (or (= (count group.clauses) 0)
              (> (count group.predicates) 0)
              (> (count group.function-clauses) 0)
              (> (count group.grounds) 0)
              (> (count group.get-elses) 0)
              (> (count group.get-somes) 0)
              (> (count group.rule-calls) 0)
              (> (count group.not-groups) 0))
      (return false))
    (for [clause-value group.clauses]
      (when clause-value.has-source
        (return false)))
    (return true))
  (when (not (source-rule-calls-typed-eligible? rules (slice group.rule-calls 0) registry))
    (return false))
  (for [step group.steps]
    (cond
      (= step.kind .Clause)
        (when group.clauses[step.index].has-source
          (when (not (= group.clauses[step.index].source "$"))
            (return false)))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? group.get-elses[step.index].has-source group.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? group.get-somes[step.index].has-source group.get-somes[step.index].source))
          (return false))
      (= step.kind .Not)
        (when (not (db-read-source-primary-typed-branch-group? rules group.not-groups[step.index] registry))
          (return false))
      (= step.kind .RuleCall) (discard step)
      :else (return false)))
  true)

(defn db-read-source-primary-typed-or-group? [rules: []Rule, group: Or-Group, registry: []Native-Query-Fn] -> bool
  (when (= (count group.branches) 0)
    (return false))
  (for [branch group.branches]
    (when (not (db-read-source-primary-typed-branch-group? rules branch registry))
      (return false)))
  true)

(defn db-read-source-primary-typed-query? [query-value: Query, registry: []Native-Query-Fn] -> bool
  (when (not (source-query-rule-calls-typed-eligible? (slice query-value.rules 0) (slice query-value.rule-calls 0) registry))
    (return false))
  (for [aggregate query-value.aggregates]
    (when (not (aggregate-supported-from-typed-relation-with-fns? aggregate registry))
      (return false)))
  (for [step query-value.where-steps]
    (cond
      (= step.kind .Clause)
        (let [clause-value query-value.clauses[step.index]]
          (when clause-value.has-source
            (when (not (= clause-value.source "$"))
              (return false))))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? query-value.get-elses[step.index].has-source query-value.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? query-value.get-somes[step.index].has-source query-value.get-somes[step.index].source))
          (return false))
      (= step.kind .Not)
        (when (not (db-read-source-primary-typed-branch-group? (slice query-value.rules 0) query-value.not-groups[step.index] registry))
          (return false))
      (= step.kind .Or)
        (when (not (db-read-source-primary-typed-or-group? (slice query-value.rules 0) query-value.or-groups[step.index] registry))
          (return false))
      (= step.kind .RuleCall) (discard step)
      :else (return false)))
  true)

(defn db-read-source-relation-value-typed-query? [sources: []DB-Read-Named-Source, query-value: Query, registry: []Native-Query-Fn] -> bool
  (when (not (source-query-rule-calls-typed-eligible? (slice query-value.rules 0) (slice query-value.rule-calls 0) registry))
    (return false))
  (for [aggregate query-value.aggregates]
    (when (not (aggregate-supported-from-typed-relation-with-fns? aggregate registry))
      (return false)))
  (for [step query-value.where-steps]
    (cond
      (= step.kind .Clause)
        (when (not (db-read-source-typed-clause-source-bound? sources query-value.clauses[step.index]))
          (return false))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-typed-db-source-bound? sources query-value.get-elses[step.index].has-source query-value.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-typed-db-source-bound? sources query-value.get-somes[step.index].has-source query-value.get-somes[step.index].source))
          (return false))
      (= step.kind .Not)
        (when (not (db-read-source-relation-value-typed-not-group? sources (slice query-value.rules 0) query-value.not-groups[step.index] registry))
          (return false))
      (= step.kind .Or)
        (when (not (db-read-source-relation-value-typed-or-group? sources (slice query-value.rules 0) query-value.or-groups[step.index] registry))
          (return false))
      (= step.kind .RuleCall) (discard step)
      :else (return false)))
  true)

(defn db-read-source-direct-entity-term-supported? [term: Term] -> bool
  (case term.kind
    .Wildcard true
    .Var true
    .LookupRef true
    .Value true
     false))

(defn db-read-source-direct-attr-term-supported? [term: Term] -> bool
  (case term.kind
    .Wildcard true
    .Var true
    .Value (or (= term.value.kind .Keyword)
               (= term.value.kind .Entity)
               (= term.value.kind .Int))
     false))

(defn db-read-source-direct-value-term-supported? [term: Term] -> bool
  (case term.kind
    .Wildcard true
    .Var true
    .LookupRef true
    .Value true
     false))

(defn db-read-source-direct-optional-term-supported? [term: Term] -> bool
  (or (omitted-term? term)
      (= term.kind .Wildcard)
      (= term.kind .Var)
      (= term.kind .Value)))

(defn db-read-source-primary-clause-direct-supported? [clause-value: Clause] -> bool
  (and (db-read-source-direct-entity-term-supported? clause-value.e)
       (db-read-source-direct-attr-term-supported? clause-value.a)
       (db-read-source-direct-value-term-supported? clause-value.v)
       (db-read-source-direct-optional-term-supported? clause-value.tx-term)
       (db-read-source-direct-optional-term-supported? clause-value.op-term)))

(defn db-read-source-direct-var-index [names: []string, name: string] -> [index: int, ok: bool]
  (for [existing index names]
    (when (= existing name)
      (return index true)))
  (return 0 false))

(defn db-read-source-direct-value-matches-actual? [source: DB-Read-Source, expected: Value, actual: Value] -> bool
  (if (= actual.kind .Entity)
    (let [[resolved resolved-ok _] (db-read-source-resolve-ref-component-value source expected)]
      (and resolved-ok (= (index-position-compare actual resolved) 0)))
    (= (index-position-compare actual expected) 0)))

(defn db-read-source-direct-dynamic-value-matches-actual? [source: DB-Read-Source, expected: Value, actual: Value] -> bool
  (let [[_ _ lookup-ref-ok] (value-lookup-ref-parts expected)]
    (if lookup-ref-ok
      (db-read-source-direct-value-matches-actual? source expected actual)
      (= (index-position-compare actual expected) 0))))

(defn db-read-source-direct-term-matches-typed-row! [source: DB-Read-Source, rel: Query-Relation, row: int, names: ^[dynamic]string, values: ^[dynamic]Value, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .LookupRef
      (let [[entity entity-ok _] (db-read-source-resolve-lookup-ref source term.lookup-attr term.lookup-value)]
        (and entity-ok (= (index-position-compare actual (value-entity entity)) 0)))
    .Value (db-read-source-direct-value-matches-actual? source term.value actual)
    .Var
      (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
        (when existing-ok
          (return (db-read-source-direct-value-matches-actual? source existing actual)))
        (let [[index index-ok] (db-read-source-direct-var-index (slice names^ 0) term.name)]
          (if index-ok
            (db-read-source-direct-value-matches-actual? source values^[index] actual)
            (do
              (arr.push! names^ term.name)
              (arr.push! values^ actual)
              true))))
     false))

(defn db-read-source-direct-value-term-matches-typed-row! [source: DB-Read-Source, rel: Query-Relation, row: int, names: ^[dynamic]string, values: ^[dynamic]Value, term: Term, actual: Value, attr-static: bool] -> bool
  (when attr-static
    (return (db-read-source-direct-term-matches-typed-row! source rel row names values term actual)))
  (case term.kind
    .Wildcard true
    .LookupRef
      (db-read-source-direct-term-matches-typed-row! source rel row names values term actual)
    .Value (= (index-position-compare actual term.value) 0)
    .Var
      (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
        (when existing-ok
          (return (db-read-source-direct-dynamic-value-matches-actual? source existing actual)))
        (let [[index index-ok] (db-read-source-direct-var-index (slice names^ 0) term.name)]
          (if index-ok
            (db-read-source-direct-dynamic-value-matches-actual? source values^[index] actual)
            (do
              (arr.push! names^ term.name)
              (arr.push! values^ actual)
              true))))
     false))

(defn db-read-source-direct-attr-term-matches-typed-row! [source: DB-Read-Source, rel: Query-Relation, row: int, names: ^[dynamic]string, values: ^[dynamic]Value, term: Term, actual: Value, resolved: Value, resolved-ok: bool] -> bool
  (when (= term.kind .Value)
    (return (and resolved-ok (= (index-position-compare actual resolved) 0))))
  (db-read-source-direct-term-matches-typed-row! source rel row names values term actual))

(defn db-read-source-direct-optional-term-matches-typed-row! [source: DB-Read-Source, rel: Query-Relation, row: int, names: ^[dynamic]string, values: ^[dynamic]Value, term: Term, actual: Value] -> bool
  (if (omitted-term? term)
    true
    (db-read-source-direct-term-matches-typed-row! source rel row names values term actual)))

(defn db-read-source-scan-semantic-entity-value [scan: Clause-Index-Scan, datom: Datom] -> Value
  (if scan.reverse-attr
    datom.v
    (value-entity datom.e)))

(defn db-read-source-scan-semantic-attr-value [scan: Clause-Index-Scan, datom: Datom] -> Value
  (if scan.reverse-attr
    scan.a-value
    (value-keyword datom.a)))

(defn db-read-source-scan-semantic-value [scan: Clause-Index-Scan, datom: Datom] -> Value
  (if scan.reverse-attr
    (value-entity datom.e)
    datom.v))

(defn db-read-source-direct-datom-clause-matches-typed-row! [source: DB-Read-Source, rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, names: ^[dynamic]string, values: ^[dynamic]Value] -> bool
  (and (db-read-source-direct-term-matches-typed-row! source rel row names values clause-value.e (db-read-source-scan-semantic-entity-value scan datom))
       (db-read-source-direct-attr-term-matches-typed-row! source rel row names values clause-value.a (db-read-source-scan-semantic-attr-value scan datom) scan.a-value scan.a-ok)
       (db-read-source-direct-value-term-matches-typed-row!
         source rel row names values
         clause-value.v
         (db-read-source-scan-semantic-value scan datom)
         (and (= clause-value.a.kind .Value)
              (= clause-value.a.value.kind .Keyword)))
       (db-read-source-direct-optional-term-matches-typed-row! source rel row names values clause-value.tx-term (datom-tx-value datom))
       (db-read-source-direct-optional-term-matches-typed-row! source rel row names values clause-value.op-term (value-bool datom.added))))

(defn db-read-source-direct-clause-var-value [rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, name: string] -> [value: Value, ok: bool]
  (let [[existing existing-ok] (query-relation-typed-row-value rel row name)]
    (when existing-ok
      (return existing true)))
  (when (term-var-name? clause-value.e name)
    (return (value-owned (db-read-source-scan-semantic-entity-value scan datom)) true))
  (when (term-var-name? clause-value.a name)
    (return (value-owned (db-read-source-scan-semantic-attr-value scan datom)) true))
  (when (term-var-name? clause-value.v name)
    (return (value-owned (db-read-source-scan-semantic-value scan datom)) true))
  (when (term-var-name? clause-value.tx-term name)
    (return (datom-tx-value datom) true))
  (when (term-var-name? clause-value.op-term name)
    (return (value-bool datom.added) true))
  (return (Value {}) false))

(defn db-read-source-direct-clause-var-borrowed-value [rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, name: string] -> [value: Value, ok: bool]
  (let [[existing existing-ok] (query-relation-typed-row-value rel row name)]
    (when existing-ok
      (return existing true)))
  (when (term-var-name? clause-value.e name)
    (return (db-read-source-scan-semantic-entity-value scan datom) true))
  (when (term-var-name? clause-value.a name)
    (return (db-read-source-scan-semantic-attr-value scan datom) true))
  (when (term-var-name? clause-value.v name)
    (return (db-read-source-scan-semantic-value scan datom) true))
  (when (term-var-name? clause-value.tx-term name)
    (return (datom-tx-value datom) true))
  (when (term-var-name? clause-value.op-term name)
    (return (value-bool datom.added) true))
  (return (Value {}) false))

(defn query-relation-builder-can-add-db-source-clause-row? [builder: Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom] -> bool
  (for [column index rel.typed-columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  (for [attr index attrs]
    (when (not (query-relation-has-attr? rel attr))
      (let [[value value-ok] (db-read-source-direct-clause-var-borrowed-value rel row scan clause-value datom attr)]
        (when (or (not value-ok)
                  (not (relation-column-can-add? builder.typed-columns[index] value)))
          (return false)))))
  true)

(defn query-relation-builder-add-db-source-clause-row! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom] -> bool
  (when (not (query-relation-builder-can-add-db-source-clause-row? builder^ attrs rel row scan clause-value datom))
    (return false))
  (for [column index rel.typed-columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (for [attr index attrs]
    (when (not (query-relation-has-attr? rel attr))
      (let [[value _] (db-read-source-direct-clause-var-borrowed-value rel row scan clause-value datom attr)]
        (discard (relation-column-add! (addr builder^.typed-columns[index]) value)))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn db-read-source-append-direct-clause-row! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom] -> bool
  (when (= (count attrs) (count rel.attrs))
    (return (query-relation-builder-add-column-row! builder (slice rel.typed-columns 0) row)))
  (query-relation-builder-add-db-source-clause-row! builder attrs rel row scan clause-value datom))

(defn db-read-source-bind-join-adds-single-value-var? [rel: Query-Relation, clause-value: Clause] -> bool
  (and (= clause-value.e.kind .Var)
       (query-relation-has-attr? rel clause-value.e.name)
       (= clause-value.a.kind .Value)
       (= clause-value.a.value.kind .Keyword)
       (= clause-value.v.kind .Var)
       (not (query-relation-has-attr? rel clause-value.v.name))
       (omitted-term? clause-value.tx-term)
       (omitted-term? clause-value.op-term)))

(defn db-read-source-bind-join-adds-single-entity-var? [rel: Query-Relation, clause-value: Clause] -> bool
  (and (= clause-value.e.kind .Var)
       (not (query-relation-has-attr? rel clause-value.e.name))
       (= clause-value.a.kind .Value)
       (= clause-value.a.value.kind .Keyword)
       (= clause-value.v.kind .Var)
       (query-relation-has-attr? rel clause-value.v.name)
       (omitted-term? clause-value.tx-term)
       (omitted-term? clause-value.op-term)))

(defn db-read-source-append-bind-join-single-value-var-row! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, clause-value: Clause, datom: Datom, op: Physical-Op] -> bool
  (when (not (db-read-source-bind-join-adds-single-value-var? rel clause-value))
    (return false))
  (when (not (db-read-source-direct-clause-pushdown-matches? rel row (Clause-Index-Scan {v-value: (Value {}) v-ok: false}) clause-value datom op))
    (return true))
  (query-relation-builder-add-column-row-with-output-value! builder attrs (slice rel.typed-columns 0) row clause-value.v.name datom.v))

(defn db-read-source-append-bind-join-single-entity-var-row! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, clause-value: Clause, datom: Datom, op: Physical-Op] -> bool
  (when (not (db-read-source-bind-join-adds-single-entity-var? rel clause-value))
    (return false))
  (when (not (db-read-source-direct-clause-pushdown-matches? rel row (Clause-Index-Scan {e-value: (Value {}) e-ok: false}) clause-value datom op))
    (return true))
  (query-relation-builder-add-column-row-with-output-value! builder attrs (slice rel.typed-columns 0) row clause-value.e.name (value-entity datom.e)))

(defn physical-op-scalar-pushdown-matches-value? [op: Physical-Op, value: Value] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [requirement op.pushdown-scalar-requirement]
    (when (not (and (= requirement.kind .VarValueCompare)
                    requirement.typed-supported
                    (= requirement.value-term.kind .Value)))
      (return true))
    (predicate-pair-matches? requirement.op value requirement.value-term.value)))

(defn physical-op-scalar-pushdown-matches-values? [op: Physical-Op, value: Value, other: Value] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [requirement op.pushdown-scalar-requirement]
    (case requirement.kind
      .VarValueCompare
        (if (and requirement.typed-supported
                 (= requirement.value-term.kind .Value))
          (predicate-pair-matches? requirement.op value requirement.value-term.value)
          true)
      .VarVarCompare
        (if requirement.typed-supported
          (predicate-pair-matches? requirement.op value other)
          true)

        true)))

(defn query-relation-physical-pushdown-other-value [rel: Query-Relation, row: int, op: Physical-Op] -> [value: Value, ok: bool]
  (when (not (and op.has-pushdown-scalar
                  (= op.pushdown-scalar-requirement.kind .VarVarCompare)))
    (return (Value {}) false))
  (query-relation-typed-row-value rel row op.pushdown-scalar-requirement.other-var))

(defn binding-physical-pushdown-other-value [binding: Binding, op: Physical-Op] -> [value: Value, ok: bool]
  (when (not (and op.has-pushdown-scalar
                  (= op.pushdown-scalar-requirement.kind .VarVarCompare)))
    (return (Value {}) false))
  (binding-lookup binding op.pushdown-scalar-requirement.other-var))

(defn db-read-source-direct-clause-pushdown-matches? [rel: Query-Relation, row: int, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, op: Physical-Op] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (db-read-source-direct-clause-var-borrowed-value rel row scan clause-value datom op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (query-relation-physical-pushdown-other-value rel row op)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn db-read-source-binding-pushdown-matches? [binding: Binding, op: Physical-Op] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (binding-lookup binding op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (binding-physical-pushdown-other-value binding op)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn physical-op-pushdown-range-value [op: Physical-Op, rel: Query-Relation, row: int] -> [value: Value, ok: bool]
  (when (not op.has-pushdown-scalar)
    (return (Value {}) false))
  (let [requirement op.pushdown-scalar-requirement]
    (case requirement.kind
      .VarValueCompare
        (if (= requirement.value-term.kind .Value)
          (return requirement.value-term.value true)
          (return (Value {}) false))
      .VarVarCompare
        (query-relation-physical-pushdown-other-value rel row op)

        (return (Value {}) false))))

(defn physical-op-pushdown-tightens-value-range? [op: Physical-Op, clause-value: Clause, rel: Query-Relation, row: int] -> bool
  (when (not op.has-pushdown-scalar)
    (return false))
  (let [requirement op.pushdown-scalar-requirement]
    (when (not (and (or (= requirement.kind .VarValueCompare)
                        (= requirement.kind .VarVarCompare))
                    requirement.typed-supported
                    (term-var-name? clause-value.v requirement.var-name)
                    (or (= requirement.op "=")
                        (= requirement.op ">")
                        (= requirement.op ">=")
                        (= requirement.op "<")
                        (= requirement.op "<="))))
      (return false))
    (let [[_ value-ok] (physical-op-pushdown-range-value op rel row)]
      value-ok)))

(defn physical-op-tighten-resident-attr-value-scan! [db: DB, scan: ^Clause-Index-Scan, clause-value: Clause, op: Physical-Op, rel: Query-Relation, row: int]
  (when (not (and (physical-op-pushdown-tightens-value-range? op clause-value rel row)
                  (not scan^.reverse-attr)
                  scan^.a-ok
                  (not scan^.e-ok)
                  (not scan^.v-ok)
                  (= scan^.a-value.kind .Keyword)
                  (not (schema-ref? db scan^.a-value.text))))
    (return))
  (let [[range-value range-value-ok] (physical-op-pushdown-range-value op rel row)]
    (when (not range-value-ok)
      (return))
  (let [view (db-index-view db .AVET)
        attr-prefix ([]Value [scan^.a-value])
        value-prefix ([]Value [scan^.a-value range-value])
        attr-low (lower-bound-index-view-values db view attr-prefix)
        attr-high (upper-bound-index-view-values db view attr-prefix)
        value-low (lower-bound-index-view-values db view value-prefix)
        value-high (upper-bound-index-view-values db view value-prefix)
        next-low attr-low
        next-high attr-high]
    (case op.pushdown-scalar-requirement.op
      "="
        (do
          (set! next-low value-low)
          (set! next-high value-high))
      ">"
        (set! next-low value-high)
      ">="
        (set! next-low value-low)
      "<"
        (set! next-high value-low)
      "<="
        (set! next-high value-high)

        (do))
    (when (< next-high next-low)
      (set! next-high next-low))
    (set! scan^.view view)
    (set! scan^.index next-low)
    (set! scan^.high next-high))))

(defn physical-op-tighten-resident-eavt-ea-value-range [db: DB, view: DB-Index-View, low: int, high: int, entity: u64, attr: string, clause-value: Clause, op: Physical-Op, rel: Query-Relation, row: int] -> [next-low: int, next-high: int]
  (when (not (and (physical-op-pushdown-tightens-value-range? op clause-value rel row)
                  (not (schema-ref? db attr))))
    (return low high))
  (let [[range-value range-value-ok] (physical-op-pushdown-range-value op rel row)]
    (when (not range-value-ok)
      (return low high))
  (let [ea-prefix ([]Value [(value-entity entity) (value-keyword attr)])
        eav-prefix ([]Value [(value-entity entity) (value-keyword attr) range-value])
        ea-low (lower-bound-index-view-values db view ea-prefix)
        ea-high (upper-bound-index-view-values db view ea-prefix)
        value-low (lower-bound-index-view-values db view eav-prefix)
        value-high (upper-bound-index-view-values db view eav-prefix)
        out-low ea-low
        out-high ea-high]
    (case op.pushdown-scalar-requirement.op
      "="
        (do
          (set! out-low value-low)
          (set! out-high value-high))
      ">"
        (set! out-low value-high)
      ">="
        (set! out-low value-low)
      "<"
        (set! out-high value-low)
      "<="
        (set! out-high value-high)

        (do))
    (when (< out-high out-low)
      (set! out-high out-low))
    (return out-low out-high))))

(defn physical-op-tighten-db-read-source-attr-value-scan! [source: DB-Read-Source, scan: ^Clause-Index-Scan, clause-value: Clause, op: Physical-Op, rel: Query-Relation, row: int] -> [ok: bool, error: string]
  (when (not (and (physical-op-pushdown-tightens-value-range? op clause-value rel row)
                  (not scan^.reverse-attr)
                  scan^.a-ok
                  (not scan^.e-ok)
                  (not scan^.v-ok)
                  (= scan^.a-value.kind .Keyword)))
    (return true ""))
  (let [[attr-ref attr-ref-ok attr-ref-error] (db-read-source-schema-ref? source scan^.a-value.text)]
    (when (not attr-ref-ok)
      (return false attr-ref-error))
    (when attr-ref
      (return true "")))
  (let [[range-value range-value-ok] (physical-op-pushdown-range-value op rel row)]
    (when (not range-value-ok)
      (return true ""))
  (let [view (db-read-source-index-view source .AVET)
        attr-prefix ([]Value [scan^.a-value])
        value-prefix ([]Value [scan^.a-value range-value])
        [attr-low attr-low-ok attr-low-error] (db-read-source-lower-bound-values source view attr-prefix)]
    (when (not attr-low-ok)
      (return false attr-low-error))
    (let [[attr-high attr-high-ok attr-high-error] (db-read-source-upper-bound-values source view attr-prefix)]
      (when (not attr-high-ok)
        (return false attr-high-error))
      (let [[value-low value-low-ok value-low-error] (db-read-source-lower-bound-values source view value-prefix)]
        (when (not value-low-ok)
          (return false value-low-error))
        (let [[value-high value-high-ok value-high-error] (db-read-source-upper-bound-values source view value-prefix)]
          (when (not value-high-ok)
            (return false value-high-error))
          (let [next-low attr-low
                next-high attr-high]
            (case op.pushdown-scalar-requirement.op
              "="
                (do
                  (set! next-low value-low)
                  (set! next-high value-high))
              ">"
                (set! next-low value-high)
              ">="
                (set! next-low value-low)
              "<"
                (set! next-high value-low)
              "<="
                (set! next-high value-high)

                (do))
            (when (< next-high next-low)
              (set! next-high next-low))
            (set! scan^.view view)
            (set! scan^.index next-low)
            (set! scan^.high next-high)
            (return true ""))))))))

(defn physical-op-tighten-db-read-source-eavt-ea-value-scan! [source: DB-Read-Source, scan: ^Clause-Index-Scan, clause-value: Clause, op: Physical-Op, rel: Query-Relation, row: int] -> [ok: bool, error: string]
  (when (not (and (physical-op-pushdown-tightens-value-range? op clause-value rel row)
                  (not scan^.reverse-attr)
                  scan^.e-ok
                  scan^.a-ok
                  (not scan^.v-ok)
                  (= scan^.e-value.kind .Entity)
                  (= scan^.a-value.kind .Keyword)))
    (return true ""))
  (let [[attr-ref attr-ref-ok attr-ref-error] (db-read-source-schema-ref? source scan^.a-value.text)]
    (when (not attr-ref-ok)
      (return false attr-ref-error))
    (when attr-ref
      (return true "")))
  (let [[range-value range-value-ok] (physical-op-pushdown-range-value op rel row)]
    (when (not range-value-ok)
      (return true ""))
  (let [view (db-read-source-index-view source .EAVT)
        ea-prefix ([]Value [scan^.e-value scan^.a-value])
        eav-prefix ([]Value [scan^.e-value scan^.a-value range-value])
        [ea-low ea-low-ok ea-low-error] (db-read-source-lower-bound-values source view ea-prefix)]
    (when (not ea-low-ok)
      (return false ea-low-error))
    (let [[ea-high ea-high-ok ea-high-error] (db-read-source-upper-bound-values source view ea-prefix)]
      (when (not ea-high-ok)
        (return false ea-high-error))
      (let [[value-low value-low-ok value-low-error] (db-read-source-lower-bound-values source view eav-prefix)]
        (when (not value-low-ok)
          (return false value-low-error))
        (let [[value-high value-high-ok value-high-error] (db-read-source-upper-bound-values source view eav-prefix)]
          (when (not value-high-ok)
            (return false value-high-error))
          (let [next-low ea-low
                next-high ea-high]
            (case op.pushdown-scalar-requirement.op
              "="
                (do
                  (set! next-low value-low)
                  (set! next-high value-high))
              ">"
                (set! next-low value-high)
              ">="
                (set! next-low value-low)
              "<"
                (set! next-high value-low)
              "<="
                (set! next-high value-high)

                (do))
            (when (< next-high next-low)
              (set! next-high next-low))
            (set! scan^.view view)
            (set! scan^.index next-low)
            (set! scan^.high next-high)
            (return true ""))))))))

(defn db-read-source-add-primary-clause-datom-typed-with-op! [source: DB-Read-Source, builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, binding: Binding, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, direct-ok: bool, op: Physical-Op] -> bool
  (if direct-ok
    (let [names (make [dynamic]string) :defer
          values (make [dynamic]Value) :defer]
      (if (db-read-source-direct-datom-clause-matches-typed-row! source rel row scan clause-value datom (addr names) (addr values))
        (if (db-read-source-direct-clause-pushdown-matches? rel row scan clause-value datom op)
          (db-read-source-append-direct-clause-row! builder attrs rel row scan clause-value datom)
          true)
        true))
    (let [[next next-ok] (db-read-source-binding-after-clause-datom source binding clause-value datom)]
      (when next-ok
        (return (if (db-read-source-binding-pushdown-matches? next op)
                  (query-relation-builder-add-binding! builder attrs next false)
                  true)))
      true)))

(defn db-read-source-add-primary-clause-datom-typed! [source: DB-Read-Source, builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, binding: Binding, scan: Clause-Index-Scan, clause-value: Clause, datom: Datom, direct-ok: bool] -> bool
  (db-read-source-add-primary-clause-datom-typed-with-op! source builder attrs rel row binding scan clause-value datom direct-ok (Physical-Op {})))

(defn db-read-source-add-primary-clause-datoms-typed-with-op! [source: DB-Read-Source, builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, binding: Binding, scan: Clause-Index-Scan, clause-value: Clause, datoms: []Datom, direct-ok: bool, op: Physical-Op, stats: ^Query-Stats] -> bool
  (for [datom datoms]
    (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
    (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source builder attrs rel row binding scan clause-value datom direct-ok op))
      (return false)))
  true)

(defn db-read-source-bind-join-op? [op: Physical-Op] -> bool
  (or (= op.kind .BindJoinScan)
      (= op.kind .PrimaryScan)))

(defn db-read-source-bind-join-eavt-cardinality-one-supported? [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [ok: bool, error: string]
  (when (not (and (db-read-source-bind-join-op? op)
                  rel.has-typed-columns
                  (db-read-source-primary-source? clause-value.has-source clause-value.source)
                  (= clause-value.e.kind .Var)
                  (query-relation-has-attr? rel clause-value.e.name)
                  (= clause-value.a.kind .Value)
                  (= clause-value.a.value.kind .Keyword)
                  (not (reverse-attr? clause-value.a.value.text))
                  (db-read-source-direct-value-term-supported? clause-value.v)
                  (db-read-source-direct-optional-term-supported? clause-value.tx-term)
                  (db-read-source-direct-optional-term-supported? clause-value.op-term)))
    (return false ""))
  (let [[many many-ok many-error] (db-read-source-schema-cardinality-many? source clause-value.a.value.text)]
    (when (not many-ok)
      (return false many-error))
    (return (not many) "")))

(defn db-read-source-bind-join-eavt-merge-supported? [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [ok: bool, error: string]
  (when (not (and (db-read-source-bind-join-op? op)
                  rel.has-typed-columns
                  (not (db-read-source-has-overlay? source))
                  (db-read-source-primary-source? clause-value.has-source clause-value.source)
                  (= clause-value.e.kind .Var)
                  (query-relation-has-attr? rel clause-value.e.name)
                  (= clause-value.a.kind .Value)
                  (= clause-value.a.value.kind .Keyword)
                  (not (reverse-attr? clause-value.a.value.text))
                  (db-read-source-direct-value-term-supported? clause-value.v)
                  (db-read-source-direct-optional-term-supported? clause-value.tx-term)
                  (db-read-source-direct-optional-term-supported? clause-value.op-term)))
    (return false ""))
  (return true ""))

(defn db-read-source-bind-join-avet-value-supported? [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [ok: bool, error: string]
  (when (not (and (db-read-source-bind-join-op? op)
                  rel.has-typed-columns
                  (not (db-read-source-has-overlay? source))
                  (db-read-source-primary-source? clause-value.has-source clause-value.source)
                  (db-read-source-direct-value-term-supported? clause-value.e)
                  (= clause-value.a.kind .Value)
                  (= clause-value.a.value.kind .Keyword)
                  (not (reverse-attr? clause-value.a.value.text))
                  (= clause-value.v.kind .Var)
                  (query-relation-has-attr? rel clause-value.v.name)
                  (db-read-source-direct-optional-term-supported? clause-value.tx-term)
                  (db-read-source-direct-optional-term-supported? clause-value.op-term)))
    (return false ""))
  (let [[_ ref-ok ref-error] (db-read-source-schema-ref? source clause-value.a.value.text)]
    (when (not ref-ok)
      (return false ref-error)))
  (return true ""))

(defn db-read-source-query-relation-apply-bind-join-eavt-cardinality-one [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[supported supported-error] (db-read-source-bind-join-eavt-cardinality-one-supported? source rel clause-value op)]
    (when (not (= supported-error ""))
      (return (query-relation-empty) false))
    (when (not supported)
      (return (query-relation-empty) false)))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[entity-value entity-ok entity-error] (db-read-source-query-relation-resolve-typed-entity-term source rel row source-clause.e)]
          (when (not (= entity-error ""))
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (when (and entity-ok (= entity-value.kind .Entity))
            (let [[found-value value-ok value-error] (db-read-source-cardinality-one-value-fast-all-current source entity-value.entity source-clause.a.value.text)]
              (when (not (= value-error ""))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (when value-ok
                (let [scan (Clause-Index-Scan {view: (db-read-source-index-view source .EAVT)
                                               index: 0
                                               high: 1
                                               e-value: entity-value
                                               e-ok: true
                                               a-value: source-clause.a.value
                                               a-ok: true
                                               v-value: (Value {})
                                               v-ok: false
                                               reverse-attr: false
                                               forward-attr: ""})
                      datom (Datom {e: entity-value.entity
                                    a: source-clause.a.value.text
                                    v: found-value})]
                  (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                  (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel row (Binding {}) scan source-clause datom true op))
                    (delete-owned-value found-value)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))
                  (delete-owned-value found-value))))))
        (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
        (set! stats^.clauses (+ stats^.clauses 1))
        (query-stats-observe-source-operator! stats)
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-apply-bind-join-eavt-cardinality-one-merge [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[supported supported-error] (db-read-source-bind-join-eavt-merge-supported? source rel clause-value op)]
    (when (not (= supported-error ""))
      (return (query-relation-empty) false))
    (when (or (not supported)
              (db-read-source-has-overlay? source))
      (return (query-relation-empty) false)))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        [entity-column-index entity-column-ok] (query-relation-attr-index-lookup rel source-clause.e.name)]
    (when (not entity-column-ok)
      (return (query-relation-empty) false))
    (let [[row-refs row-refs-ok] (sorted-entity-row-refs-from-relation-column rel.typed-columns[entity-column-index] rel.typed-rows)]
      (when (not row-refs-ok)
        (return (query-relation-empty) false))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
        (let [builder (query-relation-builder (slice attrs 0))
              [stream stream-ok stream-error] (source-index-datom-stream source source-clause.a.value.text)]
          (when (not stream-ok)
            (delete row-refs)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
          (query-stats-observe-source-operator! stats)
          (let [ref-index 0]
            (while (and (< ref-index (count row-refs))
                        stream.has-current)
              (let [target row-refs[ref-index].entity]
                (while (and stream.has-current
                            (< stream.current.e target))
                  (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                    (when (not advance-ok)
                      (delete-source-index-datom-stream stream)
                      (delete row-refs)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (when (and stream.has-current
                           (> stream.current.e target))
                  (while (and (< ref-index (count row-refs))
                              (< row-refs[ref-index].entity stream.current.e))
                    (set! ref-index (+ ref-index 1)))
                  (continue))
                (when (and stream.has-current
                           (= stream.current.e target))
                  (let [group-end ref-index]
                    (while (and (< group-end (count row-refs))
                                (= row-refs[group-end].entity target))
                      (set! group-end (+ group-end 1)))
                    (while (and stream.has-current
                                (= stream.current.e target))
                      (let [scan (Clause-Index-Scan {view: (db-read-source-index-view source .EAVT)
                                                     index: 0
                                                     high: 1
                                                     e-value: (value-entity stream.current.e)
                                                     e-ok: true
                                                     a-value: source-clause.a.value
                                                     a-ok: true
                                                     v-value: (Value {})
                                                     v-ok: false
                                                     reverse-attr: false
                                                     forward-attr: ""})
                            row-ref-index ref-index]
                        (while (< row-ref-index group-end)
                          (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                          (let [source-row row-refs[row-ref-index].row]
                            (if (db-read-source-bind-join-adds-single-value-var? rel source-clause)
                              (when (not (db-read-source-append-bind-join-single-value-var-row! (addr builder) (slice attrs 0) rel source-row source-clause stream.current op))
                                (delete-source-index-datom-stream stream)
                                (delete row-refs)
                                (delete attrs)
                                (delete attr-sources)
                                (delete-query-relation-builder builder)
                                (return (query-relation-empty) false))
                              (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel source-row (Binding {}) scan source-clause stream.current true op))
                                (delete-source-index-datom-stream stream)
                                (delete row-refs)
                                (delete attrs)
                                (delete attr-sources)
                                (delete-query-relation-builder builder)
                                (return (query-relation-empty) false))))
                          (set! row-ref-index (+ row-ref-index 1))))
                      (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                        (when (not advance-ok)
                          (delete-source-index-datom-stream stream)
                          (delete row-refs)
                          (delete attrs)
                          (delete attr-sources)
                          (delete-query-relation-builder builder)
                          (return (query-relation-empty) false))))
                    (set! ref-index group-end))))))
          (delete-source-index-datom-stream stream)
          (delete row-refs)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true))))))

(defstruct Source-Entity-Attr-Value-Link {
  value: Value
  next: int
})

(defn delete-source-entity-attr-value-links [links: [dynamic]Source-Entity-Attr-Value-Link]
  (for [link links]
    (delete-owned-value link.value))
  (delete links))

(defn append-source-entity-attr-value-link! [heads: ^map[u64]int, links: ^[dynamic]Source-Entity-Attr-Value-Link, entity: u64, value: Value]
  (let [[head found] (mmap.get heads^ entity)
        next (if found head -1)
        index (count links^)]
    (arr.push! links^ (Source-Entity-Attr-Value-Link {value: (value-owned value)
                                                       next: next}))
    (mmap.assoc! heads^ entity index)))

(defn unconstrained-clause-history-term? [term: Term] -> bool
  (or (omitted-term? term)
      (term-wildcard? term)))

(defn db-read-source-same-bound-entity-value-pair-supported? [source: DB-Read-Source, rel: Query-Relation, first: Clause, second: Clause] -> bool
  (when (or (not rel.has-typed-columns)
            (db-read-source-has-overlay? source)
            (not (db-read-source-primary-source? first.has-source first.source))
            (not (db-read-source-primary-source? second.has-source second.source)))
    (return false))
  (let [first-clause (if first.has-source (unsourced-clause first) first)
        second-clause (if second.has-source (unsourced-clause second) second)]
    (and (= first-clause.e.kind .Var)
         (= second-clause.e.kind .Var)
         (= first-clause.e.name second-clause.e.name)
         (query-relation-has-attr? rel first-clause.e.name)
         (= first-clause.a.kind .Value)
         (= first-clause.a.value.kind .Keyword)
         (= second-clause.a.kind .Value)
         (= second-clause.a.value.kind .Keyword)
         (not (reverse-attr? first-clause.a.value.text))
         (not (reverse-attr? second-clause.a.value.text))
         (= first-clause.v.kind .Var)
         (= second-clause.v.kind .Var)
         (not (= first-clause.v.name second-clause.v.name))
         (not (query-relation-has-attr? rel first-clause.v.name))
         (not (query-relation-has-attr? rel second-clause.v.name))
         (unconstrained-clause-history-term? first.tx-term)
         (unconstrained-clause-history-term? first.op-term)
         (unconstrained-clause-history-term? second.tx-term)
         (unconstrained-clause-history-term? second.op-term))))

(defn db-read-source-query-relation-apply-same-bound-entity-value-pair [source: DB-Read-Source, rel: Query-Relation, first: Clause, second: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, used: bool, error: string]
  (when (not (db-read-source-same-bound-entity-value-pair-supported? source rel first second))
    (return (query-relation-empty) false false ""))
  (let [first-clause (if first.has-source (unsourced-clause first) first)
        second-clause (if second.has-source (unsourced-clause second) second)
        [entity-column-index entity-column-ok] (query-relation-attr-index-lookup rel first-clause.e.name)]
    (when (not entity-column-ok)
      (return (query-relation-empty) false false ""))
    (let [[row-refs row-refs-ok] (sorted-entity-row-refs-from-relation-column rel.typed-columns[entity-column-index] rel.typed-rows)]
      (when (not row-refs-ok)
        (return (query-relation-empty) false true ""))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
            row-heads (make (map u64 int)) :defer
            row-links (make [dynamic]Reverse-Derived-Row-Link) :defer
            entities (make [dynamic]u64) :defer
            previous-entity: u64 0
            has-previous false]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) first-clause.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) second-clause.v "")
        (for [ref row-refs]
          (append-reverse-derived-row-link! (addr row-heads) (addr row-links) ref.entity ref.row)
          (when (or (not has-previous)
                    (not (= previous-entity ref.entity)))
            (arr.push! entities ref.entity)
            (set! previous-entity ref.entity)
            (set! has-previous true)))
        (delete row-refs)
        (let [builder (query-relation-builder (slice attrs 0))
              first-heads (make (map u64 int)) :defer
              second-heads (make (map u64 int)) :defer
              first-links (make [dynamic]Source-Entity-Attr-Value-Link)
              second-links (make [dynamic]Source-Entity-Attr-Value-Link)
              source-attrs ([]string [first-clause.a.value.text second-clause.a.value.text])
              [datoms datoms-ok datoms-used scan-count candidate-count datoms-error] (source-eavt-entity-attrs-datoms source (slice entities 0) source-attrs)]
          (defer (delete-source-entity-attr-value-links first-links))
          (defer (delete-source-entity-attr-value-links second-links))
          (defer (delete-owned-datoms datoms))
          (when (not datoms-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false true datoms-error))
          (when (not datoms-used)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false false ""))
          (for [datom datoms]
            (when (= datom.a first-clause.a.value.text)
              (append-source-entity-attr-value-link! (addr first-heads) (addr first-links) datom.e datom.v))
            (when (= datom.a second-clause.a.value.text)
              (append-source-entity-attr-value-link! (addr second-heads) (addr second-links) datom.e datom.v)))
          (for [entity entities]
            (let [[first-head first-found] (mmap.get first-heads entity)
                  [second-head second-found] (mmap.get second-heads entity)
                  [row-head row-found] (mmap.get row-heads entity)]
              (when (and first-found second-found row-found)
                (let [first-index first-head]
                  (while (>= first-index 0)
                    (let [second-index second-head]
                      (while (>= second-index 0)
                        (let [row-index row-head]
                          (while (>= row-index 0)
                            (when (not (query-relation-builder-add-column-row-with-two-output-values! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row-links[row-index].row first-clause.v.name first-links[first-index].value second-clause.v.name second-links[second-index].value))
                              (delete attrs)
                              (delete attr-sources)
                              (delete-query-relation-builder builder)
                              (return (query-relation-empty) false true "failed to build same-entity merged clause relation"))
                            (set! row-index row-links[row-index].next)))
                        (set! second-index second-links[second-index].next)))
                    (set! first-index first-links[first-index].next))))))
          (mut! stats^.clauses += 2)
          (mut! stats^.source-index-scans += scan-count)
          (when (>= candidate-count 0)
            (mut! stats^.clause-candidates += candidate-count))
          (query-stats-observe-source-operator! stats)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true true ""))))))

(defn db-read-source-query-relation-apply-bind-join-avet-value-exact-ranges [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[supported supported-error] (db-read-source-bind-join-avet-value-supported? source rel clause-value op)]
    (when (not (= supported-error ""))
      (return (query-relation-empty) false))
    (when (not supported)
      (return (query-relation-empty) false)))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        attr source-clause.a.value.text
        [value-column-index value-column-ok] (query-relation-attr-index-lookup rel source-clause.v.name)]
    (when (not value-column-ok)
      (return (query-relation-empty) false))
    (when (> rel.typed-rows 2048)
      (return (query-relation-empty) false))
    (let [[row-refs row-refs-ok row-refs-error] (sorted-value-row-refs-from-relation-column-for-source-attr source attr rel.typed-columns[value-column-index] rel.typed-rows)]
      (when (not row-refs-ok)
        (return (query-relation-empty) false))
      (when (= (count row-refs) 0)
        (delete-value-relation-row-refs row-refs)
        (return (query-relation-empty) false))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
        (let [builder (query-relation-builder (slice attrs 0))
              ref-index 0]
          (while (< ref-index (count row-refs))
            (let [group-start ref-index]
              (while (and (< ref-index (count row-refs))
                          (= (index-position-compare row-refs[ref-index].value row-refs[group-start].value) 0))
                (set! ref-index (+ ref-index 1)))
              (let [values ([]Value [(value-keyword attr) row-refs[group-start].value])
                    [stream stream-ok stream-error] (source-index-datom-stream-for-values source .AVET values)]
                (when (not stream-ok)
                  (delete-value-relation-row-refs row-refs)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
                (query-stats-observe-source-operator! stats)
                (while stream.has-current
                  (let [scan (Clause-Index-Scan {view: (db-read-source-index-view source .AVET)
                                                 index: 0
                                                 high: 1
                                                 e-value: (Value {})
                                                 e-ok: false
                                                 a-value: source-clause.a.value
                                                 a-ok: true
                                                 v-value: row-refs[group-start].value
                                                 v-ok: true
                                                 reverse-attr: false
                                                 forward-attr: ""})
                        row-ref-index group-start]
                    (while (< row-ref-index ref-index)
                      (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                      (let [source-row row-refs[row-ref-index].row]
                        (if (db-read-source-bind-join-adds-single-entity-var? rel source-clause)
                          (when (not (db-read-source-append-bind-join-single-entity-var-row! (addr builder) (slice attrs 0) rel source-row source-clause stream.current op))
                            (delete-source-index-datom-stream stream)
                            (delete-value-relation-row-refs row-refs)
                            (delete attrs)
                            (delete attr-sources)
                            (delete-query-relation-builder builder)
                            (return (query-relation-empty) false))
                          (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel source-row (Binding {}) scan source-clause stream.current true op))
                            (delete-source-index-datom-stream stream)
                            (delete-value-relation-row-refs row-refs)
                            (delete attrs)
                            (delete attr-sources)
                            (delete-query-relation-builder builder)
                            (return (query-relation-empty) false))))
                      (set! row-ref-index (+ row-ref-index 1))))
                  (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                    (when (not advance-ok)
                      (delete-source-index-datom-stream stream)
                      (delete-value-relation-row-refs row-refs)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (delete-source-index-datom-stream stream))))
          (delete-value-relation-row-refs row-refs)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true))))))

(defn db-read-source-query-relation-apply-bind-join-avet-value-merge [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[supported supported-error] (db-read-source-bind-join-avet-value-supported? source rel clause-value op)]
    (when (not (= supported-error ""))
      (return (query-relation-empty) false))
    (when (not supported)
      (return (query-relation-empty) false)))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        attr source-clause.a.value.text
        [value-column-index value-column-ok] (query-relation-attr-index-lookup rel source-clause.v.name)]
    (when (not value-column-ok)
      (return (query-relation-empty) false))
    (let [[row-refs row-refs-ok row-refs-error] (sorted-value-row-refs-from-relation-column-for-source-attr source attr rel.typed-columns[value-column-index] rel.typed-rows)]
      (when (not row-refs-ok)
        (return (query-relation-empty) false))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
        (let [builder (query-relation-builder (slice attrs 0))
              values ([]Value [(value-keyword attr)])
              [stream stream-ok stream-error] (source-index-datom-stream-for-values source .AVET values)]
          (when (not stream-ok)
            (delete-value-relation-row-refs row-refs)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
          (query-stats-observe-source-operator! stats)
          (let [ref-index 0]
            (while (and (< ref-index (count row-refs))
                        stream.has-current)
              (let [compare (index-position-compare stream.current.v row-refs[ref-index].value)]
                (cond
                  (< compare 0)
                    (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                      (when (not advance-ok)
                        (delete-source-index-datom-stream stream)
                        (delete-value-relation-row-refs row-refs)
                        (delete attrs)
                        (delete attr-sources)
                        (delete-query-relation-builder builder)
                        (return (query-relation-empty) false)))
                  (> compare 0)
                    (set! ref-index (+ ref-index 1))
                  :else
                    (let [group-end ref-index]
                      (while (and (< group-end (count row-refs))
                                  (= (index-position-compare row-refs[group-end].value row-refs[ref-index].value) 0))
                        (set! group-end (+ group-end 1)))
                      (while (and stream.has-current
                                  (= (index-position-compare stream.current.v row-refs[ref-index].value) 0))
                        (let [scan (Clause-Index-Scan {view: (db-read-source-index-view source .AVET)
                                                       index: 0
                                                       high: 1
                                                       e-value: (Value {})
                                                       e-ok: false
                                                       a-value: source-clause.a.value
                                                       a-ok: true
                                                       v-value: row-refs[ref-index].value
                                                       v-ok: true
                                                       reverse-attr: false
                                                       forward-attr: ""})
                              row-ref-index ref-index]
                          (while (< row-ref-index group-end)
                            (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                            (let [source-row row-refs[row-ref-index].row]
                              (if (db-read-source-bind-join-adds-single-entity-var? rel source-clause)
                                (when (not (db-read-source-append-bind-join-single-entity-var-row! (addr builder) (slice attrs 0) rel source-row source-clause stream.current op))
                                  (delete-source-index-datom-stream stream)
                                  (delete-value-relation-row-refs row-refs)
                                  (delete attrs)
                                  (delete attr-sources)
                                  (delete-query-relation-builder builder)
                                  (return (query-relation-empty) false))
                                (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel source-row (Binding {}) scan source-clause stream.current true op))
                                  (delete-source-index-datom-stream stream)
                                  (delete-value-relation-row-refs row-refs)
                                  (delete attrs)
                                  (delete attr-sources)
                                  (delete-query-relation-builder builder)
                                  (return (query-relation-empty) false))))
                            (set! row-ref-index (+ row-ref-index 1))))
                        (let [[advance-ok advance-error] (advance-source-index-datom-stream! source (addr stream))]
                          (when (not advance-ok)
                            (delete-source-index-datom-stream stream)
                            (delete-value-relation-row-refs row-refs)
                            (delete attrs)
                            (delete attr-sources)
                            (delete-query-relation-builder builder)
                            (return (query-relation-empty) false))))
                      (set! ref-index group-end))))))
          (delete-source-index-datom-stream stream)
          (delete-value-relation-row-refs row-refs)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true))))))

(defn db-read-source-avet-value-merge-before-exact? [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [prefer: bool, ok: bool]
  (let [[supported supported-error] (db-read-source-bind-join-avet-value-supported? source rel clause-value op)]
    (when (not (= supported-error ""))
      (return false false))
    (when (not supported)
      (return false false)))
  (when (sqlite-merge-index-view? (db-read-source-index-view source .AVET))
    ;; Exact per-value ranges preserve bound-input semantics across merged
    ;; durable runs; the sequential merge path is only preferred for flat roots.
    (return false true))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        [entry-count entry-ok _entry-error] (db-read-source-attr-range-entry-count source source-clause.a.value.text)]
    (when (not entry-ok)
      (return false false))
    (return (<= entry-count (* rel.typed-rows 8)) true)))

(defn db-read-source-query-relation-apply-primary-clause-typed-with-op [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            (not (db-read-source-primary-source? clause-value.has-source clause-value.source)))
    (return (query-relation-empty) false))
  (when (= source.kind .Relation-Value)
    (return (db-read-source-query-relation-apply-primary-relation-value-clause-with-op source rel clause-value op stats)))
  (when (> rel.typed-rows 16)
    (let [[bound-join-merge bound-join-merge-ok] (db-read-source-query-relation-apply-bind-join-eavt-cardinality-one-merge source rel clause-value op stats)]
      (when bound-join-merge-ok
        (return bound-join-merge true))
      (delete-query-relation bound-join-merge)))
  (let [[bound-join bound-join-ok] (db-read-source-query-relation-apply-bind-join-eavt-cardinality-one source rel clause-value op stats)]
    (when bound-join-ok
      (return bound-join true))
    (delete-query-relation bound-join))
  (when (<= rel.typed-rows 16)
    (let [[bound-join-merge bound-join-merge-ok] (db-read-source-query-relation-apply-bind-join-eavt-cardinality-one-merge source rel clause-value op stats)]
      (when bound-join-merge-ok
        (return bound-join-merge true))
      (delete-query-relation bound-join-merge)))
  (let [[prefer-bound-value-merge prefer-bound-value-merge-ok] (db-read-source-avet-value-merge-before-exact? source rel clause-value op)]
    (when (and prefer-bound-value-merge-ok prefer-bound-value-merge)
      (let [[bound-value-merge bound-value-merge-ok] (db-read-source-query-relation-apply-bind-join-avet-value-merge source rel clause-value op stats)]
        (when bound-value-merge-ok
          (return bound-value-merge true))
        (delete-query-relation bound-value-merge))))
  (let [[bound-value-exact bound-value-exact-ok] (db-read-source-query-relation-apply-bind-join-avet-value-exact-ranges source rel clause-value op stats)]
    (when bound-value-exact-ok
      (return bound-value-exact true))
    (delete-query-relation bound-value-exact))
  (let [[prefer-bound-value-merge prefer-bound-value-merge-ok] (db-read-source-avet-value-merge-before-exact? source rel clause-value op)]
    (when (and prefer-bound-value-merge-ok (not prefer-bound-value-merge))
      (let [[bound-value-merge bound-value-merge-ok] (db-read-source-query-relation-apply-bind-join-avet-value-merge source rel clause-value op stats)]
        (when bound-value-merge-ok
          (return bound-value-merge true))
        (delete-query-relation bound-value-merge))))
  (when (not (> rel.typed-rows 16))
    (let [[bound-value-merge bound-value-merge-ok] (db-read-source-query-relation-apply-bind-join-avet-value-merge source rel clause-value op stats)]
      (when bound-value-merge-ok
        (return bound-value-merge true))
      (delete-query-relation bound-value-merge)))
  (let [source-clause (if clause-value.has-source
                        (unsourced-clause clause-value)
                        clause-value)
        attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
    (let [builder (query-relation-builder (slice attrs 0))
          direct-ok (db-read-source-primary-clause-direct-supported? source-clause)
          row 0]
      (while (< row rel.typed-rows)
        (if (db-read-source-has-overlay? source)
          (let [[datoms scan candidates-ok _] (db-read-source-clause-candidates-for-typed-row-with-op source rel row source-clause op)]
            (when (not candidates-ok)
              (delete-owned-datoms datoms)
              (delete-clause-index-scan scan)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (if direct-ok
              (when (not (db-read-source-add-primary-clause-datoms-typed-with-op! source (addr builder) (slice attrs 0) rel row (Binding {}) scan source-clause (slice datoms 0) true op stats))
                (delete-owned-datoms datoms)
                (delete-clause-index-scan scan)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
                (when (not binding-ok)
                  (delete-owned-datoms datoms)
                  (delete-clause-index-scan scan)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (when (not (db-read-source-add-primary-clause-datoms-typed-with-op! source (addr builder) (slice attrs 0) rel row binding scan source-clause (slice datoms 0) false op stats))
                  (delete binding.items)
                  (delete-owned-datoms datoms)
                  (delete-clause-index-scan scan)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (delete binding.items)))
            (delete-owned-datoms datoms)
            (delete-clause-index-scan scan))
          (let [[stream stream-ok stream-error] (source-clause-datom-stream-for-typed-row-with-op source rel row source-clause op)]
            (when (not stream-ok)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (if direct-ok
              (while stream.has-current
                (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel row (Binding {}) stream.scan source-clause stream.current true op))
                  (delete-source-clause-datom-stream stream)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (let [[advance-ok advance-error] (advance-source-clause-datom-stream! source (addr stream))]
                  (when (not advance-ok)
                    (delete-source-clause-datom-stream stream)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))))
              (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
                (when (not binding-ok)
                  (delete-source-clause-datom-stream stream)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
                (while stream.has-current
                  (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
                  (when (not (db-read-source-add-primary-clause-datom-typed-with-op! source (addr builder) (slice attrs 0) rel row binding stream.scan source-clause stream.current false op))
                    (delete-source-clause-datom-stream stream)
                    (delete binding.items)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))
                  (let [[advance-ok advance-error] (advance-source-clause-datom-stream! source (addr stream))]
                    (when (not advance-ok)
                      (delete-source-clause-datom-stream stream)
                      (delete binding.items)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (delete binding.items)))
            (delete-source-clause-datom-stream stream)))
        (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
        (set! stats^.clauses (+ stats^.clauses 1))
        (query-stats-observe-source-operator! stats)
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-apply-primary-clause-typed [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (db-read-source-query-relation-apply-primary-clause-typed-with-op source rel clause-value (Physical-Op {}) stats))

(defn db-read-source-get-else-batch-datoms [source: DB-Read-Source, entities: []u64, attr: string] -> [datoms: [dynamic]Datom, ok: bool, used: bool, scans: int, candidates: int, error: string]
  (when (reverse-attr? attr)
    (return (make [dynamic]Datom) true false 0 0 ""))
  (source-eavt-entity-attrs-datoms source entities ([]string [attr])))

(defn db-read-source-query-relation-apply-primary-get-else-typed [source: DB-Read-Source, rel: Query-Relation, get-else: Get-Else, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-primary-source? get-else.has-source get-else.source)))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        row-entities (make [dynamic]u64 0 rel.typed-rows) :defer
        row-has-entity (make [dynamic]bool 0 rel.typed-rows) :defer
        entities (make [dynamic]u64 0 rel.typed-rows) :defer]
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-else.out "")
    (let [row 0]
      (while (< row rel.typed-rows)
        (let [[entity entity-ok entity-error] (db-read-source-query-relation-resolve-typed-entity-term source rel row get-else.e)]
          (when (not (= entity-error ""))
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false))
          (let [has-entity (and entity-ok (= entity.kind .Entity))]
            (arr.push! row-has-entity has-entity)
            (arr.push! row-entities (if has-entity entity.entity (u64 0)))
            (when has-entity
              (arr.push! entities entity.entity))))
        (mut! row += 1)))
    (let [builder (query-relation-builder-with-capacity (slice attrs 0) rel.typed-rows)
          [datoms datoms-ok datoms-used scan-count candidate-count datoms-error]
            (db-read-source-get-else-batch-datoms source (slice entities 0) get-else.a)]
      (defer (delete-owned-datoms datoms))
      (when (not datoms-ok)
        (delete attrs)
        (delete attr-sources)
        (delete-query-relation-builder builder)
        (return (query-relation-empty) false))
      (if datoms-used
        (let [values-by-entity (make (map u64 Value)) :defer
              batch-row 0]
          (for [datom datoms]
            (mmap.assoc! values-by-entity datom.e datom.v))
          (while (< batch-row rel.typed-rows)
            (when row-has-entity[batch-row]
              (let [[attr-value attr-ok] (mmap.get values-by-entity row-entities[batch-row])
                    out-value (if attr-ok attr-value get-else.default-value)]
                (when (query-relation-typed-row-var-agrees? rel batch-row get-else.out out-value)
                  (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) batch-row get-else.out out-value))
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))))
            (mut! batch-row += 1))
          (mut! stats^.source-index-scans += scan-count)
          (when (>= candidate-count 0)
            (mut! stats^.clause-candidates += candidate-count)))
        (let [fallback-row 0]
          (while (< fallback-row rel.typed-rows)
            (when row-has-entity[fallback-row]
              (let [[attr-value attr-ok attr-error] (db-read-source-pull-attr-value source row-entities[fallback-row] get-else.a)]
                (when (not (= attr-error ""))
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (let [out-value (if attr-ok attr-value get-else.default-value)]
                  (when (query-relation-typed-row-var-agrees? rel fallback-row get-else.out out-value)
                    (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) fallback-row get-else.out out-value))
                      (when attr-ok
                        (delete-owned-value attr-value))
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                  (when attr-ok
                    (delete-owned-value attr-value))))
            (mut! fallback-row += 1))
          (mut! stats^.source-index-scans += (count entities))))
      (query-stats-observe-source-operator! stats)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-apply-mixed-source-get-else-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, get-else: Get-Else, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (db-read-source-primary-source? get-else.has-source get-else.source)
    (return (db-read-source-query-relation-apply-primary-get-else-typed source rel get-else stats)))
  (when (not (query-source-input-name? get-else.source))
    (return (query-relation-empty) false))
  (let [[read-source read-source-ok _] (db-read-source-for-get-else source sources get-else)]
    (when (or (not read-source-ok)
              (= read-source.kind .Relation-Value))
      (return (query-relation-empty) false))
    (db-read-source-query-relation-apply-primary-get-else-typed read-source rel (unsourced-get-else get-else) stats)))

(defn db-read-source-typed-get-some-row-values [source: DB-Read-Source, rel: Query-Relation, row: int, get-some: Get-Some] -> [attr-result: Value, attr-value: Value, ok: bool, error: string]
  (let [[entity entity-ok entity-error] (db-read-source-query-relation-resolve-typed-entity-term source rel row get-some.e)]
    (when (not (= entity-error ""))
      (return (Value {}) (Value {}) false entity-error))
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return (Value {}) (Value {}) false ""))
    (for [attr get-some.attrs]
      (let [[value value-ok value-error] (db-read-source-pull-attr-value source entity.entity attr)]
        (when (not (= value-error ""))
          (return (Value {}) (Value {}) false value-error))
        (when value-ok
          (let [attr-result-value (value-keyword attr)]
            (when (and (query-relation-typed-row-var-agrees? rel row get-some.out-attr attr-result-value)
                       (query-relation-typed-row-var-agrees? rel row get-some.out-value value))
              (return attr-result-value value true ""))))))
    (return (Value {}) (Value {}) false "")))

(defn db-read-source-query-relation-apply-primary-get-some-typed [source: DB-Read-Source, rel: Query-Relation, get-some: Get-Some, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-primary-source? get-some.has-source get-some.source)))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-some.out-attr "")
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-some.out-value "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[attr-result attr-value value-ok value-error] (db-read-source-typed-get-some-row-values source rel row get-some)]
          (when (not (= value-error ""))
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (when value-ok
            (when (not (query-relation-builder-add-column-row-with-two-output-values! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row get-some.out-attr attr-result get-some.out-value attr-value))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))))
        (set! row (+ row 1)))
      (set! stats^.source-index-scans (+ stats^.source-index-scans rel.typed-rows))
      (query-stats-observe-source-operator! stats)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-apply-mixed-source-get-some-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, get-some: Get-Some, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (db-read-source-primary-source? get-some.has-source get-some.source)
    (return (db-read-source-query-relation-apply-primary-get-some-typed source rel get-some stats)))
  (when (not (query-source-input-name? get-some.source))
    (return (query-relation-empty) false))
  (let [[read-source read-source-ok _] (db-read-source-for-get-some source sources get-some)]
    (when (or (not read-source-ok)
              (= read-source.kind .Relation-Value))
      (return (query-relation-empty) false))
    (db-read-source-query-relation-apply-primary-get-some-typed read-source rel (unsourced-get-some get-some) stats)))

(defn source-rule-body-typed-eligible? [rules: []Rule, rule: Rule, registry: []Native-Query-Fn] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (cond
      (= step.kind .Clause) (discard step)
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? rule.get-elses[step.index].has-source rule.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? rule.get-somes[step.index].has-source rule.get-somes[step.index].source))
          (return false))
      (= step.kind .RuleCall) (discard step)
      (= step.kind .Not)
        (when (not (db-read-source-primary-typed-branch-group? rules rule.not-groups[step.index] registry))
          (return false))
      (= step.kind .Or)
        (when (not (db-read-source-primary-typed-or-group? rules rule.or-groups[step.index] registry))
          (return false))
      :else
        (return false)))
  true)

(defn source-rule-call-typed-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call, registry: []Native-Query-Fn] -> bool
  (let [local-call (if call.has-source (rule-call-without-source call) call)]
    (when plan.recursive
      (return (or (source-positive-rule-delta-plan-eligible? plan local-call)
                  (source-positive-rule-naive-plan-eligible? plan local-call)))))
  (for [rule plan.rules]
    (when (not (source-rule-body-typed-eligible? (slice plan.rules 0) rule registry))
      (return false)))
  true)

(defn source-rule-calls-typed-eligible? [rules: []Rule, calls: []Rule-Call, registry: []Native-Query-Fn] -> bool
  (when (= (count calls) 0)
    (return true))
  (when (= (count rules) 0)
    (return false))
  (for [call calls]
    (let [plan (rule-call-plan rules call.name)]
      (let [eligible (source-rule-call-typed-plan-eligible? plan call registry)]
        (delete-rule-call-plan plan)
        (when (not eligible)
          (return false)))))
  true)

(defn source-query-rule-calls-typed-eligible? [rules: []Rule, calls: []Rule-Call, registry: []Native-Query-Fn] -> bool
  (source-rule-calls-typed-eligible? rules calls registry))

(defn source-rule-body-typed-plannable? [rule: Rule] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .RuleCall)))
      (return false)))
  true)

(defn query-relation-term-ready? [rel: Query-Relation, term: Term] -> bool
  (case term.kind
    .Var (query-relation-has-attr? rel term.name)
    true))

(defn query-relation-rule-call-ready-indexed? [rules: []Rule, rule-index: []Rule-Name-Index-Entry, rel: Query-Relation, call: Rule-Call] -> bool
  (let [[ok _] (validate-rule-call-required-bindings-indexed (slice rel.attrs 0) rules rule-index call)]
    ok))

(defn query-relation-rule-call-selectivity-score [rel: Query-Relation, call: Rule-Call] -> int
  (let [bound-count (query-relation-rule-call-bound-arg-count rel call)]
    (cond
      (>= bound-count 2) 1
      (= bound-count 1) 2
      :else 6)))

(defn query-relation-clause-selectivity-score [rel: Query-Relation, clause: Clause] -> int
  (let [e-bound (query-relation-term-ready? rel clause.e)
        a-bound (query-relation-term-ready? rel clause.a)
        v-bound (query-relation-term-ready? rel clause.v)
        attr-keyword (and (= clause.a.kind .Value)
                          (= clause.a.value.kind .Keyword))]
    (cond
      (and e-bound attr-keyword) 1
      (and attr-keyword v-bound) 2
      e-bound 3
      attr-keyword 4
      (and a-bound v-bound) 4
      v-bound 5
      :else 6)))

(defn query-relation-predicate-ready? [rel: Query-Relation, predicate: Predicate] -> bool
  (predicate-ready-with-vars? predicate (slice rel.attrs 0)))

(defn query-relation-rule-body-step-ready-indexed? [rules: []Rule, rule-index: []Rule-Name-Index-Entry, rel: Query-Relation, rule: Rule, step: Query-Step, registry: []Native-Query-Fn] -> bool
  (case step.kind
    .Clause true
    .Predicate
      (and (query-relation-predicate-ready? rel rule.predicates[step.index])
           (query-relation-predicate-can-run-typed? rel rule.predicates[step.index] registry))
    .RuleCall
      (query-relation-rule-call-ready-indexed? rules rule-index rel rule.rule-calls[step.index])
    false))

(defn query-relation-rule-body-step-score [rel: Query-Relation, rule: Rule, step: Query-Step] -> int
  (case step.kind
    .Clause (query-relation-clause-selectivity-score rel rule.clauses[step.index])
    .Predicate (predicate-selectivity-score rule.predicates[step.index])
    .RuleCall (query-relation-rule-call-selectivity-score rel rule.rule-calls[step.index])
    10))

(defn best-ready-query-relation-rule-body-step-index-indexed [rules: []Rule, rule-index: []Rule-Name-Index-Entry, rel: Query-Relation, rule: Rule, steps: []Query-Step, registry: []Native-Query-Fn] -> [index: int, ok: bool]
  (let [best -1
        best-score 0]
    (for [step step-index steps]
      (when (query-relation-rule-body-step-ready-indexed? rules rule-index rel rule step registry)
        (let [score (query-relation-rule-body-step-score rel rule step)]
          (when (or (= best -1)
                    (< score best-score))
            (set! best step-index)
            (set! best-score score)))))
    (return best (>= best 0))))

(defn source-backed-not-group-has-recursive-rule-call? [rules: []Rule, group: Not-Group] -> bool
  (for [call group.rule-calls]
    (let [plan (rule-call-plan rules call.name)
          recursive plan.recursive]
      (delete-rule-call-plan plan)
      (when recursive
        (return true))))
  (for [child group.not-groups]
    (when (source-backed-not-group-has-recursive-rule-call? rules child)
      (return true)))
  false)

(defn source-backed-or-branch-has-recursive-rule-call-in-negation? [rules: []Rule, branch: Not-Group] -> bool
  (for [group branch.not-groups]
    (when (source-backed-not-group-has-recursive-rule-call? rules group)
      (return true)))
  false)

(defn source-backed-or-group-has-recursive-rule-call-in-negation? [rules: []Rule, group: Or-Group] -> bool
  (for [branch group.branches]
    (when (source-backed-or-branch-has-recursive-rule-call-in-negation? rules branch)
      (return true)))
  false)

(defn source-backed-not-group-has-rule-call-reaching-name? [rules: []Rule, group: Not-Group, name: string] -> bool
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (for [call group.rule-calls]
      (when (or (= call.name name)
                (rule-reaches-name? (slice deps 0) call.name name))
        (return true))))
  (for [child group.not-groups]
    (when (source-backed-not-group-has-rule-call-reaching-name? rules child name)
      (return true)))
  false)

(defn source-backed-or-branch-has-rule-call-reaching-name-in-negation? [rules: []Rule, branch: Not-Group, name: string] -> bool
  (for [group branch.not-groups]
    (when (source-backed-not-group-has-rule-call-reaching-name? rules group name)
      (return true)))
  false)

(defn source-backed-or-group-has-rule-call-reaching-name-in-negation? [rules: []Rule, group: Or-Group, name: string] -> bool
  (for [branch group.branches]
    (when (source-backed-or-branch-has-rule-call-reaching-name-in-negation? rules branch name)
      (return true)))
  false)

(defn source-backed-rule-has-recursive-rule-call-in-negation? [rules: []Rule, rule: Rule] -> bool
  (for [group rule.not-groups]
    (when (source-backed-not-group-has-rule-call-reaching-name? rules group rule.name)
      (return true)))
  (for [group rule.or-groups]
    (when (source-backed-or-group-has-rule-call-reaching-name-in-negation? rules group rule.name)
      (return true)))
  false)

(defn source-backed-query-has-recursive-rule-call-in-negation? [query-value: Query] -> bool
  (for [group query-value.not-groups]
    (when (source-backed-not-group-has-recursive-rule-call? (slice query-value.rules 0) group)
      (return true)))
  (for [group query-value.or-groups]
    (when (source-backed-or-group-has-recursive-rule-call-in-negation? (slice query-value.rules 0) group)
      (return true)))
  (for [rule query-value.rules]
    (when (source-backed-rule-has-recursive-rule-call-in-negation? (slice query-value.rules 0) rule)
      (return true)))
  false)

(defn rule-call-without-source [call: Rule-Call] -> Rule-Call
  (Rule-Call {name: call.name
              source: ""
              has-source: false
              args: call.args}))

(defn db-read-source-resolve-rule-call-source [source: DB-Read-Source, sources: []DB-Read-Named-Source, call: Rule-Call] -> [call-source: DB-Read-Source, local-call: Rule-Call, ok: bool]
  (when (not call.has-source)
    (return source call true))
  (let [[resolved-source resolved-ok] (db-read-source-for-rule-call-source source sources call.source)]
    (when (not resolved-ok)
      (return (DB-Read-Source {}) call false))
    (return resolved-source (rule-call-without-source call) true)))

(defn source-positive-recursive-rule-eligible? [rule: Rule] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (cond
      (= step.kind .Clause) (discard step)
      (= step.kind .RuleCall)
        (when rule.rule-calls[step.index].has-source
          (return false))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? rule.get-elses[step.index].has-source rule.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? rule.get-somes[step.index].has-source rule.get-somes[step.index].source))
          (return false))
      :else
        (return false)))
  true)

(defn source-positive-recursive-branch-eligible? [branch: Not-Group] -> bool
  (when (> (count branch.not-groups) 0)
    (return false))
  (for [step branch.steps]
    (cond
      (= step.kind .Clause) (discard step)
      (= step.kind .RuleCall)
        (when branch.rule-calls[step.index].has-source
          (return false))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? branch.get-elses[step.index].has-source branch.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? branch.get-somes[step.index].has-source branch.get-somes[step.index].source))
          (return false))
      :else
        (return false)))
  true)

(defn source-positive-recursive-or-group-eligible? [group: Or-Group] -> bool
  (when (= (count group.branches) 0)
    (return false))
  (for [branch group.branches]
    (when (not (source-positive-recursive-branch-eligible? branch))
      (return false)))
  true)

(defn source-recursive-negative-filter-group-eligible? [group: Not-Group] -> bool
  (when (> (count group.not-groups) 0)
    (return false))
  (for [step group.steps]
    (cond
      (= step.kind .Clause) (discard step)
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? group.get-elses[step.index].has-source group.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? group.get-somes[step.index].has-source group.get-somes[step.index].source))
          (return false))
      :else
        (return false)))
  true)

(defn source-positive-recursive-rule-naive-eligible? [rule: Rule] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (cond
      (= step.kind .Clause) (discard step)
      (= step.kind .RuleCall)
        (when rule.rule-calls[step.index].has-source
          (return false))
      (= step.kind .Predicate) (discard step)
      (= step.kind .Function) (discard step)
      (= step.kind .Ground) (discard step)
      (= step.kind .GetElse)
        (when (not (db-read-source-primary-source? rule.get-elses[step.index].has-source rule.get-elses[step.index].source))
          (return false))
      (= step.kind .GetSome)
        (when (not (db-read-source-primary-source? rule.get-somes[step.index].has-source rule.get-somes[step.index].source))
          (return false))
      (= step.kind .Or)
        (when (not (source-positive-recursive-or-group-eligible? rule.or-groups[step.index]))
          (return false))
      (= step.kind .Not)
        (when (not (source-recursive-negative-filter-group-eligible? rule.not-groups[step.index]))
          (return false))
      :else
        (return false)))
  true)

(defn source-positive-rule-memo-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (when (or call.has-source
            (not plan.recursive))
    (return false))
  (for [rule plan.rules]
    (when (not (source-positive-recursive-rule-eligible? rule))
      (return false)))
  true)

(defn source-positive-rule-delta-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (when (not (source-positive-rule-memo-plan-eligible? plan call))
    (return false))
  (let [recursive-names (recursive-component-names-for-rule (slice plan.rules 0) call.name)]
    (defer (delete recursive-names))
    (when (= (count recursive-names) 0)
      (return false))
    (for [rule plan.rules]
      (when (not (string-slice-contains? (slice recursive-names 0) rule.name))
        (return false))
      (for [rule-call rule.rule-calls]
        (when (not (string-slice-contains? (slice recursive-names 0) rule-call.name))
          (return false)))))
  true)

(defn source-positive-rule-naive-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (when (or call.has-source
            (not plan.recursive))
    (return false))
  (let [recursive-names (recursive-component-names-for-rule (slice plan.rules 0) call.name)]
    (defer (delete recursive-names))
    (when (= (count recursive-names) 0)
      (return false))
    (for [rule plan.rules]
      (when (not (string-slice-contains? (slice recursive-names 0) rule.name))
        (return false))
      (when (not (source-positive-recursive-rule-naive-eligible? rule))
        (return false))
      (for [rule-call rule.rule-calls]
        (when (not (string-slice-contains? (slice recursive-names 0) rule-call.name))
          (return false)))
      (for [og rule.or-groups]
        (for [br og.branches]
          (for [rc br.rule-calls]
            (when (not (string-slice-contains? (slice recursive-names 0) rc.name))
              (return false)))))))
  true)

(defn db-read-source-query-relation-apply-or-branch-memo [source: DB-Read-Source, sources: []DB-Read-Named-Source, memo: ^[dynamic]Rule-Memo-Entry, rel: Query-Relation, row: int, group: Or-Group, branch: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats, use-delta: bool, delta-call-index: int] -> [out: Query-Relation, ok: bool]
  (let [current (query-relation-empty)
        current-ok false]
    (if group.has-join
      (let [[projected projected-ok] (query-relation-single-typed-row-projected rel row (slice group.join-vars 0))]
        (set! current projected)
        (set! current-ok projected-ok))
      (let [[single single-ok] (query-relation-single-typed-row rel row)]
        (set! current single)
        (set! current-ok single-ok)))
    (when (not current-ok)
      (delete-query-relation current)
      (return (query-relation-empty) false))
    (for [step branch.steps]
      (let [next (query-relation-empty)
            next-ok false]
        (cond
          (= step.kind .RuleCall)
            (do
              (set! stats^.rule-calls (+ stats^.rule-calls 1))
              (set! next (query-relation-after-rule-call-from-memo (DB {}) memo current branch.rule-calls[step.index] use-delta delta-call-index step.index))
              (set! next-ok true))
          (or (= step.kind .Clause)
              (= step.kind .Predicate)
              (= step.kind .Function)
              (= step.kind .Ground)
              (= step.kind .GetElse)
              (= step.kind .GetSome))
            (let [[typed-next typed-ok]
                    (db-read-source-query-relation-apply-typed-step
                      source
                      sources
                      current
                      step
                      (slice branch.clauses 0)
                      (slice branch.predicates 0)
                      (slice branch.function-clauses 0)
                      (slice branch.grounds 0)
                      (slice branch.get-elses 0)
                      (slice branch.get-somes 0)
                      (slice branch.not-groups 0)
                      ([]Or-Group [])
                      ([]Rule [])
                      ([]Rule-Call [])
                      registry
                      stats)]
              (set! next typed-next)
              (set! next-ok typed-ok))
          :else
            (discard step))
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next)
          (return (query-relation-empty) false))
        (set! current next)))
    (return current true)))

(defn db-read-source-query-relation-apply-or-group-memo [source: DB-Read-Source, sources: []DB-Read-Named-Source, memo: ^[dynamic]Rule-Memo-Entry, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn, stats: ^Query-Stats, use-delta: bool, delta-call-index: int] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (source-positive-recursive-or-group-eligible? group)))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-or-group-output-vars! (addr output-vars) group)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (for [branch group.branches]
          (let [[branch-rel branch-ok] (db-read-source-query-relation-apply-or-branch-memo source sources memo rel row group branch registry stats use-delta delta-call-index)]
            (when (not branch-ok)
              (delete-query-relation branch-rel)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (let [branch-row 0]
              (while (< branch-row (query-relation-row-count branch-rel))
                (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) branch-rel branch-row))
                  (delete-query-relation branch-rel)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (set! branch-row (+ branch-row 1))))
            (delete-query-relation branch-rel)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-after-rule-step-memo [source: DB-Read-Source, sources: []DB-Read-Named-Source, memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, rel: Query-Relation, step: Query-Step, registry: []Native-Query-Fn, stats: ^Query-Stats, use-delta: bool, delta-call-index: int] -> [out: Query-Relation, ok: bool]
  (cond
    (= step.kind .RuleCall)
      (do
        (set! stats^.rule-calls (+ stats^.rule-calls 1))
        (let [out (query-relation-after-rule-call-from-memo (DB {}) memo rel rule.rule-calls[step.index] use-delta delta-call-index step.index)]
          (return out true)))
    (or (= step.kind .Clause)
        (= step.kind .Predicate)
        (= step.kind .Function)
        (= step.kind .Ground)
        (= step.kind .GetElse)
        (= step.kind .GetSome))
      (db-read-source-query-relation-apply-typed-step
        source
        sources
        rel
        step
        (slice rule.clauses 0)
        (slice rule.predicates 0)
        (slice rule.function-clauses 0)
        (slice rule.grounds 0)
        (slice rule.get-elses 0)
        (slice rule.get-somes 0)
        (slice rule.not-groups 0)
        (slice rule.or-groups 0)
        ([]Rule [])
        ([]Rule-Call [])
        registry
        stats)
    (= step.kind .Or)
      (db-read-source-query-relation-apply-or-group-memo source sources memo rel rule.or-groups[step.index] registry stats use-delta delta-call-index)
    (= step.kind .Not)
      (db-read-source-query-relation-apply-simple-not-group
        source
        sources
        ([]Rule [])
        rel
        rule.not-groups[step.index]
        registry
        stats)
    :else
      (return (query-relation-empty) false)))

(defn db-read-source-query-relation-after-rule-body-memo [source: DB-Read-Source, sources: []DB-Read-Named-Source, memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, registry: []Native-Query-Fn, stats: ^Query-Stats, use-delta: bool, delta-call-index: int] -> Query-Relation
  (let [current (query-relation-singleton)]
    (for [step rule.body-steps]
      (let [[next-raw next-ok] (db-read-source-query-relation-after-rule-step-memo source sources memo rule current step registry stats use-delta delta-call-index)]
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next-raw)
          (return (query-relation-empty)))
        (let [next (query-relation-dedupe-step next-raw)]
          (delete-query-relation next-raw)
          (set! current next)
          (when (= (query-relation-row-count current) 0)
            (return current)))))
    current))

(defn db-read-source-query-relation-from-recursive-rule-call-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, plan: Rule-Call-Plan, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (source-positive-rule-delta-plan-eligible? plan call))
    (return (query-relation-empty) false))
  (let [memo (rule-memo-build (slice plan.rules 0))]
    (defer (delete-rule-memo memo))
    (for [rule plan.rules]
      (let [[_ has-call] (first-rule-call-index rule)]
        (when (not has-call)
          (let [rel (db-read-source-query-relation-after-rule-body-memo source sources (addr memo) rule registry stats false -1)]
            (discard (rule-memo-append-relation-results-to-delta! (addr memo) (addr memo) rule rel))
            (delete-query-relation rel)))))
    (while (rule-memo-has-delta? (slice memo 0))
      (let [next-delta (rule-memo-build (slice plan.rules 0))]
        (for [rule plan.rules]
          (let [delta-call-indexes (rule-call-indexes rule)]
            (for [delta-call-index delta-call-indexes]
              (let [rel (db-read-source-query-relation-after-rule-body-memo source sources (addr memo) rule registry stats true delta-call-index)]
                (discard (rule-memo-append-relation-results-to-delta! (addr memo) (addr next-delta) rule rel))
                (delete-query-relation rel)))
            (delete delta-call-indexes)))
        (rule-memo-replace-deltas! (addr memo) (slice next-delta 0))
        (delete-rule-memo next-delta)))
    (let [seed (query-relation-singleton)
          projected (query-relation-after-rule-call-from-memo (DB {}) (addr memo) seed call false -1 -1)
          deduped (query-relation-dedupe-step projected)]
      (delete-query-relation seed)
      (delete-query-relation projected)
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (query-relation-row-count deduped))
      (return deduped deduped.has-typed-columns))))

(defn db-read-source-query-relation-from-recursive-rule-call-naive-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, plan: Rule-Call-Plan, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (source-positive-rule-naive-plan-eligible? plan call))
    (return (query-relation-empty) false))
  (let [memo (rule-memo-build (slice plan.rules 0))
        changed true]
    (defer (delete-rule-memo memo))
    (while changed
      (set! changed false)
      (let [next-delta (rule-memo-build (slice plan.rules 0))]
        (for [rule plan.rules]
          (let [rel (db-read-source-query-relation-after-rule-body-memo source sources (addr memo) rule registry stats false -1)]
            (when (rule-memo-append-relation-results-to-delta! (addr memo) (addr next-delta) rule rel)
              (set! changed true))
            (delete-query-relation rel)))
        (rule-memo-replace-deltas! (addr memo) (slice next-delta 0))
        (delete-rule-memo next-delta))
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1)))
    (let [seed (query-relation-singleton)
          projected (query-relation-after-rule-call-from-memo (DB {}) (addr memo) seed call false -1 -1)
          deduped (query-relation-dedupe-step projected)]
      (delete-query-relation seed)
      (delete-query-relation projected)
      (query-stats-observe-bindings! stats (query-relation-row-count deduped))
      (return deduped deduped.has-typed-columns))))

(defn db-read-source-query-relation-from-rule-body-typed-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rule: Rule, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int] -> [rel: Query-Relation, ok: bool]
  (when (< depth 0)
    (return (query-relation-empty) false))
  (when (not (source-rule-body-typed-eligible? rules rule registry))
    (return (query-relation-empty) false))
  (when (not (source-rule-body-typed-plannable? rule))
    (let [current (query-relation-singleton)
          step-index 0]
      (while (< step-index (count rule.body-steps))
        (let [step rule.body-steps[step-index]
              next (query-relation-empty)
              next-ok false
              pair-used false]
          (when (and (= step.kind .Clause)
                     (< (+ step-index 1) (count rule.body-steps))
                     (= rule.body-steps[(+ step-index 1)].kind .Clause))
            (let [next-step rule.body-steps[(+ step-index 1)]
                  [pair-rel pair-ok pair-used-value _pair-error] (db-read-source-query-relation-apply-same-bound-entity-value-pair source current rule.clauses[step.index] rule.clauses[next-step.index] stats)]
              (when pair-used-value
                (set! next pair-rel)
                (set! next-ok pair-ok)
                (set! pair-used true))
              (when (not pair-used-value)
                (delete-query-relation pair-rel))))
          (when (not pair-used)
            (let [[single-next single-ok] (db-read-source-query-relation-apply-typed-step
                                            source
                                            sources
                                            current
                                            step
                                            (slice rule.clauses 0)
                                            (slice rule.predicates 0)
                                            (slice rule.function-clauses 0)
                                            (slice rule.grounds 0)
                                            (slice rule.get-elses 0)
                                            (slice rule.get-somes 0)
                                            (slice rule.not-groups 0)
                                            (slice rule.or-groups 0)
                                            rules
                                            (slice rule.rule-calls 0)
                                            registry
                                            stats)]
              (delete-query-relation next)
              (set! next single-next)
              (set! next-ok single-ok)))
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) false))
          (let [deduped (query-relation-dedupe-step next)]
            (delete-query-relation next)
            (set! current deduped))
          (when (= (query-relation-row-count current) 0)
            (return current true))
          (if pair-used
            (mut! step-index += 2)
            (mut! step-index += 1))))
      (return current true)))
  (let [current (query-relation-singleton)
        remaining (arr.into [dynamic]Query-Step (slice rule.body-steps 0))
        rule-index (rule-name-index-build rules)]
    (defer (delete remaining))
    (defer (delete-rule-name-index rule-index))
    (while (and (> (count remaining) 0)
                (> (query-relation-row-count current) 0))
      (let [[chosen-index chosen-ok] (best-ready-query-relation-rule-body-step-index-indexed rules (slice rule-index 0) current rule (slice remaining 0) registry)]
        (when (not chosen-ok)
          (delete-query-relation current)
          (return (query-relation-empty) false))
        (let [step remaining[chosen-index]
            next (query-relation-empty)
            next-ok false
            pair-index -1]
        (when (and (= step.kind .Clause)
                   (>= chosen-index 0))
          (for [candidate candidate-index remaining]
            (when (and (= pair-index -1)
                       (not (= candidate-index chosen-index))
                       (= candidate.kind .Clause))
              (let [[pair-rel pair-ok pair-used-value _pair-error] (db-read-source-query-relation-apply-same-bound-entity-value-pair source current rule.clauses[step.index] rule.clauses[candidate.index] stats)]
                (if pair-used-value
                  (do
                    (set! next pair-rel)
                    (set! next-ok pair-ok)
                    (set! pair-index candidate-index))
                  (delete-query-relation pair-rel))))))
        (when (= pair-index -1)
          (let [[single-next single-ok] (db-read-source-query-relation-apply-typed-step
                                          source
                                          sources
                                          current
                                          step
                                          (slice rule.clauses 0)
                                          (slice rule.predicates 0)
                                          (slice rule.function-clauses 0)
                                          (slice rule.grounds 0)
                                          (slice rule.get-elses 0)
                                          (slice rule.get-somes 0)
                                          (slice rule.not-groups 0)
                                          (slice rule.or-groups 0)
                                          rules
                                          (slice rule.rule-calls 0)
                                          registry
                                          stats)]
            (delete-query-relation next)
            (set! next single-next)
            (set! next-ok single-ok)))
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next)
          (return (query-relation-empty) false))
        (let [deduped (query-relation-dedupe-step next)]
          (delete-query-relation next)
          (set! current deduped))
        (when (= (query-relation-row-count current) 0)
          (return current true))
        (if (>= pair-index 0)
          (do
            (if (> pair-index chosen-index)
              (do
                (arr.remove-ordered-at! remaining pair-index)
                (arr.remove-ordered-at! remaining chosen-index))
              (do
                (arr.remove-ordered-at! remaining chosen-index)
                (arr.remove-ordered-at! remaining pair-index))))
          (arr.remove-ordered-at! remaining chosen-index)))))
    (return current true)))

(defn db-read-source-query-relation-from-rule-body-seeded-typed-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rule: Rule, seed: Query-Relation, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int] -> [rel: Query-Relation, ok: bool]
  (when (< depth 0)
    (return (query-relation-empty) false))
  (when (not (and seed.has-typed-columns
                  (source-rule-body-typed-eligible? rules rule registry)))
    (return (query-relation-empty) false))
  (when (not (source-rule-body-typed-plannable? rule))
    (let [current (query-relation-copy seed)
          step-index 0]
      (while (< step-index (count rule.body-steps))
        (let [step rule.body-steps[step-index]
              next (query-relation-empty)
              next-ok false
              pair-used false]
          (when (and (= step.kind .Clause)
                     (< (+ step-index 1) (count rule.body-steps))
                     (= rule.body-steps[(+ step-index 1)].kind .Clause))
            (let [next-step rule.body-steps[(+ step-index 1)]
                  [pair-rel pair-ok pair-used-value _pair-error] (db-read-source-query-relation-apply-same-bound-entity-value-pair source current rule.clauses[step.index] rule.clauses[next-step.index] stats)]
              (when pair-used-value
                (set! next pair-rel)
                (set! next-ok pair-ok)
                (set! pair-used true))
              (when (not pair-used-value)
                (delete-query-relation pair-rel))))
          (when (not pair-used)
            (let [[single-next single-ok] (db-read-source-query-relation-apply-typed-step
                                            source
                                            sources
                                            current
                                            step
                                            (slice rule.clauses 0)
                                            (slice rule.predicates 0)
                                            (slice rule.function-clauses 0)
                                            (slice rule.grounds 0)
                                            (slice rule.get-elses 0)
                                            (slice rule.get-somes 0)
                                            (slice rule.not-groups 0)
                                            (slice rule.or-groups 0)
                                            rules
                                            (slice rule.rule-calls 0)
                                            registry
                                            stats)]
              (delete-query-relation next)
              (set! next single-next)
              (set! next-ok single-ok)))
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) false))
          (let [deduped (query-relation-dedupe-step next)]
            (delete-query-relation next)
            (set! current deduped))
          (when (= (query-relation-row-count current) 0)
            (return current true))
          (if pair-used
            (mut! step-index += 2)
            (mut! step-index += 1))))
      (return current true)))
  (let [current (query-relation-copy seed)
        remaining (arr.into [dynamic]Query-Step (slice rule.body-steps 0))
        rule-index (rule-name-index-build rules)]
    (defer (delete remaining))
    (defer (delete-rule-name-index rule-index))
    (while (and (> (count remaining) 0)
                (> (query-relation-row-count current) 0))
      (let [[chosen-index chosen-ok] (best-ready-query-relation-rule-body-step-index-indexed rules (slice rule-index 0) current rule (slice remaining 0) registry)]
        (when (not chosen-ok)
          (delete-query-relation current)
          (return (query-relation-empty) false))
        (let [step remaining[chosen-index]
            next (query-relation-empty)
            next-ok false
            pair-index -1]
        (when (and (= step.kind .Clause)
                   (>= chosen-index 0))
          (for [candidate candidate-index remaining]
            (when (and (= pair-index -1)
                       (not (= candidate-index chosen-index))
                       (= candidate.kind .Clause))
              (let [[pair-rel pair-ok pair-used-value _pair-error] (db-read-source-query-relation-apply-same-bound-entity-value-pair source current rule.clauses[step.index] rule.clauses[candidate.index] stats)]
                (if pair-used-value
                  (do
                    (set! next pair-rel)
                    (set! next-ok pair-ok)
                    (set! pair-index candidate-index))
                  (delete-query-relation pair-rel))))))
        (when (= pair-index -1)
          (let [[single-next single-ok] (db-read-source-query-relation-apply-typed-step
                                          source
                                          sources
                                          current
                                          step
                                          (slice rule.clauses 0)
                                          (slice rule.predicates 0)
                                          (slice rule.function-clauses 0)
                                          (slice rule.grounds 0)
                                          (slice rule.get-elses 0)
                                          (slice rule.get-somes 0)
                                          (slice rule.not-groups 0)
                                          (slice rule.or-groups 0)
                                          rules
                                          (slice rule.rule-calls 0)
                                          registry
                                          stats)]
            (delete-query-relation next)
            (set! next single-next)
            (set! next-ok single-ok)))
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next)
          (return (query-relation-empty) false))
        (let [deduped (query-relation-dedupe-step next)]
          (delete-query-relation next)
          (set! current deduped))
        (when (= (query-relation-row-count current) 0)
          (return current true))
        (if (>= pair-index 0)
          (do
            (if (> pair-index chosen-index)
              (do
                (arr.remove-ordered-at! remaining pair-index)
                (arr.remove-ordered-at! remaining chosen-index))
              (do
                (arr.remove-ordered-at! remaining chosen-index)
                (arr.remove-ordered-at! remaining pair-index))))
          (arr.remove-ordered-at! remaining chosen-index)))))
    (return current true)))

(defn bind-rule-param-value! [binding: ^Binding, param: string, value: Value] -> bool
  (let [[existing exists] (binding-lookup binding^ param)]
    (if exists
      (predicate-value-equal? existing value)
      (do
        (binding-store! binding param value)
        true))))

(defn query-relation-seed-for-rule-call [rel: Query-Relation, rule: Rule, call: Rule-Call] -> [seed: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (= (count rule.params) (count call.args))))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        param-indexes (make [dynamic]int 0 (count rule.params))
        arg-source-indexes (make [dynamic]int 0 (count rule.params))
        clone-columns-ok true]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (case arg.kind
          .Var
            (let [[arg-index arg-ok] (query-relation-attr-index-lookup rel arg.name)]
              (if arg-ok
                (let [[param-index param-exists] (attr-position (slice attrs 0) param)]
                  (if param-exists
                    (do
                      (arr.push! param-indexes param-index)
                      (when (not (= param arg.name))
                        (set! clone-columns-ok false)))
                    (do
                      (arr.push! attrs param)
                      (arr.push! attr-sources rel.attr-sources[arg-index])
                      (arr.push! param-indexes (- (count attrs) 1))))
                  (arr.push! arg-source-indexes arg-index))
                (do
                  (arr.push! param-indexes -1)
                  (arr.push! arg-source-indexes -1))))
          .Value
            (let [[param-index param-exists] (attr-position (slice attrs 0) param)]
              (if param-exists
                (arr.push! param-indexes param-index)
                (do
                  (arr.push! attrs param)
                  (arr.push! attr-sources "")
                  (arr.push! param-indexes (- (count attrs) 1))))
              (arr.push! arg-source-indexes -1)
              (set! clone-columns-ok false))
          .Wildcard
            (do
              (arr.push! param-indexes -1)
              (arr.push! arg-source-indexes -1))
          .LookupRef
            (do
              (delete attrs)
              (delete attr-sources)
              (delete param-indexes)
              (delete arg-source-indexes)
              (return (query-relation-empty) false))
          (do
            (delete attrs)
            (delete attr-sources)
            (delete param-indexes)
            (delete arg-source-indexes)
            (return (query-relation-empty) false)))))
    (when clone-columns-ok
      (let [typed-columns (clone-relation-columns (slice rel.typed-columns 0))
            next-index (count rel.attrs)]
        (while (< next-index (count attrs))
          (let [source-index -1]
            (for [param-index index param-indexes]
              (when (= param-index next-index)
                (set! source-index arg-source-indexes[index])))
            (when (< source-index 0)
              (delete attrs)
              (delete attr-sources)
              (delete param-indexes)
              (delete arg-source-indexes)
              (delete-relation-columns typed-columns)
              (return (query-relation-empty) false))
            (arr.push! typed-columns (clone-relation-column rel.typed-columns[source-index])))
          (set! next-index (+ next-index 1)))
        (delete param-indexes)
        (delete arg-source-indexes)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: (make [dynamic]Binding)
                                 typed-columns: typed-columns
                                 typed-rows: rel.typed-rows
                                 has-typed-columns: true}) true)))
    (let [builder (query-relation-builder-with-capacity (slice attrs 0) rel.typed-rows)
          row 0]
      (while (< row rel.typed-rows)
        (let [row-ok true]
          (for [column index rel.typed-columns]
            (when row-ok
              (when (not (relation-column-row-compatible? builder.typed-columns[index] column row))
                (set! row-ok false))))
          (for [arg arg-index call.args]
            (when row-ok
              (let [param-index param-indexes[arg-index]]
                (when (>= param-index 0)
                  (case arg.kind
                    .Var
                      (let [arg-source-index arg-source-indexes[arg-index]
                            [value value-ok] (typed-relation-column-value rel.typed-columns[arg-source-index] row)]
                        (if value-ok
                          (if (< param-index (count rel.attrs))
                            (let [[existing existing-ok] (typed-relation-column-value rel.typed-columns[param-index] row)]
                              (set! row-ok (and existing-ok
                                                 (predicate-value-equal? existing value))))
                            (when (not (relation-column-row-compatible? builder.typed-columns[param-index] rel.typed-columns[arg-source-index] row))
                              (set! row-ok false)))
                          (set! row-ok false)))
                    .Value
                      (if (< param-index (count rel.attrs))
                        (let [[existing existing-ok] (typed-relation-column-value rel.typed-columns[param-index] row)]
                          (set! row-ok (and existing-ok
                                             (predicate-value-equal? existing arg.value))))
                        (when (not (relation-column-can-add? builder.typed-columns[param-index] arg.value))
                          (set! row-ok false)))
                    .Wildcard
                      (discard param-index)
                    .LookupRef
                      (set! row-ok false)
                    (set! row-ok false))))))
          (when row-ok
            (when (not (add-relation-column-row! (addr builder.typed-columns) (slice rel.typed-columns 0) row))
              (delete attrs)
              (delete attr-sources)
              (delete param-indexes)
              (delete arg-source-indexes)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (for [arg arg-index call.args]
              (let [param-index param-indexes[arg-index]]
                (when (>= param-index 0)
                  (case arg.kind
                    .Var
                      (when (>= param-index (count rel.attrs))
                        (let [arg-source-index arg-source-indexes[arg-index]]
                          (relation-column-row-add-checked! (addr builder.typed-columns[param-index]) rel.typed-columns[arg-source-index] row)))
                    .Value
                      (when (not (relation-column-add! (addr builder.typed-columns[param-index]) arg.value))
                        (delete attrs)
                        (delete attr-sources)
                        (delete param-indexes)
                        (delete arg-source-indexes)
                        (delete-query-relation-builder builder)
                        (return (query-relation-empty) false))
                    .Wildcard
                      (discard param-index)
                    .LookupRef
                      (do)
                    (do)))))
            (set! builder.typed-rows (+ builder.typed-rows 1)))
          (set! row (+ row 1))))
      (delete param-indexes)
      (delete arg-source-indexes)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-from-rule-call-typed-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int] -> [rel: Query-Relation, ok: bool]
  (when (< depth 0)
    (return (query-relation-empty) false))
  (let [[call-source local-call source-ok] (db-read-source-resolve-rule-call-source source sources call)]
    (when (not source-ok)
      (return (query-relation-empty) false))
  (let [[two-hop two-hop-ok two-hop-error] (db-read-source-query-relation-from-two-hop-attr-param-rule-call call-source rules local-call stats)]
    (when (not (= two-hop-error ""))
      (delete-query-relation two-hop)
      (return (query-relation-empty) false))
    (when two-hop-ok
      (return two-hop true))
    (delete-query-relation two-hop))
  (let [[reverse-derived reverse-derived-ok reverse-derived-error] (db-read-source-query-relation-from-reverse-derived-edge-rule-call call-source rules local-call stats)]
    (when (not (= reverse-derived-error ""))
      (delete-query-relation reverse-derived)
      (return (query-relation-empty) false))
    (when reverse-derived-ok
      (return reverse-derived true))
    (delete-query-relation reverse-derived))
  (let [plan (rule-call-plan rules local-call.name)]
    (defer (delete-rule-call-plan plan))
    (when (not (source-rule-call-typed-plan-eligible? plan local-call registry))
      (return (query-relation-empty) false))
    (when plan.recursive
      (if (source-positive-rule-delta-plan-eligible? plan local-call)
        (return (db-read-source-query-relation-from-recursive-rule-call-typed call-source sources plan local-call registry stats))
        (return (db-read-source-query-relation-from-recursive-rule-call-naive-typed call-source sources plan local-call registry stats))))
    (let [out (query-relation-empty)
          seen (set.empty string)
          has-out false]
      (defer (delete seen))
      (for [rule plan.rules]
        (when (= rule.name local-call.name)
          (let [[attr-param attr-param-ok] (rule-attr-param-two-values-same-entity rule local-call)]
            (when attr-param-ok
              (let [[attr-param-rel attr-param-built attr-param-error] (db-read-source-query-relation-from-attr-param-two-values-same-entity-rule call-source rule attr-param stats)]
                (when (not (= attr-param-error ""))
                  (delete-query-relation attr-param-rel)
                  (when has-out
                    (delete-query-relation out))
                  (return (query-relation-empty) false))
                (when attr-param-built
                  (let [[projected projected-ok] (query-relation-project-rule-call-params-typed attr-param-rel (slice rule.params 0) local-call)]
                    (delete-query-relation attr-param-rel)
                    (when (not projected-ok)
                      (delete-query-relation projected)
                      (when has-out
                        (delete-query-relation out))
                      (return (query-relation-empty) false))
                    (when (not has-out)
                      (delete-query-relation out)
                      (set! out (query-relation-empty-typed-like projected))
                      (set! has-out true))
                    (when (not (query-relation-append-typed-rows-unique! (addr out) projected (addr seen)))
                      (delete-query-relation projected)
                      (delete-query-relation out)
                      (return (query-relation-empty) false))
                    (delete-query-relation projected)
                    (continue)))
                (delete-query-relation attr-param-rel))))
          (let [[body-rel body-ok] (db-read-source-query-relation-from-rule-body-typed-depth call-source sources (slice plan.rules 0) rule registry stats depth)]
            (when (not body-ok)
              (delete-query-relation body-rel)
              (when has-out
                (delete-query-relation out))
              (return (query-relation-empty) false))
            (let [[projected projected-ok] (query-relation-project-rule-call-params-typed body-rel (slice rule.params 0) local-call)]
              (delete-query-relation body-rel)
              (when (not projected-ok)
                (delete-query-relation projected)
                (when has-out
                  (delete-query-relation out))
                (return (query-relation-empty) false))
              (when (not has-out)
                (delete-query-relation out)
                (set! out (query-relation-empty-typed-like projected))
                (set! has-out true))
              (when (not (query-relation-append-typed-rows-unique! (addr out) projected (addr seen)))
                (delete-query-relation projected)
                (delete-query-relation out)
                (return (query-relation-empty) false))
              (delete-query-relation projected)))))
      (if has-out
        (return out true)
        (do
          (delete-query-relation out)
          (return (query-relation-empty) false)))))))

(defn db-read-source-query-relation-apply-bound-rule-call-typed-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int] -> [out: Query-Relation, ok: bool]
  (when (or (< depth 0)
            (not rel.has-typed-columns)
            (= (query-relation-rule-call-bound-arg-count rel call) 0))
    (return (query-relation-empty) false))
  (let [[call-source local-call source-ok] (db-read-source-resolve-rule-call-source source sources call)]
    (when (not source-ok)
      (return (query-relation-empty) false))
  (let [plan (rule-call-plan rules local-call.name)]
    (defer (delete-rule-call-plan plan))
    (when (or plan.recursive
              (not (source-rule-call-typed-plan-eligible? plan local-call registry)))
      (return (query-relation-empty) false))
    (let [rule-rel (query-relation-empty)
          seen (set.empty string)
          has-rule-rel false
          rule-rel-has-passthrough false]
      (defer (delete seen))
      (for [rule plan.rules]
        (when (= rule.name local-call.name)
          (let [[seed seed-ok] (query-relation-seed-for-rule-call rel rule local-call)]
            (when (not seed-ok)
              (delete-query-relation seed)
              (when has-rule-rel
                (delete-query-relation rule-rel))
              (return (query-relation-empty) false))
            (let [[attr-param attr-param-ok] (rule-attr-param-two-values-same-entity rule local-call)]
              (when attr-param-ok
                (let [[bounded-rel bounded-ok bounded-error] (db-read-source-query-relation-from-bound-attr-param-two-values-same-entity-rule call-source rel rule local-call attr-param stats)]
                  (when (not (= bounded-error ""))
                    (delete-query-relation seed)
                    (delete-query-relation bounded-rel)
                    (when has-rule-rel
                      (delete-query-relation rule-rel))
                    (return (query-relation-empty) false))
                  (when bounded-ok
                    (delete-query-relation seed)
                    (let [[projected projected-ok] (query-relation-project-rule-call-params-typed bounded-rel (slice rule.params 0) local-call)]
                      (delete-query-relation bounded-rel)
                      (when (not projected-ok)
                        (delete-query-relation projected)
                        (when has-rule-rel
                          (delete-query-relation rule-rel))
                        (return (query-relation-empty) false))
                      (when (not has-rule-rel)
                        (delete-query-relation rule-rel)
                        (set! rule-rel (query-relation-empty-typed-like projected))
                        (set! has-rule-rel true))
                      (when (not (query-relation-append-typed-rows-unique! (addr rule-rel) projected (addr seen)))
                        (delete-query-relation projected)
                        (delete-query-relation rule-rel)
                        (return (query-relation-empty) false))
                      (delete-query-relation projected)
                      (continue)))
                  (delete-query-relation bounded-rel))
                (let [[attr-param-rel attr-param-built attr-param-error] (db-read-source-query-relation-from-attr-param-two-values-same-entity-rule call-source rule attr-param stats)]
                  (delete-query-relation seed)
                  (when (not (= attr-param-error ""))
                    (delete-query-relation attr-param-rel)
                    (when has-rule-rel
                      (delete-query-relation rule-rel))
                    (return (query-relation-empty) false))
                  (when attr-param-built
                    (let [[projected projected-ok] (query-relation-project-rule-call-params-typed attr-param-rel (slice rule.params 0) local-call)]
                      (delete-query-relation attr-param-rel)
                      (when (not projected-ok)
                        (delete-query-relation projected)
                        (when has-rule-rel
                          (delete-query-relation rule-rel))
                        (return (query-relation-empty) false))
                      (when (not has-rule-rel)
                        (delete-query-relation rule-rel)
                        (set! rule-rel (query-relation-empty-typed-like projected))
                        (set! has-rule-rel true))
                      (when (not (query-relation-append-typed-rows-unique! (addr rule-rel) projected (addr seen)))
                        (delete-query-relation projected)
                        (delete-query-relation rule-rel)
                        (return (query-relation-empty) false))
                      (delete-query-relation projected)
                      (continue)))
                  (delete-query-relation attr-param-rel))))
            (let [[body-rel body-ok] (db-read-source-query-relation-from-rule-body-seeded-typed-depth call-source sources (slice plan.rules 0) rule seed registry stats depth)]
              (delete-query-relation seed)
              (when (not body-ok)
                (delete-query-relation body-rel)
                (when has-rule-rel
                  (delete-query-relation rule-rel))
                (return (query-relation-empty) false))
              (let [passthrough-projected (query-relation-empty)
                    passthrough-ok false]
                (when (or (not has-rule-rel) rule-rel-has-passthrough)
                  (let [[candidate candidate-ok] (query-relation-project-seeded-rule-call-params-typed body-rel rel (slice rule.params 0) local-call)]
                    (delete-query-relation passthrough-projected)
                    (set! passthrough-projected candidate)
                    (set! passthrough-ok candidate-ok)))
                (when passthrough-ok
                  (delete-query-relation body-rel)
                  (when (not has-rule-rel)
                    (delete-query-relation rule-rel)
                    (set! rule-rel (query-relation-empty-typed-like passthrough-projected))
                    (set! has-rule-rel true))
                  (set! rule-rel-has-passthrough true)
                  (when (not (query-relation-append-typed-rows-unique! (addr rule-rel) passthrough-projected (addr seen)))
                    (delete-query-relation passthrough-projected)
                    (delete-query-relation rule-rel)
                    (return (query-relation-empty) false))
                  (delete-query-relation passthrough-projected)
                  (continue))
                (delete-query-relation passthrough-projected)
                (let [[projected projected-ok] (query-relation-project-rule-call-params-typed body-rel (slice rule.params 0) local-call)]
                (delete-query-relation body-rel)
                (when (not projected-ok)
                  (delete-query-relation projected)
                  (when has-rule-rel
                    (delete-query-relation rule-rel))
                  (return (query-relation-empty) false))
                (when (not has-rule-rel)
                  (delete-query-relation rule-rel)
                  (set! rule-rel (query-relation-empty-typed-like projected))
                  (set! has-rule-rel true))
                (when (not (query-relation-append-typed-rows-unique! (addr rule-rel) projected (addr seen)))
                  (delete-query-relation projected)
                  (delete-query-relation rule-rel)
                  (return (query-relation-empty) false))
                (delete-query-relation projected)))))))
      (when (not has-rule-rel)
        (delete-query-relation rule-rel)
        (return (query-relation-empty) false))
      (if rule-rel-has-passthrough
        (do
          (mut! stats^.rule-iterations += 1)
          (query-stats-observe-bindings! stats (query-relation-row-count rule-rel))
          (return rule-rel rule-rel.has-typed-columns))
        (let [joined (query-relation-join (DB {}) ([]DB-Source []) rel rule-rel)
              deduped (query-relation-dedupe-step joined)]
          (delete-query-relation rule-rel)
          (delete-query-relation joined)
          (mut! stats^.rule-iterations += 1)
          (query-stats-observe-bindings! stats (query-relation-row-count deduped))
          (return deduped deduped.has-typed-columns)))))))

(defn db-read-source-query-relation-apply-rule-call-typed-depth [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (mut! stats^.rule-calls += 1)
  (let [[call-source local-call source-ok] (db-read-source-resolve-rule-call-source source sources call)]
    (when source-ok
      (let [[bounded-two-hop bounded-two-hop-ok bounded-two-hop-error] (db-read-source-query-relation-from-bound-two-hop-attr-param-rule-call call-source rel rules local-call stats)]
        (when (not (= bounded-two-hop-error ""))
          (delete-query-relation bounded-two-hop)
          (return (query-relation-empty) false))
        (when bounded-two-hop-ok
          (let [joined (query-relation-join (DB {}) ([]DB-Source []) rel bounded-two-hop)
                deduped (query-relation-dedupe-step joined)]
            (delete-query-relation bounded-two-hop)
            (delete-query-relation joined)
            (mut! stats^.rule-iterations += 1)
            (query-stats-observe-bindings! stats (query-relation-row-count deduped))
            (return deduped deduped.has-typed-columns)))
        (delete-query-relation bounded-two-hop))
      (let [[bounded-reverse-derived bounded-reverse-derived-ok bounded-reverse-derived-error] (db-read-source-query-relation-from-bound-reverse-derived-edge-rule-call call-source rel rules local-call stats)]
        (when (not (= bounded-reverse-derived-error ""))
          (delete-query-relation bounded-reverse-derived)
          (return (query-relation-empty) false))
        (when bounded-reverse-derived-ok
          (if (query-relation-has-all-attrs? bounded-reverse-derived (slice rel.attrs 0))
            (do
              (mut! stats^.rule-iterations += 1)
              (query-stats-observe-bindings! stats (query-relation-row-count bounded-reverse-derived))
              (return bounded-reverse-derived bounded-reverse-derived.has-typed-columns))
            (let [joined (query-relation-join (DB {}) ([]DB-Source []) rel bounded-reverse-derived)
                  deduped (query-relation-dedupe-step joined)]
              (delete-query-relation bounded-reverse-derived)
              (delete-query-relation joined)
              (mut! stats^.rule-iterations += 1)
              (query-stats-observe-bindings! stats (query-relation-row-count deduped))
              (return deduped deduped.has-typed-columns))))
        (delete-query-relation bounded-reverse-derived))
      (let [[two-hop two-hop-ok two-hop-error] (db-read-source-query-relation-from-two-hop-attr-param-rule-call call-source rules local-call stats)]
        (when (not (= two-hop-error ""))
          (delete-query-relation two-hop)
          (return (query-relation-empty) false))
        (when two-hop-ok
          (let [joined (query-relation-join (DB {}) ([]DB-Source []) rel two-hop)
                deduped (query-relation-dedupe-step joined)]
            (delete-query-relation two-hop)
            (delete-query-relation joined)
            (mut! stats^.rule-iterations += 1)
            (query-stats-observe-bindings! stats (query-relation-row-count deduped))
            (return deduped deduped.has-typed-columns)))
        (delete-query-relation two-hop))))
  (let [[bound bound-ok] (db-read-source-query-relation-apply-bound-rule-call-typed-depth source sources rules rel call registry stats depth)]
    (when bound-ok
      (return bound true))
    (delete-query-relation bound))
  (let [[rule-rel rule-ok] (db-read-source-query-relation-from-rule-call-typed-depth source sources rules call registry stats depth)]
    (when (not rule-ok)
      (delete-query-relation rule-rel)
      (return (query-relation-empty) false))
    (let [joined (query-relation-join (DB {}) ([]DB-Source []) rel rule-rel)
          deduped (query-relation-dedupe-step joined)]
      (delete-query-relation rule-rel)
      (delete-query-relation joined)
      (mut! stats^.rule-iterations += 1)
      (query-stats-observe-bindings! stats (query-relation-row-count deduped))
      (return deduped deduped.has-typed-columns))))

(defn db-read-source-query-relation-apply-primary-typed-step [source: DB-Read-Source, rel: Query-Relation, step: Query-Step, clauses: []Clause, predicates: []Predicate, functions: []Function-Clause, grounds: []Ground, get-elses: []Get-Else, get-somes: []Get-Some, not-groups: []Not-Group, or-groups: []Or-Group, rules: []Rule, rule-calls: []Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (cond
    (= step.kind .Clause)
      (db-read-source-query-relation-apply-primary-clause-typed source rel clauses[step.index] stats)
    (= step.kind .Predicate)
      (do
        (when (not (query-relation-predicate-can-run-typed? rel predicates[step.index] registry))
          (return (query-relation-empty) false))
        (let [out (query-relation-filter-predicate (DB {}) rel predicates[step.index] registry)]
          (return out out.has-typed-columns)))
    (= step.kind .Function)
      (let [function functions[step.index]]
        (if (= function.op "fulltext")
          (db-read-source-query-relation-extend-fulltext-typed source ([]DB-Read-Named-Source []) rel function)
          (db-read-source-query-relation-extend-function-typed source rel function registry)))
    (= step.kind .Ground)
      (query-relation-apply-ground-typed rel grounds[step.index])
    (= step.kind .GetElse)
      (db-read-source-query-relation-apply-primary-get-else-typed source rel get-elses[step.index] stats)
    (= step.kind .GetSome)
      (db-read-source-query-relation-apply-primary-get-some-typed source rel get-somes[step.index] stats)
    (= step.kind .RuleCall)
      (db-read-source-query-relation-apply-rule-call-typed-depth source ([]DB-Read-Named-Source []) rules rel rule-calls[step.index] registry stats 20)
    (= step.kind .Not)
      (db-read-source-query-relation-apply-primary-not-group source rules rel not-groups[step.index] registry stats)
    (= step.kind .Or)
      (db-read-source-query-relation-apply-primary-or-group source rules rel or-groups[step.index] registry stats)
    :else
      (return (query-relation-empty) false)))

(defn db-read-source-query-relation-apply-primary-branch-step [source: DB-Read-Source, rules: []Rule, rel: Query-Relation, step: Query-Step, group: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (cond
    (= step.kind .Clause)
      (db-read-source-query-relation-apply-primary-clause-typed source rel group.clauses[step.index] stats)
    (= step.kind .Predicate)
      (do
        (when (not (query-relation-predicate-can-run-typed? rel group.predicates[step.index] registry))
          (return (query-relation-empty) false))
        (let [out (query-relation-filter-predicate (DB {}) rel group.predicates[step.index] registry)]
          (return out out.has-typed-columns)))
    (= step.kind .Function)
      (let [function group.function-clauses[step.index]]
        (if (= function.op "fulltext")
          (db-read-source-query-relation-extend-fulltext-typed source ([]DB-Read-Named-Source []) rel function)
          (db-read-source-query-relation-extend-function-typed source rel function registry)))
    (= step.kind .Ground)
      (query-relation-apply-ground-typed rel group.grounds[step.index])
    (= step.kind .GetElse)
      (db-read-source-query-relation-apply-primary-get-else-typed source rel group.get-elses[step.index] stats)
    (= step.kind .GetSome)
      (db-read-source-query-relation-apply-primary-get-some-typed source rel group.get-somes[step.index] stats)
    (= step.kind .RuleCall)
      (db-read-source-query-relation-apply-rule-call-typed-depth source ([]DB-Read-Named-Source []) rules rel group.rule-calls[step.index] registry stats 20)
    (= step.kind .Not)
      (db-read-source-query-relation-apply-primary-not-group source rules rel group.not-groups[step.index] registry stats)
    :else
      (return (query-relation-empty) false)))

(defn db-read-source-query-relation-primary-branch [source: DB-Read-Source, rules: []Rule, rel: Query-Relation, row: int, group: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [current (query-relation-empty)
        current-ok false]
    (if group.has-join
      (let [[projected projected-ok] (query-relation-single-typed-row-projected rel row (slice group.join-vars 0))]
        (set! current projected)
        (set! current-ok projected-ok))
      (let [[single single-ok] (query-relation-single-typed-row rel row)]
        (set! current single)
        (set! current-ok single-ok)))
    (when (not current-ok)
      (delete-query-relation current)
      (return (query-relation-empty) false))
    (if (> (count group.steps) 0)
      (for [step group.steps]
        (let [[next next-ok] (db-read-source-query-relation-apply-primary-branch-step source rules current step group registry stats)]
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) false))
          (set! current next)
          (when (= (query-relation-row-count current) 0)
            (return current true))))
      (for [clause-value group.clauses]
        (let [[next next-ok] (db-read-source-query-relation-apply-primary-clause-typed source current clause-value stats)]
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) false))
          (set! current next)
          (when (= (query-relation-row-count current) 0)
            (return current true)))))
    (return current true)))

(defn db-read-source-query-relation-apply-primary-not-group [source: DB-Read-Source, rules: []Rule, rel: Query-Relation, group: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-primary-typed-branch-group? rules group registry)))
    (return (query-relation-empty) false))
  (let [[anti anti-ok] (db-read-source-query-relation-apply-set-anti-join-not-group source ([]DB-Read-Named-Source []) rules rel group registry stats)]
    (when anti-ok
      (return anti true))
    (delete-query-relation anti))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))
        row 0]
    (while (< row rel.typed-rows)
      (let [[branch-rel branch-ok] (db-read-source-query-relation-primary-branch source rules rel row group registry stats)]
        (when (not branch-ok)
          (delete-query-relation branch-rel)
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (let [matched (> (query-relation-row-count branch-rel) 0)]
          (delete-query-relation branch-rel)
          (when (not matched)
            (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false)))))
      (set! row (+ row 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: builder.typed-ok}) true)))

(defn db-read-source-query-relation-apply-primary-or-group [source: DB-Read-Source, rules: []Rule, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-primary-typed-or-group? rules group registry)))
    (return (query-relation-empty) false))
  (let [[set-or set-or-ok] (db-read-source-query-relation-apply-set-or-group source ([]DB-Read-Named-Source []) rules rel group registry stats)]
    (when set-or-ok
      (return set-or true))
    (delete-query-relation set-or))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-or-group-output-vars! (addr output-vars) group)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (for [branch group.branches]
          (let [[branch-rel branch-ok] (db-read-source-query-relation-primary-branch source rules rel row branch registry stats)]
            (when (not branch-ok)
              (delete-query-relation branch-rel)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (let [branch-row 0]
              (while (< branch-row (query-relation-row-count branch-rel))
                (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) branch-rel branch-row))
                  (delete-query-relation branch-rel)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (set! branch-row (+ branch-row 1))))
            (delete-query-relation branch-rel)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-initial-from-inputs [source: DB-Read-Source, query-value: Query, inputs: []Query-Input] -> [rel: Query-Relation, binding-count: int, ok: bool]
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        columns (make [dynamic]Relation-Column)
        row-count 1
        input-index 0
        specs (db-read-source-query-input-specs query-value) :defer]
    (for [spec specs]
      (cond
        (= spec.kind .Ignore)
          (set! input-index (+ input-index 1))
        (and (= spec.kind .Scalar)
             (query-source-input-name? spec.name))
          (when (not (= spec.name "$"))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Scalar)
          (do
            (when (>= input-index (count inputs))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false))
            (let [[value value-ok _] (db-read-source-query-input-bound-value source spec.name inputs[input-index])]
              (when (or (not value-ok)
                        (not (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.name ([]Value [value]))))
                (delete attrs)
                (delete attr-sources)
                (delete-relation-columns columns)
                (return (query-relation-empty) 0 false)))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Collection)
          (do
            (when (or (>= input-index (count inputs))
                      (not (cond
                             (= inputs[input-index].kind .Collection)
                               (query-relation-append-initial-input-values! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.name inputs[input-index].values)
                             (= inputs[input-index].kind .CollectionLookupRefs)
                               (query-relation-append-initial-lookup-ref-input-values! source (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.name inputs[input-index])
                             :else false)))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Tuple)
          (do
            (when (or (>= input-index (count inputs))
                      (not (= inputs[input-index].kind .Collection))
                      (not (= (count spec.tuple.vars) (count inputs[input-index].values)))
                      (not (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.tuple.vars inputs[input-index].values (count spec.tuple.vars))))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false))
            (set! input-index (+ input-index 1)))
        (= spec.kind .Relation)
          (do
            (when (>= input-index (count inputs))
              (delete attrs)
              (delete attr-sources)
              (delete-relation-columns columns)
              (return (query-relation-empty) 0 false))
            (let [input inputs[input-index]
                  append-ok (cond
                              (and (= input.kind .Relation)
                                   (= input.width (count spec.relation.vars)))
                                (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.relation.vars input.values input.width)
                              (and (= input.kind .Scalar)
                                   (= input.value.kind .Map)
                                   (= (count spec.relation.vars) 2))
                                (query-relation-append-initial-input-rows! (addr attrs) (addr attr-sources) (addr columns) (addr row-count) spec.relation.vars input.value.items 2)
                              :else false)]
              (when (not append-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-relation-columns columns)
                (return (query-relation-empty) 0 false)))
            (set! input-index (+ input-index 1)))
        :else
          (do
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns columns)
            (return (query-relation-empty) 0 false))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: row-count
                             has-typed-columns: true}) row-count true)))

(defn db-read-source-query-relation-apply-relation-value-source-clause-with-op [source-value: ^Value, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [source-clause (clause-with-relation-source-width
                        (if clause-value.has-source
                          (unsourced-clause clause-value)
                          clause-value))
        [indexed indexed-ok] (query-relation-apply-source-input-clause-indexed-typed-with-op source-value^ rel source-clause op)]
      (when indexed-ok
        (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
        (query-stats-observe-source-operator! stats)
        (set! stats^.clauses (+ stats^.clauses 1))
        (set! stats^.clause-candidates (+ stats^.clause-candidates (count source-value^.items)))
        (return indexed true))
      (delete-query-relation indexed)
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.e "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.a "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) source-clause.op-term "")
        (let [[positions positions-ok] (typed-relation-source-output-positions (slice attrs 0) rel source-clause)]
          (when (not positions-ok)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false))
        (let [[filtered-indexes filtered-ok] (source-input-filtered-row-indexes-if-useful source-value^ source-clause op)]
          (when filtered-ok
            (let [builder (query-relation-builder (slice attrs 0))
                  rel-row 0]
              (while (< rel-row rel.typed-rows)
                (for [source-index filtered-indexes]
                  (let [source-row source-value^.items[source-index]]
                    (when (and (typed-relation-source-row-matches? source-clause source-row rel rel-row)
                               (typed-relation-source-row-pushdown-matches? rel rel-row source-clause source-row op))
                      (when (not (append-typed-relation-source-row! (addr builder) rel rel-row (slice positions 0) source-clause source-row))
                        (delete attrs)
                        (delete attr-sources)
                        (delete positions)
                        (delete filtered-indexes)
                        (delete-query-relation-builder builder)
                        (return (query-relation-empty) false)))))
                (set! rel-row (+ rel-row 1)))
              (delete positions)
              (delete filtered-indexes)
              (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
              (query-stats-observe-source-operator! stats)
              (set! stats^.clauses (+ stats^.clauses 1))
              (set! stats^.clause-candidates (+ stats^.clause-candidates (count source-value^.items)))
              (return (Query-Relation {attrs: attrs
                                       attr-sources: attr-sources
                                       attr-index: (query-relation-attr-index (slice attrs 0))
                                       tuples: builder.tuples
                                       typed-columns: builder.typed-columns
                                       typed-rows: builder.typed-rows
                                       has-typed-columns: builder.typed-ok}) true)))
          (delete filtered-indexes))
        (let [builder (query-relation-builder (slice attrs 0))
              rel-row 0]
          (while (< rel-row rel.typed-rows)
            (for [source-row source-value^.items]
              (when (and (typed-relation-source-row-matches? source-clause source-row rel rel-row)
                         (typed-relation-source-row-pushdown-matches? rel rel-row source-clause source-row op))
                (when (not (append-typed-relation-source-row! (addr builder) rel rel-row (slice positions 0) source-clause source-row))
                  (delete attrs)
                  (delete attr-sources)
                  (delete positions)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))
            (set! rel-row (+ rel-row 1)))
          (delete positions)
          (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
          (query-stats-observe-source-operator! stats)
          (set! stats^.clauses (+ stats^.clauses 1))
          (set! stats^.clause-candidates (+ stats^.clause-candidates (* rel.typed-rows (count source-value^.items))))
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true))))))

(defn db-read-source-query-relation-apply-relation-value-clause-with-op [sources: []DB-Read-Named-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[source-value source-ok] (db-read-source-relation-value-source-for-clause sources clause-value)]
    (when (not source-ok)
      (return (query-relation-empty) false))
    (db-read-source-query-relation-apply-relation-value-source-clause-with-op source-value rel clause-value op stats)))

(defn db-read-source-query-relation-apply-relation-value-clause [sources: []DB-Read-Named-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (db-read-source-query-relation-apply-relation-value-clause-with-op sources rel clause-value (Physical-Op {}) stats))

(defn db-read-source-query-relation-apply-primary-relation-value-clause-with-op [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (= source.kind .Relation-Value))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-relation-value-source-clause-with-op source.relation-value rel clause-value op stats))

(defn db-read-source-query-relation-apply-primary-relation-value-clause [source: DB-Read-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (db-read-source-query-relation-apply-primary-relation-value-clause-with-op source rel clause-value (Physical-Op {}) stats))

(defn db-read-source-query-relation-apply-mixed-source-clause-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[_ relation-source-ok] (db-read-source-relation-value-source-for-clause sources clause-value)]
    (cond
      relation-source-ok
        (db-read-source-query-relation-apply-relation-value-clause sources rel clause-value stats)
      (and (= source.kind .Relation-Value)
           (db-read-source-primary-source? clause-value.has-source clause-value.source))
        (db-read-source-query-relation-apply-primary-relation-value-clause source rel clause-value stats)
      (db-read-source-primary-source? clause-value.has-source clause-value.source)
        (db-read-source-query-relation-apply-primary-clause-typed source rel clause-value stats)
      (query-source-input-name? clause-value.source)
        (let [[clause-source source-clause source-ok _] (db-read-source-query-clause-source source sources clause-value)]
          (if source-ok
            (db-read-source-query-relation-apply-primary-clause-typed clause-source rel source-clause stats)
            (return (query-relation-empty) false)))
      :else
        (return (query-relation-empty) false))))

(defn db-read-source-query-relation-apply-mixed-source-clause-typed-with-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [[_ relation-source-ok] (db-read-source-relation-value-source-for-clause sources clause-value)]
    (cond
      relation-source-ok
        (db-read-source-query-relation-apply-relation-value-clause-with-op sources rel clause-value op stats)
      (and (= source.kind .Relation-Value)
           (db-read-source-primary-source? clause-value.has-source clause-value.source))
        (db-read-source-query-relation-apply-primary-relation-value-clause-with-op source rel clause-value op stats)
      (db-read-source-primary-source? clause-value.has-source clause-value.source)
        (db-read-source-query-relation-apply-primary-clause-typed-with-op source rel clause-value op stats)
      (query-source-input-name? clause-value.source)
        (let [[clause-source source-clause source-ok _] (db-read-source-query-clause-source source sources clause-value)]
          (if source-ok
            (db-read-source-query-relation-apply-primary-clause-typed-with-op clause-source rel source-clause op stats)
            (return (query-relation-empty) false)))
      :else
        (return (query-relation-empty) false))))

(defn db-read-source-query-relation-apply-typed-step [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, step: Query-Step, clauses: []Clause, predicates: []Predicate, functions: []Function-Clause, grounds: []Ground, get-elses: []Get-Else, get-somes: []Get-Some, not-groups: []Not-Group, or-groups: []Or-Group, rules: []Rule, rule-calls: []Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (cond
    (= step.kind .Clause)
      (db-read-source-query-relation-apply-mixed-source-clause-typed source sources rel clauses[step.index] stats)
    (= step.kind .Predicate)
      (do
        (when (not (query-relation-predicate-can-run-typed? rel predicates[step.index] registry))
          (return (query-relation-empty) false))
        (let [out (query-relation-filter-predicate (DB {}) rel predicates[step.index] registry)]
          (return out out.has-typed-columns)))
    (= step.kind .Function)
      (let [function functions[step.index]]
        (if (= function.op "fulltext")
          (db-read-source-query-relation-extend-fulltext-typed source sources rel function)
          (db-read-source-query-relation-extend-function-typed source rel function registry)))
    (= step.kind .Ground)
      (query-relation-apply-ground-typed rel grounds[step.index])
    (= step.kind .GetElse)
      (db-read-source-query-relation-apply-mixed-source-get-else-typed source sources rel get-elses[step.index] stats)
    (= step.kind .GetSome)
      (db-read-source-query-relation-apply-mixed-source-get-some-typed source sources rel get-somes[step.index] stats)
    (= step.kind .RuleCall)
      (db-read-source-query-relation-apply-rule-call-typed-depth source sources rules rel rule-calls[step.index] registry stats 20)
    (= step.kind .Not)
      (db-read-source-query-relation-apply-simple-not-group source sources rules rel not-groups[step.index] registry stats)
    (= step.kind .Or)
      (db-read-source-query-relation-apply-simple-or-group source sources rules rel or-groups[step.index] registry stats)
    :else
      (return (query-relation-empty) false)))

(defn db-read-source-query-relation-apply-physical-scan-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (db-read-source-query-relation-apply-mixed-source-clause-typed-with-op source sources rel query-value.clauses[op.item-index] op stats))

(defn db-read-source-query-relation-apply-physical-predicate-op [rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [predicate query-value.predicates[op.item-index]]
    (when (not (query-relation-has-physical-op-inputs? rel op))
      (return (query-relation-empty) false))
    (when (not (query-relation-predicate-can-run-typed? rel predicate registry))
      (return (query-relation-empty) false))
    (let [filtered (query-relation-filter-predicate (DB {}) rel predicate registry)]
      (return filtered filtered.has-typed-columns))))

(defn db-read-source-query-relation-apply-physical-function-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (let [function query-value.function-clauses[op.item-index]]
    (if (= function.op "fulltext")
      (db-read-source-query-relation-extend-fulltext-typed source sources rel function)
      (db-read-source-query-relation-extend-function-typed source rel function registry))))

(defn db-read-source-query-relation-apply-physical-ground-op [rel: Query-Relation, op: Physical-Op, query-value: Query] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (query-relation-apply-ground-typed rel query-value.grounds[op.item-index]))

(defn db-read-source-query-relation-apply-physical-get-else-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-mixed-source-get-else-typed source sources rel query-value.get-elses[op.item-index] stats))

(defn db-read-source-query-relation-apply-physical-get-some-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-mixed-source-get-some-typed source sources rel query-value.get-somes[op.item-index] stats))

(defn db-read-source-query-relation-apply-physical-rule-call-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-rule-call-typed-depth source sources (slice query-value.rules 0) rel query-value.rule-calls[op.item-index] registry stats 20))

(defn db-read-source-query-relation-apply-physical-not-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-simple-not-group source sources (slice query-value.rules 0) rel query-value.not-groups[op.item-index] registry stats))

(defn db-read-source-query-relation-apply-physical-or-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-simple-or-group source sources (slice query-value.rules 0) rel query-value.or-groups[op.item-index] registry stats))

(defn db-read-source-query-relation-apply-primary-physical-not-op [source: DB-Read-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-primary-not-group source (slice query-value.rules 0) rel query-value.not-groups[op.item-index] registry stats))

(defn db-read-source-query-relation-apply-primary-physical-or-op [source: DB-Read-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty) false))
  (db-read-source-query-relation-apply-primary-or-group source (slice query-value.rules 0) rel query-value.or-groups[op.item-index] registry stats))

(defn db-read-source-query-relation-apply-physical-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (case op.kind
    .PrimaryScan
      (db-read-source-query-relation-apply-physical-scan-op source sources rel op query-value stats)
    .NamedSourceScan
      (db-read-source-query-relation-apply-physical-scan-op source sources rel op query-value stats)
    .RelationInput
      (db-read-source-query-relation-apply-physical-scan-op source sources rel op query-value stats)
    .BindJoinScan
      (db-read-source-query-relation-apply-physical-scan-op source sources rel op query-value stats)
    .StarJoin
      (db-read-source-query-relation-apply-primary-physical-star-join-op source rel op query-value stats)
    .Predicate
      (db-read-source-query-relation-apply-physical-predicate-op rel op query-value registry)
    .Function
      (db-read-source-query-relation-apply-physical-function-op source sources rel op query-value registry)
    .Ground
      (db-read-source-query-relation-apply-physical-ground-op rel op query-value)
    .GetElse
      (db-read-source-query-relation-apply-physical-get-else-op source sources rel op query-value stats)
    .GetSome
      (db-read-source-query-relation-apply-physical-get-some-op source sources rel op query-value stats)
    .RuleCall
      (db-read-source-query-relation-apply-physical-rule-call-op source sources rel op query-value registry stats)
    .Not
      (db-read-source-query-relation-apply-physical-not-op source sources rel op query-value registry stats)
    .Or
      (db-read-source-query-relation-apply-physical-or-op source sources rel op query-value registry stats)

      (return (query-relation-empty) false)))

(defn db-read-source-query-relation-apply-primary-physical-scan-op [source: DB-Read-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (db-read-source-query-relation-apply-primary-clause-typed-with-op source rel query-value.clauses[op.item-index] op stats))

(defn db-read-source-query-relation-apply-primary-physical-star-join-op [source: DB-Read-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (or (not (= op.kind .StarJoin))
            (not rel.has-typed-columns)
            (not (= (query-relation-row-count rel) 1)))
    (return (query-relation-empty) false))
  (when (= source.kind .Relation-Value)
    (return (db-read-source-query-relation-apply-primary-relation-value-clause-with-op source rel query-value.clauses[op.item-index] op stats)))
  (let [[star-rel star-ok star-error] (db-read-source-query-relation-star-cardinality-one-merge source query-value stats)]
    (when (not (= star-error ""))
      (delete-query-relation star-rel)
      (return (query-relation-empty) false))
    (when star-ok
      (return star-rel true))
    (delete-query-relation star-rel))
  (let [[star-product-rel star-product-ok star-product-error] (db-read-source-query-relation-star-attr-entity-projection source query-value stats)]
    (when (not (= star-product-error ""))
      (delete-query-relation star-product-rel)
      (return (query-relation-empty) false))
    (if star-product-ok
      (return star-product-rel true)
      (do
        (delete-query-relation star-product-rel)
        (return (query-relation-empty) false)))))

(defn db-read-source-query-relation-apply-primary-physical-op [source: DB-Read-Source, rel: Query-Relation, op: Physical-Op, query-value: Query, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (case op.kind
    .PrimaryScan
      (db-read-source-query-relation-apply-primary-physical-scan-op source rel op query-value stats)
    .BindJoinScan
      (db-read-source-query-relation-apply-primary-physical-scan-op source rel op query-value stats)
    .StarJoin
      (db-read-source-query-relation-apply-primary-physical-star-join-op source rel op query-value stats)
    .Predicate
      (db-read-source-query-relation-apply-physical-predicate-op rel op query-value registry)
    .Function
      (db-read-source-query-relation-apply-physical-function-op source ([]DB-Read-Named-Source []) rel op query-value registry)
    .Ground
      (db-read-source-query-relation-apply-physical-ground-op rel op query-value)
    .GetElse
      (db-read-source-query-relation-apply-physical-get-else-op source ([]DB-Read-Named-Source []) rel op query-value stats)
    .GetSome
      (db-read-source-query-relation-apply-physical-get-some-op source ([]DB-Read-Named-Source []) rel op query-value stats)
    .RuleCall
      (db-read-source-query-relation-apply-physical-rule-call-op source ([]DB-Read-Named-Source []) rel op query-value registry stats)
    .Not
      (db-read-source-query-relation-apply-primary-physical-not-op source rel op query-value registry stats)
    .Or
      (db-read-source-query-relation-apply-primary-physical-or-op source rel op query-value registry stats)

      (return (query-relation-empty) false)))

(defn physical-ops-same-bound-entity-value-pair? [first: Physical-Op, second: Physical-Op] -> bool
  (and (db-read-source-bind-join-op? first)
       (db-read-source-bind-join-op? second)
       (not first.has-pushdown-scalar)
       (not second.has-pushdown-scalar)))

(defn db-read-source-query-relation-apply-primary-physical-op-pair [source: DB-Read-Source, rel: Query-Relation, first: Physical-Op, second: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, used: bool]
  (when (not (physical-ops-same-bound-entity-value-pair? first second))
    (return (query-relation-empty) false false))
  (let [[pair-out pair-ok pair-used _error] (db-read-source-query-relation-apply-same-bound-entity-value-pair source rel query-value.clauses[first.item-index] query-value.clauses[second.item-index] stats)]
    (return pair-out pair-ok pair-used)))

(defn db-read-source-reference-link-projection-supported? [source: DB-Read-Source, rel: Query-Relation, rule-op: Physical-Op, first-op: Physical-Op, second-op: Physical-Op, query-value: Query] -> bool
  (when (or (not rel.has-typed-columns)
            (db-read-source-has-overlay? source)
            (not (= rule-op.kind .RuleCall))
            (not (physical-ops-same-bound-entity-value-pair? first-op second-op)))
    (return false))
  (let [call query-value.rule-calls[rule-op.item-index]
        first query-value.clauses[first-op.item-index]
        second query-value.clauses[second-op.item-index]
        first-clause (if first.has-source (unsourced-clause first) first)
        second-clause (if second.has-source (unsourced-clause second) second)]
    (when (not (and (not call.has-source)
                    (= (count call.args) 2)
                    (= call.args[0].kind .Var)
                    (= call.args[1].kind .Var)
                    (query-relation-has-attr? rel call.args[0].name)
                    (not (query-relation-has-attr? rel call.args[1].name))
                    (db-read-source-primary-source? first.has-source first.source)
                    (db-read-source-primary-source? second.has-source second.source)
                    (= first-clause.e.kind .Var)
                    (= second-clause.e.kind .Var)
                    (= first-clause.e.name call.args[1].name)
                    (= second-clause.e.name call.args[1].name)
                    (= first-clause.a.kind .Value)
                    (= first-clause.a.value.kind .Keyword)
                    (= second-clause.a.kind .Value)
                    (= second-clause.a.value.kind .Keyword)
                    (not (reverse-attr? first-clause.a.value.text))
                    (not (reverse-attr? second-clause.a.value.text))
                    (= first-clause.v.kind .Var)
                    (= second-clause.v.kind .Var)
                    (not (= first-clause.v.name second-clause.v.name))
                    (not (= first-clause.v.name call.args[1].name))
                    (not (= second-clause.v.name call.args[1].name))
                    (not (query-relation-has-attr? rel first-clause.v.name))
                    (not (query-relation-has-attr? rel second-clause.v.name))
                    (unconstrained-clause-history-term? first-clause.tx-term)
                    (unconstrained-clause-history-term? first-clause.op-term)
                    (unconstrained-clause-history-term? second-clause.tx-term)
                    (unconstrained-clause-history-term? second-clause.op-term)))
      (return false))
    (let [[_ _ _ shape-ok] (rule-two-hop-reverse-derived-edge (slice query-value.rules 0) call.name)]
      shape-ok)))

(defn db-read-source-query-relation-apply-reference-link-projection [source: DB-Read-Source, rel: Query-Relation, rule-op: Physical-Op, first-op: Physical-Op, second-op: Physical-Op, query-value: Query, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool, used: bool]
  (when (not (db-read-source-reference-link-projection-supported? source rel rule-op first-op second-op query-value))
    (return (query-relation-empty) false false))
  (let [call query-value.rule-calls[rule-op.item-index]
        first-value query-value.clauses[first-op.item-index]
        second-value query-value.clauses[second-op.item-index]
        first (if first-value.has-source (unsourced-clause first-value) first-value)
        second (if second-value.has-source (unsourced-clause second-value) second-value)
        [_ left-attr right-attr _] (rule-two-hop-reverse-derived-edge (slice query-value.rules 0) call.name)
        attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (arr.push! attrs call.args[1].name)
    (arr.push! attr-sources "")
    (arr.push! attrs first.v.name)
    (arr.push! attr-sources "")
    (arr.push! attrs second.v.name)
    (arr.push! attr-sources "")
    (let [builder (query-relation-builder-with-capacity (slice attrs 0) rel.typed-rows)
          left-heads (make (map u64 int)) :defer
          left-links (make [dynamic]Reverse-Derived-Row-Link) :defer
          left-seen (set.empty u64) :defer
          left-entities (make [dynamic]u64) :defer
          row 0]
      (while (< row rel.typed-rows)
        (let [[left-value left-ok] (query-relation-typed-row-value rel row call.args[0].name)]
          (when left-ok
            (let [[left-entity entity-ok] (value-as-db-entity left-value)]
              (when entity-ok
                (append-reverse-derived-row-link! (addr left-heads) (addr left-links) left-entity row)
                (when (not (set.contains? left-seen left-entity))
                  (set.add! left-seen left-entity)
                  (arr.push! left-entities left-entity))))))
        (mut! row += 1))
      (let [middle-heads (make (map u64 int)) :defer
            middle-links (make [dynamic]Reverse-Derived-Row-Link) :defer
            middle-seen (set.empty u64) :defer
            middle-entities (make [dynamic]u64) :defer
            [middle-stream middle-ok middle-used middle-candidates _middle-error] (source-vaet-entity-attr-frontier-stream source (slice left-entities 0) left-attr)]
        (when (not middle-ok)
          (delete-query-relation-builder builder)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false true))
        (when (not middle-used)
          (delete-source-index-datom-stream middle-stream)
          (delete-query-relation-builder builder)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false false))
        (while middle-stream.has-current
          (when (= middle-stream.current.v.kind .Entity)
            (let [left-entity middle-stream.current.v.entity
                  middle-entity middle-stream.current.e
                  [left-head left-found] (mmap.get left-heads left-entity)]
              (when left-found
                (when (not (set.contains? middle-seen middle-entity))
                  (set.add! middle-seen middle-entity)
                  (arr.push! middle-entities middle-entity))
                (let [left-index left-head]
                  (while (>= left-index 0)
                    (append-reverse-derived-row-link! (addr middle-heads) (addr middle-links) middle-entity left-links[left-index].row)
                    (set! left-index left-links[left-index].next))))))
          (let [[advance-ok _advance-error] (advance-source-index-datom-stream! source (addr middle-stream))]
            (when (not advance-ok)
              (delete-source-index-datom-stream middle-stream)
              (delete-query-relation-builder builder)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false true))))
        (delete-source-index-datom-stream middle-stream)
        (let [right-heads (make (map u64 int)) :defer
              right-links (make [dynamic]Reverse-Derived-Row-Link) :defer
              right-seen (set.empty u64) :defer
              right-entities (make [dynamic]u64) :defer
              [right-stream right-ok right-used right-candidates _right-error] (source-vaet-entity-attr-frontier-stream source (slice middle-entities 0) right-attr)]
          (when (not right-ok)
            (delete-query-relation-builder builder)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false true))
          (when (not right-used)
            (delete-source-index-datom-stream right-stream)
            (delete-query-relation-builder builder)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false false))
          (while right-stream.has-current
            (when (= right-stream.current.v.kind .Entity)
              (let [middle-entity right-stream.current.v.entity
                    right-entity right-stream.current.e
                    [middle-head middle-found] (mmap.get middle-heads middle-entity)]
                (when middle-found
                  (when (not (set.contains? right-seen right-entity))
                    (set.add! right-seen right-entity)
                    (arr.push! right-entities right-entity))
                  (let [middle-index middle-head]
                    (while (>= middle-index 0)
                      (append-reverse-derived-row-link! (addr right-heads) (addr right-links) right-entity middle-links[middle-index].row)
                      (set! middle-index middle-links[middle-index].next))))))
            (let [[advance-ok _advance-error] (advance-source-index-datom-stream! source (addr right-stream))]
              (when (not advance-ok)
                (delete-source-index-datom-stream right-stream)
                (delete-query-relation-builder builder)
                (delete attrs)
                (delete attr-sources)
                (return (query-relation-empty) false true))))
          (delete-source-index-datom-stream right-stream)
          (let [first-heads (make (map u64 int)) :defer
                second-heads (make (map u64 int)) :defer
                first-links (make [dynamic]Source-Entity-Attr-Value-Link)
                second-links (make [dynamic]Source-Entity-Attr-Value-Link)
                projection-attrs ([]string [first.a.value.text second.a.value.text])
                [datoms datoms-ok datoms-used scan-count projection-candidates _datoms-error] (source-eavt-entity-attrs-datoms source (slice right-entities 0) projection-attrs)]
            (defer (delete-source-entity-attr-value-links first-links))
            (defer (delete-source-entity-attr-value-links second-links))
            (defer (delete-owned-datoms datoms))
            (when (not datoms-ok)
              (delete-query-relation-builder builder)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false true))
            (when (not datoms-used)
              (delete-query-relation-builder builder)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false false))
            (for [datom datoms]
              (when (= datom.a first.a.value.text)
                (append-source-entity-attr-value-link! (addr first-heads) (addr first-links) datom.e datom.v))
              (when (= datom.a second.a.value.text)
                (append-source-entity-attr-value-link! (addr second-heads) (addr second-links) datom.e datom.v)))
            (for [right-entity right-entities]
              (let [[row-head row-found] (mmap.get right-heads right-entity)
                    [first-head first-found] (mmap.get first-heads right-entity)
                    [second-head second-found] (mmap.get second-heads right-entity)]
                (when (and row-found first-found second-found)
                  (let [row-index row-head]
                    (while (>= row-index 0)
                      (let [first-index first-head]
                        (while (>= first-index 0)
                          (let [second-index second-head]
                            (while (>= second-index 0)
                              (let [values ([]Value [(value-entity right-entity)
                                                     first-links[first-index].value
                                                     second-links[second-index].value])]
                                (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) right-links[row-index].row values))
                                  (delete-query-relation-builder builder)
                                  (delete attrs)
                                  (delete attr-sources)
                                  (return (query-relation-empty) false true)))
                              (set! second-index second-links[second-index].next)))
                          (set! first-index first-links[first-index].next)))
                      (set! row-index right-links[row-index].next))))))
            (mut! stats^.clauses += 4)
            (mut! stats^.source-index-scans += (+ 2 scan-count))
            (when (>= middle-candidates 0)
              (mut! stats^.clause-candidates += middle-candidates))
            (when (>= right-candidates 0)
              (mut! stats^.clause-candidates += right-candidates))
            (when (>= projection-candidates 0)
              (mut! stats^.clause-candidates += projection-candidates))
            (mut! stats^.rule-calls += 1)
            (mut! stats^.rule-iterations += 1)
            (query-stats-observe-source-operator! stats)
            (let [raw (Query-Relation {attrs: attrs
                                       attr-sources: attr-sources
                                       attr-index: (query-relation-attr-index (slice attrs 0))
                                       tuples: builder.tuples
                                       typed-columns: builder.typed-columns
                                       typed-rows: builder.typed-rows
                                       has-typed-columns: builder.typed-ok})
                  deduped (query-relation-dedupe-step raw)]
              (delete-query-relation raw)
              (return deduped deduped.has-typed-columns true))))))))

(defn query-relation-not-group-anti-join-vars [rel: Query-Relation, group: Not-Group] -> [vars: [dynamic]string, ok: bool]
  (let [out (make [dynamic]string)]
    (if group.has-join
      (do
        (for [name group.join-vars]
          (when (not (query-relation-has-attr? rel name))
            (delete out)
            (return (make [dynamic]string) false))
          (arr.push! out name))
        (return out (> (count out) 0)))
      (let [referenced (make [dynamic]string) :defer
            seen (set.empty string) :defer]
        (append-not-group-vars-indexed! (addr referenced) (addr seen) group)
        (for [name referenced]
          (when (not (query-relation-has-attr? rel name))
            (delete out)
            (return (make [dynamic]string) false))
          (arr.push! out name))
        (return out (> (count out) 0))))))

(defn db-read-source-query-relation-apply-set-anti-join-not-group [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, group: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-relation-value-typed-not-group? sources rules group registry)))
    (return (query-relation-empty) false))
  (let [[join-vars join-vars-ok] (query-relation-not-group-anti-join-vars rel group)]
    (defer (delete join-vars))
    (when (not join-vars-ok)
      (return (query-relation-empty) false))
    (let [branch-vars (make [dynamic]string) :defer
          branch-seen (set.empty string) :defer]
      (append-not-group-vars-indexed! (addr branch-vars) (addr branch-seen) group)
      (let [branch-query (query (slice branch-vars 0)
                                ([]string [])
                                ([]string [])
                                ([]string [])
                                ([]Tuple-Input [])
                                ([]Relation-Input [])
                                (slice group.clauses 0)
                                (slice group.predicates 0)
                                (slice group.function-clauses 0)
                                rules
                                (slice group.rule-calls 0)
                                (slice group.get-elses 0)
                                (slice group.get-somes 0)
                                (slice group.grounds 0)
                                (slice group.not-groups 0)
                                ([]Or-Group [])
                                ([]Pull-Find [])
                                ([]Aggregate-Find []))]
        (defer (delete-query-shallow branch-query))
        (let [[branch-rel branch-stats branch-used] (db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source sources branch-query ([]Query-Input []) registry)]
          (when (not branch-used)
            (delete-query-relation branch-rel)
            (return (query-relation-empty) false))
          (set! stats^.steps (+ stats^.steps branch-stats.steps))
          (set! stats^.source-operators (+ stats^.source-operators branch-stats.source-operators))
          (query-stats-observe-bindings! stats branch-stats.max-intermediate-bindings)
          (when (= (query-relation-row-count branch-rel) 0)
            (let [out (query-relation-empty-typed-like rel)]
              (when (not (query-relation-append-typed-rows! (addr out) rel))
                (delete-query-relation out)
                (delete-query-relation branch-rel)
                (return (query-relation-empty) false))
              (delete-query-relation branch-rel)
              (return out true)))
          (let [[projected projected-ok] (query-relation-project-typed branch-rel (slice join-vars 0))]
            (delete-query-relation branch-rel)
      (when (not projected-ok)
        (delete-query-relation projected)
        (return (query-relation-empty) false))
      (let [excluded (set.empty string) :defer
            projected-row 0]
        (while (< projected-row projected.typed-rows)
          (let [[key key-ok] (query-relation-row-join-key projected projected-row (slice join-vars 0))]
            (when key-ok
              (set.add! excluded key)))
          (set! projected-row (+ projected-row 1)))
        (delete-query-relation projected)
        (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
              attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
              builder (query-relation-builder (slice rel.attrs 0))
              row 0]
          (while (< row rel.typed-rows)
            (let [[key key-ok] (query-relation-row-join-key rel row (slice join-vars 0))]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (when (not (set.contains? excluded key))
                (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))
            (set! row (+ row 1)))
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true)))))))))

(defn db-read-source-query-relation-apply-simple-not-group [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, group: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-relation-value-typed-not-group? sources rules group registry)))
    (return (query-relation-empty) false))
  (let [[anti anti-ok] (db-read-source-query-relation-apply-set-anti-join-not-group source sources rules rel group registry stats)]
    (when anti-ok
      (return anti true))
    (delete-query-relation anti))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))
        row 0]
    (while (< row rel.typed-rows)
      (let [current (query-relation-empty)
            current-ok false]
        (if group.has-join
          (let [[projected projected-ok] (query-relation-single-typed-row-projected rel row (slice group.join-vars 0))]
            (set! current projected)
            (set! current-ok projected-ok))
          (let [[single single-ok] (query-relation-single-typed-row rel row)]
            (set! current single)
            (set! current-ok single-ok)))
        (when (not current-ok)
          (delete-query-relation current)
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (for [step group.steps]
          (let [[next next-ok] (db-read-source-query-relation-apply-typed-step source sources current step (slice group.clauses 0) (slice group.predicates 0) (slice group.function-clauses 0) (slice group.grounds 0) (slice group.get-elses 0) (slice group.get-somes 0) (slice group.not-groups 0) ([]Or-Group []) rules (slice group.rule-calls 0) registry stats)]
            (delete-query-relation current)
            (when (not next-ok)
              (delete-query-relation next)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (set! current next)))
        (let [matched (> (query-relation-row-count current) 0)]
          (delete-query-relation current)
          (when (not matched)
            (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false)))))
      (set! row (+ row 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: builder.typed-ok}) true)))

(defn db-read-source-query-relation-apply-or-branch [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, row: int, group: Or-Group, branch: Not-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (let [current (query-relation-empty)
        current-ok false]
    (if group.has-join
      (let [[projected projected-ok] (query-relation-single-typed-row-projected rel row (slice group.join-vars 0))]
        (set! current projected)
        (set! current-ok projected-ok))
      (let [[single single-ok] (query-relation-single-typed-row rel row)]
        (set! current single)
        (set! current-ok single-ok)))
    (when (not current-ok)
      (delete-query-relation current)
      (return (query-relation-empty) false))
    (for [step branch.steps]
      (let [[next next-ok] (db-read-source-query-relation-apply-typed-step source sources current step (slice branch.clauses 0) (slice branch.predicates 0) (slice branch.function-clauses 0) (slice branch.grounds 0) (slice branch.get-elses 0) (slice branch.get-somes 0) (slice branch.not-groups 0) ([]Or-Group []) rules (slice branch.rule-calls 0) registry stats)]
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next)
          (return (query-relation-empty) false))
        (set! current next)))
    (return current true)))

(defn query-relation-or-branch-common-vars [rel: Query-Relation, group: Or-Group, branch-rel: Query-Relation] -> [vars: [dynamic]string, ok: bool]
  (let [out (make [dynamic]string)]
    (if group.has-join
      (do
        (for [name group.join-vars]
          (when (not (and (query-relation-has-attr? rel name)
                          (query-relation-has-attr? branch-rel name)))
            (delete out)
            (return (make [dynamic]string) false))
          (arr.push! out name))
        (return out true))
      (do
        (for [name rel.attrs]
          (when (query-relation-has-attr? branch-rel name)
            (arr.push! out name)))
        (return out true)))))

(defn db-read-source-query-relation-apply-set-or-group [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-relation-value-typed-or-group? sources rules group registry)))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer
        output-seen (set.empty string) :defer]
    (append-or-group-output-vars-indexed! (addr output-vars) (addr output-seen) group)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          seen (set.empty string) :defer]
      (for [branch group.branches]
        (let [branch-vars (make [dynamic]string) :defer
              branch-seen (set.empty string) :defer]
          (append-not-group-vars-indexed! (addr branch-vars) (addr branch-seen) branch)
          (let [branch-query (query (slice branch-vars 0)
                                    ([]string [])
                                    ([]string [])
                                    ([]string [])
                                    ([]Tuple-Input [])
                                    ([]Relation-Input [])
                                    (slice branch.clauses 0)
                                    (slice branch.predicates 0)
                                    (slice branch.function-clauses 0)
                                    rules
                                    (slice branch.rule-calls 0)
                                    (slice branch.get-elses 0)
                                    (slice branch.get-somes 0)
                                    (slice branch.grounds 0)
                                    (slice branch.not-groups 0)
                                    ([]Or-Group [])
                                    ([]Pull-Find [])
                                    ([]Aggregate-Find []))]
            (defer (delete-query-shallow branch-query))
            (let [[branch-rel branch-stats branch-used] (db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source sources branch-query ([]Query-Input []) registry)]
              (when (not branch-used)
                (delete-query-relation branch-rel)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (set! stats^.steps (+ stats^.steps branch-stats.steps))
              (set! stats^.source-operators (+ stats^.source-operators branch-stats.source-operators))
              (query-stats-observe-bindings! stats branch-stats.max-intermediate-bindings)
              (let [[common common-ok] (query-relation-or-branch-common-vars rel group branch-rel)]
                (defer (delete common))
                (when (not common-ok)
                  (delete-query-relation branch-rel)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (let [[joined joined-ok] (query-relation-hash-join-typed-borrowed rel branch-rel (slice common 0))]
                  (delete-query-relation branch-rel)
                  (when (not joined-ok)
                    (delete-query-relation joined)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))
                  (let [row 0]
                    (while (< row joined.typed-rows)
                      (let [[key key-ok] (query-relation-row-join-key joined row (slice attrs 0))]
                        (when (not key-ok)
                          (delete-query-relation joined)
                          (delete attrs)
                          (delete attr-sources)
                          (delete-query-relation-builder builder)
                          (return (query-relation-empty) false))
                        (when (not (set.contains? seen key))
                          (set.add! seen key)
                          (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) joined row))
                            (delete-query-relation joined)
                            (delete attrs)
                            (delete attr-sources)
                            (delete-query-relation-builder builder)
                            (return (query-relation-empty) false))))
                      (set! row (+ row 1))))
                  (delete-query-relation joined)))))))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-apply-simple-or-group [source: DB-Read-Source, sources: []DB-Read-Named-Source, rules: []Rule, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (db-read-source-relation-value-typed-or-group? sources rules group registry)))
    (return (query-relation-empty) false))
  (let [[set-or set-or-ok] (db-read-source-query-relation-apply-set-or-group source sources rules rel group registry stats)]
    (when set-or-ok
      (return set-or true))
    (delete-query-relation set-or))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-or-group-output-vars! (addr output-vars) group)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (for [branch group.branches]
          (let [[branch-rel branch-ok] (db-read-source-query-relation-apply-or-branch source sources rules rel row group branch registry stats)]
            (when (not branch-ok)
              (delete-query-relation branch-rel)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (let [branch-row 0]
              (while (< branch-row (query-relation-row-count branch-rel))
                (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) branch-rel branch-row))
                  (delete-query-relation branch-rel)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))
                (set! branch-row (+ branch-row 1))))
            (delete-query-relation branch-rel)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-value-typed-with-sources-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> [rel: Query-Relation, stats: Query-Stats, used: bool]
  (let [[inlined inlined-ok] (query-source-inline-simple-rules query-value)]
    (when inlined-ok
      (let [[inlined-rel inlined-stats inlined-used] (db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source sources inlined inputs registry)]
        (delete-query-shallow inlined)
        (when inlined-used
          (return inlined-rel inlined-stats true))
        (delete-query-relation inlined-rel))))
  (let [out-stats (query-stats-empty)
        [plan plan-ok _] (physical-plan-from-query-for-source source sources query-value)]
    (defer (delete-physical-plan plan))
    (when (not plan-ok)
      (return (query-relation-empty) out-stats false))
    (when (and (= (count sources) 0)
               (= (count inputs) 0)
               (= (count registry) 0))
      (let [[two-rel two-ok two-error] (db-read-source-query-relation-two-attr-cardinality-one-merge source query-value (addr out-stats))]
        (when (not (= two-error ""))
          (delete-query-relation two-rel)
          (return (query-relation-empty) out-stats false))
        (when two-ok
          (set! out-stats.steps (physical-plan-step-count plan))
          (set! out-stats.max-intermediate-bindings (query-relation-row-count two-rel))
          (set! out-stats.output-rows (query-relation-row-count two-rel))
          (return two-rel out-stats true))
        (delete-query-relation two-rel))
      (let [[three-rel three-ok three-error] (db-read-source-query-relation-three-attr-cardinality-one-merge source query-value (addr out-stats))]
        (when (not (= three-error ""))
          (delete-query-relation three-rel)
          (return (query-relation-empty) out-stats false))
        (when three-ok
          (set! out-stats.steps (physical-plan-step-count plan))
          (set! out-stats.max-intermediate-bindings (query-relation-row-count three-rel))
          (set! out-stats.output-rows (query-relation-row-count three-rel))
          (return three-rel out-stats true))
        (delete-query-relation three-rel)))
    (when (and (= (count sources) 0)
               (= (count registry) 0))
      (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-projection query-value)]
        (when projection-ok
          (let [[ref-chain-rel ref-chain-ok ref-chain-error] (db-read-source-query-relation-multi-hop-ref-chain-projection-batched source query-value projection inputs (addr out-stats))]
            (when (not (= ref-chain-error ""))
              (delete-query-relation ref-chain-rel)
              (return (query-relation-empty) out-stats false))
            (when ref-chain-ok
              (set! out-stats.steps (physical-plan-step-count plan))
              (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count ref-chain-rel))
              (set! out-stats.output-rows (query-relation-row-count ref-chain-rel))
              (return ref-chain-rel out-stats true))
            (delete-query-relation ref-chain-rel))))
      (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-projection-any-order query-value)]
        (when projection-ok
          (let [[ref-chain-rel ref-chain-ok ref-chain-error] (db-read-source-query-relation-multi-hop-ref-chain-projection-batched source query-value projection inputs (addr out-stats))]
            (when (not (= ref-chain-error ""))
              (delete-query-relation ref-chain-rel)
              (return (query-relation-empty) out-stats false))
            (when ref-chain-ok
              (set! out-stats.steps (physical-plan-step-count plan))
              (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count ref-chain-rel))
              (set! out-stats.output-rows (query-relation-row-count ref-chain-rel))
              (return ref-chain-rel out-stats true))
            (delete-query-relation ref-chain-rel))))
      (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-two-final-values-projection-ordered query-value)]
        (when projection-ok
          (let [[ref-chain-rel ref-chain-ok ref-chain-error] (db-read-source-query-relation-multi-hop-ref-chain-two-final-values-batched source query-value projection inputs (addr out-stats))]
            (when (not (= ref-chain-error ""))
              (delete-query-relation ref-chain-rel)
              (return (query-relation-empty) out-stats false))
            (when ref-chain-ok
              (set! out-stats.steps (physical-plan-step-count plan))
              (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count ref-chain-rel))
              (set! out-stats.output-rows (query-relation-row-count ref-chain-rel))
              (return ref-chain-rel out-stats true))
            (delete-query-relation ref-chain-rel))))
      (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-final-filter-projection-ordered query-value)]
        (when projection-ok
          (let [[ref-chain-rel ref-chain-ok ref-chain-error] (db-read-source-query-relation-multi-hop-ref-chain-final-filter-batched source query-value projection inputs (addr out-stats))]
            (when (not (= ref-chain-error ""))
              (delete-query-relation ref-chain-rel)
              (return (query-relation-empty) out-stats false))
            (when ref-chain-ok
              (set! out-stats.steps (physical-plan-step-count plan))
              (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count ref-chain-rel))
              (set! out-stats.output-rows (query-relation-row-count ref-chain-rel))
              (return ref-chain-rel out-stats true))
            (delete-query-relation ref-chain-rel))))
      (let [[value-ref-attr-rel value-ref-attr-ok value-ref-attr-error] (db-read-source-query-relation-value-ref-attr-projection source query-value inputs (addr out-stats))]
        (when (not (= value-ref-attr-error ""))
          (delete-query-relation value-ref-attr-rel)
          (return (query-relation-empty) out-stats false))
        (when value-ref-attr-ok
          (set! out-stats.steps (physical-plan-step-count plan))
          (set! out-stats.max-intermediate-bindings (query-relation-row-count value-ref-attr-rel))
          (set! out-stats.output-rows (query-relation-row-count value-ref-attr-rel))
          (return value-ref-attr-rel out-stats true))
        (delete-query-relation value-ref-attr-rel))
      (let [[value-ref-star-rel value-ref-star-ok value-ref-star-error] (db-read-source-query-relation-value-ref-star-projection source query-value inputs (addr out-stats))]
        (when (not (= value-ref-star-error ""))
          (delete-query-relation value-ref-star-rel)
          (return (query-relation-empty) out-stats false))
        (when value-ref-star-ok
          (set! out-stats.steps (physical-plan-step-count plan))
          (set! out-stats.max-intermediate-bindings (query-relation-row-count value-ref-star-rel))
          (set! out-stats.output-rows (query-relation-row-count value-ref-star-rel))
          (return value-ref-star-rel out-stats true))
        (delete-query-relation value-ref-star-rel))
      (let [[ref-chain-rel ref-chain-ok ref-chain-error] (db-read-source-query-relation-ref-chain-string-length-aggregate source query-value (addr out-stats))]
        (when (not (= ref-chain-error ""))
          (delete-query-relation ref-chain-rel)
          (return (query-relation-empty) out-stats false))
        (when ref-chain-ok
          (set! out-stats.steps (physical-plan-step-count plan))
          (set! out-stats.output-rows (query-relation-row-count ref-chain-rel))
          (return ref-chain-rel out-stats true))
        (delete-query-relation ref-chain-rel)))
    (when (and (= (count sources) 0)
               (db-read-source-primary-typed-query? query-value registry))
      (let [[current input-binding-count input-ok] (db-read-source-query-relation-initial-from-inputs source query-value inputs)]
        (when (not input-ok)
          (delete-query-relation current)
          (return (query-relation-empty) out-stats false))
        (set! out-stats.input-bindings input-binding-count)
        (set! out-stats.steps (physical-plan-step-count plan))
        (let [op-index 0]
          (while (< op-index (count plan.ops))
            (let [op plan.ops[op-index]
                  next (query-relation-empty)
                  next-ok false
                  triple-used false
                  pair-used false]
              (when (< (+ op-index 2) (count plan.ops))
                (let [[triple-next triple-ok triple-used-value] (db-read-source-query-relation-apply-reference-link-projection source current op plan.ops[(+ op-index 1)] plan.ops[(+ op-index 2)] query-value (addr out-stats))]
                  (if triple-used-value
                    (do
                      (delete-query-relation next)
                      (set! next triple-next)
                      (set! next-ok triple-ok)
                      (set! triple-used true))
                    (delete-query-relation triple-next))))
              (when (and (not triple-used)
                         (< (+ op-index 1) (count plan.ops)))
                (let [[pair-next pair-ok pair-used-value] (db-read-source-query-relation-apply-primary-physical-op-pair source current op plan.ops[(+ op-index 1)] query-value (addr out-stats))]
                  (if pair-used-value
                    (do
                      (delete-query-relation next)
                      (set! next pair-next)
                      (set! next-ok pair-ok)
                      (set! pair-used true))
                    (delete-query-relation pair-next))))
              (when (not (or triple-used pair-used))
                (let [[single-next single-ok] (db-read-source-query-relation-apply-primary-physical-op source current op query-value registry (addr out-stats))]
                  (delete-query-relation next)
                  (set! next single-next)
                  (set! next-ok single-ok)))
            (delete-query-relation current)
            (when (not next-ok)
              (delete-query-relation next)
              (return (query-relation-empty) out-stats false))
              (set! current next)
              (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count current))
              (cond
                triple-used (mut! op-index += 3)
                pair-used (mut! op-index += 2)
                :else (mut! op-index += 1)))))
        (set! out-stats.output-rows (query-relation-row-count current))
        (return current out-stats true)))
    (when (not (db-read-source-relation-value-typed-query? sources query-value registry))
      (return (query-relation-empty) out-stats false))
    (let [[current input-binding-count input-ok] (db-read-source-query-relation-initial-from-inputs source query-value inputs)]
      (when (not input-ok)
        (delete-query-relation current)
        (return (query-relation-empty) out-stats false))
      (set! out-stats.input-bindings input-binding-count)
      (set! out-stats.steps (physical-plan-step-count plan))
      (let [op-index 0]
        (while (< op-index (count plan.ops))
          (let [op plan.ops[op-index]
                next (query-relation-empty)
                next-ok false
                triple-used false
                pair-used false]
            (when (< (+ op-index 2) (count plan.ops))
              (let [[triple-next triple-ok triple-used-value] (db-read-source-query-relation-apply-reference-link-projection source current op plan.ops[(+ op-index 1)] plan.ops[(+ op-index 2)] query-value (addr out-stats))]
                (if triple-used-value
                  (do
                    (delete-query-relation next)
                    (set! next triple-next)
                    (set! next-ok triple-ok)
                    (set! triple-used true))
                  (delete-query-relation triple-next))))
            (when (and (not triple-used)
                       (< (+ op-index 1) (count plan.ops)))
              (let [[pair-next pair-ok pair-used-value] (db-read-source-query-relation-apply-primary-physical-op-pair source current op plan.ops[(+ op-index 1)] query-value (addr out-stats))]
                (if pair-used-value
                  (do
                    (delete-query-relation next)
                    (set! next pair-next)
                    (set! next-ok pair-ok)
                    (set! pair-used true))
                  (delete-query-relation pair-next))))
            (when (not (or triple-used pair-used))
              (let [[single-next single-ok] (db-read-source-query-relation-apply-physical-op source sources current op query-value registry (addr out-stats))]
                (delete-query-relation next)
                (set! next single-next)
                (set! next-ok single-ok)))
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) out-stats false))
          (set! current next)
            (query-stats-observe-bindings! (addr out-stats) (query-relation-row-count current))
            (cond
              triple-used (mut! op-index += 3)
              pair-used (mut! op-index += 2)
              :else (mut! op-index += 1)))))
      (set! out-stats.output-rows (query-relation-row-count current))
      (return current out-stats true))))

(defn db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> [result: Result-Set, stats: Query-Stats, used: bool]
  (when (and (= (count sources) 0)
             (= (count inputs) 0))
    (let [[direct-result direct-stats direct-used] (db-read-source-q-ref-chain-string-length-aggregate source query-value registry)]
      (when direct-used
        (return direct-result direct-stats true))))
  (let [[current out-stats rel-used] (db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source sources query-value inputs registry)]
    (when (not rel-used)
      (delete-query-relation current)
      (return (result-set-error "") out-stats false))
      (if (and (> (count query-value.aggregates) 0)
               (= (count query-value.pulls) 0))
        (let [[rows rows-ok] (aggregate-rows-for-typed-relation-with-fns query-value current registry)]
          (delete-query-relation current)
          (when (not rows-ok)
            (delete-result-rows-owned-values rows)
            (return (result-set-error "") out-stats false))
          (set! out-stats.output-rows (count rows))
          (return (result-set-ok rows) out-stats true))
        (let [[rows rows-ok rows-error] (db-read-source-result-rows-for-typed-relation-with-sources-and-fns source sources query-value inputs current registry)]
          (delete-query-relation current)
          (when (not rows-ok)
            (delete-result-rows-owned-values rows)
            (return (result-set-error rows-error) out-stats false))
          (set! out-stats.output-rows (count rows))
          (return (result-set-ok rows) out-stats true)))))

(defn db-read-source-q-query-generic-with-sources-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (let [[bindings bindings-ok bindings-error] (db-read-source-initial-bindings source query-value inputs)]
    (when (not bindings-ok)
      (return (result-set-error bindings-error)))
    (for [step query-value.where-steps]
      (cond
        (= step.kind .Clause)
          (let [clause-value query-value.clauses[step.index]
                [clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
            (when (not source-clause-ok)
              (db-read-source-delete-bindings-owned bindings)
              (return (result-set-error source-clause-error)))
            (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
              (db-read-source-delete-bindings-owned bindings)
              (when (not next-ok)
                (return (result-set-error next-error)))
              (set! bindings next)))
        (= step.kind .Predicate)
          (let [next (db-read-source-bindings-after-predicate (slice bindings 0) query-value.predicates[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (set! bindings next))
        (= step.kind .Function)
          (let [function query-value.function-clauses[step.index]]
            (if (= function.op "fulltext")
              (let [[next next-ok next-error] (db-read-source-bindings-after-fulltext-with-sources source sources (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (result-set-error next-error)))
                (set! bindings next))
              (let [[next next-ok next-error] (db-read-source-bindings-after-function-with-source source (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (result-set-error next-error)))
                (set! bindings next))))
        (= step.kind .RuleCall)
          (let [next (make [dynamic]Binding)]
            (for [binding bindings]
              (let [[rule-bindings rule-ok rule-error] (db-read-source-bindings-after-rule-call-with-sources source sources (slice query-value.rules 0) query-value.rule-calls[step.index] binding)]
                (when (not rule-ok)
                  (db-read-source-delete-bindings-owned next)
                  (db-read-source-delete-bindings-owned bindings)
                  (return (result-set-error rule-error)))
                (for [rule-binding rule-bindings]
                  (arr.push! next rule-binding))
                (delete rule-bindings)))
            (db-read-source-delete-bindings-owned bindings)
            (set! bindings next))
        (= step.kind .Ground)
          (let [[next next-ok next-error] (db-read-source-bindings-after-ground (slice bindings 0) query-value.grounds[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .GetElse)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-else-with-sources source sources (slice bindings 0) query-value.get-elses[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .GetSome)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-some-with-sources source sources (slice bindings 0) query-value.get-somes[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .Not)
          (let [[next next-ok next-error] (db-read-source-bindings-after-not-group-with-sources source sources (slice bindings 0) query-value.not-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .Or)
          (let [[next next-ok next-error] (db-read-source-bindings-after-or-group-with-sources source sources (slice bindings 0) query-value.or-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        :else
          (do
            (db-read-source-delete-bindings-owned bindings)
            (return (result-set-error "SQLite DB snapshot source currently supports data clauses, predicates, scalar function clauses, ground, get-else, get-some, not/missing?, and or/or-join clauses only")))))
    (when (= (count query-value.where-steps) 0)
      (for [clause-value query-value.clauses]
        (let [[clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
          (when (not source-clause-ok)
            (db-read-source-delete-bindings-owned bindings)
            (return (result-set-error source-clause-error)))
          (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next)))))
    (let [result (db-read-source-result-rows-for-bindings-with-sources-and-fns source sources query-value inputs (slice bindings 0) registry)]
      (db-read-source-delete-bindings-owned bindings)
      result)))

(defn db-read-source-q-query-with-bound-sources-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (let [[source-inputs-ok source-inputs-error] (db-read-source-query-source-inputs-bound? query-value sources)]
    (when (not source-inputs-ok)
      (return (result-set-error source-inputs-error))))
  (let [[sources-ok sources-error] (validate-db-read-query-sources query-value sources)]
    (when (not sources-ok)
      (return (result-set-error sources-error))))
  (when (source-backed-query-has-recursive-rule-call-in-negation? query-value)
    (return (result-set-error "source-backed recursive negation is not supported; recursive rule calls inside not/not-join require stratified semantics")))
  (when (db-read-source-has-relation-value-source? sources)
    (for [step query-value.where-steps]
      (when (not (or (= step.kind .Clause)
                     (= step.kind .Predicate)
                     (= step.kind .Function)
                     (= step.kind .RuleCall)
                     (= step.kind .Ground)
                     (= step.kind .GetElse)
                     (= step.kind .GetSome)
                     (= step.kind .Not)
                     (= step.kind .Or)))
        (return (result-set-error "SQLite DB snapshot source currently supports data clauses, predicates, scalar function clauses, ground, get-else, get-some, not/missing?, and or/or-join clauses only"))))
    (when (not (query-has-compound-source-input-operators? query-value))
      (let [[typed-result _ typed-used] (db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns source sources query-value inputs registry)]
        (when typed-used
          (return typed-result))
        (delete-result-rows-owned-values typed-result.rows)))
    (when (> (count query-value.aggregates) 0)
      (return (result-set-error "SQLite DB snapshot source currently supports typed source relation aggregates for built-in aggregate operators only")))
    (return (db-read-source-q-query-generic-with-sources-inputs-and-fns source sources query-value inputs registry)))
  (let [[top-n-plan top-n-ok] (query-attr-top-n-aggregate-plan query-value)]
    (when top-n-ok
      (return (q-db-read-source-attr-top-n-aggregates source query-value top-n-plan))))
  (let [[aggregate-clause aggregate-ok] (db-read-source-single-clause-aggregate-query query-value)]
    (when aggregate-ok
      (let [[aggregate-source source-clause source-ok source-error] (db-read-source-query-clause-source source sources aggregate-clause)]
        (if source-ok
          (return (q-db-read-source-single-clause-aggregates aggregate-source query-value source-clause))
          (return (result-set-error source-error))))))
  (let [[grouped-aggregate-clause grouped-aggregate-ok] (db-read-source-single-clause-grouped-aggregate-query query-value)]
    (when grouped-aggregate-ok
      (let [[grouped-aggregate-source source-clause source-ok source-error] (db-read-source-query-clause-source source sources grouped-aggregate-clause)]
        (if source-ok
          (return (q-db-read-source-single-clause-grouped-aggregate grouped-aggregate-source query-value source-clause))
          (return (result-set-error source-error))))))
  (for [step query-value.where-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)
                   (= step.kind .Function)
                   (= step.kind .RuleCall)
                   (= step.kind .Ground)
                   (= step.kind .GetElse)
                   (= step.kind .GetSome)
                   (= step.kind .Not)
                   (= step.kind .Or)))
      (return (result-set-error "SQLite DB snapshot source currently supports data clauses, predicates, scalar function clauses, ground, get-else, get-some, not/missing?, and or/or-join clauses only"))))
  (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-projection query-value)]
    (when projection-ok
      (let [clause-value query-value.clauses[0]
            [projection-source _ source-ok source-error] (db-read-source-query-clause-source source sources clause-value)]
        (if source-ok
          (return (q-db-read-source-multi-hop-ref-chain-projection projection-source query-value projection inputs))
          (return (result-set-error source-error))))))
  (let [[projection projection-ok] (db-read-source-query-multi-hop-ref-chain-projection-any-order query-value)]
    (when projection-ok
      (let [clause-value query-value.clauses[0]
            [projection-source _ source-ok source-error] (db-read-source-query-clause-source source sources clause-value)]
        (if source-ok
          (return (q-db-read-source-multi-hop-ref-chain-projection projection-source query-value projection inputs))
          (return (result-set-error source-error))))))
  (let [[projection projection-ok] (db-read-source-query-anchor-two-branch-join-projection query-value)]
    (when projection-ok
      (let [clause-value query-value.clauses[0]
            [projection-source _ source-ok source-error] (db-read-source-query-clause-source source sources clause-value)]
        (if source-ok
          (return (q-db-read-source-anchor-two-branch-join-projection projection-source query-value projection inputs))
          (return (result-set-error source-error))))))
  (let [[projection projection-ok] (db-read-source-query-anchor-two-branch-join-projection-any-order query-value)]
    (when projection-ok
      (let [clause-value query-value.clauses[0]
            [projection-source _ source-ok source-error] (db-read-source-query-clause-source source sources clause-value)]
        (if source-ok
          (return (q-db-read-source-anchor-two-branch-join-projection projection-source query-value projection inputs))
          (return (result-set-error source-error))))))
  (when (and (= (count sources) 0)
             (= (count inputs) 0)
             (= (count registry) 0))
    (let [[projection projection-ok] (db-read-source-query-two-attr-entity-projection query-value)]
      (when projection-ok
        (return (q-db-read-source-two-attr-entity-projection source query-value projection)))))
  (when (and (= (count sources) 0)
             (= (count registry) 0))
    (let [[columns columns-ok columns-error] (q-db-read-source-string-int-pair-columns source query-value inputs)]
      (when (not (= columns-error ""))
        (delete-entity-string-int-triples columns)
        (return (result-set-error columns-error)))
      (when columns-ok
        (return (result-set-from-source-string-int-pair-columns columns)))
      (delete-entity-string-int-triples columns))
    (let [[columns columns-ok columns-error] (q-db-read-source-string-string-pair-columns source query-value inputs)]
      (when (not (= columns-error ""))
        (delete-string-string-pair-columns columns)
        (return (result-set-error columns-error)))
      (when columns-ok
        (return (result-set-from-source-string-string-pair-columns columns)))
      (delete-string-string-pair-columns columns))
    (let [[columns columns-ok columns-error] (q-db-read-source-entity-string-int-triples source query-value inputs)]
      (when (not (= columns-error ""))
        (delete-entity-string-int-triples columns)
        (return (result-set-error columns-error)))
      (when columns-ok
