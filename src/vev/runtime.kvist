      (let [[hop2-ok hop2-error] (append-source-multi-hop-ref-chain-propagated-links! source projection.hop2-attr (addr hop1-heads) (slice hop1-links 0) (addr hop2-heads) (addr hop2-links))]
        (when (not hop2-ok)
