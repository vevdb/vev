(defn db-read-source-query-entity-int-range-pair-projection [query: Query] -> [entity-var: string, projection: Source-Attr-Range-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Predicate)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].index 0)))
    (return "" (empty-source-attr-range-value-projection) false))
  (let [clause-value query.clauses[0]
        [filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] clause-value.v.name)]
    (when (or (not filter-ok)
              (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (not (= query.find[0] clause-value.e.name))
              (not (= query.find[1] clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return "" (empty-source-attr-range-value-projection) false))
    (return clause-value.e.name
            (Source-Attr-Range-Value-Projection {attr: clause-value.a.value.text
                                                 value-var: clause-value.v.name
                                                 op: filter-op
                                                 value: filter-value})
            true)))

(defn q-db-read-source-entity-int-range-pair-columns [source: DB-Read-Source, query: Query, inputs: []Query-Input] -> [columns: Entity-Int-Pair-Columns, ok: bool, error: string]
  (let [out (empty-entity-int-pair-columns)
        seen (set.empty string)]
    (defer (delete seen))
    (when (> (count inputs) 0)
      (return out false ""))
    (let [[_ projection projection-ok] (db-read-source-query-entity-int-range-pair-projection query)]
      (when (not projection-ok)
        (return out false ""))
      (let [[stream stream-ok stream-error] (source-index-datom-stream-for-attr-range source projection)]
        (when (not stream-ok)
          (return out false stream-error))
        (let [[append-ok type-ok append-error] (source-entity-int-pair-append-range-stream! (addr out) (addr seen) source (addr stream) projection)]
          (when (not append-ok)
            (delete-source-index-datom-stream stream)
            (return out false append-error))
          (when (not type-ok)
            (delete-source-index-datom-stream stream)
            (return out false "")))
        (delete-source-index-datom-stream stream))
      (return out true ""))))

(defn db-read-source-query-entity-two-value-plan [source: DB-Read-Source, query: Query] -> [plan: Entity-Two-Value-Plan, ok: bool, error: string]
  (let [out (empty-entity-two-value-plan)]
    (when (not (and (= (count query.find) 3)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 3)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false ""))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false "")))
    (let [entity-var query.find[0]
          first-var query.find[1]
          second-var query.find[2]
          first-found false
          second-found false
          first-attr ""
          second-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.e.name entity-var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard)))
          (return out false ""))
        (if (= item.v.kind .Var)
          (cond
            (= item.v.name first-var)
              (do
                (when first-found
                  (return out false ""))
                (set! first-found true)
                (set! first-attr item.a.value.text))
            (= item.v.name second-var)
              (do
                (when second-found
                  (return out false ""))
                (set! second-found true)
                (set! second-attr item.a.value.text))
            :else (return out false ""))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false ""))))
      (when (or (not first-found)
                (not second-found)
                (= (count out.filters) 0))
        (return out false ""))
      (let [[first-many first-many-ok first-many-error] (db-read-source-schema-cardinality-many? source first-attr)]
        (when (not first-many-ok)
          (return out false first-many-error))
        (when first-many
          (return out false "")))
      (let [[second-many second-many-ok second-many-error] (db-read-source-schema-cardinality-many? source second-attr)]
        (when (not second-many-ok)
          (return out false second-many-error))
        (when second-many
          (return out false "")))
      (set! out.entity-var entity-var)
      (set! out.first-var first-var)
      (set! out.first-attr first-attr)
      (set! out.second-var second-var)
      (set! out.second-attr second-attr)
      (return out true ""))))

(defn db-read-source-query-string-int-pair-plan [source: DB-Read-Source, query: Query] -> [plan: Entity-Two-Value-Plan, ok: bool, error: string]
  (let [out (empty-entity-two-value-plan)]
    (when (not (and (= (count query.find) 2)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (>= (count query.clauses) 2)
                    (= (count query.where-steps) (count query.clauses))))
      (return out false ""))
    (for [step query.where-steps]
      (when (not (= step.kind .Clause))
        (return out false "")))
    (let [first-var query.find[0]
          second-var query.find[1]
          entity-var ""
          first-found false
          second-found false
          first-attr ""
          second-attr ""]
      (for [item (slice query.clauses 0)]
        (when (or item.has-source
                  (not (= item.e.kind .Var))
                  (not (= item.a.kind .Value))
                  (not (= item.a.value.kind .Keyword))
                  (reverse-attr? item.a.value.text)
                  (not (= item.tx-term.kind .Wildcard))
                  (not (= item.op-term.kind .Wildcard)))
          (return out false ""))
        (if (= entity-var "")
          (set! entity-var item.e.name)
          (when (not (= item.e.name entity-var))
            (return out false "")))
        (if (= item.v.kind .Var)
          (cond
            (= item.v.name first-var)
              (do
                (when first-found
                  (return out false ""))
                (set! first-found true)
                (set! first-attr item.a.value.text))
            (= item.v.name second-var)
              (do
                (when second-found
                  (return out false ""))
                (set! second-found true)
                (set! second-attr item.a.value.text))
            :else (return out false ""))
          (if (= item.v.kind .Value)
            (arr.push! out.filters (Entity-Int-Pair-Filter {attr: item.a.value.text value: item.v.value}))
            (return out false ""))))
      (when (or (= entity-var "")
                (not first-found)
                (not second-found))
        (return out false ""))
      (let [[first-many first-many-ok first-many-error] (db-read-source-schema-cardinality-many? source first-attr)]
        (when (not first-many-ok)
          (return out false first-many-error))
        (when first-many
          (return out false "")))
      (let [[second-many second-many-ok second-many-error] (db-read-source-schema-cardinality-many? source second-attr)]
        (when (not second-many-ok)
          (return out false second-many-error))
        (when second-many
          (return out false "")))
      (set! out.entity-var entity-var)
      (set! out.first-var first-var)
      (set! out.first-attr first-attr)
      (set! out.second-var second-var)
      (set! out.second-attr second-attr)
      (return out true ""))))

(defn db-read-source-entity-two-value-plan-filters-match? [source: DB-Read-Source, entity: u64, plan: Entity-Two-Value-Plan, skip-filter-index: int] -> [matches: bool, ok: bool, error: string]
  (let [filter-index 0]
    (while (< filter-index (count plan.filters))
      (when (not (= filter-index skip-filter-index))
        (let [filter plan.filters[filter-index]
              [matches matches-ok matches-error] (db-read-source-cardinality-one-value-matches-fast-all-current? source entity filter.attr filter.value)]
          (when (not matches-ok)
            (return false false matches-error))
          (when (not matches)
            (return false true ""))))
      (set! filter-index (+ filter-index 1))))
  (return true true ""))

(defn db-read-source-entity-two-value-plan-best-filter [source: DB-Read-Source, plan: Entity-Two-Value-Plan] -> [filter-index: int, ok: bool, error: string]
  (let [best-index 0
        best-count 0
        i 0]
    (while (< i (count plan.filters))
      (let [filter plan.filters[i]
            [entry-count count-ok count-error] (db-read-source-attr-value-entry-count source filter.attr filter.value)]
        (when (not count-ok)
          (return 0 false count-error))
        (when (or (= i 0)
                  (< entry-count best-count))
          (set! best-index i)
          (set! best-count entry-count)))
      (set! i (+ i 1)))
    (return best-index true "")))

(defn db-read-source-string-int-pair-plan-best-driver [source: DB-Read-Source, plan: Entity-Two-Value-Plan] -> [attr: string, has-value: bool, value: Value, ok: bool, error: string]
  (let [best-attr plan.first-attr
        best-has-value false
        best-value (value-nil)
        [best-count first-count-ok first-count-error] (db-read-source-attr-range-entry-count source plan.first-attr)]
    (when (not first-count-ok)
      (return "" false (value-nil) false first-count-error))
    (let [[second-count second-count-ok second-count-error] (db-read-source-attr-range-entry-count source plan.second-attr)]
      (when (not second-count-ok)
        (return "" false (value-nil) false second-count-error))
      (when (< second-count best-count)
        (set! best-attr plan.second-attr)
        (set! best-count second-count)))
    (let [i 0]
      (while (< i (count plan.filters))
        (let [filter plan.filters[i]
              [filter-count filter-count-ok filter-count-error] (db-read-source-attr-value-entry-count source filter.attr filter.value)]
          (when (not filter-count-ok)
            (return "" false (value-nil) false filter-count-error))
          (when (< filter-count best-count)
            (set! best-attr filter.attr)
            (set! best-has-value true)
            (set! best-value filter.value)
            (set! best-count filter-count)))
        (set! i (+ i 1))))
    (return best-attr best-has-value best-value true "")))

(defn source-entity-string-int-triple-append-driver-stream! [columns: ^Entity-String-Int-Triples, seen: (ptr (map string (struct {}))), source: DB-Read-Source, stream: ^Source-Index-Datom-Stream, plan: Entity-Two-Value-Plan] -> [ok: bool, type-ok: bool, error: string]
  (while stream^.has-current
