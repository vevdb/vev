          (return (q-db-read-source-entity-attr-value-projection projection-source query-value projection))
          (return (result-set-error source-error))))))
  (let [[bindings bindings-ok bindings-error] (db-read-source-initial-bindings source query-value inputs)]
    (when (not bindings-ok)
      (return (result-set-error bindings-error)))
    (for [step query-value.where-steps]
      (cond
        (= step.kind .Clause)
          (let [clause-value query-value.clauses[step.index]
                [clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
            (when (not source-clause-ok)
              (db-read-source-delete-bindings-owned bindings)
              (return (result-set-error source-clause-error)))
            (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
              (db-read-source-delete-bindings-owned bindings)
              (when (not next-ok)
                (return (result-set-error next-error)))
              (set! bindings next)))
        (= step.kind .Predicate)
          (let [next (db-read-source-bindings-after-predicate (slice bindings 0) query-value.predicates[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (set! bindings next))
        (= step.kind .Function)
          (let [function query-value.function-clauses[step.index]]
            (if (= function.op "fulltext")
              (let [[next next-ok next-error] (db-read-source-bindings-after-fulltext-with-sources source sources (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (result-set-error next-error)))
                (set! bindings next))
              (let [[next next-ok next-error] (db-read-source-bindings-after-function-with-source source (slice bindings 0) function)]
                (db-read-source-delete-bindings-owned bindings)
                (when (not next-ok)
                  (return (result-set-error next-error)))
                (set! bindings next))))
        (= step.kind .RuleCall)
          (let [next (make [dynamic]Binding)]
            (for [binding bindings]
              (let [[rule-bindings rule-ok rule-error] (db-read-source-bindings-after-rule-call-with-sources source sources (slice query-value.rules 0) query-value.rule-calls[step.index] binding)]
                (when (not rule-ok)
                  (db-read-source-delete-bindings-owned next)
                  (db-read-source-delete-bindings-owned bindings)
                  (return (result-set-error rule-error)))
                (for [rule-binding rule-bindings]
                  (arr.push! next rule-binding))
                (delete rule-bindings)))
            (db-read-source-delete-bindings-owned bindings)
            (set! bindings next))
        (= step.kind .Ground)
          (let [[next next-ok next-error] (db-read-source-bindings-after-ground (slice bindings 0) query-value.grounds[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .GetElse)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-else-with-sources source sources (slice bindings 0) query-value.get-elses[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .GetSome)
          (let [[next next-ok next-error] (db-read-source-bindings-after-get-some-with-sources source sources (slice bindings 0) query-value.get-somes[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .Not)
          (let [[next next-ok next-error] (db-read-source-bindings-after-not-group-with-sources source sources (slice bindings 0) query-value.not-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        (= step.kind .Or)
          (let [[next next-ok next-error] (db-read-source-bindings-after-or-group-with-sources source sources (slice bindings 0) query-value.or-groups[step.index])]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next))
        :else
          (do
            (db-read-source-delete-bindings-owned bindings)
            (return (result-set-error "SQLite DB snapshot source currently supports data clauses, predicates, scalar function clauses, ground, get-else, get-some, not/missing?, and or/or-join clauses only")))))
    (when (= (count query-value.where-steps) 0)
      (for [clause-value query-value.clauses]
        (let [[clause-source source-clause source-clause-ok source-clause-error] (db-read-source-query-clause-source source sources clause-value)]
          (when (not source-clause-ok)
            (db-read-source-delete-bindings-owned bindings)
            (return (result-set-error source-clause-error)))
          (let [[next next-ok next-error] (db-read-source-bindings-after-clause clause-source (slice bindings 0) source-clause)]
            (db-read-source-delete-bindings-owned bindings)
            (when (not next-ok)
              (return (result-set-error next-error)))
            (set! bindings next)))))
    (let [result (db-read-source-result-rows-for-bindings-with-sources-and-fns source sources query-value inputs (slice bindings 0) registry)]
      (db-read-source-delete-bindings-owned bindings)
      result)))

(defn db-read-source-q-query-with-sources-inputs-and-fns [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (let [[parser-ok parser-error] (validate-query-parser-vars query-value)]
    (when (not parser-ok)
      (return (result-set-error parser-error))))
  (let [[default-source-ok default-source-error] (validate-query-default-source-input query-value)]
    (when (not default-source-ok)
      (return (result-set-error default-source-error))))
  (when (and (= (count sources) 0)
             (= (count inputs) 0))
    (let [[direct-result _ direct-used] (db-read-source-q-ref-chain-string-length-aggregate source query-value registry)]
      (when direct-used
        (return direct-result))))
  (when (and (= source.kind .Resident)
             (not source.filter-has-as-of)
             (not source.filter-has-since)
             (not source.filter-history)
             (= (count sources) 0)
             (not (db-read-source-query-has-source-inputs? query-value))
             (not (query-has-source-function? query-value)))
    (return (q-query-with-inputs-and-fns source.db^ query-value inputs registry)))
  (let [owned-source-values (make [dynamic]Value 0 (count inputs)) :defer
        augmented-sources (arr.into [dynamic]DB-Read-Named-Source sources) :defer
        [input-sources-ok input-sources-error] (append-db-read-source-query-input-sources! (addr augmented-sources) (addr owned-source-values) query-value inputs)]
    (when (not input-sources-ok)
      (for [value owned-source-values]
        (delete-owned-value value))
      (return (result-set-error input-sources-error)))
    (let [result (db-read-source-q-query-with-bound-sources-inputs-and-fns source (slice augmented-sources 0) query-value inputs registry)]
      (for [value owned-source-values]
        (delete-owned-value value))
      result)))

(defn db-read-source-q-query-with-inputs-and-fns [source: DB-Read-Source, query-value: Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (db-read-source-q-query-with-sources-inputs-and-fns source ([]DB-Read-Named-Source []) query-value inputs registry))

(defn db-read-source-q-query-with-inputs [source: DB-Read-Source, query-value: Query, inputs: []Query-Input] -> Result-Set
  (db-read-source-q-query-with-inputs-and-fns source query-value inputs ([]Native-Query-Fn [])))

(defn db-read-source-q-query-with-fns [source: DB-Read-Source, query-value: Query, registry: []Native-Query-Fn] -> Result-Set
  (db-read-source-q-query-with-inputs-and-fns source query-value ([]Query-Input []) registry))

(defn db-read-source-q-query [source: DB-Read-Source, query-value: Query] -> Result-Set
  (db-read-source-q-query-with-inputs source query-value ([]Query-Input [])))

(defn public-avet-attr? [db: DB, attr: string] -> bool
  (when (not (db-has-schema? db))
    (return true))
  (let [tuple-attrs (schema-tuple-attrs db attr)
        visible (or (schema-indexed? db attr)
                    (schema-unique? db attr)
                    (schema-ref? db attr)
                    (> (count tuple-attrs) 0))]
    (delete tuple-attrs)
    visible))

(defn public-index-datom-visible? [db: DB, order: Public-Index-Order, datom: Datom] -> bool
  (if (= order .AVET)
    (public-avet-attr? db datom.a)
    true))

(defn index-arg-attr [db: DB, arg: Index-Arg] -> [attr: string, ok: bool]
  (let [[value value-ok] (index-arg-value db arg)]
    (when (not value-ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true))
    (return "" false)))

(defn validate-public-index-args [db: DB, order: Public-Index-Order, args: []Index-Arg] -> [ok: bool, error: string]
  (let [[lookup-ok lookup-error] (validate-index-lookup-refs db args)]
    (when (not lookup-ok)
      (return false lookup-error)))
  (when (not (= order .AVET))
    (return true ""))
  (when (= (count args) 0)
    (return true ""))
  (let [[attr attr-ok] (index-arg-attr db args[0])]
    (when (not attr-ok)
      (return false "invalid index attr"))
    (when (not (public-avet-attr? db attr))
      (return false (fmt.tprintf "Attribute %s should be marked as :db/index true" attr))))
  (return true ""))

(defn append-index-view-datoms! [out: ^[dynamic]Datom, db: DB, view: DB-Index-View, values: []Value]
  (let [order view.order
        order-text (public-index-order-text order)
        low (lower-bound-index-view-values db view values)
        high (upper-bound-index-view-values db view values)
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (and (public-index-datom-visible? db order datom)
                       (datom-matches-index-values? datom order-text values))
              (arr.push! out^ datom)))))
      (set! i (+ i 1)))))

(defn append-seek-index-view-datoms! [out: ^[dynamic]Datom, db: DB, view: DB-Index-View, values: []Value]
  (let [order view.order
        low (lower-bound-index-view-values db view values)
        i low]
    (while (< i (db-index-view-count view))
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (public-index-datom-visible? db order datom)
              (arr.push! out^ datom)))))
      (set! i (+ i 1)))))

(defn append-rseek-index-view-datoms! [out: ^[dynamic]Datom, db: DB, view: DB-Index-View, values: []Value]
  (let [order view.order
        i (upper-bound-index-view-values db view values)]
    (while (> i 0)
      (set! i (- i 1))
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (let [datom db.datoms[datom-index]]
            (when (public-index-datom-visible? db order datom)
              (arr.push! out^ datom))))))))

(defn append-index-range-datoms! [out: ^[dynamic]Datom, db: DB, attr: string, start-value: Value, has-start: bool, end-value: Value, has-end: bool]
  (let [view (db-index-view db .AVET)
        lower-values (make [dynamic]Value)
        upper-values (make [dynamic]Value)]
    (defer (delete lower-values))
    (defer (delete upper-values))
    (arr.push! lower-values (value-keyword attr))
    (arr.push! upper-values (value-keyword attr))
    (when has-start
      (arr.push! lower-values start-value))
    (when has-end
      (arr.push! upper-values end-value))
    (let [low (lower-bound-index-view-values db view (slice lower-values 0))
          high (if has-end
                 (upper-bound-index-view-values db view (slice upper-values 0))
                 (upper-bound-index-view-values db view ([]Value [(value-keyword attr)])))
          i low]
      (while (< i high)
        (let [datom-index (db-index-view-at view i)]
          (when (datom-current-at? db datom-index)
            (let [datom db.datoms[datom-index]]
              (when (and (= datom.a attr)
                         (public-index-datom-visible? db .AVET datom))
                (arr.push! out^ datom)))))
        (set! i (+ i 1))))))

(defn datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        index-order (public-index-order order)
        view (db-index-view db index-order)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (append-index-view-datoms! (addr out) db view (slice values 0))
    out))

(defn datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [index-order (public-index-order order)
        [valid error] (validate-public-index-args db index-order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (datoms-with-args db order args)})))

(defn seek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        index-order (public-index-order order)
        view (db-index-view db index-order)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (append-seek-index-view-datoms! (addr out) db view (slice values 0))
    out))

(defn seek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [index-order (public-index-order order)
        [valid error] (validate-public-index-args db index-order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (seek-datoms-with-args db order args)})))

(defn rseek-datoms-with-args [db: DB, order: string, args: []Index-Arg] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        index-order (public-index-order order)
        view (db-index-view db index-order)
        [values ok] (resolve-index-args db args)]
    (defer (delete values))
    (when (not ok)
      (return out))
    (append-rseek-index-view-datoms! (addr out) db view (slice values 0))
    out))

(defn rseek-datoms-checked-with-args [db: DB, order: string, args: []Index-Arg] -> Datoms-Result
  (let [index-order (public-index-order order)
        [valid error] (validate-public-index-args db index-order args)]
    (when (not valid)
      (return (Datoms-Result {ok: false error: error datoms: (make [dynamic]Datom)})))
    (Datoms-Result {ok: true error: "" datoms: (rseek-datoms-with-args db order args)})))

(defn find-datom-with-args [db: DB, order: string, args: []Index-Arg] -> Datom-Result
  (let [found (datoms-with-args db order args)]
    (defer (delete found))
    (when (> (count found) 0)
      (return (Datom-Result {found: true datom: found[0]})))
    (Datom-Result {})))

(defn index-range-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> [dynamic]Datom
  (let [out (make [dynamic]Datom)
        start-value (Value {})
        end-value (Value {})]
    (when has-start
      (let [[value ok] (index-arg-value db start)]
        (when (not ok)
          (return out))
        (set! start-value value)))
    (when has-end
      (let [[value ok] (index-arg-value db end)]
        (when (not ok)
          (return out))
        (set! end-value value)))
    (append-index-range-datoms! (addr out) db attr start-value has-start end-value has-end)
    out))

(defn index-range-checked-with-args [db: DB, attr: string, start: Index-Arg, has-start: bool, end: Index-Arg, has-end: bool] -> Datoms-Result
  (when (not (public-avet-attr? db attr))
    (return (Datoms-Result {ok: false
                            error: (fmt.tprintf "Attribute %s should be marked as :db/index true" attr)
                            datoms: (make [dynamic]Datom)})))
  (when has-start
    (let [[start-ok start-error] (validate-index-lookup-refs db ([]Index-Arg [start]))]
      (when (not start-ok)
        (return (Datoms-Result {ok: false error: start-error datoms: (make [dynamic]Datom)})))))
  (when has-end
    (let [[end-ok end-error] (validate-index-lookup-refs db ([]Index-Arg [end]))]
      (when (not end-ok)
        (return (Datoms-Result {ok: false error: end-error datoms: (make [dynamic]Datom)})))))
  (Datoms-Result {ok: true error: "" datoms: (index-range-with-args db attr start has-start end has-end)}))

(defn append-retract-entity-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, seen: (ptr (map u64 (struct {})))]
  (when (set.contains? seen^ entity)
    (return))
  (set.add! seen^ entity)
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt" entity "" (Value {}))
        high (upper-bound-index-view db view "eavt" entity "" (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db datom.a))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity datom.a datom.v))))
      (set! i (+ i 1))))
  (let [ref-value (value-entity entity)
        view (db-index-view db .VAET)
        low (lower-bound-index-view db view "vaet" 0 "" ref-value)
        high (upper-bound-index-view db view "vaet" 0 "" ref-value)
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (push-tx-op-once! ops (tx-retract datom.e datom.a datom.v))))
      (set! i (+ i 1)))))

(defn append-retract-entity-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64]
  (let [seen (set.empty u64)]
    (defer (delete seen))
    (append-retract-entity-ops-seen! ops db entity (addr seen))))

(defn append-retract-attr-ops-seen! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string, seen: (ptr (map u64 (struct {})))]
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (when (and (= datom.v.kind .Entity)
                     (schema-component? db attr))
            (append-retract-entity-ops-seen! ops db datom.v.entity seen))
          (push-tx-op-once! ops (tx-retract entity attr datom.v))))
      (set! i (+ i 1)))))

(defn append-retract-attr-ops! [ops: ^[dynamic]Tx-Op, db: DB, entity: u64, attr: string]
  (let [seen (set.empty u64)]
    (defer (delete seen))
    (set.add! seen entity)
    (append-retract-attr-ops-seen! ops db entity attr (addr seen))))

(defn schema-entity-for-attr [db: DB, attr: string] -> [e: u64, ok: bool]
  (let [value (value-keyword attr)
        view (db-index-view db .AVET)
        low (lower-bound-index-view db view "avet" 0 ":db/ident" value)
        high (upper-bound-index-view db view "avet" 0 ":db/ident" value)
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (return db.datoms[datom-index].e true)))
      (set! i (+ i 1))))
  (return 0 false))

(defn db-has-schema? [db: DB] -> bool
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (return true)))
      (set! i (+ i 1))))
  false)

(defn schema-property-value-for-entity [db: DB, entity: u64, schema-attr: string] -> [value: Value, ok: bool]
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity schema-attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity schema-attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (return datom.v true)))
      (set! i (+ i 1))))
  (return (Value {}) false))

(defn schema-keyword-property [db: DB, entity: u64, schema-attr: string] -> [value: string, ok: bool]
  (let [[prop prop-ok] (schema-property-value-for-entity db entity schema-attr)]
    (if (and prop-ok (= prop.kind .Keyword))
      (return prop.text true)
      (return "" false))))

(defn schema-has-bool-property? [db: DB, entity: u64, schema-attr: string] -> [value: bool, ok: bool]
  (let [[prop prop-ok] (schema-property-value-for-entity db entity schema-attr)]
    (if (and prop-ok (= prop.kind .Bool))
      (return prop.bool-value true)
      (return false false))))

(defn schema-keyword [db: DB, attr: string, schema-attr: string] -> [value: string, ok: bool]
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return "" false))
    (schema-keyword-property db schema-e schema-attr)))

(defn schema-bool? [db: DB, attr: string, schema-attr: string] -> bool
  (let [[schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return false))
    (let [[value ok] (schema-has-bool-property? db schema-e schema-attr)]
      (and ok value))))

(defn schema-ident-for-entity [db: DB, entity: u64] -> [attr: string, ok: bool]
  (schema-keyword-property db entity ":db/ident"))

(defn resolve-attribute-value [db: DB, value: Value] -> [resolved: Value, ok: bool]
  (cond
    (= value.kind .Keyword) (return value true)
    (= value.kind .Entity)
      (let [[ident ident-ok] (schema-ident-for-entity db value.entity)]
        (if ident-ok
          (return (value-keyword ident) true)
          (return (Value {}) false)))
    (and (= value.kind .Int) (>= value.int-value 0))
      (let [[ident ident-ok] (schema-ident-for-entity db (u64 value.int-value))]
        (if ident-ok
          (return (value-keyword ident) true)
          (return (Value {}) false)))
    :else (return value true)))

(defn schema-has-attr? [items: []Schema-Attr, attr: string] -> bool
  (for [item items]
    (when (= item.attr attr)
      (return true)))
  false)

(defn schema-tuple-attrs-for-entity [db: DB, entity: u64] -> [dynamic]string
  (let [out (make [dynamic]string)
        view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity ":db/tupleAttrs" (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity ":db/tupleAttrs" (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Vector))
          (for [item datom.v.items]
            (when (= item.kind .Keyword)
              (arr.push! out item.text)))))
      (set! i (+ i 1)))
    out))

(defn schema-attr-for-entity [db: DB, entity: u64, attr: string] -> Schema-Attr
  (let [[value-type has-value-type] (schema-keyword-property db entity ":db/valueType")
        [cardinality has-cardinality] (schema-keyword-property db entity ":db/cardinality")
        [unique has-unique] (schema-keyword-property db entity ":db/unique")
        [indexed has-indexed] (schema-has-bool-property? db entity ":db/index")
        [component has-component] (schema-has-bool-property? db entity ":db/isComponent")
        tuple-attrs (schema-tuple-attrs-for-entity db entity)
        has-tuple-attrs (> (count tuple-attrs) 0)
        inferred-value-type value-type
        inferred-has-value-type has-value-type
        inferred-cardinality cardinality
        inferred-has-cardinality has-cardinality]
    (when has-tuple-attrs
      (when (not inferred-has-value-type)
        (set! inferred-value-type ":db.type/tuple")
        (set! inferred-has-value-type true))
      (when (not inferred-has-cardinality)
        (set! inferred-cardinality ":db.cardinality/one")
        (set! inferred-has-cardinality true)))
    (Schema-Attr {attr: attr
                  value-type: inferred-value-type
                  has-value-type: inferred-has-value-type
                  cardinality: inferred-cardinality
                  has-cardinality: inferred-has-cardinality
                  unique: unique
                  has-unique: has-unique
                  indexed: indexed
                  has-indexed: has-indexed
                  component: component
                  has-component: has-component
                  tuple-attrs: tuple-attrs
                  has-tuple-attrs: has-tuple-attrs})))

(defn db-schema [db: DB] -> [dynamic]Schema-Attr
  (let [out (make [dynamic]Schema-Attr)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (not (schema-has-attr? (slice out 0) datom.v.text)))
          (arr.push! out (schema-attr-for-entity db datom.e datom.v.text))))
      (set! i (+ i 1)))
    out))

(defn delete-schema [schema: [dynamic]Schema-Attr]
  (for [item schema]
    (delete item.tuple-attrs))
  (delete schema))

(defn schema-tuple-attrs [db: DB, attr: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        [schema-e schema-ok] (schema-entity-for-attr db attr)]
    (when (not schema-ok)
      (return out))
    (let [view (db-index-view db .EAVT)
          low (lower-bound-index-view db view "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))
          high (upper-bound-index-view db view "eavt-ea" schema-e ":db/tupleAttrs" (Value {}))
          i low]
      (while (< i high)
        (let [datom-index (db-index-view-at view i)
              datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.v.kind .Vector))
            (for [item datom.v.items]
              (when (= item.kind .Keyword)
                (arr.push! out item.text)))))
        (set! i (+ i 1))))
    out))

(defn tuple-schema-contains? [schema: Tuple-Schema, attr: string] -> bool
  (for [component schema.attrs]
    (when (= component attr)
      (return true)))
  false)

(defn tuple-schemas-containing [db: DB, attr: string] -> [dynamic]Tuple-Schema
  (let [out (make [dynamic]Tuple-Schema)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[tuple-attr ident-ok] (schema-ident-for-entity db datom.e)]
            (when ident-ok
              (let [attrs (schema-tuple-attrs db tuple-attr)
                    schema (Tuple-Schema {attr: tuple-attr attrs: attrs})]
                (if (tuple-schema-contains? schema attr)
                  (arr.push! out schema)
                  (delete attrs)))))))
      (set! i (+ i 1)))
    out))

(defn schema-indexed? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/index"))

(defn schema-ref? [db: DB, attr: string] -> bool
  (set.contains? db.schema-ref attr))

(defn schema-ref-target? [db: DB, attr: string] -> bool
  (if (reverse-attr? attr)
    (let [forward (forward-attr-for-reverse attr)]
      (defer (delete forward))
      (schema-ref? db forward))
    (schema-ref? db attr)))

(defn schema-component? [db: DB, attr: string] -> bool
  (schema-bool? db attr ":db/isComponent"))

(defn value-matches-schema-type? [value: Value, schema-type: string] -> bool
  (cond
    (= schema-type ":db.type/string") (= value.kind .String)
    (= schema-type ":db.type/long") (= value.kind .Int)
    (= schema-type ":db.type/boolean") (= value.kind .Bool)
    (= schema-type ":db.type/ref") (= value.kind .Entity)
    (= schema-type ":db.type/keyword") (= value.kind .Keyword)
    (= schema-type ":db.type/symbol") (= value.kind .Symbol)
    (= schema-type ":db.type/tuple") (= value.kind .Vector)
    (= schema-type ":db.type/uuid") (= value.kind .Uuid)
    (= schema-type ":db.type/instant") (= value.kind .Instant)
    :else true))

(defn valid-tuple-attrs-value? [db: DB, value: Value] -> bool
  (when (not (= value.kind .Vector))
    (return false))
  (when (= (count value.items) 0)
    (return false))
  (for [item value.items]
    (when (not (= item.kind .Keyword))
      (return false))
    (when (not (schema-cardinality-one? db item.text))
      (return false))
    (let [nested (schema-tuple-attrs db item.text)]
      (defer (delete nested))
      (when (> (count nested) 0)
        (return false))))
  true)

(defn valid-tuple-attr-target? [db: DB, schema-e: u64] -> bool
  (let [[attr attr-ok] (schema-ident-for-entity db schema-e)]
    (when (not attr-ok)
      (return true))
    (schema-cardinality-one? db attr)))

(defn unique-conflict? [db: DB, op: Tx-Op] -> bool
  (let [view (db-index-view db .AVET)
        low (lower-bound-index-view db view "avet" 0 op.a op.v)
        high (upper-bound-index-view db view "avet" 0 op.a op.v)
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.e op.e)))
          (return true)))
      (set! i (+ i 1))))
  false)

(defn schema-unique? [db: DB, attr: string] -> bool
  (set.contains? db.schema-unique attr))

(defn schema-unique-identity? [db: DB, attr: string] -> bool
  (let [[unique has-unique] (schema-keyword db attr ":db/unique")]
    (and has-unique
         (= unique ":db.unique/identity"))))

(defn schema-cardinality-one? [db: DB, attr: string] -> bool
  (not (set.contains? db.schema-cardinality-many attr)))

(defn schema-value-type-long? [db: DB, attr: string] -> bool
  (let [[value-type has-value-type] (mmap.get db.schema-value-types attr)]
    (and has-value-type (= value-type ":db.type/long"))))

(defn schema-cardinality-many? [db: DB, attr: string] -> bool
  (set.contains? db.schema-cardinality-many attr))

(defn tx-op-cardinality-one? [db: DB, op: Tx-Op] -> bool
  (not (set.contains? db.schema-cardinality-many op.a)))

(defn resolve-ref-component-value [db: DB, value: Value] -> [resolved: Value, ok: bool, error: string]
  (cond
    (= value.kind .Entity) (return value true "")
    (= value.kind .Int) (return (value-entity (u64 value.int-value)) true "")
    (= value.kind .Keyword)
      (let [[entity ident-ok] (schema-entity-for-attr db value.text)]
        (if ident-ok
          (return (value-entity entity) true "")
          (return value false "ident not found")))
    (and (= value.kind .Vector)
         (= (count value.items) 2)
         (= value.items[0].kind .Keyword))
      (let [[entity entity-ok lookup-error] (resolve-lookup-ref-checked db value.items[0].text value.items[1])]
        (if entity-ok
          (return (value-entity entity) true "")
          (return value false lookup-error)))
    :else (return value true "")))

(defn resolve-tuple-value [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (when (not (= value.kind .Vector))
    (return value true ""))
  (let [tuple-attrs (schema-tuple-attrs db attr)]
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return value true ""))
    (when (not (= (count tuple-attrs) (count value.items)))
      (return value true ""))
    (let [items (make [dynamic]Value 0 (count value.items))]
      (defer (delete items))
      (for [item index value.items]
        (let [component-attr tuple-attrs[index]]
          (if (schema-ref? db component-attr)
            (let [[resolved resolved-ok resolved-error] (resolve-ref-component-value db item)]
              (when (not resolved-ok)
                (return value false resolved-error))
              (arr.push! items resolved))
            (arr.push! items item))))
      (return (value-vector (slice items 0)) true ""))))

(defn resolve-lookup-ref [db: DB, attr: string, value: Value] -> [e: u64, ok: bool]
  (when (not (schema-unique? db attr))
    (return 0 false))
  (let [lookup-value value
        [resolved resolved-ok _] (resolve-tuple-value db attr value)]
    (when (not resolved-ok)
      (return 0 false))
    (set! lookup-value resolved)
    (let [view (db-index-view db .AVET)
          low (lower-bound-index-view db view "avet" 0 attr lookup-value)
          high (upper-bound-index-view db view "avet" 0 attr lookup-value)
          i low]
      (while (< i high)
        (let [datom-index (db-index-view-at view i)]
          (when (datom-current-at? db datom-index)
            (return db.datoms[datom-index].e true)))
        (set! i (+ i 1)))))
  (return 0 false))

(defn resolve-lookup-ref-checked [db: DB, attr: string, value: Value] -> [e: u64, ok: bool, error: string]
  (when (not (schema-unique? db attr))
    (return 0 false "lookup ref attribute must be unique"))
  (let [[entity found] (resolve-lookup-ref db attr value)]
    (if found
      (return entity true "")
      (return 0 false "lookup ref not found"))))

(defn current-value-exists? [db: DB, entity: u64, attr: string, value: Value] -> bool
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v value))
          (return true)))
      (set! i (+ i 1))))
  false)

(defn current-attr-exists? [db: DB, entity: u64, attr: string] -> bool
  (when (reverse-attr? attr)
    (let [forward-attr (forward-attr-for-reverse attr) :defer
          view (db-index-view db .VAET)
          target (value-entity entity)
          low (lower-bound-index-view db view "vaet" 0 "" target)
          high (upper-bound-index-view db view "vaet" 0 "" target)
          i low]
      (while (< i high)
        (let [datom-index (db-index-view-at view i)
              datom db.datoms[datom-index]]
          (when (and (= datom.a forward-attr)
                     (datom-current-at? db datom-index))
            (return true)))
        (set! i (+ i 1)))
      (return false)))
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (return true)))
      (set! i (+ i 1))))
  false)

(defn cas-expected-matches? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (if (= expected.kind .Nil)
    (not (current-attr-exists? db entity attr))
    (current-value-exists? db entity attr expected)))

(defn value-debug-str [value: Value] -> string
  (when (= value.kind .Nil)
    (return "nil"))
  (let [[text ok] (value-str value)]
    (if ok text "<value>")))

(defn current-cas-value-str [db: DB, entity: u64, attr: string] -> string
  (let [parts (make [dynamic]string) :defer
        view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (arr.push! parts (value-debug-str datom.v))))
      (set! i (+ i 1)))
    (when (= (count parts) 0)
      (return "nil"))
    (when (= (count parts) 1)
      (return parts[0]))
    (let [[joined _] (core-strings.join (slice parts 0) " ")]
      (core-strings.concatenate ([]string ["(" joined ")"])))))

(defn cas-failed-error [db: DB, entity: u64, attr: string, expected: Value] -> string
  (fmt.tprintf ":db.fn/cas failed on datom [%d %s %s], expected %s"
               entity
               attr
               (current-cas-value-str db entity attr)
               (value-debug-str expected)))

(defn max-entity-id [] -> u64
  (u64 9223372036854775807))

(defn entity-id-valid? [entity: u64] -> bool
  (<= entity (max-entity-id)))

(defn validate-entity-id [entity: u64] -> [ok: bool, error: string]
  (if (entity-id-valid? entity)
    (return true "")
    (return false "entity id exceeds supported range")))

(defn resolve-tx-value [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool, error: string]
  (when (schema-ref-target? db attr)
    (return (resolve-ref-component-value db value)))
  (resolve-tuple-value db attr value))

(defn value-lookup-ref-vector [attr: string, value: Value] -> Value
  (value-vector ([]Value [(value-keyword attr) value])))

(defn resolve-cas-expected [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has-expected-lookup-ref
    (when (not (schema-ref? db data.a))
      (return (value-lookup-ref-vector data.expected-lookup-attr data.expected-lookup-value) true ""))
    (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked db data.expected-lookup-attr data.expected-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.expected false lookup-error))))
  (resolve-tx-value db data.a data.expected))

(defn resolve-tx-data-value [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (when data.has-value-lookup-ref
    (when (not (schema-ref-target? db data.a))
      (return (value-lookup-ref-vector data.value-lookup-attr data.value-lookup-value) true ""))
    (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked db data.value-lookup-attr data.value-lookup-value)]
      (if lookup-ok
        (return (value-entity lookup-e) true "")
        (return data.v false lookup-error))))
  (resolve-tx-value db data.a data.v))

(defn tx-data-has-tempid? [db: DB, tx-data: []Tx-Data, tempid: string] -> bool
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid)
               (not (and (should-split-map-collection? db data)
                         (= (count data.v.items) 0))))
      (return true)))
  false)

(defn ref-string-value? [db: DB, attr: string, value: Value] -> bool
  (when (not (= value.kind .String))
    (return false))
  (schema-ref-target? db attr))

(defn ref-negative-int-value? [db: DB, attr: string, value: Value] -> bool
  (when (not (= value.kind .Int))
    (return false))
  (and (schema-ref-target? db attr)
       (< value.int-value 0)))

(defn ref-tempid-value-text [value: Value] -> string
  (case value.kind
    .String value.text
    .Int (fmt.tprintf "%d" value.int-value)
     ""))

(defn tempid-tuple-component-value [db: DB, tx-data: []Tx-Data, tempid: string, attr: string] -> [value: Value, ok: bool]
  (for [data tx-data]
    (when (and data.has-tempid
               (= data.tempid tempid)
               (= data.op ":db/add")
               (= data.a attr))
      (let [[value value-ok _] (resolve-tx-data-value db data)]
        (return value value-ok))))
  (return (Value {}) false))

(defn tuple-schema-already-seen? [schemas: []string, attr: string] -> bool
  (for [schema-attr schemas]
    (when (= schema-attr attr)
      (return true)))
  false)

(defn tempid-tuple-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false
        seen (make [dynamic]string)]
    (defer (delete seen))
    (for [data tx-data]
      (when (not (and data.has-tempid
                      (= data.tempid tempid)
                      (= data.op ":db/add")))
        (continue))
      (let [schemas (tuple-schemas-containing db data.a)]
        (defer (delete schemas))
        (for [schema schemas]
          (when (and (schema-unique-identity? db schema.attr)
                     (not (tuple-schema-already-seen? (slice seen 0) schema.attr)))
            (arr.push! seen schema.attr)
            (let [items (make [dynamic]Value 0 (count schema.attrs))
                  complete true]
              (for [component schema.attrs]
                (let [[value value-ok] (tempid-tuple-component-value db tx-data tempid component)]
                  (if value-ok
                    (arr.push! items value)
                    (set! complete false))))
              (when complete
                (let [tuple-value (value-vector (slice items 0))
                      [entity entity-ok] (resolve-lookup-ref db schema.attr tuple-value)]
                  (when entity-ok
                    (when (and has-found (not (= found entity)))
                      (delete items)
                      (delete schema.attrs)
                      (return found false true))
                    (set! found entity)
                    (set! has-found true))))
              (delete items)))
          (delete schema.attrs))))
    (return found has-found false)))

(defn tempid-upsert-entity [db: DB, tx-data: []Tx-Data, tempid: string] -> [e: u64, ok: bool, conflict: bool]
  (let [found: u64 0
        has-found false]
    (for [data tx-data]
      (when (and data.has-tempid
                 (= data.tempid tempid)
                 (= data.op ":db/add")
                 (schema-unique-identity? db data.a))
        (let [[value value-ok _] (resolve-tx-data-value db data)]
          (when value-ok
            (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
              (when entity-ok
                (when (and has-found (not (= found entity)))
                  (return found false true))
                (set! found entity)
                (set! has-found true)))))))
    (let [[tuple-e tuple-ok tuple-conflict] (tempid-tuple-upsert-entity db tx-data tempid)]
      (when tuple-conflict
        (return found false true))
      (when tuple-ok
        (when (and has-found (not (= found tuple-e)))
          (return found false true))
        (set! found tuple-e)
        (set! has-found true)))
    (return found has-found false)))

(defn current-tx-upsert-conflict? [db: DB, data: Tx-Data, current-tx-e: u64] -> bool
  (when (not (and (= data.op ":db/add")
                  (schema-unique-identity? db data.a)))
    (return false))
  (let [[value value-ok _] (resolve-tx-data-value db data)]
    (when (not value-ok)
      (return false))
    (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
      (and entity-ok (not (= entity current-tx-e))))))

(defn remap-resolved-tempids! [tempids: ^[dynamic]Tempid, from: u64, to: u64]
  (when (= from to)
    (return))
  (for [entry index tempids^]
    (when (= entry.e from)
      (set! tempids^[index] (Tempid {tempid: entry.tempid e: to})))))

(defn remap-resolved-ops! [ops: ^[dynamic]Tx-Op, from: u64, to: u64]
  (when (= from to)
    (return))
  (for [op index ops^]
    (let [next op]
      (when (= next.e from)
        (set! next.e to))
      (when (and (= next.v.kind .Entity)
                 (= next.v.entity from))
        (set! next.v (value-entity to)))
      (set! ops^[index] next))))

(defn remap-resolved-tempid-entity! [ops: ^[dynamic]Tx-Op, tempids: ^[dynamic]Tempid, from: u64, to: u64]
  (remap-resolved-ops! ops from to)
  (remap-resolved-tempids! tempids from to))

(defn resolved-tempid-lookup [index: (ptr (map string u64)), tempid: string] -> [e: u64, ok: bool]
  (mmap.get index^ tempid))

(defn push-resolved-tempid! [tempids: ^[dynamic]Tempid, index: (ptr (map string u64)), tempid: string, e: u64]
  (arr.push! tempids^ (Tempid {tempid: tempid e: e}))
  (mmap.assoc! index^ tempid e))

(defn ensure-resolved-tempid! [tempids: ^[dynamic]Tempid, index: (ptr (map string u64)), tempid: string, e: u64]
  (let [[_ ok] (resolved-tempid-lookup index tempid)]
    (when (not ok)
      (push-resolved-tempid! tempids index tempid e))))

(defn remap-resolved-tempid-entity-indexed! [ops: ^[dynamic]Tx-Op, tempids: ^[dynamic]Tempid, index: (ptr (map string u64)), from: u64, to: u64]
  (when (= from to)
    (return))
  (remap-resolved-ops! ops from to)
  (for [entry item-index tempids^]
    (when (= entry.e from)
      (set! tempids^[item-index] (Tempid {tempid: entry.tempid e: to}))
      (mmap.assoc! index^ entry.tempid to))))

(defn tempid-existing-upsert-target [db: DB, data: Tx-Data, existing: u64] -> [target: u64, ok: bool, conflict: bool]
  (when (not (and (= data.op ":db/add")
                  (schema-unique-identity? db data.a)))
    (return existing false false))
  (let [[value value-ok _] (resolve-tx-data-value db data)]
    (when (not value-ok)
      (return existing false false))
    (let [[entity entity-ok] (resolve-lookup-ref db data.a value)]
      (when (not entity-ok)
        (return existing false false))
      (when (= entity existing)
        (return existing false false))
      (return entity true false))))

(defn db-with-resolved-ops [db: DB, ops: []Tx-Op] -> DB
  (let [datoms (clone-datoms db.datoms)]
    (for [op ops]
      (arr.push! datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (build-db datoms)))

(defn latest-attr-value [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        latest-index -1
        latest (Value {})]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)]
        (when (and (datom-current-at? db datom-index)
                   (> datom-index latest-index))
          (set! latest-index datom-index)
          (set! latest db.datoms[datom-index].v))))
    (return latest (>= latest-index 0))))

(defn eavt-ea-prefix-compare-direct [db: DB, datom-index: int, entity: u64, attr: string] -> int
  (let [datom db.datoms[datom-index]]
    (if (< datom.e entity)
      -1
      (if (> datom.e entity)
        1
        (strings.compare datom.a attr)))))

(defn lower-bound-eavt-ea-direct [db: DB, indexes: []int, entity: u64, attr: string] -> int
  (let [low 0
        high (count indexes)]
    (while (< low high)
      (let [mid (/ (+ low high) 2)
            compare (eavt-ea-prefix-compare-direct db indexes[mid] entity attr)]
        (if (< compare 0)
          (set! low (+ mid 1))
          (set! high mid))))
    low))

(defn eavt-entity-range [db: DB, entity: u64] -> [low: int, high: int, ok: bool]
  (let [view (db-index-view db .EAVT)
        values ([]Value [(value-entity entity)])
        range-low (lower-bound-index-view-values db view values)
        range-high (upper-bound-index-view-values db view values)]
    (if (> range-high range-low)
      (return range-low range-high true)
      (return 0 0 false))))

(defn eavt-entity-attr-position [db: DB, entity: u64, attr: string] -> [pos: int, ok: bool]
  (let [[low high range-ok] (eavt-entity-range db entity)]
    (when (not range-ok)
      (return 0 false))
    (let [view (db-index-view db .EAVT)
          i low]
      (while (< i high)
        (let [datom db.datoms[(db-index-view-at view i)]
              compare (strings.compare datom.a attr)]
          (cond
            (= compare 0) (return i true)
            (> compare 0) (return 0 false)
            :else (set! i (+ i 1)))))
      (return 0 false))))

(defn current-cardinality-one-int-value-fast [db: DB, entity: u64, attr: string] -> [value: i64, ok: bool]
  (let [view (db-index-view db .EAVT)
        [index-pos pos-ok] (eavt-entity-attr-position db entity attr)]
    (when (not pos-ok)
      (return 0 false))
    (let [datom-index (db-index-view-at view index-pos)
          datom db.datoms[datom-index]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (= datom.v.kind .Int)
                 (datom-current-at? db datom-index))
        (return datom.v.int-value true))
      (return 0 false))))

(defn cardinality-one-int-value-fast-all-current [db: DB, entity: u64, attr: string] -> [value: i64, ok: bool]
  (let [view (db-index-view db .EAVT)
        [index-pos pos-ok] (eavt-entity-attr-position db entity attr)]
    (when (not pos-ok)
      (return 0 false))
    (let [datom db.datoms[(db-index-view-at view index-pos)]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (= datom.v.kind .Int))
        (return datom.v.int-value true))
      (return 0 false))))

(defn current-cardinality-one-value-fast [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [view (db-index-view db .EAVT)
        [index-pos pos-ok] (eavt-entity-attr-position db entity attr)]
    (when (not pos-ok)
      (return (Value {}) false))
    (let [datom-index (db-index-view-at view index-pos)
          datom db.datoms[datom-index]]
      (when (and (= datom.e entity)
                 (= datom.a attr)
                 (datom-current-at? db datom-index))
        (return datom.v true))
      (return (Value {}) false))))

(defn cardinality-one-value-fast-all-current [db: DB, entity: u64, attr: string] -> [value: Value, ok: bool]
  (let [view (db-index-view db .EAVT)
        [index-pos pos-ok] (eavt-entity-attr-position db entity attr)]
    (when (not pos-ok)
      (return (Value {}) false))
    (let [datom db.datoms[(db-index-view-at view index-pos)]]
      (when (and (= datom.e entity)
                 (= datom.a attr))
        (return datom.v true))
      (return (Value {}) false))))

(defn current-cardinality-one-value-matches-fast? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (let [[value ok] (current-cardinality-one-value-fast db entity attr)]
    (and ok (value-equal? value expected))))

(defn cardinality-one-value-matches-fast-all-current? [db: DB, entity: u64, attr: string, expected: Value] -> bool
  (let [[value ok] (cardinality-one-value-fast-all-current db entity attr)]
    (and ok (value-equal? value expected))))

(defn tuple-value-for-entity [db: DB, entity: u64, attrs: []string] -> [value: Value, ok: bool]
  (let [items (make [dynamic]Value 0 (count attrs))
        any false]
    (for [attr attrs]
      (let [[value found] (latest-attr-value db entity attr)]
        (if found
          (do
            (set! any true)
            (arr.push! items value))
          (arr.push! items (value-nil)))))
    (when (not any)
      (delete items)
      (return (Value {}) false))
    (let [out (value-vector (slice items 0))]
      (delete items)
      (return out true))))

(defn remove-derived-tuple-adds! [ops: ^[dynamic]Tx-Op, entity: u64, attr: string, map-group: string]
  (when (= (count map-group) 0)
    (return))
  (let [index (- (count ops^) 1)]
    (while (>= index 0)
      (let [op ops^[index]]
        (when (and op.derived
                   (= op.kind .Add)
                   (= op.e entity)
                   (= op.a attr)
                   (= op.map-group map-group))
          (arr.remove-ordered-at! ops^ index))
        (set! index (- index 1))))))

(defn append-tuple-maintenance-ops! [out: ^[dynamic]Tx-Op, db: DB, op: Tx-Op]
  (when (= op.a ":db/tupleAttrs")
    (return))
  (let [schemas (tuple-schemas-containing db op.a)]
    (defer (delete schemas))
    (for [schema schemas]
      (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice schema.attrs 0))]
        (if has-value
          (do
            (remove-derived-tuple-adds! out op.e schema.attr op.map-group)
            (let [derived (tx-add-derived op.e schema.attr tuple-value)]
              (set! derived.map-group op.map-group)
              (arr.push! out^ derived)))
          (append-retract-attr-ops! out db op.e schema.attr)))
      (delete schema.attrs))))

(defn direct-tuple-add-matches? [db: DB, op: Tx-Op] -> bool
  (when (not (= op.kind .Add))
    (return false))
  (let [tuple-attrs (schema-tuple-attrs db op.a)]
    (defer (delete tuple-attrs))
    (when (= (count tuple-attrs) 0)
      (return false))
    (let [[tuple-value has-value] (tuple-value-for-entity db op.e (slice tuple-attrs 0))]
      (and has-value (value-equal? tuple-value op.v)))))

(defn db-has-tuple-schema? [db: DB] -> bool
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (return true)))))
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/valueType" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/valueType" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (= datom.v.text ":db.type/tuple"))
          (return true)))))
  false)

(defn op-modifies-tuple-schema? [op: Tx-Op] -> bool
  (and (= op.kind .Add)
       (or (= op.a ":db/tupleAttrs")
           (and (= op.a ":db/valueType")
                (= op.v.kind .Keyword)
                (= op.v.text ":db.type/tuple")))))

(defn ops-modify-tuple-schema? [ops: []Tx-Op] -> bool
  (for [op ops]
    (when (op-modifies-tuple-schema? op)
      (return true)))
  false)

(defn expand-tuple-ops [db: DB, ops: []Tx-Op] -> [dynamic]Tx-Op
  (when (and (not (db-has-tuple-schema? db))
             (not (ops-modify-tuple-schema? ops)))
    (let [owned-ops (arr.into [dynamic]Tx-Op ops)]
      (return owned-ops)))
  (let [out (make [dynamic]Tx-Op 0 (count ops))
        whole-tx-db (db-with-resolved-ops db ops)]
    (for [op ops]
      (let [direct-tuple-matches (or (direct-tuple-add-matches? whole-tx-db op)
                                     (and op.tuple-identity
                                          (direct-tuple-add-matches? db op)))]
        (when direct-tuple-matches
          (continue)))
      (arr.push! out op)
      (let [scratch (db-with-resolved-ops db (slice out 0))]
        (append-tuple-maintenance-ops! (addr out) scratch op)
        (delete-owned-db scratch)))
    (delete-owned-db whole-tx-db)
    out))

(defn lookup-ref-vector-value? [value: Value] -> bool
  (and (= value.kind .Vector)
       (= (count value.items) 2)
       (= value.items[0].kind .Keyword)))

(defn tx-map-db-id [map-value: Value] -> [value: Value, ok: bool]
  (when (not (= map-value.kind .Map))
    (return (Value {}) false))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (when (and (= map-value.items[index].kind .Keyword)
                 (= map-value.items[index].text ":db/id"))
        (return map-value.items[(+ index 1)] true))
      (set! index (+ index 2))))
  (return (Value {}) false))

(defn nested-entity-ref-data [map-value: Value, generated-tempid: string] -> [data: Tx-Data, ok: bool, error: string]
  (let [[id-value has-id] (tx-map-db-id map-value)]
    (when (not has-id)
      (return (Tx-Data {tempid: generated-tempid has-tempid: true}) true ""))
    (case id-value.kind
      .Entity (return (Tx-Data {e: id-value.entity}) true "")
      .Int (if (< id-value.int-value 0)
             (return (Tx-Data {tempid: (fmt.tprintf "%d" id-value.int-value) has-tempid: true}) true "")
             (return (Tx-Data {e: (u64 id-value.int-value)}) true ""))
      .String (return (Tx-Data {tempid: id-value.text has-tempid: true}) true "")
      .Keyword (return (Tx-Data {ident: id-value.text has-ident: true}) true "")
      .Vector
        (if (lookup-ref-vector-value? id-value)
          (return (Tx-Data {lookup-attr: id-value.items[0].text
                            lookup-value: id-value.items[1]
                            has-lookup-ref: true}) true "")
          (return (Tx-Data {}) false "nested map :db/id vector must be a lookup ref"))
       (return (Tx-Data {}) false "nested map :db/id must be int, entity, tempid string, ident keyword, or lookup ref"))))

(defn tx-add-from-entity-data [entity: Tx-Data, attr: string, value: Value] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid entity.tempid attr value)
    entity.has-lookup-ref (add-lookup-ref entity.lookup-attr entity.lookup-value attr value)
    entity.has-ident (add-ident entity.ident attr value)
    :else (add entity.e attr value)))

(defn tx-add-value-tempid-from-entity-data [entity: Tx-Data, attr: string, value-tempid: string] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-value-tempid entity.tempid attr value-tempid)
    entity.has-lookup-ref (add-lookup-ref-value-tempid entity.lookup-attr entity.lookup-value attr value-tempid)
    entity.has-ident (add-ident-value-tempid entity.ident attr value-tempid)
    :else (add-value-tempid entity.e attr value-tempid)))

(defn tx-add-value-lookup-from-entity-data [entity: Tx-Data, attr: string, lookup-attr: string, lookup-value: Value] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-value-lookup-ref entity.tempid attr lookup-attr lookup-value)
    entity.has-lookup-ref (Tx-Data {op: ":db/add"
                                    lookup-attr: entity.lookup-attr
                                    lookup-value: entity.lookup-value
                                    has-lookup-ref: true
                                    a: attr
                                    value-lookup-attr: lookup-attr
                                    value-lookup-value: lookup-value
                                    has-value-lookup-ref: true})
    entity.has-ident (Tx-Data {op: ":db/add"
                               ident: entity.ident
                               has-ident: true
                               a: attr
                               value-lookup-attr: lookup-attr
                               value-lookup-value: lookup-value
                               has-value-lookup-ref: true})
    :else (add-value-lookup-ref entity.e attr lookup-attr lookup-value)))

(defn tx-add-nested-map-from-entity-data [entity: Tx-Data, attr: string, nested-map: Value, nested-tempid: string] -> Tx-Data
  (cond
    entity.has-tempid (add-tempid-nested-map entity.tempid attr nested-map nested-tempid)
    entity.has-lookup-ref (add-lookup-ref-nested-map entity.lookup-attr entity.lookup-value attr nested-map nested-tempid)
    entity.has-ident (add-ident-nested-map entity.ident attr nested-map nested-tempid)
    :else (add-nested-map entity.e attr nested-map nested-tempid)))

(defn tx-op-with-map-group [op: Tx-Op, map-group: string] -> Tx-Op
  (let [out op]
    (set! out.map-group map-group)
    out))

(defn append-nested-map-value-tx! [pending: ^[dynamic]Tx-Data, entity: Tx-Data, attr: string, value: Value, seed: string]
  (if (= value.kind .Vector)
    (if (lookup-ref-vector-value? value)
      (arr.push! pending^ (tx-data-with-map-group (tx-add-value-lookup-from-entity-data entity attr value.items[0].text value.items[1]) entity.map-group))
      (for [item value.items]
        (append-nested-map-value-tx! pending entity attr item seed)))
    (if (= value.kind .Map)
      (arr.push! pending^ (tx-data-with-map-group (tx-add-nested-map-from-entity-data entity attr value (fmt.tprintf "%s_%d" seed (count pending^))) entity.map-group))
      (arr.push! pending^ (tx-data-with-map-group (tx-add-from-entity-data entity attr value) entity.map-group)))))

(defn append-nested-map-tx! [pending: ^[dynamic]Tx-Data, entity: Tx-Data, map-value: Value, seed: string] -> [ok: bool, error: string]
  (when (not (= map-value.kind .Map))
    (return false "nested tx value must be a map"))
  (let [index 0]
    (while (< (+ index 1) (count map-value.items))
      (let [key map-value.items[index]
            value map-value.items[(+ index 1)]]
        (when (not (= key.kind .Keyword))
          (return false "nested tx map attributes must be keywords"))
        (when (not (= key.text ":db/id"))
          (append-nested-map-value-tx! pending entity key.text value seed)))
      (set! index (+ index 2))))
  (return true ""))

(defn tx-entity-ref-from-data [data: Tx-Data] -> Tx-Data
  (Tx-Data {e: data.e
            tempid: data.tempid
            has-tempid: data.has-tempid
            lookup-attr: data.lookup-attr
            lookup-value: data.lookup-value
            has-lookup-ref: data.has-lookup-ref
            ident: data.ident
            has-ident: data.has-ident
            map-group: data.map-group}))

(defn append-map-collection-items! [pending: ^[dynamic]Tx-Data, data: Tx-Data, db: DB]
  (when (not (or (= data.v.kind .Vector)
                 (= data.v.kind .Set)))
    (return))
  (let [entity (tx-entity-ref-from-data data)
        ref-attr (schema-ref-target? db data.a)]
    (for [item index data.v.items]
      (if (and ref-attr (lookup-ref-vector-value? item))
        (arr.push! pending^ (tx-data-with-map-group (tx-add-value-lookup-from-entity-data entity data.a item.items[0].text item.items[1]) data.map-group))
        (if (and ref-attr (= item.kind .Map))
          (arr.push! pending^ (tx-data-with-map-group (tx-add-nested-map-from-entity-data entity data.a item (fmt.tprintf "vev_tx_map_%d" (+ (count pending^) index))) data.map-group))
          (arr.push! pending^ (tx-data-with-map-group (tx-add-from-entity-data entity data.a item) data.map-group)))))))

(defn should-split-map-collection? [db: DB, data: Tx-Data] -> bool
  (when (not (and data.from-map-collection
                  (= data.op ":db/add")
                  (or (= data.v.kind .Vector)
                      (= data.v.kind .Set))))
    (return false))
  ;; EDN sets are unambiguously transaction collections; vectors may instead
  ;; be tuple values or lookup refs and still require schema disambiguation.
  (when (= data.v.kind .Set)
    (return true))
  (if (reverse-attr? data.a)
    (let [schema-attr (forward-attr-for-reverse data.a)]
      (defer (delete schema-attr))
      (let [tuple-attrs (schema-tuple-attrs db schema-attr)]
        (defer (delete tuple-attrs))
        (when (> (count tuple-attrs) 0)
          (return false)))
      (return (not (schema-cardinality-one? db schema-attr)))))
  (let [tuple-attrs (schema-tuple-attrs db data.a)]
    (defer (delete tuple-attrs))
    (when (> (count tuple-attrs) 0)
      (return false)))
  (not (schema-cardinality-one? db data.a)))

(defn tx-data-op-known? [op: string] -> bool
  (or (= op ":db/add")
      (= op ":db/retract")
      (= op ":db/retractAttr")
      (= op ":db/retractEntity")
      (= op ":db.fn/cas")
      (= op ":db/cas")))

(defn tx-data-op-needs-attr? [op: string] -> bool
  (not (= op ":db/retractEntity")))

(defn attr-name-valid? [attr: string] -> bool
  (and (strings.has_prefix attr ":")
       (> (count attr) 1)))

(defn validate-tx-data-item [data: Tx-Data] -> [ok: bool, error: string]
  (when (not (tx-data-op-known? data.op))
    (return false "unknown tx op"))
  (when (and data.has-tempid
             (not (= data.op ":db/add")))
    (return false "tempids not allowed outside add"))
  (when (and (tx-data-op-needs-attr? data.op)
             (not (attr-name-valid? data.a)))
    (return false "bad entity attribute"))
  (when (and data.has-lookup-ref
             (not (attr-name-valid? data.lookup-attr)))
    (return false "bad lookup attribute"))
  (when (and data.has-expected-lookup-ref
             (not (attr-name-valid? data.expected-lookup-attr)))
    (return false "bad lookup attribute"))
  (when (and data.has-value-lookup-ref
             (not (attr-name-valid? data.value-lookup-attr)))
    (return false "bad lookup attribute"))
  (return true ""))

(defn tx-data-modifies-validation-schema? [data: Tx-Data] -> bool
  (or (= data.a ":db/ident")
      (= data.a ":db/valueType")
      (= data.a ":db/cardinality")
      (= data.a ":db/unique")
      (= data.a ":db/tupleAttrs")
      (= data.a ":db/index")
      (= data.a ":db/isComponent")))

(defn direct-tx-data-item? [db: DB, data: Tx-Data] -> bool
  (when (not (or (= data.op ":db/add")
                 (= data.op ":db/retract")))
    (return false))
  (when (or data.has-tempid
            data.has-lookup-ref
            data.has-ident
            data.has-expected-lookup-ref
            data.has-value-tempid
            data.has-value-lookup-ref
            data.has-nested-map
            data.from-map-collection
            (tx-data-modifies-validation-schema? data)
            (current-tx-value? data.v)
            (ref-string-value? db data.a data.v)
            (ref-negative-int-value? db data.a data.v)
            (reverse-attr? data.a))
    (return false))
  true)

(defn direct-tx-data? [db: DB, tx-data: []Tx-Data] -> bool
  (when (db-has-tuple-schema? db)
    (return false))
  (for [data tx-data]
    (when (not (direct-tx-data-item? db data))
      (return false)))
  true)

(defn resolve-direct-tx-data-value [db: DB, data: Tx-Data] -> [resolved: Value, ok: bool, error: string]
  (if (schema-ref-target? db data.a)
    (resolve-ref-component-value db data.v)
    (return data.v true "")))

(defn resolve-direct-tx-data-for-tx [db: DB, tx-data: []Tx-Data] -> Resolved-Tx
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)]
    (for [data tx-data]
      (let [[shape-ok shape-error] (validate-tx-data-item data)]
        (when (not shape-ok)
          (return (Resolved-Tx {ok: false
                                error: shape-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids}))))
      (let [[value value-ok value-error] (resolve-direct-tx-data-value db data)]
        (when (not value-ok)
          (return (Resolved-Tx {ok: false
                                error: value-error
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (if (= data.op ":db/retract")
          (arr.push! resolved-ops (tx-retract data.e data.a value))
          (arr.push! resolved-ops (tx-add data.e data.a value)))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn resolve-tx-data-for-tx [db: DB, tx-data: []Tx-Data, tx: u64] -> Resolved-Tx
  (when (direct-tx-data? db tx-data)
    (return (resolve-direct-tx-data-for-tx db tx-data)))
  (let [resolved-ops (make [dynamic]Tx-Op 0 (count tx-data))
        resolved-meta (make [dynamic]Tx-Meta)
        resolved-tempids (make [dynamic]Tempid)
        tempid-index (make (map string u64))
        pending (arr.into [dynamic]Tx-Data tx-data)
        next-e (next-entity-id (slice db.datoms 0))
        current-tx-e tx
        current-tx-reserved false
        data-index 0]
    (defer (delete tempid-index))
    (defer (delete pending))
    (for [data pending]
      (when (and (not data.has-tempid)
                 (not data.has-lookup-ref)
                 (not data.has-ident)
                 (>= data.e next-e))
        (set! next-e (+ data.e 1))))
    (while (< data-index (count pending))
      (let [data pending[data-index]
            current-db (db-with-resolved-ops db (slice resolved-ops 0))
            e data.e
            skip-data false]
        (set! data-index (+ data-index 1))
        (let [[shape-ok shape-error] (validate-tx-data-item data)]
          (when (not shape-ok)
            (return (Resolved-Tx {ok: false
                                  error: shape-error
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids}))))
        (when data.has-tempid
          (if (current-tx-tempid? data.tempid)
            (do
              (when (not current-tx-reserved)
                (set! current-tx-reserved true))
              (set! e current-tx-e)
              (ensure-resolved-tempid! (addr resolved-tempids) (addr tempid-index) data.tempid current-tx-e)
              (when (current-tx-upsert-conflict? current-db data current-tx-e)
                (return (Resolved-Tx {ok: false
                                      error: "conflicting upsert"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))
              (when (= data.op ":db/add")
                (arr.push! resolved-meta (Tx-Meta {a: data.a v: data.v}))))
          (let [[existing ok] (resolved-tempid-lookup (addr tempid-index) data.tempid)]
            (if ok
              (let [[target target-ok _] (tempid-existing-upsert-target current-db data existing)]
                (if target-ok
                  (if (entity-exists? db existing)
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids}))
                    (do
                      (remap-resolved-tempid-entity-indexed! (addr resolved-ops) (addr resolved-tempids) (addr tempid-index) existing target)
                      (set! e target)))
                  (set! e existing)))
              (do
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db (slice pending 0) data.tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (set! e upsert-e)
                    (do
                      (set! e next-e)
                      (set! next-e (+ next-e 1)))))
                (push-resolved-tempid! (addr resolved-tempids) (addr tempid-index) data.tempid e))))))
        (when data.has-lookup-ref
          (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked current-db data.lookup-attr data.lookup-value)]
            (if lookup-ok
              (set! e lookup-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: lookup-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
                (if (= lookup-error "lookup ref not found")
                  (set! skip-data true)
                  (return (Resolved-Tx {ok: false
                                        error: lookup-error
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids})))))))
        (when skip-data
          (continue))
        (when (should-split-map-collection? current-db data)
          (append-map-collection-items! (addr pending) data current-db)
          (continue))
        (when (and (reverse-attr? data.a)
                   (not (schema-ref-target? current-db data.a)))
          (return (Resolved-Tx {ok: false
                                error: "reverse attribute requires ref schema"
                                ops: resolved-ops
                                tx-meta: resolved-meta
                                tempids: resolved-tempids})))
        (when data.has-ident
          (let [[ident-e ident-ok] (schema-entity-for-attr current-db data.ident)]
            (if ident-ok
              (set! e ident-e)
              (if (= data.op ":db/add")
                (return (Resolved-Tx {ok: false
                                      error: "ident not found"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
                (set! skip-data true)))))
        (when skip-data
          (continue))
        (when data.has-nested-map
          (if (schema-ref-target? current-db data.a)
            (let [[nested-entity nested-ok nested-error] (nested-entity-ref-data data.nested-map data.nested-tempid)]
              (when (not nested-ok)
                (return (Resolved-Tx {ok: false
                                      error: nested-error
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids})))
              (let [[children-ok children-error] (append-nested-map-tx! (addr pending) nested-entity data.nested-map data.nested-tempid)]
                (when (not children-ok)
                  (return (Resolved-Tx {ok: false
                                        error: children-error
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids}))))
              (set! data.has-nested-map false)
              (let [nested-assigned false]
                (when nested-entity.has-tempid
                  (set! data.has-value-tempid true)
                  (set! data.value-tempid nested-entity.tempid)
                  (set! nested-assigned true))
                (when (and (not nested-assigned) nested-entity.has-lookup-ref)
                  (set! data.has-value-lookup-ref true)
                  (set! data.value-lookup-attr nested-entity.lookup-attr)
                  (set! data.value-lookup-value nested-entity.lookup-value)
                  (set! nested-assigned true))
                (when (and (not nested-assigned) nested-entity.has-ident)
                  (set! data.v (value-keyword nested-entity.ident))
                  (set! nested-assigned true))
                (when (not nested-assigned)
                  (set! data.v (value-entity nested-entity.e)))))
            (do
              (set! data.v data.nested-map)
              (set! data.has-nested-map false))))
        (when (or (= data.op ":db/retract")
                  (= data.op ":db/retractAttr"))
          (let [tuple-attrs (schema-tuple-attrs current-db data.a) :defer]
            (when (> (count tuple-attrs) 0)
              (return (Resolved-Tx {ok: false
                                    error: "cannot modify tuple attrs directly"
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))))
        (when (and (= data.op ":db/add")
                   (not data.has-tempid)
                   (not data.has-lookup-ref)
                   (not data.has-ident)
                   (schema-unique-identity? current-db data.a))
          (let [[identity-value identity-ok _] (resolve-tx-data-value current-db data)]
            (when identity-ok
              (let [[identity-e identity-found] (resolve-lookup-ref current-db data.a identity-value)]
                (when (and identity-found (not (= identity-e e)))
                  (return (Resolved-Tx {ok: false
                                        error: "conflicting upsert"
                                        ops: resolved-ops
                                        tx-meta: resolved-meta
                                        tempids: resolved-tempids})))))))
        (when (= data.op ":db/retractEntity")
          (append-retract-entity-ops! (addr resolved-ops) current-db e)
          (continue))
        (when (= data.op ":db/retractAttr")
          (append-retract-attr-ops! (addr resolved-ops) current-db e data.a)
          (continue))
        (when (= data.op ":db.fn/cas")
          (let [[expected expected-ok expected-error] (resolve-cas-expected current-db data)]
            (when (not expected-ok)
              (return (Resolved-Tx {ok: false
                                    error: expected-error
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))
            (when (not (cas-expected-matches? current-db e data.a expected))
              (return (Resolved-Tx {ok: false
                                    error: (cas-failed-error current-db e data.a expected)
                                    ops: resolved-ops
                                    tx-meta: resolved-meta
                                    tempids: resolved-tempids})))))
        (let [v data.v
              value-ok true
              value-error ""]
          (when (and (not (current-tx-value? v))
                     (not (ref-negative-int-value? current-db data.a v)))
            (let [[resolved resolved-ok resolved-error] (resolve-tx-value current-db data.a data.v)]
              (set! v resolved)
              (set! value-ok resolved-ok)
              (set! value-error resolved-error)))
          (when data.has-value-lookup-ref
            (if (not (schema-ref-target? current-db data.a))
              (set! v (value-lookup-ref-vector data.value-lookup-attr data.value-lookup-value))
              (let [[lookup-e lookup-ok lookup-error] (resolve-lookup-ref-checked current-db data.value-lookup-attr data.value-lookup-value)]
                (if lookup-ok
                  (set! v (value-entity lookup-e))
                  (if (and (= data.op ":db/retract")
                           (= lookup-error "lookup ref not found"))
                    (set! skip-data true)
                    (return (Resolved-Tx {ok: false
                                          error: lookup-error
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))))))
          (when skip-data
            (continue))
          (when (current-tx-value? v)
            (let [current-tx-tempid v.text]
              (when (not current-tx-reserved)
                (set! current-tx-reserved true))
              (set! v (value-entity current-tx-e))
              (ensure-resolved-tempid! (addr resolved-tempids) (addr tempid-index) current-tx-tempid current-tx-e)))
          (when (or data.has-value-tempid
                    (ref-string-value? current-db data.a v)
                    (ref-negative-int-value? current-db data.a v))
            (let [value-tempid data.value-tempid]
              (when (not data.has-value-tempid)
                (set! value-tempid (ref-tempid-value-text v)))
              (if (current-tx-tempid? value-tempid)
                (do
                  (when (not current-tx-reserved)
                    (set! current-tx-reserved true))
                  (set! v (value-entity current-tx-e))
                  (ensure-resolved-tempid! (addr resolved-tempids) (addr tempid-index) value-tempid current-tx-e))
              (if (not (tx-data-has-tempid? current-db (slice pending 0) value-tempid))
                (return (Resolved-Tx {ok: false
                                      error: "tempid used only as value"
                                      ops: resolved-ops
                                      tx-meta: resolved-meta
                                      tempids: resolved-tempids}))
              (let [[existing ok] (resolved-tempid-lookup (addr tempid-index) value-tempid)]
              (if ok
                (set! v (value-entity existing))
                (let [[upsert-e upsert-ok upsert-conflict] (tempid-upsert-entity current-db (slice pending 0) value-tempid)]
                  (when upsert-conflict
                    (return (Resolved-Tx {ok: false
                                          error: "conflicting upsert"
                                          ops: resolved-ops
                                          tx-meta: resolved-meta
                                          tempids: resolved-tempids})))
                  (if upsert-ok
                    (do
                      (set! v (value-entity upsert-e))
                      (push-resolved-tempid! (addr resolved-tempids) (addr tempid-index) value-tempid upsert-e))
                    (do
                      (set! v (value-entity next-e))
                      (push-resolved-tempid! (addr resolved-tempids) (addr tempid-index) value-tempid next-e)
                      (set! next-e (+ next-e 1)))))))))))
          (when (not value-ok)
            (return (Resolved-Tx {ok: false
                                  error: value-error
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids})))
        (if (reverse-attr? data.a)
          (if (= v.kind .Entity)
            (let [forward-attr (forward-attr-for-reverse data.a)]
              (if (= data.op ":db/retract")
                (arr.push! resolved-ops (tx-op-with-map-group (tx-retract v.entity forward-attr (value-entity e)) data.map-group))
                (arr.push! resolved-ops (tx-op-with-map-group (tx-add v.entity forward-attr (value-entity e)) data.map-group))))
            (return (Resolved-Tx {ok: false
                                  error: "reverse ref value must resolve to entity"
                                  ops: resolved-ops
                                  tx-meta: resolved-meta
                                  tempids: resolved-tempids})))
          (if (= data.op ":db/retract")
            (arr.push! resolved-ops (tx-op-with-map-group (tx-retract e data.a v) data.map-group))
            (let [op (tx-add e data.a v)]
              (when data.has-tempid
                (set! op.tuple-identity true))
              (when data.has-lookup-ref
                (let [lookup-tuple-attrs (schema-tuple-attrs current-db data.lookup-attr) :defer]
                  (when (> (count lookup-tuple-attrs) 0)
                    (set! op.tuple-identity true))))
              (set! op.map-group data.map-group)
              (arr.push! resolved-ops op)))))))
    (Resolved-Tx {ok: true error: "" ops: resolved-ops tx-meta: resolved-meta tempids: resolved-tempids})))

(defn validate-add-op [db: DB, op: Tx-Op] -> [ok: bool, error: string]
  (when (= op.v.kind .Nil)
    (return false "cannot store nil"))
  (when (and (= op.a ":db/tupleAttrs")
             (not (and (valid-tuple-attr-target? db op.e)
                       (valid-tuple-attrs-value? db op.v))))
    (return false "invalid tuple schema"))
  (when (not op.derived)
    (let [tuple-attrs (schema-tuple-attrs db op.a)]
      (defer (delete tuple-attrs))
      (when (> (count tuple-attrs) 0)
        (return false "cannot modify tuple attrs directly"))))
  (let [[schema-type has-type] (mmap.get db.schema-value-types op.a)]
    (when (and has-type (not (value-matches-schema-type? op.v schema-type)))
      (return false "schema value type mismatch")))
  (return true ""))

(defn validate-op-entity-ids [op: Tx-Op] -> [ok: bool, error: string]
  (let [[entity-ok entity-error] (validate-entity-id op.e)]
    (when (not entity-ok)
      (return false entity-error)))
  (when (= op.v.kind .Entity)
    (let [[value-ok value-error] (validate-entity-id op.v.entity)]
      (when (not value-ok)
        (return false value-error))))
  (return true ""))

(defn op-modifies-validation-schema? [op: Tx-Op] -> bool
  (or (= op.a ":db/ident")
      (= op.a ":db/valueType")
      (= op.a ":db/cardinality")
      (= op.a ":db/unique")
      (= op.a ":db/tupleAttrs")
      (= op.a ":db/index")
      (= op.a ":db/isComponent")))

(defn ops-require-incremental-validation? [before: DB, ops: []Tx-Op] -> bool
  (for [op ops]
    (when (op-modifies-validation-schema? op)
      (return true)))
  false)

(defn ops-modify-validation-schema? [ops: []Tx-Op] -> bool
  (for [op ops]
    (when (op-modifies-validation-schema? op)
      (return true)))
  false)

(defn unique-op-value-key [op: Tx-Op] -> [key: string, ok: bool]
  (if (= op.v.kind .Vector)
    (let [[value-key value-ok] (row-values-dedupe-key (slice op.v.items 0))]
      (when (not value-ok)
        (return "" false))
      (return (fmt.tprintf "%d:%s:%d:%s" (count op.a) op.a (count value-key) value-key) true))
    (let [[value-key value-ok] (primitive-value-dedupe-key op.v)]
      (when (not value-ok)
        (return "" false))
      (return (fmt.tprintf "%d:%s:%d:%s" (count op.a) op.a (count value-key) value-key) true))))

(defn validate-final-schema-db [scratch: DB] -> [ok: bool, error: string]
  (let [[ok error] (validate-tuple-schema scratch)]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-ident-values scratch)]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-schema-keyword-values scratch ":db/valueType")]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-schema-keyword-values scratch ":db/cardinality")]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-schema-keyword-values scratch ":db/unique")]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-unique-schema-values scratch)]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-schema-bool-values scratch ":db/index")]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-schema-bool-values scratch ":db/isComponent")]
    (when (not ok)
      (return false error)))
  (let [[ok error] (validate-component-schema scratch)]
    (when (not ok)
      (return false error)))
  (return true ""))

(defn validate-final-schema [scratch-datoms: []Datom] -> [ok: bool, error: string]
  (let [scratch-owned (arr.into [dynamic]Datom scratch-datoms) :defer
        scratch (build-db scratch-owned)
        [final-ok final-error] (validate-final-schema-db scratch)]
    (return final-ok final-error)))

(defn validate-ops-batch-against-before [before: DB, ops: []Tx-Op] -> [ok: bool, error: string]
  (let [seen-unique (mmap.empty string u64)]
    (defer (delete seen-unique))
  (for [op ops]
    (let [[entity-ok entity-error] (validate-op-entity-ids op)]
      (when (not entity-ok)
        (return false entity-error)))
    (when (= op.kind .Add)
      (let [[ok error] (validate-add-op before op)]
        (when (not ok)
          (return false error)))
      (when (schema-unique? before op.a)
        (when (unique-conflict? before op)
          (let [tuple-attrs (schema-tuple-attrs before op.a) :defer]
            (if (and (not op.tuple-identity)
                     (= (count tuple-attrs) 0)
                     (schema-unique-identity? before op.a))
              (return false "conflicting upsert")
              (return false "schema unique conflict"))))
        (let [[key key-ok] (unique-op-value-key op)]
          (when (not key-ok)
            (return false "schema unique value unsupported"))
          (let [[existing existing-ok] (mmap.get seen-unique key)]
            (when (and existing-ok (not (= existing op.e)))
              (let [tuple-attrs (schema-tuple-attrs before op.a) :defer]
                (if (and (not op.tuple-identity)
                         (= (count tuple-attrs) 0)
                         (schema-unique-identity? before op.a))
                  (return false "conflicting upsert")
                  (return false "schema unique conflict")))))
          (mmap.assoc! seen-unique key op.e))))))
  (return true ""))

(defn validate-tuple-schema [db: DB] -> [ok: bool, error: string]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/valueType" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/valueType" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Keyword)
                   (= datom.v.text ":db.type/tuple"))
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when attr-ok
              (let [tuple-attrs (schema-tuple-attrs db attr)]
                (defer (delete tuple-attrs))
                (when (= (count tuple-attrs) 0)
                  (return false "invalid tuple schema")))))))))
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/tupleAttrs" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (datom-current-at? db datom-index)
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when attr-ok
              (when (not (valid-tuple-attr-target? db datom.e))
                (return false "invalid tuple schema"))
              (when (not (valid-tuple-attrs-value? db datom.v))
                (return false "invalid tuple schema"))
              (let [[value-type has-value-type] (schema-keyword db attr ":db/valueType")]
                (when (and has-value-type (not (= value-type ":db.type/tuple")))
                  (return false "invalid tuple schema")))))))))
  (return true ""))

(defn validate-schema-bool-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 schema-attr (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Bool)))
          (return false "schema boolean value must be boolean")))))
  (return true ""))

(defn validate-ident-values [db: DB] -> [ok: bool, error: string]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/ident" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (= datom.v.kind .Keyword)))
          (return false ":db/ident value must be keyword")))))
  (return true ""))

(defn valid-schema-keyword-value? [schema-attr: string, value: string] -> bool
  (cond
    (= schema-attr ":db/valueType")
      (or (= value ":db.type/string")
          (= value ":db.type/long")
          (= value ":db.type/boolean")
          (= value ":db.type/ref")
          (= value ":db.type/keyword")
          (= value ":db.type/symbol")
          (= value ":db.type/tuple")
          (= value ":db.type/uuid"))
    (= schema-attr ":db/cardinality")
      (or (= value ":db.cardinality/one")
          (= value ":db.cardinality/many"))
    (= schema-attr ":db/unique")
      (or (= value ":db.unique/identity")
          (= value ":db.unique/value"))
    :else true))

(defn validate-schema-keyword-values [db: DB, schema-attr: string] -> [ok: bool, error: string]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 schema-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 schema-attr (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (or (not (= datom.v.kind .Keyword))
                       (not (valid-schema-keyword-value? schema-attr datom.v.text))))
          (return false "invalid schema keyword value")))))
  (return true ""))

(defn validate-unique-schema-values [db: DB] -> [ok: bool, error: string]
  (for [attr db.schema-unique]
    (let [seen (mmap.empty string u64)
          view (db-index-view db .AVET)
          values ([]Value [(value-keyword attr)])
          low (lower-bound-index-view-values db view values)
          high (upper-bound-index-view-values db view values)
          i low]
      (defer (delete seen))
      (while (< i high)
        (let [datom-index (db-index-view-at view i)
              datom db.datoms[datom-index]]
          (when (and (datom-current-at? db datom-index)
                     (= datom.a attr))
            (let [op (datom-add-op datom)
                  [key key-ok] (unique-op-value-key op)]
              (when (not key-ok)
                (return false "schema unique value unsupported"))
              (let [[existing existing-ok] (mmap.get seen key)]
                (when (and existing-ok (not (= existing datom.e)))
                  (delete key)
                  (return false "schema unique conflict")))
              (mmap.assoc! seen key datom.e))))
        (set! i (+ i 1)))))
  (return true ""))

(defn validate-component-schema [db: DB] -> [ok: bool, error: string]
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 ":db/isComponent" (Value {}))
        high (upper-bound-index-view db view "aevt" 0 ":db/isComponent" (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Bool)
                   datom.v.bool-value)
          (let [[attr attr-ok] (schema-ident-for-entity db datom.e)]
            (when (and attr-ok (not (schema-ref? db attr)))
              (return false "invalid component schema")))))))
  (return true ""))

(defn validate-ops [before: DB, ops: []Tx-Op] -> [ok: bool, error: string]
  (when (not (ops-require-incremental-validation? before ops))
    (return (validate-ops-batch-against-before before ops)))
  (let [scratch-datoms (clone-datoms before.datoms)]
    (defer (delete scratch-datoms))
    (for [op ops]
      (let [[entity-ok entity-error] (validate-op-entity-ids op)]
        (when (not entity-ok)
          (return false entity-error)))
      (when (= op.kind .Add)
        (let [scratch-owned (arr.into [dynamic]Datom (slice scratch-datoms 0)) :defer
              scratch (build-db scratch-owned)
              [ok error] (validate-add-op scratch op)]
          (when (not ok)
            (return false error))
          (when (and (schema-unique? scratch op.a)
                     (unique-conflict? scratch op))
            (return false "schema unique conflict"))))
      (arr.push! scratch-datoms
        (Datom {e: op.e
                a: op.a
                v: op.v
                tx: 0
                added: (= op.kind .Add)})))
    (validate-final-schema (slice scratch-datoms 0))))

(defn failed-tx-report [db: DB, error: string] -> Tx-Report
  (Tx-Report {ok: false
              error: (string-owned error)
              db-before: db
              db-after: db
              tx-data: (make [dynamic]Datom)
              tx: 0
              tx-meta: (make [dynamic]Tx-Meta)
              tempids: (make [dynamic]Tempid)
              datom-start-index: 0
              append-only: false
              new-entities-after-existing: false
              publish-plan: (tx-publish-plan-empty 0 0)}))

(defn reset-conn-with-meta [conn: ^Conn, next-db: DB, tx-meta: []Tx-Meta] -> Tx-Report
  (let [before (clone-db conn^.db)
        after (clone-db next-db)
        diff (db-diff before after)
        tx conn^.next-tx
        tx-data (make [dynamic]Datom 0 (+ (count diff.only-left) (count diff.only-right)))]
    (for [datom diff.only-left]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: false})))
    (for [datom diff.only-right]
      (arr.push! tx-data
        (Datom {e: datom.e a: datom.a v: datom.v tx: tx added: true})))
    (delete diff.only-left)
    (delete diff.only-right)
    (delete diff.both)
    (set! conn^.db after)
    (set! conn^.next-tx (+ conn^.next-tx 1))
    (let [report (Tx-Report {ok: true
                             error: (string-owned "")
                             db-before: before
                             db-after: after
                             tx-data: tx-data
                             tx: tx
                             tx-meta: (clone-tx-meta tx-meta)
                             tempids: (make [dynamic]Tempid)
                             datom-start-index: 0
                             append-only: false
                             new-entities-after-existing: false
                             publish-plan: (tx-publish-plan-empty 0 (count tx-data))})]
      (notify-listeners! conn report)
      report)))

(defn reset-conn [conn: ^Conn, next-db: DB] -> Tx-Report
  (reset-conn-with-meta conn next-db ([]Tx-Meta [])))

(defn tx-fn-ok [tx-data: []Tx-Data] -> Tx-Fn-Result
  (let [owned (tx-data-slice-owned tx-data)]
    (Tx-Fn-Result {ok: true
                   error: ""
                   tx-data: owned})))

(defn tx-fn-error [error: string] -> Tx-Fn-Result
  (let [empty (make [dynamic]Tx-Data)]
    (Tx-Fn-Result {ok: false
                   error: error
                   tx-data: empty})))

(defn tx-fn-string [ident: string, f: fn [db: DB, arg: string] -> Tx-Fn-Result] -> Tx-Fn-String
  (Tx-Fn-String {ident: ident f: f}))

(defn tx-fn-values [ident: string, f: fn [db: DB, args: []Value] -> Tx-Fn-Result] -> Tx-Fn-String
  (Tx-Fn-String {ident: ident has-values-fn: true values-f: f}))

(defn tx-fn-string-index [registry: []Tx-Fn-String, ident: string] -> [index: int, ok: bool]
  (for [entry index registry]
    (when (= entry.ident ident)
      (return index true)))
  (return 0 false))

(defn tx-fn-string-duplicate-ident [registry: []Tx-Fn-String] -> [ident: string, found: bool]
  (let [left 0]
    (while (< left (count registry))
      (let [right (+ left 1)]
        (while (< right (count registry))
          (when (= registry[left].ident registry[right].ident)
            (return registry[left].ident true))
          (set! right (+ right 1))))
      (set! left (+ left 1))))
  (return "" false))

(defn current-log-attr-exists? [datoms: []Datom, entity: u64, attr: string] -> bool
  (for [datom index datoms]
    (when (and (= datom.e entity)
               (= datom.a attr)
               (datom-current-in-log? datoms index))
      (return true)))
  false)

(defn current-db-attr-exists? [db: DB, entity: u64, attr: string] -> bool
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)]
        (when (datom-current-at? db datom-index)
          (return true)))))
  false)

(defn entity-attr-key [entity: u64, attr: string] -> string
  (fmt.tprintf "%d:%d:%s" entity (count attr) attr))

(defn entity-attr-seen? [seen: (map string (struct {})), entity: u64, attr: string] -> bool
  (set.contains? seen (entity-attr-key entity attr)))

(defn op-fact-key [op: Tx-Op] -> [key: string, ok: bool]
  (let [[value-key value-ok] (primitive-value-dedupe-key op.v)]
    (when (not value-ok)
      (return "" false))
    (return (fmt.tprintf "%d:%d:%s:%d:%s" op.e (count op.a) op.a (count value-key) value-key) true)))

(defn append-cardinality-one-retractions! [before: DB, seen-ea: (map string (struct {})), after-datoms: ^[dynamic]Datom, tx-data: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (when (not (= op.kind .Add))
    (return))
  (when (not (tx-op-cardinality-one? before op))
    (return))
  (if (entity-attr-seen? seen-ea op.e op.a)
    (let [index (- (count after-datoms^) 1)]
      (while (>= index 0)
        (let [datom after-datoms^[index]]
          (when (and (= datom.e op.e)
                     (= datom.a op.a))
            (when (and datom.added
                       (not (value-equal? datom.v op.v)))
              (let [retract (Datom {e: datom.e
                                    a: datom.a
                                    v: datom.v
                                    tx: tx
                                    added: false})]
                (arr.push! after-datoms^ (datom-owned retract))
                (arr.push! tx-data^ (datom-owned retract))))
            (return)))
        (set! index (- index 1))))
    (do
      (when (not (current-db-attr-exists? before op.e op.a))
        (return))
      (let [view (db-index-view before .EAVT)
            low (lower-bound-index-view before view "eavt-ea" op.e op.a (Value {}))
            high (upper-bound-index-view before view "eavt-ea" op.e op.a (Value {}))]
        (for [i (arr.range low high)]
          (let [datom-index (db-index-view-at view i)
                datom before.datoms[datom-index]]
            (when (and (datom-current-at? before datom-index)
                       (not (value-equal? datom.v op.v)))
              (let [retract (Datom {e: datom.e
                                    a: datom.a
                                    v: datom.v
                                    tx: tx
                                    added: false})]
                (arr.push! after-datoms^ (datom-owned retract))
                (arr.push! tx-data^ (datom-owned retract))))))))))

(defn append-cardinality-one-retractions-conservative! [before: DB, seen-ea: (map string (struct {})), after-datoms: ^[dynamic]Datom, tx-data: ^[dynamic]Datom, op: Tx-Op, tx: u64]
  (when (not (= op.kind .Add))
    (return))
  (when (not (or (current-db-attr-exists? before op.e op.a)
                 (entity-attr-seen? seen-ea op.e op.a)))
    (return))
  (let [current (build-db (clone-datoms after-datoms^))]
    (when (not (tx-op-cardinality-one? current op))
      (delete-owned-db current)
      (return))
    (let [view (db-index-view current .EAVT)
          low (lower-bound-index-view current view "eavt-ea" op.e op.a (Value {}))
          high (upper-bound-index-view current view "eavt-ea" op.e op.a (Value {}))]
      (for [i (arr.range low high)]
        (let [datom-index (db-index-view-at view i)
              datom current.datoms[datom-index]]
          (when (and (datom-current-at? current datom-index)
                     (not (value-equal? datom.v op.v)))
            (let [retract (Datom {e: datom.e
                                  a: datom.a
                                  v: datom.v
                                  tx: tx
                                  added: false})]
              (arr.push! after-datoms^ (datom-owned retract))
              (arr.push! tx-data^ (datom-owned retract)))))))
    (delete-owned-db current)))

(defn current-op-value-exists-in-log? [datoms: []Datom, op: Tx-Op] -> bool
  (for [datom index datoms]
    (when (and (= datom.e op.e)
               (= datom.a op.a)
               (value-equal? datom.v op.v)
               (datom-current-in-log? datoms index))
      (return true)))
  false)

(defn current-db-fact-exists? [db: DB, op: Tx-Op] -> bool
  (let [view (db-index-view db .EAVT)
        low (lower-bound-index-view db view "eavt-ea" op.e op.a (Value {}))
        high (upper-bound-index-view db view "eavt-ea" op.e op.a (Value {}))]
    (for [i (arr.range low high)]
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v op.v))
          (return true)))))
  false)

(defn same-add-op-fact? [left: Tx-Op, right: Tx-Op] -> bool
  (and (= left.kind .Add)
       (= right.kind .Add)
       (= left.e right.e)
       (= left.a right.a)
       (value-equal? left.v right.v)))

(defn prior-add-op-fact-exists? [ops: []Tx-Op, index: int, op: Tx-Op] -> bool
  (let [prior 0]
    (while (< prior index)
      (when (same-add-op-fact? ops[prior] op)
        (return true))
      (set! prior (+ prior 1))))
  false)

(defn compact-redundant-add-ops [ops: []Tx-Op] -> [dynamic]Tx-Op
  (let [out (make [dynamic]Tx-Op 0 (count ops))
        seen-facts (set.empty string)]
    (defer (delete seen-facts))
    (for [op ops]
      (let [keep true]
        (when (= op.kind .Add)
          (let [[fact-key fact-ok] (op-fact-key op)]
            (when fact-ok
              (if (set.contains? seen-facts fact-key)
                (set! keep false)
                (set.add! seen-facts fact-key)))))
        (when keep
          (arr.push! out op))))
    out))

(defn db-next-entity-id-fast [db: DB] -> u64
  (let [view (db-index-view db .EAVT)]
    (let [position (- (db-index-view-count view) 1)]
      (while (>= position 0)
        (let [entity db.datoms[(db-index-view-at view position)].e]
          (when (< entity tx-partition-base)
            (return (+ entity 1))))
        (mut! position -= 1)))
    1))

(defn append-only-ops-all-new-entities? [db: DB, ops: []Tx-Op] -> bool
  (let [next-e (db-next-entity-id-fast db)]
    (for [op ops]
      (when (< op.e next-e)
        (return false))))
  true)

(defn append-only-ops-all-entities-absent? [db: DB, ops: []Tx-Op] -> bool
  (let [last-entity (u64 0)
        have-last false]
    (for [op ops]
      (when (or (not have-last)
                (not (= op.e last-entity)))
        (let [[_ _ exists] (eavt-entity-range db op.e)]
          (when exists
            (return false)))
        (set! last-entity op.e)
        (set! have-last true))))
  true)

(defn append-only-ordered-new-entity-ops-eligible? [before: DB, ops: []Tx-Op] -> bool
  (when (= (count ops) 0)
    (return true))
  (let [current-entity (u64 0)
        current-attrs (set.empty string)
        current-facts (set.empty string)
        first true]
    (defer (delete current-attrs))
    (defer (delete current-facts))
    (for [op ops]
      (when (not (= op.kind .Add))
        (return false))
      (when (and (not first)
                 (< op.e current-entity))
        (return false))
      (when (or first
                (not (= op.e current-entity)))
        (when (not first)
          (delete current-attrs)
          (delete current-facts)
          (set! current-attrs (set.empty string))
          (set! current-facts (set.empty string)))
        (let [[_ _ exists] (eavt-entity-range before op.e)]
          (when exists
            (return false)))
        (set! current-entity op.e)
        (set! first false))
      (if (schema-cardinality-one? before op.a)
        (do
          (when (set.contains? current-attrs op.a)
            (return false))
          (set.add! current-attrs op.a))
        (let [[fact-key fact-ok] (op-fact-key op)]
          (when (not fact-ok)
            (return false))
          (when (set.contains? current-facts fact-key)
            (return false))
          (set.add! current-facts fact-key)))))
  true)

(defn compact-redundant-add-ops-with-ordered [ops: []Tx-Op, ordered-append-only-ok: bool] -> [dynamic]Tx-Op
  (if ordered-append-only-ok
    (arr.into [dynamic]Tx-Op ops)
    (compact-redundant-add-ops ops)))

(defn append-only-ops-eligible? [before: DB, ops: []Tx-Op] -> bool
  (when (append-only-ordered-new-entity-ops-eligible? before ops)
    (return true))
  (let [seen-ea (set.empty string)
        seen-facts (set.empty string)
        all-new-entities (or (append-only-ops-all-new-entities? before ops)
                             (append-only-ops-all-entities-absent? before ops))]
    (defer (delete seen-ea))
    (defer (delete seen-facts))
    (for [op ops]
      (when (not (= op.kind .Add))
        (return false))
      (when (and (not all-new-entities)
                 (current-db-fact-exists? before op))
        (return false))
      (if (schema-cardinality-one? before op.a)
        (do
          (when (or (and (not all-new-entities)
                         (current-db-attr-exists? before op.e op.a))
                    (entity-attr-seen? seen-ea op.e op.a))
            (return false))
          (set.add! seen-ea (entity-attr-key op.e op.a)))
        (do
          (let [[fact-key fact-ok] (op-fact-key op)]
            (when (not fact-ok)
              (return false))
            (when (set.contains? seen-facts fact-key)
              (return false))
            (set.add! seen-facts fact-key))
          (set.add! seen-ea (entity-attr-key op.e op.a))))))
  true)

(defn append-only-ops-ineligible-reason [before: DB, ops: []Tx-Op] -> string
  (when (append-only-ordered-new-entity-ops-eligible? before ops)
    (return "eligible:ordered-new-entities"))
  (let [seen-ea (set.empty string)
        seen-facts (set.empty string)
        all-new-entities (or (append-only-ops-all-new-entities? before ops)
                             (append-only-ops-all-entities-absent? before ops))]
    (defer (delete seen-ea))
    (defer (delete seen-facts))
    (for [op ops]
      (when (not (= op.kind .Add))
        (return "non-add-op"))
      (when (and (not all-new-entities)
                 (current-db-fact-exists? before op))
        (return "existing-fact"))
      (if (schema-cardinality-one? before op.a)
        (do
          (when (and (not all-new-entities)
                     (current-db-attr-exists? before op.e op.a))
            (return "existing-cardinality-one-attr"))
          (when (entity-attr-seen? seen-ea op.e op.a)
            (return "duplicate-cardinality-one-attr-in-tx"))
          (set.add! seen-ea (entity-attr-key op.e op.a)))
        (do
          (let [[fact-key fact-ok] (op-fact-key op)]
            (when (not fact-ok)
              (return "unkeyable-fact"))
            (when (set.contains? seen-facts fact-key)
              (return "duplicate-fact-in-tx"))
            (set.add! seen-facts fact-key))
          (set.add! seen-ea (entity-attr-key op.e op.a))))))
  "eligible:general")

(defn datom-modifies-validation-schema? [datom: Datom] -> bool
  (or (= datom.a ":db/ident")
      (= datom.a ":db/valueType")
      (= datom.a ":db/cardinality")
      (= datom.a ":db/unique")
      (= datom.a ":db/tupleAttrs")
      (= datom.a ":db/isComponent")))

(defn datom-add-op [datom: Datom] -> Tx-Op
  (Tx-Op {kind: .Add
          e: datom.e
          a: datom.a
          v: datom.v}))

(defn append-only-datoms-all-entities-absent? [db: DB, datoms: []Datom] -> bool
  (let [last-entity (u64 0)
        have-last false]
    (for [datom datoms]
      (when (or (not have-last)
                (not (= datom.e last-entity)))
        (let [[_ _ exists] (eavt-entity-range db datom.e)]
          (when exists
            (return false)))
        (set! last-entity datom.e)
        (set! have-last true))))
  true)

(defn append-only-datoms-eligible? [before: DB, datoms: []Datom] -> bool
  (let [seen-facts (set.empty string)
        all-new-entities (append-only-datoms-all-entities-absent? before datoms)]
    (defer (delete seen-facts))
    (for [datom datoms]
      (when (or (not datom.added)
                (datom-modifies-validation-schema? datom))
        (return false))
      (let [op (datom-add-op datom)
            [fact-key fact-ok] (op-fact-key op)]
        (when (not fact-ok)
          (return false))
        (when (or (set.contains? seen-facts fact-key)
                  (and (not all-new-entities)
                       (current-db-fact-exists? before op)))
          (return false))
        (set.add! seen-facts fact-key))))
  true)

(defn build-db-with-appended-datoms [before: DB, datoms: [dynamic]Datom, start-index: int, appended: []Datom] -> DB
  (if (append-only-datoms-eligible? before appended)
    (let [new-entities-after-existing (added-entities-after-existing? before (slice datoms 0) start-index)
          plan (tx-publish-plan-for-append appended start-index new-entities-after-existing)]
      (defer (delete-tx-publish-plan plan))
      (build-db-append-only-with-publish-plan before datoms plan))
    (build-db datoms)))

(defn failed-tx-apply-result [error: string] -> Tx-Apply-Result
  (Tx-Apply-Result {ok: false
                    error: error
                    after-datoms: (make [dynamic]Datom)
                    tx-data: (make [dynamic]Datom)
                    tx: 0
                    start-index: 0
                    append-only: false
                    new-entities-after-existing: false
                    publish-plan: (tx-publish-plan-empty 0 0)}))

(defn delete-tx-apply-result [result: Tx-Apply-Result]
  (delete result.after-datoms)
  (delete result.tx-data)
  (delete-tx-publish-plan result.publish-plan))

(defn tx-report-from-apply-result [before: DB, after: DB, applied: Tx-Apply-Result, tx-meta: []Tx-Meta, tempids: [dynamic]Tempid] -> Tx-Report
  (let [report-tempids (arr.into [dynamic]Tempid (slice tempids 0))
        report-meta (clone-tx-meta tx-meta)
        has-tx-instant false]
    (delete tempids)
    (for [meta report-meta]
      (when (= meta.a ":db/txInstant")
        (set! has-tx-instant true)))
    (when (not has-tx-instant)
      (for [datom applied.tx-data]
        (when (and (= datom.e applied.tx)
                   (= datom.a ":db/txInstant")
                   datom.added)
          (arr.push! report-meta (Tx-Meta {a: ":db/txInstant" v: datom.v}))
          (break))))
    (let [[_ has-current-tx] (tempid-lookup (slice report-tempids 0) ":db/current-tx")]
      (when (not has-current-tx)
        (arr.push! report-tempids (Tempid {tempid: ":db/current-tx" e: applied.tx}))))
    (Tx-Report {db-before: before
                db-after: after
                ok: true
                error: (string-owned "")
                tx-data: applied.tx-data
                tx: applied.tx
                tx-meta: report-meta
                tempids: report-tempids
                datom-start-index: applied.start-index
                append-only: applied.append-only
                new-entities-after-existing: applied.new-entities-after-existing
                publish-plan: applied.publish-plan})))

(defn apply-resolved-ops-to-datoms [before: DB, ops: []Tx-Op, tx: u64] -> Tx-Apply-Result
  (let [expanded-ops (expand-tuple-ops before ops)
        clock-instant (current-instant)
        tx-instant clock-instant
        has-explicit-tx-instant false]
    (for [op expanded-ops]
      (when (and (= op.e tx) (= op.a ":db/txInstant"))
        (when (or has-explicit-tx-instant
                  (not (= op.kind .Add))
                  (not (= op.v.kind .Instant)))
          (delete expanded-ops)
          (return (failed-tx-apply-result "invalid explicit :db/txInstant")))
        (set! has-explicit-tx-instant true)
        (set! tx-instant op.v)))
    (when has-explicit-tx-instant
      (when (> tx-instant.int-value clock-instant.int-value)
        (delete expanded-ops)
        (return (failed-tx-apply-result ":db/txInstant cannot be newer than the wall clock")))
      (for [datom before.datoms]
        (when (and datom.added
                   (= datom.e datom.tx)
                   (= datom.a ":db/txInstant")
                   (= datom.v.kind .Instant)
                   (< tx-instant.int-value datom.v.int-value))
          (delete expanded-ops)
          (return (failed-tx-apply-result ":db/txInstant must be monotonic")))))
    (when (not has-explicit-tx-instant)
      (arr.push! expanded-ops (tx-add tx ":db/txInstant" tx-instant)))
    (let [
        expanded-schema-changed (ops-modify-validation-schema? (slice expanded-ops 0))
        ordered-append-only-ok (and (not expanded-schema-changed)
                                    (append-only-ordered-new-entity-ops-eligible? before (slice expanded-ops 0)))
        compacted-ops (compact-redundant-add-ops-with-ordered (slice expanded-ops 0) ordered-append-only-ok)
        tx-data (make [dynamic]Datom 0 (count compacted-ops))
        seen-ea (set.empty string)
        start-index (count before.datoms)
        schema-changed (ops-modify-validation-schema? (slice compacted-ops 0))
        append-only-ok (or ordered-append-only-ok
                           (and (not schema-changed)
                                (append-only-ops-eligible? before (slice compacted-ops 0))))]
    (defer (delete seen-ea))
    (let [[valid error] (validate-ops before (slice compacted-ops 0))]
      (when (not valid)
        (delete expanded-ops)
        (delete compacted-ops)
        (delete tx-data)
        (return (failed-tx-apply-result error))))
    (let [after-datoms (clone-datoms before.datoms)]
      (if append-only-ok
        (for [op compacted-ops]
          (let [datom (Datom {e: op.e
                              a: op.a
                              v: op.v
                              tx: tx
                              added: true})]
            (arr.push! after-datoms (datom-owned datom))
            (arr.push! tx-data (datom-owned datom))))
        (for [op compacted-ops]
          (let [apply-op (or (= op.kind .Add)
                             (current-op-value-exists-in-log? (slice after-datoms 0) op))]
            (when apply-op
              (if schema-changed
                (append-cardinality-one-retractions-conservative! before seen-ea (addr after-datoms) (addr tx-data) op tx)
                (append-cardinality-one-retractions! before seen-ea (addr after-datoms) (addr tx-data) op tx))
              (let [datom (Datom {e: op.e
                                  a: op.a
                                  v: op.v
                                  tx: tx
                                  added: (= op.kind .Add)})]
                (arr.push! after-datoms (datom-owned datom))
                (arr.push! tx-data (datom-owned datom))))
            (when (= op.kind .Add)
              (set.add! seen-ea (entity-attr-key op.e op.a))))))
      (let [new-entities-after-existing (and append-only-ok
                                             (added-entities-after-existing? before (slice after-datoms 0) start-index))
            publish-plan (if append-only-ok
                           (tx-publish-plan-for-append (slice tx-data 0) start-index new-entities-after-existing)
                           (tx-publish-plan-empty start-index (count tx-data)))]
        (delete expanded-ops)
        (delete compacted-ops)
        (Tx-Apply-Result {ok: true
                          error: ""
                          after-datoms: after-datoms
                          tx-data: tx-data
                          tx: tx
                          start-index: start-index
                          append-only: append-only-ok
                          new-entities-after-existing: new-entities-after-existing
                          publish-plan: publish-plan}))))))

(defn transact-ops-with-tempids-from-before [conn: ^Conn, before: DB, ops: []Tx-Op, tx-meta: []Tx-Meta, tempids: [dynamic]Tempid] -> Tx-Report
  (let [applied (apply-resolved-ops-to-datoms before ops conn^.next-tx)]
    (when (not applied.ok)
      (delete tempids)
      (delete-tx-apply-result applied)
      (return (failed-tx-report before applied.error)))
    (let [after (if applied.append-only
                  (build-db-append-only-with-publish-plan before applied.after-datoms applied.publish-plan)
                  (build-db applied.after-datoms))]
      (set! conn^.db after)
      (set! conn^.next-tx (+ conn^.next-tx 1))
      (let [report (tx-report-from-apply-result before after applied tx-meta tempids)]
        (notify-listeners! conn report)
        report))))

(defn transact-ops-with-tempids [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta, tempids: [dynamic]Tempid] -> Tx-Report
  (let [before conn^.db]
    (transact-ops-with-tempids-from-before conn before ops tx-meta tempids)))

(defn transact-with-meta [conn: ^Conn, ops: []Tx-Op, tx-meta: []Tx-Meta] -> Tx-Report
  (transact-ops-with-tempids conn ops tx-meta (make [dynamic]Tempid)))

(defn transact-ops [conn: ^Conn, ops: []Tx-Op] -> Tx-Report
  (transact-with-meta conn ops ([]Tx-Meta [])))

(defn transact-tx-data [conn: ^Conn, tx-data: []Tx-Data] -> Tx-Report
  (let [before conn^.db
        resolved (resolve-tx-data-for-tx before tx-data conn^.next-tx)]
    (when (not resolved.ok)
      (delete-resolved-tx resolved)
      (return (failed-tx-report before resolved.error)))
    (let [report (transact-ops-with-tempids-from-before conn before (slice resolved.ops 0) (slice resolved.tx-meta 0) resolved.tempids)]
      (delete-resolved-tx-after-tempids-moved resolved)
      report)))

(defn with-tx-data [db: DB, tx-data: []Tx-Data] -> Tx-Report
  (let [conn (conn-from-db db)]
    (transact-tx-data (addr conn) tx-data)))

(defn db-with-tx-data [db: DB, tx-data: []Tx-Data] -> DB
  (let [report (with-tx-data db tx-data)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn with-ops [db: DB, ops: []Tx-Op] -> Tx-Report
  (let [conn (conn-from-db db)]
    (transact-ops (addr conn) ops)))

(defn db-with-ops [db: DB, ops: []Tx-Op] -> DB
  (let [report (with-ops db ops)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn db-with-datoms [db: DB, datoms: []Datom] -> DB
  (let [out (clone-datoms db.datoms)
        start-index (count out)]
    (for [datom datoms]
      (arr.push! out datom))
    (build-db-with-appended-datoms db out start-index datoms)))

(defn next-tx-after-datoms [current-next-tx: u64, datoms: []Datom] -> u64
  (let [candidate (next-transaction-id (max-tx datoms))]
    (if (> candidate current-next-tx)
      candidate
      current-next-tx)))

(defn report-tx-for-datoms [fallback: u64, datoms: []Datom] -> u64
  (let [tx (max-tx datoms)]
    (if (> tx 0) tx fallback)))

(defn with-datoms [db: DB, datoms: []Datom] -> Tx-Report
  (let [before (clone-db db)
        out (clone-datoms db.datoms)
        start-index (count out)]
    (for [datom datoms]
      (arr.push! out datom))
    (let [append-only-ok (append-only-datoms-eligible? before datoms)
          new-entities-after-existing (and append-only-ok
                                           (added-entities-after-existing? before (slice out 0) start-index))
          publish-plan (if append-only-ok
                         (tx-publish-plan-for-append datoms start-index new-entities-after-existing)
                         (tx-publish-plan-empty start-index (count datoms)))
          after (if append-only-ok
                  (build-db-append-only-with-publish-plan before out publish-plan)
                  (build-db out))
          tx-data (arr.into [dynamic]Datom datoms)]
      (Tx-Report {ok: true
                  error: (string-owned "")
                  db-before: before
                  db-after: after
                  tx-data: tx-data
                  tx: (report-tx-for-datoms (next-transaction-id (max-tx (slice db.datoms 0))) datoms)
                  tx-meta: (make [dynamic]Tx-Meta)
                  tempids: (make [dynamic]Tempid)
                  datom-start-index: start-index
                  append-only: append-only-ok
                  new-entities-after-existing: new-entities-after-existing
                  publish-plan: publish-plan}))))

(defn transact-datoms [conn: ^Conn, datoms: []Datom] -> Tx-Report
  (let [before conn^.db
        out (clone-datoms conn^.db.datoms)
        start-index (count out)]
    (for [datom datoms]
      (arr.push! out datom))
    (let [append-only-ok (append-only-datoms-eligible? before datoms)
          tx-data (arr.into [dynamic]Datom datoms)
          tx (report-tx-for-datoms conn^.next-tx datoms)]
      (let [new-entities-after-existing (and append-only-ok
                                             (added-entities-after-existing? before (slice out 0) start-index))
            publish-plan (if append-only-ok
                           (tx-publish-plan-for-append datoms start-index new-entities-after-existing)
                           (tx-publish-plan-empty start-index (count datoms)))
            after (if append-only-ok
                    (build-db-append-only-with-publish-plan before out publish-plan)
                    (build-db out))
            report (Tx-Report {ok: true
                               error: (string-owned "")
                               db-before: before
                               db-after: after
                               tx-data: tx-data
                               tx: tx
                               tx-meta: (make [dynamic]Tx-Meta)
                               tempids: (make [dynamic]Tempid)
                               datom-start-index: start-index
                               append-only: append-only-ok
                               new-entities-after-existing: new-entities-after-existing
                               publish-plan: publish-plan})]
        (set! conn^.db after)
        (set! conn^.next-tx (next-tx-after-datoms conn^.next-tx (slice conn^.db.datoms 0)))
        (notify-listeners! conn report)
        report))))

(defn delete-owned-db [db: DB]
  (delete db.current)
  (delete db.eavt)
  (delete db.eavt-entities)
  (delete db.eavt-entity-starts)
  (delete db.aevt)
  (delete db.avet)
  (delete db.vaet)
  (delete db.schema-value-types)
  (delete db.schema-cardinality-many)
  (delete db.schema-unique)
  (delete db.schema-ref)
  (delete db.datoms))

;; Resident connections own the strings and nested values in their final
;; datom log. Intermediate DB values share those datoms and therefore use the
;; shallow container cleanup above.
(defn delete-resident-db [db: DB]
  (for [datom db.datoms]
    (delete-owned-datom datom))
  (delete-owned-db db))

(defn serializable [db: DB] -> Serializable-DB
  (let [datoms (clone-datom-slice (slice db.datoms 0))]
    (Serializable-DB {datoms: datoms})))

(defn from-serializable [data: Serializable-DB] -> DB
  (init-db (slice data.datoms 0)))

(defn delete-serializable [data: Serializable-DB]
  (delete data.datoms))

(defn append-resolved-tx! [ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, resolved: Resolved-Tx]
  (for [op resolved.ops]
    (arr.push! ops^ op))
  (for [meta resolved.tx-meta]
    (arr.push! tx-meta^ meta))
  (for [tempid resolved.tempids]
    (arr.push! tempids^ tempid)))

(defn resolve-tx-segment! [base: DB, tx: u64, ops: ^[dynamic]Tx-Op, tx-meta: ^[dynamic]Tx-Meta, tempids: ^[dynamic]Tempid, segment: ^[dynamic]Tx-Data] -> [ok: bool, error: string]
  (when (= (count segment^) 0)
    (return true ""))
  (let [current-db (db-with-resolved-ops base (slice ops^ 0))
        resolved (resolve-tx-data-for-tx current-db (slice segment^ 0) tx)]
    (delete-owned-db current-db)
    (when (not resolved.ok)
      (delete-resolved-tx resolved)
      (return false resolved.error))
    (append-resolved-tx! ops tx-meta tempids resolved)
    (delete resolved.ops)
    (delete resolved.tx-meta)
    (delete resolved.tempids)
    (delete segment^)
    (set! segment^ (make [dynamic]Tx-Data))
    (return true "")))

(defn failed-registered-tx [before: DB, ops: [dynamic]Tx-Op, tx-meta: [dynamic]Tx-Meta, tempids: [dynamic]Tempid, segment: [dynamic]Tx-Data, error: string] -> Tx-Report
  (delete ops)
  (delete tx-meta)
  (delete tempids)
  (delete segment)
  (failed-tx-report before error))

(defn call-registered-tx-fn [entry: Tx-Fn-String, db: DB, data: Tx-Data] -> Tx-Fn-Result
  (when (= data.v.kind .Vector)
    (when entry.has-values-fn
      (return (entry.values-f db (slice data.v.items 0))))
    (when (and (= (count data.v.items) 1)
               (= data.v.items[0].kind .String))
      (return (entry.f db data.v.items[0].text)))
    (return (tx-fn-error "transaction fn expects one string argument")))
  (when entry.has-values-fn
    (return (entry.values-f db ([]Value [data.v]))))
  (when (= data.v.kind .String)
    (return (entry.f db data.v.text)))
  (tx-fn-error "transaction fn expects one string argument"))

(defn transact-tx-data-with-string-fns [conn: ^Conn, tx-data: []Tx-Data, registry: []Tx-Fn-String] -> Tx-Report
  (let [before conn^.db
        [duplicate-ident has-duplicate] (tx-fn-string-duplicate-ident registry)
        tx conn^.next-tx
        ops (make [dynamic]Tx-Op)
        tx-meta (make [dynamic]Tx-Meta)
        tempids (make [dynamic]Tempid)
        segment (make [dynamic]Tx-Data)]
    (when has-duplicate
      (return (failed-registered-tx before ops tx-meta tempids segment (fmt.tprintf "duplicate transaction fn registration: %s" duplicate-ident))))
    (for [data tx-data]
      (if (= data.op ":db.fn/call-ident")
        (do
          (let [[segment-ok segment-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
            (when (not segment-ok)
              (return (failed-registered-tx before ops tx-meta tempids segment segment-error))))
          (let [current-db (db-with-resolved-ops before (slice ops 0))
                [_ fn-entity-ok] (schema-entity-for-attr current-db data.ident)
                [fn-index fn-ok] (tx-fn-string-index registry data.ident)]
            (when (not fn-entity-ok)
              (delete-owned-db current-db)
              (return (failed-registered-tx before ops tx-meta tempids segment "transaction fn not found")))
            (when (not fn-ok)
              (delete-owned-db current-db)
              (return (failed-registered-tx before ops tx-meta tempids segment "transaction fn not registered")))
            (let [result (call-registered-tx-fn registry[fn-index] current-db data)]
              (delete-owned-db current-db)
              (when (not result.ok)
                (delete result.tx-data)
                (return (failed-registered-tx before ops tx-meta tempids segment result.error)))
              (let [[result-ok result-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr result.tx-data))]
                (delete result.tx-data)
                (when (not result-ok)
                  (return (failed-registered-tx before ops tx-meta tempids segment result-error)))))))
        (arr.push! segment data)))
    (let [[tail-ok tail-error] (resolve-tx-segment! before tx (addr ops) (addr tx-meta) (addr tempids) (addr segment))]
      (when (not tail-ok)
        (return (failed-registered-tx before ops tx-meta tempids segment tail-error))))
    (delete segment)
    (let [report (transact-ops-with-tempids-from-before conn before (slice ops 0) (slice tx-meta 0) tempids)]
      (delete ops)
      (delete tx-meta)
      report)))

(defn transact-fn [conn: ^Conn, f: (fn [db: DB] -> Tx-Fn-Result)] -> Tx-Report
  (let [before conn^.db
        result (f before)]
    (defer (delete result.tx-data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (let [resolved (resolve-tx-data-for-tx before (slice result.tx-data 0) conn^.next-tx)]
      (when (not resolved.ok)
        (delete-resolved-tx resolved)
        (return (failed-tx-report before resolved.error)))
      (let [report (transact-ops-with-tempids-from-before conn before (slice resolved.ops 0) (slice resolved.tx-meta 0) resolved.tempids)]
        (delete-resolved-tx-after-tempids-moved resolved)
        report))))

(defn transact-fn-string [conn: ^Conn, f: (fn [db: DB, arg: string] -> Tx-Fn-Result), arg: string] -> Tx-Report
  (let [before conn^.db
        result (f before arg)]
    (defer (delete result.tx-data))
    (when (not result.ok)
      (return (failed-tx-report before result.error)))
    (let [resolved (resolve-tx-data-for-tx before (slice result.tx-data 0) conn^.next-tx)]
      (when (not resolved.ok)
        (delete-resolved-tx resolved)
        (return (failed-tx-report before resolved.error)))
      (let [report (transact-ops-with-tempids-from-before conn before (slice resolved.ops 0) (slice resolved.tx-meta 0) resolved.tempids)]
        (delete-resolved-tx-after-tempids-moved resolved)
        report))))

(defn match-entity-term? [db: DB, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .Var)
    (let [[existing exists] (binding-lookup binding^ term.name)]
      (if exists
        (return (entity-value-equal? db existing actual))
        (do
          (binding-store! binding term.name actual)
          (return true)))))
  (let [[resolved resolved-ok] (resolve-entity-term db term binding^)]
    (when resolved-ok
      (return (value-equal? resolved actual))))
  (match-term? term actual binding))

(defn match-attr-term? [db: DB, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .Value)
    (let [[resolved resolved-ok] (resolve-attribute-value db term.value)]
      (return (and resolved-ok (value-equal? resolved actual)))))
  (match-term? term actual binding))

(defn ref-entity-literal [db: DB, attr: string, value: Value] -> [resolved: Value, ok: bool]
  (when (schema-ref? db attr)
    (let [[entity ok] (value-as-entity db value)]
      (when ok
        (return entity true))))
  (return value false))

(defn match-clause-value-term? [db: DB, attr: string, attr-static: bool, term: Term, actual: Value, binding: ^Binding] -> bool
  (when (= term.kind .LookupRef)
    (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
      (return (and lookup-ok (value-equal? (value-entity entity) actual)))))
  (when (= term.kind .Var)
    (let [[existing exists] (binding-lookup binding^ term.name)]
      (if exists
        (return (clause-value-equal? db attr existing actual))
        (do
          (binding-store! binding term.name actual)
          (return true)))))
  (when (= term.kind .Value)
    (when (not attr-static)
      (return (entity-id-value-equal? term.value actual)))
    (let [[resolved ok] (ref-entity-literal db attr term.value)]
      (when ok
        (return (value-equal? resolved actual)))))
  (match-term? term actual binding))

(defn datom-tx-value [datom: Datom] -> Value
  (value-entity datom.tx))

(defn datom-op-value [datom: Datom] -> Value
  (if datom.added
    (value-keyword ":db/add")
    (value-keyword ":db/retract")))

(defn datom-value [datom: Datom] -> Value
  (value-map
    ([]Value [(value-keyword (string-owned ":e")) (value-entity datom.e)
              (value-keyword (string-owned ":a")) (value-keyword (string-owned datom.a))
              (value-keyword (string-owned ":v")) (value-owned datom.v)
              (value-keyword (string-owned ":tx")) (datom-tx-value datom)
              (value-keyword (string-owned ":op")) (value-owned (datom-op-value datom))
              (value-keyword (string-owned ":added")) (value-bool datom.added)])))

(defn datoms-value [datoms: []Datom] -> Value
  (let [items (make [dynamic]Value 0 (count datoms))]
    (defer (delete items))
    (for [datom datoms]
      (arr.push! items (datom-value datom)))
    (value-vector (slice items 0))))

(defn tx-meta-value [meta: Tx-Meta] -> Value
  (value-map
    ([]Value [(value-keyword (string-owned ":a")) (value-keyword (string-owned meta.a))
              (value-keyword (string-owned ":v")) (value-owned meta.v)])))

(defn tx-metas-value [metas: []Tx-Meta] -> Value
  (let [items (make [dynamic]Value 0 (count metas))]
    (defer (delete items))
    (for [meta metas]
      (arr.push! items (tx-meta-value meta)))
    (value-vector (slice items 0))))

(defn tempid-key-value [tempid: string] -> Value
  (if (strings.has_prefix tempid ":")
    (value-keyword (string-owned tempid))
    (value-string (string-owned tempid))))

(defn tempids-value [tempids: []Tempid] -> Value
  (let [items (make [dynamic]Value 0 (* (count tempids) 2))]
    (defer (delete items))
    (for [tempid tempids]
      (arr.push! items (tempid-key-value tempid.tempid))
      (arr.push! items (value-entity tempid.e)))
    (value-map (slice items 0))))

(defn tx-report-value [report: Tx-Report] -> Value
  (value-map
    ([]Value [(value-keyword (string-owned ":ok")) (value-bool report.ok)
              (value-keyword (string-owned ":error")) (value-string (string-owned report.error))
              (value-keyword (string-owned ":tx")) (if report.ok (value-entity report.tx) (value-nil))
              (value-keyword (string-owned ":tx-data")) (datoms-value (slice report.tx-data 0))
              (value-keyword (string-owned ":tempids")) (tempids-value (slice report.tempids 0))
              (value-keyword (string-owned ":tx-meta")) (tx-metas-value (slice report.tx-meta 0))])))

(defn omitted-term? [term: Term] -> bool
  (and (= term.kind .Value)
       (= term.value.kind .Nil)))

(defn match-optional-datom-term? [term: Term, actual: Value, binding: ^Binding] -> bool
  (if (omitted-term? term)
    true
    (match-term? term actual binding)))

(defn datom-tx-op-terms-match? [datom: Datom, clause: Clause, binding: ^Binding] -> bool
  (and (match-optional-datom-term? clause.tx-term (datom-tx-value datom) binding)
       (match-optional-datom-term? clause.op-term (value-bool datom.added) binding)))

(defn datom-clause-matches? [db: DB, datom: Datom, clause: Clause, binding: ^Binding] -> bool
  (when (and (= clause.a.kind .Value)
             (= clause.a.value.kind .Keyword)
             (reverse-attr? clause.a.value.text))
    (when (not (= datom.v.kind .Entity))
      (return false))
    (let [forward-attr (forward-attr-for-reverse clause.a.value.text) :defer]
      (return
        (and (= datom.a forward-attr)
             (match-entity-term? db clause.e (value-entity datom.v.entity) binding)
             (match-entity-term? db clause.v (value-entity datom.e) binding)
             (datom-tx-op-terms-match? datom clause binding)))))
  (and (match-entity-term? db clause.e (value-entity datom.e) binding)
       (match-attr-term? db clause.a (value-keyword datom.a) binding)
       (match-clause-value-term? db datom.a
                                 (and (= clause.a.kind .Value)
                                      (= clause.a.value.kind .Keyword))
                                 clause.v datom.v binding)
       (datom-tx-op-terms-match? datom clause binding)))

(defn candidate-index-matches? [datom: Datom,
                                e-value: Value, e-ok: bool,
                                a-value: Value, a-ok: bool,
                                v-value: Value, v-ok: bool] -> bool
  (when e-ok
    (when (not (and (= e-value.kind .Entity)
                    (= datom.e e-value.entity)))
      (return false)))
  (when a-ok
    (when (not (and (= a-value.kind .Keyword)
                    (= datom.a a-value.text)))
      (return false)))
  (when v-ok
    (when (not (value-equal? datom.v v-value))
      (return false)))
  true)

(defn clause-selectivity-score [clause: Clause, binding: Binding] -> int
  (let [[a-value a-ok] (resolve-term clause.a binding)
        bounds (physical-clause-scan-bounds-with-binding clause binding)
        scan-range (physical-scan-range-from-bounds bounds)]
    (when (and a-ok (not (= a-value.kind .Keyword)))
      (return 0))
    (case scan-range.kind
      .EntityAttr 1
      .AttrValue 2
      .Entity 3
      .Attr 4
      .Value 5

      6)))

(defn best-clause-index [clauses: []Clause, binding: Binding] -> int
  (let [best 0
        best-score (clause-selectivity-score clauses[0] binding)
        i 1]
    (while (< i (count clauses))
      (let [score (clause-selectivity-score clauses[i] binding)]
        (when (< score best-score)
          (set! best i)
          (set! best-score score)))
      (set! i (+ i 1)))
    best))

(defn clause-candidate-count-estimate-for-db [db: DB, clause: Clause, binding: Binding] -> int
  (let [scan (clause-index-scan db clause binding)
        count 0]
    (defer (delete-clause-index-scan scan))
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (clause-index-scan-candidate? scan datom)
            (set! count (+ count 1))))
        (set! scan-index (+ scan-index 1))))
    count))

(defn clause-candidate-count-estimate [db: DB, sources: []DB-Source, clause: Clause, binding: Binding] -> int
  (when clause.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause.source)]
      (when source-ok
        (return (clause-candidate-count-estimate-for-db source-db (unsourced-clause clause) binding)))))
  (clause-candidate-count-estimate-for-db db clause binding))

(defn best-clause-index-estimated [db: DB, sources: []DB-Source, clauses: []Clause, binding: Binding] -> int
  (let [best 0
        best-score (clause-selectivity-score clauses[0] binding)
        best-count -1
        i 1]
    (while (< i (count clauses))
      (let [score (clause-selectivity-score clauses[i] binding)]
        (when (< score best-score)
          (set! best i)
          (set! best-score score)
          (set! best-count -1))
        (when (= score best-score)
          (when (< best-count 0)
            (set! best-count (clause-candidate-count-estimate db sources clauses[best] binding)))
          (let [candidate-count (clause-candidate-count-estimate db sources clauses[i] binding)]
            (when (< candidate-count best-count)
              (set! best i)
              (set! best-count candidate-count)))))
      (set! i (+ i 1)))
    best))

(defn relation-source-row-matches? [clause: Clause, row: Value, binding: ^Binding] -> bool
  (when (and (= clause.source-width 1)
             (not (= row.kind .Vector)))
    (return (match-term? clause.e row binding)))
  (when (not (= row.kind .Vector))
    (return false))
  (when (not (= (count row.items) clause.source-width))
    (return false))
  (when (= clause.source-width 1)
    (return (match-term? clause.e row.items[0] binding)))
  (when (= clause.source-width 2)
    (return
      (and (match-term? clause.e row.items[0] binding)
           (match-term? clause.a row.items[1] binding))))
  (when (not (and (match-term? clause.e row.items[0] binding)
                  (match-term? clause.a row.items[1] binding)
                  (match-term? clause.v row.items[2] binding)))
    (return false))
  (when (= clause.source-width 3)
    (return true))
  (when (not (match-term? clause.tx-term row.items[3] binding))
    (return false))
  (when (= clause.source-width 4)
    (return true))
  (match-term? clause.op-term row.items[4] binding))

(defn typed-relation-source-term-matches? [rel: Query-Relation, row: int, term: Term, actual: Value] -> bool
  (case term.kind
    .Value (value-equal? term.value actual)
    .Wildcard true
    .Var (query-relation-typed-row-var-agrees? rel row term.name actual)
     false))

(defn source-row-position-value [source-row: Value, width: int, position: int] -> [value: Value, ok: bool]
  (when (and (= width 1)
             (not (= source-row.kind .Vector)))
    (if (= position 0)
      (return source-row true)
      (return (Value {}) false)))
  (when (not (= source-row.kind .Vector))
    (return (Value {}) false))
  (when (not (= (count source-row.items) width))
    (return (Value {}) false))
  (when (or (< position 0)
            (>= position width))
    (return (Value {}) false))
  (return source-row.items[position] true))

(defn source-row-prior-var-agrees? [clause: Clause, source-row: Value, position: int, name: string, actual: Value] -> bool
  (let [prior 0]
    (while (< prior position)
      (let [[prior-term prior-term-ok] (clause-term-at-source-position clause prior)]
        (when (and prior-term-ok
                   (= prior-term.kind .Var)
                   (= prior-term.name name))
          (let [[prior-value prior-value-ok] (source-row-position-value source-row clause.source-width prior)]
            (when (not prior-value-ok)
              (return false))
            (when (not (value-equal? prior-value actual))
              (return false)))))
      (set! prior (+ prior 1))))
  true)

(defn direct-source-term-matches-at-position? [clause: Clause, source-row: Value, position: int, term: Term, actual: Value] -> bool
  (case term.kind
    .Value (value-equal? term.value actual)
    .Wildcard true
    .Var (source-row-prior-var-agrees? clause source-row position term.name actual)
     false))

(defn direct-source-row-matches? [clause: Clause, source-row: Value] -> bool
  (let [position 0]
    (while (< position clause.source-width)
      (let [[actual actual-ok] (source-row-position-value source-row clause.source-width position)]
        (when (not actual-ok)
          (return false))
        (let [[term term-ok] (clause-term-at-source-position clause position)]
          (when (not term-ok)
            (return false))
          (when (not (direct-source-term-matches-at-position? clause source-row position term actual))
            (return false))))
      (set! position (+ position 1))))
  true)

(defn direct-source-output-position [clause: Clause, name: string] -> [position: int, ok: bool]
  (let [position 0]
    (while (< position clause.source-width)
      (let [[term term-ok] (clause-term-at-source-position clause position)]
        (when (and term-ok
                   (= term.kind .Var)
                   (= term.name name))
          (return position true)))
      (set! position (+ position 1))))
  (return 0 false))

(defn source-row-var-value [clause: Clause, source-row: Value, name: string] -> [value: Value, ok: bool]
  (let [[position position-ok] (direct-source-output-position clause name)]
    (when (not position-ok)
      (return (Value {}) false))
    (source-row-position-value source-row clause.source-width position)))

(defn direct-source-row-pushdown-matches? [clause: Clause, source-row: Value, op: Physical-Op] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (source-row-var-value clause source-row op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (source-row-var-value clause source-row op.pushdown-scalar-requirement.other-var)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn binding-source-row-pushdown-other-value [binding: Binding, clause: Clause, source-row: Value, op: Physical-Op] -> [value: Value, ok: bool]
  (let [[binding-value binding-ok] (binding-physical-pushdown-other-value binding op)]
    (when binding-ok
      (return binding-value true)))
  (source-row-var-value clause source-row op.pushdown-scalar-requirement.other-var))

(defn binding-source-row-pushdown-matches? [binding: Binding, clause: Clause, source-row: Value, op: Physical-Op] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (source-row-var-value clause source-row op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (binding-source-row-pushdown-other-value binding clause source-row op)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn typed-relation-source-row-pushdown-matches? [rel: Query-Relation, rel-row: int, clause: Clause, source-row: Value, op: Physical-Op] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (source-row-var-value clause source-row op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (query-relation-physical-pushdown-other-value rel rel-row op)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              (let [[source-other source-other-ok] (source-row-var-value clause source-row op.pushdown-scalar-requirement.other-var)]
                (if source-other-ok
                  (physical-op-scalar-pushdown-matches-values? op value source-other)
                  true))))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn direct-source-output-positions [attrs: []string, clause: Clause] -> [positions: [dynamic]int, ok: bool]
  (let [out (make [dynamic]int 0 (count attrs))]
    (for [attr attrs]
      (let [[position position-ok] (direct-source-output-position clause attr)]
        (when (not position-ok)
          (delete out)
          (return (make [dynamic]int) false))
        (arr.push! out position)))
    (return out true)))

(defn query-relation-builder-can-add-direct-source-row? [builder: Query-Relation-Builder, positions: []int, width: int, source-row: Value] -> bool
  (for [position index positions]
    (let [[value value-ok] (source-row-position-value source-row width position)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  true)

(defn query-relation-builder-add-direct-source-row! [builder: ^Query-Relation-Builder, positions: []int, width: int, source-row: Value] -> bool
  (when (not (query-relation-builder-can-add-direct-source-row? builder^ positions width source-row))
    (return false))
  (for [position index positions]
    (let [[value _] (source-row-position-value source-row width position)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn clause-term-at-source-position [clause: Clause, position: int] -> [term: Term, ok: bool]
  (case position
    0 (return clause.e true)
    1 (return clause.a true)
    2 (return clause.v true)
    3 (return clause.tx-term true)
    4 (return clause.op-term true)
     (return (Term {}) false)))

(defn source-input-clause-bound-key-position [rel: Query-Relation, clause: Clause] -> [position: int, ok: bool]
  (let [position 0]
    (while (< position clause.source-width)
      (let [[term term-ok] (clause-term-at-source-position clause position)]
        (when (and term-ok
                   (= term.kind .Var)
                   (query-relation-has-attr? rel term.name))
          (return position true)))
      (set! position (+ position 1))))
  (return 0 false))

(defn query-relation-source-bound-row-key [rel: Query-Relation, rel-row: int, clause: Clause, position: int] -> [key: string, ok: bool]
  (let [[term term-ok] (clause-term-at-source-position clause position)]
    (when (not (and term-ok (= term.kind .Var)))
      (return "" false))
    (let [[value value-ok] (query-relation-typed-row-value rel rel-row term.name)]
      (when (not value-ok)
        (return "" false))
      (primitive-value-dedupe-key value))))

(defn source-input-clause-has-direct-filter? [clause: Clause, op: Physical-Op] -> bool
  (when op.has-pushdown-scalar
    (return true))
  (let [position 0]
    (while (< position clause.source-width)
      (let [[term term-ok] (clause-term-at-source-position clause position)]
        (when (and term-ok (= term.kind .Value))
          (return true)))
      (set! position (+ position 1))))
  false)

(defn source-input-filtered-row-indexes [source: Value, clause: Clause, op: Physical-Op] -> [indexes: [dynamic]int, ok: bool]
  (let [out (make [dynamic]int)]
    (when (not (= source.kind .Vector))
      (return out false))
    (for [row index source.items]
      (when (and (direct-source-row-matches? clause row)
                 (direct-source-row-pushdown-matches? clause row op))
        (arr.push! out index)))
    (return out true)))

(defn source-input-filtered-row-indexes-if-useful [source: Value, clause: Clause, op: Physical-Op] -> [indexes: [dynamic]int, ok: bool]
  (when (not (source-input-clause-has-direct-filter? clause op))
    (return (make [dynamic]int) false))
  (source-input-filtered-row-indexes source clause op))

(defn typed-relation-source-output-positions [attrs: []string, rel: Query-Relation, clause: Clause] -> [positions: [dynamic]int, ok: bool]
  (let [out (make [dynamic]int)]
    (for [attr attrs]
      (when (not (query-relation-has-attr? rel attr))
        (let [[position position-ok] (direct-source-output-position clause attr)]
          (when (not position-ok)
            (delete out)
            (return (make [dynamic]int) false))
          (arr.push! out position))))
    (return out true)))

(defn typed-relation-source-row-matches? [clause: Clause, source-row: Value, rel: Query-Relation, rel-row: int] -> bool
  (when (and (= clause.source-width 1)
             (not (= source-row.kind .Vector)))
    (return (typed-relation-source-term-matches? rel rel-row clause.e source-row)))
  (when (not (= source-row.kind .Vector))
    (return false))
  (when (not (= (count source-row.items) clause.source-width))
    (return false))
  (when (= clause.source-width 1)
    (return (typed-relation-source-term-matches? rel rel-row clause.e source-row.items[0])))
  (when (= clause.source-width 2)
    (return
      (and (typed-relation-source-term-matches? rel rel-row clause.e source-row.items[0])
           (typed-relation-source-term-matches? rel rel-row clause.a source-row.items[1]))))
  (when (not (and (typed-relation-source-term-matches? rel rel-row clause.e source-row.items[0])
                  (typed-relation-source-term-matches? rel rel-row clause.a source-row.items[1])
                  (typed-relation-source-term-matches? rel rel-row clause.v source-row.items[2])))
    (return false))
  (when (= clause.source-width 3)
    (return true))
  (when (not (typed-relation-source-term-matches? rel rel-row clause.tx-term source-row.items[3]))
    (return false))
  (when (= clause.source-width 4)
    (return true))
  (typed-relation-source-term-matches? rel rel-row clause.op-term source-row.items[4]))

(defn query-relation-builder-can-add-source-projection-row? [builder: Query-Relation-Builder, columns: []Relation-Column, row: int, positions: []int, width: int, source-row: Value] -> bool
  (for [column index columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[index] value)))
        (return false))))
  (for [position index positions]
    (let [column-index (+ (count columns) index)
          [value value-ok] (source-row-position-value source-row width position)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder.typed-columns[column-index] value)))
        (return false))))
  true)

(defn query-relation-builder-add-source-projection-row! [builder: ^Query-Relation-Builder, columns: []Relation-Column, row: int, positions: []int, width: int, source-row: Value] -> bool
  (when (not (query-relation-builder-can-add-source-projection-row? builder^ columns row positions width source-row))
    (return false))
  (for [column index columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (for [position index positions]
    (let [column-index (+ (count columns) index)
          [value _] (source-row-position-value source-row width position)]
      (discard (relation-column-add! (addr builder^.typed-columns[column-index]) value))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn bindings-after-relation-source-clause-with-op [clause: Clause, binding: Binding, op: Physical-Op] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)
        [source source-ok] (binding-lookup binding clause.source)]
    (when (not (and source-ok (= source.kind .Vector)))
      (return out))
    (for [row source.items]
      (let [next (clone-binding binding)]
        (if (and (relation-source-row-matches? clause row (addr next))
                 (binding-source-row-pushdown-matches? binding clause row op))
          (arr.push! out next)
          (delete next.items))))
    out))

(defn bindings-after-relation-source-clause [clause: Clause, binding: Binding] -> [dynamic]Binding
  (bindings-after-relation-source-clause-with-op clause binding (Physical-Op {})))

(defn bindings-from-relation-source-value-clause [source: Value, clause: Clause] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (not (= source.kind .Vector))
      (return out))
    (for [row source.items]
      (let [next (Binding {})]
        (if (relation-source-row-matches? clause row (addr next))
          (arr.push! out next)
          (delete next.items))))
    out))

(defn query-relation-from-source-value-clause-typed-with-op [source: Value, clause-value: Clause, op: Physical-Op] -> [rel: Query-Relation, ok: bool]
  (let [[attrs attr-sources] (clause-output-attrs clause-value "")
        [positions positions-ok] (direct-source-output-positions (slice attrs 0) clause-value)
        builder (query-relation-builder (slice attrs 0))]
    (when (not positions-ok)
      (delete attrs)
      (delete attr-sources)
      (delete-query-relation-builder builder)
      (return (query-relation-empty) false))
    (when (not (= source.kind .Vector))
      (delete attrs)
      (delete attr-sources)
      (delete positions)
      (delete-query-relation-builder builder)
      (return (query-relation-empty) false))
    (for [row source.items]
      (when (and (direct-source-row-matches? clause-value row)
                 (direct-source-row-pushdown-matches? clause-value row op))
        (when (not (query-relation-builder-add-direct-source-row! (addr builder) (slice positions 0) clause-value.source-width row))
          (delete attrs)
          (delete attr-sources)
          (delete positions)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))))
    (delete positions)
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-source-value-clause-typed [source: Value, clause-value: Clause] -> [rel: Query-Relation, ok: bool]
  (query-relation-from-source-value-clause-typed-with-op source clause-value (Physical-Op {})))

(defn query-relation-from-source-value-clause-binding-backed-with-op [source: Value, clause-value: Clause, op: Physical-Op] -> Query-Relation
  (let [[attrs attr-sources] (clause-output-attrs clause-value "")
        tuples (make [dynamic]Binding)]
    (when (= source.kind .Vector)
      (for [row source.items]
        (let [next (Binding {})]
          (if (and (relation-source-row-matches? clause-value row (addr next))
                   (direct-source-row-pushdown-matches? clause-value row op))
            (arr.push! tuples next)
            (delete next.items)))))
    (let [[typed-columns typed-rows typed-ok] (typed-columns-from-relation-bindings (slice attrs 0) (slice tuples 0))]
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: tuples
                     typed-columns: typed-columns
                     typed-rows: typed-rows
                     has-typed-columns: typed-ok}))))

(defn query-relation-from-source-value-clause-binding-backed [source: Value, clause-value: Clause] -> Query-Relation
  (query-relation-from-source-value-clause-binding-backed-with-op source clause-value (Physical-Op {})))

(defn query-relation-from-source-value-clause-with-op [source: Value, clause-value: Clause, op: Physical-Op] -> Query-Relation
  (let [[typed typed-ok] (query-relation-from-source-value-clause-typed-with-op source clause-value op)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (query-relation-from-source-value-clause-binding-backed-with-op source clause-value op))

(defn query-relation-from-source-value-clause [source: Value, clause-value: Clause] -> Query-Relation
  (query-relation-from-source-value-clause-with-op source clause-value (Physical-Op {})))

(defn source-db-lookup [db: DB, sources: []DB-Source, name: string] -> [source-db: DB, ok: bool]
  (when (= name "$")
    (return db true))
  (for [source sources]
    (when (= source.name name)
      (return source.db true)))
  (return db false))

(defn unsourced-clause [clause: Clause] -> Clause
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           tx-term: clause.tx-term
           op-term: clause.op-term
           source: ""
           has-source: false
           source-width: clause.source-width}))

(defn unsourced-get-else [get-else: Get-Else] -> Get-Else
  (let [out get-else]
    (set! out.source "")
    (set! out.has-source false)
    out))

(defn unsourced-get-some [get-some: Get-Some] -> Get-Some
  (let [out get-some]
    (set! out.source "")
    (set! out.has-source false)
    out))

(defn append-bindings-after-clause! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding]
  (when clause-value.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause-value binding)]
      (defer (delete source-bindings))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (let [scan (clause-index-scan db clause-value binding)]
    (defer (delete-clause-index-scan scan))
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (and (clause-index-scan-candidate? scan datom)
                     (datom-current-at? db datom-index))
            (let [next (clone-binding binding)]
              (if (datom-clause-matches? db datom clause-value (addr next))
                (arr.push! out^ next)
                (delete next.items)))))
        (set! scan-index (+ scan-index 1))))))

(defn append-bindings-after-clause-profiled! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding, stats: ^Query-Stats]
  (set! stats^.clauses (+ stats^.clauses 1))
  (when clause-value.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause-value binding)]
      (defer (delete source-bindings))
      (set! stats^.clause-candidates (+ stats^.clause-candidates (count source-bindings)))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (let [scan (clause-index-scan db clause-value binding)
        candidate-count 0]
    (defer (delete-clause-index-scan scan))
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (clause-index-scan-candidate? scan datom)
            (set! candidate-count (+ candidate-count 1))
            (when (datom-current-at? db datom-index)
              (let [next (clone-binding binding)]
                (if (datom-clause-matches? db datom clause-value (addr next))
                  (arr.push! out^ next)
                  (delete next.items))))))
        (set! scan-index (+ scan-index 1))))
    (set! stats^.clause-candidates (+ stats^.clause-candidates candidate-count))))

(defn append-bindings-after-clause-profiled-with-op! [out: ^[dynamic]Binding, db: DB, clause-value: Clause, binding: Binding, op: Physical-Op, stats: ^Query-Stats]
  (set! stats^.clauses (+ stats^.clauses 1))
  (when clause-value.has-source
    (let [source-bindings (bindings-after-relation-source-clause-with-op clause-value binding op)]
      (defer (delete source-bindings))
      (set! stats^.clause-candidates (+ stats^.clause-candidates (count source-bindings)))
      (for [source-binding source-bindings]
        (arr.push! out^ source-binding)))
    (return))
  (append-bindings-after-clause-profiled! out db clause-value binding stats))

(defn append-bindings-after-clause-with-sources! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding]
  (when clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause! out source-db (unsourced-clause clause-value) binding)
        (return))))
  (append-bindings-after-clause! out db clause-value binding))

(defn append-bindings-after-clause-with-sources-profiled! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding, stats: ^Query-Stats]
  (when clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause-profiled! out source-db (unsourced-clause clause-value) binding stats)
        (return))))
  (append-bindings-after-clause-profiled! out db clause-value binding stats))

(defn append-bindings-after-clause-with-sources-profiled-with-op! [out: ^[dynamic]Binding, db: DB, sources: []DB-Source, clause-value: Clause, binding: Binding, op: Physical-Op, stats: ^Query-Stats]
  (when clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when source-ok
        (append-bindings-after-clause-profiled-with-op! out source-db (unsourced-clause clause-value) binding op stats)
        (return))))
  (append-bindings-after-clause-profiled-with-op! out db clause-value binding op stats))

(defn bindings-after-planned-clauses [db: DB, sources: []DB-Source, bindings: []Binding, clauses: []Clause] -> [dynamic]Binding
  (let [current (arr.into [dynamic]Binding bindings)
        remaining (arr.into [dynamic]Clause clauses)]
    (defer (delete remaining))
    (while (and (> (count current) 0)
                (> (count remaining) 0))
      (let [clause-index (best-clause-index-estimated db sources (slice remaining 0) current[0])
            clause remaining[clause-index]
            next (make [dynamic]Binding)]
        (for [binding current]
          (append-bindings-after-clause-with-sources! (addr next) db sources clause binding))
        (delete current)
        (set! current next)
        (arr.remove-ordered-at! remaining clause-index)))
    current))

(defstruct Clause-Index-Scan {
  view: DB-Index-View
  index: int
  high: int
  e-value: Value
  e-ok: bool
  a-value: Value
  a-ok: bool
  v-value: Value
  v-ok: bool
  reverse-attr: bool
  forward-attr: string
})

(defn delete-clause-index-scan [scan: Clause-Index-Scan]
  (when scan.reverse-attr
    (delete scan.forward-attr)))

(defn clause-index-scan-clone [scan: Clause-Index-Scan] -> Clause-Index-Scan
  (Clause-Index-Scan {view: scan.view
                      index: scan.index
                      high: scan.high
                      e-value: scan.e-value
                      e-ok: scan.e-ok
                      a-value: scan.a-value
                      a-ok: scan.a-ok
                      v-value: scan.v-value
                      v-ok: scan.v-ok
                      reverse-attr: scan.reverse-attr
                      forward-attr: (if scan.reverse-attr (string-owned scan.forward-attr) "")}))

(defn empty-clause-index-scan [db: DB] -> Clause-Index-Scan
  (Clause-Index-Scan {view: (db-index-view db .EAVT)
                      index: 0
                      high: 0
                      e-value: (Value {})
                      e-ok: false
                      a-value: (Value {})
                      a-ok: false
                      v-value: (Value {})
                      v-ok: false
                      reverse-attr: false
                      forward-attr: ""}))

(defn physical-scan-range-from-resolved-flags [e-ok: bool, a-ok: bool, v-ok: bool] -> Physical-Scan-Range
  (let [bounds (Physical-Clause-Scan-Bounds {e: (if e-ok .Constant .Free)
                                             a: (if a-ok .Constant .Free)
                                             v: (if v-ok .Constant .Free)
                                             tx: .Free
                                             op: .Free})]
    (physical-scan-range-from-bounds bounds)))

(defn physical-reverse-scan-range-from-resolved-flags [semantic-e-ok: bool, semantic-v-ok: bool] -> Physical-Scan-Range
  (cond
    semantic-e-ok
      (Physical-Scan-Range {kind: .Value order: .VAET prefix-width: 1})
    semantic-v-ok
      (Physical-Scan-Range {kind: .EntityAttr order: .EAVT prefix-width: 2})
    :else
      (Physical-Scan-Range {kind: .Attr order: .AEVT prefix-width: 1})))

(defn clause-index-range-from-physical-prefix [db: DB, range: Physical-Scan-Range, values: []Value] -> [view: DB-Index-View, low: int, high: int, ok: bool]
  (let [index-view (db-index-view db range.order)]
    (case range.kind
      .Full
        (return index-view 0 (db-index-view-count index-view) true)
      .Entity
        (do
          (when (or (not (= (count values) 1))
                    (not (= values[0].kind .Entity)))
            (return index-view 0 0 false))
          (return index-view
                  (lower-bound-index-view db index-view "eavt" values[0].entity "" (Value {}))
                  (upper-bound-index-view db index-view "eavt" values[0].entity "" (Value {}))
                  true))
      .Attr
        (do
          (when (or (not (= (count values) 1))
                    (not (= values[0].kind .Keyword)))
            (return index-view 0 0 false))
          (return index-view
                  (lower-bound-index-view db index-view "aevt" 0 values[0].text (Value {}))
                  (upper-bound-index-view db index-view "aevt" 0 values[0].text (Value {}))
                  true))
      .Value
        (do
          (when (not (= (count values) 1))
            (return index-view 0 0 false))
          (return index-view
                  (lower-bound-index-view db index-view "vaet" 0 "" values[0])
                  (upper-bound-index-view db index-view "vaet" 0 "" values[0])
                  true))
      .EntityAttr
        (do
          (when (or (not (= (count values) 2))
                    (not (= values[0].kind .Entity))
                    (not (= values[1].kind .Keyword)))
            (return index-view 0 0 false))
          (return index-view
                  (lower-bound-index-view db index-view "eavt-ea" values[0].entity values[1].text (Value {}))
                  (upper-bound-index-view db index-view "eavt-ea" values[0].entity values[1].text (Value {}))
                  true))
      .AttrValue
        (do
          (when (or (not (= (count values) 2))
                    (not (= values[0].kind .Keyword)))
            (return index-view 0 0 false))
          (return index-view
                  (lower-bound-index-view db index-view "avet" 0 values[0].text values[1])
                  (upper-bound-index-view db index-view "avet" 0 values[0].text values[1])
                  true))

      (return index-view 0 0 false))))

(defn clause-index-scan-resolved [db: DB, clause: Clause, e-value-in: Value, e-ok: bool, a-value-in: Value, a-ok-in: bool, v-value-in: Value, v-ok-in: bool, reverse-source-value: Value, reverse-source-ok: bool] -> Clause-Index-Scan
  (let [a-value a-value-in
        a-ok a-ok-in
        v-value v-value-in
        v-ok v-ok-in
        view (db-index-view db .EAVT)
        low 0
        high (db-index-view-count view)]
    (when a-ok
      (let [[resolved resolved-ok] (resolve-attribute-value db a-value)]
        (when (not resolved-ok)
          (return (empty-clause-index-scan db)))
        (set! a-value resolved)))
    (when (= clause.v.kind .LookupRef)
      (let [[lookup-entity lookup-ok] (resolve-lookup-ref db clause.v.lookup-attr clause.v.lookup-value)]
        (when lookup-ok
          (set! v-value (value-entity lookup-entity))
          (set! v-ok true))))
    (when v-ok
      (let [[entity entity-ok] (lookup-ref-value-as-entity db v-value)]
        (when entity-ok
          (set! v-value entity))))
    (when (and a-ok
               v-ok
               (= a-value.kind .Keyword)
               (= clause.a.kind .Value)
               (= clause.a.value.kind .Keyword))
      (let [[resolved resolved-ok] (ref-entity-literal db a-value.text v-value)]
        (when resolved-ok
          (set! v-value resolved))))
    (when (and a-ok
               (= a-value.kind .Keyword)
               (reverse-attr? a-value.text))
      (let [forward-attr (forward-attr-for-reverse a-value.text) :defer]
        (when reverse-source-ok
          (set! v-value reverse-source-value)
          (set! v-ok true))
        (when (and e-ok (not (= e-value-in.kind .Entity)))
          (return (empty-clause-index-scan db)))
        (when (and v-ok (not (= v-value.kind .Entity)))
          (return (empty-clause-index-scan db)))
        (let [range (physical-reverse-scan-range-from-resolved-flags e-ok v-ok)]
          (case range.kind
            .Value
              (let [values ([]Value [(value-entity e-value-in.entity)])
                    [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
                (when (not range-ok)
                  (return (empty-clause-index-scan db)))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))
            .EntityAttr
              (let [values ([]Value [(value-entity v-value.entity) (value-keyword forward-attr)])
                    [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
                (when (not range-ok)
                  (return (empty-clause-index-scan db)))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))
            .Attr
              (let [values ([]Value [(value-keyword forward-attr)])
                    [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
                (when (not range-ok)
                  (return (empty-clause-index-scan db)))
                (set! view candidate-view)
                (set! low candidate-low)
                (set! high candidate-high))

              (return (empty-clause-index-scan db))))
        (return (Clause-Index-Scan {view: view
                                    index: low
                                    high: high
                                    e-value: e-value-in
                                    e-ok: e-ok
                                    a-value: a-value
                                    a-ok: a-ok
                                    v-value: v-value
                                    v-ok: v-ok
                                    reverse-attr: true
                                    forward-attr: (forward-attr-for-reverse a-value.text)}))))
    (when (and v-ok
               (= clause.v.kind .Var)
               (= v-value.kind .Entity))
      (set! v-ok false))
    (let [range (physical-scan-range-from-resolved-flags e-ok a-ok v-ok)]
      (case range.kind
        .Full
          (do)
        .Entity
          (let [values ([]Value [e-value-in])
                [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
            (when (not range-ok)
              (return (empty-clause-index-scan db)))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .Attr
          (let [values ([]Value [a-value])
                [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
            (when (not range-ok)
              (return (empty-clause-index-scan db)))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .Value
          (let [values ([]Value [v-value])
                [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
            (when (not range-ok)
              (return (empty-clause-index-scan db)))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .EntityAttr
          (let [values ([]Value [e-value-in a-value])
                [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
            (when (not range-ok)
              (return (empty-clause-index-scan db)))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))
        .AttrValue
          (let [values ([]Value [a-value v-value])
                [candidate-view candidate-low candidate-high range-ok] (clause-index-range-from-physical-prefix db range values)]
            (when (not range-ok)
              (return (empty-clause-index-scan db)))
            (set! view candidate-view)
            (set! low candidate-low)
            (set! high candidate-high))

          (do)))
    (Clause-Index-Scan {view: view
                        index: low
                        high: high
                        e-value: e-value-in
                        e-ok: e-ok
                        a-value: a-value
                        a-ok: a-ok
                        v-value: v-value
                        v-ok: v-ok
                        reverse-attr: false
                        forward-attr: ""})))

(defn clause-index-scan-datom-index [scan: Clause-Index-Scan, index: int] -> int
  (db-index-view-at scan.view index))

(defn clause-index-scan [db: DB, clause: Clause, binding: Binding] -> Clause-Index-Scan
  (let [[e-value e-ok] (resolve-entity-term db clause.e binding)
        [a-value a-ok] (resolve-term clause.a binding)
        [v-value v-ok] (resolve-term clause.v binding)
        [reverse-source-value reverse-source-ok] (resolve-entity-term db clause.v binding)]
    (clause-index-scan-resolved db clause e-value e-ok a-value a-ok v-value v-ok reverse-source-value reverse-source-ok)))

(defn clause-index-scan-typed-row [db: DB, rel: Query-Relation, row: int, clause: Clause] -> Clause-Index-Scan
  (let [[e-value e-ok] (query-relation-resolve-typed-entity-scan-term db rel row clause.e)
        [a-value a-ok] (query-relation-resolve-typed-term rel row clause.a)
        [v-value v-ok] (query-relation-resolve-typed-term rel row clause.v)
        [reverse-source-value reverse-source-ok] (query-relation-resolve-typed-entity-scan-term db rel row clause.v)]
    (clause-index-scan-resolved db clause e-value e-ok a-value a-ok v-value v-ok reverse-source-value reverse-source-ok)))

(defn clause-index-scan-candidate? [scan: Clause-Index-Scan, datom: Datom] -> bool
  (if scan.reverse-attr
    (and (= datom.a scan.forward-attr)
         (= datom.v.kind .Entity))
    (candidate-index-matches? datom scan.e-value scan.e-ok scan.a-value scan.a-ok scan.v-value scan.v-ok)))

(defn binding-matches-clause? [db: DB, clause: Clause, binding: Binding] -> bool
  (when clause.has-source
    (let [source-bindings (bindings-after-relation-source-clause clause binding) :defer]
      (return (> (count source-bindings) 0))))
  (let [scan (clause-index-scan db clause binding)]
    (defer (delete-clause-index-scan scan))
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (and (clause-index-scan-candidate? scan datom)
                     (datom-current-at? db datom-index))
            (let [candidate (clone-binding binding)]
              (if (datom-clause-matches? db datom clause (addr candidate))
                (do
                  (delete candidate.items)
                  (return true))
                (delete candidate.items)))))
        (set! scan-index (+ scan-index 1)))))
  false)

(defn bindings-after-not-group-local-step-with-fns [db: DB, sources: []DB-Source, rules: []Rule, bindings: []Binding, group: Not-Group, step: Query-Step, registry: []Native-Query-Fn] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources! (addr out) db sources group.clauses[step.index] binding))
        out)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings group.predicates[step.index] registry)
    .Function
      (bindings-after-function-with-fns bindings group.function-clauses[step.index] registry)
    .GetElse
      (bindings-after-get-else-step db bindings group.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings group.get-somes[step.index])
    .Ground
      (apply-ground bindings group.grounds[step.index])
    .RuleCall
      (let [out (make [dynamic]Binding)
            call group.rule-calls[step.index]]
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-with-fns db rules call binding registry)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)
    .Not
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-rules-sources-and-fns? db rules sources group.not-groups[step.index] binding registry))
            (arr.push! out binding)))
        out)

      (arr.into [dynamic]Binding bindings)))

(defn bindings-after-clause-group-with-rules-sources-and-fns [db: DB, rules: []Rule, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings ([dynamic]Binding [binding])]
    (if (> (count group.steps) 0)
      (for [step group.steps]
        (let [next-bindings (bindings-after-not-group-local-step-with-fns db sources rules (slice bindings 0) group step registry)]
          (delete bindings)
          (set! bindings next-bindings)
          (when (= (count bindings) 0)
            (return bindings))))
      (do
        (when (> (count group.clauses) 0)
          (let [next-bindings (bindings-after-planned-clauses db sources (slice bindings 0) (slice group.clauses 0))]
            (delete bindings)
            (set! bindings next-bindings)
            (when (= (count bindings) 0)
              (return bindings))))
        (for [not-group group.not-groups]
          (let [next-bindings (make [dynamic]Binding)]
            (for [candidate-binding bindings]
              (when (not (binding-matches-not-group-with-rules-sources-and-fns? db rules sources not-group candidate-binding registry))
                (arr.push! next-bindings candidate-binding)))
            (delete bindings)
            (set! bindings next-bindings)
            (when (= (count bindings) 0)
              (return bindings))))))
    bindings))

(defn bindings-after-clause-group-with-sources-and-fns [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-clause-group-with-rules-sources-and-fns db ([]Rule []) sources group binding registry))

(defn bindings-after-clause-group-with-sources [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-clause-group-with-sources-and-fns db sources group binding ([]Native-Query-Fn [])))

(defn bindings-after-clause-group [db: DB, group: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-clause-group-with-sources db ([]DB-Source []) group binding))

(defn project-binding [binding: Binding, names: []string] -> Binding
  (let [out (Binding {})]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (when ok
          (binding-store! (addr out) name value))))
    out))

(defn merge-binding [base: Binding, extra: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding base)]
    (for [item extra.items]
      (let [[existing exists] (binding-lookup out item.name)]
        (if exists
          (when (not (predicate-value-equal? existing item.value))
            (return out false))
          (binding-store! (addr out) item.name item.value))))
    (return out true)))

(defn binding-with-value [binding: Binding, name: string, value: Value] -> [next: Binding, ok: bool]
  (let [out (clone-binding binding)
        [existing exists] (binding-lookup out name)]
    (if exists
      (return out (predicate-value-equal? existing value))
      (do
        (binding-store! (addr out) name value)
        (return out true)))))

(defn apply-get-else [db: DB, binding: Binding, clause: Get-Else] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (let [[value value-ok] (pull-attr-value db entity.entity clause.a)]
      (if value-ok
        (binding-with-value binding clause.out value)
        (binding-with-value binding clause.out clause.default-value)))))

(defn get-some-attr-result-value [db: DB, attr: string] -> Value
  (discard db)
  (value-keyword attr))

(defn apply-get-some [db: DB, binding: Binding, clause: Get-Some] -> [next: Binding, ok: bool]
  (let [[entity entity-ok] (resolve-entity-term db clause.e binding)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return binding false))
    (for [attr clause.attrs]
      (let [[value value-ok] (pull-attr-value db entity.entity attr)]
        (when value-ok
          (let [[with-attr attr-ok] (binding-with-value binding clause.out-attr (get-some-attr-result-value db attr))]
            (when (not attr-ok)
              (return with-attr false))
            (return (binding-with-value with-attr clause.out-value value))))))
    (return binding false)))

(defn ground-bind-values [binding: Binding, vars: []string, values: []Value] -> [next: Binding, ok: bool]
  (when (not (= (count vars) (count values)))
    (return binding false))
  (let [bound-binding (clone-binding binding)]
    (for [name index vars]
      (when (not (= name ""))
        (let [[bound bound-ok] (binding-with-value bound-binding name values[index])]
          (when (not bound-ok)
            (return binding false))
          (set! bound-binding bound))))
    (return bound-binding true)))

(defn apply-ground [bindings: []Binding, ground: Ground] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[source source-ok] (resolve-term ground.source binding)]
        (when source-ok
          (if (not (= ground.binding.kind .None))
            (do
              (let [bound (bind-input-pattern binding ground.binding source)]
                (for [item bound]
                  (arr.push! out item))))
            (if ground.is-tuple
            (when (= source.kind .Vector)
              (let [[next ok] (ground-bind-values binding ground.tuple-vars (slice source.items 0))]
                (when ok
                  (arr.push! out next))))
            (if ground.is-relation
              (when (= source.kind .Vector)
                (for [row source.items]
                  (when (and (= row.kind .Vector)
                             (= (count row.items) ground.width))
                    (let [[next ok] (ground-bind-values binding ground.tuple-vars (slice row.items 0))]
                      (when ok
                        (arr.push! out next))))))
              (if ground.is-collection
                (when (or (= source.kind .Vector)
                          (= source.kind .Set))
                  (for [value source.items]
                    (let [[next ok] (binding-with-value binding ground.out value)]
                      (when ok
                        (arr.push! out next)))))
                (if (= ground.out "")
                  (arr.push! out binding)
                  (let [[next ok] (binding-with-value binding ground.out source)]
                    (when ok
                      (arr.push! out next)))))))))))
    out))

(defn typed-ground-produced-values [rel: Query-Relation, row: int, vars: []string, values: []Value, output-vars: []string] -> [produced: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (when (not (= (count vars) (count values)))
      (return out false))
    (for [name index vars]
      (when (and (not (= name ""))
                 (not (= name "_")))
        (let [value values[index]]
          (when (not (query-relation-typed-row-var-agrees? rel row name value))
            (return out false))
          (let [prev 0]
            (while (< prev index)
              (when (and (= vars[prev] name)
                         (not (predicate-value-equal? values[prev] value)))
                (return out false))
              (set! prev (+ prev 1)))))))
    (for [name output-vars]
      (when (and (not (= name ""))
                 (not (= name "_"))
                 (not (query-relation-has-attr? rel name)))
        (let [found false
              index 0]
          (while (< index (count vars))
            (when (and (not found) (= vars[index] name))
              (arr.push! out values[index])
              (set! found true))
            (set! index (+ index 1))))))
    (return out true)))

(defn typed-binding-temp-index [names: []string, name: string] -> [index: int, ok: bool]
  (for [candidate index names]
    (when (= candidate name)
      (return index true)))
  (return -1 false))

(defn input-binding-contains-collection? [binding: Input-Binding] -> bool
  (case binding.kind
    .Collection (return true)
    .Tuple
      (do
        (for [item binding.items]
          (when (input-binding-contains-collection? item)
            (return true)))
        (return false))
     (return false))
  false)

(defn typed-bind-input-pattern-value! [rel: Query-Relation, row: int, binding: Input-Binding, value: Value, names: ^[dynamic]string, values: ^[dynamic]Value] -> bool
  (case binding.kind
    .Ignore (return true)
    .None (return true)
    .Var
      (do
        (when (or (= binding.name "")
                  (= binding.name "_"))
          (return true))
        (when (not (query-relation-typed-row-var-agrees? rel row binding.name value))
          (return false))
        (let [[existing-index existing-ok] (typed-binding-temp-index (slice names^ 0) binding.name)]
          (if existing-ok
            (predicate-value-equal? values^[existing-index] value)
            (do
              (arr.push! names^ binding.name)
              (arr.push! values^ value)
              (return true)))))
    .Tuple
      (do
        (when (not (= value.kind .Vector))
          (return false))
        (when (not (= (count binding.items) (count value.items)))
          (return false))
        (for [item index binding.items]
          (when (not (typed-bind-input-pattern-value! rel row item value.items[index] names values))
            (return false)))
        (return true))
    .Collection (return false)
    (return false))
  false)

(defn typed-produced-values-from-input-binding [rel: Query-Relation, row: int, binding: Input-Binding, value: Value, output-vars: []string] -> [produced: [dynamic]Value, ok: bool]
  (let [names (make [dynamic]string) :defer
        values (make [dynamic]Value) :defer
        out (make [dynamic]Value)]
    (when (not (typed-bind-input-pattern-value! rel row binding value (addr names) (addr values)))
      (return out false))
    (for [name output-vars]
      (when (and (not (= name ""))
                 (not (= name "_"))
                 (not (query-relation-has-attr? rel name)))
        (let [[index found] (typed-binding-temp-index (slice names 0) name)]
          (if found
            (arr.push! out values[index])
            (return out false)))))
    (return out true)))

(defstruct Typed-Input-Binding-Env {
  names: [dynamic]string
  values: [dynamic]Value
})

(defstruct Typed-Produced-Values {
  values: [dynamic]Value
})

(defn typed-input-binding-env-empty [] -> Typed-Input-Binding-Env
  (Typed-Input-Binding-Env {names: (make [dynamic]string)
                            values: (make [dynamic]Value)}))

(defn clone-typed-input-binding-env [env: Typed-Input-Binding-Env] -> Typed-Input-Binding-Env
  (let [names (arr.into [dynamic]string (slice env.names 0))
        values (arr.into [dynamic]Value (slice env.values 0))]
    (Typed-Input-Binding-Env {names: names
                              values: values})))

(defn delete-typed-input-binding-env [env: Typed-Input-Binding-Env]
  (let [names env.names
        values env.values]
    (delete names)
    (delete values)))

(defn delete-typed-input-binding-envs [envs: [dynamic]Typed-Input-Binding-Env]
  (for [env envs]
    (delete-typed-input-binding-env env))
  (delete envs))

(defn delete-typed-produced-values [rows: [dynamic]Typed-Produced-Values]
  (for [row rows]
    (let [values row.values]
      (delete values)))
  (delete rows))

(defn typed-input-binding-env-bind-var! [rel: Query-Relation, row: int, env: ^Typed-Input-Binding-Env, name: string, value: Value] -> bool
  (when (or (= name "")
            (= name "_"))
    (return true))
  (when (not (query-relation-typed-row-var-agrees? rel row name value))
    (return false))
  (let [[existing-index existing-ok] (typed-binding-temp-index (slice env^.names 0) name)]
    (if existing-ok
      (predicate-value-equal? env^.values[existing-index] value)
      (do
        (arr.push! env^.names name)
        (arr.push! env^.values value)
        (return true)))))

(defn typed-bind-input-pattern-envs [rel: Query-Relation, row: int, binding: Input-Binding, value: Value, env: Typed-Input-Binding-Env] -> [dynamic]Typed-Input-Binding-Env
  (let [out (make [dynamic]Typed-Input-Binding-Env)]
    (case binding.kind
      .Ignore (arr.push! out (clone-typed-input-binding-env env))
      .None (arr.push! out (clone-typed-input-binding-env env))
      .Var
        (do
          (let [next (clone-typed-input-binding-env env)]
            (if (typed-input-binding-env-bind-var! rel row (addr next) binding.name value)
              (arr.push! out next)
              (delete-typed-input-binding-env next))))
      .Tuple
        (when (and (= value.kind .Vector)
                   (= (count binding.items) (count value.items)))
          (let [current (make [dynamic]Typed-Input-Binding-Env)]
            (arr.push! current (clone-typed-input-binding-env env))
            (for [item index binding.items]
              (let [next-current (make [dynamic]Typed-Input-Binding-Env)]
                (for [candidate current]
                  (let [bound (typed-bind-input-pattern-envs rel row item value.items[index] candidate)]
                    (for [bound-item bound]
                      (arr.push! next-current bound-item))
                    (delete bound)
                    (delete-typed-input-binding-env candidate)))
                (delete current)
                (set! current next-current)))
            (for [candidate current]
              (arr.push! out candidate))
            (delete current)))
      .Collection
        (when (and (or (= value.kind .Vector)
                       (= value.kind .Set))
                   (= (count binding.items) 1))
          (for [item value.items]
            (let [bound (typed-bind-input-pattern-envs rel row binding.items[0] item env)]
              (for [bound-item bound]
                (arr.push! out bound-item))
              (delete bound))))
       (do))
    out))

(defn typed-produced-values-from-env [rel: Query-Relation, env: Typed-Input-Binding-Env, output-vars: []string] -> [produced: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name output-vars]
      (when (and (not (= name ""))
                 (not (= name "_"))
                 (not (query-relation-has-attr? rel name)))
        (let [[index found] (typed-binding-temp-index (slice env.names 0) name)]
          (if found
            (arr.push! out env.values[index])
            (return out false)))))
    (return out true)))

(defn typed-produced-value-rows-from-input-binding [rel: Query-Relation, row: int, binding: Input-Binding, value: Value, output-vars: []string] -> [produced: [dynamic]Typed-Produced-Values, ok: bool]
  (let [out (make [dynamic]Typed-Produced-Values)
        seed (typed-input-binding-env-empty)
        envs (typed-bind-input-pattern-envs rel row binding value seed)]
    (for [env envs]
      (let [[values values-ok] (typed-produced-values-from-env rel env output-vars)]
        (if values-ok
          (arr.push! out (Typed-Produced-Values {values: values}))
          (delete values))))
    (delete-typed-input-binding-envs envs)
    (delete-typed-input-binding-env seed)
    (return out true)))

(defn bindings-after-function-with-fns [bindings: []Binding, function: Function-Clause, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (if (not (= function.out-binding.kind .None))
        (let [[value value-ok] (apply-function-op-with-fns function binding registry)]
          (when value-ok
            (let [bound (bind-input-pattern binding function.out-binding value)]
              (for [item bound]
                (arr.push! out item)))))
        (let [[next ok] (apply-function-clause-with-fns binding function registry)]
          (when ok
            (arr.push! out next)))))
    out))

(defn bindings-after-function [bindings: []Binding, function: Function-Clause] -> [dynamic]Binding
  (bindings-after-function-with-fns bindings function ([]Native-Query-Fn [])))

(defn bindings-after-predicate-with-db-and-fns [db: DB, bindings: []Binding, predicate: Predicate, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (when (predicate-matches-with-db-and-fns? db predicate binding registry)
        (arr.push! out binding)))
    out))

(defn bindings-after-predicate-with-fns [bindings: []Binding, predicate: Predicate, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-predicate-with-db-and-fns (DB {}) bindings predicate registry))

(defn bindings-after-predicate [bindings: []Binding, predicate: Predicate] -> [dynamic]Binding
  (bindings-after-predicate-with-fns bindings predicate ([]Native-Query-Fn [])))

(defn rule-clause-with-source [clause: Clause, source: string, has-source: bool] -> Clause
  (when (or (not has-source) clause.has-source)
    (return clause))
  (Clause {e: clause.e
           a: clause.a
           v: clause.v
           tx-term: clause.tx-term
           op-term: clause.op-term
           source: source
           has-source: true
           source-width: (relation-source-width-for-clause clause)}))

(defn rule-clauses-with-source [clauses: []Clause, source: string, has-source: bool] -> [dynamic]Clause
  (let [out (make [dynamic]Clause 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (rule-clause-with-source clause source has-source)))
    out))

(defn get-else-with-source [clause: Get-Else, source: string, has-source: bool] -> Get-Else
  (when (or (not has-source) clause.has-source)
    (return clause))
  (let [out clause]
    (set! out.source source)
    (set! out.has-source true)
    out))

(defn get-elses-with-source [clauses: []Get-Else, source: string, has-source: bool] -> [dynamic]Get-Else
  (let [out (make [dynamic]Get-Else 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (get-else-with-source clause source has-source)))
    out))

(defn get-some-with-source [clause: Get-Some, source: string, has-source: bool] -> Get-Some
  (let [out (get-some-owned clause)]
    (when (and has-source (not clause.has-source))
      (set! out.source source)
      (set! out.has-source true))
    out))

(defn get-somes-with-source [clauses: []Get-Some, source: string, has-source: bool] -> [dynamic]Get-Some
  (let [out (make [dynamic]Get-Some 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (get-some-with-source clause source has-source)))
    out))

(defn bind-rule-source [outer: Binding, initial: Binding, source: string, has-source: bool] -> [binding: Binding, ok: bool]
  (when (not has-source)
    (return initial true))
  (let [[source-value source-ok] (binding-lookup outer source)]
    (when (not source-ok)
      (return initial false))
    (let [next (clone-binding initial)]
      (binding-store! (addr next) source source-value)
      (return next true))))

(defn binding-equal? [left: Binding, right: Binding] -> bool
  (when (not (= (count left.items) (count right.items)))
    (return false))
  (for [item left.items]
    (let [[right-value right-ok] (binding-lookup right item.name)]
      (when (not (and right-ok (value-equal? item.value right-value)))
        (return false))))
  true)

(defn binding-exists? [bindings: []Binding, binding: Binding] -> bool
  (for [existing bindings]
    (when (binding-equal? existing binding)
      (return true)))
  false)

(defn append-unique-binding! [out: ^[dynamic]Binding, seen: (ptr (map string (struct {}))), binding: Binding] -> bool
  (let [[key key-ok] (binding-dedupe-key binding)]
    (when key-ok
      (let [already-seen (set.contains? seen^ key)]
        (when already-seen
          (return false))
        (set.add! seen key)
        (arr.push! out^ binding)
        (return true)))
    (when (not (binding-exists? (slice out^ 0) binding))
      (arr.push! out^ binding)
      (return true))
    false))

(defn unique-bindings [bindings: []Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding 0 (count bindings))
        seen (set.empty string)]
    (defer (delete seen))
    (for [binding bindings]
      (discard (append-unique-binding! (addr out) (addr seen) binding)))
    out))

(defn query-stats-observe-bindings! [stats: ^Query-Stats, count-value: int]
  (when (> count-value stats^.max-intermediate-bindings)
    (set! stats^.max-intermediate-bindings count-value)))

(defn query-stats-observe-materialization! [stats: ^Query-Stats, count-value: int]
  (set! stats^.generic-materialization-steps (+ stats^.generic-materialization-steps 1))
  (set! stats^.binding-materializations (+ stats^.binding-materializations count-value)))

(defn query-stats-observe-source-operator! [stats: ^Query-Stats]
  (set! stats^.source-operators (+ stats^.source-operators 1)))

(defn term-var-name? [term: Term, name: string] -> bool
  (and (= term.kind .Var)
       (= term.name name)))

(defn term-wildcard? [term: Term] -> bool
  (= term.kind .Wildcard))

(defn clause-attr-keyword [clause: Clause] -> [attr: string, ok: bool]
  (when (and (= clause.a.kind .Value)
             (= clause.a.value.kind .Keyword))
    (return clause.a.value.text true))
  (return "" false))

(defn rule-has-only-plain-clauses-and-calls? [rule: Rule] -> bool
  (and (= (count rule.predicates) 0)
       (= (count rule.function-clauses) 0)
       (= (count rule.get-elses) 0)
       (= (count rule.get-somes) 0)
       (= (count rule.grounds) 0)
       (= (count rule.not-groups) 0)
       (= (count rule.or-groups) 0)))

(defstruct Linear-Transitive-Plan {
  attr: string
  derived-edge: bool
  derived-left-attr: string
  derived-right-attr: string
  filters: [dynamic]Clause
})

(defn delete-linear-transitive-plan [plan: Linear-Transitive-Plan]
  (delete plan.filters))

(defn linear-transitive-filter-clause? [clause: Clause, node-var: string] -> bool
  (and (not clause.has-source)
       (term-wildcard? clause.tx-term)
       (term-wildcard? clause.op-term)
       (term-var-name? clause.e node-var)
       (= clause.a.kind .Value)
       (= clause.a.value.kind .Keyword)
       (= clause.v.kind .Value)))

(defn linear-transitive-filter-same? [left: Clause, right: Clause] -> bool
  (and (= left.a.value.text right.a.value.text)
       (value-equal? left.v.value right.v.value)))

(defn linear-transitive-filter-exists? [filters: []Clause, filter: Clause] -> bool
  (for [existing filters]
    (when (linear-transitive-filter-same? existing filter)
      (return true)))
  false)

(defn linear-transitive-filters-same? [left: []Clause, right: []Clause] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [filter left]
    (when (not (linear-transitive-filter-exists? right filter))
      (return false)))
  true)

(defn linear-transitive-edge-and-filters [rule: Rule, from-var: string, to-var: string] -> [attr: string, filters: [dynamic]Clause, ok: bool]
  (let [out-filters (make [dynamic]Clause)
        attr ""
        found-edge false]
    (for [rule-clause rule.clauses]
      (let [[clause-attr clause-attr-ok] (clause-attr-keyword rule-clause)]
        (if (and clause-attr-ok
                 (term-var-name? rule-clause.e from-var)
                 (term-var-name? rule-clause.v to-var))
          (do
            (when found-edge
              (delete out-filters)
              (return "" (make [dynamic]Clause) false))
            (set! attr clause-attr)
            (set! found-edge true))
          (if (linear-transitive-filter-clause? rule-clause to-var)
            (arr.push! out-filters rule-clause)
            (do
              (delete out-filters)
              (return "" (make [dynamic]Clause) false))))))
    (return attr out-filters found-edge)))

(defn rule-two-hop-derived-edge [rules: []Rule, name: string] -> [left-attr: string, right-attr: string, ok: bool]
  (for [rule rules]
    (when (= rule.name name)
      (when (and (= (count rule.params) 2)
                 (= (count rule.rule-calls) 1)
                 (= (count rule.clauses) 1)
                 (rule-has-only-plain-clauses-and-calls? rule))
        (let [rule-clause rule.clauses[0]
              rule-call rule.rule-calls[0]
              [clause-attr clause-attr-ok] (clause-attr-keyword rule-clause)]
          (when (and clause-attr-ok
                     (not rule-call.has-source)
                     (= (count rule-call.args) 2)
                     (term-var-name? rule-clause.e rule.params[0])
                     (= rule-clause.v.kind .Var)
                     (term-var-name? rule-call.args[0] rule-clause.v.name)
                     (term-var-name? rule-call.args[1] rule.params[1]))
            (for [leaf-rule rules]
              (when (= leaf-rule.name rule-call.name)
                (when (= (count leaf-rule.params) 2)
                  (let [[leaf-attr leaf-filters leaf-ok] (linear-transitive-edge-and-filters leaf-rule leaf-rule.params[0] leaf-rule.params[1])]
                    (delete leaf-filters)
                    (when leaf-ok
                      (return clause-attr leaf-attr true)))))))))
      (when (not (and (= (count rule.params) 2)
                      (= (count rule.rule-calls) 0)
                      (= (count rule.clauses) 2)
                      (rule-has-only-plain-clauses-and-calls? rule)))
        (return "" "" false))
      (let [first rule.clauses[0]
            second rule.clauses[1]
            [first-attr first-attr-ok] (clause-attr-keyword first)
            [second-attr second-attr-ok] (clause-attr-keyword second)]
        (when (and first-attr-ok
                   second-attr-ok
                   (term-var-name? first.e rule.params[0])
                   (= first.v.kind .Var)
                   (term-var-name? second.e first.v.name)
                   (term-var-name? second.v rule.params[1]))
          (return first-attr second-attr true))
        (when (and first-attr-ok
                   second-attr-ok
                   (term-var-name? second.e rule.params[0])
                   (= second.v.kind .Var)
                   (term-var-name? first.e second.v.name)
                   (term-var-name? first.v rule.params[1]))
          (return second-attr first-attr true))
        (return "" "" false))))
  (return "" "" false))

(defn rule-two-hop-reverse-derived-edge [rules: []Rule, name: string] -> [rule: Rule, left-attr: string, right-attr: string, ok: bool]
  (for [rule rules]
    (when (= rule.name name)
      (when (not (and (= (count rule.params) 2)
                      (= (count rule.rule-calls) 0)
                      (= (count rule.clauses) 2)
                      (rule-has-only-plain-clauses-and-calls? rule)))
        (return (Rule {}) "" "" false))
      (let [first rule.clauses[0]
            second rule.clauses[1]
            [first-attr first-attr-ok] (clause-attr-keyword first)
            [second-attr second-attr-ok] (clause-attr-keyword second)]
        (when (and first-attr-ok
                   second-attr-ok
                   (= first.e.kind .Var)
                   (term-var-name? first.v rule.params[0])
                   (term-var-name? second.e rule.params[1])
                   (= second.v.kind .Var)
                   (= second.v.name first.e.name))
          (return rule first-attr second-attr true))
        (when (and first-attr-ok
                   second-attr-ok
                   (= second.e.kind .Var)
                   (term-var-name? second.v rule.params[0])
                   (term-var-name? first.e rule.params[1])
                   (= first.v.kind .Var)
                   (= first.v.name second.e.name))
          (return rule second-attr first-attr true))
        (return (Rule {}) "" "" false))))
  (return (Rule {}) "" "" false))

(defn derived-edge-call? [rules: []Rule, call: Rule-Call, from-var: string, to-var: string] -> [left-attr: string, right-attr: string, ok: bool]
  (when (not (and (not call.has-source)
                  (= (count call.args) 2)
                  (term-var-name? call.args[0] from-var)
                  (term-var-name? call.args[1] to-var)))
    (return "" "" false))
  (rule-two-hop-derived-edge rules call.name))

(defn empty-linear-transitive-plan [] -> Linear-Transitive-Plan
  (Linear-Transitive-Plan {filters: (make [dynamic]Clause)}))

(defn linear-derived-plan-compatible? [derived-edge: bool, left-attr: string, right-attr: string, next-derived: bool, next-left: string, next-right: string] -> bool
  (or (= (count left-attr) 0)
      (and (= derived-edge next-derived)
           (= left-attr next-left)
           (= right-attr next-right))))

(defn linear-transitive-rule-plan [rules: []Rule, name: string] -> [plan: Linear-Transitive-Plan, ok: bool]
  (let [found-base false
        found-recursive false
        attr ""
        derived-edge false
        derived-left-attr ""
        derived-right-attr ""
        filters (make [dynamic]Clause)]
    (for [rule rules]
      (when (= rule.name name)
        (when (not (and (= (count rule.params) 2)
                        (rule-has-only-plain-clauses-and-calls? rule)))
          (delete filters)
          (return (empty-linear-transitive-plan) false))
        (when (= (count rule.rule-calls) 0)
          (let [[base-attr base-filters base-ok] (linear-transitive-edge-and-filters rule rule.params[0] rule.params[1])]
            (when (or (not base-ok)
                      found-base
                      (not (linear-derived-plan-compatible? derived-edge derived-left-attr derived-right-attr false base-attr "")))
              (delete filters)
              (delete base-filters)
              (return (empty-linear-transitive-plan) false))
            (set! attr base-attr)
            (set! derived-edge false)
            (set! derived-left-attr base-attr)
            (set! derived-right-attr "")
            (delete filters)
            (set! filters base-filters)
            (set! found-base true)))
        (when (and (= (count rule.clauses) 0)
                   (= (count rule.rule-calls) 1)
                   (not (= rule.rule-calls[0].name name)))
          (let [[left-attr right-attr edge-ok] (derived-edge-call? rules rule.rule-calls[0] rule.params[0] rule.params[1])]
            (when (or (not edge-ok)
                      found-base
                      (not (linear-derived-plan-compatible? derived-edge derived-left-attr derived-right-attr true left-attr right-attr)))
              (delete filters)
              (return (empty-linear-transitive-plan) false))
            (set! attr "")
            (set! derived-edge true)
            (set! derived-left-attr left-attr)
            (set! derived-right-attr right-attr)
            (set! found-base true)))
        (when (> (count rule.rule-calls) 0)
          (let [recursive-index -1
                recursive-mid ""]
            (for [rule-call index rule.rule-calls]
              (when (and (= rule-call.name name)
                         (= (count rule-call.args) 2)
                         (= rule-call.args[0].kind .Var)
                         (term-var-name? rule-call.args[1] rule.params[1]))
                (set! recursive-index index)
                (set! recursive-mid rule-call.args[0].name)))
            (when (>= recursive-index 0)
              (if (= (count rule.rule-calls) 1)
                (let [[recursive-attr recursive-filters recursive-ok] (linear-transitive-edge-and-filters rule rule.params[0] recursive-mid)]
                  (when (or (not recursive-ok)
                            (not (linear-derived-plan-compatible? derived-edge derived-left-attr derived-right-attr false recursive-attr ""))
                            (and found-base (not (linear-transitive-filters-same? (slice filters 0) (slice recursive-filters 0)))))
                    (delete filters)
                    (delete recursive-filters)
                    (return (empty-linear-transitive-plan) false))
                  (when (not found-base)
                    (delete filters)
                    (let [owned-filters (arr.into [dynamic]Clause (slice recursive-filters 0))]
                      (set! filters owned-filters)))
                  (set! attr recursive-attr)
                  (set! derived-edge false)
                  (set! derived-left-attr recursive-attr)
                  (set! derived-right-attr "")
                  (delete recursive-filters)
                  (set! found-recursive true))
                (when (and (= (count rule.clauses) 0)
                           (= (count rule.rule-calls) 2))
                  (let [edge-index (if (= recursive-index 0) 1 0)
                        [left-attr right-attr edge-ok] (derived-edge-call? rules rule.rule-calls[edge-index] rule.params[0] recursive-mid)]
                    (when (or (not edge-ok)
                              (not (linear-derived-plan-compatible? derived-edge derived-left-attr derived-right-attr true left-attr right-attr)))
                      (delete filters)
                      (return (empty-linear-transitive-plan) false))
                    (set! attr "")
                    (set! derived-edge true)
                    (set! derived-left-attr left-attr)
                    (set! derived-right-attr right-attr)
                    (set! found-recursive true)))))))))
    (return (Linear-Transitive-Plan {attr: attr derived-edge: derived-edge derived-left-attr: derived-left-attr derived-right-attr: derived-right-attr filters: filters}) (and found-base found-recursive))))

(defn linear-transitive-rule-attr [rules: []Rule, name: string] -> [attr: string, ok: bool]
  (let [[plan plan-ok] (linear-transitive-rule-plan rules name)]
    (defer (delete-linear-transitive-plan plan))
    (return plan.attr plan-ok)))

(defstruct Alternating-Transitive-Plan {
  left-name: string
  left-attr: string
  right-name: string
  right-attr: string
})

(defn empty-alternating-transitive-plan [] -> Alternating-Transitive-Plan
  (Alternating-Transitive-Plan {}))

(defn alternating-base-rule-attr [rule: Rule] -> [attr: string, ok: bool]
  (when (not (and (= (count rule.params) 2)
                  (rule-has-only-plain-clauses-and-calls? rule)
                  (= (count rule.rule-calls) 0)
                  (= (count rule.clauses) 1)))
    (return "" false))
  (let [rule-clause rule.clauses[0]
        [attr attr-ok] (clause-attr-keyword rule-clause)]
    (return attr
      (and attr-ok
           (not rule-clause.has-source)
           (term-wildcard? rule-clause.tx-term)
           (term-wildcard? rule-clause.op-term)
           (term-var-name? rule-clause.e rule.params[0])
           (term-var-name? rule-clause.v rule.params[1])))))

(defn alternating-recursive-rule-shape [rule: Rule] -> [attr: string, next-name: string, ok: bool]
  (when (not (and (= (count rule.params) 2)
                  (rule-has-only-plain-clauses-and-calls? rule)
                  (= (count rule.rule-calls) 1)
                  (= (count rule.clauses) 1)))
    (return "" "" false))
  (let [call rule.rule-calls[0]]
    (when (not (and (= (count call.args) 2)
                    (= call.args[0].kind .Var)
                    (= call.args[1].kind .Var)
                    (= call.args[1].name rule.params[1])))
      (return "" "" false))
    (let [mid-var call.args[0].name
          rule-clause rule.clauses[0]
          [attr attr-ok] (clause-attr-keyword rule-clause)]
      (return attr call.name
        (and attr-ok
             (not call.has-source)
             (not rule-clause.has-source)
             (term-wildcard? rule-clause.tx-term)
             (term-wildcard? rule-clause.op-term)
             (term-var-name? rule-clause.e rule.params[0])
             (term-var-name? rule-clause.v mid-var))))))

(defn alternating-rule-shape [rules: []Rule, name: string] -> [attr: string, next-name: string, ok: bool]
  (let [attr ""
        next-rule-name ""
        found-base false
        found-recursive false]
    (for [rule rules]
      (when (= rule.name name)
        (let [branch-ok false]
        (let [[base-attr base-ok] (alternating-base-rule-attr rule)]
          (when base-ok
            (set! branch-ok true)
            (when (or found-base
                      (and (> (count attr) 0) (not (= attr base-attr))))
              (return "" "" false))
            (set! attr base-attr)
            (set! found-base true)))
        (let [[recursive-attr recursive-next recursive-ok] (alternating-recursive-rule-shape rule)]
          (when recursive-ok
            (set! branch-ok true)
            (when (or found-recursive
                      (and (> (count attr) 0) (not (= attr recursive-attr))))
              (return "" "" false))
            (set! attr recursive-attr)
            (set! next-rule-name recursive-next)
            (set! found-recursive true)))
        (when (not branch-ok)
          (return "" "" false)))))
    (return attr next-rule-name (and found-base found-recursive))))

(defn alternating-transitive-rule-plan [rules: []Rule, name: string] -> [plan: Alternating-Transitive-Plan, ok: bool]
  (let [[left-attr right-name left-ok] (alternating-rule-shape rules name)]
    (when (not left-ok)
      (return (empty-alternating-transitive-plan) false))
    (let [[right-attr next-name right-ok] (alternating-rule-shape rules right-name)]
      (when (not (and right-ok (= next-name name) (not (= name right-name))))
        (return (empty-alternating-transitive-plan) false))
      (return (Alternating-Transitive-Plan {left-name: name
                                            left-attr: left-attr
                                            right-name: right-name
                                            right-attr: right-attr})
              true))))

(defn first-rule-by-name [rules: []Rule, name: string] -> [rule: Rule, ok: bool]
  (for [rule rules]
    (when (= rule.name name)
      (return rule true)))
  (return (Rule {}) false))

(defn append-transitive-targets! [out: ^[dynamic]u64, db: DB, attr: string, start: u64]
  (let [expanded (set.empty u64)
        emitted (set.empty u64)
        frontier (make [dynamic]u64)
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            edge-clause (clause (term-value (value-entity current)) attr (term-wildcard))
            scan (clause-index-scan db edge-clause (Binding {}))]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (set.contains? expanded current)]
          (when (not already-expanded)
            (set.add! expanded current)
            (let [scan-index scan.index]
              (while (< scan-index scan.high)
                (let [datom-index (clause-index-scan-datom-index scan scan-index)
                      datom db.datoms[datom-index]]
                  (when (and (clause-index-scan-candidate? scan datom)
                             (datom-current-at? db datom-index)
                             (= datom.v.kind .Entity))
                    (let [already-emitted (set.contains? emitted datom.v.entity)
                          target-expanded (set.contains? expanded datom.v.entity)]
                      (when (not already-emitted)
                        (set.add! emitted datom.v.entity)
                        (arr.push! out^ datom.v.entity))
                      (when (not target-expanded)
                        (arr.push! frontier datom.v.entity)))))
                (set! scan-index (+ scan-index 1))))))
        (delete-clause-index-scan scan)))))

(defn append-transitive-starts! [out: ^[dynamic]u64, db: DB, attr: string]
  (let [seen (set.empty u64)
        attr-clause (clause (term-wildcard) attr (term-wildcard))
        scan (clause-index-scan db attr-clause (Binding {}))]
    (defer (delete seen))
    (defer (delete-clause-index-scan scan))
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (and (clause-index-scan-candidate? scan datom)
                     (datom-current-at? db datom-index))
            (let [found (set.contains? seen datom.e)]
              (when (not found)
                (set.add! seen datom.e)
                (arr.push! out^ datom.e)))))
        (set! scan-index (+ scan-index 1))))))

(defn append-transitive-sources! [out: ^[dynamic]u64, db: DB, attr: string, target: u64]
  (let [expanded (set.empty u64)
        emitted (set.empty u64)
        frontier (make [dynamic]u64)
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier target)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            edge-clause (clause (term-wildcard) attr (term-value (value-entity current)))
            scan (clause-index-scan db edge-clause (Binding {}))]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (set.contains? expanded current)]
          (when (not already-expanded)
            (set.add! expanded current)
            (let [scan-index scan.index]
              (while (< scan-index scan.high)
                (let [datom-index (clause-index-scan-datom-index scan scan-index)
                      datom db.datoms[datom-index]]
                  (when (and (clause-index-scan-candidate? scan datom)
                             (datom-current-at? db datom-index))
                    (let [already-emitted (set.contains? emitted datom.e)
                          source-expanded (set.contains? expanded datom.e)]
                      (when (not already-emitted)
                        (set.add! emitted datom.e)
                        (arr.push! out^ datom.e))
                      (when (not source-expanded)
                        (arr.push! frontier datom.e)))))
                (set! scan-index (+ scan-index 1))))))
        (delete-clause-index-scan scan)))))

(defn u64-slice-contains? [items: []u64, value: u64] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn transitive-adjacency-max-entity [adjacency: []Transitive-Adjacency] -> u64
  (let [max-entity: u64 0]
    (for [entry adjacency]
      (when (> entry.entity max-entity)
        (set! max-entity entry.entity))
      (for [target entry.targets]
        (when (> target max-entity)
          (set! max-entity target))))
    max-entity))

(defn transitive-adjacency-use-dense-seen? [adjacency: []Transitive-Adjacency] -> [max-entity: u64, ok: bool]
  (let [max-value (transitive-adjacency-max-entity adjacency)
        adjacency-count (count adjacency)]
    (return max-value
      (and (> adjacency-count 0)
           (< max-value 1000000)
           (<= (int max-value) (* adjacency-count 8))))))

(defn make-bool-dense-index [size: int] -> [dynamic]bool
  (arr.repeat size false))

(defstruct Transitive-Adjacency {
  entity: u64
  targets: [dynamic]u64
})

(defstruct Transitive-Adjacency-Index {
  items: [dynamic]Transitive-Adjacency
  index: map[u64]int
})

(defn transitive-adjacency-index [lookup: map[u64]int, entity: u64] -> [index: int, ok: bool]
  (mmap.get lookup entity))

(defn append-transitive-adjacency-edge! [out: ^[dynamic]Transitive-Adjacency, index: (ptr (map u64 int)), source: u64, target: u64]
  (let [[adjacency-index found] (transitive-adjacency-index index^ source)]
    (if found
      (arr.push! out^[adjacency-index].targets target)
      (let [targets (make [dynamic]u64 0 4)]
        (arr.push! targets target)
        (mmap.assoc! index^ source (count out^))
        (arr.push! out^ (Transitive-Adjacency {entity: source targets: targets}))))))

(defn entity-matches-transitive-filter? [db: DB, entity: u64, filter: Clause] -> bool
  (let [view (db-index-view db .EAVT)
        attr filter.a.value.text
        expected filter.v.value
        low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
        high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (value-equal? datom.v expected))
          (return true)))
      (set! i (+ i 1)))
    false))

(defn entity-matches-transitive-filters? [db: DB, entity: u64, filters: []Clause] -> bool
  (for [filter filters]
    (when (not (entity-matches-transitive-filter? db entity filter))
      (return false)))
  true)

(defn transitive-adjacency-from-db-with-filters [db: DB, attr: string, filters: []Clause] -> Transitive-Adjacency-Index
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 attr (Value {}))
        out (make [dynamic]Transitive-Adjacency 0 (- high low))
        index (make (map u64 int))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (entity-matches-transitive-filters? db datom.v.entity filters))
          (append-transitive-adjacency-edge! (addr out) (addr index) datom.e datom.v.entity)))
      (set! i (+ i 1)))
    (Transitive-Adjacency-Index {items: out index: index})))

(defn transitive-adjacency-from-db [db: DB, attr: string] -> Transitive-Adjacency-Index
  (transitive-adjacency-from-db-with-filters db attr ([]Clause [])))

(defn transitive-derived-adjacency-from-db [db: DB, left-attr: string, right-attr: string] -> Transitive-Adjacency-Index
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 left-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 left-attr (Value {}))
        out (make [dynamic]Transitive-Adjacency 0 (- high low))
        index (make (map u64 int))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity))
          (let [[target target-ok] (latest-attr-value db datom.v.entity right-attr)]
            (when target-ok
              (let [[target-entity target-entity-ok] (value-as-entity db target)]
                (when target-entity-ok
                  (append-transitive-adjacency-edge! (addr out) (addr index) datom.e target-entity.entity)))))))
      (set! i (+ i 1)))
    (Transitive-Adjacency-Index {items: out index: index})))

(defn transitive-reverse-adjacency-from-db-with-filters [db: DB, attr: string, filters: []Clause] -> Transitive-Adjacency-Index
  (let [view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 attr (Value {}))
        out (make [dynamic]Transitive-Adjacency 0 (- high low))
        index (make (map u64 int))
        i low]
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (= datom.v.kind .Entity)
                   (entity-matches-transitive-filters? db datom.v.entity filters))
          (append-transitive-adjacency-edge! (addr out) (addr index) datom.v.entity datom.e)))
      (set! i (+ i 1)))
    (Transitive-Adjacency-Index {items: out index: index})))

(defn transitive-reverse-adjacency-from-db [db: DB, attr: string] -> Transitive-Adjacency-Index
  (transitive-reverse-adjacency-from-db-with-filters db attr ([]Clause [])))

(defn transitive-derived-reverse-adjacency-from-db [db: DB, left-attr: string, right-attr: string] -> Transitive-Adjacency-Index
  (let [forward (transitive-derived-adjacency-from-db db left-attr right-attr)
        out (make [dynamic]Transitive-Adjacency 0 (count forward.items))
        index (make (map u64 int))]
    (for [entry forward.items]
      (for [target entry.targets]
        (append-transitive-adjacency-edge! (addr out) (addr index) target entry.entity)))
    (delete-transitive-adjacency forward)
    (Transitive-Adjacency-Index {items: out index: index})))

(defn delete-transitive-adjacency [adjacency: Transitive-Adjacency-Index]
  (for [item adjacency.items]
    (delete item.targets))
  (delete adjacency.items)
  (delete adjacency.index))

(defn append-transitive-targets-with-adjacency! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64]
  (let [expanded (make [dynamic]u64 0 (count adjacency))
        emitted (make [dynamic]u64 0 (count adjacency))
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (u64-slice-contains? (slice expanded 0) current)]
          (when (and (not already-expanded) has-edges)
            (arr.push! expanded current)
            (for [target-entity adjacency[adj-index].targets]
              (let [already-emitted (u64-slice-contains? (slice emitted 0) target-entity)
                    target-expanded (u64-slice-contains? (slice expanded 0) target-entity)]
                (when (not already-emitted)
                  (arr.push! emitted target-entity)
                  (arr.push! out^ target-entity))
                (when (not target-expanded)
                  (arr.push! frontier target-entity))))))))))

(defn append-transitive-targets-with-dense-adjacency! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64, max-entity: u64]
  (let [dense-size (+ (int max-entity) 1)
        expanded (make-bool-dense-index dense-size)
        emitted (make-bool-dense-index dense-size)
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)
            current-index (int current)]
        (set! frontier-index (+ frontier-index 1))
        (when (and has-edges
                   (< current-index dense-size)
                   (not expanded[current-index]))
          (set! expanded[current-index] true)
          (for [target-entity adjacency[adj-index].targets]
            (let [target-index (int target-entity)]
              (when (< target-index dense-size)
                (when (not emitted[target-index])
                  (set! emitted[target-index] true)
                  (arr.push! out^ target-entity))
                (when (not expanded[target-index])
                  (arr.push! frontier target-entity))))))))))

(defn append-transitive-targets-fast! [out: ^[dynamic]u64, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, start: u64]
  (let [[max-entity use-dense] (transitive-adjacency-use-dense-seen? adjacency)]
    (if use-dense
      (append-transitive-targets-with-dense-adjacency! out adjacency adjacency-index start max-entity)
      (append-transitive-targets-with-adjacency! out adjacency adjacency-index start))))

(defstruct Alternating-Frontier-State {
  entity: u64
  use-left: bool
})

(defstruct Rule-Memo-Entry {
  name: string
  params: [dynamic]string
  bindings: [dynamic]Binding
  delta: [dynamic]Binding
  seen: (map string (struct {}))
  bindings-rel: Query-Relation
  bindings-rel-valid: bool
  bindings-rel-count: int
  delta-rel: Query-Relation
  delta-rel-valid: bool
  delta-rel-count: int
})

(defn alternating-state-expanded? [left-expanded: []u64, right-expanded: []u64, entity: u64, use-left: bool] -> bool
  (if use-left
    (u64-slice-contains? left-expanded entity)
    (u64-slice-contains? right-expanded entity)))

(defn mark-alternating-state-expanded! [left-expanded: ^[dynamic]u64, right-expanded: ^[dynamic]u64, entity: u64, use-left: bool]
  (if use-left
    (arr.push! left-expanded^ entity)
    (arr.push! right-expanded^ entity)))

(defn append-alternating-targets! [out: ^[dynamic]u64, left-adjacency: Transitive-Adjacency-Index, right-adjacency: Transitive-Adjacency-Index, start: u64]
  (let [left-expanded (make [dynamic]u64)
        right-expanded (make [dynamic]u64)
        emitted (make [dynamic]u64)
        frontier (make [dynamic]Alternating-Frontier-State)
        frontier-index 0]
    (defer (delete left-expanded))
    (defer (delete right-expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier (Alternating-Frontier-State {entity: start use-left: true}))
    (while (< frontier-index (count frontier))
      (let [state frontier[frontier-index]]
        (set! frontier-index (+ frontier-index 1))
        (when (not (alternating-state-expanded? (slice left-expanded 0) (slice right-expanded 0) state.entity state.use-left))
          (mark-alternating-state-expanded! (addr left-expanded) (addr right-expanded) state.entity state.use-left)
          (let [adjacency (if state.use-left left-adjacency right-adjacency)
                [adj-index has-edges] (transitive-adjacency-index adjacency.index state.entity)]
            (when has-edges
              (for [target-entity adjacency.items[adj-index].targets]
                (when (not (u64-slice-contains? (slice emitted 0) target-entity))
                  (arr.push! emitted target-entity)
                  (arr.push! out^ target-entity))
                (when (not (alternating-state-expanded? (slice left-expanded 0) (slice right-expanded 0) target-entity (not state.use-left)))
                  (arr.push! frontier (Alternating-Frontier-State {entity: target-entity use-left: (not state.use-left)})))))))))))

(defn append-linear-transitive-direct-result! [out: ^[dynamic]Binding, call: Rule-Call, binding: Binding, rule: Rule, start-entity: u64, target-entity: u64]
  (when (and (= (count binding.items) 0)
             (= (count rule.params) 2)
             (= (count call.args) 2)
             (= call.args[0].kind .Var)
             (= call.args[1].kind .Var)
             (not (= call.args[0].name call.args[1].name)))
    (let [items (make [dynamic]Var-Binding 0 2)]
      (arr.push! items (Var-Binding {name: call.args[0].name value: (value-entity start-entity)}))
      (arr.push! items (Var-Binding {name: call.args[1].name value: (value-entity target-entity)}))
      (arr.push! out^ (Binding {items: items}))
      (return)))
  (let [result (clone-binding binding)
        start-value (value-entity start-entity)
        target-value (value-entity target-entity)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [value (if (= param rule.params[0]) start-value target-value)
                [existing exists] (binding-lookup result arg.name)]
            (if exists
              (when (not (value-equal? existing value))
                (return))
              (binding-store! (addr result) arg.name value))))))
    (arr.push! out^ result)))

(defn append-linear-transitive-unbound-from-start-adjacency! [out: ^[dynamic]Binding, adjacency: []Transitive-Adjacency, adjacency-index: map[u64]int, call: Rule-Call, binding: Binding, rule: Rule, start-entity: u64]
  (let [expanded (make [dynamic]u64 0 (count adjacency))
        emitted (make [dynamic]u64 0 (count adjacency))
        frontier (make [dynamic]u64 0 (count adjacency))
        frontier-index 0]
    (defer (delete expanded))
    (defer (delete emitted))
    (defer (delete frontier))
    (arr.push! frontier start-entity)
    (while (< frontier-index (count frontier))
      (let [current frontier[frontier-index]
            [adj-index has-edges] (transitive-adjacency-index adjacency-index current)]
        (set! frontier-index (+ frontier-index 1))
        (let [already-expanded (u64-slice-contains? (slice expanded 0) current)]
          (when (and (not already-expanded) has-edges)
            (arr.push! expanded current)
            (for [target-entity adjacency[adj-index].targets]
              (let [already-emitted (u64-slice-contains? (slice emitted 0) target-entity)
                    target-expanded (u64-slice-contains? (slice expanded 0) target-entity)]
                (when (not already-emitted)
                  (arr.push! emitted target-entity)
                  (append-linear-transitive-direct-result! out call binding rule start-entity target-entity))
                (when (not target-expanded)
                  (arr.push! frontier target-entity))))))))))

(defn transitive-target-matches? [db: DB, target: Value, target-ok: bool, entity: u64] -> bool
  (when (not target-ok)
    (return true))
  (let [[target-entity target-entity-ok] (value-as-entity db target)]
    (and target-entity-ok (= target-entity.entity entity))))

(defn append-linear-transitive-target-result! [out: ^[dynamic]Binding, db: DB, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64, target: Value, target-ok: bool, target-entity: u64]
  (when (not (transitive-target-matches? db target target-ok target-entity))
    (return))
  (when (and (= (count rule.params) 2)
             (= (count call.args) 2)
             (= call.args[0].kind .Var)
             (= call.args[1].kind .Var)
             (not (= call.args[0].name call.args[1].name)))
    (let [[_ start-bound] (binding-lookup binding call.args[0].name)
          [_ target-bound] (binding-lookup binding call.args[1].name)]
      (when (and start-bound (not target-bound))
        (let [fast-result (clone-binding binding)]
          (binding-store! (addr fast-result) call.args[1].name (value-entity target-entity))
          (arr.push! out^ fast-result)
          (return)))))
  (let [[_ start-bound] (binding-lookup initial rule.params[0])
        with-start initial
        with-start-ok true]
    (when (not start-bound)
      (let [[bound bound-ok] (binding-with-value initial rule.params[0] (value-entity start-entity))]
        (set! with-start bound)
        (set! with-start-ok bound-ok)))
    (when (not with-start-ok)
      (return))
    (let [[_ target-bound] (binding-lookup with-start rule.params[1])
          result with-start
          result-ok true]
      (when (not target-bound)
        (let [[bound bound-ok] (binding-with-value with-start rule.params[1] (value-entity target-entity))]
          (set! result bound)
          (set! result-ok bound-ok)))
      (when (not result-ok)
        (return))
      (let [[merged merged-ok] (merge-rule-output binding call rule result)]
        (when merged-ok
          (arr.push! out^ merged))))))

(defn append-linear-transitive-from-start! [out: ^[dynamic]Binding, db: DB, attr: string, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64]
  (let [[target target-ok] (binding-lookup initial rule.params[1])
        targets (make [dynamic]u64)]
    (defer (delete targets))
    (append-transitive-targets! (addr targets) db attr start-entity)
    (for [target-entity targets]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target target-ok target-entity))))

(defn append-linear-transitive-from-start-adjacency! [out: ^[dynamic]Binding, db: DB, adjacency: Transitive-Adjacency-Index, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, start-entity: u64]
  (let [[target target-ok] (binding-lookup initial rule.params[1])
        targets (make [dynamic]u64)]
    (defer (delete targets))
    (append-transitive-targets-fast! (addr targets) (slice adjacency.items 0) adjacency.index start-entity)
    (for [target-entity targets]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target target-ok target-entity))))

(defn append-linear-transitive-from-all-starts! [out: ^[dynamic]Binding, db: DB, plan: Linear-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding]
  (let [adjacency (if plan.derived-edge
                    (transitive-derived-adjacency-from-db db plan.derived-left-attr plan.derived-right-attr)
                    (transitive-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0)))]
    (defer (delete-transitive-adjacency adjacency))
    (for [entry adjacency.items]
      (append-linear-transitive-unbound-from-start-adjacency! out (slice adjacency.items 0) adjacency.index call binding rule entry.entity))))

(defn append-linear-transitive-to-target! [out: ^[dynamic]Binding, db: DB, attr: string, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, target-entity: u64]
  (let [starts (make [dynamic]u64)
        target-value (value-entity target-entity)]
    (defer (delete starts))
    (append-transitive-sources! (addr starts) db attr target-entity)
    (for [start-entity starts]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target-value true target-entity))))

(defn append-linear-transitive-to-target-adjacency! [out: ^[dynamic]Binding, db: DB, adjacency: Transitive-Adjacency-Index, call: Rule-Call, binding: Binding, rule: Rule, initial: Binding, target-entity: u64]
  (let [starts (make [dynamic]u64)
        target-value (value-entity target-entity)]
    (defer (delete starts))
    (append-transitive-targets-fast! (addr starts) (slice adjacency.items 0) adjacency.index target-entity)
    (for [start-entity starts]
      (append-linear-transitive-target-result! out db call binding rule initial start-entity target-value true target-entity))))

(defn append-linear-transitive-results! [out: ^[dynamic]Binding, db: DB, plan: Linear-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule]
  (let [[initial initial-ok] (bind-rule-args binding call rule)]
    (when (not initial-ok)
      (return))
    (let [[start start-ok] (binding-lookup initial rule.params[0])]
      (if start-ok
        (let [[start-entity start-entity-ok] (value-as-entity db start)]
          (when (not start-entity-ok)
            (return))
          (let [adjacency (if plan.derived-edge
                            (transitive-derived-adjacency-from-db db plan.derived-left-attr plan.derived-right-attr)
                            (transitive-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0)))]
            (defer (delete-transitive-adjacency adjacency))
            (append-linear-transitive-from-start-adjacency! out db adjacency call binding rule initial start-entity.entity)))
        (let [[target target-ok] (binding-lookup initial rule.params[1])]
          (if target-ok
            (let [[target-entity target-entity-ok] (value-as-entity db target)]
              (when target-entity-ok
                (let [adjacency (if plan.derived-edge
                                  (transitive-derived-reverse-adjacency-from-db db plan.derived-left-attr plan.derived-right-attr)
                                  (transitive-reverse-adjacency-from-db-with-filters db plan.attr (slice plan.filters 0)))]
                  (defer (delete-transitive-adjacency adjacency))
                  (append-linear-transitive-to-target-adjacency! out db adjacency call binding rule initial target-entity.entity))))
            (append-linear-transitive-from-all-starts! out db plan call binding rule initial)))))))

(defn bindings-after-linear-transitive-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)
        [plan plan-ok] (linear-transitive-rule-plan rules call.name)]
    (defer (delete-linear-transitive-plan plan))
    (when (not plan-ok)
      (return result-bindings false))
    (for [rule rules]
      (when (= rule.name call.name)
        (append-linear-transitive-results! (addr result-bindings) db plan call binding rule)
        (return result-bindings true)))
    (return result-bindings true)))

(defn append-alternating-transitive-results! [out: ^[dynamic]Binding, db: DB, plan: Alternating-Transitive-Plan, call: Rule-Call, binding: Binding, rule: Rule]
  (let [[initial initial-ok] (bind-rule-args binding call rule)]
    (when (not initial-ok)
      (return))
    (let [[start start-ok] (binding-lookup initial rule.params[0])]
      (when (not start-ok)
        (return))
      (let [[start-entity start-entity-ok] (value-as-entity db start)]
        (when (not start-entity-ok)
          (return))
        (let [left-adjacency (transitive-adjacency-from-db db plan.left-attr)
              right-adjacency (transitive-adjacency-from-db db plan.right-attr)
              targets (make [dynamic]u64)]
          (defer (delete-transitive-adjacency left-adjacency))
          (defer (delete-transitive-adjacency right-adjacency))
          (defer (delete targets))
          (append-alternating-targets! (addr targets) left-adjacency right-adjacency start-entity.entity)
          (let [[target target-ok] (binding-lookup initial rule.params[1])]
            (for [target-entity targets]
              (append-linear-transitive-target-result! out db call binding rule initial start-entity.entity target target-ok target-entity))))))))

(defn bindings-after-alternating-transitive-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)
        [plan plan-ok] (alternating-transitive-rule-plan rules call.name)]
    (when (not plan-ok)
      (return result-bindings false))
    (let [[rule rule-ok] (first-rule-by-name rules call.name)]
      (when (not rule-ok)
        (return result-bindings false))
      (append-alternating-transitive-results! (addr result-bindings) db plan call binding rule)
      (return result-bindings true))))

(defn bindings-after-rule-step-depth-with-fns [db: DB, rules: []Rule, rule: Rule, bindings: []Binding, step: Query-Step, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)
            clause (rule-clause-with-source rule.clauses[step.index] source has-source)]
        (for [binding bindings]
          (append-bindings-after-clause! (addr out) db clause binding))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call rule.rule-calls[step.index]]
        (for [binding bindings]
          (let [next-source (if call.has-source call.source source)
                next-has-source (or call.has-source has-source)
                rule-bindings (bindings-after-rule-call-depth-with-fns db rules call binding (- depth 1) next-source next-has-source registry)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)
    .Ground
      (apply-ground bindings rule.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings rule.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings rule.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings rule.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings rule.predicates[step.index] registry)
    .Or
      (let [out (make [dynamic]Binding)
            group (if has-source (relation-db-or-group rule.or-groups[step.index] source) rule.or-groups[step.index])]
        (defer (when has-source (delete group.branches)))
        (for [binding bindings]
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-rules-sources-and-fns db rules ([]DB-Source []) group branch binding registry)]
              (for [branch-binding branch-bindings]
                (arr.push! out branch-binding))
              (delete branch-bindings))))
        out)

      (let [out (make [dynamic]Binding)
            group (if has-source (relation-db-not-group rule.not-groups[step.index] source) rule.not-groups[step.index])]
        (defer (when has-source
          (delete group.clauses)
          (delete group.get-elses)
          (delete group.get-somes)
          (delete group.grounds)
          (delete group.rule-calls)
          (delete group.not-groups)
          (delete group.join-vars)))
        (for [binding bindings]
          (when (not (binding-matches-not-group-with-rules-sources-and-fns? db rules ([]DB-Source []) group binding registry))
            (arr.push! out binding)))
        out)))

(defn bindings-after-rule-step-depth [db: DB, rules: []Rule, rule: Rule, bindings: []Binding, step: Query-Step, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-step-depth-with-fns db rules rule bindings step depth source has-source ([]Native-Query-Fn [])))

(defn bindings-after-rule-body-ordered-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings (make [dynamic]Binding)]
    (arr.push! bindings initial)
    (for [step rule.body-steps]
      (let [next-raw (bindings-after-rule-step-depth-with-fns db rules rule (slice bindings 0) step depth source has-source registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)
        (when (= (count bindings) 0)
          (return bindings))))
    bindings))

(defn bindings-after-rule-body-ordered-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-ordered-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn rule-body-pure-clause-call? [rule: Rule] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .RuleCall)))
      (return false)))
  true)

(defn rule-body-planned-clause-call-predicate? [rule: Rule] -> bool
  (when (= (count rule.body-steps) 0)
    (return false))
  (for [step rule.body-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .RuleCall)))
      (return false)))
  true)

(defn rule-call-bound-arg-count [call: Rule-Call, binding: Binding] -> int
  (let [out 0]
    (for [arg call.args]
      (when (= arg.kind .Var)
        (let [[_ ok] (binding-lookup binding arg.name)]
          (when ok
            (set! out (+ out 1)))))
      (when (or (= arg.kind .Value)
                (= arg.kind .LookupRef))
        (set! out (+ out 1))))
    out))

(defn query-relation-rule-call-bound-arg-count [rel: Query-Relation, call: Rule-Call] -> int
  (let [out 0]
    (for [arg call.args]
      (when (= arg.kind .Var)
        (when (query-relation-has-attr? rel arg.name)
          (set! out (+ out 1))))
      (when (or (= arg.kind .Value)
                (= arg.kind .LookupRef))
        (set! out (+ out 1))))
    out))

(defn rule-call-ready-for-binding-indexed? [rules: []Rule, index: []Rule-Name-Index-Entry, call: Rule-Call, binding: Binding] -> bool
  (let [available (binding-available-vars binding) :defer
        [ok _] (validate-rule-call-required-bindings-indexed (slice available 0) rules index call)]
    ok))

(defn rule-call-ready-for-binding? [rules: []Rule, call: Rule-Call, binding: Binding] -> bool
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (rule-call-ready-for-binding-indexed? rules (slice index 0) call binding)))

(defn rule-call-selectivity-score [call: Rule-Call, binding: Binding] -> int
  (let [bound-count (rule-call-bound-arg-count call binding)]
    (cond
      (>= bound-count 2) 1
      (= bound-count 1) 2
      :else 6)))

(defn best-rule-predicate-score-unlocked-by-clause [rule: Rule, steps: []Query-Step, binding: Binding, clause-value: Clause] -> int
  (let [available (available-vars-after-clause binding clause-value) :defer
        best -1]
    (for [step steps]
      (when (= step.kind .Predicate)
        (let [predicate rule.predicates[step.index]]
          (when (predicate-ready-with-vars? predicate (slice available 0))
            (let [score (predicate-selectivity-score predicate)]
              (when (or (= best -1)
                        (< score best))
                (set! best score)))))))
    best))

(defn best-ready-rule-body-step-index-indexed [db: DB, rules: []Rule, rule-index: []Rule-Name-Index-Entry, rule: Rule, steps: []Query-Step, binding: Binding, source: string, has-source: bool] -> [index: int, ok: bool]
  (let [best -1
        best-score 0
        best-unlocked-predicate-score -1
        best-count -1]
    (for [step step-index steps]
      (let [ready false
            score 0
            unlocked-predicate-score -1
            candidate-count -1]
        (when (= step.kind .Clause)
          (let [clause (rule-clause-with-source rule.clauses[step.index] source has-source)]
            (set! ready true)
            (set! score (clause-selectivity-score clause binding))
            (set! unlocked-predicate-score (best-rule-predicate-score-unlocked-by-clause rule steps binding clause))
            (when (and (>= best 0)
                       (= score best-score))
              (set! candidate-count (clause-candidate-count-estimate db ([]DB-Source []) clause binding)))))
        (when (= step.kind .Predicate)
          (let [available (binding-available-vars binding) :defer
                predicate rule.predicates[step.index]]
            (when (predicate-ready-with-vars? predicate (slice available 0))
              (set! ready true)
              (set! score (predicate-selectivity-score predicate))
              (set! candidate-count 0))))
        (when (= step.kind .RuleCall)
          (let [call rule.rule-calls[step.index]]
            (when (rule-call-ready-for-binding-indexed? rules rule-index call binding)
              (set! ready true)
              (set! score (rule-call-selectivity-score call binding)))))
        (when ready
          (when (or (= best -1)
                    (< score best-score))
            (set! best step-index)
            (set! best-score score)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-count candidate-count))
          (when (and (not (= best step-index))
                     (= score best-score)
                     (>= unlocked-predicate-score 0)
                     (or (< best-unlocked-predicate-score 0)
                         (< unlocked-predicate-score best-unlocked-predicate-score)))
            (set! best step-index)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-count candidate-count))
          (when (and (not (= best step-index))
                     (= score best-score)
                     (= unlocked-predicate-score best-unlocked-predicate-score))
            (when (< best-count 0)
              (let [best-step steps[best]]
                (if (= best-step.kind .Clause)
                  (let [best-clause (rule-clause-with-source rule.clauses[best-step.index] source has-source)]
                    (set! best-count (clause-candidate-count-estimate db ([]DB-Source []) best-clause binding)))
                  (set! best-count 0))))
            (let [count-estimate (if (>= candidate-count 0) candidate-count 0)]
              (when (< count-estimate best-count)
                (set! best step-index)
                (set! best-unlocked-predicate-score unlocked-predicate-score)
                (set! best-count count-estimate)))))))
    (return best (>= best 0))))

(defn best-ready-rule-body-step-index [db: DB, rules: []Rule, rule: Rule, steps: []Query-Step, binding: Binding, source: string, has-source: bool] -> [index: int, ok: bool]
  (let [rule-index (rule-name-index-build rules)]
    (defer (delete-rule-name-index rule-index))
    (best-ready-rule-body-step-index-indexed db rules (slice rule-index 0) rule steps binding source has-source)))

(defn bindings-after-rule-body-planned-clause-call-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings (make [dynamic]Binding)
        remaining (arr.into [dynamic]Query-Step (slice rule.body-steps 0))
        rule-index (rule-name-index-build rules)]
    (defer (delete remaining))
    (defer (delete-rule-name-index rule-index))
    (arr.push! bindings initial)
    (while (and (> (count bindings) 0)
                (> (count remaining) 0))
      (let [[step-index step-ok] (best-ready-rule-body-step-index-indexed db rules (slice rule-index 0) rule (slice remaining 0) bindings[0] source has-source)]
        (when (not step-ok)
          (delete bindings)
          (return (make [dynamic]Binding)))
        (let [step remaining[step-index]
              next-raw (bindings-after-rule-step-depth-with-fns db rules rule (slice bindings 0) step depth source has-source registry)
              next (unique-bindings (slice next-raw 0))]
          (delete next-raw)
          (delete bindings)
          (set! bindings next)
          (arr.remove-ordered-at! remaining step-index))))
    bindings))

(defn bindings-after-rule-body-grouped-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [clauses (rule-clauses-with-source rule.clauses source has-source)
        group (not-group-simple (slice clauses 0))
        initial-bindings (bindings-after-clause-group-with-sources-and-fns db ([]DB-Source []) group initial registry)
        bindings (unique-bindings (slice initial-bindings 0))]
    (delete initial-bindings)
    (delete clauses)
    (for [call rule.rule-calls]
      (let [next-bindings (make [dynamic]Binding)]
        (for [binding bindings]
          (let [next-source (if call.has-source call.source source)
                next-has-source (or call.has-source has-source)
                rule-bindings (bindings-after-rule-call-depth-with-fns db rules call binding (- depth 1) next-source next-has-source registry)]
            (for [rule-binding rule-bindings]
              (arr.push! next-bindings rule-binding))
            (delete rule-bindings)))
        (let [next (unique-bindings (slice next-bindings 0))]
          (delete next-bindings)
          (delete bindings)
          (set! bindings next))))
    (for [ground rule.grounds]
      (let [next-raw (apply-ground (slice bindings 0) ground)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [get-else rule.get-elses]
      (let [next-raw (bindings-after-get-else-step db (slice bindings 0) get-else)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [get-some rule.get-somes]
      (let [next-raw (bindings-after-get-some-step db (slice bindings 0) get-some)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [function rule.function-clauses]
      (let [next-raw (bindings-after-function-with-fns (slice bindings 0) function registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    (for [predicate rule.predicates]
      (let [next-raw (bindings-after-predicate-with-db-and-fns db (slice bindings 0) predicate registry)
            next (unique-bindings (slice next-raw 0))]
        (delete next-raw)
        (delete bindings)
        (set! bindings next)))
    bindings))

(defn bindings-after-rule-body-grouped-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-grouped-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn bindings-after-rule-body-depth-with-fns [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (if (rule-body-planned-clause-call-predicate? rule)
    (bindings-after-rule-body-planned-clause-call-depth-with-fns db rules rule initial depth source has-source registry)
    (if (> (count rule.body-steps) 0)
      (bindings-after-rule-body-ordered-depth-with-fns db rules rule initial depth source has-source registry)
      (bindings-after-rule-body-grouped-depth-with-fns db rules rule initial depth source has-source registry))))

(defn bindings-after-rule-body-depth [db: DB, rules: []Rule, rule: Rule, initial: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-body-depth-with-fns db rules rule initial depth source has-source ([]Native-Query-Fn [])))

(defn bind-rule-args [outer: Binding, call: Rule-Call, rule: Rule] -> [binding: Binding, ok: bool]
  (let [out (Binding {})]
    (when (not (= (count call.args) (count rule.params)))
      (return out false))
    (for [param index rule.params]
      (let [arg call.args[index]]
        (case arg.kind
          .Var (let [[value value-ok] (binding-lookup outer arg.name)]
                 (when (and (< index rule.required-param-count)
                            (not value-ok))
                   (return out false))
                 (when value-ok
                   (let [[next bind-ok] (binding-with-value out param value)]
                     (when (not bind-ok)
                       (return next false))
                     (set! out next))))
          .Value (let [[next bind-ok] (binding-with-value out param arg.value)]
                   (when (not bind-ok)
                     (return next false))
                   (set! out next))
          .Wildcard (do)
           (return out false))))
    (return out true)))

(defn merge-rule-output [outer: Binding, call: Rule-Call, rule: Rule, result: Binding] -> [binding: Binding, ok: bool]
  (let [out (clone-binding outer)]
    (for [param index rule.params]
      (let [arg call.args[index]]
        (when (= arg.kind .Var)
          (let [[value value-ok] (binding-lookup result param)]
            (when value-ok
              (let [[existing exists] (binding-lookup out arg.name)]
                (if exists
                  (when (not (predicate-value-equal? existing value))
                    (return out false))
                  (binding-store! (addr out) arg.name value))))))))
    (return out true)))

(defn positive-rule-memo-eligible? [rule: Rule] -> bool
  (when (or (> (count rule.predicates) 0)
            (> (count rule.function-clauses) 0)
            (> (count rule.get-elses) 0)
            (> (count rule.get-somes) 0)
            (> (count rule.grounds) 0)
            (> (count rule.not-groups) 0)
            (> (count rule.or-groups) 0))
    (return false))
  (for [rule-clause rule.clauses]
    (when rule-clause.has-source
      (return false)))
  (for [call rule.rule-calls]
    (when call.has-source
      (return false)))
  (for [step rule.body-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .RuleCall)))
      (return false)))
  true)

(defn positive-rule-memo-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (when (or call.has-source
            plan.linear-transitive
            plan.alternating-transitive
            (not plan.recursive))
    (return false))
  (for [rule plan.rules]
    (when (not (positive-rule-memo-eligible? rule))
      (return false)))
  true)

(defn recursive-component-names-for-rule [rules: []Rule, name: string] -> [dynamic]string
  (let [deps (rules-dependency-graph rules)
        components (rule-components-in-deps (slice deps 0))
        out (make [dynamic]string)]
    (defer (delete-rule-dependency-graph deps))
    (defer (delete-rule-components components))
    (let [[component-index found] (rule-component-index-for-name (slice components 0) name)]
      (when (and found components[component-index].recursive)
        (for [component-name components[component-index].names]
          (arr.push! out component-name))))
    out))

(defn positive-rule-delta-plan-eligible? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (when (not (positive-rule-memo-plan-eligible? plan call))
    (return false))
  (let [recursive-names (recursive-component-names-for-rule (slice plan.rules 0) call.name)]
    (defer (delete recursive-names))
    (when (= (count recursive-names) 0)
      (return false))
    (for [rule plan.rules]
      (when (not (string-slice-contains? (slice recursive-names 0) rule.name))
        (return false))
      (for [rule-call rule.rule-calls]
        (when (not (string-slice-contains? (slice recursive-names 0) rule-call.name))
          (return false)))))
  true)

(defn string-slices-equal? [left: []string, right: []string] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [item index left]
    (when (not (= item right[index]))
      (return false)))
  true)

(defn delete-rule-memo [memo: [dynamic]Rule-Memo-Entry]
  (for [entry memo]
    (delete entry.params)
    (delete entry.bindings)
    (delete entry.delta)
    (delete entry.seen)
    (delete-query-relation entry.bindings-rel)
    (delete-query-relation entry.delta-rel))
  (delete memo))

(defn rule-memo-entry-index [memo: []Rule-Memo-Entry, name: string, params: []string] -> [index: int, ok: bool]
  (for [entry index memo]
    (when (and (= entry.name name)
               (string-slices-equal? (slice entry.params 0) params))
      (return index true)))
  (return 0 false))

(defn rule-memo-build [rules: []Rule] -> [dynamic]Rule-Memo-Entry
  (let [memo (make [dynamic]Rule-Memo-Entry)]
    (for [rule rules]
      (let [[_ found] (rule-memo-entry-index (slice memo 0) rule.name (slice rule.params 0))]
        (when (not found)
          (let [params (arr.into [dynamic]string (slice rule.params 0))
                bindings (make [dynamic]Binding)
                delta (make [dynamic]Binding)
                seen (set.empty string)]
            (arr.push! memo (Rule-Memo-Entry {name: rule.name
                                              params: params
                                              bindings: bindings
                                              delta: delta
                                              seen: seen
                                              bindings-rel: (query-relation-empty)
                                              delta-rel: (query-relation-empty)}))))))
    memo))

(defn rule-memo-entry-invalidate-bindings-relation! [entry: ^Rule-Memo-Entry]
  (when entry^.bindings-rel-valid
    (delete-query-relation entry^.bindings-rel)
    (set! entry^.bindings-rel (query-relation-empty))
    (set! entry^.bindings-rel-valid false)
    (set! entry^.bindings-rel-count 0)))

(defn rule-memo-entry-invalidate-delta-relation! [entry: ^Rule-Memo-Entry]
  (when entry^.delta-rel-valid
    (delete-query-relation entry^.delta-rel)
    (set! entry^.delta-rel (query-relation-empty))
    (set! entry^.delta-rel-valid false)
    (set! entry^.delta-rel-count 0)))

(defn rule-memo-entry-append-bindings-relation! [entry: ^Rule-Memo-Entry, output: Binding]
  (when entry^.bindings-rel-valid
    (if (and entry^.bindings-rel.has-typed-columns
             (binding-can-add-to-relation-columns? (slice entry^.params 0) (slice entry^.bindings-rel.typed-columns 0) output))
      (do
        (add-binding-to-relation-columns! (slice entry^.params 0) (addr entry^.bindings-rel.typed-columns) output)
        (set! entry^.bindings-rel.typed-rows (+ entry^.bindings-rel.typed-rows 1))
        (set! entry^.bindings-rel-count (+ entry^.bindings-rel-count 1)))
      (rule-memo-entry-invalidate-bindings-relation! entry))))

(defn rule-memo-entry-append-delta-relation! [entry: ^Rule-Memo-Entry, output: Binding]
  (when entry^.delta-rel-valid
    (if (and entry^.delta-rel.has-typed-columns
             (binding-can-add-to-relation-columns? (slice entry^.params 0) (slice entry^.delta-rel.typed-columns 0) output))
      (do
        (add-binding-to-relation-columns! (slice entry^.params 0) (addr entry^.delta-rel.typed-columns) output)
        (set! entry^.delta-rel.typed-rows (+ entry^.delta-rel.typed-rows 1))
        (set! entry^.delta-rel-count (+ entry^.delta-rel-count 1)))
      (rule-memo-entry-invalidate-delta-relation! entry))))

(defn rule-output-binding [rule: Rule, result: Binding] -> [binding: Binding, ok: bool]
  (let [out (Binding {})]
    (for [param rule.params]
      (let [[value value-ok] (binding-lookup result param)]
        (when (not value-ok)
          (return out false))
        (binding-store! (addr out) param value)))
    (return out true)))

(defn rule-memo-append-result! [memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, result: Binding] -> bool
  (let [[output output-ok] (rule-output-binding rule result)]
    (when (not output-ok)
      (return false))
    (let [[entry-index entry-ok] (rule-memo-entry-index (slice memo^ 0) rule.name (slice rule.params 0))]
      (when (not entry-ok)
        (return false))
      (let [[key key-ok] (binding-dedupe-key output)]
        (if key-ok
          (let [already-seen (set.contains? memo^[entry-index].seen key)]
            (when already-seen
              (return false))
            (set.add! memo^[entry-index].seen key))
          (when (binding-exists? (slice memo^[entry-index].bindings 0) output)
            (return false))))
      (rule-memo-entry-append-bindings-relation! (addr memo^[entry-index]) output)
      (arr.push! memo^[entry-index].bindings output)
      true)))

(defn rule-memo-append-result-to-delta! [memo: ^[dynamic]Rule-Memo-Entry, next-delta: ^[dynamic]Rule-Memo-Entry, rule: Rule, result: Binding] -> bool
  (let [[output output-ok] (rule-output-binding rule result)]
    (when (not output-ok)
      (return false))
    (let [[entry-index entry-ok] (rule-memo-entry-index (slice memo^ 0) rule.name (slice rule.params 0))]
      (when (not entry-ok)
        (return false))
      (let [[key key-ok] (binding-dedupe-key output)]
        (if key-ok
          (let [already-seen (set.contains? memo^[entry-index].seen key)]
            (when already-seen
              (return false))
            (set.add! memo^[entry-index].seen key))
          (when (binding-exists? (slice memo^[entry-index].bindings 0) output)
            (return false))))
      (rule-memo-entry-append-bindings-relation! (addr memo^[entry-index]) output)
      (arr.push! memo^[entry-index].bindings output)
      (let [[delta-index delta-ok] (rule-memo-entry-index (slice next-delta^ 0) rule.name (slice rule.params 0))]
        (when delta-ok
          (rule-memo-entry-append-delta-relation! (addr next-delta^[delta-index]) output)
          (arr.push! next-delta^[delta-index].delta output)))
      true)))

(defn bindings-after-rule-call-from-memo-bindings [params: []string, memo-bindings: []Binding, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (not (= (count call.args) (count params)))
      (return out))
    (for [memo-binding memo-bindings]
      (let [next (clone-binding binding)
            ok true]
        (for [arg index call.args]
          (let [param params[index]
                [value value-ok] (binding-lookup memo-binding param)]
            (when (not value-ok)
              (set! ok false))
            (when ok
              (case arg.kind
                .Var (let [[existing exists] (binding-lookup next arg.name)]
                       (if exists
                         (when (not (predicate-value-equal? existing value))
                           (set! ok false))
                         (binding-store! (addr next) arg.name value)))
                .Value (when (not (predicate-value-equal? arg.value value))
                         (set! ok false))
                .Wildcard (do)
                .LookupRef (set! ok false)
                 (set! ok false)))))
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-rule-call-from-memo-entry [entry: Rule-Memo-Entry, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (bindings-after-rule-call-from-memo-bindings (slice entry.params 0) (slice entry.bindings 0) call binding))

(defn bindings-after-rule-call-from-memo-entry-delta [entry: Rule-Memo-Entry, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (bindings-after-rule-call-from-memo-bindings (slice entry.params 0) (slice entry.delta 0) call binding))

(defn bindings-after-rule-call-from-memo [memo: []Rule-Memo-Entry, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [entry memo]
      (when (= entry.name call.name)
        (let [entry-bindings (bindings-after-rule-call-from-memo-entry entry call binding)]
          (for [entry-binding entry-bindings]
            (arr.push! out entry-binding))
          (delete entry-bindings))))
    out))

(defn bindings-after-rule-call-from-memo-delta [memo: []Rule-Memo-Entry, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [entry memo]
      (when (= entry.name call.name)
        (let [entry-bindings (bindings-after-rule-call-from-memo-entry-delta entry call binding)]
          (for [entry-binding entry-bindings]
            (arr.push! out entry-binding))
          (delete entry-bindings))))
    out))

(defn query-relation-project-rule-call-bindings-typed-distinct [params: []string, memo-bindings: []Binding, call: Rule-Call] -> [rel: Query-Relation, ok: bool]
  (when (not (= (count params) (count call.args)))
    (return (query-relation-empty) false))
  (let [seen (set.empty string)]
    (defer (delete seen))
    (for [arg call.args]
      (when (not (= arg.kind .Var))
        (return (query-relation-empty) false))
      (when (set.contains? seen arg.name)
        (return (query-relation-empty) false))
      (set.add! seen arg.name)))
  (let [attrs (make [dynamic]string 0 (count call.args))
        attr-sources (make [dynamic]string 0 (count call.args))
        typed-columns (make [dynamic]Relation-Column 0 (count call.args))
        typed-rows 0]
    (for [arg call.args]
      (arr.push! attrs arg.name)
      (arr.push! attr-sources "")
      (arr.push! typed-columns (relation-column-empty)))
    (for [tuple memo-bindings]
      (for [param index params]
        (let [[value value-ok] (binding-lookup tuple param)]
          (when (not value-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns typed-columns)
            (return (query-relation-empty) false))
          (when (not (relation-column-add! (addr typed-columns[index]) value))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns typed-columns)
            (return (query-relation-empty) false))))
      (set! typed-rows (+ typed-rows 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: typed-columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-rule-memo-bindings [params: []string, memo-bindings: []Binding] -> [rel: Query-Relation, ok: bool]
  (let [attrs (arr.into [dynamic]string params)
        attr-sources (make [dynamic]string 0 (count params))
        typed-columns (relation-columns-for-attrs params)
        typed-rows 0]
    (for [_ params]
      (arr.push! attr-sources ""))
    (for [tuple memo-bindings]
      (for [param index params]
        (let [[value value-ok] (binding-lookup tuple param)]
          (when (or (not value-ok)
                    (not (relation-column-add! (addr typed-columns[index]) value)))
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns typed-columns)
            (return (query-relation-empty) false))))
      (set! typed-rows (+ typed-rows 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: typed-columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn rule-call-distinct-var-projection-params? [params: []string, call: Rule-Call] -> bool
  (when (not (= (count params) (count call.args)))
    (return false))
  (let [seen (set.empty string)]
    (defer (delete seen))
    (for [arg call.args]
      (when (not (= arg.kind .Var))
        (return false))
      (when (set.contains? seen arg.name)
        (return false))
      (set.add! seen arg.name))
    true))

(defn query-relation-project-rule-call-params-typed-general [rel: Query-Relation, params: []string, call: Rule-Call, param-indexes: []int] -> [projected: Query-Relation, ok: bool]
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)]
    (for [arg arg-index call.args]
      (when (= arg.kind .Var)
        (append-var-binding-attr! (addr attrs) (addr attr-sources) arg.name rel.attr-sources[param-indexes[arg-index]])))
    (let [attr-index (query-relation-attr-index (slice attrs 0))
          output-indexes (make [dynamic]int 0 (count call.args))]
      (for [arg call.args]
        (if (= arg.kind .Var)
          (let [[output-index output-ok] (mmap.get attr-index arg.name)]
            (when (not output-ok)
              (delete attrs)
              (delete attr-sources)
              (delete attr-index)
              (delete output-indexes)
              (return (query-relation-empty) false))
            (arr.push! output-indexes output-index))
          (arr.push! output-indexes -1)))
    (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
          seen (set.empty string)
          values (make [dynamic]Value 0 (count attrs)) :defer
          filled (make [dynamic]bool 0 (count attrs)) :defer
          typed-rows 0
          row 0]
      (defer (delete seen))
      (for [_ attrs]
        (arr.push! values (value-nil))
        (arr.push! filled false))
      (while (< row rel.typed-rows)
        (let [ok true]
          (arr.fill! values (value-nil))
          (arr.fill! filled false)
          (for [arg arg-index call.args]
            (when ok
              (let [[value value-ok] (typed-relation-column-value rel.typed-columns[param-indexes[arg-index]] row)]
                (if value-ok
                  (case arg.kind
                    .Var
                      (let [output-index output-indexes[arg-index]]
                        (if filled[output-index]
                          (set! ok (predicate-value-equal? values[output-index] value))
                          (do
                            (set! values[output-index] value)
                            (set! filled[output-index] true))))
                    .Value
                      (set! ok (predicate-value-equal? value arg.value))
                    .Wildcard
                      (discard value)
                    .LookupRef
                      (set! ok false)

                      (set! ok false))
                  (set! ok false)))))
          (when ok
            (for [filled-value filled]
              (when (not filled-value)
                (set! ok false))))
          (when ok
            (let [[key key-ok] (row-values-dedupe-key (slice values 0))]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete attr-index)
                (delete output-indexes)
                (delete-relation-columns typed-columns)
                (return (query-relation-empty) false))
              (when (not (set.contains? seen key))
                (set.add! seen key)
                (for [value index values]
                  (when (not (relation-column-can-add? typed-columns[index] value))
                    (delete attrs)
                    (delete attr-sources)
                    (delete attr-index)
                    (delete output-indexes)
                    (delete-relation-columns typed-columns)
                    (return (query-relation-empty) false)))
                (for [value index values]
                  (discard (relation-column-add! (addr typed-columns[index]) value)))
                (set! typed-rows (+ typed-rows 1))))))
        (set! row (+ row 1)))
      (delete output-indexes)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: attr-index
                               tuples: (make [dynamic]Binding)
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true)))))

(defn query-relation-project-rule-call-params-typed [rel: Query-Relation, params: []string, call: Rule-Call] -> [projected: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (= (count params) (count call.args))))
    (return (query-relation-empty) false))
  (let [param-indexes (make [dynamic]int 0 (count params))]
    (for [param params]
      (let [[column-index column-ok] (query-relation-attr-index-lookup rel param)]
        (when (not column-ok)
          (delete param-indexes)
          (return (query-relation-empty) false))
        (arr.push! param-indexes column-index)))
    (let [attrs (make [dynamic]string 0 (count call.args))
          attr-sources (make [dynamic]string 0 (count call.args))
          tuples (make [dynamic]Binding)
          typed-columns (make [dynamic]Relation-Column 0 (count call.args))]
      (when (not (rule-call-distinct-var-projection-params? params call))
        (delete attrs)
        (delete attr-sources)
        (delete tuples)
        (delete-relation-columns typed-columns)
        (let [[general general-ok] (query-relation-project-rule-call-params-typed-general rel params call (slice param-indexes 0))]
          (delete param-indexes)
          (return general general-ok)))
      (for [arg arg-index call.args]
        (arr.push! attrs arg.name)
        (arr.push! attr-sources rel.attr-sources[param-indexes[arg-index]])
        (arr.push! typed-columns (clone-relation-column rel.typed-columns[param-indexes[arg-index]])))
      (delete param-indexes)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: tuples
                               typed-columns: typed-columns
                               typed-rows: rel.typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-project-seeded-rule-call-params-typed [body-rel: Query-Relation, passthrough: Query-Relation, params: []string, call: Rule-Call] -> [projected: Query-Relation, ok: bool]
  (when (not (and body-rel.has-typed-columns
                  passthrough.has-typed-columns
                  (= (count params) (count call.args))))
    (return (query-relation-empty) false))
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)
        source-indexes (make [dynamic]int)]
    (for [name index passthrough.attrs]
      (let [[body-index body-ok] (query-relation-attr-index-lookup body-rel name)]
        (when (not body-ok)
          (delete attrs)
          (delete attr-sources)
          (delete source-indexes)
          (return (query-relation-empty) false))
        (arr.push! attrs name)
        (arr.push! attr-sources passthrough.attr-sources[index])
        (arr.push! source-indexes body-index)))
    (let [param-indexes (make [dynamic]int 0 (count params))]
      (for [param params]
        (let [[param-index param-ok] (query-relation-attr-index-lookup body-rel param)]
          (when (not param-ok)
            (delete attrs)
            (delete attr-sources)
            (delete source-indexes)
            (delete param-indexes)
            (return (query-relation-empty) false))
          (arr.push! param-indexes param-index)))
      (for [arg arg-index call.args]
        (when (= arg.kind .Var)
          (let [[_ exists] (attr-position (slice attrs 0) arg.name)]
            (when (not exists)
              (arr.push! attrs arg.name)
              (arr.push! attr-sources body-rel.attr-sources[param-indexes[arg-index]])
              (arr.push! source-indexes param-indexes[arg-index])))))
      (let [call-output-indexes (make [dynamic]int 0 (count call.args))]
        (for [arg call.args]
          (if (= arg.kind .Var)
            (let [[output-index output-ok] (attr-position (slice attrs 0) arg.name)]
              (when (not output-ok)
                (delete attrs)
                (delete attr-sources)
                (delete source-indexes)
                (delete param-indexes)
                (delete call-output-indexes)
                (return (query-relation-empty) false))
              (arr.push! call-output-indexes output-index))
            (arr.push! call-output-indexes -1)))
      (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
            typed-rows 0
            row 0]
        (while (< row body-rel.typed-rows)
          (let [row-ok true]
            (for [arg arg-index call.args]
              (when row-ok
                (let [[param-value param-ok] (typed-relation-column-value body-rel.typed-columns[param-indexes[arg-index]] row)]
                  (if param-ok
                    (case arg.kind
                      .Var
                        (let [output-index call-output-indexes[arg-index]
                              [existing existing-ok] (typed-relation-column-value body-rel.typed-columns[source-indexes[output-index]] row)]
                          (set! row-ok (and existing-ok
                                             (predicate-value-equal? existing param-value))))
                      .Value
                        (set! row-ok (predicate-value-equal? param-value arg.value))
                      .Wildcard
                        (discard param-value)
                      .LookupRef
                        (set! row-ok false)

                        (set! row-ok false))
                    (set! row-ok false)))))
            (when row-ok
              (for [source-index output-index source-indexes]
                (when row-ok
                  (let [source-column body-rel.typed-columns[source-index]]
                    (if (relation-column-row-compatible? typed-columns[output-index] source-column row)
                      (relation-column-row-add-checked! (addr typed-columns[output-index]) source-column row)
                      (set! row-ok false)))))
              (if row-ok
                (set! typed-rows (+ typed-rows 1))
                (do
                  (delete attrs)
                  (delete attr-sources)
                  (delete source-indexes)
                  (delete param-indexes)
                  (delete call-output-indexes)
                  (delete-relation-columns typed-columns)
                  (return (query-relation-empty) false)))))
          (set! row (+ row 1)))
        (delete source-indexes)
        (delete param-indexes)
        (delete call-output-indexes)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: (make [dynamic]Binding)
                                 typed-columns: typed-columns
                                 typed-rows: typed-rows
                                 has-typed-columns: true}) true))))))

(defn query-relation-project-rule-call-bindings [params: []string, memo-bindings: []Binding, call: Rule-Call] -> Query-Relation
  (let [[typed typed-ok] (query-relation-project-rule-call-bindings-typed-distinct params memo-bindings call)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (when (not (= (count params) (count call.args)))
    (return (query-relation-empty)))
  (let [bindings (make [dynamic]Binding)
        seen (set.empty string)]
    (defer (delete seen))
    (for [tuple memo-bindings]
      (let [out (Binding {})
            ok true]
        (for [param index params]
          (when ok
            (let [[value value-ok] (binding-lookup tuple param)]
              (if value-ok
                (let [arg call.args[index]]
                  (case arg.kind
                    .Var
                      (let [[next bind-ok] (binding-with-value out arg.name value)]
                        (set! out next)
                        (set! ok bind-ok))
                    .Value
                      (set! ok (predicate-value-equal? value arg.value))
                    .Wildcard
                      (discard value)

                      (set! ok false)))
                (set! ok false)))))
        (when ok
          (let [[key key-ok] (binding-dedupe-key out)]
            (if key-ok
              (let [already-seen (set.contains? seen key)]
                (if already-seen
                  (delete out.items)
                  (do
                    (set.add! seen key)
                    (arr.push! bindings out))))
              (if (binding-exists? (slice bindings 0) out)
                (delete out.items)
                (arr.push! bindings out)))))
        (when (not ok)
          (delete out.items))))
    (let [projected (query-relation-from-bindings (slice bindings 0))]
      (delete bindings)
      projected)))

(defn rule-memo-entry-relation! [entry: ^Rule-Memo-Entry, use-delta: bool] -> [rel: Query-Relation, ok: bool]
  (if use-delta
    (do
      (when (or (not entry^.delta-rel-valid)
                (not (= entry^.delta-rel-count (count entry^.delta))))
        (rule-memo-entry-invalidate-delta-relation! entry)
        (let [[rel rel-ok] (query-relation-from-rule-memo-bindings (slice entry^.params 0) (slice entry^.delta 0))]
          (when (not rel-ok)
            (delete-query-relation rel)
            (return (query-relation-empty) false))
          (delete-query-relation entry^.delta-rel)
          (set! entry^.delta-rel rel)
          (set! entry^.delta-rel-valid true)
          (set! entry^.delta-rel-count (count entry^.delta))))
      (return entry^.delta-rel true))
    (do
      (when (or (not entry^.bindings-rel-valid)
                (not (= entry^.bindings-rel-count (count entry^.bindings))))
        (rule-memo-entry-invalidate-bindings-relation! entry)
        (let [[rel rel-ok] (query-relation-from-rule-memo-bindings (slice entry^.params 0) (slice entry^.bindings 0))]
          (when (not rel-ok)
            (delete-query-relation rel)
            (return (query-relation-empty) false))
          (delete-query-relation entry^.bindings-rel)
          (set! entry^.bindings-rel rel)
          (set! entry^.bindings-rel-valid true)
          (set! entry^.bindings-rel-count (count entry^.bindings))))
      (return entry^.bindings-rel true))))

(defn query-relation-after-rule-call-from-memo [db: DB, memo: ^[dynamic]Rule-Memo-Entry, rel: Query-Relation, call: Rule-Call, use-delta: bool, delta-call-index: int, step-index: int] -> Query-Relation
  (let [matching-count 0
        matching-index -1]
    (for [entry index memo^]
      (when (= entry.name call.name)
        (let [memo-bindings (if (and use-delta (= step-index delta-call-index))
                              (slice entry.delta 0)
                              (slice entry.bindings 0))]
          (when (> (count memo-bindings) 0)
            (set! matching-count (+ matching-count 1))
            (set! matching-index index)))))
    (when (= matching-count 1)
      (let [use-entry-delta (and use-delta (= step-index delta-call-index))
            [memo-rel memo-rel-ok] (rule-memo-entry-relation! (addr memo^[matching-index]) use-entry-delta)]
        (when memo-rel-ok
          (let [[projected projected-ok] (query-relation-project-rule-call-params-typed memo-rel (slice memo^[matching-index].params 0) call)]
            (when projected-ok
              (let [joined (query-relation-join db ([]DB-Source []) rel projected)]
                (delete-query-relation projected)
                (return joined)))
            (delete-query-relation projected)))))
  (let [out-bindings (make [dynamic]Binding)
        out-rel (query-relation-empty)
        has-out-rel false
        out-rel-typed true]
    (for [entry index memo^]
      (when (= entry.name call.name)
        (let [memo-bindings (if (and use-delta (= step-index delta-call-index))
                              (slice entry.delta 0)
                              (slice entry.bindings 0))]
          (when (> (count memo-bindings) 0)
            (let [use-entry-delta (and use-delta (= step-index delta-call-index))
                  [memo-rel memo-rel-ok] (rule-memo-entry-relation! (addr memo^[index]) use-entry-delta)]
              (if memo-rel-ok
                (let [[projected projected-ok] (query-relation-project-rule-call-params-typed memo-rel (slice entry.params 0) call)]
	                  (if projected-ok
	                    (let [joined (query-relation-join db ([]DB-Source []) rel projected)]
	                      (delete-query-relation projected)
	                      (when (not (query-relation-accumulate-typed! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) joined))
	                        (let [materialized (query-relation-materialized-bindings joined) :defer]
	                          (for [binding materialized]
	                            (arr.push! out-bindings binding))))
	                      (delete-query-relation joined))
	                    (let [fallback (query-relation-project-rule-call-bindings (slice entry.params 0) memo-bindings call)
	                          joined (query-relation-join db ([]DB-Source []) rel fallback)
	                          materialized (query-relation-materialized-bindings joined) :defer]
	                      (query-relation-flush-typed-accumulator! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed))
	                      (delete-query-relation projected)
	                      (delete-query-relation fallback)
	                      (delete-query-relation joined)
                      (for [binding materialized]
                        (arr.push! out-bindings binding)))))
	                (let [projected (query-relation-project-rule-call-bindings (slice entry.params 0) memo-bindings call)
	                      joined (query-relation-join db ([]DB-Source []) rel projected)
	                      materialized (query-relation-materialized-bindings joined) :defer]
	                  (query-relation-flush-typed-accumulator! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed))
	                  (delete-query-relation projected)
	                  (delete-query-relation joined)
	                  (for [binding materialized]
                    (arr.push! out-bindings binding)))))))))
    (if (and out-rel-typed has-out-rel (= (count out-bindings) 0))
      (do
        (delete out-bindings)
        out-rel)
      (do
        (when has-out-rel
          (let [materialized (query-relation-materialized-bindings out-rel) :defer]
            (for [binding materialized]
              (arr.push! out-bindings binding))))
        (delete-query-relation out-rel)
        (let [out (query-relation-from-bindings (slice out-bindings 0))]
          (delete out-bindings)
          out))))))

(defn query-relation-after-rule-call-from-memo-rowwise [memo: []Rule-Memo-Entry, rel: Query-Relation, call: Rule-Call, use-delta: bool, delta-call-index: int, step-index: int] -> Query-Relation
  (let [bindings (make [dynamic]Binding)
        materialized (query-relation-materialized-bindings rel) :defer]
    (for [binding materialized]
      (let [rule-bindings (if (and use-delta (= step-index delta-call-index))
                            (bindings-after-rule-call-from-memo-delta memo call binding)
                            (bindings-after-rule-call-from-memo memo call binding))]
        (for [rule-binding rule-bindings]
          (arr.push! bindings rule-binding))
        (delete rule-bindings)))
    (let [next (query-relation-from-bindings (slice bindings 0))]
      (delete bindings)
      next)))

(defn bindings-after-rule-step-memo [db: DB, memo: []Rule-Memo-Entry, rule: Rule, bindings: []Binding, step: Query-Step] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)
            clause rule.clauses[step.index]]
        (for [binding bindings]
          (append-bindings-after-clause! (addr out) db clause binding))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call rule.rule-calls[step.index]]
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-from-memo memo call binding)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)

      (make [dynamic]Binding)))

(defn bindings-after-rule-step-memo-with-delta [db: DB, memo: []Rule-Memo-Entry, rule: Rule, bindings: []Binding, step: Query-Step, delta-call-index: int] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)
            clause rule.clauses[step.index]]
        (for [binding bindings]
          (append-bindings-after-clause! (addr out) db clause binding))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call rule.rule-calls[step.index]]
        (for [binding bindings]
          (let [rule-bindings (if (= step.index delta-call-index)
                                (bindings-after-rule-call-from-memo-delta memo call binding)
                                (bindings-after-rule-call-from-memo memo call binding))]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        out)

      (make [dynamic]Binding)))

(defn query-relation-after-rule-step-memo [db: DB, memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, rel: Query-Relation, step: Query-Step, use-delta: bool, delta-call-index: int] -> [out: Query-Relation, ok: bool]
  (case step.kind
    .Clause
      (let [clause-rel (query-relation-from-db-clause db rule.clauses[step.index] "")
            joined (query-relation-join db ([]DB-Source []) rel clause-rel)]
        (delete-query-relation clause-rel)
        (return joined true))
    .RuleCall
      (if (<= (query-relation-row-count rel) 65536)
        (return (query-relation-after-rule-call-from-memo-rowwise (slice memo^ 0) rel rule.rule-calls[step.index] use-delta delta-call-index step.index) true)
        (return (query-relation-after-rule-call-from-memo db memo rel rule.rule-calls[step.index] use-delta delta-call-index step.index) true))

      (return (query-relation-empty) false)))

(defn query-relation-dedupe-typed [rel: Query-Relation] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [deduped (query-relation-empty-typed-like rel)
        seen (set.empty string)]
    (defer (delete seen))
    (when (not (query-relation-append-typed-rows-unique! (addr deduped) rel (addr seen)))
      (delete-query-relation deduped)
      (return (query-relation-empty) false))
    (return deduped true)))

(defn query-relation-dedupe-step [rel: Query-Relation] -> Query-Relation
  (let [[typed typed-ok] (query-relation-dedupe-typed rel)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel)
        unique (unique-bindings (slice materialized 0))
        out (query-relation-from-bindings (slice unique 0))]
    (delete materialized)
    (delete unique)
    out))

(defn query-relation-after-rule-body-memo [db: DB, memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, use-delta: bool, delta-call-index: int] -> Query-Relation
  (let [current (query-relation-singleton)]
    (for [step rule.body-steps]
      (let [[next-raw next-ok] (query-relation-after-rule-step-memo db memo rule current step use-delta delta-call-index)]
        (delete-query-relation current)
        (when (not next-ok)
          (delete-query-relation next-raw)
          (return (query-relation-empty)))
        (let [next (query-relation-dedupe-step next-raw)]
          (delete-query-relation next-raw)
          (set! current next)
          (when (= (query-relation-row-count current) 0)
            (return current)))))
    current))

(defn rule-memo-append-relation-results! [memo: ^[dynamic]Rule-Memo-Entry, rule: Rule, rel: Query-Relation] -> bool
  (let [changed false]
    (if (> (count rel.tuples) 0)
      (for [result rel.tuples]
        (when (rule-memo-append-result! memo rule result)
          (set! changed true)))
      (when rel.has-typed-columns
        (let [row 0]
          (while (< row rel.typed-rows)
            (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
              (when binding-ok
                (when (rule-memo-append-result! memo rule binding)
                  (set! changed true))
                (delete binding.items)))
            (set! row (+ row 1))))))
    changed))

(defn rule-memo-append-relation-results-to-delta! [memo: ^[dynamic]Rule-Memo-Entry, next-delta: ^[dynamic]Rule-Memo-Entry, rule: Rule, rel: Query-Relation] -> bool
  (let [changed false]
    (if (> (count rel.tuples) 0)
      (for [result rel.tuples]
        (when (rule-memo-append-result-to-delta! memo next-delta rule result)
          (set! changed true)))
      (when rel.has-typed-columns
        (let [row 0]
          (while (< row rel.typed-rows)
            (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
              (when binding-ok
                (when (rule-memo-append-result-to-delta! memo next-delta rule binding)
                  (set! changed true))
                (delete binding.items)))
            (set! row (+ row 1))))))
    changed))

(defn first-rule-call-index [rule: Rule] -> [index: int, ok: bool]
  (for [step rule.body-steps]
    (when (= step.kind .RuleCall)
      (return step.index true)))
  (return 0 false))

(defn rule-call-indexes [rule: Rule] -> [dynamic]int
  (let [out (make [dynamic]int)]
    (for [step rule.body-steps]
      (when (= step.kind .RuleCall)
        (arr.push! out step.index)))
    out))

(defn rule-memo-has-delta? [memo: []Rule-Memo-Entry] -> bool
  (for [entry memo]
    (when (> (count entry.delta) 0)
      (return true)))
  false)

(defn rule-memo-replace-deltas! [memo: ^[dynamic]Rule-Memo-Entry, next-delta: []Rule-Memo-Entry]
  (for [entry index memo^]
    (delete memo^[index].delta)
    (rule-memo-entry-invalidate-delta-relation! (addr memo^[index]))
    (let [[delta-index delta-ok] (rule-memo-entry-index next-delta entry.name (slice entry.params 0))
          delta-values (make [dynamic]Binding)]
      (when delta-ok
        (delete delta-values)
        (set! delta-values (arr.into [dynamic]Binding (slice next-delta[delta-index].delta 0))))
      (set! memo^[index].delta delta-values))))

(defn bindings-after-rule-call-delta-fixpoint [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding] -> [bindings: [dynamic]Binding, ok: bool]
  (when (not (positive-rule-delta-plan-eligible? plan call))
    (return (make [dynamic]Binding) false))
  (let [memo (rule-memo-build (slice plan.rules 0))]
    (defer (delete-rule-memo memo))
    (for [rule plan.rules]
      (let [[_ has-call] (first-rule-call-index rule)]
        (when (not has-call)
          (let [rel (query-relation-after-rule-body-memo db (addr memo) rule false -1)]
            (discard (rule-memo-append-relation-results-to-delta! (addr memo) (addr memo) rule rel))
            (delete-query-relation rel)))))
    (while (rule-memo-has-delta? (slice memo 0))
      (let [next-delta (rule-memo-build (slice plan.rules 0))]
        (for [rule plan.rules]
          (let [delta-call-indexes (rule-call-indexes rule)]
            (for [delta-call-index delta-call-indexes]
              (let [rel (query-relation-after-rule-body-memo db (addr memo) rule true delta-call-index)]
                (discard (rule-memo-append-relation-results-to-delta! (addr memo) (addr next-delta) rule rel))
                (delete-query-relation rel)))
            (delete delta-call-indexes)))
        (rule-memo-replace-deltas! (addr memo) (slice next-delta 0))
        (delete-rule-memo next-delta)))
    (return (bindings-after-rule-call-from-memo (slice memo 0) call binding) true)))

(defn bindings-after-rule-call-memo-fixpoint [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding] -> [bindings: [dynamic]Binding, ok: bool]
  (when (not (positive-rule-memo-plan-eligible? plan call))
    (return (make [dynamic]Binding) false))
  (let [[delta-bindings delta-ok] (bindings-after-rule-call-delta-fixpoint db plan call binding)]
    (when delta-ok
      (return delta-bindings true))
    (delete delta-bindings))
  (let [memo (rule-memo-build (slice plan.rules 0))
        changed true]
    (defer (delete-rule-memo memo))
    (while changed
      (set! changed false)
      (for [rule plan.rules]
        (let [rel (query-relation-after-rule-body-memo db (addr memo) rule false -1)]
          (when (rule-memo-append-relation-results! (addr memo) rule rel)
            (set! changed true))
          (delete-query-relation rel))))
    (return (bindings-after-rule-call-from-memo (slice memo 0) call binding) true)))

(defn bindings-after-rule-call-depth-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, depth: int, source: string, has-source: bool, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (when (<= depth 0)
      (return out))
    (for [rule rules]
      (when (= rule.name call.name)
        (let [[initial ok] (bind-rule-args binding call rule)]
          (when ok
            (let [[source-initial source-ok] (bind-rule-source binding initial source has-source)]
              (when source-ok
                (let [results (bindings-after-rule-body-depth-with-fns db rules rule source-initial depth source has-source registry)]
                  (for [result results]
                    (let [[merged merged-ok] (merge-rule-output binding call rule result)]
                      (when merged-ok
                        (arr.push! out merged))))
                  (delete results))))))))
    out))

(defn bindings-after-rule-call-depth [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, depth: int, source: string, has-source: bool] -> [dynamic]Binding
  (bindings-after-rule-call-depth-with-fns db rules call binding depth source has-source ([]Native-Query-Fn [])))

(defn matching-rules-are-leaves? [rules: []Rule, call: Rule-Call] -> bool
  (let [matched false]
    (for [rule rules]
      (when (= rule.name call.name)
        (set! matched true)
        (when (> (count rule.rule-calls) 0)
          (return false))))
    matched))

(defn string-push-unique! [out: ^[dynamic]string, value: string]
  (when (not (string-slice-contains? (slice out^ 0) value))
    (arr.push! out^ value)))

(defn rule-name-index-entry [index: []Rule-Name-Index-Entry, name: string] -> [entry-index: int, ok: bool]
  (for [entry entry-index index]
    (when (= entry.name name)
      (return entry-index true)))
  (return 0 false))

(defn rule-name-index-build [rules: []Rule] -> [dynamic]Rule-Name-Index-Entry
  (let [out (make [dynamic]Rule-Name-Index-Entry)]
    (for [rule rule-index rules]
      (let [[entry-index found] (rule-name-index-entry (slice out 0) rule.name)]
        (if found
          (arr.push! out[entry-index].indexes rule-index)
          (let [indexes (make [dynamic]int)]
            (arr.push! indexes rule-index)
            (arr.push! out (Rule-Name-Index-Entry {name: rule.name indexes: indexes}))))))
    out))

(defn delete-rule-name-index [index: [dynamic]Rule-Name-Index-Entry]
  (for [entry index]
    (delete entry.indexes))
  (delete index))

(defn rule-name-index-has? [index: []Rule-Name-Index-Entry, name: string] -> bool
  (let [[_ ok] (rule-name-index-entry index name)]
    ok))

(defn rule-name-index-first-matching-rule [rules: []Rule, index: []Rule-Name-Index-Entry, call: Rule-Call] -> [rule: Rule, ok: bool]
  (let [[entry-index found] (rule-name-index-entry index call.name)]
    (when found
      (for [rule-index index[entry-index].indexes]
        (let [rule rules[rule-index]]
          (when (= (count call.args) (count rule.params))
            (return rule true))))))
  (return (Rule {}) false))

(defn rule-name-dependency-exists? [deps: []Rule-Dependency, from: string, target: string] -> bool
  (for [dep deps]
    (when (= dep.name from)
      (return (string-slice-contains? (slice dep.deps 0) target))))
  false)

(defn rule-dependency-index [deps: []Rule-Dependency, name: string] -> [index: int, ok: bool]
  (for [dep index deps]
    (when (= dep.name name)
      (return index true)))
  (return 0 false))

(defn rule-unique-names [rules: []Rule] -> [dynamic]string
  (let [out (make [dynamic]string)]
    (for [rule rules]
      (string-push-unique! (addr out) rule.name))
    out))

(defn rule-direct-dependencies-indexed [rules: []Rule, index: []Rule-Name-Index-Entry, name: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        [entry-index found] (rule-name-index-entry index name)]
    (when found
      (for [rule-index index[entry-index].indexes]
        (let [rule rules[rule-index]]
          (for [call rule.rule-calls]
            (when (rule-name-index-has? index call.name)
              (string-push-unique! (addr out) call.name))))))
    out))

(defn rules-dependency-graph-indexed [rules: []Rule, index: []Rule-Name-Index-Entry] -> [dynamic]Rule-Dependency
  (let [out (make [dynamic]Rule-Dependency)]
    (for [entry index]
      (arr.push! out (Rule-Dependency {name: entry.name deps: (rule-direct-dependencies-indexed rules index entry.name)})))
    out))

(defn rules-dependency-graph [rules: []Rule] -> [dynamic]Rule-Dependency
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (rules-dependency-graph-indexed rules (slice index 0))))

(defn delete-rule-dependency-graph [deps: [dynamic]Rule-Dependency]
  (for [dep deps]
    (delete dep.deps))
  (delete deps))

(defn rule-reaches-name? [deps: []Rule-Dependency, from: string, target: string] -> bool
  (let [seen (make [dynamic]string)]
    (defer (delete seen))
    (let [visit (make [dynamic]string)]
      (defer (delete visit))
      (arr.push! visit from)
      (while (> (count visit) 0)
        (let [last-index (- (count visit) 1)
              current visit[last-index]]
          (arr.remove-ordered-at! visit last-index)
          (when (= current target)
            (return true))
          (when (not (string-slice-contains? (slice seen 0) current))
            (arr.push! seen current)
            (for [dep deps]
              (when (= dep.name current)
                (for [next dep.deps]
                  (when (not (string-slice-contains? (slice seen 0) next))
                    (arr.push! visit next)))))))))
    false))

(defn rule-reachable-names-in-deps [deps: []Rule-Dependency, name: string] -> [dynamic]string
  (let [seen (make [dynamic]string)
        visit (make [dynamic]string)
        out (make [dynamic]string)]
    (defer (delete seen))
    (defer (delete visit))
    (arr.push! visit name)
    (while (> (count visit) 0)
      (let [last-index (- (count visit) 1)
            current visit[last-index]]
        (arr.remove-ordered-at! visit last-index)
        (when (not (string-slice-contains? (slice seen 0) current))
          (arr.push! seen current)
          (let [[dep-index dep-ok] (rule-dependency-index deps current)]
            (when dep-ok
              (string-push-unique! (addr out) current)
              (for [next deps[dep-index].deps]
                (when (not (string-slice-contains? (slice seen 0) next))
                  (arr.push! visit next))))))))
    out))

(defn rule-component-visit-order! [deps: []Rule-Dependency, name: string, visited: ^[dynamic]string, order: ^[dynamic]string]
  (when (string-slice-contains? (slice visited^ 0) name)
    (return))
  (arr.push! visited^ name)
  (let [[dep-index dep-ok] (rule-dependency-index deps name)]
    (when dep-ok
      (for [next deps[dep-index].deps]
        (rule-component-visit-order! deps next visited order))))
  (arr.push! order^ name))

(defn rule-component-collect-reverse! [deps: []Rule-Dependency, name: string, assigned: ^[dynamic]string, component: ^[dynamic]string]
  (when (string-slice-contains? (slice assigned^ 0) name)
    (return))
  (arr.push! assigned^ name)
  (arr.push! component^ name)
  (for [dep deps]
    (when (string-slice-contains? (slice dep.deps 0) name)
      (rule-component-collect-reverse! deps dep.name assigned component))))

(defn rule-component-recursive? [deps: []Rule-Dependency, names: []string] -> bool
  (when (> (count names) 1)
    (return true))
  (when (= (count names) 0)
    (return false))
  (rule-name-dependency-exists? deps names[0] names[0]))

(defn rule-components-in-deps [deps: []Rule-Dependency] -> [dynamic]Rule-Component
  (let [visited (make [dynamic]string)
        order (make [dynamic]string)
        assigned (make [dynamic]string)
        out (make [dynamic]Rule-Component)]
    (defer (delete visited))
    (defer (delete order))
    (defer (delete assigned))
    (for [dep deps]
      (rule-component-visit-order! deps dep.name (addr visited) (addr order)))
    (let [i (- (count order) 1)]
      (while (>= i 0)
        (let [name order[i]]
          (when (not (string-slice-contains? (slice assigned 0) name))
            (let [component-names (make [dynamic]string)]
              (rule-component-collect-reverse! deps name (addr assigned) (addr component-names))
              (arr.push! out (Rule-Component {names: component-names recursive: (rule-component-recursive? deps (slice component-names 0))}))))
          (set! i (- i 1)))))
    out))

(defn rule-component-index-for-name [components: []Rule-Component, name: string] -> [index: int, ok: bool]
  (for [component index components]
    (when (string-slice-contains? (slice component.names 0) name)
      (return index true)))
  (return 0 false))

(defn rule-name-recursive-in-components? [components: []Rule-Component, name: string] -> bool
  (let [[component-index found] (rule-component-index-for-name components name)]
    (and found components[component-index].recursive)))

(defn rule-name-recursive? [rules: []Rule, name: string] -> bool
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (rule-name-recursive-in-deps? (slice deps 0) name)))

(defn rule-name-recursive-in-deps? [deps: []Rule-Dependency, name: string] -> bool
  (let [components (rule-components-in-deps deps)]
    (defer (delete-rule-components components))
    (rule-name-recursive-in-components? (slice components 0) name)))

(defn rule-name-depends-on-recursive? [rules: []Rule, name: string] -> bool
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (rule-name-depends-on-recursive-in-deps? (slice deps 0) name)))

(defn rule-call-can-use-acyclic-depth? [rules: []Rule, name: string] -> bool
  (not (rule-name-depends-on-recursive? rules name)))

(defn rule-name-depends-on-recursive-in-deps? [deps: []Rule-Dependency, name: string] -> bool
  (let [components (rule-components-in-deps deps)]
    (defer (delete-rule-components components))
    (rule-name-depends-on-recursive-in-components? deps (slice components 0) name)))

(defn rule-name-depends-on-recursive-in-components? [deps: []Rule-Dependency, components: []Rule-Component, name: string] -> bool
  (let [names (rule-reachable-names-in-deps deps name)]
    (defer (delete names))
    (for [name names]
      (when (rule-name-recursive-in-components? components name)
        (return true)))
    false))

(defn any-rule-name-recursive-in-deps? [deps: []Rule-Dependency, names: []string] -> bool
  (let [components (rule-components-in-deps deps)]
    (defer (delete-rule-components components))
    (any-rule-name-recursive-in-components? (slice components 0) names)))

(defn any-rule-name-recursive-in-components? [components: []Rule-Component, names: []string] -> bool
  (for [name names]
    (when (rule-name-recursive-in-components? components name)
      (return true)))
  false)

(defn rule-components [rules: []Rule] -> [dynamic]Rule-Component
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (rule-components-in-deps (slice deps 0))))

(defn delete-rule-components [components: [dynamic]Rule-Component]
  (for [component components]
    (delete component.names))
  (delete components))

(defn non-recursive-rule-depth [rules: []Rule, name: string] -> int
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (non-recursive-rule-depth-in-deps (slice deps 0) name)))

(defn non-recursive-rule-depth-in-deps [deps: []Rule-Dependency, name: string] -> int
  (let [names (rule-reachable-names-in-deps deps name)]
    (defer (delete names))
    (+ (count names) 1)))

(defn rules-reachable-from-name [rules: []Rule, name: string] -> [dynamic]string
  (let [deps (rules-dependency-graph rules)]
    (defer (delete-rule-dependency-graph deps))
    (rule-reachable-names-in-deps (slice deps 0) name)))

(defn rules-filter-by-names [rules: []Rule, names: []string] -> [dynamic]Rule
  (let [out (make [dynamic]Rule)]
    (for [rule rules]
      (when (string-slice-contains? names rule.name)
        (arr.push! out rule)))
    out))

(defn rules-for-call [rules: []Rule, name: string] -> [dynamic]Rule
  (let [names (rules-reachable-from-name rules name)
        out (rules-filter-by-names rules (slice names 0))]
    (delete names)
    out))

(defn rule-call-plan [rules: []Rule, name: string] -> Rule-Call-Plan
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (rule-call-plan-indexed rules (slice index 0) name)))

(defn rule-call-plan-indexed [rules: []Rule, index: []Rule-Name-Index-Entry, name: string] -> Rule-Call-Plan
  (let [deps (rules-dependency-graph-indexed rules index)
        components (rule-components-in-deps (slice deps 0))
        names (rule-reachable-names-in-deps (slice deps 0) name)]
    (defer (delete-rule-dependency-graph deps))
    (defer (delete-rule-components components))
    (defer (delete names))
    (let [call-rules (rules-filter-by-names rules (slice names 0))
          recursive (any-rule-name-recursive-in-components? (slice components 0) (slice names 0))
          acyclic-depth (if recursive 0 (+ (count names) 1))
          [linear-plan linear-ok] (linear-transitive-rule-plan (slice call-rules 0) name)
          linear-filters (make [dynamic]Clause)
          [alternating-plan alternating-ok] (alternating-transitive-rule-plan (slice call-rules 0) name)]
      (defer (delete-linear-transitive-plan linear-plan))
      (when linear-ok
        (delete linear-filters)
        (let [owned-linear-filters (arr.into [dynamic]Clause (slice linear-plan.filters 0))]
          (set! linear-filters owned-linear-filters)))
      (Rule-Call-Plan {rules: call-rules
                       recursive: recursive
                       acyclic-depth: acyclic-depth
                       linear-transitive: linear-ok
                       linear-attr: linear-plan.attr
                       linear-derived-edge: linear-plan.derived-edge
                       linear-derived-left-attr: linear-plan.derived-left-attr
                       linear-derived-right-attr: linear-plan.derived-right-attr
                       linear-filters: linear-filters
                       alternating-transitive: alternating-ok
                       alternating-left-name: alternating-plan.left-name
                       alternating-left-attr: alternating-plan.left-attr
                       alternating-right-name: alternating-plan.right-name
                       alternating-right-attr: alternating-plan.right-attr}))))

(defn delete-rule-call-plan [plan: Rule-Call-Plan]
  (delete plan.rules)
  (delete plan.linear-filters))

(defn clone-rule-call-plan [plan: Rule-Call-Plan] -> Rule-Call-Plan
  (let [rules (arr.into [dynamic]Rule (slice plan.rules 0))
        linear-filters (arr.into [dynamic]Clause (slice plan.linear-filters 0))]
    (Rule-Call-Plan {rules: rules
                     recursive: plan.recursive
                     acyclic-depth: plan.acyclic-depth
                     linear-transitive: plan.linear-transitive
                     linear-attr: plan.linear-attr
                     linear-derived-edge: plan.linear-derived-edge
                     linear-derived-left-attr: plan.linear-derived-left-attr
                     linear-derived-right-attr: plan.linear-derived-right-attr
                     linear-filters: linear-filters
                     alternating-transitive: plan.alternating-transitive
                     alternating-left-name: plan.alternating-left-name
                     alternating-left-attr: plan.alternating-left-attr
                     alternating-right-name: plan.alternating-right-name
                     alternating-right-attr: plan.alternating-right-attr})))

(defn clone-rule-call-plans [plans: []Rule-Call-Plan] -> [dynamic]Rule-Call-Plan
  (let [out (make [dynamic]Rule-Call-Plan 0 (count plans))]
    (for [plan plans]
      (arr.push! out (clone-rule-call-plan plan)))
    out))

(defn delete-rule-call-plans [plans: [dynamic]Rule-Call-Plan]
  (for [plan plans]
    (delete-rule-call-plan plan))
  (delete plans))

(defn rule-call-plans-for-query [query: Query] -> [dynamic]Rule-Call-Plan
  (let [out (make [dynamic]Rule-Call-Plan 0 (count query.rule-calls))
        index (rule-name-index-build (slice query.rules 0))]
    (defer (delete-rule-name-index index))
    (for [call query.rule-calls]
      (arr.push! out (rule-call-plan-indexed (slice query.rules 0) (slice index 0) call.name)))
    out))

(defn query-with-rule-call-plans [query: Query] -> Query
  (let [out query]
    (delete-rule-call-plans out.rule-call-plans)
    (set! out.rule-call-plans (rule-call-plans-for-query out))
    out))

(defn bindings-after-linear-transitive-rule-call-with-plan [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)]
    (when (not plan.linear-transitive)
      (return result-bindings false))
    (let [[rule rule-ok] (first-rule-by-name (slice plan.rules 0) call.name)]
      (when rule-ok
        (let [linear-plan (Linear-Transitive-Plan {attr: plan.linear-attr
                                                   derived-edge: plan.linear-derived-edge
                                                   derived-left-attr: plan.linear-derived-left-attr
                                                   derived-right-attr: plan.linear-derived-right-attr
                                                   filters: plan.linear-filters})]
          (append-linear-transitive-results! (addr result-bindings) db linear-plan call binding rule)))
      (return result-bindings true))))

(defn bindings-after-alternating-transitive-rule-call-with-plan [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding] -> [out: [dynamic]Binding, ok: bool]
  (let [result-bindings (make [dynamic]Binding)]
    (when (not plan.alternating-transitive)
      (return result-bindings false))
    (let [[rule rule-ok] (first-rule-by-name (slice plan.rules 0) call.name)]
      (when rule-ok
        (let [alternating-plan (Alternating-Transitive-Plan {left-name: plan.alternating-left-name
                                                             left-attr: plan.alternating-left-attr
                                                             right-name: plan.alternating-right-name
                                                             right-attr: plan.alternating-right-attr})]
          (append-alternating-transitive-results! (addr result-bindings) db alternating-plan call binding rule)))
      (return result-bindings true))))

(defn bindings-after-attr-param-two-values-same-entity-rule-call-with-plan [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding, stats: ^Query-Stats] -> [out: [dynamic]Binding, ok: bool]
  (let [out-bindings (make [dynamic]Binding)]
    (for [rule plan.rules]
      (when (= rule.name call.name)
        (let [[attr attr-ok] (rule-attr-param-two-values-same-entity rule call)]
          (when attr-ok
            (let [[rel rel-ok] (query-relation-from-attr-param-two-values-same-entity-rule db rule attr stats)]
              (when rel-ok
                (let [[projected projected-ok] (query-relation-project-rule-call-typed rel rule call)]
                  (when projected-ok
                    (let [projected-bindings (query-relation-materialized-bindings projected) :defer]
                      (for [candidate projected-bindings]
                        (let [[merged merged-ok] (merge-binding binding candidate)]
                          (if merged-ok
                            (arr.push! out-bindings merged)
                            (delete merged.items)))))
                    (delete-query-relation projected)
                    (delete-query-relation rel)
                    (return out-bindings true))
                  (delete-query-relation projected)))
              (delete-query-relation rel))))))
    (return out-bindings false)))

(defn bindings-after-rule-call-planned-with-fns [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [[optimized optimized-ok] (bindings-after-linear-transitive-rule-call-with-plan db plan call binding)]
    (when optimized-ok
      (return optimized))
    (delete optimized))
  (let [[optimized optimized-ok] (bindings-after-alternating-transitive-rule-call-with-plan db plan call binding)]
    (when optimized-ok
      (return optimized))
    (delete optimized))
  (let [stats (query-stats-empty)
        [optimized optimized-ok] (bindings-after-attr-param-two-values-same-entity-rule-call-with-plan db plan call binding (addr stats))]
    (when optimized-ok
      (return optimized))
    (delete optimized))
  (when (matching-rules-are-leaves? (slice plan.rules 0) call)
    (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding 1 call.source call.has-source registry)
          out (unique-bindings (slice candidates 0))]
      (delete candidates)
      (return out)))
  (when (not plan.recursive)
    (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding plan.acyclic-depth call.source call.has-source registry)
          out (unique-bindings (slice candidates 0))]
      (delete candidates)
      (return out)))
  (let [[memoized memoized-ok] (bindings-after-rule-call-memo-fixpoint db plan call binding)]
    (when memoized-ok
      (return memoized))
    (delete memoized))
  (let [out (make [dynamic]Binding)
        seen (set.empty string)
        depth 1
        min-depth (+ (count plan.rules) 1)
        changed true]
    (defer (delete seen))
    (while (or changed (<= depth min-depth))
      (set! changed false)
      (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding depth call.source call.has-source registry)]
        (defer (delete candidates))
        (for [candidate candidates]
          (when (append-unique-binding! (addr out) (addr seen) candidate)
            (set! changed true))))
      (set! depth (+ depth 1)))
    out))

(defn bindings-after-rule-call-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [plan (rule-call-plan rules call.name)]
    (defer (delete-rule-call-plan plan))
    (bindings-after-rule-call-planned-with-fns db plan call binding registry)))

(defn bindings-after-rule-call-profiled-with-fns [db: DB, rules: []Rule, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (let [plan (rule-call-plan rules call.name)]
    (defer (delete-rule-call-plan plan))
    (bindings-after-rule-call-profiled-with-plan db plan call binding registry stats)))

(defn bindings-after-rule-call-profiled-with-plan [db: DB, plan: Rule-Call-Plan, call: Rule-Call, binding: Binding, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (set! stats^.rule-calls (+ stats^.rule-calls 1))
  (let [[optimized optimized-ok] (bindings-after-linear-transitive-rule-call-with-plan db plan call binding)]
    (when optimized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count optimized))
      (return optimized))
    (delete optimized))
  (let [[optimized optimized-ok] (bindings-after-alternating-transitive-rule-call-with-plan db plan call binding)]
    (when optimized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count optimized))
      (return optimized))
    (delete optimized))
  (let [[optimized optimized-ok] (bindings-after-attr-param-two-values-same-entity-rule-call-with-plan db plan call binding stats)]
    (when optimized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count optimized))
      (return optimized))
    (delete optimized))
  (when (matching-rules-are-leaves? (slice plan.rules 0) call)
    (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
    (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding 1 call.source call.has-source registry)
          out (unique-bindings (slice candidates 0))]
      (delete candidates)
      (query-stats-observe-bindings! stats (count out))
      (return out)))
  (when (not plan.recursive)
    (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
    (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding plan.acyclic-depth call.source call.has-source registry)
          out (unique-bindings (slice candidates 0))]
      (delete candidates)
      (query-stats-observe-bindings! stats (count out))
      (return out)))
  (let [[memoized memoized-ok] (bindings-after-rule-call-memo-fixpoint db plan call binding)]
    (when memoized-ok
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (count memoized))
      (return memoized))
    (delete memoized))
  (let [out (make [dynamic]Binding)
        seen (set.empty string)
        depth 1
        min-depth (+ (count plan.rules) 1)
        changed true]
    (defer (delete seen))
    (while (or changed (<= depth min-depth))
      (set! changed false)
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (let [candidates (bindings-after-rule-call-depth-with-fns db (slice plan.rules 0) call binding depth call.source call.has-source registry)]
        (defer (delete candidates))
        (for [candidate candidates]
          (when (append-unique-binding! (addr out) (addr seen) candidate)
            (set! changed true))))
      (query-stats-observe-bindings! stats (count out))
      (set! depth (+ depth 1)))
    out))

(defn bindings-after-rule-call [db: DB, rules: []Rule, call: Rule-Call, binding: Binding] -> [dynamic]Binding
  (bindings-after-rule-call-with-fns db rules call binding ([]Native-Query-Fn [])))

(defn query-can-trust-unique-bindings? [query: Query] -> bool
  (when (not (and (= (count query.with) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .RuleCall)))
    (return false))
  (let [call query.rule-calls[query.where-steps[0].index]
        [_ ok] (linear-transitive-rule-attr (slice query.rules 0) call.name)]
    ok))

(defn bindings-after-or-branch-with-rules-sources-and-fns [db: DB, rules: []Rule, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [initial (clone-binding binding)]
    (when group.has-join
      (set! initial (project-binding binding group.join-vars))
      (for [branch-clause branch.clauses]
        (let [has-source branch-clause.has-source]
          (when has-source
          (let [[source source-ok] (binding-lookup binding branch-clause.source)]
            (when source-ok
              (binding-store! (addr initial) branch-clause.source source)))))))
  (let [branch-bindings (bindings-after-clause-group-with-rules-sources-and-fns db rules sources branch initial registry) :defer
        out (make [dynamic]Binding)]
    (for [branch-binding branch-bindings]
      (let [branch-output (if group.has-join (project-binding branch-binding group.join-vars) branch-binding)
            [merged ok] (merge-binding binding branch-output)]
        (when ok
          (arr.push! out merged))))
    out)))

(defn bindings-after-or-branch-with-sources-and-fns [db: DB, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-or-branch-with-rules-sources-and-fns db ([]Rule []) sources group branch binding registry))

(defn bindings-after-or-branch-with-sources [db: DB, sources: []DB-Source, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-or-branch-with-sources-and-fns db sources group branch binding ([]Native-Query-Fn [])))

(defn bindings-after-or-branch [db: DB, group: Or-Group, branch: Not-Group, binding: Binding] -> [dynamic]Binding
  (bindings-after-or-branch-with-sources db ([]DB-Source []) group branch binding))

(defn binding-matches-not-group-with-rules-sources-and-fns? [db: DB, rules: []Rule, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> bool
  (let [initial (clone-binding binding)]
    (when group.has-join
      (delete initial.items)
      (set! initial (project-binding binding group.join-vars)))
    (let [bindings (bindings-after-clause-group-with-rules-sources-and-fns db rules sources group initial registry)]
      (let [matched (> (count bindings) 0)]
        (delete bindings)
        (return matched)))))

(defn binding-matches-not-group-with-sources-and-fns? [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding, registry: []Native-Query-Fn] -> bool
  (binding-matches-not-group-with-rules-sources-and-fns? db ([]Rule []) sources group binding registry))

(defn binding-matches-not-group-with-sources? [db: DB, sources: []DB-Source, group: Not-Group, binding: Binding] -> bool
  (binding-matches-not-group-with-sources-and-fns? db sources group binding ([]Native-Query-Fn [])))

(defn binding-matches-not-group? [db: DB, group: Not-Group, binding: Binding] -> bool
  (binding-matches-not-group-with-sources? db ([]DB-Source []) group binding))

(defn query-expected-input-count [query-value: Query] -> int
  (if (> (count query-value.input-specs) 0)
    (count query-value.input-specs)
    (+ (count query-value.inputs)
       (count query-value.collection-inputs)
       (count query-value.tuple-inputs)
       (count query-value.relation-inputs))))

(defn query-source-input? [query-value: Query, source: string] -> bool
  (for [input query-value.inputs]
    (when (= input source)
      (return true)))
  (for [spec query-value.input-specs]
    (when (and (= spec.kind .Scalar)
               (= spec.name source))
      (return true)))
  false)

(defn query-source-db? [sources: []DB-Source, source: string] -> bool
  (for [item sources]
    (when (= item.name source)
      (return true)))
  false)

(defn query-source-known? [query-value: Query, sources: []DB-Source, source: string] -> bool
  (or (= source "$")
      (query-source-input? query-value source)
      (query-source-db? sources source)))

(defn query-input-specs-include-default-source? [query-value: Query] -> bool
  query-value.has-default-source-input)

(defn query-not-group-uses-default-source? [group: Not-Group] -> bool
  (for [item group.clauses]
    (when (not item.has-source)
      (return true)))
  (for [child group.not-groups]
    (when (query-not-group-uses-default-source? child)
      (return true)))
  (for [call group.rule-calls]
    (when (not call.has-source)
      (return true)))
  false)

(defn query-or-group-uses-default-source? [group: Or-Group] -> bool
  (for [branch group.branches]
    (when (query-not-group-uses-default-source? branch)
      (return true)))
  false)

(defn query-uses-default-source? [query-value: Query] -> bool
  (for [item query-value.clauses]
    (when (not item.has-source)
      (return true)))
  (for [item query-value.pulls]
    (when (not item.has-source)
      (return true)))
  (for [group query-value.not-groups]
    (when (query-not-group-uses-default-source? group)
      (return true)))
  (for [group query-value.or-groups]
    (when (query-or-group-uses-default-source? group)
      (return true)))
  (for [call query-value.rule-calls]
    (when (not call.has-source)
      (return true)))
  false)

(defn validate-query-default-source-input [query-value: Query] -> [ok: bool, error: string]
  (when (and (> (count query-value.input-specs) 0)
             (query-uses-default-source? query-value)
             (not (query-input-specs-include-default-source? query-value)))
    (return false "query uses default data source $, but :in does not include $"))
  (return true ""))

(defn append-unknown-query-source! [out: ^[dynamic]string, query-value: Query, sources: []DB-Source, source: string]
  (when (not (query-source-known? query-value sources source))
    (append-var-once! out source)))

(defn append-unknown-query-not-group-sources! [out: ^[dynamic]string, query-value: Query, sources: []DB-Source, group: Not-Group]
  (for [item group.clauses]
    (when item.has-source
      (append-unknown-query-source! out query-value sources item.source)))
  (for [child group.not-groups]
    (append-unknown-query-not-group-sources! out query-value sources child)))

(defn append-unknown-query-or-group-sources! [out: ^[dynamic]string, query-value: Query, sources: []DB-Source, group: Or-Group]
  (for [branch group.branches]
    (append-unknown-query-not-group-sources! out query-value sources branch)))

(defn query-input-index-for-source [query-value: Query, source: string] -> [index: int, ok: bool]
  (when (> (count query-value.input-specs) 0)
    (for [spec index query-value.input-specs]
      (when (and (= spec.kind .Scalar)
                 (= spec.name source))
        (return index true)))
    (return -1 false))
  (for [name index query-value.inputs]
    (when (= name source)
      (return index true)))
  (return -1 false))

(defn validate-source-input-value [query-value: Query, inputs: []Query-Input, sources: []DB-Source, source: string] -> [ok: bool, error: string]
  (when (or (= source "$") (query-source-db? sources source))
    (return true ""))
  (let [[index found] (query-input-index-for-source query-value source)]
    (when (not found)
      (return true ""))
    (when (>= index (count inputs))
      (return true ""))
    (let [input inputs[index]]
      (if (query-source-input-value? input)
        (return true "")
        (return false (fmt.tprintf "query source is not a collection: %s" source))))))

(defn validate-not-group-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, group: Not-Group] -> [ok: bool, error: string]
  (for [item group.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [child group.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, group: Or-Group] -> [ok: bool, error: string]
  (for [branch group.branches]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources branch)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-rule-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source, rule: Rule] -> [ok: bool, error: string]
  (for [item rule.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [call rule.rule-calls]
    (when call.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources call.source)]
        (when (not ok)
          (return false error)))))
  (for [group rule.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [group rule.or-groups]
    (let [[ok error] (validate-or-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-source-input-values [query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (for [item query-value.clauses]
    (when item.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources item.source)]
        (when (not ok)
          (return false error)))))
  (for [call query-value.rule-calls]
    (when call.has-source
      (let [[ok error] (validate-source-input-value query-value inputs sources call.source)]
        (when (not ok)
          (return false error)))))
  (for [group query-value.not-groups]
    (let [[ok error] (validate-not-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [group query-value.or-groups]
    (let [[ok error] (validate-or-group-source-input-values query-value inputs sources group)]
      (when (not ok)
        (return false error))))
  (for [rule query-value.rules]
    (let [[ok error] (validate-rule-source-input-values query-value inputs sources rule)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-collection-input [input: Query-Input, name: string] -> [ok: bool, error: string]
  (if (or (= input.kind .Collection)
          (= input.kind .CollectionLookupRefs))
    (return true "")
    (return false (fmt.tprintf "cannot bind query input to collection %s" name))))

(defn validate-query-tuple-input [input: Query-Input, tuple: Tuple-Input] -> [ok: bool, error: string]
  (when (not (= input.kind .Collection))
    (return false "cannot bind query input to tuple"))
  (when (< (count input.values) (count tuple.vars))
    (return false "not enough values to bind tuple input"))
  (return true ""))

(defn validate-query-relation-input [input: Query-Input, relation: Relation-Input] -> [ok: bool, error: string]
  (when (= input.kind .Collection)
    (return true ""))
  (when (and (= input.kind .Scalar)
             (= input.value.kind .Map)
             (or (not (= relation.binding.kind .None))
                 (= (count relation.vars) 2)))
    (return true ""))
  (when (not (= input.kind .Relation))
    (return false "cannot bind query input to relation"))
  (when (not (= input.width (count relation.vars)))
    (return false "query relation input width mismatch"))
  (return true ""))

(defn validate-query-input-spec-value [spec: Query-Input-Spec, input: Query-Input] -> [ok: bool, error: string]
  (case spec.kind
    .Scalar (if (or (= input.kind .Scalar)
                    (= input.kind .PullPattern)
                    (and (query-source-input-name? spec.name)
                         (query-source-input-value? input)))
              (return true "")
              (return false (fmt.tprintf "cannot bind query input to scalar %s" spec.name)))
    .Collection (validate-query-collection-input input spec.name)
    .Tuple (validate-query-tuple-input input spec.tuple)
    .Relation (validate-query-relation-input input spec.relation)
    .Ignore (return true "")
     (return true "")))

(defn append-legacy-query-input-specs! [out: ^[dynamic]Query-Input-Spec, query-value: Query]
  (for [name query-value.inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Scalar name: name})))
  (for [name query-value.collection-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Collection name: name})))
  (for [tuple query-value.tuple-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Tuple tuple: tuple})))
  (for [relation query-value.relation-inputs]
    (arr.push! out^ (Query-Input-Spec {kind: .Relation relation: relation}))))

(defn validate-query-input-values [query-value: Query, inputs: []Query-Input] -> [ok: bool, error: string]
  (let [specs (make [dynamic]Query-Input-Spec) :defer]
    (if (> (count query-value.input-specs) 0)
      (for [spec query-value.input-specs]
        (arr.push! specs spec))
      (append-legacy-query-input-specs! (addr specs) query-value))
    (for [spec index specs]
      (when (< index (count inputs))
        (let [[ok error] (validate-query-input-spec-value spec inputs[index])]
          (when (not ok)
            (return false error)))))
    (return true "")))

(defn query-clause-db [db: DB, sources: []DB-Source, clause-value: Clause] -> [clause-db: DB, ok: bool]
  (if clause-value.has-source
    (source-db-lookup db sources clause-value.source)
    (return db true)))

(defn validate-inline-lookup-ref-term [db: DB, term: Term] -> [ok: bool, error: string]
  (when (= term.kind .LookupRef)
    (let [[_ found lookup-error] (resolve-lookup-ref-checked db term.lookup-attr term.lookup-value)]
      (when (not found)
        (return false lookup-error))))
  (return true ""))

(defn validate-query-clause-inline-lookup-refs [db: DB, sources: []DB-Source, clause-value: Clause] -> [ok: bool, error: string]
  (let [[clause-db db-ok] (query-clause-db db sources clause-value)]
    (when (not db-ok)
      (return true ""))
    (let [[e-ok e-error] (validate-inline-lookup-ref-term clause-db clause-value.e)]
      (when (not e-ok)
        (return false e-error)))
    (let [[v-ok v-error] (validate-inline-lookup-ref-term clause-db clause-value.v)]
      (when (not v-ok)
        (return false v-error))))
  (return true ""))

(defn validate-not-group-inline-lookup-refs [db: DB, sources: []DB-Source, group: Not-Group] -> [ok: bool, error: string]
  (for [item group.clauses]
    (let [[ok error] (validate-query-clause-inline-lookup-refs db sources item)]
      (when (not ok)
        (return false error))))
  (for [child group.not-groups]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-inline-lookup-refs [db: DB, sources: []DB-Source, group: Or-Group] -> [ok: bool, error: string]
  (for [branch group.branches]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources branch)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-query-inline-lookup-refs [db: DB, query-value: Query, sources: []DB-Source] -> [ok: bool, error: string]
  (for [item query-value.clauses]
    (let [[ok error] (validate-query-clause-inline-lookup-refs db sources item)]
      (when (not ok)
        (return false error))))
  (for [group query-value.not-groups]
    (let [[ok error] (validate-not-group-inline-lookup-refs db sources group)]
      (when (not ok)
        (return false error))))
  (for [group query-value.or-groups]
    (let [[ok error] (validate-or-group-inline-lookup-refs db sources group)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn string-slice-contains? [items: []string, value: string] -> bool
  (for [item items]
    (when (= item value)
      (return true)))
  false)

(defn append-var-once! [vars: ^[dynamic]string, name: string]
  (when (= name "")
    (return))
  (when (not (string-slice-contains? (slice vars^ 0) name))
    (arr.push! vars^ name)))

(defn append-var-once-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), name: string]
  (when (= name "")
    (return))
  (let [found (set.contains? seen^ name)]
    (when (not found)
      (set.add! seen name)
      (arr.push! vars^ name))))

(defn append-term-var! [vars: ^[dynamic]string, term: Term]
  (when (= term.kind .Var)
    (append-var-once! vars term.name)))

(defn append-term-var-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), term: Term]
  (when (= term.kind .Var)
    (append-var-once-indexed! vars seen term.name)))

(defn append-input-binding-vars! [vars: ^[dynamic]string, binding: Input-Binding]
  (let [names (input-binding-vars binding) :defer]
    (for [name names]
      (append-var-once! vars name))))

(defn append-input-binding-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), binding: Input-Binding]
  (let [names (input-binding-vars binding) :defer]
    (for [name names]
      (append-var-once-indexed! vars seen name))))

(defn append-query-input-vars! [vars: ^[dynamic]string, query-value: Query]
  (for [name query-value.inputs]
    (append-var-once! vars name))
  (for [name query-value.collection-inputs]
    (append-var-once! vars name))
  (for [tuple query-value.tuple-inputs]
    (for [name tuple.vars]
      (append-var-once! vars name))
    (append-input-binding-vars! vars tuple.binding))
  (for [relation query-value.relation-inputs]
    (for [name relation.vars]
      (append-var-once! vars name))
    (append-input-binding-vars! vars relation.binding))
  (for [spec query-value.input-specs]
    (case spec.kind
      .Scalar (append-var-once! vars spec.name)
      .Collection (append-var-once! vars spec.name)
      .Tuple (do
        (for [name spec.tuple.vars]
          (append-var-once! vars name))
        (append-input-binding-vars! vars spec.tuple.binding))
      .Relation (do
        (for [name spec.relation.vars]
          (append-var-once! vars name))
        (append-input-binding-vars! vars spec.relation.binding))
      .Ignore (do)
       (do))))

(defn append-query-input-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), query-value: Query]
  (for [name query-value.inputs]
    (append-var-once-indexed! vars seen name))
  (for [name query-value.collection-inputs]
    (append-var-once-indexed! vars seen name))
  (for [tuple query-value.tuple-inputs]
    (for [name tuple.vars]
      (append-var-once-indexed! vars seen name))
    (append-input-binding-vars-indexed! vars seen tuple.binding))
  (for [relation query-value.relation-inputs]
    (for [name relation.vars]
      (append-var-once-indexed! vars seen name))
    (append-input-binding-vars-indexed! vars seen relation.binding))
  (for [spec query-value.input-specs]
    (case spec.kind
      .Scalar (append-var-once-indexed! vars seen spec.name)
      .Collection (append-var-once-indexed! vars seen spec.name)
      .Tuple (do
        (for [name spec.tuple.vars]
          (append-var-once-indexed! vars seen name))
        (append-input-binding-vars-indexed! vars seen spec.tuple.binding))
      .Relation (do
        (for [name spec.relation.vars]
          (append-var-once-indexed! vars seen name))
        (append-input-binding-vars-indexed! vars seen spec.relation.binding))
      .Ignore (do)
       (do))))

(defn append-clause-vars! [vars: ^[dynamic]string, clause: Clause]
  (append-term-var! vars clause.e)
  (append-term-var! vars clause.a)
  (append-term-var! vars clause.v)
  (append-term-var! vars clause.tx-term)
  (append-term-var! vars clause.op-term))

(defn append-clause-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), clause: Clause]
  (append-term-var-indexed! vars seen clause.e)
  (append-term-var-indexed! vars seen clause.a)
  (append-term-var-indexed! vars seen clause.v)
  (append-term-var-indexed! vars seen clause.tx-term)
  (append-term-var-indexed! vars seen clause.op-term))

(defn append-not-group-vars! [vars: ^[dynamic]string, group: Not-Group]
  (for [clause group.clauses]
    (append-clause-vars! vars clause))
  (for [predicate group.predicates]
    (append-predicate-vars! vars predicate))
  (for [function group.function-clauses]
    (append-function-vars! vars function))
  (for [ground group.grounds]
    (append-ground-output-vars! vars ground))
  (for [get-else group.get-elses]
    (append-get-else-vars! vars get-else))
  (for [get-some group.get-somes]
    (append-get-some-vars! vars get-some))
  (for [call group.rule-calls]
    (append-rule-call-vars! vars call))
  (for [child group.not-groups]
    (append-not-group-vars! vars child))
  (for [name group.join-vars]
    (append-var-once! vars name)))

(defn append-not-group-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), group: Not-Group]
  (for [clause group.clauses]
    (append-clause-vars-indexed! vars seen clause))
  (for [predicate group.predicates]
    (append-predicate-vars-indexed! vars seen predicate))
  (for [function group.function-clauses]
    (append-function-vars-indexed! vars seen function))
  (for [ground group.grounds]
    (append-ground-output-vars-indexed! vars seen ground))
  (for [get-else group.get-elses]
    (append-get-else-vars-indexed! vars seen get-else))
  (for [get-some group.get-somes]
    (append-get-some-vars-indexed! vars seen get-some))
  (for [call group.rule-calls]
    (append-rule-call-vars-indexed! vars seen call))
  (for [child group.not-groups]
    (append-not-group-vars-indexed! vars seen child))
  (for [name group.join-vars]
    (append-var-once-indexed! vars seen name)))

(defn append-branch-output-vars! [vars: ^[dynamic]string, branch: Not-Group]
  (for [clause branch.clauses]
    (append-clause-vars! vars clause))
  (for [function branch.function-clauses]
    (append-function-output-vars! vars function))
  (for [ground branch.grounds]
    (append-ground-output-vars! vars ground))
  (for [get-else branch.get-elses]
    (append-var-once! vars get-else.out))
  (for [get-some branch.get-somes]
    (append-var-once! vars get-some.out-attr)
    (append-var-once! vars get-some.out-value))
  (for [call branch.rule-calls]
    (append-rule-call-vars! vars call)))

(defn append-branch-output-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), branch: Not-Group]
  (for [clause branch.clauses]
    (append-clause-vars-indexed! vars seen clause))
  (for [function branch.function-clauses]
    (append-function-output-vars-indexed! vars seen function))
  (for [ground branch.grounds]
    (append-ground-output-vars-indexed! vars seen ground))
  (for [get-else branch.get-elses]
    (append-var-once-indexed! vars seen get-else.out))
  (for [get-some branch.get-somes]
    (append-var-once-indexed! vars seen get-some.out-attr)
    (append-var-once-indexed! vars seen get-some.out-value))
  (for [call branch.rule-calls]
    (append-rule-call-vars-indexed! vars seen call)))

(defn append-or-group-vars! [vars: ^[dynamic]string, group: Or-Group]
  (for [branch group.branches]
    (append-branch-output-vars! vars branch))
  (for [name group.join-vars]
    (append-var-once! vars name)))

(defn append-or-group-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), group: Or-Group]
  (for [branch group.branches]
    (append-branch-output-vars-indexed! vars seen branch))
  (for [name group.join-vars]
    (append-var-once-indexed! vars seen name)))

(defn append-or-group-output-vars! [vars: ^[dynamic]string, group: Or-Group]
  (if group.has-join
    (for [name group.join-vars]
      (append-var-once! vars name))
    (append-or-group-vars! vars group)))

(defn append-or-group-output-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), group: Or-Group]
  (if group.has-join
    (for [name group.join-vars]
      (append-var-once-indexed! vars seen name))
    (append-or-group-vars-indexed! vars seen group)))

(defn append-rule-call-vars! [vars: ^[dynamic]string, call: Rule-Call]
  (for [arg call.args]
    (append-term-var! vars arg)))

(defn append-rule-call-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), call: Rule-Call]
  (for [arg call.args]
    (append-term-var-indexed! vars seen arg)))

(defn append-ground-output-vars! [vars: ^[dynamic]string, ground: Ground]
  (append-var-once! vars ground.out)
  (for [name ground.tuple-vars]
    (append-var-once! vars name))
  (append-input-binding-vars! vars ground.binding))

(defn append-ground-output-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), ground: Ground]
  (append-var-once-indexed! vars seen ground.out)
  (for [name ground.tuple-vars]
    (append-var-once-indexed! vars seen name))
  (append-input-binding-vars-indexed! vars seen ground.binding))

(defn append-function-output-vars! [vars: ^[dynamic]string, function: Function-Clause]
  (append-var-once! vars function.out)
  (for [name function.out-vars]
    (append-var-once! vars name))
  (append-input-binding-vars! vars function.out-binding))

(defn append-function-output-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), function: Function-Clause]
  (append-var-once-indexed! vars seen function.out)
  (for [name function.out-vars]
    (append-var-once-indexed! vars seen name))
  (append-input-binding-vars-indexed! vars seen function.out-binding))

(defn append-predicate-vars! [vars: ^[dynamic]string, predicate: Predicate]
  (when (query-var-name? predicate.op)
    (append-var-once! vars predicate.op))
  (for [term predicate.terms]
    (append-term-var! vars term)))

(defn append-predicate-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), predicate: Predicate]
  (when (query-var-name? predicate.op)
    (append-var-once-indexed! vars seen predicate.op))
  (for [term predicate.terms]
    (append-term-var-indexed! vars seen term)))

(defn append-function-vars! [vars: ^[dynamic]string, function: Function-Clause]
  (when (query-var-name? function.op)
    (append-var-once! vars function.op))
  (for [term function.terms]
    (append-term-var! vars term))
  (append-function-output-vars! vars function))

(defn append-function-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), function: Function-Clause]
  (when (query-var-name? function.op)
    (append-var-once-indexed! vars seen function.op))
  (for [term function.terms]
    (append-term-var-indexed! vars seen term))
  (append-function-output-vars-indexed! vars seen function))

(defn append-get-else-vars! [vars: ^[dynamic]string, clause: Get-Else]
  (append-term-var! vars clause.e)
  (append-var-once! vars clause.out))

(defn append-get-else-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), clause: Get-Else]
  (append-term-var-indexed! vars seen clause.e)
  (append-var-once-indexed! vars seen clause.out))

(defn append-get-some-vars! [vars: ^[dynamic]string, clause: Get-Some]
  (append-term-var! vars clause.e)
  (append-var-once! vars clause.out-attr)
  (append-var-once! vars clause.out-value))

(defn append-get-some-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), clause: Get-Some]
  (append-term-var-indexed! vars seen clause.e)
  (append-var-once-indexed! vars seen clause.out-attr)
  (append-var-once-indexed! vars seen clause.out-value))

(defn append-find-vars! [vars: ^[dynamic]string, query-value: Query]
  (for [name query-value.find]
    (append-var-once! vars name))
  (for [pull-find query-value.pulls]
    (append-var-once! vars pull-find.var)
    (when pull-find.has-pattern-var
      (append-var-once! vars pull-find.pattern-var)))
  (for [aggregate query-value.aggregates]
    (append-var-once! vars aggregate.var)
    (for [arg aggregate.args]
      (append-term-var! vars arg))
    (when aggregate.has-function-var
      (append-var-once! vars aggregate.function-var))
    (when aggregate.has-limit-var
      (append-var-once! vars aggregate.limit-var))))

(defn append-find-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), query-value: Query]
  (for [name query-value.find]
    (append-var-once-indexed! vars seen name))
  (for [pull-find query-value.pulls]
    (append-var-once-indexed! vars seen pull-find.var)
    (when pull-find.has-pattern-var
      (append-var-once-indexed! vars seen pull-find.pattern-var)))
  (for [aggregate query-value.aggregates]
    (append-var-once-indexed! vars seen aggregate.var)
    (for [arg aggregate.args]
      (append-term-var-indexed! vars seen arg))
    (when aggregate.has-function-var
      (append-var-once-indexed! vars seen aggregate.function-var))
    (when aggregate.has-limit-var
      (append-var-once-indexed! vars seen aggregate.limit-var))))

(defn query-var-list-text [vars: []string] -> string
  (let [inner (make [dynamic]string) :defer]
    (for [name vars]
      (arr.push! inner name))
    (let [[joined _] (core-strings.join (slice inner 0) " ")
          out (core-strings.concatenate ([]string ["[" joined "]"]))]
      (delete joined)
      (return out))))

(defn query-potential-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (append-query-input-vars-indexed! (addr vars) (addr seen) query-value)
    (for [clause query-value.clauses]
      (append-clause-vars-indexed! (addr vars) (addr seen) clause))
    (for [call query-value.rule-calls]
      (append-rule-call-vars-indexed! (addr vars) (addr seen) call))
    (for [predicate query-value.predicates]
      (append-predicate-vars-indexed! (addr vars) (addr seen) predicate))
    (for [function query-value.function-clauses]
      (append-function-vars-indexed! (addr vars) (addr seen) function))
    (for [get-else query-value.get-elses]
      (append-get-else-vars-indexed! (addr vars) (addr seen) get-else))
    (for [get-some query-value.get-somes]
      (append-get-some-vars-indexed! (addr vars) (addr seen) get-some))
    (for [ground query-value.grounds]
      (append-ground-output-vars-indexed! (addr vars) (addr seen) ground))
    (for [group query-value.not-groups]
      (append-not-group-vars-indexed! (addr vars) (addr seen) group))
    (for [group query-value.or-groups]
      (append-or-group-output-vars-indexed! (addr vars) (addr seen) group))
    vars))

(defn query-positive-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (append-query-input-vars-indexed! (addr vars) (addr seen) query-value)
    (for [clause query-value.clauses]
      (append-clause-vars-indexed! (addr vars) (addr seen) clause))
    (for [call query-value.rule-calls]
      (append-rule-call-vars-indexed! (addr vars) (addr seen) call))
    (for [ground query-value.grounds]
      (append-ground-output-vars-indexed! (addr vars) (addr seen) ground))
    (for [get-else query-value.get-elses]
      (append-get-else-vars-indexed! (addr vars) (addr seen) get-else))
    (for [get-some query-value.get-somes]
      (append-get-some-vars-indexed! (addr vars) (addr seen) get-some))
    (for [function query-value.function-clauses]
      (append-function-output-vars-indexed! (addr vars) (addr seen) function))
    vars))

(defn query-input-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (append-query-input-vars-indexed! (addr vars) (addr seen) query-value)
    vars))

(defn append-query-input-vars-raw! [vars: ^[dynamic]string, query-value: Query]
  (when (> (count query-value.input-specs) 0)
    (for [spec query-value.input-specs]
      (case spec.kind
        .Scalar (when (not (= spec.name ""))
                  (arr.push! vars^ spec.name))
        .Collection (when (not (= spec.name ""))
                      (arr.push! vars^ spec.name))
        .Tuple (for [name spec.tuple.vars]
                 (when (not (= name ""))
                   (arr.push! vars^ name)))
        .Relation (for [name spec.relation.vars]
                    (when (not (= name ""))
                      (arr.push! vars^ name)))
        .Ignore (do)
         (do)))
    (return))
  (for [name query-value.inputs]
    (when (not (= name ""))
      (arr.push! vars^ name)))
  (for [name query-value.collection-inputs]
    (when (not (= name ""))
      (arr.push! vars^ name)))
  (for [tuple query-value.tuple-inputs]
    (for [name tuple.vars]
      (when (not (= name ""))
        (arr.push! vars^ name))))
  (for [relation query-value.relation-inputs]
    (for [name relation.vars]
      (when (not (= name ""))
        (arr.push! vars^ name))))
  (do))

(defn query-input-vars-raw [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (append-query-input-vars-raw! (addr vars) query-value)
    vars))

(defn query-find-vars [query-value: Query] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (append-find-vars-indexed! (addr vars) (addr seen) query-value)
    vars))

(defn validate-query-parser-vars [query-value: Query] -> [ok: bool, error: string]
  (let [find-vars (query-find-vars query-value) :defer
        available (query-potential-vars query-value) :defer
        unknown (make [dynamic]string) :defer]
    (for [name find-vars]
      (when (not (string-slice-contains? (slice available 0) name))
        (append-var-once! (addr unknown) name)))
    (for [name query-value.with]
      (when (not (string-slice-contains? (slice available 0) name))
        (append-var-once! (addr unknown) name)))
    (when (> (count unknown) 0)
      (let [vars-text (query-var-list-text (slice unknown 0))]
        (defer (delete vars-text))
        (return false (fmt.tprintf "Query for unknown vars: %s" vars-text))))
    (let [overlap (make [dynamic]string) :defer]
      (for [name find-vars]
        (when (string-slice-contains? (slice query-value.with 0) name)
          (append-var-once! (addr overlap) name)))
      (when (> (count overlap) 0)
        (let [vars-text (query-var-list-text (slice overlap 0))]
          (defer (delete vars-text))
          (return false (fmt.tprintf ":find and :with should not use same variables: %s" vars-text))))))
  (let [input-vars (query-input-vars-raw query-value) :defer]
    (when (string-slice-has-duplicate? (slice input-vars 0))
      (return false "Vars used in :in should be distinct")))
  (when (string-slice-has-duplicate? (slice query-value.with 0))
    (return false "Vars used in :with should be distinct"))
  (let [[duplicate-pull-var duplicate-pull-found] (query-duplicate-pull-var query-value)]
    (when duplicate-pull-found
      (return false (fmt.tprintf "invalid pull expression in query: duplicate pull for %s" duplicate-pull-var))))
  (when (and (> (count query-value.rule-calls) 0)
             (not query-value.has-rules-input))
    (return false "Missing rules var '%' in :in"))
  (return true ""))

(defn string-slices-intersect? [left: []string, right: []string] -> bool
  (for [item left]
    (when (string-slice-contains? right item)
      (return true)))
  false)

(defn append-unbound-vars! [out: ^[dynamic]string, vars: []string, available: []string]
  (for [name vars]
    (when (not (string-slice-contains? available name))
      (append-var-once! out name))))

(defn string-slices-same-set? [left: []string, right: []string] -> bool
  (for [item left]
    (when (not (string-slice-contains? right item))
      (return false)))
  (for [item right]
    (when (not (string-slice-contains? left item))
      (return false)))
  true)

(defn validate-not-group-bindings [available: []string, group: Not-Group] -> [ok: bool, error: string]
  (let [vars (make [dynamic]string) :defer]
    (append-not-group-vars! (addr vars) group)
    (when (and (> (count vars) 0)
               (not (string-slices-intersect? (slice vars 0) available)))
      (return false (fmt.tprintf "insufficient bindings for not: %s" vars[0])))
    (when group.has-join
      (for [name group.join-vars]
        (when (not (string-slice-contains? available name))
          (return false (fmt.tprintf "insufficient bindings for not-join: %s" name)))))
    (for [child group.not-groups]
      (let [[ok error] (validate-not-group-bindings available child)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn or-branch-unbound-vars [branch: Not-Group, available: []string, join-vars: []string] -> [dynamic]string
  (let [branch-vars (make [dynamic]string) :defer
        blocked (arr.into [dynamic]string available) :defer
        out (make [dynamic]string)]
    (for [name join-vars]
      (append-var-once! (addr blocked) name))
    (append-branch-output-vars! (addr branch-vars) branch)
    (append-unbound-vars! (addr out) (slice branch-vars 0) (slice blocked 0))
    out))

(defn validate-or-branch-child-not-bindings [available: []string, branch: Not-Group] -> [ok: bool, error: string]
  (for [child branch.not-groups]
    (let [[ok error] (validate-not-group-bindings available child)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-or-group-bindings [available: []string, group: Or-Group] -> [ok: bool, error: string]
  (when (= (count group.branches) 0)
    (return false "or requires at least one branch"))
  (let [join-vars (if group.has-join (slice group.join-vars 0) ([]string []))
        expected (or-branch-unbound-vars group.branches[0] available join-vars)]
    (defer (delete expected))
    (for [branch index group.branches]
      (let [vars (or-branch-unbound-vars branch available join-vars)]
        (defer (delete vars))
        (when (and (not group.has-join)
                   (not (string-slices-same-set? (slice expected 0) (slice vars 0))))
          (return false "or branches must use same vars"))
        (let [[ok error] (validate-or-branch-child-not-bindings available branch)]
          (when (not ok)
            (return false error)))))
    (when group.has-join
      (for [name group.join-vars]
        (for [branch group.branches]
          (let [branch-vars (make [dynamic]string) :defer]
            (append-branch-output-vars! (addr branch-vars) branch)
            (when (and (not (string-slice-contains? available name))
                       (not (string-slice-contains? (slice branch-vars 0) name)))
              (return false (fmt.tprintf "or-join branch missing join var: %s" name))))))))
  (return true ""))

(defn validate-query-not-or-bindings [query-value: Query] -> [ok: bool, error: string]
  (let [available (query-positive-vars query-value)
        input-vars (query-input-vars query-value)]
    (defer (delete available))
    (defer (delete input-vars))
    (for [group query-value.not-groups]
      (let [[ok error] (validate-not-group-bindings (slice available 0) group)]
        (when (not ok)
          (return false error))))
    (for [group query-value.or-groups]
      (let [[ok error] (validate-or-group-bindings (slice input-vars 0) group)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn append-query-step-output-vars! [available: ^[dynamic]string, query-value: Query, step: Query-Step]
  (case step.kind
    .Clause (append-clause-vars! available query-value.clauses[step.index])
    .RuleCall (append-rule-call-vars! available query-value.rule-calls[step.index])
    .Ground (append-ground-output-vars! available query-value.grounds[step.index])
    .Function (append-function-output-vars! available query-value.function-clauses[step.index])
    .Or (if query-value.or-groups[step.index].has-join
          (for [name query-value.or-groups[step.index].join-vars]
            (append-var-once! available name))
          (append-or-group-vars! available query-value.or-groups[step.index]))
     (do)))

(defn predicate-op-supported-with-fns? [op: string, registry: []Native-Query-Fn] -> bool
  (or (predicate-op-supported? op)
      (query-fn-supported? registry op)))

(defn function-op-supported-with-fns? [op: string, registry: []Native-Query-Fn] -> bool
  (or (function-op-supported? op)
      (query-fn-supported? registry op)))

(defn validate-query-ordered-step-indexed-with-fns [available: ^[dynamic]string, query-value: Query, rule-index: []Rule-Name-Index-Entry, step: Query-Step, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (case step.kind
    .Predicate (let [predicate query-value.predicates[step.index]]
                 (when (not (predicate-op-supported-with-fns? predicate.op registry))
                   (return false (fmt.tprintf "unknown query predicate: %s" predicate.op)))
                 (when (and (query-var-name? predicate.op)
                            (not (string-slice-contains? (slice available^ 0) predicate.op)))
                   (return false (fmt.tprintf "insufficient bindings for %s: %s" predicate.op predicate.op)))
                 (let [[ok error] (validate-term-vars-bound (slice available^ 0) predicate.terms predicate.op)]
                   (when (not ok)
                     (return false error))))
    .Function (let [function query-value.function-clauses[step.index]]
                (when (not (function-op-supported-with-fns? function.op registry))
                  (return false (fmt.tprintf "unknown query function: %s" function.op)))
                (when (and (query-var-name? function.op)
                           (not (string-slice-contains? (slice available^ 0) function.op)))
                  (return false (fmt.tprintf "insufficient bindings for %s: %s" function.op function.op)))
                (let [[ok error] (validate-term-vars-bound (slice available^ 0) function.terms function.op)]
                  (when (not ok)
                    (return false error))))
    .Not (let [[ok error] (validate-not-group-bindings (slice available^ 0) query-value.not-groups[step.index])]
           (when (not ok)
             (return false error)))
    .Or (let [[ok error] (validate-or-group-bindings (slice available^ 0) query-value.or-groups[step.index])]
          (when (not ok)
            (return false error)))
    .RuleCall (let [call query-value.rule-calls[step.index]
                    [ok error] (validate-rule-call-required-bindings-indexed (slice available^ 0) (slice query-value.rules 0) rule-index call)]
                (when (not ok)
                  (return false error)))
     (do))
  (append-query-step-output-vars! available query-value step)
  (return true ""))

(defn validate-query-ordered-step-with-fns [available: ^[dynamic]string, query-value: Query, step: Query-Step, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [rule-index (rule-name-index-build (slice query-value.rules 0))]
    (defer (delete-rule-name-index rule-index))
    (validate-query-ordered-step-indexed-with-fns available query-value (slice rule-index 0) step registry)))

(defn validate-query-ordered-step [available: ^[dynamic]string, query-value: Query, step: Query-Step] -> [ok: bool, error: string]
  (validate-query-ordered-step-with-fns available query-value step ([]Native-Query-Fn [])))

(defn validate-query-ordered-bindings-with-fns [query-value: Query, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [available (query-input-vars query-value)
        rule-index (rule-name-index-build (slice query-value.rules 0))]
    (defer (delete available))
    (defer (delete-rule-name-index rule-index))
    (for [step query-value.where-steps]
      (let [[ok error] (validate-query-ordered-step-indexed-with-fns (addr available) query-value (slice rule-index 0) step registry)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn validate-query-ordered-bindings [query-value: Query] -> [ok: bool, error: string]
  (validate-query-ordered-bindings-with-fns query-value ([]Native-Query-Fn [])))

(defn predicate-op-supported? [op: string] -> bool
  (or (query-var-name? op)
      (= op "=")
      (= op "!=")
      (= op "not=")
      (= op ">")
      (= op "<")
      (= op ">=")
      (= op "<=")
      (= op "true?")
      (= op "false?")
      (= op "nil?")
      (= op "some?")
      (= op "not")
      (= op "empty?")
      (= op "even?")
      (= op "odd?")
      (= op "zero?")
      (= op "pos?")
      (= op "neg?")
      (= op "re-find")
      (= op "contains?")
      (= op "clojure.string/includes?")
      (= op "clojure.string/starts-with?")
      (= op "clojure.string/ends-with?")))

(defn function-op-supported? [op: string] -> bool
  (or (query-var-name? op)
      (source-function-op? op)
      (= op "count")
      (= op "identity")
      (= op "ground")
      (= op "inc")
      (= op "dec")
      (= op "range")
      (= op "name")
      (= op "subs")
      (= op "re-pattern")
      (= op "re-find")
      (= op "str")
      (= op "keyword")
      (= op "first")
      (= op "second")
      (= op "vector")
      (= op "tuple")
      (= op "untuple")
      (= op "hash-map")
      (= op "get")
      (= op "contains?")
      (= op "clojure.string/includes?")
      (= op "clojure.string/starts-with?")
      (= op "clojure.string/ends-with?")
      (= op "+")
      (= op "-")
      (= op "*")
      (= op "/")
      (= op "quot")
      (= op "rem")
      (= op "mod")
      (= op "min")
      (= op "max")
      (= op "compare")))

(defn validate-term-vars-bound [available: []string, terms: []Term, ctx: string] -> [ok: bool, error: string]
  (for [term index terms]
    (when (and (= term.kind .Var)
               (not (and (= index 0)
                         (source-function-op? ctx)
                         (source-default-token-term? term)))
               (not (string-slice-contains? available term.name)))
      (return false (fmt.tprintf "insufficient bindings for %s: %s" ctx term.name))))
  (return true ""))

(defn validate-query-predicates-and-functions-with-fns [query-value: Query, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [available (query-potential-vars query-value)]
    (defer (delete available))
    (for [function query-value.function-clauses]
      (when (not (function-op-supported-with-fns? function.op registry))
        (return false (fmt.tprintf "unknown query function: %s" function.op)))
      (when (and (query-var-name? function.op)
                 (not (string-slice-contains? (slice available 0) function.op)))
        (return false (fmt.tprintf "insufficient bindings for %s: %s" function.op function.op)))
      (let [[ok error] (validate-term-vars-bound (slice available 0) function.terms function.op)]
        (when (not ok)
          (return false error)))
      (append-function-output-vars! (addr available) function))
    (for [predicate query-value.predicates]
      (when (not (predicate-op-supported-with-fns? predicate.op registry))
        (return false (fmt.tprintf "unknown query predicate: %s" predicate.op)))
      (when (and (query-var-name? predicate.op)
                 (not (string-slice-contains? (slice available 0) predicate.op)))
        (return false (fmt.tprintf "insufficient bindings for %s: %s" predicate.op predicate.op)))
      (let [[ok error] (validate-term-vars-bound (slice available 0) predicate.terms predicate.op)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn validate-query-predicates-and-functions [query-value: Query] -> [ok: bool, error: string]
  (validate-query-predicates-and-functions-with-fns query-value ([]Native-Query-Fn [])))

(defn validate-query-get-elses [query-value: Query] -> [ok: bool, error: string]
  (for [get-else query-value.get-elses]
    (when (= get-else.default-value.kind .Nil)
      (return false "get-else: nil default value is not supported")))
  (for [rule query-value.rules]
    (for [get-else rule.get-elses]
      (when (= get-else.default-value.kind .Nil)
        (return false "get-else: nil default value is not supported"))))
  (return true ""))

(defn validate-query-sources [query-value: Query, sources: []DB-Source] -> [ok: bool, error: string]
  (let [unknown (make [dynamic]string) :defer]
  (for [item query-value.clauses]
    (when item.has-source
      (append-unknown-query-source! (addr unknown) query-value sources item.source)))
  (for [item query-value.rule-calls]
    (when item.has-source
      (append-unknown-query-source! (addr unknown) query-value sources item.source)))
  (for [item query-value.pulls]
    (when item.has-source
      (append-unknown-query-source! (addr unknown) query-value sources item.source)))
  (for [group query-value.not-groups]
    (append-unknown-query-not-group-sources! (addr unknown) query-value sources group))
  (for [group query-value.or-groups]
    (append-unknown-query-or-group-sources! (addr unknown) query-value sources group))
  (when (> (count unknown) 0)
    (let [vars-text (query-var-list-text (slice unknown 0))]
      (defer (delete vars-text))
      (return false (fmt.tprintf "Where uses unknown source vars: %s" vars-text)))))
  (return true ""))

(defn rule-param-valid? [name: string] -> bool
  (strings.has_prefix name "?"))

(defn rule-call-matches-rule? [call: Rule-Call, rule: Rule] -> bool
  (and (= call.name rule.name)
       (= (count call.args) (count rule.params))))

(defn string-slice-has-duplicate? [items: []string] -> bool
  (for [item index items]
    (let [other-index (+ index 1)]
      (while (< other-index (count items))
      (when (= item items[other-index])
        (return true))
      (set! other-index (+ other-index 1)))))
  false)

(defn query-duplicate-pull-var [query-value: Query] -> [name: string, found: bool]
  (for [pull-find index query-value.pulls]
    (let [other-index (+ index 1)]
      (while (< other-index (count query-value.pulls))
      (when (= pull-find.var query-value.pulls[other-index].var)
        (return pull-find.var true))
      (set! other-index (+ other-index 1)))))
  (return "" false))

(defn validate-rule-call-known-indexed [rules: []Rule, index: []Rule-Name-Index-Entry, call: Rule-Call] -> [ok: bool, error: string]
  (let [[entry-index name-found] (rule-name-index-entry index call.name)]
    (when (not name-found)
      (return false (fmt.tprintf "unknown rule: %s" call.name)))
    (for [rule-index index[entry-index].indexes]
      (when (= (count call.args) (count rules[rule-index].params))
        (return true "")))
    (return false (fmt.tprintf "wrong arity for rule: %s" call.name))))

(defn validate-rule-call-known [rules: []Rule, call: Rule-Call] -> [ok: bool, error: string]
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (validate-rule-call-known-indexed rules (slice index 0) call)))

(defn validate-rule-definition-indexed [rules: []Rule, index: []Rule-Name-Index-Entry, rule: Rule] -> [ok: bool, error: string]
  (when (= (count rule.body-steps) 0)
    (return false "Rule branch should have clauses"))
  (when (string-slice-has-duplicate? (slice rule.params 0))
    (return false "Rule variables should be distinct"))
  (let [[entry-index found] (rule-name-index-entry index rule.name)]
    (when found
      (for [rule-index index[entry-index].indexes]
        (let [other rules[rule-index]]
          (when (or (not (= other.required-param-count rule.required-param-count))
                    (not (= (count other.params) (count rule.params))))
            (return false (fmt.tprintf "Arity mismatch for rule: %s" rule.name)))))))
  (for [param rule.params]
    (when (not (rule-param-valid? param))
      (return false (fmt.tprintf "rule params must be variables: %s" param))))
  (for [call rule.rule-calls]
    (let [[ok error] (validate-rule-call-known-indexed rules index call)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn validate-rule-definition [rules: []Rule, rule: Rule] -> [ok: bool, error: string]
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (validate-rule-definition-indexed rules (slice index 0) rule)))

(defn validate-rule-call-required-bindings-indexed [available: []string, rules: []Rule, index: []Rule-Name-Index-Entry, call: Rule-Call] -> [ok: bool, error: string]
  (let [[rule rule-ok] (rule-name-index-first-matching-rule rules index call)]
    (when rule-ok
      (let [param-index 0]
        (while (< param-index rule.required-param-count)
          (let [arg call.args[param-index]]
            (when (= arg.kind .Wildcard)
              (return false (fmt.tprintf "insufficient bindings for rule: %s" call.name)))
            (when (and (= arg.kind .Var)
                       (not (string-slice-contains? available arg.name)))
              (return false (fmt.tprintf "insufficient bindings for rule: %s" arg.name))))
          (set! param-index (+ param-index 1))))))
  (return true ""))

(defn validate-rule-call-required-bindings [available: []string, rules: []Rule, call: Rule-Call] -> [ok: bool, error: string]
  (let [index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (validate-rule-call-required-bindings-indexed available rules (slice index 0) call)))

(defn validate-query-rules [query-value: Query] -> [ok: bool, error: string]
  (let [rules (slice query-value.rules 0)
        index (rule-name-index-build rules)]
    (defer (delete-rule-name-index index))
    (for [rule query-value.rules]
      (let [[ok error] (validate-rule-definition-indexed rules (slice index 0) rule)]
        (when (not ok)
          (return false error))))
    (for [call query-value.rule-calls]
      (let [[ok error] (validate-rule-call-known-indexed rules (slice index 0) call)]
        (when (not ok)
          (return false error)))))
  (return true ""))

(defn validate-query-pull-patterns [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (for [pull-find query-value.pulls]
    (let [[pull-db pull-db-ok] (pull-db-for-find db sources pull-find)]
      (when (not pull-db-ok)
        (return false "unknown pull source"))
      (let [[pattern pattern-ok] (pull-find-pattern query-value inputs pull-find)]
        (when (not pattern-ok)
          (return false "pull pattern input must be a pull pattern"))
        (let [[pattern-valid pattern-error] (validate-pull-pattern pull-db pattern)]
          (when (not pattern-valid)
            (return false pattern-error))))))
  (return true ""))

(defn validate-query-call-with-fns [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn] -> [ok: bool, error: string]
  (let [expected (query-expected-input-count query-value)
        provided (count inputs)]
    (when (not (= expected provided))
      (return false (fmt.tprintf "wrong number of query inputs: expected %d, got %d" expected provided))))
  (let [[parser-ok parser-error] (validate-query-parser-vars query-value)]
    (when (not parser-ok)
      (return false parser-error)))
  (let [[default-source-ok default-source-error] (validate-query-default-source-input query-value)]
    (when (not default-source-ok)
      (return false default-source-error)))
  (let [[source-ok source-error] (validate-query-sources query-value sources)]
    (when (not source-ok)
      (return false source-error)))
  (let [[source-input-ok source-input-error] (validate-query-source-input-values query-value inputs sources)]
    (when (not source-input-ok)
      (return false source-input-error)))
  (let [[input-ok input-error] (validate-query-input-values query-value inputs)]
    (when (not input-ok)
      (return false input-error)))
  (let [[pull-ok pull-error] (validate-query-pull-patterns db query-value inputs sources)]
    (when (not pull-ok)
      (return false pull-error)))
  (let [[lookup-ok lookup-error] (validate-query-inline-lookup-refs db query-value sources)]
    (when (not lookup-ok)
      (return false lookup-error)))
  (let [[rules-ok rules-error] (validate-query-rules query-value)]
    (when (not rules-ok)
      (return false rules-error)))
  (if (> (count query-value.where-steps) 0)
    (do
      (let [[get-else-ok get-else-error] (validate-query-get-elses query-value)]
        (when (not get-else-ok)
          (return false get-else-error)))
      (validate-query-ordered-bindings-with-fns query-value registry))
    (do
      (let [[get-else-ok get-else-error] (validate-query-get-elses query-value)]
        (when (not get-else-ok)
          (return false get-else-error)))
      (let [[binding-ok binding-error] (validate-query-not-or-bindings query-value)]
        (when (not binding-ok)
          (return false binding-error)))
      (validate-query-predicates-and-functions-with-fns query-value registry))))

(defn validate-query-call [db: DB, query-value: Query, inputs: []Query-Input, sources: []DB-Source] -> [ok: bool, error: string]
  (validate-query-call-with-fns db query-value inputs sources ([]Native-Query-Fn [])))

(defn aggregate-initial-value [aggregate: Aggregate-Find] -> Value
  (when (= aggregate.op "distinct")
    (return (value-vector-owned (make [dynamic]Value))))
  (if (or (= aggregate.op "count")
          (= aggregate.op "count-distinct")
          (= aggregate.op "sum")
          (= aggregate.op "avg")
          (= aggregate.op "median")
          (= aggregate.op "variance")
          (= aggregate.op "stddev"))
    (value-int 0)
    (Value {})))

(defn sort-i64! [values: ^[dynamic]i64]
  (arr.sort! values^))

(defn sort-values! [values: ^[dynamic]Value]
  (let [i 1]
    (while (< i (count values^))
    (let [current values^[i]
          j i]
      (while (and (> j 0)
                  (value-less? current values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] current))
    (set! i (+ i 1)))))

(defn top-n-values [values: []Value, limit: int, max?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (let [take-count (min limit (count sorted))]
      (if max?
        (let [index (count sorted)
              remaining take-count]
          (while (> remaining 0)
            (set! index (- index 1))
            (arr.push! out sorted[index])
            (set! remaining (- remaining 1))))
        (let [index 0]
          (while (< index take-count)
            (arr.push! out sorted[index])
            (set! index (+ index 1)))))
      (value-vector-owned out))))

(defn query-attr-top-n-aggregate-plan [query: Query] -> [plan: Attr-Top-N-Aggregate-Plan, ok: bool]
  (let [out (empty-attr-top-n-aggregate-plan)]
    (when (not (and (= (count query.find) 0)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (> (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 1)
                    (= query.where-steps[0].kind .Clause)))
      (return out false))
    (let [query-clause: Clause query.clauses[0]]
      (when (or query-clause.has-source
                (not (= query-clause.e.kind .Var))
                (not (= query-clause.a.kind .Value))
                (not (= query-clause.a.value.kind .Keyword))
                (not (= query-clause.v.kind .Var))
                (not (= query-clause.tx-term.kind .Wildcard))
                (not (= query-clause.op-term.kind .Wildcard)))
        (return out false))
      (for [aggregate query.aggregates]
        (when (or (not (or (= aggregate.op "min")
                           (= aggregate.op "max")))
                  aggregate.has-limit-var
                  (and aggregate.has-limit
                       (<= aggregate.limit 0))
                  (not (= aggregate.var query-clause.v.name)))
          (return out false))
        (when (> (count aggregate.args) 0)
          (when (not (and (= (count aggregate.args) 1)
                          (= aggregate.args[0].kind .Var)
                          (= aggregate.args[0].name query-clause.v.name)))
            (return out false))))
      (return (Attr-Top-N-Aggregate-Plan {attr: query-clause.a.value.text
                                          value-var: query-clause.v.name})
              true))))

(defn attr-top-n-values [db: DB, plan: Attr-Top-N-Aggregate-Plan, aggregate: Aggregate-Find, inspected: ^int] -> Value
  (let [view (db-index-view db .AVET)
        attr-prefix ([]Value [(value-keyword plan.attr)])
        low (lower-bound-index-view-values db view attr-prefix)
        high (upper-bound-index-view-values db view attr-prefix)
        out (make [dynamic]Value)
        all-current (all-datoms-current? db)
        last-value (Value {})
        has-last false]
    (if (= aggregate.op "max")
      (let [i high]
        (while (and (> i low)
                    (or (not aggregate.has-limit)
                        (< (count out) aggregate.limit)))
          (set! i (- i 1))
          (set! inspected^ (+ inspected^ 1))
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (or all-current (datom-current-at? db datom-index))
              (when (not (and has-last (value-equal? datom.v last-value)))
                (when (not aggregate.has-limit)
                  (delete out)
                  (return (value-owned datom.v)))
                (arr.push! out datom.v)
                (set! last-value datom.v)
                (set! has-last true))))))
      (let [i low]
        (while (and (< i high)
                    (or (not aggregate.has-limit)
                        (< (count out) aggregate.limit)))
          (set! inspected^ (+ inspected^ 1))
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (or all-current (datom-current-at? db datom-index))
              (when (not (and has-last (value-equal? datom.v last-value)))
                (when (not aggregate.has-limit)
                  (delete out)
                  (return (value-owned datom.v)))
                (arr.push! out datom.v)
                (set! last-value datom.v)
                (set! has-last true))))
          (set! i (+ i 1)))))
    (if aggregate.has-limit
      (value-vector-owned out)
      (do
        (delete out)
        (Value {})))))

(defn q-attr-top-n-aggregate-profiled [db: DB, query: Query, plan: Attr-Top-N-Aggregate-Plan, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        values (make [dynamic]Value 0 (count query.aggregates))
        pulls (make [dynamic]Pull-Result)
        rows (make [dynamic]Result-Row)
        inspected 0]
    (set! out-stats.steps 1)
    (set! out-stats.clauses 1)
    (for [aggregate query.aggregates]
      (arr.push! values (attr-top-n-values db plan aggregate (addr inspected))))
    (set! out-stats.clause-candidates inspected)
    (arr.push! rows (Result-Row {values: values pulls: pulls}))
    (set! out-stats.output-rows 1)
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn query-missing-attr-projection-plan [db: DB, query: Query] -> [plan: Missing-Attr-Projection-Plan, ok: bool]
  (let [out (empty-missing-attr-projection-plan)]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.not-groups) 1)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 2)))
      (return out false))
    (when (not (and (= query.where-steps[0].kind .Clause)
                    (= query.where-steps[1].kind .Not)))
      (return out false))
    (let [value-clause: Clause query.clauses[0]
          group query.not-groups[0]]
      (when (or value-clause.has-source
                (not (= value-clause.e.kind .Var))
                (not (= value-clause.a.kind .Value))
                (not (= value-clause.a.value.kind .Keyword))
                (not (= value-clause.v.kind .Var))
                (not (= value-clause.v.name query.find[0]))
                (not (= value-clause.tx-term.kind .Wildcard))
                (not (= value-clause.op-term.kind .Wildcard))
                (not (schema-cardinality-one? db value-clause.a.value.text))
                group.has-join
                (not (= (count group.clauses) 1))
                (> (count group.not-groups) 0))
        (return out false))
      (let [missing-clause: Clause group.clauses[0]]
        (when (or missing-clause.has-source
                  (not (= missing-clause.e.kind .Var))
                  (not (= missing-clause.e.name value-clause.e.name))
                  (not (= missing-clause.a.kind .Value))
                  (not (= missing-clause.a.value.kind .Keyword))
                  (not (= missing-clause.v.kind .Wildcard)))
          (return out false))
        (return (Missing-Attr-Projection-Plan {entity-var: value-clause.e.name
                                               value-var: value-clause.v.name
                                               value-attr: value-clause.a.value.text
                                               missing-attr: missing-clause.a.value.text})
                true)))))

(defn q-missing-attr-projection-profiled [db: DB, plan: Missing-Attr-Projection-Plan, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 plan.value-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 plan.value-attr (Value {}))
        rows (make [dynamic]Result-Row)
        seen (set.empty string)
        i low]
    (defer (delete seen))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 2)
    (set! out-stats.clause-candidates (- high low))
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (current-attr-exists? db datom.e plan.missing-attr)))
          (let [[key key-ok] (primitive-value-dedupe-key datom.v)]
            (if key-ok
              (when (not (set.contains? seen key))
                (set.add! seen key)
                (let [values (make [dynamic]Value 0 1)
                      pulls (make [dynamic]Pull-Result)]
                  (arr.push! values datom.v)
                  (arr.push! rows (Result-Row {values: values pulls: pulls}))))
              (let [dedupe-values ([]Value [datom.v])]
                (when (not (row-values-exist? (slice rows 0) dedupe-values))
                  (let [values (make [dynamic]Value 0 1)
                        pulls (make [dynamic]Pull-Result)]
                    (arr.push! values datom.v)
                    (arr.push! rows (Result-Row {values: values pulls: pulls})))))))))
      (set! i (+ i 1)))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-missing-attr-string-column [db: DB, plan: Missing-Attr-Projection-Plan] -> [values: [dynamic]string, ok: bool]
  (let [out (make [dynamic]string)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 plan.value-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 plan.value-attr (Value {}))
        seen (set.empty string)
        i low]
    (defer (delete seen))
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (and (datom-current-at? db datom-index)
                   (not (current-attr-exists? db datom.e plan.missing-attr)))
          (when (not (or (= datom.v.kind .String)
                         (= datom.v.kind .Keyword)
                         (= datom.v.kind .Symbol)
                         (= datom.v.kind .Uuid)))
            (return out false))
          (when (not (set.contains? seen datom.v.text))
            (set.add! seen datom.v.text)
            (arr.push! out (string-owned datom.v.text)))))
      (set! i (+ i 1)))
    (return out true)))

(defn sorted-values-vector [values: []Value, descending?: bool] -> Value
  (let [sorted (arr.into [dynamic]Value values)
        out (make [dynamic]Value)]
    (defer (delete sorted))
    (sort-values! (addr sorted))
    (if descending?
      (let [index (count sorted)]
        (while (> index 0)
          (set! index (- index 1))
          (arr.push! out sorted[index])))
      (for [value sorted]
        (arr.push! out value)))
    (value-vector-owned out)))

(defn numeric-aggregate-op? [op: string] -> bool
  (or (= op "median")
      (= op "variance")
      (= op "stddev")))

(defn numeric-value? [value: Value] -> bool
  (or (= value.kind .Int)
      (= value.kind .Float)))

(defn value-as-f64 [value: Value] -> [out: f64, ok: bool]
  (case value.kind
    .Int (return (f64 value.int-value) true)
    .Float (return value.float-value true)
     (return 0.0 false)))

(defn numeric-values-to-sorted-f64 [values: []Value] -> [numbers: [dynamic]f64, all-int?: bool]
  (let [out-values (make [dynamic]f64)
        all-int-values? true]
    (for [value values]
      (let [[number number-ok] (value-as-f64 value)]
        (when number-ok
          (when (not (= value.kind .Int))
            (set! all-int-values? false))
          (arr.push! out-values number))))
    (arr.sort! out-values)
    (return out-values all-int-values?)))

(defn median-numeric [values: []Value] -> Value
  (let [[sorted all-int?] (numeric-values-to-sorted-f64 values)]
    (defer (delete sorted))
    (when (= (count sorted) 0)
      (return (value-int 0)))
    (let [mid (/ (count sorted) 2)]
      (when (= (% (count sorted) 2) 1)
        (if all-int?
          (return (value-int (i64 sorted[mid])))
          (return (value-float sorted[mid]))))
      (value-float (/ (+ sorted[(- mid 1)] sorted[mid]) 2.0)))))

(defn variance-numeric [values: []Value] -> Value
  (let [[numbers _] (numeric-values-to-sorted-f64 values)]
    (defer (delete numbers))
    (when (= (count numbers) 0)
      (return (value-int 0)))
    (let [sum: f64 0.0]
      (for [value numbers]
        (set! sum (+ sum value)))
      (let [mean (/ sum (f64 (count numbers)))
            squared: f64 0.0]
        (for [value numbers]
          (let [diff (- value mean)]
            (set! squared (+ squared (* diff diff)))))
        (value-float (/ squared (f64 (count numbers))))))))

(defn stddev-numeric [values: []Value] -> Value
  (let [variance (variance-numeric values)]
    (when (= variance.kind .Float)
      (return (value-float (math.sqrt variance.float-value))))
    (value-float (math.sqrt (f64 variance.int-value)))))

(defn median-int [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sorted (arr.into [dynamic]i64 values)]
    (defer (delete sorted))
    (sort-i64! (addr sorted))
    (let [mid (/ (count sorted) 2)]
      (if (= (% (count sorted) 2) 1)
        (value-int sorted[mid])
        (value-int (/ (+ sorted[(- mid 1)] sorted[mid]) 2))))))

(defn variance-float [values: []i64] -> Value
  (when (= (count values) 0)
    (return (value-int 0)))
  (let [sum: f64 0]
    (for [value values]
      (set! sum (+ sum (f64 value))))
    (let [mean (/ sum (f64 (count values)))
          squared: f64 0]
      (for [value values]
        (let [diff (- (f64 value) mean)]
          (set! squared (+ squared (* diff diff)))))
      (value-float (/ squared (f64 (count values)))))))

(defn stddev-float [values: []i64] -> Value
  (let [variance (variance-float values)]
    (when (= variance.kind .Float)
      (return (value-float (math.sqrt variance.float-value))))
    (value-float (math.sqrt (f64 variance.int-value)))))

(defn builtin-aggregate-op? [op: string] -> bool
  (or (= op "count")
      (= op "count-distinct")
      (= op "distinct")
      (= op "min")
      (= op "max")
      (= op "sum")
      (= op "avg")
      (= op "median")
      (= op "variance")
      (= op "stddev")
      (= op "rand")
      (= op "sample")
      (= op "aggregate")))

(defn custom-aggregate-op? [aggregate: Aggregate-Find] -> bool
  (not (builtin-aggregate-op? aggregate.op)))

(defn aggregate-function-name [binding: Binding, aggregate: Aggregate-Find] -> [name: string, ok: bool]
  (when (not aggregate.has-function-var)
    (return "" false))
  (let [[value ok] (binding-lookup binding aggregate.function-var)]
    (when (not ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true)))
  (return "" false))

(defn apply-named-aggregate [name: string, values: []Value] -> [value: Value, ok: bool]
  (cond
    (or (= name "sort-reverse")
        (= name ":sort-reverse")) (return (sorted-values-vector values true) true)
    (or (= name "sort")
        (= name ":sort")) (return (sorted-values-vector values false) true)
    :else (return (Value {}) false)))

(defn apply-named-aggregate-with-fns [name: string, values: []Value, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (let [[builtin builtin-ok] (apply-named-aggregate name values)]
    (when builtin-ok
      (return builtin true)))
  (let [[index found] (query-fn-index registry name)]
    (when (not found)
      (return (Value {}) false))
    (let [entry registry[index]]
      (when entry.has-aggregate-callback
        (let [result (entry.aggregate-callback values)]
          (return result.value result.ok)))
      (when (> (count entry.target) 0)
        (return (apply-named-aggregate entry.target values)))))
  (return (Value {}) false))

(defn apply-aggregate-value [current: Value, aggregate: Aggregate-Find, value: Value] -> Value
  (when (or (= aggregate.op "count")
            (= aggregate.op "count-distinct"))
    (return (value-int (+ current.int-value 1))))
  (when (or (= aggregate.op "sum")
            (= aggregate.op "avg"))
    (when (= value.kind .Int)
      (if (= current.kind .Float)
        (return (value-float (+ current.float-value (f64 value.int-value))))
        (return (value-int (+ current.int-value value.int-value)))))
    (when (= value.kind .Float)
      (if (= current.kind .Float)
        (return (value-float (+ current.float-value value.float-value)))
        (return (value-float (+ (f64 current.int-value) value.float-value))))))
  (when (= current.kind .Nil)
    (return value))
  (if (= aggregate.op "min")
    (if (value-less? value current) value current)
    (if (= aggregate.op "max")
      (if (value-less? current value) value current)
      current)))

(defn distinct-values-vector-owned [values: []Value] -> Value
  (let [out (make [dynamic]Value 0 (count values))]
    (for [value values]
      (arr.push! out (value-owned value)))
    (value-vector-owned out)))

(defn random-values-owned [values: []Value, limit: int] -> Value
  (let [out (make [dynamic]Value)]
    (when (= (count values) 0)
      (return (value-vector-owned out)))
    (for [_ (arr.range 0 limit)]
      (arr.push! out (value-owned values[(rand.int_max (count values))])))
    (value-vector-owned out)))

(defn sample-values-owned [values: []Value, limit: int] -> Value
  (let [out (make [dynamic]Value)
        available (make [dynamic]int) :defer
        take-count (min limit (count values))]
    (for [index (arr.range 0 (count values))]
      (arr.push! available index))
    (for [_ (arr.range 0 take-count)]
      (let [available-index (rand.int_max (count available))
            value-index available[available-index]]
        (arr.push! out (value-owned values[value-index]))
        (arr.remove-unordered-at! available available-index)))
    (value-vector-owned out)))

(defn random-value-owned [values: []Value] -> Value
  (when (= (count values) 0)
    (return (Value {})))
  (value-owned values[(rand.int_max (count values))]))

(defn selection-values-owned [values: []Value, limit: int, op: string] -> Value
  (if (= op "rand")
    (random-values-owned values limit)
    (sample-values-owned values limit)))

(defn limited-selection-aggregate-op? [op: string] -> bool
  (or (= op "rand")
      (= op "sample")))

(defn aggregate-collects-limited-values? [aggregate: Aggregate-Find] -> bool
  (or (limited-selection-aggregate-op? aggregate.op)
      (and (or aggregate.has-limit aggregate.has-limit-var)
           (or (= aggregate.op "min")
               (= aggregate.op "max")))))

(defn binding-values-for-vars [binding: Binding, names: []string] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value 0 (count names))]
    (for [name names]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-key-values [binding: Binding, query: Query, aggregate: Aggregate-Find] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query.find]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (for [name query.with]
      (let [[value ok] (binding-lookup binding name)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (if (> (count aggregate.args) 0)
      (for [arg aggregate.args]
        (let [[value ok] (resolve-term arg binding)]
          (if ok
            (arr.push! out value)
            (return out false))))
      (let [[value ok] (binding-lookup binding aggregate.var)]
        (if ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-key-row [values: []Value] -> Result-Row
  (let [stored (arr.into [dynamic]Value values)
        pulls (make [dynamic]Pull-Result)]
    (Result-Row {values: stored pulls: pulls})))

(defn aggregate-owned-key-row [values: []Value] -> Result-Row
  (let [stored (make [dynamic]Value 0 (count values))
        pulls (make [dynamic]Pull-Result)]
    (for [value values]
      (arr.push! stored (value-owned value)))
    (Result-Row {values: stored pulls: pulls})))

(defn aggregate-value-for-group-with-fns [bindings: []Binding, query: Query, aggregate: Aggregate-Find, group-values: []Value, registry: []Native-Query-Fn] -> Value
  (let [current (aggregate-initial-value aggregate)
        avg-count: i64 0
        resolved-limit aggregate.limit
        aggregate-values (make [dynamic]Value)
        distinct-values (make [dynamic]Value)
        seen-keys (make [dynamic]Result-Row)
        custom-name ""
        custom-name-ok false]
    (defer (delete aggregate-values))
    (defer (delete distinct-values))
    (defer (delete seen-keys))
    (for [binding bindings]
      (let [[binding-group ok] (binding-values-for-vars binding (slice query.find 0))]
        (when (and ok (values-equal? (slice binding-group 0) group-values))
          (when aggregate.has-limit-var
            (let [[limit-value limit-ok] (binding-lookup binding aggregate.limit-var)]
              (when (and limit-ok (= limit-value.kind .Int))
                (set! resolved-limit (int limit-value.int-value)))))
          (let [[key key-ok] (aggregate-key-values binding query aggregate)]
            (when (and key-ok (not (row-values-exist? (slice seen-keys 0) (slice key 0))))
              (arr.push! seen-keys (aggregate-key-row (slice key 0)))
              (let [[value has-value] (binding-lookup binding aggregate.var)]
                (when has-value
                  (if (= aggregate.op "count")
                    (set! current.int-value (+ current.int-value 1))
                    (if (or (= aggregate.op "count-distinct")
                            (= aggregate.op "distinct"))
                      (when (not (value-exists? (slice distinct-values 0) value))
                        (arr.push! distinct-values value))
                      (do
                        (when (and (numeric-aggregate-op? aggregate.op)
                                   (numeric-value? value))
                          (arr.push! aggregate-values value))
                        (when (aggregate-collects-limited-values? aggregate)
                          (arr.push! aggregate-values value))
                        (when (or (= aggregate.op "aggregate")
                                  (custom-aggregate-op? aggregate))
                          (arr.push! aggregate-values value)
                          (when (not custom-name-ok)
                            (if (custom-aggregate-op? aggregate)
                              (do
                                (set! custom-name aggregate.op)
                                (set! custom-name-ok true))
                              (let [[name name-ok] (aggregate-function-name binding aggregate)]
                                (when name-ok
                                  (set! custom-name name)
                                  (set! custom-name-ok true))))))
                        (when (and (= aggregate.op "avg")
                                   (or (= value.kind .Int)
                                       (= value.kind .Float)))
                          (set! avg-count (+ avg-count 1)))
                        (set! current (apply-aggregate-value current aggregate value))))))))))))
    (when (= aggregate.op "count-distinct")
      (return (value-int (i64 (count distinct-values)))))
    (when (= aggregate.op "distinct")
      (return (distinct-values-vector-owned (slice distinct-values 0))))
    (when (and (or aggregate.has-limit aggregate.has-limit-var)
               (or (= aggregate.op "min")
                   (= aggregate.op "max")))
      (return (top-n-values (slice aggregate-values 0) resolved-limit (= aggregate.op "max"))))
    (when (and (= aggregate.op "rand") (not (or aggregate.has-limit aggregate.has-limit-var)))
      (return (random-value-owned (slice aggregate-values 0))))
    (when (limited-selection-aggregate-op? aggregate.op)
      (return (selection-values-owned (slice aggregate-values 0) resolved-limit aggregate.op)))
    (when (and (= aggregate.op "avg") (> avg-count 0))
      (if (= current.kind .Float)
        (return (value-float (/ current.float-value (f64 avg-count))))
        (if (= (% current.int-value avg-count) 0)
          (return (value-int (/ current.int-value avg-count)))
          (return (value-float (/ (f64 current.int-value) (f64 avg-count)))))))
    (when (= aggregate.op "median")
      (return (median-numeric (slice aggregate-values 0))))
    (when (= aggregate.op "variance")
      (return (variance-numeric (slice aggregate-values 0))))
    (when (= aggregate.op "stddev")
      (return (stddev-numeric (slice aggregate-values 0))))
    (when (or (= aggregate.op "aggregate")
              (custom-aggregate-op? aggregate))
      (let [[value ok] (apply-named-aggregate-with-fns custom-name (slice aggregate-values 0) registry)]
        (when ok
          (return value))))
    current))

(defn aggregate-value-for-group [bindings: []Binding, query: Query, aggregate: Aggregate-Find, group-values: []Value] -> Value
  (aggregate-value-for-group-with-fns bindings query aggregate group-values ([]Native-Query-Fn [])))

(defn query-relation-typed-row-values-for-vars [rel: Query-Relation, row: int, names: []string] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value 0 (count names))]
    (for [name names]
      (let [[value value-ok] (query-relation-typed-row-value rel row name)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn query-relation-typed-row-resolve-term [rel: Query-Relation, row: int, term: Term] -> [value: Value, ok: bool]
  (case term.kind
    .Value (return term.value true)
    .Var (return (query-relation-typed-row-value rel row term.name))
     (return (Value {}) false)))

(defn query-relation-typed-aggregate-function-name [rel: Query-Relation, row: int, aggregate: Aggregate-Find] -> [name: string, ok: bool]
  (when (not aggregate.has-function-var)
    (return "" false))
  (let [[value value-ok] (query-relation-typed-row-value rel row aggregate.function-var)]
    (when (not value-ok)
      (return "" false))
    (when (or (= value.kind .Keyword)
              (= value.kind .String))
      (return value.text true)))
  (return "" false))

(defn aggregate-supported-from-typed-relation-with-fns? [aggregate: Aggregate-Find, registry: []Native-Query-Fn] -> bool
  (when aggregate.has-limit-var
    (return false))
  (when (= aggregate.op "aggregate")
    (return aggregate.has-function-var))
  (when (custom-aggregate-op? aggregate)
    (let [[index found] (query-fn-index registry aggregate.op)]
      (return (and found registry[index].has-aggregate-callback))))
  (not aggregate.has-function-var))

(defn aggregate-supported-from-typed-relation? [aggregate: Aggregate-Find] -> bool
  (aggregate-supported-from-typed-relation-with-fns? aggregate ([]Native-Query-Fn [])))

(defn query-relation-typed-aggregate-key-values [rel: Query-Relation, row: int, query: Query, aggregate: Aggregate-Find] -> [values: [dynamic]Value, ok: bool]
  (let [out (make [dynamic]Value)]
    (for [name query.find]
      (let [[value value-ok] (query-relation-typed-row-value rel row name)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (for [name query.with]
      (let [[value value-ok] (query-relation-typed-row-value rel row name)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (if (> (count aggregate.args) 0)
      (for [arg aggregate.args]
        (let [[value value-ok] (query-relation-typed-row-resolve-term rel row arg)]
          (if value-ok
            (arr.push! out value)
            (return out false))))
      (let [[value value-ok] (query-relation-typed-row-value rel row aggregate.var)]
        (if value-ok
          (arr.push! out value)
          (return out false))))
    (return out true)))

(defn aggregate-value-for-typed-group-with-fns [rel: Query-Relation, query: Query, aggregate: Aggregate-Find, group-values: []Value, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (when (not (and rel.has-typed-columns
                  (aggregate-supported-from-typed-relation-with-fns? aggregate registry)))
    (return (Value {}) false))
  (let [current (aggregate-initial-value aggregate)
        avg-count: i64 0
        aggregate-values (make [dynamic]Value)
        distinct-values (make [dynamic]Value)
        seen-keys (make [dynamic]Result-Row)
        custom-name ""
        custom-name-ok false
        row 0]
    (defer (delete aggregate-values))
    (defer (delete distinct-values))
    (defer (delete seen-keys))
    (while (< row rel.typed-rows)
      (let [[row-group group-ok] (query-relation-typed-row-values-for-vars rel row (slice query.find 0))]
        (when (and group-ok (values-equal? (slice row-group 0) group-values))
          (let [[key key-ok] (query-relation-typed-aggregate-key-values rel row query aggregate)]
            (when (and key-ok (not (row-values-exist? (slice seen-keys 0) (slice key 0))))
              (arr.push! seen-keys (aggregate-key-row (slice key 0)))
              (let [[input-value input-ok] (query-relation-typed-row-value rel row aggregate.var)]
                (when input-ok
                  (if (= aggregate.op "count")
                    (set! current.int-value (+ current.int-value 1))
                    (if (or (= aggregate.op "count-distinct")
                            (= aggregate.op "distinct"))
                      (when (not (value-exists? (slice distinct-values 0) input-value))
                        (arr.push! distinct-values input-value))
                      (do
                        (when (and (numeric-aggregate-op? aggregate.op)
                                   (numeric-value? input-value))
                          (arr.push! aggregate-values input-value))
                        (when (aggregate-collects-limited-values? aggregate)
                          (arr.push! aggregate-values input-value))
                        (when (or (= aggregate.op "aggregate")
                                  (custom-aggregate-op? aggregate))
                          (arr.push! aggregate-values input-value)
                          (when (not custom-name-ok)
                            (if (custom-aggregate-op? aggregate)
                              (do
                                (set! custom-name aggregate.op)
                                (set! custom-name-ok true))
                              (let [[name name-ok] (query-relation-typed-aggregate-function-name rel row aggregate)]
                                (when name-ok
                                  (set! custom-name name)
                                  (set! custom-name-ok true))))))
                        (when (and (= aggregate.op "avg")
                                   (or (= input-value.kind .Int)
                                       (= input-value.kind .Float)))
                          (set! avg-count (+ avg-count 1)))
                        (set! current (apply-aggregate-value current aggregate input-value))))))))
            (delete key)))
        (delete row-group))
      (set! row (+ row 1)))
    (when (= aggregate.op "count-distinct")
      (return (value-int (i64 (count distinct-values))) true))
    (when (= aggregate.op "distinct")
      (return (distinct-values-vector-owned (slice distinct-values 0)) true))
    (when (and aggregate.has-limit
               (or (= aggregate.op "min")
                   (= aggregate.op "max")))
      (return (top-n-values (slice aggregate-values 0) aggregate.limit (= aggregate.op "max")) true))
    (when (and (= aggregate.op "rand") (not aggregate.has-limit))
      (return (random-value-owned (slice aggregate-values 0)) true))
    (when (limited-selection-aggregate-op? aggregate.op)
      (return (selection-values-owned (slice aggregate-values 0) aggregate.limit aggregate.op) true))
    (when (and (= aggregate.op "avg") (> avg-count 0))
      (if (= current.kind .Float)
        (return (value-float (/ current.float-value (f64 avg-count))) true)
        (if (= (% current.int-value avg-count) 0)
          (return (value-int (/ current.int-value avg-count)) true)
          (return (value-float (/ (f64 current.int-value) (f64 avg-count))) true))))
    (when (= aggregate.op "median")
      (return (median-numeric (slice aggregate-values 0)) true))
    (when (= aggregate.op "variance")
      (return (variance-numeric (slice aggregate-values 0)) true))
    (when (= aggregate.op "stddev")
      (return (stddev-numeric (slice aggregate-values 0)) true))
    (when (or (= aggregate.op "aggregate")
              (custom-aggregate-op? aggregate))
      (let [[value value-ok] (apply-named-aggregate-with-fns custom-name (slice aggregate-values 0) registry)]
        (return value value-ok)))
    (return current true)))

(defn aggregate-value-for-typed-group [rel: Query-Relation, query: Query, aggregate: Aggregate-Find, group-values: []Value] -> [value: Value, ok: bool]
  (aggregate-value-for-typed-group-with-fns rel query aggregate group-values ([]Native-Query-Fn [])))

(defn aggregate-output-attrs [query: Query] -> [dynamic]string
  (let [out (arr.into [dynamic]string (slice query.find 0))]
    (for [_ index query.aggregates]
      (arr.push! out (fmt.tprintf "$aggregate%d" index)))
    out))

(defn aggregate-supported-for-typed-output-relation? [aggregate: Aggregate-Find] -> bool
  (and (not (= aggregate.op "aggregate"))
       (not aggregate.has-limit)
       (not aggregate.has-limit-var)
       (not aggregate.has-function-var)))

(defn query-relation-output-group-exists? [columns: []Relation-Column, rows: int, group-width: int, group-values: []Value] -> bool
  (when (not (= group-width (count group-values)))
    (return false))
  (let [row 0]
    (while (< row rows)
      (let [matches true
            index 0]
        (while (and matches (< index group-width))
          (let [[value value-ok] (typed-relation-column-value columns[index] row)]
            (if (and value-ok (value-equal? value group-values[index]))
              (set! index (+ index 1))
              (set! matches false))))
        (when matches
          (return true)))
      (set! row (+ row 1))))
  false)

(defn result-row-value-prefix-exists? [rows: []Result-Row, values: []Value] -> bool
  (for [row rows]
    (when (and (>= (count row.values) (count values))
               (values-equal? (slice row.values 0 (count values)) values))
      (return true)))
  false)

(defn aggregate-group-already-seen? [seen: (ptr (map string (struct {}))), values: []Value] -> [already: bool, keyable: bool]
  (let [[key key-ok] (row-values-dedupe-key values)]
    (when (not key-ok)
      (return false false))
    (when (set.contains? seen^ key)
      (return true true))
    (set.add! seen^ key)
    (return false true)))

(defstruct Typed-Aggregate-Accumulator {
  current: Value
  avg-count: i64
  aggregate-values: [dynamic]Value
  distinct-values: [dynamic]Value
  seen-keys: (map string (struct {}))
  seen-rows: [dynamic]Result-Row
  custom-name: string
  custom-name-ok: bool
})

(defn typed-aggregate-accumulator [aggregate: Aggregate-Find] -> Typed-Aggregate-Accumulator
  (Typed-Aggregate-Accumulator {current: (aggregate-initial-value aggregate)
                                avg-count: 0
                                aggregate-values: (make [dynamic]Value)
                                distinct-values: (make [dynamic]Value)
                                seen-keys: (set.empty string)
                                seen-rows: (make [dynamic]Result-Row)
                                custom-name: ""
                                custom-name-ok: false}))

(defn delete-typed-aggregate-accumulator [state: Typed-Aggregate-Accumulator]
  (delete state.aggregate-values)
  (delete state.distinct-values)
  (delete-owned-string-set state.seen-keys)
  (delete-result-rows-owned-values state.seen-rows))

(defn delete-typed-aggregate-accumulators [states: [dynamic]Typed-Aggregate-Accumulator]
  (for [state states]
    (delete-typed-aggregate-accumulator state))
  (delete states))

(defn typed-aggregate-key-seen-or-add! [state: ^Typed-Aggregate-Accumulator, values: []Value] -> bool
  (let [[key key-ok] (row-values-dedupe-key values)]
    (if key-ok
      (if (set.contains? state^.seen-keys key)
        (do
          (delete key)
          true)
        (do
          (set.add! state^.seen-keys key)
          false))
      (if (row-values-exist? (slice state^.seen-rows 0) values)
        true
        (do
          (arr.push! state^.seen-rows (aggregate-owned-key-row values))
          false)))))

(defn typed-aggregate-accumulate-value! [state: ^Typed-Aggregate-Accumulator, aggregate: Aggregate-Find, input-value: Value]
  (if (= aggregate.op "count")
    (set! state^.current.int-value (+ state^.current.int-value 1))
    (if (or (= aggregate.op "count-distinct")
            (= aggregate.op "distinct"))
      (when (not (value-exists? (slice state^.distinct-values 0) input-value))
        (arr.push! state^.distinct-values input-value))
      (do
        (when (and (numeric-aggregate-op? aggregate.op)
                   (numeric-value? input-value))
          (arr.push! state^.aggregate-values input-value))
        (when (aggregate-collects-limited-values? aggregate)
          (arr.push! state^.aggregate-values input-value))
        (when (or (= aggregate.op "aggregate")
                  (custom-aggregate-op? aggregate))
          (arr.push! state^.aggregate-values input-value))
        (when (and (= aggregate.op "avg")
                   (or (= input-value.kind .Int)
                       (= input-value.kind .Float)))
          (set! state^.avg-count (+ state^.avg-count 1)))
        (set! state^.current (apply-aggregate-value state^.current aggregate input-value))))))

(defn typed-aggregate-accumulator-value [state: Typed-Aggregate-Accumulator, aggregate: Aggregate-Find, registry: []Native-Query-Fn] -> [value: Value, ok: bool]
  (when (= aggregate.op "count-distinct")
    (return (value-int (i64 (count state.distinct-values))) true))
  (when (= aggregate.op "distinct")
    (return (distinct-values-vector-owned (slice state.distinct-values 0)) true))
  (when (and aggregate.has-limit
             (or (= aggregate.op "min")
                 (= aggregate.op "max")))
    (return (top-n-values (slice state.aggregate-values 0) aggregate.limit (= aggregate.op "max")) true))
  (when (and (= aggregate.op "rand") (not aggregate.has-limit))
    (return (random-value-owned (slice state.aggregate-values 0)) true))
  (when (limited-selection-aggregate-op? aggregate.op)
    (return (selection-values-owned (slice state.aggregate-values 0) aggregate.limit aggregate.op) true))
  (when (and (= aggregate.op "avg") (> state.avg-count 0))
    (if (= state.current.kind .Float)
      (return (value-float (/ state.current.float-value (f64 state.avg-count))) true)
      (if (= (% state.current.int-value state.avg-count) 0)
        (return (value-int (/ state.current.int-value state.avg-count)) true)
        (return (value-float (/ (f64 state.current.int-value) (f64 state.avg-count))) true))))
  (when (= aggregate.op "median")
    (return (median-numeric (slice state.aggregate-values 0)) true))
  (when (= aggregate.op "variance")
    (return (variance-numeric (slice state.aggregate-values 0)) true))
  (when (= aggregate.op "stddev")
    (return (stddev-numeric (slice state.aggregate-values 0)) true))
  (when (or (= aggregate.op "aggregate")
            (custom-aggregate-op? aggregate))
    (when state.custom-name-ok
      (let [[value value-ok] (apply-named-aggregate-with-fns state.custom-name (slice state.aggregate-values 0) registry)]
        (return value value-ok)))
    (return (Value {}) false))
  (return state.current true))

(defn typed-aggregate-group-index [groups: []Result-Row, group-index: ^map[string]int, values: []Value] -> [index: int, found: bool, keyable: bool]
  (let [[key key-ok] (row-values-dedupe-key values)]
    (when key-ok
      (let [[existing existing-ok] (mmap.get group-index^ key)]
        (return existing existing-ok true))))
  (let [[existing existing-ok] (result-row-values-index groups values)]
    (return existing existing-ok false)))

(defn append-typed-aggregate-group! [groups: ^[dynamic]Result-Row, group-index: ^map[string]int, states: ^[dynamic]Typed-Aggregate-Accumulator, query: Query, values: []Value] -> int
  (let [index (count groups^)
        [key key-ok] (row-values-dedupe-key values)]
    (when key-ok
      (mmap.assoc! group-index^ key index))
    (arr.push! groups^ (aggregate-owned-key-row values))
    (for [aggregate query.aggregates]
      (arr.push! states^ (typed-aggregate-accumulator aggregate)))
    index))

(defn reduce-typed-aggregate-row-for-vars! [rel: Query-Relation, query: Query, group-vars: []string, registry: []Native-Query-Fn, groups: ^[dynamic]Result-Row, group-index: ^map[string]int, states: ^[dynamic]Typed-Aggregate-Accumulator, row: int] -> bool
  (let [[group-values group-ok] (query-relation-typed-row-values-for-vars rel row group-vars)]
    (when (not group-ok)
      (delete group-values)
      (return false))
    (let [[existing-index existing-ok _] (typed-aggregate-group-index (slice groups^ 0) group-index (slice group-values 0))
          actual-index (if existing-ok existing-index (append-typed-aggregate-group! groups group-index states query (slice group-values 0)))]
      (delete group-values)
      (for [aggregate aggregate-index query.aggregates]
        (let [state-index (+ (* actual-index (count query.aggregates)) aggregate-index)
              [key key-ok] (query-relation-typed-aggregate-key-values rel row query aggregate)]
          (when (not key-ok)
            (delete key)
            (return false))
          (when (not (typed-aggregate-key-seen-or-add! (addr states^[state-index]) (slice key 0)))
            (when (not states^[state-index].custom-name-ok)
              (if (custom-aggregate-op? aggregate)
                (do
                  (set! states^[state-index].custom-name aggregate.op)
                  (set! states^[state-index].custom-name-ok true))
                (when (= aggregate.op "aggregate")
                  (let [[name name-ok] (query-relation-typed-aggregate-function-name rel row aggregate)]
                    (when name-ok
                      (set! states^[state-index].custom-name name)
                      (set! states^[state-index].custom-name-ok true))))))
            (let [[input-value input-ok] (query-relation-typed-row-value rel row aggregate.var)]
              (when input-ok
                (typed-aggregate-accumulate-value! (addr states^[state-index]) aggregate input-value))))
          (delete key))))
    true))

(defn reduce-typed-aggregate-row! [rel: Query-Relation, query: Query, registry: []Native-Query-Fn, groups: ^[dynamic]Result-Row, group-index: ^map[string]int, states: ^[dynamic]Typed-Aggregate-Accumulator, row: int] -> bool
  (reduce-typed-aggregate-row-for-vars! rel query (slice query.find 0) registry groups group-index states row))

(defn aggregate-query-relation-for-typed-relation-one-pass-with-fns [query: Query, rel: Query-Relation, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [attrs (aggregate-output-attrs query)
        attr-sources (make [dynamic]string 0 (count attrs))
        groups (make [dynamic]Result-Row)
        group-index (mmap.empty string int)
        states (make [dynamic]Typed-Aggregate-Accumulator)]
    (defer (delete group-index))
    (defer (delete-result-rows-owned-values groups))
    (defer (delete-typed-aggregate-accumulators states))
    (for [_ attrs]
      (arr.push! attr-sources ""))
    (let [row 0]
      (while (< row rel.typed-rows)
        (when (not (reduce-typed-aggregate-row! rel query registry (addr groups) (addr group-index) (addr states) row))
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false))
        (set! row (+ row 1))))
    (let [builder (query-relation-builder (slice attrs 0))]
      (for [group group-row groups]
        (let [values (arr.into [dynamic]Value (slice group.values 0))
              aggregate-ok true]
          (for [aggregate aggregate-index query.aggregates]
            (when aggregate-ok
              (let [state-index (+ (* group-row (count query.aggregates)) aggregate-index)
                    [aggregate-value one-ok] (typed-aggregate-accumulator-value states[state-index] aggregate registry)]
                (if one-ok
                  (arr.push! values aggregate-value)
                  (set! aggregate-ok false)))))
          (if (and aggregate-ok
                   (query-relation-builder-add-column-row-with-values! (addr builder) ([]Relation-Column []) 0 (slice values 0)))
            (delete values)
            (do
              (delete values)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false)))))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn aggregate-query-relation-for-typed-relation-with-fns [query: Query, rel: Query-Relation, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            (> (count query.pulls) 0)
            (= (count query.aggregates) 0))
    (return (query-relation-empty) false))
  (for [aggregate query.aggregates]
    (when (not (and (aggregate-supported-from-typed-relation-with-fns? aggregate registry)
                    (aggregate-supported-for-typed-output-relation? aggregate)))
      (return (query-relation-empty) false)))
  (when (or (> rel.typed-rows 0)
            (> (count query.find) 0))
    (return (aggregate-query-relation-for-typed-relation-one-pass-with-fns query rel registry)))
  (let [attrs (aggregate-output-attrs query)
        attr-sources (make [dynamic]string 0 (count attrs))]
    (for [_ attrs]
      (arr.push! attr-sources ""))
    (let [builder (query-relation-builder (slice attrs 0))
          seen-groups (set.empty string) :defer
          row 0]
      (when (and (= rel.typed-rows 0)
                 (= (count query.find) 0))
        (let [values (make [dynamic]Value 0 (count query.aggregates))]
          (for [aggregate query.aggregates]
            (let [[aggregate-value aggregate-ok] (aggregate-value-for-typed-group-with-fns rel query aggregate ([]Value []) registry)]
              (when (not aggregate-ok)
                (delete values)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (arr.push! values aggregate-value)))
          (when (not (query-relation-builder-add-column-row-with-values! (addr builder) ([]Relation-Column []) 0 (slice values 0)))
            (delete values)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (delete values)))
      (while (< row rel.typed-rows)
        (let [[group-values group-ok] (query-relation-typed-row-values-for-vars rel row (slice query.find 0))]
          (when group-ok
            (let [[already-seen keyable] (aggregate-group-already-seen? (addr seen-groups) (slice group-values 0))]
            (when (not (if keyable
                         already-seen
                         (query-relation-output-group-exists? (slice builder.typed-columns 0) builder.typed-rows (count query.find) (slice group-values 0))))
              (let [values (arr.into [dynamic]Value (slice group-values 0))
                    aggregate-ok true]
                (for [aggregate query.aggregates]
                  (when aggregate-ok
                    (let [[aggregate-value one-ok] (aggregate-value-for-typed-group-with-fns rel query aggregate (slice group-values 0) registry)]
                      (if one-ok
                        (arr.push! values aggregate-value)
                        (set! aggregate-ok false)))))
                (if (and aggregate-ok
                         (query-relation-builder-add-column-row-with-values! (addr builder) ([]Relation-Column []) 0 (slice values 0)))
                  (delete values)
                  (do
                    (delete values)
                    (delete group-values)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))))))
          (delete group-values))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn aggregate-query-relation-for-typed-relation [query: Query, rel: Query-Relation] -> [out: Query-Relation, ok: bool]
  (aggregate-query-relation-for-typed-relation-with-fns query rel ([]Native-Query-Fn [])))

(defn aggregate-rows-for-typed-relation-one-pass-with-fns [query: Query, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (aggregate-rows-for-typed-relation-one-pass-with-group-vars-and-fns query rel (slice query.find 0) registry))

(defn aggregate-rows-for-typed-relation-one-pass-with-group-vars-and-fns [query: Query, rel: Query-Relation, group-vars: []string, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (let [out (make [dynamic]Result-Row)
        groups (make [dynamic]Result-Row)
        group-index (mmap.empty string int)
        states (make [dynamic]Typed-Aggregate-Accumulator)]
    (defer (delete group-index))
    (defer (delete-result-rows-owned-values groups))
    (defer (delete-typed-aggregate-accumulators states))
    (let [row 0]
      (while (< row rel.typed-rows)
        (when (not (reduce-typed-aggregate-row-for-vars! rel query group-vars registry (addr groups) (addr group-index) (addr states) row))
          (return out false))
        (set! row (+ row 1))))
    (for [group group-row groups]
      (let [values (arr.into [dynamic]Value (slice group.values 0))
            aggregate-ok true]
        (for [aggregate aggregate-index query.aggregates]
          (when aggregate-ok
            (let [state-index (+ (* group-row (count query.aggregates)) aggregate-index)
                  [aggregate-value one-ok] (typed-aggregate-accumulator-value states[state-index] aggregate registry)]
              (if one-ok
                (arr.push! values aggregate-value)
                (set! aggregate-ok false)))))
        (if aggregate-ok
          (arr.push! out (Result-Row {values: values pulls: (make [dynamic]Pull-Result)}))
          (do
            (delete values)
            (return out false)))))
    (return out true)))

(defn aggregate-rows-for-typed-relation-with-fns [query: Query, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (when (not rel.has-typed-columns)
    (return (make [dynamic]Result-Row) false))
  (for [aggregate query.aggregates]
    (when (not (aggregate-supported-from-typed-relation-with-fns? aggregate registry))
      (return (make [dynamic]Result-Row) false)))
  (when (or (> rel.typed-rows 0)
            (> (count query.find) 0))
    (return (aggregate-rows-for-typed-relation-one-pass-with-fns query rel registry)))
  (let [out (make [dynamic]Result-Row)
        seen-groups (set.empty string) :defer
        row 0]
    (when (and (= rel.typed-rows 0)
               (= (count query.find) 0))
      (let [values (make [dynamic]Value 0 (count query.aggregates))]
        (for [aggregate query.aggregates]
          (let [[aggregate-value aggregate-ok] (aggregate-value-for-typed-group-with-fns rel query aggregate ([]Value []) registry)]
            (when (not aggregate-ok)
              (delete values)
              (return out false))
            (arr.push! values aggregate-value)))
        (arr.push! out (Result-Row {values: values pulls: (make [dynamic]Pull-Result)}))))
    (while (< row rel.typed-rows)
      (let [[group-values group-ok] (query-relation-typed-row-values-for-vars rel row (slice query.find 0))]
        (when group-ok
          (let [[already-seen keyable] (aggregate-group-already-seen? (addr seen-groups) (slice group-values 0))]
          (when (not (if keyable
                       already-seen
                       (result-row-value-prefix-exists? (slice out 0) (slice group-values 0))))
            (let [values (arr.into [dynamic]Value (slice group-values 0))
                  aggregate-ok true]
              (for [aggregate query.aggregates]
                (when aggregate-ok
                  (let [[aggregate-value one-ok] (aggregate-value-for-typed-group-with-fns rel query aggregate (slice group-values 0) registry)]
                    (if one-ok
                      (arr.push! values aggregate-value)
                      (set! aggregate-ok false)))))
              (if aggregate-ok
                (arr.push! out (Result-Row {values: values pulls: (make [dynamic]Pull-Result)}))
                (do
                  (delete values)
                  (delete group-values)
                  (return out false)))))))
        (delete group-values))
      (set! row (+ row 1)))
    (return out true)))

(defn aggregate-rows-for-typed-relation [query: Query, rel: Query-Relation] -> [rows: [dynamic]Result-Row, ok: bool]
  (aggregate-rows-for-typed-relation-with-fns query rel ([]Native-Query-Fn [])))

(defn aggregate-row-column-needs-value-column? [rows: []Result-Row, column: int] -> bool
  (for [row rows]
    (when (or (>= column (count row.values))
              (> (count row.pulls) 0)
              (not (materialized-value-can-stay-primitive? row.values[column])))
      (return true)))
  false)

(defn materialize-typed-aggregate-value-batch-with-fns [query: Query, rel: Query-Relation, registry: []Native-Query-Fn] -> Typed-Materialized-Batch
  (when (= (count query.aggregates) 0)
    (return (typed-materialized-batch-empty)))
  (let [[rows rows-ok] (aggregate-rows-for-typed-relation-with-fns query rel registry)]
    (when (not rows-ok)
      (delete-result-rows-owned-values rows)
      (return (typed-materialized-batch-empty)))
    (when (= (count rows) 0)
      (delete-result-rows-owned-values rows)
      (return (typed-materialized-batch-empty)))
    (let [width (count rows[0].values)
          row-count (count rows)
          names (aggregate-output-attrs query)
          sources (make [dynamic]string 0 width)
          columns (make [dynamic]Relation-Column 0 width)
          value-columns (make [dynamic]bool 0 width)]
      (when (not (= (count names) width))
        (delete names)
        (delete sources)
        (delete value-columns)
        (delete-relation-columns columns)
        (delete-result-rows-owned-values rows)
        (return (typed-materialized-batch-empty)))
      (for [column (arr.range 0 width)]
        (arr.push! sources "")
        (arr.push! columns (relation-column-empty))
        (arr.push! value-columns (aggregate-row-column-needs-value-column? (slice rows 0) column)))
      (for [row rows]
        (when (or (not (= (count row.values) width))
                  (> (count row.pulls) 0))
          (delete names)
          (delete sources)
          (delete value-columns)
          (delete-relation-columns columns)
          (delete-result-rows-owned-values rows)
          (return (typed-materialized-batch-empty)))
        (for [value column row.values]
          (when (not (typed-materialized-batch-append-borrowed-value! (addr columns) (slice value-columns 0) column value))
            (delete names)
            (delete sources)
            (delete value-columns)
            (delete-relation-columns columns)
            (delete-result-rows-owned-values rows)
            (return (typed-materialized-batch-empty)))))
      (let [batch (Typed-Materialized-Batch {ok: true
                                             names: names
                                             sources: sources
                                             columns: columns
                                             value-columns: value-columns
                                             rows: row-count
                                             owns-values: true})]
        (delete-result-rows-owned-values rows)
        (return batch)))
    (typed-materialized-batch-empty)))

(defn materialize-typed-aggregate-value-batch [query: Query, rel: Query-Relation] -> Typed-Materialized-Batch
  (materialize-typed-aggregate-value-batch-with-fns query rel ([]Native-Query-Fn [])))

(defn pull-aggregate-group-vars [query: Query] -> [dynamic]string
  (let [vars (arr.into [dynamic]string (slice query.find 0))]
    (for [pull-find query.pulls]
      (append-var-once! (addr vars) pull-find.var))
    vars))

(defn aggregate-row-value-for-var-in-vars [group-vars: []string, row: Result-Row, name: string] -> [value: Value, ok: bool]
  (for [find-name index group-vars]
    (when (= find-name name)
      (when (< index (count row.values))
        (return row.values[index] true))
      (return (Value {}) false)))
  (return (Value {}) false))

(defn aggregate-row-value-for-var [query: Query, row: Result-Row, name: string] -> [value: Value, ok: bool]
  (aggregate-row-value-for-var-in-vars (slice query.find 0) row name))

(defn pull-aggregate-column-needs-value-column? [query: Query, group-vars: []string, rows: []Result-Row, column: Physical-Result-Column] -> bool
  (case column.kind
    .PullResultColumn true
    .ValueResultColumn
      (do
        (for [row rows]
          (when (or (>= column.source-index (count row.values))
                    (not (materialized-value-can-stay-primitive? row.values[column.source-index])))
            (return true)))
        false)
    .AggregateResultColumn
      (do
        (let [aggregate-index (+ (count group-vars) column.source-index)]
          (for [row rows]
            (when (or (>= aggregate-index (count row.values))
                      (not (materialized-value-can-stay-primitive? row.values[aggregate-index])))
              (return true))))
        false)
    .WithDedupeColumn false
    true))

(defn pull-aggregate-row-scalar-result-column-value [group-vars: []string, row: Result-Row, column: Physical-Result-Column] -> [value: Value, ok: bool]
  (case column.kind
    .ValueResultColumn
      (do
        (when (or (< column.source-index 0)
                  (>= column.source-index (count row.values)))
          (return (Value {}) false))
        (return row.values[column.source-index] true))
    .AggregateResultColumn
      (do
        (let [aggregate-index (+ (count group-vars) column.source-index)]
          (when (or (< aggregate-index 0)
                    (>= aggregate-index (count row.values)))
            (return (Value {}) false))
          (return row.values[aggregate-index] true)))
    (return (Value {}) false)))

(defn materialize-source-typed-pull-aggregate-batch [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [batch: Typed-Materialized-Batch, ok: bool, error: string]
  (when (or (not rel.has-typed-columns)
            (= (count query-value.pulls) 0)
            (= (count query-value.aggregates) 0))
    (return (typed-materialized-batch-empty) false "typed pull+aggregate materialization expects typed relation with pulls and aggregates"))
  (let [materialization (physical-materialization-plan-from-query query-value)
        group-vars (pull-aggregate-group-vars query-value) :defer
        [pull-columns pull-columns-ok pull-columns-error] (materialized-pull-columns-for-query source sources query-value inputs)
        [rows rows-ok] (aggregate-rows-for-typed-relation-one-pass-with-group-vars-and-fns query-value rel (slice group-vars 0) registry)]
    (defer (delete-physical-materialization-plan materialization))
    (when (not pull-columns-ok)
      (delete-result-rows-owned-values rows)
      (delete pull-columns)
      (return (typed-materialized-batch-empty) false pull-columns-error))
    (defer (delete pull-columns))
    (when (not rows-ok)
      (delete-result-rows-owned-values rows)
      (return (typed-materialized-batch-empty) false "aggregate rows could not be materialized"))
    (when (= (count rows) 0)
      (delete-result-rows-owned-values rows)
      (return (typed-materialized-batch-empty) false "aggregate rows were empty"))
    (let [column-count (count materialization.columns)
          names (make [dynamic]string 0 column-count)
          sources-out (make [dynamic]string 0 column-count)
          columns (make [dynamic]Relation-Column 0 column-count)
          value-columns (make [dynamic]bool 0 column-count)]
      (for [column materialization.columns]
        (case column.kind
          .ValueResultColumn
            (typed-materialized-batch-add-output-column! (addr names) (addr sources-out) (addr columns) (addr value-columns) column.var-name "" (pull-aggregate-column-needs-value-column? query-value (slice group-vars 0) (slice rows 0) column))
          .PullResultColumn
            (do
              (when (or (< column.source-index 0)
                        (>= column.source-index (count pull-columns)))
                (delete names)
                (delete sources-out)
                (delete value-columns)
                (delete-relation-columns columns)
                (delete-result-rows-owned-values rows)
                (return (typed-materialized-batch-empty) false "pull result column source index was out of range"))
              (let [pull-column pull-columns[column.source-index]]
                (typed-materialized-batch-add-output-column! (addr names) (addr sources-out) (addr columns) (addr value-columns) (fmt.tprintf "(pull %s)" column.var-name) pull-column.pull-find.source true)))
          .AggregateResultColumn
            (typed-materialized-batch-add-output-column! (addr names) (addr sources-out) (addr columns) (addr value-columns) (fmt.tprintf "$aggregate%d" column.source-index) "" (pull-aggregate-column-needs-value-column? query-value (slice group-vars 0) (slice rows 0) column))
          .WithDedupeColumn
            (do)
          (do)))
      (for [row rows]
        (when (not (= (count row.values) (+ (count group-vars) (count query-value.aggregates))))
          (delete names)
          (delete sources-out)
          (delete value-columns)
          (delete-relation-columns columns)
          (delete-result-rows-owned-values rows)
          (return (typed-materialized-batch-empty) false "aggregate row width did not match query output"))
        (for [column materialization.columns]
          (when (not (= column.kind .WithDedupeColumn))
            (let [output-column column.output-index]
              (when (or (< output-column 0)
                        (>= output-column (count columns)))
                (delete names)
                (delete sources-out)
                (delete value-columns)
                (delete-relation-columns columns)
                (delete-result-rows-owned-values rows)
                (return (typed-materialized-batch-empty) false "result column output index was out of range"))
              (case column.kind
                .ValueResultColumn
                  (let [[value value-ok] (pull-aggregate-row-scalar-result-column-value (slice group-vars 0) row column)]
                    (when (or (not value-ok)
                              (not (typed-materialized-batch-append-borrowed-value! (addr columns) (slice value-columns 0) output-column value)))
                      (delete names)
                      (delete sources-out)
                      (delete value-columns)
                      (delete-relation-columns columns)
                      (delete-result-rows-owned-values rows)
                      (return (typed-materialized-batch-empty) false "scalar result column could not accept value")))
                .AggregateResultColumn
                  (let [[value value-ok] (pull-aggregate-row-scalar-result-column-value (slice group-vars 0) row column)]
                    (when (or (not value-ok)
                              (not (typed-materialized-batch-append-borrowed-value! (addr columns) (slice value-columns 0) output-column value)))
                      (delete names)
                      (delete sources-out)
                      (delete value-columns)
                      (delete-relation-columns columns)
                      (delete-result-rows-owned-values rows)
                      (return (typed-materialized-batch-empty) false "scalar result column could not accept value")))
                .PullResultColumn
                  (do
                    (when (or (< column.source-index 0)
                              (>= column.source-index (count pull-columns)))
                      (delete names)
                      (delete sources-out)
                      (delete value-columns)
                      (delete-relation-columns columns)
                      (delete-result-rows-owned-values rows)
                      (return (typed-materialized-batch-empty) false "pull result column source index was out of range"))
                    (let [pull-column pull-columns[column.source-index]
                          [entity-value entity-value-ok] (aggregate-row-value-for-var-in-vars (slice group-vars 0) row pull-column.pull-find.var)]
                      (when (not entity-value-ok)
                        (delete names)
                        (delete sources-out)
                        (delete value-columns)
                        (delete-relation-columns columns)
                        (delete-result-rows-owned-values rows)
                        (return (typed-materialized-batch-empty) false "pull entity var must be a grouped value for pull+aggregate materialization"))
                      (let [[entity entity-ok] (db-read-source-pull-entity entity-value)]
                        (when (not entity-ok)
                          (delete names)
                          (delete sources-out)
                          (delete value-columns)
                          (delete-relation-columns columns)
                          (delete-result-rows-owned-values rows)
                          (return (typed-materialized-batch-empty) false "pull entity value must be an entity id"))
                        (let [[pull pull-ok pull-error] (db-read-source-pull-result-for-pattern-with-fns pull-column.source entity pull-column.pattern registry)]
                          (when (not pull-ok)
                            (delete-pull-result-owned-values pull)
                            (delete names)
                            (delete sources-out)
                            (delete value-columns)
                            (delete-relation-columns columns)
                            (delete-result-rows-owned-values rows)
                            (return (typed-materialized-batch-empty) false pull-error))
                          (let [[rendered rendered-ok rendered-error] (db-read-source-pull-result-value pull-column.source pull)]
                            (delete-pull-result-owned-values pull)
                            (when (not rendered-ok)
                              (delete-owned-value rendered)
                              (delete names)
                              (delete sources-out)
                              (delete value-columns)
                              (delete-relation-columns columns)
                              (delete-result-rows-owned-values rows)
                              (return (typed-materialized-batch-empty) false rendered-error))
                            (when (not (typed-materialized-batch-append-owned-value! (addr columns) (slice value-columns 0) output-column rendered))
                              (delete names)
                              (delete sources-out)
                              (delete value-columns)
                              (delete-relation-columns columns)
                              (delete-result-rows-owned-values rows)
                              (return (typed-materialized-batch-empty) false "pull result column could not accept value")))))))
                .WithDedupeColumn
                  (do)
                (do))))))
      (let [batch (Typed-Materialized-Batch {ok: true
                                             names: names
                                             sources: sources-out
                                             columns: columns
                                             value-columns: value-columns
                                             rows: (count rows)
                                             owns-values: true})]
        (delete-result-rows-owned-values rows)
        (return batch true ""))))
  (return (typed-materialized-batch-empty) false "typed pull+aggregate materialization did not produce a batch"))

(defn pull-pattern-input [query: Query, inputs: []Query-Input, name: string] -> [pattern: []Pull-Spec, ok: bool]
  (for [input-name index query.inputs]
    (when (= input-name name)
      (when (and (< index (count inputs))
                 (= inputs[index].kind .PullPattern))
        (return (slice inputs[index].pattern 0) true))
      (return ([]Pull-Spec []) false)))
  (return ([]Pull-Spec []) false))

(defn pull-find-pattern [query: Query, inputs: []Query-Input, pull-find: Pull-Find] -> [pattern: []Pull-Spec, ok: bool]
  (if pull-find.has-pattern-var
    (pull-pattern-input query inputs pull-find.pattern-var)
    (return (slice pull-find.pattern 0) true)))

(defn pull-db-for-find [db: DB, sources: []DB-Source, pull-find: Pull-Find] -> [pull-db: DB, ok: bool]
  (if pull-find.has-source
    (source-db-lookup db sources pull-find.source)
    (return db true)))

(defn pull-entity-from-value [db: DB, value: Value] -> [entity: u64, ok: bool]
  (cond
    (= value.kind .Entity) (return value.entity true)
    (= value.kind .Int) (return (u64 value.int-value) true)
    (= value.kind .Keyword)
      (schema-entity-for-attr db value.text)
    (and (= value.kind .Vector)
         (= (count value.items) 2)
         (= value.items[0].kind .Keyword))
      (resolve-lookup-ref db value.items[0].text value.items[1])
    :else (return 0 false)))

(defn pulls-for-binding-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, binding: Binding, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (let [out (make [dynamic]Pull-Result 0 (count query.pulls))]
    (for [pull-find query.pulls]
      (let [[entity-value ok] (binding-lookup binding pull-find.var)]
        (if ok
          (let [[pattern pattern-ok] (pull-find-pattern query inputs pull-find)
                [pull-db pull-db-ok] (pull-db-for-find db sources pull-find)
                entity: u64 0
                entity-ok false]
            (when pull-db-ok
              (let [[resolved resolved-ok] (pull-entity-from-value pull-db entity-value)]
                (set! entity resolved)
                (set! entity-ok resolved-ok)))
            (if (and pattern-ok pull-db-ok)
              (if entity-ok
                (arr.push! out (pull-pattern-spec-with-fns pull-db entity pattern registry))
                (return out false))
              (return out false)))
          (return out false))))
    (return out true)))

(defn pulls-for-binding-with-sources [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (pulls-for-binding-with-sources-and-fns db sources query inputs binding ([]Native-Query-Fn [])))

(defn pulls-for-binding [db: DB, query: Query, inputs: []Query-Input, binding: Binding] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (pulls-for-binding-with-sources db ([]DB-Source []) query inputs binding))

(defn pulls-for-aggregate-row-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, group-vars: []string, row: Result-Row, registry: []Native-Query-Fn] -> [pulls: [dynamic]Pull-Result, ok: bool]
  (let [out (make [dynamic]Pull-Result 0 (count query.pulls))]
    (for [pull-find query.pulls]
      (let [[entity-value entity-value-ok] (aggregate-row-value-for-var-in-vars group-vars row pull-find.var)
            [pattern pattern-ok] (pull-find-pattern query inputs pull-find)
            [pull-db pull-db-ok] (pull-db-for-find db sources pull-find)]
        (when (not (and entity-value-ok pattern-ok pull-db-ok))
          (for [pull out]
            (delete-pull-result-shallow pull))
          (delete out)
          (return (make [dynamic]Pull-Result) false))
        (let [[entity entity-ok] (pull-entity-from-value pull-db entity-value)]
          (when (not entity-ok)
            (for [pull out]
              (delete-pull-result-shallow pull))
            (delete out)
            (return (make [dynamic]Pull-Result) false))
          (arr.push! out (pull-pattern-spec-with-fns pull-db entity pattern registry)))))
    (return out true)))

(defn pull-aggregate-result-rows-for-typed-relation-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (when (or (not rel.has-typed-columns)
            (= (count query.pulls) 0)
            (= (count query.aggregates) 0))
    (return (make [dynamic]Result-Row) false))
  (let [group-vars (pull-aggregate-group-vars query) :defer
        [aggregate-rows aggregate-rows-ok] (aggregate-rows-for-typed-relation-one-pass-with-group-vars-and-fns query rel (slice group-vars 0) registry)]
    (when (not aggregate-rows-ok)
      (delete-result-rows-owned-values aggregate-rows)
      (return (make [dynamic]Result-Row) false))
    (let [out (make [dynamic]Result-Row 0 (count aggregate-rows))]
      (for [row aggregate-rows]
        (when (not (= (count row.values) (+ (count group-vars) (count query.aggregates))))
          (delete-result-rows-owned-values out)
          (delete-result-rows-owned-values aggregate-rows)
          (return (make [dynamic]Result-Row) false))
        (let [values (make [dynamic]Value 0 (+ (count query.find) (count query.aggregates)))
              [pulls pulls-ok] (pulls-for-aggregate-row-with-sources-and-fns db sources query inputs (slice group-vars 0) row registry)]
          (when (not pulls-ok)
            (delete values)
            (delete-result-rows-owned-values out)
            (delete-result-rows-owned-values aggregate-rows)
            (return (make [dynamic]Result-Row) false))
          (for [index (arr.range 0 (count query.find))]
            (arr.push! values (value-owned row.values[index])))
          (for [index (arr.range 0 (count query.aggregates))]
            (arr.push! values (value-owned row.values[(+ (count group-vars) index)])))
          (arr.push! out (Result-Row {values: values pulls: pulls}))))
      (delete-result-rows-owned-values aggregate-rows)
      (return out true))))

(defn aggregate-result-rows-for-typed-relation-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, rel: Query-Relation, registry: []Native-Query-Fn] -> [rows: [dynamic]Result-Row, ok: bool]
  (if (> (count query.pulls) 0)
    (pull-aggregate-result-rows-for-typed-relation-with-sources-and-fns db sources query inputs rel registry)
    (aggregate-rows-for-typed-relation query rel)))

(defn append-aggregate-rows-with-sources-and-fns! [rows: ^[dynamic]Result-Row, db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn]
  (let [seen-groups (make [dynamic]Result-Row)]
    (defer (delete-result-rows-owned-values seen-groups))
    (for [binding bindings]
      (let [[group-values ok] (binding-values-for-vars binding (slice query.find 0))]
        (when ok
          (if (row-values-exist? (slice seen-groups 0) (slice group-values 0))
            (delete group-values)
            (do
              (arr.push! seen-groups (aggregate-owned-key-row (slice group-values 0)))
              (let [values (arr.into [dynamic]Value (slice group-values 0))
                    [pulls pulls-ok] (pulls-for-binding-with-sources-and-fns db sources query inputs binding registry)]
                (delete group-values)
                (when (not pulls-ok)
                  (delete pulls)
                  (return))
                (for [aggregate query.aggregates]
                  (arr.push! values (aggregate-initial-value aggregate)))
                (arr.push! rows^ (Result-Row {values: values pulls: pulls})))))))))
  (for [row rows^]
    (for [aggregate index query.aggregates]
      (set! row.values[(+ (count query.find) index)]
        (aggregate-value-for-group-with-fns bindings query aggregate (slice row.values 0 (count query.find)) registry)))))

(defn append-aggregate-rows-with-sources! [rows: ^[dynamic]Result-Row, db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding]
  (append-aggregate-rows-with-sources-and-fns! rows db sources query inputs bindings ([]Native-Query-Fn [])))

(defn append-aggregate-rows! [rows: ^[dynamic]Result-Row, db: DB, query: Query, inputs: []Query-Input, bindings: []Binding]
  (append-aggregate-rows-with-sources! rows db ([]DB-Source []) query inputs bindings))

(defn result-rows-for-bindings-with-sources-and-fns [db: DB, sources: []DB-Source, query: Query, inputs: []Query-Input, bindings: []Binding, registry: []Native-Query-Fn] -> [dynamic]Result-Row
  (let [rows (make [dynamic]Result-Row 0 (count bindings))
        seen (set.empty string)
        seen-entities (set.empty u64)
        seen-ints (set.empty i64)
        seen-strings (set.empty string)
        seen-keywords (set.empty string)
        seen-symbols (set.empty string)
        seen-nil false
        seen-true false
        seen-false false
        trust-unique-bindings (query-can-trust-unique-bindings? query)]
    (defer (delete-owned-string-set seen))
    (defer (delete seen-entities))
    (defer (delete seen-ints))
    (defer (delete seen-strings))
    (defer (delete seen-keywords))
    (defer (delete seen-symbols))
    (for [binding bindings]
      (let [values (make [dynamic]Value 0 (count query.find))
            dedupe-values (make [dynamic]Value)
            [pulls pulls-ok] (pulls-for-binding-with-sources-and-fns db sources query inputs binding registry)
            complete true]
        (when (not pulls-ok)
          (set! complete false))
        (for [name query.find]
          (let [[value ok] (binding-lookup binding name)]
            (if ok
              (do
                (arr.push! values (value-owned value))
                (arr.push! dedupe-values value))
              (set! complete false))))
        (for [name query.with]
          (let [[value ok] (binding-lookup binding name)]
            (if ok
              (arr.push! dedupe-values value)
              (set! complete false))))
        (when complete
          (if trust-unique-bindings
            (arr.push! rows (Result-Row {values: values pulls: pulls}))
            (if (> (count pulls) 0)
              (let [[key key-ok] (result-row-dedupe-key (slice dedupe-values 0) (slice pulls 0))]
                (if key-ok
                  (let [already-seen (set.contains? seen key)]
                    (when (not already-seen)
                      (set.add! seen key)
                      (arr.push! rows (Result-Row {values: values pulls: pulls})))
                    (when already-seen
                      (delete key)))
                  (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                    (arr.push! rows (Result-Row {values: values pulls: pulls})))))
            (if (= (count dedupe-values) 1)
              (let [dedupe-value dedupe-values[0]]
                (case dedupe-value.kind
                  .Entity (let [already-seen (set.contains? seen-entities dedupe-value.entity)]
                            (when (not already-seen)
                              (set.add! seen-entities dedupe-value.entity)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Int (let [already-seen (set.contains? seen-ints dedupe-value.int-value)]
                         (when (not already-seen)
                           (set.add! seen-ints dedupe-value.int-value)
                           (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .String (let [already-seen (set.contains? seen-strings dedupe-value.text)]
                            (when (not already-seen)
                              (set.add! seen-strings dedupe-value.text)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Keyword (let [already-seen (set.contains? seen-keywords dedupe-value.text)]
                             (when (not already-seen)
                               (set.add! seen-keywords dedupe-value.text)
                               (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Symbol (let [already-seen (set.contains? seen-symbols dedupe-value.text)]
                            (when (not already-seen)
                              (set.add! seen-symbols dedupe-value.text)
                              (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Bool (if dedupe-value.bool-value
                          (when (not seen-true)
                            (set! seen-true true)
                            (arr.push! rows (Result-Row {values: values pulls: pulls})))
                          (when (not seen-false)
                            (set! seen-false true)
                            (arr.push! rows (Result-Row {values: values pulls: pulls}))))
                  .Nil (when (not seen-nil)
                         (set! seen-nil true)
                         (arr.push! rows (Result-Row {values: values pulls: pulls})))
                   (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                          (arr.push! rows (Result-Row {values: values pulls: pulls})))))
              (let [[key key-ok] (row-values-dedupe-key (slice dedupe-values 0))]
                (if key-ok
                  (let [already-seen (set.contains? seen key)]
                    (when (not already-seen)
                      (set.add! seen key)
                      (arr.push! rows (Result-Row {values: values pulls: pulls})))
                    (when already-seen
                      (delete key)))
                  (when (not (row-values-exist? (slice rows 0) (slice dedupe-values 0)))
                    (arr.push! rows (Result-Row {values: values pulls: pulls})))))))))))
    rows))

(defn bindings-after-rule-call-step [db: DB, rules: []Rule, bindings: []Binding, call: Rule-Call] -> [dynamic]Binding
  (bindings-after-rule-call-step-with-fns db rules bindings call ([]Native-Query-Fn [])))

(defn bindings-after-rule-call-step-with-fns [db: DB, rules: []Rule, bindings: []Binding, call: Rule-Call, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [plan (rule-call-plan rules call.name)]
    (defer (delete-rule-call-plan plan))
    (bindings-after-rule-call-step-with-plan db plan bindings call registry)))

(defn bindings-after-rule-call-step-with-plans [db: DB, rules: []Rule, plans: []Rule-Call-Plan, bindings: []Binding, call: Rule-Call, call-index: int, registry: []Native-Query-Fn] -> [dynamic]Binding
  (if (< call-index (count plans))
    (bindings-after-rule-call-step-with-plan db plans[call-index] bindings call registry)
    (bindings-after-rule-call-step-with-fns db rules bindings call registry)))

(defn bindings-after-rule-call-step-with-plan [db: DB, plan: Rule-Call-Plan, bindings: []Binding, call: Rule-Call, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [rule-bindings (bindings-after-rule-call-planned-with-fns db plan call binding registry)]
        (for [rule-binding rule-bindings]
          (arr.push! out rule-binding))
        (delete rule-bindings)))
    out))

(defn bindings-after-get-else-step [db: DB, bindings: []Binding, get-else: Get-Else] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[next ok] (apply-get-else db binding get-else)]
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-get-some-step [db: DB, bindings: []Binding, get-some: Get-Some] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (let [[next ok] (apply-get-some db binding get-some)]
        (when ok
          (arr.push! out next))))
    out))

(defn bindings-after-or-group-step-with-rules-and-fns [db: DB, rules: []Rule, sources: []DB-Source, bindings: []Binding, group: Or-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (for [branch group.branches]
        (let [branch-bindings (bindings-after-or-branch-with-rules-sources-and-fns db rules sources group branch binding registry)]
          (for [branch-binding branch-bindings]
            (arr.push! out branch-binding))
          (delete branch-bindings))))
    out))

(defn bindings-after-or-group-step-with-fns [db: DB, sources: []DB-Source, bindings: []Binding, group: Or-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-or-group-step-with-rules-and-fns db ([]Rule []) sources bindings group registry))

(defn bindings-after-or-group-step [db: DB, sources: []DB-Source, bindings: []Binding, group: Or-Group] -> [dynamic]Binding
  (bindings-after-or-group-step-with-fns db sources bindings group ([]Native-Query-Fn [])))

(defn bindings-after-not-group-step-with-rules-and-fns [db: DB, rules: []Rule, sources: []DB-Source, bindings: []Binding, group: Not-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [out (make [dynamic]Binding)]
    (for [binding bindings]
      (when (not (binding-matches-not-group-with-rules-sources-and-fns? db rules sources group binding registry))
        (arr.push! out binding)))
    out))

(defn bindings-after-not-group-step-with-fns [db: DB, sources: []DB-Source, bindings: []Binding, group: Not-Group, registry: []Native-Query-Fn] -> [dynamic]Binding
  (bindings-after-not-group-step-with-rules-and-fns db ([]Rule []) sources bindings group registry))

(defn bindings-after-not-group-step [db: DB, sources: []DB-Source, bindings: []Binding, group: Not-Group] -> [dynamic]Binding
  (bindings-after-not-group-step-with-fns db sources bindings group ([]Native-Query-Fn [])))

(defn bindings-after-query-step-with-fns [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step, registry: []Native-Query-Fn] -> [dynamic]Binding
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources! (addr out) db sources query^.clauses[step.index] binding))
        out)
    .RuleCall
      (bindings-after-rule-call-step-with-plans db (slice query^.rules 0) (slice query^.rule-call-plans 0) bindings query^.rule-calls[step.index] step.index registry)
    .Ground
      (apply-ground bindings query^.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings query^.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings query^.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings query^.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings query^.predicates[step.index] registry)
    .Or
      (bindings-after-or-group-step-with-rules-and-fns db (slice query^.rules 0) sources bindings query^.or-groups[step.index] registry)

      (bindings-after-not-group-step-with-rules-and-fns db (slice query^.rules 0) sources bindings query^.not-groups[step.index] registry)))

(defn bindings-after-query-step [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step] -> [dynamic]Binding
  (bindings-after-query-step-with-fns db sources query bindings step ([]Native-Query-Fn [])))

(defn bindings-after-query-step-profiled-with-fns [db: DB, sources: []DB-Source, query: ^Query, bindings: []Binding, step: Query-Step, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (set! stats^.steps (+ stats^.steps 1))
  (case step.kind
    .Clause
      (let [out (make [dynamic]Binding)]
        (for [binding bindings]
          (append-bindings-after-clause-with-sources-profiled! (addr out) db sources query^.clauses[step.index] binding stats))
        out)
    .RuleCall
      (let [out (make [dynamic]Binding)
            call query^.rule-calls[step.index]
            use-cached-plan (< step.index (count query^.rule-call-plans))
            plan (if use-cached-plan query^.rule-call-plans[step.index] (rule-call-plan (slice query^.rules 0) call.name))]
        (for [binding bindings]
          (let [rule-bindings (bindings-after-rule-call-profiled-with-plan db plan call binding registry stats)]
            (for [rule-binding rule-bindings]
              (arr.push! out rule-binding))
            (delete rule-bindings)))
        (when (not use-cached-plan)
          (delete-rule-call-plan plan))
        out)
    .Ground
      (apply-ground bindings query^.grounds[step.index])
    .GetElse
      (bindings-after-get-else-step db bindings query^.get-elses[step.index])
    .GetSome
      (bindings-after-get-some-step db bindings query^.get-somes[step.index])
    .Function
      (bindings-after-function-with-fns bindings query^.function-clauses[step.index] registry)
    .Predicate
      (bindings-after-predicate-with-db-and-fns db bindings query^.predicates[step.index] registry)
    .Or
      (bindings-after-or-group-step-with-rules-and-fns db (slice query^.rules 0) sources bindings query^.or-groups[step.index] registry)

      (bindings-after-not-group-step-with-rules-and-fns db (slice query^.rules 0) sources bindings query^.not-groups[step.index] registry)))

(defn bindings-after-planned-clauses-profiled [db: DB, sources: []DB-Source, bindings: []Binding, clauses: []Clause, stats: ^Query-Stats] -> [dynamic]Binding
  (let [current (arr.into [dynamic]Binding bindings)
        remaining (arr.into [dynamic]Clause clauses)]
    (defer (delete remaining))
    (while (and (> (count current) 0) (> (count remaining) 0))
      (let [clause-index (best-clause-index-estimated db sources (slice remaining 0) current[0])
            clause remaining[clause-index]
            next (make [dynamic]Binding)]
        (set! stats^.steps (+ stats^.steps 1))
        (for [binding current]
          (append-bindings-after-clause-with-sources-profiled! (addr next) db sources clause binding stats))
        (delete current)
        (set! current next)
        (query-stats-observe-bindings! stats (count current))
        (arr.remove-ordered-at! remaining clause-index)))
    current))

(defn query-steps-are-clauses? [query: Query] -> bool
  (when (= (count query.where-steps) 0)
    (return true))
  (when (not (= (count query.where-steps) (count query.clauses)))
    (return false))
  (for [step query.where-steps]
    (when (not (= step.kind .Clause))
      (return false)))
  true)

(defn query-steps-are-relation-engine-supported? [query: Query] -> bool
  (when (= (count query.where-steps) 0)
    (return true))
  (let [clause-count 0
        predicate-count 0
        function-count 0
        not-count 0
        or-count 0
        rule-call-count 0
        ground-count 0
        get-else-count 0
        get-some-count 0]
    (for [step query.where-steps]
      (cond
        (= step.kind .Clause) (set! clause-count (+ clause-count 1))
        (= step.kind .Predicate) (set! predicate-count (+ predicate-count 1))
        (= step.kind .Function) (set! function-count (+ function-count 1))
        (= step.kind .Not) (set! not-count (+ not-count 1))
        (= step.kind .Or) (set! or-count (+ or-count 1))
        (= step.kind .RuleCall) (set! rule-call-count (+ rule-call-count 1))
        (= step.kind .Ground) (set! ground-count (+ ground-count 1))
        (= step.kind .GetElse) (set! get-else-count (+ get-else-count 1))
        (= step.kind .GetSome) (set! get-some-count (+ get-some-count 1))
        :else (return false)))
    (and (= clause-count (count query.clauses))
         (= predicate-count (count query.predicates))
         (= function-count (count query.function-clauses))
         (= not-count (count query.not-groups))
         (= or-count (count query.or-groups))
         (= rule-call-count (count query.rule-calls))
         (= ground-count (count query.grounds))
         (= get-else-count (count query.get-elses))
         (= get-some-count (count query.get-somes)))))

(defn query-clause-uses-source-input? [query: Query, sources: []DB-Source, clause: Clause] -> bool
  (and clause.has-source
       (not (= clause.source "$"))
       (not (query-source-db? sources clause.source))
       (query-source-input? query clause.source)))

(defn query-source-input-binding [query: Query, inputs: []Query-Input, source: string] -> [binding: Binding, ok: bool]
  (let [[index found] (query-input-index-for-source query source)]
    (when (not found)
      (return (Binding {}) false))
    (when (>= index (count inputs))
      (return (Binding {}) false))
    (let [[value value-ok] (query-input-source-value inputs[index])]
      (when (not value-ok)
        (return (Binding {}) false))
      (let [source-binding (Binding {})]
        (binding-store! (addr source-binding) source value)
        (return source-binding true)))))

(defn query-uses-primary-relation-db-source? [query: Query] -> bool
  (let [primary (primary-relation-db-source-name)]
    (for [clause-value query.clauses]
      (when (and clause-value.has-source
                 (= clause-value.source primary))
        (return true)))
    (for [call query.rule-calls]
      (when (and call.has-source
                 (= call.source primary))
        (return true)))
    false))

(defn query-uses-source-input-clause? [query: Query] -> bool
  (for [clause-value query.clauses]
    (when (and clause-value.has-source
               (query-source-input? query clause-value.source))
      (return true)))
  (for [group query.not-groups]
    (when (not-group-uses-source-input? query group)
      (return true)))
  (for [group query.or-groups]
    (when (or-group-uses-source-input? query group)
      (return true)))
  (for [call query.rule-calls]
    (when (and call.has-source
               (query-source-input? query call.source))
      (return true)))
  (for [rule query.rules]
    (when (rule-uses-source-input? query rule)
      (return true)))
  false)

(defn query-has-compound-source-input-operators? [query: Query] -> bool
  (and (query-uses-source-input-clause? query)
       (or (> (count query.rule-calls) 0)
           (> (count query.not-groups) 0)
           (> (count query.or-groups) 0))))

(defn not-group-uses-source-input? [query: Query, group: Not-Group] -> bool
  (for [clause-value group.clauses]
    (when (and clause-value.has-source
               (query-source-input? query clause-value.source))
      (return true)))
  (for [child group.not-groups]
    (when (not-group-uses-source-input? query child)
      (return true)))
  (for [call group.rule-calls]
    (when (and call.has-source
               (query-source-input? query call.source))
      (return true)))
  false)

(defn or-group-uses-source-input? [query: Query, group: Or-Group] -> bool
  (for [branch group.branches]
    (when (not-group-uses-source-input? query branch)
      (return true)))
  false)

(defn rule-uses-source-input? [query: Query, rule: Rule] -> bool
  (for [clause-value rule.clauses]
    (when (and clause-value.has-source
               (query-source-input? query clause-value.source))
      (return true)))
  (for [call rule.rule-calls]
    (when (and call.has-source
               (query-source-input? query call.source))
      (return true)))
  (for [group rule.not-groups]
    (when (not-group-uses-source-input? query group)
      (return true)))
  (for [group rule.or-groups]
    (when (or-group-uses-source-input? query group)
      (return true)))
  false)

(defn query-simple-inputs-can-start-typed? [query: Query] -> bool
  (when (> (count query.input-specs) 0)
    (do
      (for [spec query.input-specs]
        (when (not (or (= spec.kind .Scalar)
                       (= spec.kind .Collection)
                       (= spec.kind .Tuple)
                       (= spec.kind .Relation)
                       (= spec.kind .Ignore)))
          (return false)))
      (return true)))
  true)

(defn query-relation-engine-eligible? [query: Query, sources: []DB-Source] -> bool
  (when (not (query-steps-are-relation-engine-supported? query))
    (return false))
  (when (query-has-compound-source-input-operators? query)
    (return false))
  (when (and (query-steps-are-clauses-and-predicates? query)
             (> (+ (count query.inputs)
                   (count query.collection-inputs)
                   (count query.tuple-inputs)
                   (count query.relation-inputs)
                   (count query.input-specs))
                0)
             (not (query-uses-source-input-clause? query))
             (not (query-simple-inputs-can-start-typed? query)))
    (return false))
  (when (and (query-uses-primary-relation-db-source? query)
             (or (> (count query.predicates) 0)
                 (> (count query.function-clauses) 0)
                 (> (count query.rule-calls) 0)))
    (return false))
  (for [clause-value query.clauses]
    (when (and clause-value.has-source
               (not (= clause-value.source "$"))
               (not (query-source-input? query clause-value.source))
               (not (query-source-db? sources clause-value.source)))
      (return false)))
  true)

(defn query-relation-copy [rel: Query-Relation] -> Query-Relation
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        tuples (clone-bindings (slice rel.tuples 0))]
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: tuples
                     typed-columns: (if rel.has-typed-columns
                                      (clone-relation-columns (slice rel.typed-columns 0))
                                      (make [dynamic]Relation-Column))
                     typed-rows: rel.typed-rows
                     has-typed-columns: rel.has-typed-columns})))

(defn query-relation-predicate-can-run-typed? [rel: Query-Relation, predicate: Predicate, registry: []Native-Query-Fn] -> bool
  (when (not rel.has-typed-columns)
    (return false))
  (let [row 0]
    (while (< row rel.typed-rows)
      (let [[_ ok] (typed-predicate-matches? rel row predicate registry)]
        (when (not ok)
          (return false)))
      (set! row (+ row 1))))
  true)

(defn query-relation-filter-predicate [db: DB, rel: Query-Relation, predicate: Predicate, registry: []Native-Query-Fn] -> Query-Relation
  (when (not (query-relation-predicate-can-run-typed? rel predicate registry))
    (let [materialized (query-relation-materialized-bindings rel) :defer
          bindings (bindings-after-predicate-with-db-and-fns db (slice materialized 0) predicate registry) :defer]
      (return (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel))))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))
        row 0]
    (while (< row rel.typed-rows)
      (let [[match _] (typed-predicate-matches? rel row predicate registry)]
        (when match
          (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty)))))
      (set! row (+ row 1)))
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: builder.tuples
                     typed-columns: builder.typed-columns
                     typed-rows: builder.typed-rows
                     has-typed-columns: true})))

(defn query-relation-extend-function-out-binding-typed [rel: Query-Relation, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer
        seen-output-vars (set.empty string) :defer]
    (append-input-binding-vars-indexed! (addr output-vars) (addr seen-output-vars) function.out-binding)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[value value-ok] (typed-function-op-value rel row function registry)]
          (when value-ok
            (if (input-binding-contains-collection? function.out-binding)
              (let [[produced-rows produced-ok] (typed-produced-value-rows-from-input-binding rel row function.out-binding value (slice output-vars 0))]
                (when produced-ok
                  (for [produced produced-rows]
                    (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced.values 0)))
                      (delete-typed-produced-values produced-rows)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (delete-typed-produced-values produced-rows))
              (let [[produced produced-ok] (typed-produced-values-from-input-binding rel row function.out-binding value (slice output-vars 0))]
                (when produced-ok
                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                    (delete produced)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))
                (delete produced)))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-extend-function-out-binding-typed [source: DB-Read-Source, rel: Query-Relation, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer
        seen-output-vars (set.empty string) :defer]
    (append-input-binding-vars-indexed! (addr output-vars) (addr seen-output-vars) function.out-binding)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[value value-ok] (db-read-source-typed-function-op-value source rel row function registry)]
          (when value-ok
            (if (input-binding-contains-collection? function.out-binding)
              (let [[produced-rows produced-ok] (typed-produced-value-rows-from-input-binding rel row function.out-binding value (slice output-vars 0))]
                (when produced-ok
                  (for [produced produced-rows]
                    (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced.values 0)))
                      (delete-typed-produced-values produced-rows)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (delete-typed-produced-values produced-rows))
              (let [[produced produced-ok] (typed-produced-values-from-input-binding rel row function.out-binding value (slice output-vars 0))]
                (when produced-ok
                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                    (delete produced)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))
                (delete produced)))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn db-read-source-query-relation-extend-fulltext-typed [source: DB-Read-Source, sources: []DB-Read-Named-Source, rel: Query-Relation, function: Function-Clause] -> [out: Query-Relation, ok: bool]
  (when (not (= function.op "fulltext"))
    (return (query-relation-empty) false))
  (when (not rel.has-typed-columns)
    (let [materialized (query-relation-materialized-bindings rel)
          [bindings bindings-ok _] (db-read-source-bindings-after-fulltext-with-sources source sources (slice materialized 0) function)]
      (delete materialized)
      (when (not bindings-ok)
        (db-read-source-delete-bindings-owned bindings)
        (return (query-relation-empty) false))
      (let [relation (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
        (db-read-source-delete-bindings-owned bindings)
        (return relation true))))
  (let [[source-name source-name-ok] (fulltext-source-name function)]
    (when (not source-name-ok)
      (return (query-relation-empty) false))
    (let [[read-source read-source-ok _] (db-read-source-for-name source sources source-name)]
      (when (not read-source-ok)
        (return (query-relation-empty) false))
      (let [[attr attr-ok] (fulltext-attr-from-term function.terms[1])]
        (when (not attr-ok)
          (return (query-relation-empty) false))
        (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
              attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
              output-binding (fulltext-output-row-binding function.out-binding)
              output-vars (make [dynamic]string) :defer
              seen-output-vars (set.empty string) :defer
              row-width (fulltext-output-width function.out-binding)
              [stream stream-ok _] (source-index-datom-stream read-source attr)]
          (append-input-binding-vars-indexed! (addr output-vars) (addr seen-output-vars) output-binding)
          (for [name output-vars]
            (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
          (let [builder (query-relation-builder (slice attrs 0))]
            (when (and (= read-source.kind .SQLite-Snapshot)
                       (not read-source.sqlite-snapshot^.has-retractions))
              (let [row 0]
                (while (< row rel.typed-rows)
                  (let [[search search-ok] (fulltext-search-from-typed-row rel row function)]
                    (when search-ok
                      (let [[candidates candidates-ok candidates-error] (sqlite-db-snapshot-attr-string-contains-datoms read-source.sqlite-snapshot attr search)]
                        (when (not candidates-ok)
                          (delete attrs)
                          (delete attr-sources)
                          (delete-query-relation-builder builder)
                          (return (query-relation-empty) false))
                        (for [candidate candidates]
                          (when (and (= candidate.v.kind .String)
                                     (fulltext-matches? search candidate.v.text))
                            (let [row-value (db-read-source-fulltext-row-value candidate search row-width)]
                              (let [[produced produced-ok] (typed-produced-values-from-input-binding rel row output-binding row-value (slice output-vars 0))]
                                (when produced-ok
                                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                                    (delete produced)
                                    (delete-owned-value row-value)
                                    (delete-owned-datoms candidates)
                                    (delete attrs)
                                    (delete attr-sources)
                                    (delete-query-relation-builder builder)
                                    (return (query-relation-empty) false)))
                                (delete produced))
                              (delete-owned-value row-value))))
                        (delete-owned-datoms candidates))))
                  (set! row (+ row 1))))
              (return (Query-Relation {attrs: attrs
                                       attr-sources: attr-sources
                                       attr-index: (query-relation-attr-index (slice attrs 0))
                                       tuples: builder.tuples
                                       typed-columns: builder.typed-columns
                                       typed-rows: builder.typed-rows
                                       has-typed-columns: builder.typed-ok}) true))
            (when (not stream-ok)
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))
            (while stream.has-current
              (when (= stream.current.v.kind .String)
                (let [row 0]
                  (while (< row rel.typed-rows)
                    (let [[search search-ok] (fulltext-search-from-typed-row rel row function)]
                      (when (and search-ok
                                 (fulltext-matches? search stream.current.v.text))
                        (let [row-value (db-read-source-fulltext-row-value stream.current search row-width)]
                          (let [[produced produced-ok] (typed-produced-values-from-input-binding rel row output-binding row-value (slice output-vars 0))]
                            (when produced-ok
                              (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                                (delete produced)
                                (delete-owned-value row-value)
                                (delete-source-index-datom-stream stream)
                                (delete attrs)
                                (delete attr-sources)
                                (delete-query-relation-builder builder)
                                (return (query-relation-empty) false)))
                            (delete produced))
                          (delete-owned-value row-value))))
                    (set! row (+ row 1)))))
              (let [[advance-ok _] (advance-source-index-datom-stream! read-source (addr stream))]
                (when (not advance-ok)
                  (delete-source-index-datom-stream stream)
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))
            (delete-source-index-datom-stream stream)
            (return (Query-Relation {attrs: attrs
                                     attr-sources: attr-sources
                                     attr-index: (query-relation-attr-index (slice attrs 0))
                                     tuples: builder.tuples
                                     typed-columns: builder.typed-columns
                                     typed-rows: builder.typed-rows
                                     has-typed-columns: builder.typed-ok}) true)))))))

(defn db-read-source-query-relation-extend-function-typed [source: DB-Read-Source, rel: Query-Relation, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [[op op-ok] (query-op-name function.op (Binding {}))]
    (when (and op-ok (source-function-op? op))
      (when (not rel.has-typed-columns)
        (let [materialized (query-relation-materialized-bindings rel)
              [bindings bindings-ok _] (db-read-source-bindings-after-function-with-source source (slice materialized 0) function)]
          (when (not bindings-ok)
            (delete materialized)
            (db-read-source-delete-bindings-owned bindings)
            (return (query-relation-empty) false))
          (let [out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
            (delete materialized)
            (db-read-source-delete-bindings-owned bindings)
            (return out true))))
      (when (not (= function.out-binding.kind .None))
        (return (db-read-source-query-relation-extend-function-out-binding-typed source rel function registry)))
      (when (or function.is-tuple (= function.out ""))
        (return (query-relation-empty) false))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-var-binding-attr! (addr attrs) (addr attr-sources) function.out "")
        (let [builder (query-relation-builder (slice attrs 0))
              row 0]
          (while (< row rel.typed-rows)
            (let [[value value-ok] (db-read-source-typed-function-op-value source rel row function registry)]
              (when value-ok
                (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row function.out value))
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))
            (set! row (+ row 1)))
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true)))))
  (query-relation-extend-function-typed rel function registry))

(defn query-relation-extend-function-binding-typed [rel: Query-Relation, op: string, terms: []Term, binding: Input-Binding, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [function (Function-Clause {op: op
                                   terms: terms
                                   out-binding: binding})
        [_ op-ok] (typed-function-op-name function registry)]
    (when (not op-ok)
      (return (query-relation-empty) false))
    (query-relation-extend-function-out-binding-typed rel function registry)))

(defn query-relation-extend-function-value-binding-typed [rel: Query-Relation, op: string, values: []Value, binding: Input-Binding, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [terms (make [dynamic]Term) :defer]
    (for [value values]
      (arr.push! terms (term-value value)))
    (query-relation-extend-function-binding-typed rel op (slice terms 0) binding registry)))

(defn query-relation-extend-function-typed [rel: Query-Relation, function: Function-Clause, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [[_ op-ok] (typed-function-op-name function registry)]
    (when (not op-ok)
      (return (query-relation-empty) false)))
  (when (not (= function.out-binding.kind .None))
    (return (query-relation-extend-function-out-binding-typed rel function registry)))
  (when function.is-tuple
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          output-vars (make [dynamic]string) :defer]
      (for [name function.out-vars]
        (append-var-once! (addr output-vars) name))
      (for [name output-vars]
        (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (let [[value value-ok] (typed-function-op-value rel row function registry)]
            (when value-ok
              (when (not (= value.kind .Vector))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (let [[produced produced-ok] (typed-ground-produced-values rel row function.out-vars (slice value.items 0) (slice output-vars 0))]
                (when produced-ok
                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                    (delete produced)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))
                (delete produced))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))
  (when (= function.out "")
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-var-binding-attr! (addr attrs) (addr attr-sources) function.out "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[value value-ok] (typed-function-op-value rel row function registry)]
          (when value-ok
            (when (query-relation-typed-row-var-agrees? rel row function.out value)
              (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row function.out value))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false)))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-extend-function [rel: Query-Relation, function: Function-Clause, registry: []Native-Query-Fn] -> Query-Relation
  (let [[typed typed-ok] (query-relation-extend-function-typed rel function registry)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (bindings-after-function-with-fns (slice materialized 0) function registry)
        out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
    (delete bindings)
    out))

(defn plain-typed-branch-group? [group: Not-Group] -> bool
  (when (= (count group.steps) 0)
    (return false))
  (for [step group.steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)
                   (= step.kind .Function)
                   (= step.kind .Ground)
                   (= step.kind .RuleCall)
                   (= step.kind .GetElse)
                   (= step.kind .GetSome)
                   (= step.kind .Not)))
      (return false))
    (when (and (= step.kind .Not)
               (not (plain-typed-branch-group? group.not-groups[step.index])))
      (return false)))
  true)

(defn branch-has-source-input? [query: Query, branch: Not-Group] -> bool
  (let [index 0]
    (while (< index (count branch.clauses))
      (let [item branch.clauses[index]]
        (when (and item.has-source
                   (query-source-input? query item.source))
          (return true)))
      (set! index (+ index 1))))
  (for [child branch.not-groups]
    (when (branch-has-source-input? query child)
      (return true)))
  (for [call branch.rule-calls]
    (when (and call.has-source
               (query-source-input? query call.source))
      (return true)))
  false)

(defn or-group-has-source-input? [query: Query, group: Or-Group] -> bool
  (for [branch group.branches]
    (when (branch-has-source-input? query branch)
      (return true)))
  false)

(defn query-relation-apply-branch-local-step-typed [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, step: Query-Step, group: Not-Group, stats: ^Query-Stats, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (case step.kind
    .Clause
      (if (and group.clauses[step.index].has-source
               (query-source-input? query group.clauses[step.index].source))
        (query-relation-apply-source-input-clause-typed query inputs rel group.clauses[step.index])
        (query-relation-apply-bound-db-clause-typed-scan-with-sources db sources rel group.clauses[step.index] stats))
    .Predicate
      (do
        (when (not (query-relation-predicate-can-run-typed? rel group.predicates[step.index] registry))
          (return (query-relation-empty) false))
        (let [out (query-relation-filter-predicate db rel group.predicates[step.index] registry)]
          (if out.has-typed-columns
            (return out true)
            (return out false))))
    .Function
      (query-relation-extend-function-typed rel group.function-clauses[step.index] registry)
    .Ground
      (query-relation-apply-ground-typed rel group.grounds[step.index])
    .RuleCall
      (let [cache (make [dynamic]Materialized-Rule-Cache-Entry)
            next (query-relation-apply-rule-call db sources (slice query.rules 0) ([]Rule-Call-Plan []) rel group.rule-calls[step.index] -1 registry stats (addr cache))]
        (delete cache)
        (if next.has-typed-columns
          (return next true)
          (return next false)))
    .GetElse
      (let [get-else group.get-elses[step.index]]
        (if get-else.has-source
          (if (= get-else.source "$")
            (query-relation-apply-get-else-typed db rel (unsourced-get-else get-else))
            (let [[source-db source-ok] (source-db-lookup db sources get-else.source)]
              (when (not source-ok)
                (return (query-relation-empty) false))
              (query-relation-apply-get-else-typed source-db rel (unsourced-get-else get-else))))
          (query-relation-apply-get-else-typed db rel get-else)))
    .GetSome
      (let [get-some group.get-somes[step.index]]
        (if get-some.has-source
          (if (= get-some.source "$")
            (query-relation-apply-get-some-typed db rel (unsourced-get-some get-some))
            (let [[source-db source-ok] (source-db-lookup db sources get-some.source)]
              (when (not source-ok)
                (return (query-relation-empty) false))
              (query-relation-apply-get-some-typed source-db rel (unsourced-get-some get-some))))
          (query-relation-apply-get-some-typed db rel get-some)))
    .Not
      (query-relation-apply-not-typed db query inputs sources rel group.not-groups[step.index] registry)

      (return (query-relation-empty) false)))

(defn query-relation-apply-plain-branch-pipeline-typed [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, row: int, group: Not-Group, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (let [current (query-relation-empty)
        current-ok false]
    (if group.has-join
      (let [[projected projected-ok] (query-relation-single-typed-row-projected rel row (slice group.join-vars 0))]
        (set! current projected)
        (set! current-ok projected-ok))
      (let [[single single-ok] (query-relation-single-typed-row rel row)]
        (set! current single)
        (set! current-ok single-ok)))
    (when (not current-ok)
      (delete-query-relation current)
      (return (query-relation-empty) false))
    (let [stats (query-stats-empty)]
      (for [step group.steps]
        (let [[next next-ok] (query-relation-apply-branch-local-step-typed db query inputs sources current step group (addr stats) registry)]
          (delete-query-relation current)
          (when (not next-ok)
            (delete-query-relation next)
            (return (query-relation-empty) false))
          (set! current next)
          (when (= (query-relation-row-count current) 0)
            (return current true))))
      (return current true))))

(defn typed-row-matches-plain-branch-group? [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, row: int, group: Not-Group, registry: []Native-Query-Fn] -> [matched: bool, ok: bool]
  (let [[branch-rel branch-ok] (query-relation-apply-plain-branch-pipeline-typed db query inputs sources rel row group registry)]
    (when (not branch-ok)
      (delete-query-relation branch-rel)
      (return false false))
    (let [has-match (> (query-relation-row-count branch-rel) 0)]
      (delete-query-relation branch-rel)
      (return has-match true))))

(defn query-relation-apply-not-existence-typed [db: DB, rel: Query-Relation, clause-value: Clause] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (not clause-value.has-source)
                  (= clause-value.e.kind .Var)
                  (query-relation-has-attr? rel clause-value.e.name)
                  (= clause-value.a.kind .Value)
                  (= clause-value.a.value.kind .Keyword)
                  (= clause-value.v.kind .Wildcard)
                  (or (= clause-value.tx-term.kind .Wildcard)
                      (omitted-term? clause-value.tx-term))
                  (or (= clause-value.op-term.kind .Wildcard)
                      (omitted-term? clause-value.op-term))))
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))
        row 0]
    (while (< row rel.typed-rows)
      (let [[entity entity-ok] (query-relation-resolve-typed-entity-term db rel row clause-value.e)]
        (when (not (and entity-ok (= entity.kind .Entity)))
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (when (not (current-attr-exists? db entity.entity clause-value.a.value.text))
          (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))))
      (set! row (+ row 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: builder.typed-ok}) true)))

(defn query-relation-apply-not-existence-typed-with-sources [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause] -> [out: Query-Relation, ok: bool]
  (if clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when (not source-ok)
        (return (query-relation-empty) false))
      (query-relation-apply-not-existence-typed source-db rel (unsourced-clause clause-value)))
    (query-relation-apply-not-existence-typed db rel clause-value)))

(defn query-relation-apply-not-typed [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, group: Not-Group, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (when (and (not group.has-join)
             (= (count group.clauses) 1)
             (= (count group.predicates) 0)
             (= (count group.function-clauses) 0)
             (= (count group.grounds) 0)
             (= (count group.get-elses) 0)
             (= (count group.get-somes) 0)
             (= (count group.not-groups) 0)
             (not (branch-has-source-input? query group)))
    (let [[existence existence-ok] (query-relation-apply-not-existence-typed-with-sources db sources rel group.clauses[0])]
      (when existence-ok
        (return existence true))
      (delete-query-relation existence))
    (let [clause group.clauses[0]]
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          builder (query-relation-builder (slice rel.attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[matched match-ok] (typed-row-matches-single-db-clause? db sources rel row clause)]
          (when (not match-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (when (not matched)
            (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))
  (when (plain-typed-branch-group? group)
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          builder (query-relation-builder (slice rel.attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[matched match-ok] (typed-row-matches-plain-branch-group? db query inputs sources rel row group registry)]
          (when (not match-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (when (not matched)
            (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true)))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        builder (query-relation-builder (slice rel.attrs 0))
        row 0]
    (while (< row rel.typed-rows)
      (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
        (when (not binding-ok)
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (when (not (binding-matches-not-group-with-rules-sources-and-fns? db (slice query.rules 0) sources group binding registry))
          (when (not (query-relation-builder-add-column-row! (addr builder) (slice rel.typed-columns 0) row))
            (delete binding.items)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false)))
        (delete binding.items))
      (set! row (+ row 1)))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: builder.tuples
                             typed-columns: builder.typed-columns
                             typed-rows: builder.typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-apply-not [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, group: Not-Group, registry: []Native-Query-Fn] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-not-typed db query inputs sources rel group registry)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (make [dynamic]Binding)]
    (for [tuple materialized]
      (when (not (binding-matches-not-group-with-rules-sources-and-fns? db (slice query.rules 0) sources group tuple registry))
        (arr.push! bindings tuple)))
    (let [out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
      (delete bindings)
      out)))

(defn simple-db-clause-or-group? [group: Or-Group] -> bool
  (when group.has-join
    (return false))
  (when (= (count group.branches) 0)
    (return false))
  (for [branch group.branches]
    (when (or branch.has-join
              (not (= (count branch.clauses) 1))
              (> (count branch.predicates) 0)
              (> (count branch.function-clauses) 0)
              (> (count branch.grounds) 0)
              (> (count branch.rule-calls) 0)
              (> (count branch.get-elses) 0)
              (> (count branch.get-somes) 0)
              (> (count branch.not-groups) 0))
      (return false)))
  true)

(defn plain-db-clause-or-group? [group: Or-Group] -> bool
  (when group.has-join
    (return false))
  (when (= (count group.branches) 0)
    (return false))
  (let [branch-index 0]
    (while (< branch-index (count group.branches))
      (let [branch group.branches[branch-index]]
        (when (not (plain-typed-branch-group? branch))
          (return false)))
      (set! branch-index (+ branch-index 1))))
  true)

(defn plain-typed-or-join-group? [group: Or-Group] -> bool
  (when (not group.has-join)
    (return false))
  (when (= (count group.branches) 0)
    (return false))
  (for [branch group.branches]
    (when (not (plain-typed-branch-group? branch))
      (return false)))
  true)

(defn query-relation-apply-plain-or-branch-typed [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, row: int, branch: Not-Group, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-plain-branch-pipeline-typed db query inputs sources rel row branch registry))

(defn append-typed-or-branch-row! [builder: ^Query-Relation-Builder, attrs: []string, db: DB, sources: []DB-Source, rel: Query-Relation, row: int, clause-value: Clause, stats: ^Query-Stats] -> [ok: bool, supported: bool]
  (let [clause-db db
        clause clause-value]
    (when clause-value.has-source
      (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
        (when (not source-ok)
          (return false false))
        (set! clause-db source-db)
        (set! clause (unsourced-clause clause-value))))
    (when (not (append-typed-bound-db-clause-scan-row! builder attrs clause-db rel row clause (all-datoms-current? clause-db) stats))
      (return false true))
    (return true true)))

(defn query-relation-apply-or-typed [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-or-group-output-vars! (addr output-vars) group)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (when (and (simple-db-clause-or-group? group)
               (not (or-group-has-source-input? query group)))
      (let [builder (query-relation-builder (slice attrs 0))
            stats (query-stats-empty)
            row 0]
        (while (< row rel.typed-rows)
          (for [branch group.branches]
            (let [[branch-ok branch-supported] (append-typed-or-branch-row! (addr builder) (slice attrs 0) db sources rel row branch.clauses[0] (addr stats))]
              (when (not branch-supported)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (when (not branch-ok)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true)))
    (when (plain-db-clause-or-group? group)
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (for [branch group.branches]
            (let [[branch-rel branch-ok] (query-relation-apply-plain-or-branch-typed db query inputs sources rel row branch registry)]
              (when (not branch-ok)
                (delete-query-relation branch-rel)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (let [branch-row 0]
                (while (< branch-row (query-relation-row-count branch-rel))
                  (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) branch-rel branch-row))
                    (delete-query-relation branch-rel)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))
                  (set! branch-row (+ branch-row 1))))
              (delete-query-relation branch-rel)))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true)))
    (when (plain-typed-or-join-group? group)
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (for [branch group.branches]
            (let [[branch-rel branch-ok] (query-relation-apply-plain-or-branch-typed db query inputs sources rel row branch registry)]
              (when (not branch-ok)
                (delete-query-relation branch-rel)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (let [branch-row 0]
                (while (< branch-row (query-relation-row-count branch-rel))
                  (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) branch-rel branch-row))
                    (delete-query-relation branch-rel)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))
                  (set! branch-row (+ branch-row 1))))
              (delete-query-relation branch-rel)))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true)))
    (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
          typed-rows 0
          row 0]
      (while (< row rel.typed-rows)
        (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
          (when (not binding-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-relation-columns typed-columns)
            (return (query-relation-empty) false))
          (for [branch group.branches]
            (let [branch-bindings (bindings-after-or-branch-with-rules-sources-and-fns db (slice query.rules 0) sources group branch binding registry)]
              (for [next branch-bindings]
                (if (binding-can-add-to-relation-columns? (slice attrs 0) (slice typed-columns 0) next)
                  (do
                    (add-binding-to-relation-columns! (slice attrs 0) (addr typed-columns) next)
                    (set! typed-rows (+ typed-rows 1)))
                  (do
                    (delete branch-bindings)
                    (delete binding.items)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-relation-columns typed-columns)
                    (return (query-relation-empty) false))))
              (delete branch-bindings)))
          (delete binding.items))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: (make [dynamic]Binding)
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-apply-or [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, group: Or-Group, registry: []Native-Query-Fn] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-or-typed db query inputs sources rel group registry)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (bindings-after-or-group-step-with-fns db sources (slice materialized 0) group registry)
        out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
    (delete bindings)
    out))

(defn typed-row-entity-value [rel: Query-Relation, row: int, name: string] -> [entity: u64, ok: bool]
  (let [[value value-ok] (query-relation-typed-row-value rel row name)]
    (when (not value-ok)
      (return 0 false))
    (case value.kind
      .Entity (return value.entity true)
      .Int (return (u64 value.int-value) true)
       (return 0 false))))

(defn typed-bound-clause-term-matches? [db: DB, rel: Query-Relation, row: int, attr: string, attr-static: bool, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .Var (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
           (if existing-ok
             (clause-value-equal? db attr existing actual)
             true))
    .Value (if attr-static
             (let [[resolved resolved-ok] (ref-entity-literal db attr term.value)]
               (if resolved-ok
                 (value-equal? resolved actual)
                 (value-equal? term.value actual)))
             (entity-id-value-equal? term.value actual))
    .LookupRef (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
                 (and lookup-ok (value-equal? (value-entity entity) actual)))
     false))

(defn typed-bound-optional-term-matches? [rel: Query-Relation, row: int, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .Var (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
           (if existing-ok
             (predicate-value-equal? existing actual)
             true))
    .Value (value-equal? term.value actual)
     false))

(defn typed-bound-entity-term-matches? [db: DB, rel: Query-Relation, row: int, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .LookupRef (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
                 (and lookup-ok (value-equal? (value-entity entity) actual)))
    .Var (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
           (if existing-ok
             (entity-value-equal? db existing actual)
             true))
    .Value (let [[entity entity-ok] (value-as-entity db term.value)]
             (when entity-ok
               (return (value-equal? entity actual)))
             (when (= term.value.kind .Keyword)
               (let [[ident-entity ident-ok] (schema-entity-for-attr db term.value.text)]
                 (return (and ident-ok (value-equal? (value-entity ident-entity) actual)))))
             (when (= term.value.kind .Int)
               (return (value-equal? (value-entity (u64 term.value.int-value)) actual)))
             (value-equal? term.value actual))
     false))

(defn typed-bound-attr-term-matches? [db: DB, rel: Query-Relation, row: int, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .Var (let [[existing existing-ok] (query-relation-typed-row-value rel row term.name)]
           (if existing-ok
             (predicate-value-equal? existing actual)
             true))
    .Value (let [[resolved resolved-ok] (resolve-attribute-value db term.value)]
             (and resolved-ok (value-equal? resolved actual)))
     false))

(defn unbound-clause-term-matches? [term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .Var true
    .Value (value-equal? term.value actual)
     false))

(defn unbound-clause-attr-term-matches? [db: DB, term: Term, actual: Value] -> bool
  (when (= term.kind .Value)
    (let [[resolved resolved-ok] (resolve-attribute-value db term.value)]
      (return (and resolved-ok (value-equal? resolved actual)))))
  (unbound-clause-term-matches? term actual))

(defn unbound-clause-optional-term-matches? [term: Term, actual: Value] -> bool
  (if (omitted-term? term)
    true
    (unbound-clause-term-matches? term actual)))

(defn unbound-clause-entity-term-matches? [db: DB, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .LookupRef (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
                 (and lookup-ok (value-equal? (value-entity entity) actual)))
    .Var true
    .Value (let [[entity entity-ok] (value-as-entity db term.value)]
             (when entity-ok
               (return (value-equal? entity actual)))
             (when (= term.value.kind .Keyword)
               (let [[ident-entity ident-ok] (schema-entity-for-attr db term.value.text)]
                 (return (and ident-ok (value-equal? (value-entity ident-entity) actual)))))
             (when (= term.value.kind .Int)
               (return (value-equal? (value-entity (u64 term.value.int-value)) actual)))
             (value-equal? term.value actual))
     false))

(defn unbound-clause-value-term-matches? [db: DB, attr: string, attr-static: bool, term: Term, actual: Value] -> bool
  (case term.kind
    .Wildcard true
    .LookupRef (let [[entity lookup-ok] (resolve-lookup-ref db term.lookup-attr term.lookup-value)]
                 (and lookup-ok (value-equal? (value-entity entity) actual)))
    .Var true
    .Value (if attr-static
             (let [[resolved resolved-ok] (ref-entity-literal db attr term.value)]
               (if resolved-ok
                 (value-equal? resolved actual)
                 (value-equal? term.value actual)))
             (entity-id-value-equal? term.value actual))
     false))

(defn unbound-datom-clause-values [datom: Datom, clause-value: Clause] -> [e-value: Value, a-value: Value, v-value: Value]
  (if (and (= clause-value.a.kind .Value)
           (= clause-value.a.value.kind .Keyword)
           (reverse-attr? clause-value.a.value.text)
           (= datom.v.kind .Entity))
    (return (value-entity datom.v.entity) clause-value.a.value (value-entity datom.e))
    (return (value-entity datom.e) (value-keyword datom.a) datom.v)))

(defn unbound-datom-clause-matches? [db: DB, datom: Datom, clause-value: Clause] -> bool
  (let [[e-value a-value v-value] (unbound-datom-clause-values datom clause-value)
        tx-value (datom-tx-value datom)
        op-value (value-bool datom.added)]
    (when (and (= clause-value.a.kind .Value)
               (= clause-value.a.value.kind .Keyword)
               (reverse-attr? clause-value.a.value.text))
      (when (not (= datom.v.kind .Entity))
        (return false))
      (let [forward-attr (forward-attr-for-reverse clause-value.a.value.text) :defer]
        (when (not (= datom.a forward-attr))
          (return false))))
    (if (and (= clause-value.a.kind .Value)
             (= clause-value.a.value.kind .Keyword)
             (reverse-attr? clause-value.a.value.text))
      (and (unbound-clause-entity-term-matches? db clause-value.e e-value)
           (unbound-clause-attr-term-matches? db clause-value.a a-value)
           (unbound-clause-entity-term-matches? db clause-value.v v-value)
           (unbound-clause-optional-term-matches? clause-value.tx-term tx-value)
           (unbound-clause-optional-term-matches? clause-value.op-term op-value)
           (typed-clause-repeated-vars-match? db clause-value e-value a-value v-value tx-value op-value))
      (and (unbound-clause-entity-term-matches? db clause-value.e e-value)
           (unbound-clause-attr-term-matches? db clause-value.a a-value)
           (unbound-clause-value-term-matches? db datom.a
                                               (and (= clause-value.a.kind .Value)
                                                    (= clause-value.a.value.kind .Keyword))
                                               clause-value.v v-value)
           (unbound-clause-optional-term-matches? clause-value.tx-term tx-value)
           (unbound-clause-optional-term-matches? clause-value.op-term op-value)
           (typed-clause-repeated-vars-match? db clause-value e-value a-value v-value tx-value op-value)))))

(defn unbound-datom-clause-var-value [datom: Datom, clause-value: Clause, name: string] -> [value: Value, ok: bool]
  (let [[e-value a-value v-value] (unbound-datom-clause-values datom clause-value)]
    (when (term-var-name? clause-value.e name)
      (return e-value true))
    (when (term-var-name? clause-value.a name)
      (return a-value true))
    (when (term-var-name? clause-value.v name)
      (return v-value true))
    (when (term-var-name? clause-value.tx-term name)
      (return (datom-tx-value datom) true))
    (when (term-var-name? clause-value.op-term name)
      (return (value-bool datom.added) true))
    (return (Value {}) false)))

(defn typed-same-var-term-agrees? [db: DB, name: string, term: Term, actual: Value, base: Value] -> bool
  (if (term-var-name? term name)
    (entity-value-equal? db actual base)
    true))

(defn typed-clause-var-agrees? [db: DB, clause-value: Clause, name: string, base: Value, e-value: Value, a-value: Value, v-value: Value, tx-value: Value, op-value: Value] -> bool
  (and (typed-same-var-term-agrees? db name clause-value.e e-value base)
       (typed-same-var-term-agrees? db name clause-value.a a-value base)
       (typed-same-var-term-agrees? db name clause-value.v v-value base)
       (typed-same-var-term-agrees? db name clause-value.tx-term tx-value base)
       (typed-same-var-term-agrees? db name clause-value.op-term op-value base)))

(defn typed-clause-repeated-vars-match? [db: DB, clause-value: Clause, e-value: Value, a-value: Value, v-value: Value, tx-value: Value, op-value: Value] -> bool
  (when (= clause-value.e.kind .Var)
    (when (not (typed-clause-var-agrees? db clause-value clause-value.e.name e-value e-value a-value v-value tx-value op-value))
      (return false)))
  (when (= clause-value.a.kind .Var)
    (when (not (typed-clause-var-agrees? db clause-value clause-value.a.name a-value e-value a-value v-value tx-value op-value))
      (return false)))
  (when (= clause-value.v.kind .Var)
    (when (not (typed-clause-var-agrees? db clause-value clause-value.v.name v-value e-value a-value v-value tx-value op-value))
      (return false)))
  (when (= clause-value.tx-term.kind .Var)
    (when (not (typed-clause-var-agrees? db clause-value clause-value.tx-term.name tx-value e-value a-value v-value tx-value op-value))
      (return false)))
  (when (= clause-value.op-term.kind .Var)
    (when (not (typed-clause-var-agrees? db clause-value clause-value.op-term.name op-value e-value a-value v-value tx-value op-value))
      (return false)))
  true)

(defn typed-datom-clause-matches? [db: DB, rel: Query-Relation, row: int, datom: Datom, clause-value: Clause] -> bool
  (let [tx-value (datom-tx-value datom)
        op-value (value-bool datom.added)]
    (when (and (= clause-value.a.kind .Value)
               (= clause-value.a.value.kind .Keyword)
               (reverse-attr? clause-value.a.value.text))
      (when (not (= datom.v.kind .Entity))
        (return false))
      (let [forward-attr (forward-attr-for-reverse clause-value.a.value.text) :defer
            e-value (value-entity datom.v.entity)
            a-value clause-value.a.value
            v-value (value-entity datom.e)]
        (return
          (and (= datom.a forward-attr)
               (typed-bound-entity-term-matches? db rel row clause-value.e e-value)
               (typed-bound-entity-term-matches? db rel row clause-value.v v-value)
               (typed-bound-optional-term-matches? rel row clause-value.tx-term tx-value)
               (typed-bound-optional-term-matches? rel row clause-value.op-term op-value)
               (typed-clause-repeated-vars-match? db clause-value e-value a-value v-value tx-value op-value)))))
    (let [e-value (value-entity datom.e)
          a-value (value-keyword datom.a)
          v-value datom.v]
      (and (typed-bound-entity-term-matches? db rel row clause-value.e e-value)
           (typed-bound-attr-term-matches? db rel row clause-value.a a-value)
           (typed-bound-clause-term-matches? db rel row datom.a
                                             (and (= clause-value.a.kind .Value)
                                                  (= clause-value.a.value.kind .Keyword))
                                             clause-value.v v-value)
           (typed-bound-optional-term-matches? rel row clause-value.tx-term tx-value)
           (typed-bound-optional-term-matches? rel row clause-value.op-term op-value)
           (typed-clause-repeated-vars-match? db clause-value e-value a-value v-value tx-value op-value)))))

(defn typed-bound-clause-var-value [rel: Query-Relation, row: int, clause-value: Clause, datom: Datom, name: string] -> [value: Value, ok: bool]
  (let [[existing existing-ok] (query-relation-typed-row-value rel row name)]
    (when existing-ok
      (return existing true)))
  (when (and (= clause-value.a.kind .Value)
             (= clause-value.a.value.kind .Keyword)
             (reverse-attr? clause-value.a.value.text))
    (when (term-var-name? clause-value.e name)
      (return (value-entity datom.v.entity) true))
    (when (term-var-name? clause-value.a name)
      (return clause-value.a.value true))
    (when (term-var-name? clause-value.v name)
      (return (value-entity datom.e) true))
    (when (term-var-name? clause-value.tx-term name)
      (return (datom-tx-value datom) true))
    (when (term-var-name? clause-value.op-term name)
      (return (value-bool datom.added) true))
    (return (Value {}) false))
  (when (term-var-name? clause-value.e name)
    (return (value-entity datom.e) true))
  (when (term-var-name? clause-value.a name)
    (return (value-keyword datom.a) true))
  (when (term-var-name? clause-value.v name)
    (return datom.v true))
  (when (term-var-name? clause-value.tx-term name)
    (return (datom-tx-value datom) true))
  (when (term-var-name? clause-value.op-term name)
    (return (value-bool datom.added) true))
  (return (Value {}) false))

(defn append-typed-bound-clause-row! [builder: ^Query-Relation-Builder, attrs: []string, rel: Query-Relation, row: int, clause-value: Clause, datom: Datom] -> bool
  (for [column index rel.typed-columns]
    (let [[value value-ok] (typed-relation-column-value column row)]
      (when (or (not value-ok)
                (not (relation-column-can-add? builder^.typed-columns[index] value)))
        (return false))))
  (for [attr index attrs]
    (when (not (query-relation-has-attr? rel attr))
      (let [[value value-ok] (typed-bound-clause-var-value rel row clause-value datom attr)]
        (when (or (not value-ok)
                  (not (relation-column-can-add? builder^.typed-columns[index] value)))
          (return false)))))
  (for [column index rel.typed-columns]
    (let [[value _] (typed-relation-column-value column row)]
      (discard (relation-column-add! (addr builder^.typed-columns[index]) value))))
  (for [attr index attrs]
    (when (not (query-relation-has-attr? rel attr))
      (let [[value _] (typed-bound-clause-var-value rel row clause-value datom attr)]
        (discard (relation-column-add! (addr builder^.typed-columns[index]) value)))))
  (set! builder^.typed-rows (+ builder^.typed-rows 1))
  true)

(defn query-relation-apply-bound-ea-clause-typed-with-op [db: DB, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (not clause-value.has-source)
                  (= clause-value.e.kind .Var)
                  (query-relation-has-attr? rel clause-value.e.name)
                  (not (query-relation-typed-entity-var-column-needs-semantic-match? rel clause-value.e.name))
                  (= clause-value.a.kind .Value)
                  (= clause-value.a.value.kind .Keyword)
                  (not (= clause-value.a.value.text ":db/ident"))
                  (not (reverse-attr? clause-value.a.value.text))))
    (return (query-relation-empty) false))
  (set! stats^.typed-index-scans (+ stats^.typed-index-scans 1))
  (let [attr clause-value.a.value.text
        attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.e "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.a "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.v "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.tx-term "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.op-term "")
    (let [builder (query-relation-builder (slice attrs 0))
          view (db-index-view db .EAVT)
          all-current (all-datoms-current? db)
          row 0]
      (set! stats^.clauses (+ stats^.clauses rel.typed-rows))
      (while (< row rel.typed-rows)
        (let [[entity entity-ok] (typed-row-entity-value rel row clause-value.e.name)]
          (when (not entity-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (let [base-low (lower-bound-index-view db view "eavt-ea" entity attr (Value {}))
                base-high (upper-bound-index-view db view "eavt-ea" entity attr (Value {}))
                [low high] (physical-op-tighten-resident-eavt-ea-value-range db view base-low base-high entity attr clause-value op rel row)]
            (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
            (let [i low]
              (while (< i high)
                (let [datom-index (db-index-view-at view i)
                      datom db.datoms[datom-index]]
                  (when (and (or all-current (datom-current-at? db datom-index))
                             (typed-bound-clause-term-matches? db rel row attr true clause-value.v datom.v)
                             (typed-bound-optional-term-matches? rel row clause-value.tx-term (datom-tx-value datom))
                             (typed-bound-optional-term-matches? rel row clause-value.op-term (value-bool datom.added))
                             (resident-clause-pushdown-matches? op rel row datom clause-value))
                    (when (not (append-typed-bound-clause-row! (addr builder) (slice attrs 0) rel row clause-value datom))
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                  (set! i (+ i 1))))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-bound-ea-clause-typed [db: DB, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-bound-ea-clause-typed-with-op db rel clause-value (Physical-Op {}) stats))

(defn query-relation-apply-bound-ea-clause-typed-with-sources-and-op [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (if clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when (not source-ok)
        (return (query-relation-empty) false))
      (let [[out out-ok] (query-relation-apply-bound-ea-clause-typed-with-op source-db rel (unsourced-clause clause-value) op stats)]
        (when out-ok
          (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
          (query-stats-observe-source-operator! stats))
        (return out out-ok)))
    (query-relation-apply-bound-ea-clause-typed-with-op db rel clause-value op stats)))

(defn query-relation-apply-bound-ea-clause-typed-with-sources [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-bound-ea-clause-typed-with-sources-and-op db sources rel clause-value (Physical-Op {}) stats))

(defn resident-clause-pushdown-value [rel: Query-Relation, row: int, datom: Datom, clause-value: Clause, name: string] -> [value: Value, ok: bool]
  (let [[existing existing-ok] (query-relation-typed-row-value rel row name)]
    (when existing-ok
      (return existing true)))
  (unbound-datom-clause-var-value datom clause-value name))

(defn resident-clause-pushdown-matches? [op: Physical-Op, rel: Query-Relation, row: int, datom: Datom, clause-value: Clause] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (resident-clause-pushdown-value rel row datom clause-value op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (query-relation-physical-pushdown-other-value rel row op)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn append-typed-bound-db-clause-scan-row-with-op! [builder: ^Query-Relation-Builder, attrs: []string, db: DB, rel: Query-Relation, row: int, clause-value: Clause, all-current: bool, op: Physical-Op, stats: ^Query-Stats] -> bool
  (let [scan (clause-index-scan-typed-row db rel row clause-value)]
    (defer (delete-clause-index-scan scan))
    (physical-op-tighten-resident-attr-value-scan! db (addr scan) clause-value op rel row)
    (let [scan-index scan.index]
      (while (< scan-index scan.high)
        (let [datom-index (clause-index-scan-datom-index scan scan-index)
              datom db.datoms[datom-index]]
          (when (clause-index-scan-candidate? scan datom)
            (set! stats^.clause-candidates (+ stats^.clause-candidates 1))
            (when (or all-current (datom-current-at? db datom-index))
              (when (typed-datom-clause-matches? db rel row datom clause-value)
                (when (and (resident-clause-pushdown-matches? op rel row datom clause-value)
                           (not (append-typed-bound-clause-row! builder attrs rel row clause-value datom)))
                  (return false))))))
        (set! scan-index (+ scan-index 1)))))
  true)

(defn append-typed-bound-db-clause-scan-row! [builder: ^Query-Relation-Builder, attrs: []string, db: DB, rel: Query-Relation, row: int, clause-value: Clause, all-current: bool, stats: ^Query-Stats] -> bool
  (append-typed-bound-db-clause-scan-row-with-op! builder attrs db rel row clause-value all-current (Physical-Op {}) stats))

(defn typed-row-matches-single-db-clause? [db: DB, sources: []DB-Source, rel: Query-Relation, row: int, clause-value: Clause] -> [matched: bool, ok: bool]
  (let [clause-db db
        clause clause-value]
    (when clause-value.has-source
      (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
        (when (not source-ok)
          (return false false))
        (set! clause-db source-db)
        (set! clause (unsourced-clause clause-value))))
    (let [scan (clause-index-scan-typed-row clause-db rel row clause)]
      (defer (delete-clause-index-scan scan))
      (let [scan-index scan.index
            all-current (all-datoms-current? clause-db)]
        (while (< scan-index scan.high)
          (let [datom-index (clause-index-scan-datom-index scan scan-index)
                datom clause-db.datoms[datom-index]]
            (when (and (clause-index-scan-candidate? scan datom)
                       (or all-current (datom-current-at? clause-db datom-index))
                       (typed-datom-clause-matches? clause-db rel row datom clause))
              (return true true)))
          (set! scan-index (+ scan-index 1)))))
    (return false true)))

(defn query-relation-apply-bound-db-clause-typed-scan-with-op [db: DB, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            clause-value.has-source)
    (return (query-relation-empty) false))
  (set! stats^.typed-index-scans (+ stats^.typed-index-scans 1))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.e "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.a "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.v "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.tx-term "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.op-term "")
    (let [builder (query-relation-builder (slice attrs 0))
          all-current (all-datoms-current? db)
          row 0]
      (while (< row rel.typed-rows)
        (set! stats^.clauses (+ stats^.clauses 1))
        (when (not (append-typed-bound-db-clause-scan-row-with-op! (addr builder) (slice attrs 0) db rel row clause-value all-current op stats))
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-bound-db-clause-typed-scan [db: DB, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-bound-db-clause-typed-scan-with-op db rel clause-value (Physical-Op {}) stats))

(defn query-relation-apply-bound-db-clause-typed-scan-with-sources-and-op [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (if clause-value.has-source
    (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
      (when (not source-ok)
        (return (query-relation-empty) false))
      (let [[out out-ok] (query-relation-apply-bound-db-clause-typed-scan-with-op source-db rel (unsourced-clause clause-value) op stats)]
        (when out-ok
          (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
          (query-stats-observe-source-operator! stats))
        (return out out-ok)))
    (query-relation-apply-bound-db-clause-typed-scan-with-op db rel clause-value op stats)))

(defn query-relation-apply-bound-db-clause-typed-scan-with-sources [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-bound-db-clause-typed-scan-with-sources-and-op db sources rel clause-value (Physical-Op {}) stats))

(defn query-relation-apply-bound-clause-typed-fallback [db: DB, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.e "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.a "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.v "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.tx-term "")
    (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.op-term "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
          (when (not binding-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (let [next-bindings (make [dynamic]Binding)]
            (append-bindings-after-clause-with-sources-profiled! (addr next-bindings) db sources clause-value binding stats)
            (delete binding.items)
            (for [next next-bindings]
              (when (not (query-relation-builder-add-binding! (addr builder) (slice attrs 0) next false))
                (delete next.items)
                (delete next-bindings)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false)))
            (delete next-bindings)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: true}) true))))

(defn append-typed-relation-source-row! [builder: ^Query-Relation-Builder, rel: Query-Relation, rel-row: int, positions: []int, clause-value: Clause, source-row: Value] -> bool
  (query-relation-builder-add-source-projection-row! builder (slice rel.typed-columns 0) rel-row positions clause-value.source-width source-row))

(defn query-relation-apply-source-input-clause-indexed-typed-with-op [source: Value, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [out: Query-Relation, ok: bool]
  (let [[key-position key-position-ok] (source-input-clause-bound-key-position rel clause-value)]
    (when (not key-position-ok)
      (return (query-relation-empty) false))
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          bucket-heads (make (map string int))
          next-indexes (make [dynamic]int (count source.items))]
      (arr.fill! next-indexes -1)
      (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.e "")
      (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.a "")
      (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.v "")
      (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.op-term "")
      (let [[positions positions-ok] (typed-relation-source-output-positions (slice attrs 0) rel clause-value)]
        (when (not positions-ok)
          (delete attrs)
          (delete attr-sources)
          (delete bucket-heads)
          (delete next-indexes)
          (return (query-relation-empty) false))
      (let [source-row-index (- (count source.items) 1)]
        (while (>= source-row-index 0)
          (when (direct-source-row-pushdown-matches? clause-value source.items[source-row-index] op)
            (let [[value value-ok] (source-row-position-value source.items[source-row-index] clause-value.source-width key-position)]
              (when value-ok
                (let [[key key-ok] (primitive-value-dedupe-key value)]
                  (when key-ok
                    (let [[head found] (mmap.get bucket-heads key)]
                      (when found
                        (set! next-indexes[source-row-index] head))
                      (mmap.assoc! bucket-heads key source-row-index)))))))
          (dec! source-row-index)))
      (let [builder (query-relation-builder (slice attrs 0))
            rel-row 0]
        (while (< rel-row rel.typed-rows)
          (let [[key key-ok] (query-relation-source-bound-row-key rel rel-row clause-value key-position)]
            (when (not key-ok)
              (delete attrs)
              (delete attr-sources)
              (delete bucket-heads)
              (delete next-indexes)
              (delete-query-relation-builder builder)
              (delete positions)
              (return (query-relation-empty) false))
            (let [[head found] (mmap.get bucket-heads key)]
              (when found
                (let [source-index head]
                  (while (>= source-index 0)
                    (let [source-row source.items[source-index]]
                      (when (and (typed-relation-source-row-matches? clause-value source-row rel rel-row)
                                 (typed-relation-source-row-pushdown-matches? rel rel-row clause-value source-row op))
                        (when (not (append-typed-relation-source-row! (addr builder) rel rel-row (slice positions 0) clause-value source-row))
                          (delete attrs)
                          (delete attr-sources)
                          (delete bucket-heads)
                          (delete next-indexes)
                          (delete positions)
                          (delete-query-relation-builder builder)
                          (return (query-relation-empty) false))))
                    (set! source-index next-indexes[source-index]))))))
          (set! rel-row (+ rel-row 1)))
        (delete bucket-heads)
        (delete next-indexes)
        (delete positions)
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))))

(defn query-relation-apply-source-input-clause-indexed-typed [source: Value, rel: Query-Relation, clause-value: Clause] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-source-input-clause-indexed-typed-with-op source rel clause-value (Physical-Op {})))

(defn query-relation-apply-source-input-clause-typed-with-op [query: Query, inputs: []Query-Input, rel: Query-Relation, clause-value: Clause, op: Physical-Op] -> [out: Query-Relation, ok: bool]
  (when (or (not rel.has-typed-columns)
            (not clause-value.has-source))
    (return (query-relation-empty) false))
  (let [[index found] (query-input-index-for-source query clause-value.source)]
    (when (not found)
      (return (query-relation-empty) false))
    (when (>= index (count inputs))
      (return (query-relation-empty) false))
    (let [[source source-ok] (query-input-source-value inputs[index])]
      (when (not (and source-ok (= source.kind .Vector)))
        (return (query-relation-empty) false))
      (let [[indexed indexed-ok] (query-relation-apply-source-input-clause-indexed-typed-with-op source rel clause-value op)]
        (when indexed-ok
          (return indexed true))
        (delete-query-relation indexed))
      (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
            attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.e "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.a "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.v "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.tx-term "")
        (append-clause-term-var-attr! (addr attrs) (addr attr-sources) clause-value.op-term "")
        (let [[positions positions-ok] (typed-relation-source-output-positions (slice attrs 0) rel clause-value)]
          (when (not positions-ok)
            (delete attrs)
            (delete attr-sources)
            (return (query-relation-empty) false))
        (let [builder (query-relation-builder (slice attrs 0))
              rel-row 0]
          (while (< rel-row rel.typed-rows)
            (for [source-row source.items]
              (when (and (typed-relation-source-row-matches? clause-value source-row rel rel-row)
                         (typed-relation-source-row-pushdown-matches? rel rel-row clause-value source-row op))
                (when (not (append-typed-relation-source-row! (addr builder) rel rel-row (slice positions 0) clause-value source-row))
                  (delete attrs)
                  (delete attr-sources)
                  (delete positions)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))
            (set! rel-row (+ rel-row 1)))
          (delete positions)
          (return (Query-Relation {attrs: attrs
                                   attr-sources: attr-sources
                                   attr-index: (query-relation-attr-index (slice attrs 0))
                                   tuples: builder.tuples
                                   typed-columns: builder.typed-columns
                                   typed-rows: builder.typed-rows
                                   has-typed-columns: builder.typed-ok}) true)))))))

(defn query-relation-apply-source-input-clause-typed [query: Query, inputs: []Query-Input, rel: Query-Relation, clause-value: Clause] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-source-input-clause-typed-with-op query inputs rel clause-value (Physical-Op {})))

(defn query-relation-apply-bound-clause-with-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, op: Physical-Op, stats: ^Query-Stats] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-source-input-clause-typed-with-op query inputs rel clause-value op)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [[typed typed-ok] (query-relation-apply-bound-ea-clause-typed-with-sources-and-op db sources rel clause-value op stats)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [[typed typed-ok] (query-relation-apply-bound-db-clause-typed-scan-with-sources-and-op db sources rel clause-value op stats)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [[typed typed-ok] (query-relation-apply-bound-clause-typed-fallback db sources rel clause-value stats)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [bindings (make [dynamic]Binding)]
    (let [materialized (query-relation-materialized-bindings rel) :defer]
      (query-stats-observe-materialization! stats (count materialized))
      (for [tuple materialized]
        (append-bindings-after-clause-with-sources-profiled! (addr bindings) db sources clause-value tuple stats))
    (let [out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
      (delete bindings)
      out))))

(defn query-relation-apply-bound-clause [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, clause-value: Clause, stats: ^Query-Stats] -> Query-Relation
  (query-relation-apply-bound-clause-with-op db query inputs sources rel clause-value (Physical-Op {}) stats))

(defn query-relation-clause-has-bound-var? [rel: Query-Relation, clause-value: Clause] -> bool
  (or (and (= clause-value.e.kind .Var)
           (query-relation-has-attr? rel clause-value.e.name))
      (and (= clause-value.a.kind .Var)
           (query-relation-has-attr? rel clause-value.a.name))
      (and (= clause-value.v.kind .Var)
           (query-relation-has-attr? rel clause-value.v.name))
      (and (= clause-value.tx-term.kind .Var)
           (query-relation-has-attr? rel clause-value.tx-term.name))
      (and (= clause-value.op-term.kind .Var)
           (query-relation-has-attr? rel clause-value.op-term.name))))

(defn query-relation-should-bind-clause? [rel: Query-Relation, clause-value: Clause] -> bool
  (and (> (count rel.attrs) 0)
       (query-relation-clause-has-bound-var? rel clause-value)
       (<= (query-relation-row-count rel) 65536)))

(defn physical-op-scan-has-bound-pushdown-input? [rel: Query-Relation, op: Physical-Op] -> bool
  (and op.has-pushdown-scalar
       (= op.pushdown-scalar-requirement.kind .VarVarCompare)
       (query-relation-has-attr? rel op.pushdown-scalar-requirement.other-var)
       (<= (query-relation-row-count rel) 65536)))

(defn rule-body-relation-materializable? [rule: Rule] -> bool
  (when (or (> (count rule.predicates) 0)
            (> (count rule.get-elses) 0)
            (> (count rule.get-somes) 0)
            (> (count rule.grounds) 0)
            (> (count rule.not-groups) 0)
            (> (count rule.or-groups) 0))
    (return false))
  (for [function rule.function-clauses]
    (when (not (= function.op "fulltext"))
      (return false)))
  (for [clause-value rule.clauses]
    (when clause-value.has-source
      (return false)))
  (for [call rule.rule-calls]
    (when call.has-source
      (return false)))
  (for [step rule.body-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Function)
                   (= step.kind .RuleCall)))
      (return false)))
  true)

(defn rule-call-can-materialize-relation? [plan: Rule-Call-Plan, call: Rule-Call] -> bool
  (and (not call.has-source)
       (not plan.recursive)
       (not plan.linear-transitive)
       (not plan.alternating-transitive)
       (> (count plan.rules) 0)))

(defn query-relation-project-rule-call [rel: Query-Relation, rule: Rule, call: Rule-Call] -> Query-Relation
  (when (not (= (count rule.params) (count call.args)))
    (return (query-relation-empty)))
  (let [bindings (make [dynamic]Binding)
        seen (set.empty string)
        materialized (query-relation-materialized-bindings rel) :defer]
    (defer (delete seen))
    (for [tuple materialized]
      (let [out (Binding {})
            ok true]
        (for [param index rule.params]
          (when ok
            (let [[value value-ok] (binding-lookup tuple param)]
              (if value-ok
                (let [arg call.args[index]]
                  (case arg.kind
                    .Var
                      (let [[next bind-ok] (binding-with-value out arg.name value)]
                        (set! out next)
                        (set! ok bind-ok))
                    .Value
                      (set! ok (predicate-value-equal? value arg.value))
                    .Wildcard
                      (discard value)

                      (set! ok false)))
                (set! ok false)))))
        (when ok
          (let [[key key-ok] (binding-dedupe-key out)]
            (if key-ok
              (let [already-seen (set.contains? seen key)]
                (if already-seen
                  (delete out.items)
                  (do
                    (set.add! seen key)
                    (arr.push! bindings out))))
              (if (binding-exists? (slice bindings 0) out)
                (delete out.items)
                (arr.push! bindings out)))))
        (when (not ok)
          (delete out.items))))
    (let [projected (query-relation-from-bindings (slice bindings 0))]
      (delete bindings)
      projected)))

(defn rule-call-distinct-var-projection? [rule: Rule, call: Rule-Call] -> bool
  (when (not (= (count rule.params) (count call.args)))
    (return false))
  (let [seen (set.empty string)]
    (defer (delete seen))
    (for [arg call.args]
      (when (not (= arg.kind .Var))
        (return false))
      (when (set.contains? seen arg.name)
        (return false))
      (set.add! seen arg.name))
    true))

(defn append-projected-rule-call-bindings-fast! [out: ^[dynamic]Binding, rel: Query-Relation, rule: Rule, call: Rule-Call] -> bool
  (when (not (and rel.has-typed-columns
                  (rule-call-distinct-var-projection? rule call)))
    (return false))
  (let [param-indexes (make [dynamic]int 0 (count rule.params)) :defer]
    (for [param rule.params]
      (let [[column-index column-ok] (query-relation-attr-index-lookup rel param)]
        (when (not column-ok)
          (return false))
        (arr.push! param-indexes column-index)))
    (let [row 0]
      (while (< row rel.typed-rows)
        (let [items (make [dynamic]Var-Binding 0 (count call.args))]
          (for [arg arg-index call.args]
            (let [[value value-ok] (typed-relation-column-value rel.typed-columns[param-indexes[arg-index]] row)]
              (when (not value-ok)
                (delete items)
                (return false))
              (arr.push! items (Var-Binding {name: arg.name value: value}))))
          (arr.push! out^ (Binding {items: items})))
        (set! row (+ row 1))))
    true))

(defn append-projected-rule-call-bindings! [out: ^[dynamic]Binding, rel: Query-Relation, rule: Rule, call: Rule-Call]
  (when (append-projected-rule-call-bindings-fast! out rel rule call)
    (return))
  (let [projected (query-relation-project-rule-call rel rule call)]
    (let [materialized (query-relation-materialized-bindings projected) :defer]
      (for [binding materialized]
        (arr.push! out^ (clone-binding binding))))
    (delete-query-relation projected)))

(defn accumulate-projected-rule-call-relation! [out-bindings: ^[dynamic]Binding, out-rel: ^Query-Relation, has-out-rel: ^bool, out-rel-typed: ^bool, seen: (ptr (map string (struct {}))), rel: Query-Relation, rule: Rule, call: Rule-Call]
  (let [[projected projected-ok] (query-relation-project-rule-call-typed rel rule call)]
    (when projected-ok
      (when (query-relation-accumulate-typed-unique! out-bindings out-rel has-out-rel out-rel-typed seen projected)
        (delete-query-relation projected)
        (return))
      (delete-query-relation projected)))
  (query-relation-flush-typed-accumulator! out-bindings out-rel has-out-rel out-rel-typed)
  (append-projected-rule-call-bindings! out-bindings rel rule call))

(defn query-relation-project-rule-call-typed-general [rel: Query-Relation, rule: Rule, call: Rule-Call, param-indexes: []int] -> [projected: Query-Relation, ok: bool]
  (let [attrs (make [dynamic]string)
        attr-sources (make [dynamic]string)]
    (for [arg arg-index call.args]
      (when (= arg.kind .Var)
        (append-var-binding-attr! (addr attrs) (addr attr-sources) arg.name rel.attr-sources[param-indexes[arg-index]])))
    (let [attr-index (query-relation-attr-index (slice attrs 0))
          output-indexes (make [dynamic]int 0 (count call.args))]
      (for [arg call.args]
        (if (= arg.kind .Var)
          (let [[output-index output-ok] (mmap.get attr-index arg.name)]
            (when (not output-ok)
              (delete attrs)
              (delete attr-sources)
              (delete attr-index)
              (delete output-indexes)
              (return (query-relation-empty) false))
            (arr.push! output-indexes output-index))
          (arr.push! output-indexes -1)))
    (let [typed-columns (relation-columns-for-attrs (slice attrs 0))
          seen (set.empty string)
          values (make [dynamic]Value 0 (count attrs)) :defer
          filled (make [dynamic]bool 0 (count attrs)) :defer
          typed-rows 0
          row 0]
      (defer (delete seen))
      (for [_ attrs]
        (arr.push! values (value-nil))
        (arr.push! filled false))
      (while (< row rel.typed-rows)
        (let [ok true]
          (arr.fill! values (value-nil))
          (arr.fill! filled false)
          (for [arg arg-index call.args]
            (when ok
              (let [[value value-ok] (typed-relation-column-value rel.typed-columns[param-indexes[arg-index]] row)]
                (if value-ok
                  (case arg.kind
                    .Var
                      (let [output-index output-indexes[arg-index]]
                        (if filled[output-index]
                          (set! ok (predicate-value-equal? values[output-index] value))
                          (do
                            (set! values[output-index] value)
                            (set! filled[output-index] true))))
                    .Value
                      (set! ok (predicate-value-equal? value arg.value))
                    .Wildcard
                      (discard value)
                    .LookupRef
                      (set! ok false)

                      (set! ok false))
                  (set! ok false)))))
          (when ok
            (for [filled-value filled]
              (when (not filled-value)
                (set! ok false))))
          (when ok
            (let [[key key-ok] (row-values-dedupe-key (slice values 0))]
              (when (not key-ok)
                (delete attrs)
                (delete attr-sources)
                (delete attr-index)
                (delete output-indexes)
                (delete-relation-columns typed-columns)
                (return (query-relation-empty) false))
              (when (not (set.contains? seen key))
                (set.add! seen key)
                (for [value index values]
                  (when (not (relation-column-can-add? typed-columns[index] value))
                    (delete attrs)
                    (delete attr-sources)
                    (delete attr-index)
                    (delete output-indexes)
                    (delete-relation-columns typed-columns)
                    (return (query-relation-empty) false)))
                (for [value index values]
                  (discard (relation-column-add! (addr typed-columns[index]) value)))
                (set! typed-rows (+ typed-rows 1))))))
        (set! row (+ row 1)))
      (delete output-indexes)
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: attr-index
                               tuples: (make [dynamic]Binding)
                               typed-columns: typed-columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true)))))

(defn query-relation-project-rule-call-typed [rel: Query-Relation, rule: Rule, call: Rule-Call] -> [projected: Query-Relation, ok: bool]
  (when (not (and rel.has-typed-columns
                  (= (count rule.params) (count call.args))))
    (return (query-relation-empty) false))
  (let [attrs (make [dynamic]string 0 (count call.args))
        attr-sources (make [dynamic]string 0 (count call.args))
        tuples (make [dynamic]Binding)
        typed-columns (make [dynamic]Relation-Column 0 (count call.args))
        param-indexes (make [dynamic]int 0 (count rule.params))]
    (for [param rule.params]
      (let [[column-index column-ok] (query-relation-attr-index-lookup rel param)]
        (when (not column-ok)
          (delete attrs)
          (delete attr-sources)
          (delete tuples)
          (delete-relation-columns typed-columns)
          (delete param-indexes)
          (return (query-relation-empty) false))
        (arr.push! param-indexes column-index)))
    (when (not (rule-call-distinct-var-projection? rule call))
      (delete attrs)
      (delete attr-sources)
      (delete tuples)
      (delete-relation-columns typed-columns)
      (let [[general general-ok] (query-relation-project-rule-call-typed-general rel rule call (slice param-indexes 0))]
        (delete param-indexes)
        (return general general-ok)))
    (for [arg arg-index call.args]
      (arr.push! attrs arg.name)
      (arr.push! attr-sources rel.attr-sources[param-indexes[arg-index]])
      (arr.push! typed-columns (clone-relation-column rel.typed-columns[param-indexes[arg-index]])))
    (delete param-indexes)
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: tuples
                             typed-columns: typed-columns
                             typed-rows: rel.typed-rows
                             has-typed-columns: true}) true)))

(defstruct Materialized-Rule-Cache-Entry {
  name: string
  rel: Query-Relation
})

(defn delete-materialized-rule-cache-entry [entry: Materialized-Rule-Cache-Entry]
  (delete-query-relation entry.rel))

(defn delete-materialized-rule-cache [cache: [dynamic]Materialized-Rule-Cache-Entry]
  (for [entry cache]
    (delete-materialized-rule-cache-entry entry))
  (delete cache))

(defn materialized-rule-cache-index [cache: []Materialized-Rule-Cache-Entry, name: string] -> [index: int, ok: bool]
  (for [entry index cache]
    (when (= entry.name name)
      (return index true)))
  (return 0 false))

(defn materialized-rule-cache-store! [cache: ^[dynamic]Materialized-Rule-Cache-Entry, name: string, rel: Query-Relation]
  (let [[_ exists] (materialized-rule-cache-index (slice cache^ 0) name)]
    (when exists
      (return)))
  (arr.push! cache^ (Materialized-Rule-Cache-Entry {name: name rel: (query-relation-copy rel)})))

(defn value-as-db-entity [value: Value] -> [entity: u64, ok: bool]
  (case value.kind
    .Entity (return value.entity true)
    .Int (return (u64 value.int-value) true)
     (return 0 false)))

(defn query-relation-from-derived-edge-rule [db: DB, rule: Rule, left-attr: string, right-attr: string, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (= (count rule.params) 2))
    (return (query-relation-empty) false))
  (let [bindings (make [dynamic]Binding)
        columns (relation-columns-for-attrs (slice rule.params 0))
        typed-rows 0
        seen (set.empty string)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 left-attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 left-attr (Value {}))
        all-current (all-datoms-current? db)
        i low]
    (defer (delete seen))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (or all-current (datom-current-at? db datom-index))
          (let [[target-entity target-ok] (value-as-db-entity datom.v)]
            (when target-ok
              (let [value (Value {})
                    value-ok false]
                (if all-current
                  (let [[found-value found-ok] (cardinality-one-value-fast-all-current db target-entity right-attr)]
                    (set! value found-value)
                    (set! value-ok found-ok))
                  (let [[found-value found-ok] (pull-attr-value db target-entity right-attr)]
                    (set! value found-value)
                    (set! value-ok found-ok)))
                (when value-ok
                  (when (not (append-two-param-relation-row! (addr columns) (addr typed-rows) (addr seen) (value-entity datom.e) value))
                    (delete bindings)
                    (delete-relation-columns columns)
                    (return (query-relation-empty) false))))))))
      (set! i (+ i 1)))
    (let [attrs ([dynamic]string [rule.params[0] rule.params[1]])
          attr-sources ([dynamic]string ["" ""])]
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: bindings
                               typed-columns: columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true))))

(defn rule-two-attr-same-entity [rule: Rule] -> [first-attr: string, second-attr: string, ok: bool]
  (when (not (and (= (count rule.params) 2)
                  (= (count rule.clauses) 2)
                  (= (count rule.rule-calls) 0)
                  (rule-has-only-plain-clauses-and-calls? rule)))
    (return "" "" false))
  (let [left rule.clauses[0]
        right rule.clauses[1]
        [left-attr left-attr-ok] (clause-attr-keyword left)
        [right-attr right-attr-ok] (clause-attr-keyword right)]
    (when (not (and left-attr-ok right-attr-ok
                    (= left.e.kind .Var)
                    (= right.e.kind .Var)
                    (= left.e.name right.e.name)))
      (return "" "" false))
    (when (and (term-var-name? left.v rule.params[0])
               (term-var-name? right.v rule.params[1]))
      (return left-attr right-attr true))
    (when (and (term-var-name? right.v rule.params[0])
               (term-var-name? left.v rule.params[1]))
      (return right-attr left-attr true))
    (return "" "" false)))

(defn two-param-row-key [first-value: Value, second-value: Value] -> [key: string, ok: bool]
  (let [[first-key first-ok] (primitive-value-dedupe-key first-value)]
    (when (not first-ok)
      (return "" false))
    (let [[second-key second-ok] (primitive-value-dedupe-key second-value)]
      (when (not second-ok)
        (return "" false))
      (return (fmt.tprintf "%d:%s;%d:%s" (count first-key) first-key (count second-key) second-key) true))))

(defn append-two-param-relation-row! [columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), first-value: Value, second-value: Value] -> bool
  (let [[key key-ok] (two-param-row-key first-value second-value)]
    (when (not key-ok)
      (return false))
    (when (set.contains? seen^ key)
      (return true))
    (when (not (and (relation-column-can-add? columns^[0] first-value)
                    (relation-column-can-add? columns^[1] second-value)))
      (return false))
    (set.add! seen^ key)
    (discard (relation-column-add! (addr columns^[0]) first-value))
    (discard (relation-column-add! (addr columns^[1]) second-value))
    (set! rows^ (+ rows^ 1))
    true))

(defn rule-attr-param-distinct-predicate? [rule: Rule, left-param: string, right-param: string] -> bool
  (when (= (count rule.predicates) 0)
    (return true))
  (when (not (= (count rule.predicates) 1))
    (return false))
  (let [predicate rule.predicates[0]]
    (when (not (or (= predicate.op "!=")
                   (= predicate.op "not=")))
      (return false))
    (when (not (= (count predicate.terms) 2))
      (return false))
    (or (and (term-var-name? predicate.terms[0] left-param)
             (term-var-name? predicate.terms[1] right-param))
        (and (term-var-name? predicate.terms[0] right-param)
             (term-var-name? predicate.terms[1] left-param)))))

(defn attr-param-two-values-clause? [clause-value: Clause, entity-var: string, attr-param: string, value-param: string] -> bool
  (and (not clause-value.has-source)
       (term-wildcard? clause-value.tx-term)
       (term-wildcard? clause-value.op-term)
       (term-var-name? clause-value.e entity-var)
       (term-var-name? clause-value.a attr-param)
       (term-var-name? clause-value.v value-param)))

(defn rule-attr-param-two-values-same-entity [rule: Rule, call: Rule-Call] -> [attr: string, ok: bool]
  (when (not (and (= (count rule.params) 3)
                  (= (count call.args) 3)
                  (= call.args[0].kind .Value)
                  (= call.args[0].value.kind .Keyword)
                  (= (count rule.clauses) 2)
                  (= (count rule.rule-calls) 0)
                  (= (count rule.function-clauses) 0)
                  (= (count rule.get-elses) 0)
                  (= (count rule.get-somes) 0)
                  (= (count rule.grounds) 0)
                  (= (count rule.not-groups) 0)
                  (= (count rule.or-groups) 0)))
    (return "" false))
  (let [attr-param rule.params[0]
        left-param rule.params[1]
        right-param rule.params[2]
        first rule.clauses[0]
        second rule.clauses[1]]
    (when (not (rule-attr-param-distinct-predicate? rule left-param right-param))
      (return "" false))
    (when (not (and (= first.e.kind .Var)
                    (= second.e.kind .Var)
                    (= first.e.name second.e.name)))
      (return "" false))
    (let [entity-var first.e.name]
      (if (and (attr-param-two-values-clause? first entity-var attr-param left-param)
               (attr-param-two-values-clause? second entity-var attr-param right-param))
        (return call.args[0].value.text true)
        (if (and (attr-param-two-values-clause? first entity-var attr-param right-param)
                 (attr-param-two-values-clause? second entity-var attr-param left-param))
          (return call.args[0].value.text true)
          (return "" false))))))

(defn append-attr-param-two-values-row! [columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), attr: string, left-value: Value, right-value: Value] -> bool
  (when (predicate-value-equal? left-value right-value)
    (return true))
  (let [[key key-ok] (two-param-row-key left-value right-value)]
    (when (not key-ok)
      (return false))
    (when (set.contains? seen^ key)
      (return true))
    (when (not (and (relation-column-can-add? columns^[0] (value-keyword attr))
                    (relation-column-can-add? columns^[1] left-value)
                    (relation-column-can-add? columns^[2] right-value)))
      (return false))
    (set.add! seen^ key)
    (discard (relation-column-add! (addr columns^[0]) (value-keyword attr)))
    (discard (relation-column-add! (addr columns^[1]) left-value))
    (discard (relation-column-add! (addr columns^[2]) right-value))
    (set! rows^ (+ rows^ 1))
    true))

(defn append-attr-param-two-values-group! [columns: ^[dynamic]Relation-Column, rows: ^int, seen: (ptr (map string (struct {}))), attr: string, values: []Value] -> bool
  (let [left-index 0]
    (while (< left-index (count values))
      (let [right-index 0]
        (while (< right-index (count values))
          (when (not (= left-index right-index))
            (when (not (append-attr-param-two-values-row! columns rows seen attr values[left-index] values[right-index]))
              (return false)))
          (set! right-index (+ right-index 1))))
      (set! left-index (+ left-index 1))))
  true)

(defn query-relation-from-attr-param-two-values-same-entity-rule [db: DB, rule: Rule, attr: string, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (let [attrs ([dynamic]string [rule.params[0] rule.params[1] rule.params[2]])
        attr-sources ([dynamic]string ["" "" ""])
        columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0
        seen (set.empty string)
        values (make [dynamic]Value)
        view (db-index-view db .AEVT)
        low (lower-bound-index-view db view "aevt" 0 attr (Value {}))
        high (upper-bound-index-view db view "aevt" 0 attr (Value {}))
        all-current (all-datoms-current? db)
        current-entity: u64 0
        has-current false
        i low]
    (defer (delete seen))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- high low)))
    (while (< i high)
      (let [datom-index (db-index-view-at view i)
            datom db.datoms[datom-index]]
        (when (or all-current (datom-current-at? db datom-index))
          (when (and has-current (not (= datom.e current-entity)))
            (when (not (append-attr-param-two-values-group! (addr columns) (addr typed-rows) (addr seen) attr (slice values 0)))
              (delete values)
              (delete-relation-columns columns)
              (delete attrs)
              (delete attr-sources)
              (return (query-relation-empty) false))
            (delete values)
            (set! values (make [dynamic]Value)))
          (set! current-entity datom.e)
          (set! has-current true)
          (arr.push! values datom.v)))
      (set! i (+ i 1)))
    (when has-current
      (when (not (append-attr-param-two-values-group! (addr columns) (addr typed-rows) (addr seen) attr (slice values 0)))
        (delete values)
        (delete-relation-columns columns)
        (delete attrs)
        (delete attr-sources)
        (return (query-relation-empty) false)))
    (delete values)
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-two-attr-same-entity-rule [db: DB, rule: Rule, first-attr: string, second-attr: string, stats: ^Query-Stats] -> [rel: Query-Relation, ok: bool]
  (when (not (and (schema-cardinality-one? db first-attr)
                  (schema-cardinality-one? db second-attr)))
    (return (query-relation-empty) false))
  (let [bindings (make [dynamic]Binding)
        columns (relation-columns-for-attrs (slice rule.params 0))
        typed-rows 0
        seen (set.empty string)
        view (db-index-view db .AEVT)
        first-low (lower-bound-index-view db view "aevt" 0 first-attr (Value {}))
        first-high (upper-bound-index-view db view "aevt" 0 first-attr (Value {}))
        second-low (lower-bound-index-view db view "aevt" 0 second-attr (Value {}))
        second-high (upper-bound-index-view db view "aevt" 0 second-attr (Value {}))
        all-current (all-datoms-current? db)]
    (defer (delete seen))
    (set! stats^.clause-candidates (+ stats^.clause-candidates (- first-high first-low) (- second-high second-low)))
    (if all-current
      (let [first-i first-low
            second-i second-low]
        (while (and (< first-i first-high) (< second-i second-high))
          (let [first-datom db.datoms[(db-index-view-at view first-i)]
                second-datom db.datoms[(db-index-view-at view second-i)]]
            (cond
              (< first-datom.e second-datom.e)
                (set! first-i (+ first-i 1))
              (> first-datom.e second-datom.e)
                (set! second-i (+ second-i 1))
              :else
                (do
                  (when (not (append-two-param-relation-row! (addr columns) (addr typed-rows) (addr seen) first-datom.v second-datom.v))
                    (delete bindings)
                    (delete-relation-columns columns)
                    (return (query-relation-empty) false))
                  (set! first-i (+ first-i 1))
                  (set! second-i (+ second-i 1)))))))
      (let [second-values (current-entity-attr-values db second-attr stats)
            i first-low]
        (defer (delete second-values))
        (while (< i first-high)
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (datom-current-at? db datom-index)
              (let [[second-value second-ok] (mmap.get second-values datom.e)]
                (when second-ok
                  (when (not (append-two-param-relation-row! (addr columns) (addr typed-rows) (addr seen) datom.v second-value))
                    (delete bindings)
                    (delete-relation-columns columns)
                    (return (query-relation-empty) false))))))
          (set! i (+ i 1)))))
    (let [attrs ([dynamic]string [rule.params[0] rule.params[1]])
          attr-sources ([dynamic]string ["" ""])]
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: bindings
                               typed-columns: columns
                               typed-rows: typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-from-materialized-rule-call [db: DB, sources: []DB-Source, rules: []Rule, plan: Rule-Call-Plan, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats, depth: int, cache: ^[dynamic]Materialized-Rule-Cache-Entry] -> [rel: Query-Relation, ok: bool]
  (when (or (> depth 8)
            (not (rule-call-can-materialize-relation? plan call)))
    (return (query-relation-empty) false))
  (let [out-bindings (make [dynamic]Binding)
        out-rel (query-relation-empty)
        has-out-rel false
        out-rel-typed true
        seen (set.empty string)]
    (defer (delete seen))
    (when (= (count plan.rules) 1)
      (let [[cached-index cached-ok] (materialized-rule-cache-index (slice cache^ 0) call.name)]
        (when cached-ok
          (let [[projected projected-ok] (query-relation-project-rule-call-typed cache^[cached-index].rel plan.rules[0] call)]
            (when projected-ok
              (delete out-bindings)
              (delete-query-relation out-rel)
              (return projected true))
            (delete-query-relation projected))
          (accumulate-projected-rule-call-relation! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) (addr seen) cache^[cached-index].rel plan.rules[0] call)
          (let [unique (unique-bindings (slice out-bindings 0))
                out (query-relation-from-bindings (slice unique 0))]
            (delete out-bindings)
            (delete-query-relation out-rel)
            (delete unique)
            (return out true)))))
    (for [rule plan.rules]
      (when (= rule.name call.name)
        (let [[attr-param attr-param-ok] (rule-attr-param-two-values-same-entity rule call)]
          (when attr-param-ok
            (let [[attr-param-rel attr-param-built] (query-relation-from-attr-param-two-values-same-entity-rule db rule attr-param stats)]
              (when attr-param-built
                (when (= (count plan.rules) 1)
                  (materialized-rule-cache-store! cache call.name attr-param-rel))
                (when (= (count plan.rules) 1)
                  (let [[projected projected-ok] (query-relation-project-rule-call-typed attr-param-rel rule call)]
                    (when projected-ok
                      (delete out-bindings)
                      (delete-query-relation out-rel)
                      (delete-query-relation attr-param-rel)
                      (return projected true))
                    (delete-query-relation projected)))
                (accumulate-projected-rule-call-relation! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) (addr seen) attr-param-rel rule call)
                (delete-query-relation attr-param-rel)
                (continue))
              (delete-query-relation attr-param-rel))))
        (when (not (rule-body-relation-materializable? rule))
          (delete out-bindings)
          (delete-query-relation out-rel)
          (return (query-relation-empty) false))
        (let [[left-attr right-attr derived-ok] (rule-two-hop-derived-edge rules rule.name)]
          (when derived-ok
            (let [[derived derived-built] (query-relation-from-derived-edge-rule db rule left-attr right-attr stats)]
              (when derived-built
                (when (= (count plan.rules) 1)
                  (materialized-rule-cache-store! cache call.name derived))
                (when (= (count plan.rules) 1)
                  (let [[projected projected-ok] (query-relation-project-rule-call-typed derived rule call)]
                    (when projected-ok
                      (delete out-bindings)
                      (delete-query-relation out-rel)
                      (delete-query-relation derived)
                      (return projected true))
                    (delete-query-relation projected)))
                (accumulate-projected-rule-call-relation! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) (addr seen) derived rule call)
                (delete-query-relation derived)
                (continue))
              (delete-query-relation derived))))
        (let [[first-attr second-attr two-attr-ok] (rule-two-attr-same-entity rule)]
          (when two-attr-ok
            (let [[two-attr-rel two-attr-built] (query-relation-from-two-attr-same-entity-rule db rule first-attr second-attr stats)]
              (when two-attr-built
                (when (= (count plan.rules) 1)
                  (materialized-rule-cache-store! cache call.name two-attr-rel))
                (when (= (count plan.rules) 1)
                  (let [[projected projected-ok] (query-relation-project-rule-call-typed two-attr-rel rule call)]
                    (when projected-ok
                      (delete out-bindings)
                      (delete-query-relation out-rel)
                      (delete-query-relation two-attr-rel)
                      (return projected true))
                    (delete-query-relation projected)))
                (accumulate-projected-rule-call-relation! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) (addr seen) two-attr-rel rule call)
                (delete-query-relation two-attr-rel)
                (continue))
              (delete-query-relation two-attr-rel))))
        (let [current (query-relation-singleton)]
          (if (> (count rule.body-steps) 0)
            (for [step rule.body-steps]
              (when (= step.kind .Clause)
                (let [clause-rel (query-relation-from-db-clause db rule.clauses[step.index] "")
                      joined (query-relation-join db sources current clause-rel)]
                  (set! stats^.steps (+ stats^.steps 1))
                  (set! stats^.clauses (+ stats^.clauses 1))
                  (set! stats^.clause-candidates (+ stats^.clause-candidates (query-relation-row-count clause-rel)))
                  (delete-query-relation current)
                  (delete-query-relation clause-rel)
                  (set! current joined)))
              (when (= step.kind .Function)
                (let [function rule.function-clauses[step.index]
                      db-alias db
                      source (resident-db-read-source (addr db-alias))
                      materialized (query-relation-materialized-bindings current)
                      [function-bindings function-ok _] (db-read-source-bindings-after-fulltext-with-sources source ([]DB-Read-Named-Source []) (slice materialized 0) function)]
                  (delete materialized)
                  (when (not function-ok)
                    (delete-query-relation current)
                    (db-read-source-delete-bindings-owned function-bindings)
                    (delete out-bindings)
                    (delete-query-relation out-rel)
                    (return (query-relation-empty) false))
                  (let [function-rel (query-relation-from-bindings-inheriting-sources (slice function-bindings 0) current)]
                    (db-read-source-delete-bindings-owned function-bindings)
                    (delete-query-relation current)
                    (set! current function-rel)
                    (set! stats^.steps (+ stats^.steps 1)))))
              (when (= step.kind .RuleCall)
                (let [inner-call rule.rule-calls[step.index]
                      inner-plan (rule-call-plan rules inner-call.name)
                      [inner-rel inner-ok] (query-relation-from-materialized-rule-call db sources rules inner-plan inner-call registry stats (+ depth 1) cache)]
                  (delete-rule-call-plan inner-plan)
                  (when (not inner-ok)
                    (delete-query-relation current)
                    (delete-query-relation inner-rel)
                    (delete out-bindings)
                    (delete-query-relation out-rel)
                    (return (query-relation-empty) false))
                  (let [joined (query-relation-join db sources current inner-rel)]
                    (set! stats^.rule-calls (+ stats^.rule-calls 1))
                    (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
                    (delete-query-relation current)
                    (delete-query-relation inner-rel)
                    (set! current joined)))))
            (do
              (for [clause-value rule.clauses]
                (let [clause-rel (query-relation-from-db-clause db clause-value "")
                      joined (query-relation-join db sources current clause-rel)]
                  (set! stats^.steps (+ stats^.steps 1))
                  (set! stats^.clauses (+ stats^.clauses 1))
                  (set! stats^.clause-candidates (+ stats^.clause-candidates (query-relation-row-count clause-rel)))
                  (delete-query-relation current)
                  (delete-query-relation clause-rel)
                  (set! current joined)))
              (for [inner-call rule.rule-calls]
                (let [inner-plan (rule-call-plan rules inner-call.name)
                      [inner-rel inner-ok] (query-relation-from-materialized-rule-call db sources rules inner-plan inner-call registry stats (+ depth 1) cache)]
                  (delete-rule-call-plan inner-plan)
                  (when (not inner-ok)
                    (delete-query-relation current)
                    (delete-query-relation inner-rel)
                    (delete out-bindings)
                    (delete-query-relation out-rel)
                    (return (query-relation-empty) false))
                  (let [joined (query-relation-join db sources current inner-rel)]
                    (set! stats^.rule-calls (+ stats^.rule-calls 1))
                    (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
                    (delete-query-relation current)
                    (delete-query-relation inner-rel)
                    (set! current joined))))))
          (when (= (count plan.rules) 1)
            (materialized-rule-cache-store! cache call.name current))
          (accumulate-projected-rule-call-relation! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed) (addr seen) current rule call)
          (delete-query-relation current))))
    (if (and out-rel-typed has-out-rel (= (count out-bindings) 0))
      (do
        (delete out-bindings)
        (return out-rel true))
      (do
        (query-relation-flush-typed-accumulator! (addr out-bindings) (addr out-rel) (addr has-out-rel) (addr out-rel-typed))
        (let [unique (unique-bindings (slice out-bindings 0))
              out (query-relation-from-bindings (slice unique 0))]
          (delete out-bindings)
          (delete unique)
          (return out true))))))

(defn query-relation-apply-materialized-rule-call [db: DB, sources: []DB-Source, rel: Query-Relation, plan: Rule-Call-Plan, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats, cache: ^[dynamic]Materialized-Rule-Cache-Entry] -> [out: Query-Relation, ok: bool]
  (when (not (rule-call-can-materialize-relation? plan call))
    (return (query-relation-empty) false))
  (let [[rule-rel rule-ok] (query-relation-from-materialized-rule-call db sources (slice plan.rules 0) plan call registry stats 0 cache)]
    (when (not rule-ok)
      (delete-query-relation rule-rel)
      (return (query-relation-empty) false))
    (let [joined (query-relation-join db sources rel rule-rel)]
      (set! stats^.rule-calls (+ stats^.rule-calls 1))
      (set! stats^.rule-iterations (+ stats^.rule-iterations 1))
      (query-stats-observe-bindings! stats (query-relation-row-count rule-rel))
      (delete-query-relation rule-rel)
      (return joined true))))

(defn query-relation-apply-rule-call-typed-fallback [db: DB, plan: Rule-Call-Plan, rel: Query-Relation, call: Rule-Call, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-rule-call-vars! (addr output-vars) call)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
          (when (not binding-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (let [rule-bindings (bindings-after-rule-call-profiled-with-plan db plan call binding registry stats)]
            (delete binding.items)
            (for [next rule-bindings]
              (when (not (query-relation-builder-add-binding! (addr builder) (slice attrs 0) next false))
                (delete next.items)
                (delete rule-bindings)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false)))
            (delete rule-bindings)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: true}) true))))

(defn query-relation-apply-rule-call [db: DB, sources: []DB-Source, rules: []Rule, plans: []Rule-Call-Plan, rel: Query-Relation, call: Rule-Call, call-index: int, registry: []Native-Query-Fn, stats: ^Query-Stats, cache: ^[dynamic]Materialized-Rule-Cache-Entry] -> Query-Relation
  (let [bindings (make [dynamic]Binding)
        use-cached-plan (and (>= call-index 0) (< call-index (count plans)))
        plan (if use-cached-plan plans[call-index] (rule-call-plan rules call.name))
        bound-arg-count (query-relation-rule-call-bound-arg-count rel call)]
    (when (and (= bound-arg-count 0)
               (or (> (query-relation-row-count rel) 128)
                   (and (= (query-relation-row-count rel) 1)
                        (= (count rel.attrs) 0))))
      (let [[materialized materialized-ok] (query-relation-apply-materialized-rule-call db sources rel plan call registry stats cache)]
        (when materialized-ok
          (when (not use-cached-plan)
            (delete-rule-call-plan plan))
          (delete bindings)
          (return materialized))
        (delete-query-relation materialized)))
    (let [[typed typed-ok] (query-relation-apply-rule-call-typed-fallback db plan rel call registry stats)]
      (when typed-ok
        (when (not use-cached-plan)
          (delete-rule-call-plan plan))
        (delete bindings)
        (return typed))
      (delete-query-relation typed))
    (let [materialized (query-relation-materialized-bindings rel) :defer]
      (for [tuple materialized]
        (let [rule-bindings (bindings-after-rule-call-profiled-with-plan db plan call tuple registry stats)]
          (for [rule-binding rule-bindings]
            (arr.push! bindings rule-binding))
          (delete rule-bindings))))
    (when (not use-cached-plan)
      (delete-rule-call-plan plan))
    (let [out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
      (delete bindings)
      out)))

(defn query-relation-apply-ground-binding-typed [rel: Query-Relation, source-term: Term, binding: Input-Binding] -> [out: Query-Relation, ok: bool]
  (when (= binding.kind .None)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer
        seen-output-vars (set.empty string) :defer]
    (append-input-binding-vars-indexed! (addr output-vars) (addr seen-output-vars) binding)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[source source-ok] (query-relation-resolve-typed-term rel row source-term)]
          (when source-ok
            (if (input-binding-contains-collection? binding)
              (let [[produced-rows produced-ok] (typed-produced-value-rows-from-input-binding rel row binding source (slice output-vars 0))]
                (when produced-ok
                  (for [produced produced-rows]
                    (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced.values 0)))
                      (delete-typed-produced-values produced-rows)
                      (delete attrs)
                      (delete attr-sources)
                      (delete-query-relation-builder builder)
                      (return (query-relation-empty) false))))
                (delete-typed-produced-values produced-rows))
              (let [[produced produced-ok] (typed-produced-values-from-input-binding rel row binding source (slice output-vars 0))]
                (when produced-ok
                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                    (delete produced)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))
                (delete produced)))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-ground-value-binding-typed [rel: Query-Relation, source: Value, binding: Input-Binding] -> [out: Query-Relation, ok: bool]
  (query-relation-apply-ground-binding-typed rel (term-value source) binding))

(defn query-relation-apply-ground-typed [rel: Query-Relation, ground: Ground] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (when (not (= ground.binding.kind .None))
    (return (query-relation-apply-ground-binding-typed rel ground.source ground.binding)))
  (when (and (= ground.binding.kind .None)
             ground.is-collection
             (not (= ground.out "")))
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) ground.out "")
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (let [[source source-ok] (query-relation-resolve-typed-term rel row ground.source)]
            (when source-ok
              (when (not (or (= source.kind .Vector)
                             (= source.kind .Set)))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (for [value source.items]
                (when (query-relation-typed-row-var-agrees? rel row ground.out value)
                  (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row ground.out value))
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false))))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))
  (when (and (= ground.binding.kind .None)
             ground.is-tuple)
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          output-vars (make [dynamic]string) :defer]
      (append-ground-output-vars! (addr output-vars) ground)
      (for [name output-vars]
        (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (let [[source source-ok] (query-relation-resolve-typed-term rel row ground.source)]
            (when source-ok
              (when (not (= source.kind .Vector))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (let [[produced produced-ok] (typed-ground-produced-values rel row ground.tuple-vars (slice source.items 0) (slice output-vars 0))]
                (when produced-ok
                  (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                    (delete produced)
                    (delete attrs)
                    (delete attr-sources)
                    (delete-query-relation-builder builder)
                    (return (query-relation-empty) false)))
                (delete produced))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))
  (when (and (= ground.binding.kind .None)
             ground.is-relation)
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
          output-vars (make [dynamic]string) :defer]
      (append-ground-output-vars! (addr output-vars) ground)
      (for [name output-vars]
        (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (let [[source source-ok] (query-relation-resolve-typed-term rel row ground.source)]
            (when source-ok
              (when (not (= source.kind .Vector))
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false))
              (for [source-row source.items]
                (when (and (= source-row.kind .Vector)
                           (= (count source-row.items) ground.width))
                  (let [[produced produced-ok] (typed-ground-produced-values rel row ground.tuple-vars (slice source-row.items 0) (slice output-vars 0))]
                    (when produced-ok
                      (when (not (query-relation-builder-add-column-row-with-values! (addr builder) (slice rel.typed-columns 0) row (slice produced 0)))
                        (delete produced)
                        (delete attrs)
                        (delete attr-sources)
                        (delete-query-relation-builder builder)
                        (return (query-relation-empty) false)))
                    (delete produced))))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))
  (when (and (= ground.binding.kind .None)
             (not ground.is-collection)
             (not ground.is-tuple)
             (not ground.is-relation)
             (not (= ground.out "")))
    (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
          attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) ground.out "")
      (let [builder (query-relation-builder (slice attrs 0))
            row 0]
        (while (< row rel.typed-rows)
          (let [[value value-ok] (query-relation-resolve-typed-term rel row ground.source)]
            (when value-ok
              (when (query-relation-typed-row-var-agrees? rel row ground.out value)
                (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row ground.out value))
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false)))))
          (set! row (+ row 1)))
        (return (Query-Relation {attrs: attrs
                                 attr-sources: attr-sources
                                 attr-index: (query-relation-attr-index (slice attrs 0))
                                 tuples: builder.tuples
                                 typed-columns: builder.typed-columns
                                 typed-rows: builder.typed-rows
                                 has-typed-columns: builder.typed-ok}) true))))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))
        output-vars (make [dynamic]string) :defer]
    (append-ground-output-vars! (addr output-vars) ground)
    (for [name output-vars]
      (append-var-binding-attr! (addr attrs) (addr attr-sources) name ""))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[binding binding-ok] (binding-from-query-relation-typed-row rel row)]
          (when (not binding-ok)
            (delete attrs)
            (delete attr-sources)
            (delete-query-relation-builder builder)
            (return (query-relation-empty) false))
          (let [expanded (apply-ground ([]Binding [binding]) ground)]
            (delete binding.items)
            (for [next expanded]
              (when (not (query-relation-builder-add-binding! (addr builder) (slice attrs 0) next false))
                (delete next.items)
                (delete expanded)
                (delete attrs)
                (delete attr-sources)
                (delete-query-relation-builder builder)
                (return (query-relation-empty) false)))
            (delete expanded)))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-ground [rel: Query-Relation, ground: Ground] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-ground-typed rel ground)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (apply-ground (slice materialized 0) ground)
        out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
    (delete bindings)
    out))

(defn query-relation-apply-get-else-typed [db: DB, rel: Query-Relation, get-else: Get-Else] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-else.out "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[entity entity-ok] (query-relation-resolve-typed-entity-term db rel row get-else.e)]
          (when (and entity-ok (= entity.kind .Entity))
            (let [[attr-value attr-ok] (pull-attr-value db entity.entity get-else.a)
                  out-value (if attr-ok attr-value get-else.default-value)]
              (when (query-relation-typed-row-var-agrees? rel row get-else.out out-value)
                (when (not (query-relation-builder-add-column-row-with-output-value! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row get-else.out out-value))
                  (delete attrs)
                  (delete attr-sources)
                  (delete-query-relation-builder builder)
                  (return (query-relation-empty) false))))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-get-else [db: DB, rel: Query-Relation, get-else: Get-Else] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-get-else-typed db rel get-else)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (bindings-after-get-else-step db (slice materialized 0) get-else)
        out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
    (delete bindings)
    out))

(defn typed-get-some-row-values [db: DB, rel: Query-Relation, row: int, get-some: Get-Some] -> [attr-result: Value, attr-value: Value, ok: bool]
  (let [[entity entity-ok] (query-relation-resolve-typed-entity-term db rel row get-some.e)]
    (when (not (and entity-ok (= entity.kind .Entity)))
      (return (Value {}) (Value {}) false))
    (for [attr get-some.attrs]
      (let [[value value-ok] (pull-attr-value db entity.entity attr)]
        (when value-ok
          (let [attr-value-result (get-some-attr-result-value db attr)]
            (when (and (query-relation-typed-row-var-agrees? rel row get-some.out-attr attr-value-result)
                       (query-relation-typed-row-var-agrees? rel row get-some.out-value value))
              (return attr-value-result value true))))))
    (return (Value {}) (Value {}) false)))

(defn query-relation-apply-get-some-typed [db: DB, rel: Query-Relation, get-some: Get-Some] -> [out: Query-Relation, ok: bool]
  (when (not rel.has-typed-columns)
    (return (query-relation-empty) false))
  (let [attrs (arr.into [dynamic]string (slice rel.attrs 0))
        attr-sources (arr.into [dynamic]string (slice rel.attr-sources 0))]
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-some.out-attr "")
    (append-var-binding-attr! (addr attrs) (addr attr-sources) get-some.out-value "")
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (let [[attr-result attr-value value-ok] (typed-get-some-row-values db rel row get-some)]
          (when value-ok
            (when (not (query-relation-builder-add-column-row-with-two-output-values! (addr builder) (slice attrs 0) (slice rel.typed-columns 0) row get-some.out-attr attr-result get-some.out-value attr-value))
              (delete attrs)
              (delete attr-sources)
              (delete-query-relation-builder builder)
              (return (query-relation-empty) false))))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok}) true))))

(defn query-relation-apply-get-some [db: DB, rel: Query-Relation, get-some: Get-Some] -> Query-Relation
  (let [[typed typed-ok] (query-relation-apply-get-some-typed db rel get-some)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (let [materialized (query-relation-materialized-bindings rel) :defer
        bindings (bindings-after-get-some-step db (slice materialized 0) get-some)
        out (query-relation-from-bindings-inheriting-sources (slice bindings 0) rel)]
    (delete bindings)
    out))

(defn query-relation-from-source-input-clause-with-op [query: Query, inputs: []Query-Input, clause-value: Clause, op: Physical-Op] -> Query-Relation
  (let [[index found] (query-input-index-for-source query clause-value.source)]
    (when (not found)
      (return (query-relation-empty)))
    (when (>= index (count inputs))
      (return (query-relation-empty)))
    (let [[source source-ok] (query-input-source-value inputs[index])]
      (when (not source-ok)
        (return (query-relation-empty)))
      (query-relation-from-source-value-clause-with-op source clause-value op))))

(defn query-relation-from-source-input-clause [query: Query, inputs: []Query-Input, clause-value: Clause] -> Query-Relation
  (query-relation-from-source-input-clause-with-op query inputs clause-value (Physical-Op {})))

(defn query-relation-from-db-clause-binding-backed [db: DB, clause-value: Clause, source: string] -> Query-Relation
  (let [[attrs attr-sources] (clause-output-attrs clause-value source)
        tuples (make [dynamic]Binding)
        typed-columns (relation-columns-for-attrs (slice attrs 0))
        typed-ok true
        typed-rows 0]
    (let [scan (clause-index-scan db clause-value (Binding {}))]
      (defer (delete-clause-index-scan scan))
      (let [scan-index scan.index]
        (while (< scan-index scan.high)
          (let [datom-index (clause-index-scan-datom-index scan scan-index)
                datom db.datoms[datom-index]]
          (when (and (clause-index-scan-candidate? scan datom)
                     (datom-current-at? db datom-index))
            (let [next (Binding {items: (make [dynamic]Var-Binding 0 (count attrs))})]
              (if (datom-clause-matches? db datom clause-value (addr next))
                (do
                  (when typed-ok
                    (if (binding-can-add-to-relation-columns? (slice attrs 0) (slice typed-columns 0) next)
                      (do
                        (add-binding-to-relation-columns! (slice attrs 0) (addr typed-columns) next)
                        (set! typed-rows (+ typed-rows 1)))
                      (set! typed-ok false)))
                  (arr.push! tuples next))
                (delete next.items)))))
          (set! scan-index (+ scan-index 1)))))
    (when (not typed-ok)
      (for [column typed-columns]
        (delete-relation-column column))
      (delete typed-columns)
      (set! typed-columns (make [dynamic]Relation-Column))
      (set! typed-rows 0))
    (Query-Relation {attrs: attrs
                     attr-sources: attr-sources
                     attr-index: (query-relation-attr-index (slice attrs 0))
                     tuples: tuples
                     typed-columns: typed-columns
                     typed-rows: typed-rows
                     has-typed-columns: typed-ok})))

(defn resident-unbound-clause-pushdown-matches? [op: Physical-Op, datom: Datom, clause-value: Clause] -> bool
  (when (not op.has-pushdown-scalar)
    (return true))
  (let [[value value-ok] (unbound-datom-clause-var-value datom clause-value op.pushdown-scalar-requirement.var-name)]
    (if value-ok
      (case op.pushdown-scalar-requirement.kind
        .VarVarCompare
          (let [[other other-ok] (unbound-datom-clause-var-value datom clause-value op.pushdown-scalar-requirement.other-var)]
            (if other-ok
              (physical-op-scalar-pushdown-matches-values? op value other)
              true))

          (physical-op-scalar-pushdown-matches-value? op value))
      true)))

(defn query-relation-from-db-clause-typed-with-op [db: DB, clause-value: Clause, source: string, op: Physical-Op] -> [rel: Query-Relation, ok: bool]
  (let [[attrs attr-sources] (clause-output-attrs clause-value source)
        typed-columns (relation-columns-for-attrs (slice attrs 0))
        typed-rows 0]
    (let [scan (clause-index-scan db clause-value (Binding {}))]
      (defer (delete-clause-index-scan scan))
      (physical-op-tighten-resident-attr-value-scan! db (addr scan) clause-value op (Query-Relation {}) 0)
      (let [scan-index scan.index]
        (while (< scan-index scan.high)
          (let [datom-index (clause-index-scan-datom-index scan scan-index)
                datom db.datoms[datom-index]]
            (when (and (clause-index-scan-candidate? scan datom)
                       (datom-current-at? db datom-index)
                       (unbound-datom-clause-matches? db datom clause-value)
                       (resident-unbound-clause-pushdown-matches? op datom clause-value))
              (for [attr index attrs]
                (let [[value value-ok] (unbound-datom-clause-var-value datom clause-value attr)]
                  (when (or (not value-ok)
                            (not (relation-column-can-add? typed-columns[index] value)))
                    (delete attrs)
                    (delete attr-sources)
                    (delete-relation-columns typed-columns)
                    (return (query-relation-empty) false))))
              (for [attr index attrs]
                (let [[value _] (unbound-datom-clause-var-value datom clause-value attr)]
                  (discard (relation-column-add! (addr typed-columns[index]) value))))
              (set! typed-rows (+ typed-rows 1))))
          (set! scan-index (+ scan-index 1)))))
    (return (Query-Relation {attrs: attrs
                             attr-sources: attr-sources
                             attr-index: (query-relation-attr-index (slice attrs 0))
                             tuples: (make [dynamic]Binding)
                             typed-columns: typed-columns
                             typed-rows: typed-rows
                             has-typed-columns: true}) true)))

(defn query-relation-from-db-clause-typed [db: DB, clause-value: Clause, source: string] -> [rel: Query-Relation, ok: bool]
  (query-relation-from-db-clause-typed-with-op db clause-value source (Physical-Op {})))

(defn query-relation-from-db-clause-with-op [db: DB, clause-value: Clause, source: string, op: Physical-Op] -> Query-Relation
  (let [[typed typed-ok] (query-relation-from-db-clause-typed-with-op db clause-value source op)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (query-relation-from-db-clause-binding-backed db clause-value source))

(defn query-relation-from-db-clause [db: DB, clause-value: Clause, source: string] -> Query-Relation
  (let [[typed typed-ok] (query-relation-from-db-clause-typed db clause-value source)]
    (when typed-ok
      (return typed))
    (delete-query-relation typed))
  (query-relation-from-db-clause-binding-backed db clause-value source))

(defn query-relation-from-clause-with-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, clause-value: Clause, op: Physical-Op] -> Query-Relation
  (if clause-value.has-source
    (if (query-source-input? query clause-value.source)
      (return (query-relation-from-source-input-clause-with-op query inputs clause-value op))
      (let [[source-db source-ok] (source-db-lookup db sources clause-value.source)]
        (when source-ok
          (let [source-name (if (and (not (= clause-value.source "$"))
                                     (query-source-db? sources clause-value.source))
                              clause-value.source
                              "")]
            (return (query-relation-from-db-clause-with-op source-db (unsourced-clause clause-value) source-name op))))))
    (return (query-relation-from-db-clause-with-op db clause-value "" op)))
  (query-relation-empty))

(defn query-relation-from-clause [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, clause-value: Clause] -> Query-Relation
  (query-relation-from-clause-with-op db query inputs sources clause-value (Physical-Op {})))

(defn query-stats-observe-clause-relation! [stats: ^Query-Stats, query: Query, sources: []DB-Source, clause-value: Clause, rel: Query-Relation]
  (when (not rel.has-typed-columns)
    (return))
  (if clause-value.has-source
    (when (and (not (query-source-input? query clause-value.source))
               (query-source-db? sources clause-value.source))
      (set! stats^.source-index-scans (+ stats^.source-index-scans 1))
      (query-stats-observe-source-operator! stats))
    (set! stats^.typed-index-scans (+ stats^.typed-index-scans 1))))

(defn query-relation-reduce [db: DB, sources: []DB-Source, relations: []Query-Relation] -> Query-Relation
  (let [current (query-relation-singleton)]
    (for [rel relations]
      (let [next (query-relation-join db sources current rel)]
        (delete-query-relation current)
        (set! current next)))
    current))

(defn relation-engine-relation-profiled [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn, stats: ^Query-Stats] -> Query-Relation
  (let [[star-rel star-ok] (query-relation-from-entity-star-plan db query inputs sources registry stats)]
    (when star-ok
      (query-stats-observe-bindings! stats (query-relation-row-count star-rel))
      (return star-rel))
    (delete-query-relation star-rel))
  (let [plan (physical-plan-from-query query)
        materialized-rule-cache (make [dynamic]Materialized-Rule-Cache-Entry)
        [current input-binding-count] (query-relation-initial-from-inputs db query inputs)]
    (defer (delete-physical-plan plan))
    (defer (delete-materialized-rule-cache materialized-rule-cache))
    (set! stats^.input-bindings input-binding-count)
    (query-stats-observe-bindings! stats input-binding-count)
    (for [op plan.ops]
      (let [next (query-relation-apply-resident-physical-op db query inputs sources current op registry stats (addr materialized-rule-cache))]
        (set! stats^.steps (+ stats^.steps 1))
        (delete-query-relation current)
        (set! current next)
        (query-stats-observe-bindings! stats (query-relation-row-count current))))
    current))

(defn relation-engine-bindings-profiled [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (let [post-rel (relation-engine-relation-profiled db query inputs sources registry stats)
        bindings (query-relation-materialized-bindings post-rel)]
    (delete-query-relation post-rel)
    bindings))

(defn bindings-after-ordered-where-with-fns [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> [dynamic]Binding
  (let [bindings (bindings-from-inputs db query^ inputs)]
    (for [step query^.where-steps]
      (let [next-bindings (bindings-after-query-step-with-fns db sources query (slice bindings 0) step registry)]
        (delete bindings)
        (set! bindings next-bindings)
        (when (= (count bindings) 0)
          (return bindings))))
    (return bindings)))

(defn bindings-after-ordered-where [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input] -> [dynamic]Binding
  (bindings-after-ordered-where-with-fns db sources query inputs ([]Native-Query-Fn [])))

(defenum Physical-Op-Kind [
  PrimaryScan
  NamedSourceScan
  RelationInput
  BindJoinScan
  StarJoin
  Predicate
  Function
  Ground
  GetElse
  GetSome
  RuleCall
  Not
  Or
  Project
  Materialize
])

(defenum Physical-Result-Shape-Kind [
  EmptyResultShape
  FlatPrimitiveResult
  PullResult
  AggregateResult
  PullAggregateResult
  CompositeResult
])

(defstruct Physical-Result-Shape {
  kind: Physical-Result-Shape-Kind
  find-count: int
  value-column-count: int
  pull-count: int
  aggregate-count: int
  with-count: int
  has-distinct: bool
})

(defenum Physical-Result-Column-Kind [
  ValueResultColumn
  PullResultColumn
  AggregateResultColumn
  WithDedupeColumn
])

(defstruct Physical-Result-Column {
  kind: Physical-Result-Column-Kind
  var-name: string
  source-index: int
  output-index: int
})

(defstruct Physical-Materialization-Plan {
  shape: Physical-Result-Shape
  columns: [dynamic]Physical-Result-Column
  trust-unique-bindings: bool
})

(defenum Physical-Term-Bound-Kind [
  Free
  Variable
  Constant
  LookupRef
])

(defstruct Physical-Clause-Scan-Bounds {
  e: Physical-Term-Bound-Kind
  a: Physical-Term-Bound-Kind
  v: Physical-Term-Bound-Kind
  tx: Physical-Term-Bound-Kind
  op: Physical-Term-Bound-Kind
})

(defenum Physical-Scan-Range-Kind [
  Full
  Entity
  Attr
  Value
  EntityAttr
  AttrValue
])

(defstruct Physical-Scan-Range {
  kind: Physical-Scan-Range-Kind
  order: Public-Index-Order
  prefix-width: int
})

(defstruct Physical-Resolved-Scan-Range {
  range: Physical-Scan-Range
  values: [dynamic]Value
})

(defenum Physical-Scalar-Requirement-Kind [
  NoScalarRequirement
  UnaryPredicate
  VarValueCompare
  VarVarCompare
  UnknownScalarRequirement
])

(defstruct Physical-Scalar-Requirement {
  kind: Physical-Scalar-Requirement-Kind
  op: string
  var-name: string
  other-var: string
  value-term: Term
  arity: int
  is-equality: bool
  is-range: bool
  typed-supported: bool
})

(defenum Physical-Function-Requirement-Kind [
  NoFunctionRequirement
  ScalarFunction
  TupleFunction
  BindingFunction
  UnknownFunctionRequirement
])

(defstruct Physical-Function-Requirement {
  kind: Physical-Function-Requirement-Kind
  op: string
  arity: int
  output-count: int
  typed-supported: bool
})

(defstruct Physical-Op {
  kind: Physical-Op-Kind
  step: Query-Step
  item-index: int
  scan-bounds: Physical-Clause-Scan-Bounds
  scan-range: Physical-Scan-Range
  scalar-requirement: Physical-Scalar-Requirement
  function-requirement: Physical-Function-Requirement
  has-pushdown-scalar: bool
  pushdown-predicate-index: int
  pushdown-scalar-requirement: Physical-Scalar-Requirement
  referenced-vars: [dynamic]string
  input-vars: [dynamic]string
  output-vars: [dynamic]string
})

(defstruct Physical-Plan {
  ops: [dynamic]Physical-Op
  materialization: Physical-Materialization-Plan
  has-project: bool
  project-op: Physical-Op
  has-materialize: bool
  materialize-op: Physical-Op
})

(defn physical-result-shape-from-query [query: Query] -> Physical-Result-Shape
  (let [find-count (count query.find)
        pull-count (count query.pulls)
        aggregate-count (count query.aggregates)
        with-count (count query.with)
        value-column-count (+ find-count aggregate-count)
        has-pull (> pull-count 0)
        has-aggregate (> aggregate-count 0)
        kind: Physical-Result-Shape-Kind (cond
                                           (and (= find-count 0)
                                                (not has-pull)
                                                (not has-aggregate))
                                             .EmptyResultShape
                                           (and has-pull has-aggregate)
                                             .PullAggregateResult
                                           has-pull
                                             .PullResult
                                           has-aggregate
                                             .AggregateResult
                                           :else
                                             .FlatPrimitiveResult)]
    (Physical-Result-Shape {kind: kind
                            find-count: find-count
                            value-column-count: value-column-count
                            pull-count: pull-count
                            aggregate-count: aggregate-count
                            with-count: with-count
                            has-distinct: (= with-count 0)})))

(defn physical-result-shape-flat-primitive? [shape: Physical-Result-Shape] -> bool
  (= shape.kind .FlatPrimitiveResult))

(defn query-physical-result-shape-flat-primitive? [query: Query] -> bool
  (physical-result-shape-flat-primitive? (physical-result-shape-from-query query)))

(defn physical-result-columns-from-query [query: Query] -> [dynamic]Physical-Result-Column
  (let [columns (make [dynamic]Physical-Result-Column 0 (+ (count query.find)
                                                           (count query.pulls)
                                                           (count query.aggregates)
                                                           (count query.with)))
        output-index 0]
    (for [name source-index query.find]
      (arr.push! columns (Physical-Result-Column {kind: .ValueResultColumn
                                                  var-name: name
                                                  source-index: source-index
                                                  output-index: output-index}))
      (set! output-index (+ output-index 1)))
    (for [pull-find source-index query.pulls]
      (arr.push! columns (Physical-Result-Column {kind: .PullResultColumn
                                                  var-name: pull-find.var
                                                  source-index: source-index
                                                  output-index: output-index}))
      (set! output-index (+ output-index 1)))
    (for [aggregate source-index query.aggregates]
      (arr.push! columns (Physical-Result-Column {kind: .AggregateResultColumn
                                                  var-name: aggregate.var
                                                  source-index: source-index
                                                  output-index: output-index}))
      (set! output-index (+ output-index 1)))
    (for [name source-index query.with]
      (arr.push! columns (Physical-Result-Column {kind: .WithDedupeColumn
                                                  var-name: name
                                                  source-index: source-index
                                                  output-index: -1})))
    columns))

(defn physical-materialization-plan-from-query [query: Query] -> Physical-Materialization-Plan
  (Physical-Materialization-Plan {shape: (physical-result-shape-from-query query)
                                  columns: (physical-result-columns-from-query query)
                                  trust-unique-bindings: (query-can-trust-unique-bindings? query)}))

(defn delete-physical-materialization-plan [plan: Physical-Materialization-Plan]
  (delete plan.columns))

(defn physical-clause-op-kind [query: Query, clause-value: Clause] -> Physical-Op-Kind
  (cond
    (and clause-value.has-source
         (query-source-input? query clause-value.source))
      .RelationInput
    (and clause-value.has-source
         (not (= clause-value.source "$")))
      .NamedSourceScan
    :else
      .PrimaryScan))

(defn physical-op-kind-from-query-step [query: Query, step: Query-Step] -> Physical-Op-Kind
  (case step.kind
    .Clause
      (physical-clause-op-kind query query.clauses[step.index])
    .Predicate
      .Predicate
    .Function
      .Function
    .Ground
      .Ground
    .GetElse
      .GetElse
    .GetSome
      .GetSome
    .RuleCall
      .RuleCall
    .Not
      .Not
      .Or
      .Or

      .PrimaryScan))

(defn physical-clause-has-available-var? [query: Query, step: Query-Step, available: []string] -> bool
  (when (not (= step.kind .Clause))
    (return false))
  (let [referenced-vars (physical-op-referenced-vars-from-query-step query step) :defer]
    (for [name referenced-vars]
      (when (string-slice-contains? available name)
        (return true)))
    false))

(defn physical-op-kind-from-query-step-and-available [query: Query, step: Query-Step, available: []string] -> Physical-Op-Kind
  (let [base-kind (physical-op-kind-from-query-step query step)]
    (if (physical-clause-has-available-var? query step available)
      .BindJoinScan
      base-kind)))

(defn physical-term-bound-kind [term: Term] -> Physical-Term-Bound-Kind
  (case term.kind
    .Value
      .Constant
    .LookupRef
      .LookupRef
    .Var
      .Variable

      .Free))

(defn physical-term-bound-kind-with-binding [term: Term, binding: Binding] -> Physical-Term-Bound-Kind
  (case term.kind
    .Var
      (let [[_ ok] (binding-lookup binding term.name)]
        (if ok
          .Constant
          .Variable))

      (physical-term-bound-kind term)))

(defn physical-clause-scan-bounds [clause-value: Clause] -> Physical-Clause-Scan-Bounds
  (Physical-Clause-Scan-Bounds {e: (physical-term-bound-kind clause-value.e)
                                a: (physical-term-bound-kind clause-value.a)
                                v: (physical-term-bound-kind clause-value.v)
                                tx: (physical-term-bound-kind clause-value.tx-term)
                                op: (physical-term-bound-kind clause-value.op-term)}))

(defn physical-clause-scan-bounds-with-binding [clause-value: Clause, binding: Binding] -> Physical-Clause-Scan-Bounds
  (Physical-Clause-Scan-Bounds {e: (physical-term-bound-kind-with-binding clause-value.e binding)
                                a: (physical-term-bound-kind-with-binding clause-value.a binding)
                                v: (physical-term-bound-kind-with-binding clause-value.v binding)
                                tx: (physical-term-bound-kind-with-binding clause-value.tx-term binding)
                                op: (physical-term-bound-kind-with-binding clause-value.op-term binding)}))

(defn physical-op-scan-bounds-from-query-step [query: Query, step: Query-Step] -> Physical-Clause-Scan-Bounds
  (if (= step.kind .Clause)
    (physical-clause-scan-bounds query.clauses[step.index])
    (Physical-Clause-Scan-Bounds {})))

(defn physical-bound-kind-range-ready? [kind: Physical-Term-Bound-Kind] -> bool
  (or (= kind .Constant)
      (= kind .LookupRef)))

(defn physical-scan-range-from-bounds [bounds: Physical-Clause-Scan-Bounds] -> Physical-Scan-Range
  (cond
    (and (physical-bound-kind-range-ready? bounds.e)
         (physical-bound-kind-range-ready? bounds.a))
      (Physical-Scan-Range {kind: .EntityAttr order: .EAVT prefix-width: 2})
    (and (physical-bound-kind-range-ready? bounds.a)
         (physical-bound-kind-range-ready? bounds.v))
      (Physical-Scan-Range {kind: .AttrValue order: .AVET prefix-width: 2})
    (physical-bound-kind-range-ready? bounds.e)
      (Physical-Scan-Range {kind: .Entity order: .EAVT prefix-width: 1})
    (physical-bound-kind-range-ready? bounds.a)
      (Physical-Scan-Range {kind: .Attr order: .AEVT prefix-width: 1})
    (physical-bound-kind-range-ready? bounds.v)
      (Physical-Scan-Range {kind: .Value order: .VAET prefix-width: 1})
    :else
      (Physical-Scan-Range {kind: .Full order: .EAVT prefix-width: 0})))

(defn physical-op-scan-range-from-query-step [step: Query-Step, bounds: Physical-Clause-Scan-Bounds] -> Physical-Scan-Range
  (if (= step.kind .Clause)
    (physical-scan-range-from-bounds bounds)
    (Physical-Scan-Range {})))

(defn physical-compare-op-equality? [op: string] -> bool
  (or (= op "=")
      (= op "!=")
      (= op "not=")))

(defn physical-compare-op-range? [op: string] -> bool
  (or (= op ">")
      (= op ">=")
      (= op "<")
      (= op "<=")))

(defn physical-inverted-compare-op [op: string] -> [inverted: string, ok: bool]
  (cond
    (= op ">") (return "<" true)
    (= op ">=") (return "<=" true)
    (= op "<") (return ">" true)
    (= op "<=") (return ">=" true)
    (= op "=") (return "=" true)
    (= op "!=") (return "!=" true)
    (= op "not=") (return "not=" true)
    :else (return "" false)))

(defn physical-predicate-requirement [predicate: Predicate] -> Physical-Scalar-Requirement
  (when (query-var-name? predicate.op)
    (return (Physical-Scalar-Requirement {kind: .UnknownScalarRequirement
                                          op: predicate.op
                                          arity: (count predicate.terms)})))
  (when (= (count predicate.terms) 1)
    (let [term predicate.terms[0]]
      (if (= term.kind .Var)
        (return (Physical-Scalar-Requirement {kind: .UnaryPredicate
                                              op: predicate.op
                                              var-name: term.name
                                              arity: 1
                                              typed-supported: (predicate-op-supported? predicate.op)}))
        (return (Physical-Scalar-Requirement {kind: .UnknownScalarRequirement
                                              op: predicate.op
                                              arity: 1
                                              typed-supported: (predicate-op-supported? predicate.op)})))))
  (when (= (count predicate.terms) 2)
    (let [left predicate.terms[0]
          right predicate.terms[1]
          equality (physical-compare-op-equality? predicate.op)
          range (physical-compare-op-range? predicate.op)
          typed (predicate-op-supported? predicate.op)]
      (when (and (= left.kind .Var)
                 (= right.kind .Var))
        (return (Physical-Scalar-Requirement {kind: .VarVarCompare
                                              op: predicate.op
                                              var-name: left.name
                                              other-var: right.name
                                              arity: 2
                                              is-equality: equality
                                              is-range: range
                                              typed-supported: typed})))
      (when (and (= left.kind .Var)
                 (not (= right.kind .Var)))
        (return (Physical-Scalar-Requirement {kind: .VarValueCompare
                                              op: predicate.op
                                              var-name: left.name
                                              value-term: right
                                              arity: 2
                                              is-equality: equality
                                              is-range: range
                                              typed-supported: typed})))
      (when (and (= right.kind .Var)
                 (not (= left.kind .Var)))
        (let [[inverted inverted-ok] (physical-inverted-compare-op predicate.op)]
          (when inverted-ok
            (return (Physical-Scalar-Requirement {kind: .VarValueCompare
                                                  op: inverted
                                                  var-name: right.name
                                                  value-term: left
                                                  arity: 2
                                                  is-equality: equality
                                                  is-range: range
                                                  typed-supported: typed})))))))
  (Physical-Scalar-Requirement {kind: .UnknownScalarRequirement
                                op: predicate.op
                                arity: (count predicate.terms)
                                typed-supported: (predicate-op-supported? predicate.op)}))

(defn physical-function-output-count [function: Function-Clause] -> int
  (let [out-count 0]
    (when (> (count function.out) 0)
      (set! out-count (+ out-count 1)))
    (set! out-count (+ out-count (count function.out-vars)))
    (let [binding-vars (input-binding-vars function.out-binding) :defer]
      (set! out-count (+ out-count (count binding-vars))))
    out-count))

(defn physical-function-requirement [function: Function-Clause] -> Physical-Function-Requirement
  (when (query-var-name? function.op)
    (return (Physical-Function-Requirement {kind: .UnknownFunctionRequirement
                                            op: function.op
                                            arity: (count function.terms)
                                            output-count: (physical-function-output-count function)})))
  (let [output-count (physical-function-output-count function)
        typed (or (typed-function-op-supported? function.op)
                  (source-function-op? function.op))]
    (cond
      (not (= function.out-binding.kind .None))
        (Physical-Function-Requirement {kind: .BindingFunction
                                        op: function.op
                                        arity: (count function.terms)
                                        output-count: output-count
                                        typed-supported: typed})
      function.is-tuple
        (Physical-Function-Requirement {kind: .TupleFunction
                                        op: function.op
                                        arity: (count function.terms)
                                        output-count: output-count
                                        typed-supported: typed})
      (> output-count 0)
        (Physical-Function-Requirement {kind: .ScalarFunction
                                        op: function.op
                                        arity: (count function.terms)
                                        output-count: output-count
                                        typed-supported: typed})
      :else
        (Physical-Function-Requirement {kind: .NoFunctionRequirement
                                        op: function.op
                                        arity: (count function.terms)
                                        typed-supported: typed}))))

(defn physical-op-scalar-requirement-from-query-step [query: Query, step: Query-Step] -> Physical-Scalar-Requirement
  (if (= step.kind .Predicate)
    (physical-predicate-requirement query.predicates[step.index])
    (Physical-Scalar-Requirement {})))

(defn physical-op-function-requirement-from-query-step [query: Query, step: Query-Step] -> Physical-Function-Requirement
  (if (= step.kind .Function)
    (physical-function-requirement query.function-clauses[step.index])
    (Physical-Function-Requirement {})))

(defn physical-normalized-scan-pushdown-requirement [requirement: Physical-Scalar-Requirement, output-vars: []string] -> [normalized: Physical-Scalar-Requirement, ok: bool]
  (when (not requirement.typed-supported)
    (return (Physical-Scalar-Requirement {}) false))
  (case requirement.kind
    .VarValueCompare
      (if (and (= requirement.value-term.kind .Value)
               (string-slice-contains? output-vars requirement.var-name))
        (return requirement true)
        (return (Physical-Scalar-Requirement {}) false))
    .VarVarCompare
      (cond
        (and (string-slice-contains? output-vars requirement.var-name)
             (not (string-slice-contains? output-vars requirement.other-var)))
          (return requirement true)
        (and (string-slice-contains? output-vars requirement.other-var)
             (not (string-slice-contains? output-vars requirement.var-name)))
          (let [[inverted inverted-ok] (physical-inverted-compare-op requirement.op)]
            (if inverted-ok
              (return (Physical-Scalar-Requirement {kind: .VarVarCompare
                                                    op: inverted
                                                    var-name: requirement.other-var
                                                    other-var: requirement.var-name
                                                    arity: requirement.arity
                                                    is-equality: requirement.is-equality
                                                    is-range: requirement.is-range
                                                    typed-supported: requirement.typed-supported})
                      true)
              (return (Physical-Scalar-Requirement {}) false)))
        :else
          (return (Physical-Scalar-Requirement {}) false))

      (return (Physical-Scalar-Requirement {}) false)))

(defn physical-best-scan-pushdown [query: Query, step-index: int, output-vars: []string] -> [requirement: Physical-Scalar-Requirement, predicate-index: int, ok: bool]
  (let [best-requirement (Physical-Scalar-Requirement {})
        best-predicate-index -1
        best-score 0
        candidate-index (+ step-index 1)]
    (while (< candidate-index (count query.where-steps))
      (let [candidate query.where-steps[candidate-index]]
        (when (= candidate.kind .Predicate)
          (let [requirement (physical-predicate-requirement query.predicates[candidate.index])]
            (let [[normalized normalized-ok] (physical-normalized-scan-pushdown-requirement requirement output-vars)]
              (when normalized-ok
              (let [score (physical-scalar-requirement-selectivity-score normalized)]
                (when (or (< best-predicate-index 0)
                          (< score best-score))
                  (set! best-requirement normalized)
                  (set! best-predicate-index candidate.index)
                  (set! best-score score))))))))
      (set! candidate-index (+ candidate-index 1)))
    (return best-requirement best-predicate-index (>= best-predicate-index 0))))

(defn physical-best-scan-pushdown-from-steps [query: Query, steps: []Query-Step, output-vars: []string] -> [requirement: Physical-Scalar-Requirement, predicate-index: int, ok: bool]
  (let [best-requirement (Physical-Scalar-Requirement {})
        best-predicate-index -1
        best-score 0]
    (for [candidate steps]
      (when (= candidate.kind .Predicate)
        (let [requirement (physical-predicate-requirement query.predicates[candidate.index])
              [normalized normalized-ok] (physical-normalized-scan-pushdown-requirement requirement output-vars)]
          (when normalized-ok
            (let [score (physical-scalar-requirement-selectivity-score normalized)]
              (when (or (< best-predicate-index 0)
                        (< score best-score))
                (set! best-requirement normalized)
                (set! best-predicate-index candidate.index)
                (set! best-score score)))))))
    (return best-requirement best-predicate-index (>= best-predicate-index 0))))

(defn physical-op-pushdown-from-query-step [query: Query, step: Query-Step, step-index: int, output-vars: []string] -> [requirement: Physical-Scalar-Requirement, predicate-index: int, ok: bool]
  (if (= step.kind .Clause)
    (physical-best-scan-pushdown query step-index output-vars)
    (return (Physical-Scalar-Requirement {}) -1 false)))

(defn physical-op-pushdown-from-query-step-and-remaining [query: Query, step: Query-Step, remaining: []Query-Step, output-vars: []string] -> [requirement: Physical-Scalar-Requirement, predicate-index: int, ok: bool]
  (if (= step.kind .Clause)
    (physical-best-scan-pushdown-from-steps query remaining output-vars)
    (return (Physical-Scalar-Requirement {}) -1 false)))

(defn physical-pushdown-op-from-clause-and-steps [query: Query, clause-value: Clause, steps: []Query-Step] -> Physical-Op
  (let [output-vars (make [dynamic]string) :defer
        seen (set.empty string) :defer]
    (append-clause-vars-indexed! (addr output-vars) (addr seen) clause-value)
    (let [[requirement predicate-index pushdown-ok] (physical-best-scan-pushdown-from-steps query steps (slice output-vars 0))]
      (Physical-Op {kind: .PrimaryScan
                    has-pushdown-scalar: pushdown-ok
                    pushdown-predicate-index: predicate-index
                    pushdown-scalar-requirement: requirement}))))

(defn physical-resolved-scan-range-empty [range: Physical-Scan-Range] -> Physical-Resolved-Scan-Range
  (Physical-Resolved-Scan-Range {range: range
                                 values: (make [dynamic]Value)}))

(defn delete-physical-resolved-scan-range [resolved: Physical-Resolved-Scan-Range]
  (delete-owned-values-array resolved.values))

(defn physical-resolved-scan-append-value! [values: ^[dynamic]Value, term: Term, binding: Binding] -> bool
  (let [[value ok] (resolve-term term binding)]
    (when (not ok)
      (return false))
    (arr.push! values^ (value-owned value))
    true))

(defn physical-resolve-clause-scan-range [clause-value: Clause, binding: Binding] -> [scan: Physical-Resolved-Scan-Range, ok: bool]
  (let [dynamic-bounds (physical-clause-scan-bounds-with-binding clause-value binding)
        dynamic-range (physical-scan-range-from-bounds dynamic-bounds)
        resolved-range (physical-resolved-scan-range-empty dynamic-range)]
    (case dynamic-range.kind
      .Full
        (return resolved-range true)
      .Entity
        (if (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.e binding)
          (return resolved-range true)
          (do
            (delete-physical-resolved-scan-range resolved-range)
            (return (physical-resolved-scan-range-empty dynamic-range) false)))
      .Attr
        (if (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.a binding)
          (return resolved-range true)
          (do
            (delete-physical-resolved-scan-range resolved-range)
            (return (physical-resolved-scan-range-empty dynamic-range) false)))
      .Value
        (if (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.v binding)
          (return resolved-range true)
          (do
            (delete-physical-resolved-scan-range resolved-range)
            (return (physical-resolved-scan-range-empty dynamic-range) false)))
      .EntityAttr
        (if (and (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.e binding)
                 (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.a binding))
          (return resolved-range true)
          (do
            (delete-physical-resolved-scan-range resolved-range)
            (return (physical-resolved-scan-range-empty dynamic-range) false)))
      .AttrValue
        (if (and (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.a binding)
                 (physical-resolved-scan-append-value! (addr resolved-range.values) clause-value.v binding))
          (return resolved-range true)
          (do
            (delete-physical-resolved-scan-range resolved-range)
            (return (physical-resolved-scan-range-empty dynamic-range) false)))

        (return resolved-range false))))

(defn physical-op-referenced-vars-from-query-step [query: Query, step: Query-Step] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (case step.kind
      .Clause
        (append-clause-vars-indexed! (addr vars) (addr seen) query.clauses[step.index])
      .Predicate
        (append-predicate-vars-indexed! (addr vars) (addr seen) query.predicates[step.index])
      .Function
        (append-function-vars-indexed! (addr vars) (addr seen) query.function-clauses[step.index])
      .Ground
        (append-ground-output-vars-indexed! (addr vars) (addr seen) query.grounds[step.index])
      .GetElse
        (append-get-else-vars-indexed! (addr vars) (addr seen) query.get-elses[step.index])
      .GetSome
        (append-get-some-vars-indexed! (addr vars) (addr seen) query.get-somes[step.index])
      .RuleCall
        (append-rule-call-vars-indexed! (addr vars) (addr seen) query.rule-calls[step.index])
      .Not
        (append-not-group-vars-indexed! (addr vars) (addr seen) query.not-groups[step.index])
      .Or
        (append-or-group-vars-indexed! (addr vars) (addr seen) query.or-groups[step.index])

        (do))
    vars))

(defn physical-op-output-vars-from-query-step [query: Query, step: Query-Step] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (case step.kind
      .Clause
        (append-clause-vars-indexed! (addr vars) (addr seen) query.clauses[step.index])
      .RuleCall
        (append-rule-call-vars-indexed! (addr vars) (addr seen) query.rule-calls[step.index])
      .Ground
        (append-ground-output-vars-indexed! (addr vars) (addr seen) query.grounds[step.index])
      .Function
        (append-function-output-vars-indexed! (addr vars) (addr seen) query.function-clauses[step.index])
      .GetElse
        (append-var-once-indexed! (addr vars) (addr seen) query.get-elses[step.index].out)
      .GetSome
        (do
          (append-var-once-indexed! (addr vars) (addr seen) query.get-somes[step.index].out-attr)
          (append-var-once-indexed! (addr vars) (addr seen) query.get-somes[step.index].out-value))
      .Or
        (append-or-group-output-vars-indexed! (addr vars) (addr seen) query.or-groups[step.index])

        (do))
    vars))

(defn physical-op-input-vars-from-vars [referenced-vars: []string, output-vars: []string] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (for [name referenced-vars]
      (when (not (string-slice-contains? output-vars name))
        (append-var-once! (addr vars) name)))
    vars))

(defn physical-op-rule-call-input-vars [rules: []Rule, rule-index: []Rule-Name-Index-Entry, call: Rule-Call] -> [dynamic]string
  (let [vars (make [dynamic]string)
        [rule rule-ok] (rule-name-index-first-matching-rule rules rule-index call)]
    (when rule-ok
      (let [param-index 0]
        (while (< param-index rule.required-param-count)
          (append-term-var! (addr vars) call.args[param-index])
          (set! param-index (+ param-index 1)))))
    vars))

(defn physical-op-available-input-vars [vars: []string, available: []string] -> [dynamic]string
  (let [out (make [dynamic]string)]
    (for [name vars]
      (when (string-slice-contains? available name)
        (append-var-once! (addr out) name)))
    out))

(defn physical-op-not-input-vars [group: Not-Group, referenced-vars: []string, available: []string] -> [dynamic]string
  (if group.has-join
    (physical-op-available-input-vars (slice group.join-vars 0) available)
    (physical-op-available-input-vars referenced-vars available)))

(defn append-branch-input-vars-indexed! [vars: ^[dynamic]string, seen: (ptr (map string (struct {}))), branch: Not-Group, available: []string]
  (let [referenced (make [dynamic]string) :defer
        output (make [dynamic]string) :defer
        referenced-seen (set.empty string) :defer
        output-seen (set.empty string) :defer]
    (append-not-group-vars-indexed! (addr referenced) (addr referenced-seen) branch)
    (append-branch-output-vars-indexed! (addr output) (addr output-seen) branch)
    (for [name referenced]
      (when (and (not (string-slice-contains? (slice output 0) name))
                 (string-slice-contains? available name))
        (append-var-once-indexed! vars seen name)))))

(defn physical-op-or-input-vars [group: Or-Group, available: []string] -> [dynamic]string
  (let [vars (make [dynamic]string)
        seen (set.empty string) :defer]
    (for [name group.join-vars]
      (when (string-slice-contains? available name)
        (append-var-once-indexed! (addr vars) (addr seen) name)))
    (for [branch group.branches]
      (append-branch-input-vars-indexed! (addr vars) (addr seen) branch available))
    vars))

(defn physical-op-input-vars-from-query-step [query: Query, rule-index: []Rule-Name-Index-Entry, step: Query-Step, referenced-vars: []string, output-vars: []string, available: []string] -> [dynamic]string
  (case step.kind
    .RuleCall
      (physical-op-rule-call-input-vars (slice query.rules 0) rule-index query.rule-calls[step.index])
    .Not
      (physical-op-not-input-vars query.not-groups[step.index] referenced-vars available)
    .Or
      (physical-op-or-input-vars query.or-groups[step.index] available)

      (physical-op-input-vars-from-vars referenced-vars output-vars)))

(defn physical-materialization-projectable? [materialization: Physical-Materialization-Plan] -> bool
  (and (physical-result-shape-flat-primitive? materialization.shape)
       (> (count materialization.columns) 0)))

(defn physical-materialization-materializable? [materialization: Physical-Materialization-Plan] -> bool
  (> (count materialization.columns) 0))

(defn physical-terminal-op-vars-from-materialization [materialization: Physical-Materialization-Plan] -> [dynamic]string
  (let [vars (make [dynamic]string)]
    (for [column materialization.columns]
      (case column.kind
        .ValueResultColumn
          (append-var-once! (addr vars) column.var-name)
        .WithDedupeColumn
          (append-var-once! (addr vars) column.var-name)
        .PullResultColumn
          (append-var-once! (addr vars) column.var-name)
        .AggregateResultColumn
          (append-var-once! (addr vars) column.var-name)

          (do)))
    vars))

(defn physical-project-op-from-materialization [materialization: Physical-Materialization-Plan] -> Physical-Op
  (let [vars (make [dynamic]string)]
    (for [column materialization.columns]
      (when (or (= column.kind .ValueResultColumn)
                (= column.kind .WithDedupeColumn))
        (append-var-once! (addr vars) column.var-name)))
    (let [referenced-vars (arr.into [dynamic]string (slice vars 0))
          input-vars (arr.into [dynamic]string (slice vars 0))]
      (Physical-Op {kind: .Project
                    item-index: -1
                    referenced-vars: referenced-vars
                    input-vars: input-vars
                    output-vars: vars}))))

(defn physical-materialize-op-from-materialization [materialization: Physical-Materialization-Plan] -> Physical-Op
  (let [vars (physical-terminal-op-vars-from-materialization materialization)
        referenced-vars (arr.into [dynamic]string (slice vars 0))
        input-vars (arr.into [dynamic]string (slice vars 0))]
    (Physical-Op {kind: .Materialize
                  item-index: -1
                  referenced-vars: referenced-vars
                  input-vars: input-vars
                  output-vars: vars})))

(defn query-primary-source-star-join-physical-op? [query: Query] -> bool
  (when (not (db-read-source-query-star-attr-entity-projection? query))
    (return false))
  (for [clause-value query.clauses]
    (when (not (db-read-source-primary-source? clause-value.has-source clause-value.source))
      (return false)))
  true)

(defn physical-star-join-op-from-query [query: Query] -> Physical-Op
  (let [vars (arr.into [dynamic]string (slice query.find 0))
        referenced-vars (arr.into [dynamic]string (slice query.find 0))
        input-vars (make [dynamic]string)]
    (Physical-Op {kind: .StarJoin
                  item-index: 0
                  referenced-vars: referenced-vars
                  input-vars: input-vars
                  output-vars: vars})))

(defn physical-plan-step-ready? [query: Query, step: Query-Step, available: []string] -> bool
  (case step.kind
    .Clause
      true
    .Predicate
      (predicate-ready-with-vars? query.predicates[step.index] available)
    .Function
      (function-ready-with-vars? query.function-clauses[step.index] available)

      true))

(defn function-ready-with-vars? [function: Function-Clause, available: []string] -> bool
  (let [vars (make [dynamic]string) :defer
        seen (set.empty string) :defer]
    (when (query-var-name? function.op)
      (append-var-once-indexed! (addr vars) (addr seen) function.op))
    (for [term index function.terms]
      (when (not (and (= index 0)
                      (source-function-op? function.op)
                      (source-default-token-term? term)))
        (append-term-var-indexed! (addr vars) (addr seen) term)))
    (for [name vars]
      (when (not (string-slice-contains? available name))
        (return false)))
    true))

(defn physical-plan-clause-unlocked-predicate-score [query: Query, remaining: []Query-Step, available: []string, clause-value: Clause] -> int
  (let [next-available (arr.into [dynamic]string available)]
    (append-clause-vars! (addr next-available) clause-value)
    (let [best -1]
      (for [step remaining]
        (when (= step.kind .Predicate)
          (let [predicate query.predicates[step.index]]
            (when (predicate-ready-with-vars? predicate (slice next-available 0))
              (let [score (predicate-selectivity-score predicate)]
                (when (or (= best -1)
                          (< score best))
                  (set! best score)))))))
      (delete next-available)
      best)))

(defn physical-plan-step-score [query: Query, remaining: []Query-Step, step: Query-Step, available: []string] -> [score: int, unlocked-predicate-score: int]
  (case step.kind
    .Clause
      (let [binding (Binding {items: (make [dynamic]Var-Binding)})
            clause-value query.clauses[step.index]]
        (let [score (clause-selectivity-score clause-value binding)
              unlocked (physical-plan-clause-unlocked-predicate-score query remaining available clause-value)]
          (delete binding.items)
          (return score unlocked)))
    .Predicate
      (return (predicate-selectivity-score query.predicates[step.index]) -1)

      (return 10 -1)))

(defn physical-plan-best-ready-step-index [query: Query, remaining: []Query-Step, available: []string] -> [index: int, ok: bool]
  (let [best -1
        best-score 0
        best-unlocked-predicate-score -1]
    (for [step step-index remaining]
      (when (physical-plan-step-ready? query step available)
        (let [[score unlocked-predicate-score] (physical-plan-step-score query remaining step available)]
          (when (or (= best -1)
                    (< score best-score)
                    (and (= score best-score)
                         (>= unlocked-predicate-score 0)
                         (or (< best-unlocked-predicate-score 0)
                             (< unlocked-predicate-score best-unlocked-predicate-score))))
            (set! best step-index)
            (set! best-score score)
            (set! best-unlocked-predicate-score unlocked-predicate-score)))))
    (return best (>= best 0))))

(defn physical-source-candidate-count-for-step [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, step: Query-Step] -> [count-value: int, ok: bool, error: string]
  (when (not (= step.kind .Clause))
    (return 0 true ""))
  (let [binding (Binding {items: (make [dynamic]Var-Binding)})
        [estimated-count count-ok count-error] (db-read-source-clause-candidate-count-estimate source sources query.clauses[step.index] binding)]
    (delete binding.items)
    (return estimated-count count-ok count-error)))

(defn physical-clause-available-var-count [query: Query, step: Query-Step, available: []string] -> int
  (when (not (= step.kind .Clause))
    (return 0))
  (let [referenced-vars (physical-op-referenced-vars-from-query-step query step) :defer
        out 0]
    (for [name referenced-vars]
      (when (string-slice-contains? available name)
        (set! out (+ out 1))))
    out))

(defn physical-source-step-rank [query: Query, step: Query-Step, available: []string] -> int
  (case step.kind
    .Clause
      (if (> (physical-clause-available-var-count query step available) 0)
        0
        1)
    .Function
      2

      0))

(defn physical-plan-best-ready-step-index-for-source [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, remaining: []Query-Step, available: []string] -> [index: int, ok: bool, error: string]
  (let [best -1
        best-score 0
        best-unlocked-predicate-score -1
        best-rank 0
        best-count -1]
    (for [step step-index remaining]
      (when (physical-plan-step-ready? query step available)
        (let [[score unlocked-predicate-score] (physical-plan-step-score query remaining step available)
              rank (physical-source-step-rank query step available)
              [candidate-count candidate-ok candidate-error] (physical-source-candidate-count-for-step source sources query step)]
          (when (not candidate-ok)
            (return -1 false candidate-error))
          (when (or (= best -1)
                    (< rank best-rank)
                    (and (= rank best-rank)
                         (< score best-score))
                    (and (= rank best-rank)
                         (= score best-score)
                         (or (= best-count -1)
                             (< candidate-count best-count)))
                    (and (= rank best-rank)
                         (= score best-score)
                         (= candidate-count best-count)
                         (>= unlocked-predicate-score 0)
                         (or (< best-unlocked-predicate-score 0)
                             (< unlocked-predicate-score best-unlocked-predicate-score))))
            (set! best step-index)
            (set! best-score score)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-rank rank)
            (set! best-count candidate-count)))))
    (return best (>= best 0) "")))

(defn physical-plan-append-op! [ops: ^[dynamic]Physical-Op, query: Query, rule-index: []Rule-Name-Index-Entry, step: Query-Step, step-index: int, remaining-after-step: []Query-Step, available: []string]
  (let [referenced-vars (physical-op-referenced-vars-from-query-step query step)
        output-vars (physical-op-output-vars-from-query-step query step)
        input-vars (physical-op-input-vars-from-query-step query rule-index step (slice referenced-vars 0) (slice output-vars 0) available)
        scan-bounds (physical-op-scan-bounds-from-query-step query step)
        [pushdown-requirement pushdown-predicate-index pushdown-ok] (physical-op-pushdown-from-query-step-and-remaining query step remaining-after-step (slice output-vars 0))]
    (arr.push! ops^ (Physical-Op {kind: (physical-op-kind-from-query-step-and-available query step available)
                                  step: step
                                  item-index: step.index
                                  scan-bounds: scan-bounds
                                  scan-range: (physical-op-scan-range-from-query-step step scan-bounds)
                                  scalar-requirement: (physical-op-scalar-requirement-from-query-step query step)
                                  function-requirement: (physical-op-function-requirement-from-query-step query step)
                                  has-pushdown-scalar: pushdown-ok
                                  pushdown-predicate-index: pushdown-predicate-index
                                  pushdown-scalar-requirement: pushdown-requirement
                                  referenced-vars: referenced-vars
                                  input-vars: input-vars
                                  output-vars: output-vars}))))

(defn physical-plan-append-source-ordered-ops! [ops: ^[dynamic]Physical-Op, query: Query, rule-index: []Rule-Name-Index-Entry, available: ^[dynamic]string]
  (for [step step-index query.where-steps]
    (let [remaining-after-step (if (< (+ step-index 1) (count query.where-steps))
                                 (slice query.where-steps (+ step-index 1))
                                 ([]Query-Step []))]
      (physical-plan-append-op! ops query rule-index step step-index remaining-after-step (slice available^ 0))
      (for [name ops^[(- (count ops^) 1)].output-vars]
        (append-var-once! available name)))))

(defn physical-plan-append-planned-clause-predicate-ops! [ops: ^[dynamic]Physical-Op, query: Query, rule-index: []Rule-Name-Index-Entry, available: ^[dynamic]string]
  (let [remaining (arr.into [dynamic]Query-Step (slice query.where-steps 0))]
    (while (> (count remaining) 0)
      (let [[chosen-index chosen-ok] (physical-plan-best-ready-step-index query (slice remaining 0) (slice available^ 0))]
        (when (not chosen-ok)
          (delete remaining)
          (physical-plan-append-source-ordered-ops! ops query rule-index available)
          (return))
        (let [step remaining[chosen-index]]
          (arr.remove-ordered-at! remaining chosen-index)
          (physical-plan-append-op! ops query rule-index step chosen-index (slice remaining 0) (slice available^ 0))
          (for [name ops^[(- (count ops^) 1)].output-vars]
            (append-var-once! available name)))))
    (delete remaining)))

(defn query-steps-are-source-plan-friendly? [query: Query] -> bool
  (when (= (count query.where-steps) 0)
    (return false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)
                   (= step.kind .Function)))
      (return false)))
  true)

(defn physical-plan-append-source-estimated-ops! [ops: ^[dynamic]Physical-Op, source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query, rule-index: []Rule-Name-Index-Entry, available: ^[dynamic]string] -> [ok: bool, error: string]
  (let [remaining (arr.into [dynamic]Query-Step (slice query.where-steps 0))]
    (while (> (count remaining) 0)
      (let [[chosen-index chosen-ok chosen-error] (physical-plan-best-ready-step-index-for-source source sources query (slice remaining 0) (slice available^ 0))]
        (when (not (= chosen-error ""))
          (delete remaining)
          (return false chosen-error))
        (when (not chosen-ok)
          (delete remaining)
          (physical-plan-append-source-ordered-ops! ops query rule-index available)
          (return true ""))
        (let [step remaining[chosen-index]]
          (arr.remove-ordered-at! remaining chosen-index)
          (physical-plan-append-op! ops query rule-index step chosen-index (slice remaining 0) (slice available^ 0))
          (for [name ops^[(- (count ops^) 1)].output-vars]
            (append-var-once! available name)))))
    (delete remaining)
    (return true "")))

(defn physical-plan-from-query [query: Query] -> Physical-Plan
  (let [ops (make [dynamic]Physical-Op 0 (count query.where-steps))
        available (query-input-vars query) :defer
        rule-index (rule-name-index-build (slice query.rules 0)) :defer]
    (if (query-primary-source-star-join-physical-op? query)
      (arr.push! ops (physical-star-join-op-from-query query))
      (if (query-steps-are-clauses-and-predicates? query)
        (physical-plan-append-planned-clause-predicate-ops! (addr ops) query (slice rule-index 0) (addr available))
        (physical-plan-append-source-ordered-ops! (addr ops) query (slice rule-index 0) (addr available))))
    (let [materialization (physical-materialization-plan-from-query query)
          has-project (physical-materialization-projectable? materialization)
          has-materialize (physical-materialization-materializable? materialization)
          project-op (if has-project
                       (physical-project-op-from-materialization materialization)
                       (Physical-Op {referenced-vars: (make [dynamic]string)
                                     input-vars: (make [dynamic]string)
                                     output-vars: (make [dynamic]string)}))
          materialize-op (if has-materialize
                           (physical-materialize-op-from-materialization materialization)
                           (Physical-Op {referenced-vars: (make [dynamic]string)
                                         input-vars: (make [dynamic]string)
                                         output-vars: (make [dynamic]string)}))]
      (Physical-Plan {ops: ops
                      materialization: materialization
                      has-project: has-project
                      project-op: project-op
                      has-materialize: has-materialize
                      materialize-op: materialize-op}))))

(defn physical-plan-from-query-for-source [source: DB-Read-Source, sources: []DB-Read-Named-Source, query: Query] -> [plan: Physical-Plan, ok: bool, error: string]
  (let [ops (make [dynamic]Physical-Op 0 (count query.where-steps))
        available (query-input-vars query) :defer
        rule-index (rule-name-index-build (slice query.rules 0)) :defer]
    (if (query-primary-source-star-join-physical-op? query)
      (arr.push! ops (physical-star-join-op-from-query query))
      (if (query-steps-are-source-plan-friendly? query)
        (let [[plan-ok plan-error] (physical-plan-append-source-estimated-ops! (addr ops) source sources query (slice rule-index 0) (addr available))]
          (when (not plan-ok)
            (delete ops)
            (return (physical-plan-from-query query) false plan-error)))
        (physical-plan-append-source-ordered-ops! (addr ops) query (slice rule-index 0) (addr available))))
    (let [materialization (physical-materialization-plan-from-query query)
          has-project (physical-materialization-projectable? materialization)
          has-materialize (physical-materialization-materializable? materialization)
          project-op (if has-project
                       (physical-project-op-from-materialization materialization)
                       (Physical-Op {referenced-vars: (make [dynamic]string)
                                     input-vars: (make [dynamic]string)
                                     output-vars: (make [dynamic]string)}))
          materialize-op (if has-materialize
                           (physical-materialize-op-from-materialization materialization)
                           (Physical-Op {referenced-vars: (make [dynamic]string)
                                         input-vars: (make [dynamic]string)
                                         output-vars: (make [dynamic]string)}))]
      (return (Physical-Plan {ops: ops
                              materialization: materialization
                              has-project: has-project
                              project-op: project-op
                              has-materialize: has-materialize
                              materialize-op: materialize-op})
              true
              ""))))

(defn delete-physical-plan [plan: Physical-Plan]
  (for [op plan.ops]
    (delete op.referenced-vars)
    (delete op.input-vars)
    (delete op.output-vars))
  (delete plan.project-op.referenced-vars)
  (delete plan.project-op.input-vars)
  (delete plan.project-op.output-vars)
  (delete plan.materialize-op.referenced-vars)
  (delete plan.materialize-op.input-vars)
  (delete plan.materialize-op.output-vars)
  (delete-physical-materialization-plan plan.materialization)
  (delete plan.ops))

(defn physical-plan-step-count [plan: Physical-Plan] -> int
  (count plan.ops))

(defn query-relation-apply-physical-project-op [rel: Query-Relation, op: Physical-Op, materialization: Physical-Materialization-Plan] -> [out: Query-Relation, ok: bool]
  (when (or (not (= op.kind .Project))
            (not rel.has-typed-columns)
            (not (physical-materialization-projectable? materialization)))
    (return (query-relation-empty) false))
  (let [attrs (make [dynamic]string 0 (count op.output-vars))
        attr-sources (make [dynamic]string 0 (count op.output-vars))]
    (for [name op.output-vars]
      (let [[source source-ok] (relation-attr-source rel name)]
        (when (not source-ok)
          (delete attrs)
          (delete attr-sources)
          (return (query-relation-empty) false))
        (append-var-binding-attr! (addr attrs) (addr attr-sources) name source)))
    (let [builder (query-relation-builder (slice attrs 0))
          row 0]
      (while (< row rel.typed-rows)
        (when (not (query-relation-builder-add-relation-row-by-attrs! (addr builder) (slice attrs 0) rel row))
          (delete attrs)
          (delete attr-sources)
          (delete-query-relation-builder builder)
          (return (query-relation-empty) false))
        (set! row (+ row 1)))
      (return (Query-Relation {attrs: attrs
                               attr-sources: attr-sources
                               attr-index: (query-relation-attr-index (slice attrs 0))
                               tuples: builder.tuples
                               typed-columns: builder.typed-columns
                               typed-rows: builder.typed-rows
                               has-typed-columns: builder.typed-ok})
              true))))

(defn db-read-source-apply-physical-materialize-op [source: DB-Read-Source, sources: []DB-Read-Named-Source, query-value: Query, inputs: []Query-Input, rel: Query-Relation, op: Physical-Op, materialization: Physical-Materialization-Plan, registry: []Native-Query-Fn] -> [batch: Typed-Materialized-Batch, ok: bool, error: string]
  (when (or (not (= op.kind .Materialize))
            (not rel.has-typed-columns)
            (not (physical-materialization-materializable? materialization)))
    (return (typed-materialized-batch-empty) false "typed materialize op expected"))
  (case materialization.shape.kind
    .FlatPrimitiveResult
      (let [resolved (resolve-typed-flat-materialization rel materialization)]
        (when (not resolved.ok)
          (delete-resolved-typed-flat-materialization resolved)
          (return (typed-materialized-batch-empty) false "flat typed materialization could not be resolved"))
        (defer (delete-resolved-typed-flat-materialization resolved))
        (let [batch (materialize-typed-flat-batch rel resolved)]
          (return batch batch.ok (if batch.ok "" "flat typed materialization failed"))))
    .PullResult
      (materialize-source-typed-pull-batch source sources query-value inputs rel registry)
    .AggregateResult
      (let [batch (materialize-typed-aggregate-value-batch-with-fns query-value rel registry)]
        (return batch batch.ok (if batch.ok "" "aggregate typed materialization failed")))
    .PullAggregateResult
      (materialize-source-typed-pull-aggregate-batch source sources query-value inputs rel registry)

      (return (typed-materialized-batch-empty) false "unsupported typed materialization shape")))

(defn query-relation-has-physical-op-inputs? [rel: Query-Relation, op: Physical-Op] -> bool
  (for [name op.input-vars]
    (when (not (query-relation-has-attr? rel name))
      (return false)))
  true)

(defn query-relation-apply-resident-physical-scan-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, op: Physical-Op, stats: ^Query-Stats, allow-bound-apply: bool, observe-source-relation: bool] -> Query-Relation
  (let [clause-value query.clauses[op.item-index]]
    (set! stats^.clauses (+ stats^.clauses 1))
    (when (and allow-bound-apply
               (or (query-relation-should-bind-clause? rel clause-value)
                   (physical-op-scan-has-bound-pushdown-input? rel op)))
      (return (query-relation-apply-bound-clause-with-op db query inputs sources rel clause-value op stats)))
    (let [clause-rel (query-relation-from-clause-with-op db query inputs sources clause-value op)
          next (query-relation-join db sources rel clause-rel)]
      (when observe-source-relation
        (query-stats-observe-clause-relation! stats query sources clause-value clause-rel))
      (set! stats^.clause-candidates (+ stats^.clause-candidates (query-relation-row-count clause-rel)))
      (delete-query-relation clause-rel)
      next)))

(defn query-relation-apply-resident-physical-predicate-op [db: DB, query: Query, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-filter-predicate db rel query.predicates[op.item-index] registry))

(defn query-relation-apply-resident-physical-function-op [query: Query, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-extend-function rel query.function-clauses[op.item-index] registry))

(defn query-relation-apply-resident-physical-ground-op [query: Query, rel: Query-Relation, op: Physical-Op] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-ground rel query.grounds[op.item-index]))

(defn query-relation-apply-resident-physical-get-else-op [db: DB, query: Query, rel: Query-Relation, op: Physical-Op] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-get-else db rel query.get-elses[op.item-index]))

(defn query-relation-apply-resident-physical-get-some-op [db: DB, query: Query, rel: Query-Relation, op: Physical-Op] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-get-some db rel query.get-somes[op.item-index]))

(defn query-relation-apply-resident-physical-not-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-not db query inputs sources rel query.not-groups[op.item-index] registry))

(defn query-relation-apply-resident-physical-or-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-or db query inputs sources rel query.or-groups[op.item-index] registry))

(defn query-relation-apply-resident-physical-rule-call-op [db: DB, query: Query, sources: []DB-Source, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn, stats: ^Query-Stats, materialized-rule-cache: ^[dynamic]Materialized-Rule-Cache-Entry] -> Query-Relation
  (when (not (query-relation-has-physical-op-inputs? rel op))
    (return (query-relation-empty)))
  (query-relation-apply-rule-call db sources (slice query.rules 0) (slice query.rule-call-plans 0) rel query.rule-calls[op.item-index] op.item-index registry stats materialized-rule-cache))

(defn query-relation-apply-resident-physical-op [db: DB, query: Query, inputs: []Query-Input, sources: []DB-Source, rel: Query-Relation, op: Physical-Op, registry: []Native-Query-Fn, stats: ^Query-Stats, materialized-rule-cache: ^[dynamic]Materialized-Rule-Cache-Entry] -> Query-Relation
  (case op.kind
    .PrimaryScan
      (query-relation-apply-resident-physical-scan-op db query inputs sources rel op stats true true)
    .NamedSourceScan
      (query-relation-apply-resident-physical-scan-op db query inputs sources rel op stats true true)
    .RelationInput
      (query-relation-apply-resident-physical-scan-op db query inputs sources rel op stats (physical-op-scan-has-bound-pushdown-input? rel op) false)
    .BindJoinScan
      (query-relation-apply-resident-physical-scan-op db query inputs sources rel op stats true true)
    .StarJoin
      (let [[star-rel star-ok] (query-relation-from-entity-star-plan db query inputs sources registry stats)]
        (if star-ok
          star-rel
          (do
            (delete-query-relation star-rel)
            (query-relation-empty))))
    .Predicate
      (query-relation-apply-resident-physical-predicate-op db query rel op registry)
    .Function
      (query-relation-apply-resident-physical-function-op query rel op registry)
    .Not
      (query-relation-apply-resident-physical-not-op db query inputs sources rel op registry)
    .Or
      (query-relation-apply-resident-physical-or-op db query inputs sources rel op registry)
    .RuleCall
      (query-relation-apply-resident-physical-rule-call-op db query sources rel op registry stats materialized-rule-cache)
    .Ground
      (query-relation-apply-resident-physical-ground-op query rel op)
    .GetElse
      (query-relation-apply-resident-physical-get-else-op db query rel op)
    .GetSome
      (query-relation-apply-resident-physical-get-some-op db query rel op)

      (query-relation-empty)))

(defn query-steps-are-clauses-and-predicates? [query: Query] -> bool
  (when (= (count query.where-steps) 0)
    (return false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)))
      (return false)))
  true)

(defn rule-index-has-single-definition? [index: []Rule-Name-Index-Entry, name: string] -> bool
  (let [[entry-index found] (rule-name-index-entry index name)]
    (and found (= (count index[entry-index].indexes) 1))))

(defn rule-call-inlinable? [rules: []Rule, index: []Rule-Name-Index-Entry, deps: []Rule-Dependency, call: Rule-Call] -> bool
  (when (or call.has-source
            (not (rule-index-has-single-definition? index call.name))
            (rule-name-recursive-in-deps? deps call.name))
    (return false))
  (let [[rule rule-ok] (rule-name-index-first-matching-rule rules index call)]
    (when (not rule-ok)
      (return false))
    (when (not (= (count rule.params) (count call.args)))
      (return false))
    (when (or (> (count rule.get-elses) 0)
              (> (count rule.get-somes) 0)
              (> (count rule.grounds) 0)
              (> (count rule.not-groups) 0)
              (> (count rule.or-groups) 0))
      (return false))
    (for [inner-call rule.rule-calls]
      (when (not (rule-call-inlinable? rules index deps inner-call))
        (return false)))
    true))

(defn rule-var-fresh-name [name: string, id: int] -> string
  (fmt.tprintf "%s__rule_%d" name id))

(defstruct Rule-Inline-Binding {
  name: string
  term: Term
})

(defn rule-inline-binding-lookup [bindings: []Rule-Inline-Binding, name: string] -> [term: Term, ok: bool]
  (for [binding bindings]
    (when (= binding.name name)
      (return binding.term true)))
  (return (Term {}) false))

(defn rule-inline-binding-add! [bindings: ^[dynamic]Rule-Inline-Binding, name: string, term: Term]
  (arr.push! bindings^ (Rule-Inline-Binding {name: name term: term})))

(defn rule-inline-term [term: Term, subst: ^[dynamic]Rule-Inline-Binding, locals: ^[dynamic]Rule-Inline-Binding, id: int] -> Term
  (when (not (= term.kind .Var))
    (return term))
  (let [[existing existing-ok] (rule-inline-binding-lookup (slice subst^ 0) term.name)]
    (when existing-ok
      (return existing)))
  (let [[local local-ok] (rule-inline-binding-lookup (slice locals^ 0) term.name)]
    (when local-ok
      (return local)))
  (let [fresh (term-var (rule-var-fresh-name term.name id))]
    (rule-inline-binding-add! locals term.name fresh)
    fresh))

(defn rule-inline-clause [clause-value: Clause, subst: ^[dynamic]Rule-Inline-Binding, locals: ^[dynamic]Rule-Inline-Binding, id: int] -> Clause
  (Clause {e: (rule-inline-term clause-value.e subst locals id)
           a: (rule-inline-term clause-value.a subst locals id)
           v: (rule-inline-term clause-value.v subst locals id)
           tx-term: (rule-inline-term clause-value.tx-term subst locals id)
           op-term: (rule-inline-term clause-value.op-term subst locals id)
           source: clause-value.source
           has-source: clause-value.has-source
           source-width: clause-value.source-width}))

(defn rule-inline-predicate [predicate: Predicate, subst: ^[dynamic]Rule-Inline-Binding, locals: ^[dynamic]Rule-Inline-Binding, id: int] -> Predicate
  (let [terms (make [dynamic]Term 0 (count predicate.terms))]
    (for [term predicate.terms]
      (arr.push! terms (rule-inline-term term subst locals id)))
    (Predicate {op: predicate.op terms: terms})))

(defn rule-inline-function-clause [function: Function-Clause, subst: ^[dynamic]Rule-Inline-Binding, locals: ^[dynamic]Rule-Inline-Binding, id: int] -> Function-Clause
  (let [terms (make [dynamic]Term 0 (count function.terms))]
    (for [term function.terms]
      (arr.push! terms (rule-inline-term term subst locals id)))
    (Function-Clause {op: function.op terms: terms out: function.out out-vars: function.out-vars out-binding: function.out-binding is-tuple: function.is-tuple})))

(defn rule-inline-call [call: Rule-Call, subst: ^[dynamic]Rule-Inline-Binding, locals: ^[dynamic]Rule-Inline-Binding, id: int] -> Rule-Call
  (let [args (make [dynamic]Term 0 (count call.args))]
    (for [arg call.args]
      (arr.push! args (rule-inline-term arg subst locals id)))
    (Rule-Call {name: call.name source: call.source has-source: call.has-source args: args})))

(defn append-inlined-rule-call-steps! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, rule-calls: ^[dynamic]Rule-Call, steps: ^[dynamic]Query-Step, rules: []Rule, index: []Rule-Name-Index-Entry, deps: []Rule-Dependency, call: Rule-Call, next-id: ^int] -> bool
  (when (not (rule-call-inlinable? rules index deps call))
    (return false))
  (let [[rule rule-ok] (rule-name-index-first-matching-rule rules index call)]
    (when (not rule-ok)
      (return false))
    (let [subst (make [dynamic]Rule-Inline-Binding)
          locals (make [dynamic]Rule-Inline-Binding)
          id next-id^]
      (defer (delete subst))
      (defer (delete locals))
      (mut! next-id^ += 1)
      (for [param param-index rule.params]
        (rule-inline-binding-add! (addr subst) param call.args[param-index]))
      (for [step rule.body-steps]
        (if (= step.kind .Clause)
          (do
            (arr.push! clauses^ (rule-inline-clause rule.clauses[step.index] (addr subst) (addr locals) id))
            (arr.push! steps^ (Query-Step {kind: .Clause index: (- (count clauses^) 1)})))
          (if (= step.kind .Predicate)
            (do
              (arr.push! predicates^ (rule-inline-predicate rule.predicates[step.index] (addr subst) (addr locals) id))
              (arr.push! steps^ (Query-Step {kind: .Predicate index: (- (count predicates^) 1)})))
            (if (= step.kind .Function)
              (do
                (arr.push! function-clauses^ (rule-inline-function-clause rule.function-clauses[step.index] (addr subst) (addr locals) id))
                (arr.push! steps^ (Query-Step {kind: .Function index: (- (count function-clauses^) 1)})))
              (if (= step.kind .RuleCall)
                (let [inner-call (rule-inline-call rule.rule-calls[step.index] (addr subst) (addr locals) id)
                      inner-ok (append-inlined-rule-call-steps! clauses predicates function-clauses rule-calls steps rules index deps inner-call next-id)]
                  (delete inner-call.args)
                  (when (not inner-ok)
                    (return false)))
                (return false))))))))
	  true)

(defn rule-call-correlated-with-vars? [call: Rule-Call, available: []string] -> bool
  (for [arg call.args]
    (when (and (= arg.kind .Var)
               (string-slice-contains? available arg.name))
      (return true)))
  false)

(defn query-source-inline-simple-rules [query-value: Query] -> [out: Query, ok: bool]
  (when (= (count query-value.rule-calls) 0)
    (return (Query {}) false))
  (let [index (rule-name-index-build (slice query-value.rules 0))
        deps (rules-dependency-graph-indexed (slice query-value.rules 0) (slice index 0))
        clauses (make [dynamic]Clause)
        predicates (make [dynamic]Predicate)
        function-clauses (make [dynamic]Function-Clause)
	        rule-calls (make [dynamic]Rule-Call)
	        steps (make [dynamic]Query-Step)
	        available (make [dynamic]string)
	        next-id 0
	        changed false]
	    (defer (delete-rule-name-index index))
	    (defer (delete-rule-dependency-graph deps))
	    (defer (delete available))
	    (for [step query-value.where-steps]
	      (if (= step.kind .Clause)
	        (do
	          (arr.push! clauses query-value.clauses[step.index])
	          (arr.push! steps (Query-Step {kind: .Clause index: (- (count clauses) 1)}))
	          (append-clause-vars! (addr available) query-value.clauses[step.index]))
	        (if (= step.kind .Predicate)
	          (do
	            (arr.push! predicates query-value.predicates[step.index])
	            (arr.push! steps (Query-Step {kind: .Predicate index: (- (count predicates) 1)})))
	          (if (= step.kind .Function)
	            (do
	              (arr.push! function-clauses query-value.function-clauses[step.index])
	              (arr.push! steps (Query-Step {kind: .Function index: (- (count function-clauses) 1)}))
	              (append-function-output-vars! (addr available) query-value.function-clauses[step.index]))
	            (if (= step.kind .RuleCall)
	              (if (and (not (rule-call-correlated-with-vars? query-value.rule-calls[step.index] (slice available 0)))
	                       (append-inlined-rule-call-steps! (addr clauses) (addr predicates) (addr function-clauses) (addr rule-calls) (addr steps) (slice query-value.rules 0) (slice index 0) (slice deps 0) query-value.rule-calls[step.index] (addr next-id)))
	                (do
	                  (set! changed true)
	                  (append-rule-call-vars! (addr available) query-value.rule-calls[step.index]))
	                (do
	                  (arr.push! rule-calls query-value.rule-calls[step.index])
	                  (arr.push! steps (Query-Step {kind: .RuleCall index: (- (count rule-calls) 1)}))
	                  (append-rule-call-vars! (addr available) query-value.rule-calls[step.index])))
	              (do
	                (delete clauses)
	                (delete predicates)
	                (delete function-clauses)
	                (delete rule-calls)
	                (delete steps)
	                (return (Query {}) false)))))))
    (when (not changed)
      (delete clauses)
      (delete predicates)
      (delete function-clauses)
      (delete rule-calls)
      (delete steps)
      (return (Query {}) false))
    (let [out-query (query (slice query-value.find 0)
                           (slice query-value.with 0)
                           (slice query-value.inputs 0)
                           (slice query-value.collection-inputs 0)
                           (slice query-value.tuple-inputs 0)
                           (slice query-value.relation-inputs 0)
                           (slice clauses 0)
                           (slice predicates 0)
                           (slice function-clauses 0)
                           (slice query-value.rules 0)
                           (slice rule-calls 0)
                           (slice query-value.get-elses 0)
                           (slice query-value.get-somes 0)
                           (slice query-value.grounds 0)
                           (slice query-value.not-groups 0)
                           (slice query-value.or-groups 0)
                           (slice query-value.pulls 0)
                           (slice query-value.aggregates 0))
          out-with-steps (query-with-where-steps out-query (slice steps 0))]
      (delete clauses)
      (delete predicates)
      (delete function-clauses)
      (delete rule-calls)
      (delete steps)
      (delete out-with-steps.input-specs)
      (set! out-with-steps.input-specs (arr.into [dynamic]Query-Input-Spec (slice query-value.input-specs 0)))
      (set! out-with-steps.has-default-source-input query-value.has-default-source-input)
      (set! out-with-steps.has-rules-input query-value.has-rules-input)
      (set! out-with-steps.has-return-map query-value.has-return-map)
      (set! out-with-steps.return-map-marker query-value.return-map-marker)
      (delete out-with-steps.return-map-keys)
      (set! out-with-steps.return-map-keys (arr.into [dynamic]string (slice query-value.return-map-keys 0)))
      (return out-with-steps true))))

(defn binding-available-vars [binding: Binding] -> [dynamic]string
  (let [out (make [dynamic]string 0 (count binding.items))]
    (for [item binding.items]
      (append-var-once! (addr out) item.name))
    out))

(defn query-step-ready-for-binding? [query: ^Query, step: Query-Step, binding: Binding, registry: []Native-Query-Fn] -> bool
  (when (= step.kind .Clause)
    (return true))
  (let [available (binding-available-vars binding) :defer
        [ok _] (validate-query-ordered-step-with-fns (addr available) query^ step registry)]
    ok))

(defn predicate-ready-with-vars? [predicate: Predicate, available: []string] -> bool
  (let [vars (make [dynamic]string) :defer
        seen (set.empty string) :defer]
    (append-predicate-vars-indexed! (addr vars) (addr seen) predicate)
    (for [name vars]
      (when (not (string-slice-contains? available name))
        (return false)))
    true))

(defn available-vars-after-clause [binding: Binding, clause-value: Clause] -> [dynamic]string
  (let [available (binding-available-vars binding)]
    (append-clause-vars! (addr available) clause-value)
    available))

(defn best-predicate-score-unlocked-by-clause [query: ^Query, steps: []Query-Step, binding: Binding, clause-value: Clause] -> int
  (let [available (available-vars-after-clause binding clause-value) :defer
        best -1]
    (for [step steps]
      (when (= step.kind .Predicate)
        (let [predicate query^.predicates[step.index]]
          (when (predicate-ready-with-vars? predicate (slice available 0))
            (let [score (predicate-selectivity-score predicate)]
              (when (or (= best -1)
                        (< score best))
                (set! best score)))))))
    best))

(defn best-ready-clause-step-index [db: DB, sources: []DB-Source, query: ^Query, steps: []Query-Step, binding: Binding, registry: []Native-Query-Fn] -> [index: int, ok: bool]
  (let [best -1
        best-score 0
        best-unlocked-predicate-score -1
        best-count -1]
    (for [step step-index steps]
      (when (and (= step.kind .Clause)
                 (query-step-ready-for-binding? query step binding registry))
        (let [clause query^.clauses[step.index]
              score (clause-selectivity-score clause binding)
              unlocked-predicate-score (best-predicate-score-unlocked-by-clause query steps binding clause)]
          (when (or (= best -1)
                    (< score best-score)
                    (and (= score best-score)
                         (>= unlocked-predicate-score 0)
                         (or (< best-unlocked-predicate-score 0)
                             (< unlocked-predicate-score best-unlocked-predicate-score))))
            (set! best step-index)
            (set! best-score score)
            (set! best-unlocked-predicate-score unlocked-predicate-score)
            (set! best-count -1))
          (when (and (not (= best -1))
                     (= score best-score)
                     (= unlocked-predicate-score best-unlocked-predicate-score)
                     (not (= step-index best)))
            (when (< best-count 0)
              (set! best-count (clause-candidate-count-estimate db sources query^.clauses[steps[best].index] binding)))
            (let [candidate-count (clause-candidate-count-estimate db sources clause binding)]
              (when (< candidate-count best-count)
                (set! best step-index)
                (set! best-unlocked-predicate-score unlocked-predicate-score)
                (set! best-count candidate-count)))))))
    (return best (>= best 0))))

(defn physical-scalar-requirement-selectivity-score [requirement: Physical-Scalar-Requirement] -> int
  (case requirement.kind
    .VarValueCompare
      (cond
        requirement.is-equality 0
        requirement.is-range 1
        :else 4)
    .VarVarCompare
      (cond
        requirement.is-equality 2
        requirement.is-range 3
        :else 5)
    .UnaryPredicate
      6
    .UnknownScalarRequirement
      10
      10))

(defn predicate-selectivity-score [predicate: Predicate] -> int
  (physical-scalar-requirement-selectivity-score (physical-predicate-requirement predicate)))

(defn best-ready-predicate-step-index [query: ^Query, steps: []Query-Step, binding: Binding, registry: []Native-Query-Fn] -> [index: int, ok: bool]
  (let [best -1
        best-score 0]
    (for [step step-index steps]
      (when (and (= step.kind .Predicate)
                 (query-step-ready-for-binding? query step binding registry))
        (let [score (predicate-selectivity-score query^.predicates[step.index])]
          (when (or (= best -1)
                    (< score best-score))
            (set! best step-index)
            (set! best-score score)))))
    (return best (>= best 0))))

(defn first-ready-predicate-step-index [query: ^Query, steps: []Query-Step, binding: Binding, registry: []Native-Query-Fn] -> [index: int, ok: bool]
  (for [step step-index steps]
    (when (and (= step.kind .Predicate)
               (query-step-ready-for-binding? query step binding registry))
      (return step-index true)))
  (return -1 false))

(defn bindings-after-dependency-planned-where-profiled-with-fns [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (let [bindings (bindings-from-inputs db query^ inputs)
        remaining (arr.into [dynamic]Query-Step (slice query^.where-steps 0))]
    (defer (delete remaining))
    (set! stats^.input-bindings (count bindings))
    (query-stats-observe-bindings! stats (count bindings))
    (while (and (> (count bindings) 0)
                (> (count remaining) 0))
      (let [[predicate-index predicate-ok] (best-ready-predicate-step-index query (slice remaining 0) bindings[0] registry)
            [clause-index clause-ok] (best-ready-clause-step-index db sources query (slice remaining 0) bindings[0] registry)
            chosen-index (if (and predicate-ok (> (count bindings) 1))
                           predicate-index
                           (if clause-ok clause-index predicate-index))]
        (when (< chosen-index 0)
          (delete bindings)
          (return (make [dynamic]Binding)))
        (let [step remaining[chosen-index]
              next-bindings (make [dynamic]Binding)]
          (if (= step.kind .Clause)
            (let [clause query^.clauses[step.index]
                  pushdown-op (physical-pushdown-op-from-clause-and-steps query^ clause (slice remaining 0))]
              (set! stats^.steps (+ stats^.steps 1))
              (for [binding bindings]
                (append-bindings-after-clause-with-sources-profiled-with-op! (addr next-bindings) db sources clause binding pushdown-op stats)))
            (do
              (delete next-bindings)
              (set! next-bindings (bindings-after-query-step-profiled-with-fns db sources query (slice bindings 0) step registry stats))))
          (delete bindings)
          (set! bindings next-bindings)
          (query-stats-observe-bindings! stats (count bindings))
          (arr.remove-ordered-at! remaining chosen-index))))
    bindings))

(defn bindings-after-ordered-where-profiled-with-fns [db: DB, sources: []DB-Source, query: ^Query, inputs: []Query-Input, registry: []Native-Query-Fn, stats: ^Query-Stats] -> [dynamic]Binding
  (when (query-steps-are-clauses-and-predicates? query^)
    (return (bindings-after-dependency-planned-where-profiled-with-fns db sources query inputs registry stats)))
  (let [bindings (bindings-from-inputs db query^ inputs)
        step-index 0]
    (set! stats^.input-bindings (count bindings))
    (query-stats-observe-bindings! stats (count bindings))
    (while (< step-index (count query^.where-steps))
      (let [step query^.where-steps[step-index]]
        (if (= step.kind .Clause)
          (let [clauses (make [dynamic]Clause)]
            (while (and (< step-index (count query^.where-steps))
                        (= query^.where-steps[step-index].kind .Clause))
              (arr.push! clauses query^.clauses[query^.where-steps[step-index].index])
              (set! step-index (+ step-index 1)))
            (let [next-bindings (bindings-after-planned-clauses-profiled db sources (slice bindings 0) (slice clauses 0) stats)]
              (delete clauses)
              (delete bindings)
              (set! bindings next-bindings)))
          (do
            (let [next-bindings (bindings-after-query-step-profiled-with-fns db sources query (slice bindings 0) step registry stats)]
              (delete bindings)
              (set! bindings next-bindings)
              (query-stats-observe-bindings! stats (count bindings)))
            (set! step-index (+ step-index 1)))))
      (when (= (count bindings) 0)
        (return bindings)))
    (return bindings)))

(defn profiled-result-set [result: Result-Set, stats: Query-Stats] -> Profiled-Result-Set
  (Profiled-Result-Set {result: result stats: stats}))

(defn query-single-attr-value-distinct-clause [query: Query] -> [clause-value: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 1)
                    (= query.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [candidate-clause query.clauses[0]]
      (when (or candidate-clause.has-source
                (not (= candidate-clause.a.kind .Value))
                (not (= candidate-clause.a.value.kind .Keyword))
                (not (= candidate-clause.v.kind .Var))
                (not (= candidate-clause.v.name query.find[0]))
                (not (or (= candidate-clause.e.kind .Wildcard)
                         (= candidate-clause.e.kind .Var))))
        (return empty-clause false))
      (return candidate-clause true))))

(defn append-distinct-single-value-row! [rows: ^[dynamic]Result-Row, value: Value]
  (let [values (make [dynamic]Value 0 1)
        pulls ([dynamic]Pull-Result [])]
    (arr.push! values value)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn append-distinct-single-value-row-if-new! [rows: ^[dynamic]Result-Row, seen: (ptr (map string (struct {}))), value: Value]
  (let [[key key-ok] (primitive-value-dedupe-key value)]
    (if key-ok
      (when (not (set.contains? seen^ key))
        (set.add! seen^ key)
        (append-distinct-single-value-row! rows (value-owned value)))
      (when (not (row-values-exist? (slice rows^ 0) ([]Value [value])))
        (append-distinct-single-value-row! rows (value-owned value))))))

(defn append-two-value-row! [rows: ^[dynamic]Result-Row, first: Value, second: Value]
  (let [values (make [dynamic]Value 0 2)
        pulls ([dynamic]Pull-Result [])]
    (arr.push! values first)
    (arr.push! values second)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn append-owned-two-value-row! [rows: ^[dynamic]Result-Row, first: Value, second: Value]
  (append-two-value-row! rows (value-owned first) (value-owned second)))

(defn append-three-value-row! [rows: ^[dynamic]Result-Row, first: Value, second: Value, third: Value]
  (let [values (make [dynamic]Value 0 3)
        pulls ([dynamic]Pull-Result [])]
    (arr.push! values first)
    (arr.push! values second)
    (arr.push! values third)
    (arr.push! rows^ (Result-Row {values: values pulls: pulls}))))

(defn query-single-entity-by-attr-value-clause [db: DB, query: Query] -> [clause-value: Clause, ok: bool]
  (let [empty-clause (Clause {})]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.not-groups) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 1)
                    (= query.where-steps[0].kind .Clause)))
      (return empty-clause false))
    (let [candidate-clause query.clauses[0]]
      (when (or candidate-clause.has-source
                (not (= candidate-clause.e.kind .Var))
                (not (= candidate-clause.e.name query.find[0]))
                (not (= candidate-clause.a.kind .Value))
                (not (= candidate-clause.a.value.kind .Keyword))
                (tx-data-modifies-validation-schema? (Tx-Data {a: candidate-clause.a.value.text}))
                (schema-ref-target? db candidate-clause.a.value.text)
                (not (= candidate-clause.v.kind .Value))
                (not (= candidate-clause.tx-term.kind .Wildcard))
                (not (= candidate-clause.op-term.kind .Wildcard)))
        (return empty-clause false))
      (return candidate-clause true))))

(defn append-entity-row! [rows: ^[dynamic]Result-Row, entity: u64]
  (append-distinct-single-value-row! rows (value-entity entity)))

(defn q-single-entity-by-attr-value-profiled [db: DB, clause-value: Clause, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        attr clause-value.a.value.text
        value clause-value.v.value
        view (db-index-view db .AVET)
        low (lower-bound-index-view db view "avet" 0 attr value)
        high (upper-bound-index-view db view "avet" 0 attr value)
        rows (make [dynamic]Result-Row 0 (- high low))
        all-current (all-datoms-current? db)]
    (set! out-stats.steps 1)
    (set! out-stats.clauses 1)
    (set! out-stats.clause-candidates (- high low))
    (set! out-stats.max-intermediate-bindings (- high low))
    (if all-current
      (let [i low]
        (while (< i high)
        (let [datom db.datoms[(db-index-view-at view i)]]
          (append-entity-row! (addr rows) datom.e))
        (set! i (+ i 1))))
      (let [seen (set.empty u64)]
        (defer (delete seen))
        (let [i low]
          (while (< i high)
          (let [datom-index (db-index-view-at view i)
                datom db.datoms[datom-index]]
            (when (datom-current-at? db datom-index)
              (let [already-seen (set.contains? seen datom.e)]
                (when (not already-seen)
                  (set.add! seen datom.e)
                  (append-entity-row! (addr rows) datom.e)))))
          (set! i (+ i 1))))))
    (set! out-stats.output-rows (count rows))
    (profiled-result-set (result-set-ok rows) out-stats)))

(defn q-query-entity-column [db: DB, query: Query, inputs: []Query-Input] -> [entities: [dynamic]u64, ok: bool]
  (let [out (make [dynamic]u64)]
    (when (> (count inputs) 0)
      (return out false))
    (let [[clause-value clause-ok] (query-single-entity-by-attr-value-clause db query)]
      (when (not clause-ok)
        (return out false))
      (let [attr clause-value.a.value.text
            value clause-value.v.value
            view (db-index-view db .AVET)
            low (lower-bound-index-view db view "avet" 0 attr value)
            high (upper-bound-index-view db view "avet" 0 attr value)
            all-current (all-datoms-current? db)]
        (if all-current
          (let [i low]
            (while (< i high)
              (arr.push! out db.datoms[(db-index-view-at view i)].e)
              (set! i (+ i 1))))
          (let [seen (set.empty u64)]
            (defer (delete seen))
            (let [i low]
              (while (< i high)
              (let [datom-index (db-index-view-at view i)
                    datom db.datoms[datom-index]]
                (when (datom-current-at? db datom-index)
                  (let [already-seen (set.contains? seen datom.e)]
                    (when (not already-seen)
                      (set.add! seen datom.e)
                      (arr.push! out datom.e)))))
              (set! i (+ i 1)))))))
      (return out true))))

(defn q-query-string-column [db: DB, query: Query, inputs: []Query-Input] -> [values: [dynamic]string, ok: bool]
  (let [out (make [dynamic]string)]
    (when (not (and (= (count query.find) 1)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)))
      (return out false))
    (let [[missing-plan missing-ok] (query-missing-attr-projection-plan db query)]
      (when missing-ok
        (delete out)
        (return (q-missing-attr-string-column db missing-plan))))
    (let [result (q-query-with-inputs db query inputs)]
      (defer (delete-result-set-shallow result))
      (when (not result.ok)
        (return out false))
      (for [row result.rows]
        (when (not (= (count row.values) 1))
          (return out false))
        (let [value row.values[0]]
          (if (or (= value.kind .String)
                  (= value.kind .Keyword)
                  (= value.kind .Symbol)
                  (= value.kind .Uuid))
            (arr.push! out (string-owned value.text))
            (return out false))))
      (return out true))))

(defstruct Distinct-Attr-Value {
  first-e: u64
  value: Value
})

(defn distinct-attr-value-less? [left: Distinct-Attr-Value, right: Distinct-Attr-Value] -> bool
  (if (not (= left.first-e right.first-e))
    (< left.first-e right.first-e)
    (value-less? left.value right.value)))

(defn sort-distinct-attr-values! [values: ^[dynamic]Distinct-Attr-Value]
  (let [i 1]
    (while (< i (count values^))
    (let [item values^[i]
          j i]
      (while (and (> j 0)
                  (distinct-attr-value-less? item values^[(- j 1)]))
        (set! values^[j] values^[(- j 1)])
        (set! j (- j 1)))
      (set! values^[j] item))
    (set! i (+ i 1)))))

(defn q-single-attr-value-distinct-profiled [db: DB, clause-value: Clause, stats: Query-Stats] -> Profiled-Result-Set
  (let [out-stats stats
        attr clause-value.a.value.text
        view (db-index-view db .AVET)
        attr-prefix ([]Value [(value-keyword attr)])
        low (lower-bound-index-view-values db view attr-prefix)
        high (upper-bound-index-view-values db view attr-prefix)
        distinct-values (make [dynamic]Distinct-Attr-Value)
        all-current (all-datoms-current? db)]
    (defer (delete distinct-values))
    (set! out-stats.steps 1)
    (set! out-stats.clauses 1)
    (set! out-stats.clause-candidates (- high low))
    (set! out-stats.max-intermediate-bindings (- high low))
    (let [i low]
      (while (< i high)
        (let [first-index (db-index-view-at view i)
              datom db.datoms[first-index]
              value datom.v]
          (if all-current
            (do
              (while (and (< i high)
                          (value-equal? db.datoms[(db-index-view-at view i)].v value))
                (set! i (+ i 1)))
              (arr.push! distinct-values (Distinct-Attr-Value {first-e: datom.e value: value})))
            (let [first-current-e: u64 0
                  first-current-value (Value {})
                  has-current false]
              (while (and (< i high)
                          (value-equal? db.datoms[(db-index-view-at view i)].v value))
                (let [candidate-index (db-index-view-at view i)
                      candidate db.datoms[candidate-index]]
                  (when (and (datom-current-at? db candidate-index)
                             (not has-current))
                    (set! first-current-e candidate.e)
                    (set! first-current-value candidate.v)
                    (set! has-current true)))
                (set! i (+ i 1)))
              (when has-current
                (arr.push! distinct-values (Distinct-Attr-Value {first-e: first-current-e value: first-current-value})))))))
    (sort-distinct-attr-values! (addr distinct-values))
    (let [rows (make [dynamic]Result-Row 0 (count distinct-values))]
      (for [item distinct-values]
        (append-distinct-single-value-row! (addr rows) item.value))
      (set! out-stats.output-rows (count rows))
      (profiled-result-set (result-set-ok rows) out-stats)))))

