                  (= query.where-steps[5].index 5)
                  (= query.where-steps[6].kind .Clause)
                  (= query.where-steps[6].index 6)
                  (= query.where-steps[7].kind .Predicate)
                  (= query.where-steps[7].index 0)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (source-final-filter-ref-chain-projection-from-candidates
