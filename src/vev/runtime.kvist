  (delete columns.values))

(defn reset-entity-int-pair-columns-capacity! [columns: ^Entity-Int-Pair-Columns, capacity: int]
  (delete columns^.entities)
  (delete columns^.values)
  (set! columns^.entities (make [dynamic]u64 0 capacity))
  (set! columns^.values (make [dynamic]i64 0 capacity)))

