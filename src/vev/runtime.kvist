                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 1)
                  (= (count query.grounds) 1)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 0)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Ground)
                  (= query.where-steps[1].kind .GetSome)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].index 0)))
    (return (empty-source-fixed-entity-get-some-projection) false))
  (let [ground query.grounds[0]
        get-some query.get-somes[0]
        [entity entity-ok] (query-entity-term-literal ground.source)]
    (when (or (not entity-ok)
              (not (= ground.binding.kind .None))
              ground.is-collection
              ground.is-tuple
              ground.is-relation
              (not (= get-some.e.kind .Var))
              (not (= ground.out get-some.e.name))
              (not (or (and (= query.find[0] get-some.out-attr)
                            (= query.find[1] get-some.out-value))
                       (and (= query.find[0] get-some.out-value)
                            (= query.find[1] get-some.out-attr)))))
      (return (empty-source-fixed-entity-get-some-projection) false))
    (return (Source-Fixed-Entity-Get-Some-Projection {entity: entity
                                                      out-attr: get-some.out-attr
                                                      out-value: get-some.out-value})
            true)))

(defn db-read-source-query-missing-attr-projection [query: Query] -> [projection: Missing-Attr-Projection-Plan, ok: bool]
  (let [out (empty-missing-attr-projection-plan)]
    (when (not (and (= (count query.find) 1)
                    (= (count query.with) 0)
                    (= (count query.inputs) 0)
                    (= (count query.collection-inputs) 0)
                    (= (count query.tuple-inputs) 0)
                    (= (count query.relation-inputs) 0)
                    (= (count query.input-specs) 0)
                    (= (count query.pulls) 0)
                    (= (count query.aggregates) 0)
                    (= (count query.rules) 0)
                    (= (count query.rule-calls) 0)
                    (= (count query.predicates) 0)
                    (= (count query.function-clauses) 0)
                    (= (count query.get-elses) 0)
                    (= (count query.get-somes) 0)
                    (= (count query.grounds) 0)
                    (= (count query.or-groups) 0)
                    (= (count query.not-groups) 1)
                    (= (count query.clauses) 1)
                    (= (count query.where-steps) 2)
                    (= query.where-steps[0].kind .Clause)
                    (= query.where-steps[1].kind .Not)))
      (return out false))
    (let [value-clause query.clauses[0]
          group query.not-groups[0]]
      (when (or (not (= value-clause.e.kind .Var))
                (not (= value-clause.a.kind .Value))
                (not (= value-clause.a.value.kind .Keyword))
                (reverse-attr? value-clause.a.value.text)
                (not (= value-clause.v.kind .Var))
                (not (= value-clause.v.name query.find[0]))
                (not (= value-clause.tx-term.kind .Wildcard))
                (not (= value-clause.op-term.kind .Wildcard))
                group.has-join
                (not (= (count group.clauses) 1))
                (> (count group.predicates) 0)
                (> (count group.function-clauses) 0)
                (> (count group.not-groups) 0)
                (not (= (count group.steps) 1))
                (not (= group.steps[0].kind .Clause))
                (not (= group.steps[0].index 0)))
        (return out false))
      (let [missing-clause group.clauses[0]]
        (when (or (not (= missing-clause.e.kind .Var))
                  (not (= missing-clause.e.name value-clause.e.name))
                  (not (= missing-clause.has-source value-clause.has-source))
                  (and value-clause.has-source
                       (not (= missing-clause.source value-clause.source)))
                  (not (= missing-clause.a.kind .Value))
                  (not (= missing-clause.a.value.kind .Keyword))
                  (reverse-attr? missing-clause.a.value.text)
                  (not (= missing-clause.v.kind .Wildcard)))
          (return out false))
        (return (Missing-Attr-Projection-Plan {entity-var: value-clause.e.name
                                               value-var: value-clause.v.name
                                               value-attr: value-clause.a.value.text
                                               missing-attr: missing-clause.a.value.text})
                true)))))

(defn db-read-source-query-filtered-entity-attr-value-projection [query: Query] -> [projection: Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (or (= (count query.find) 1)
                       (= (count query.find) 2))
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Clause)))
    (return (empty-entity-attr-value-projection) false))
  (let [left query.clauses[0]
        right query.clauses[1]]
    (when (or (not (= left.has-source right.has-source))
              (and left.has-source (not (= left.source right.source)))
              (not (= left.e.kind .Var))
              (not (= right.e.kind .Var))
              (not (= left.e.name right.e.name))
              (not (= left.a.kind .Value))
              (not (= right.a.kind .Value))
              (not (= left.a.value.kind .Keyword))
              (not (= right.a.value.kind .Keyword))
              (not (= left.tx-term.kind .Wildcard))
              (not (= right.tx-term.kind .Wildcard))
              (not (= left.op-term.kind .Wildcard))
              (not (= right.op-term.kind .Wildcard)))
      (return (empty-entity-attr-value-projection) false))
    (let [filter-clause (if (= left.v.kind .Value) left right)
          value-clause (if (= left.v.kind .Value) right left)]
      (when (or (not (= filter-clause.v.kind .Value))
                (not (= value-clause.v.kind .Var))
                (not (if (= (count query.find) 1)
                       (= query.find[0] value-clause.v.name)
                       (or (and (= query.find[0] filter-clause.e.name)
                                (= query.find[1] value-clause.v.name))
                           (and (= query.find[0] value-clause.v.name)
                                (= query.find[1] filter-clause.e.name))))))
        (return (empty-entity-attr-value-projection) false))
      (return (Entity-Attr-Value-Projection {entity-var: filter-clause.e.name
                                             filter-attr: filter-clause.a.value.text
                                             filter-value: filter-clause.v.value
                                             value-attr: value-clause.a.value.text
                                             value-var: value-clause.v.name})
              true))))

(defn query-entity-term-literal [term: Term] -> [entity: u64, ok: bool]
  (when (not (= term.kind .Value))
    (return 0 false))
  (cond
    (= term.value.kind .Entity) (return term.value.entity true)
    (= term.value.kind .Int) (return (u64 term.value.int-value) true)
    :else (return 0 false)))

(defn db-read-source-query-fixed-entity-attr-projection [query: Query] -> [projection: Source-Fixed-Entity-Attr-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-fixed-entity-attr-projection) false))
  (let [clause-value query.clauses[0]
        [entity entity-ok] (query-entity-term-literal clause-value.e)]
    (when (or (not entity-ok)
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (not (= query.find[0] clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-fixed-entity-attr-projection) false))
    (return (Source-Fixed-Entity-Attr-Projection {entity: entity
                                                  attr: clause-value.a.value.text
                                                  value-var: clause-value.v.name})
            true)))

(defn db-read-source-query-ground-fixed-entity-attr-projection [query: Query] -> [projection: Source-Fixed-Entity-Attr-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 1)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Ground)
                  (= query.where-steps[1].kind .Clause)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].index 0)))
    (return (empty-source-fixed-entity-attr-projection) false))
  (let [ground query.grounds[0]
        clause-value query.clauses[0]
        [entity entity-ok] (query-entity-term-literal ground.source)]
    (when (or (not entity-ok)
              (not (= ground.out clause-value.e.name))
              (not (= ground.binding.kind .None))
              ground.is-collection
              ground.is-tuple
              ground.is-relation
              (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (not (= query.find[0] clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-fixed-entity-attr-projection) false))
    (return (Source-Fixed-Entity-Attr-Projection {entity: entity
                                                  attr: clause-value.a.value.text
                                                  value-var: clause-value.v.name})
            true)))

