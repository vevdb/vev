                  (= (count query.where-steps) 8)
                  (query-find-vars-unique? query)))
    (return (empty-source-multi-hop-ref-chain-projection) false))
  (when (not (and (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].kind .Clause)
                  (= query.where-steps[1].index 1)
                  (= query.where-steps[2].kind .Clause)
