          hop2-heads (make (map u64 int)) :defer
          hop2-links (make [dynamic]Source-Multi-Hop-Ref-Chain-Link)]
      (defer (delete-source-multi-hop-ref-chain-links filter-links))
      (defer (delete-source-multi-hop-ref-chain-links first-value-links))
      (defer (delete-source-multi-hop-ref-chain-links hop1-links))
      (defer (delete-source-multi-hop-ref-chain-links hop2-links))
      (let [[anchor-stream anchor-ok anchor-error] (source-attr-value-match-stream source projection.anchor-attr anchor-value)]
        (when (not anchor-ok)
          (return (result-set-error anchor-error)))
        (while anchor-stream.has-current
          (let [anchor-datom (source-attr-value-match-current anchor-stream)]
            (when (not (set.contains? anchor-entities anchor-datom.e))
              (set.add! anchor-entities anchor-datom.e)
              (arr.push! anchor-entity-list anchor-datom.e)))
          (let [[anchor-advance-ok anchor-advance-error] (advance-source-attr-value-match-stream! source (addr anchor-stream))]
            (when (not anchor-advance-ok)
              (delete-source-attr-value-match-stream anchor-stream)
              (return (result-set-error anchor-advance-error)))))
        (delete-source-attr-value-match-stream anchor-stream))
      (arr.sort! anchor-entity-list)
      (let [[reverse-ok reverse-error _ _] (append-source-multi-hop-ref-chain-first-entities-from-frontier! source projection.reverse-ref-attr (slice anchor-entity-list 0) (addr first-entities) (addr first-entity-list))]
        (when (not reverse-ok)
          (return (result-set-error reverse-error))))
      (let [[filter-ok filter-error] (append-source-multi-hop-ref-chain-filter-links! source projection (addr first-entities) (addr filter-heads) (addr filter-links))]
        (when (not filter-ok)
          (delete-result-rows-owned-values rows)
          (return (result-set-error filter-error))))
      (let [[first-value-ok first-value-error] (append-source-multi-hop-ref-chain-first-value-links! source projection (addr filter-heads) (slice filter-links 0) (addr first-value-heads) (addr first-value-links))]
        (when (not first-value-ok)
          (delete-result-rows-owned-values rows)
          (return (result-set-error first-value-error))))
      (let [[hop1-ok hop1-error] (append-source-multi-hop-ref-chain-propagated-links! source projection.hop1-attr (addr first-value-heads) (slice first-value-links 0) (addr hop1-heads) (addr hop1-links))]
        (when (not hop1-ok)
