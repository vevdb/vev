(defn source-var-equality-filter [predicate: Predicate, var-name: string] -> [value: Value, ok: bool]
  (let [requirement (physical-predicate-requirement predicate)]
    (when (not (and (= requirement.kind .VarValueCompare)
                    (= requirement.op "=")
                    (= requirement.var-name var-name)
                    (= requirement.value-term.kind .Value)))
      (return (Value {}) false))
    (return requirement.value-term.value true)))

(defn range-predicate-op? [op: string] -> bool
  (physical-compare-op-range? op))

(defn inverted-range-predicate-op [op: string] -> [inverted: string, ok: bool]
  (physical-inverted-compare-op op))

(defn source-var-range-filter [predicate: Predicate, var-name: string] -> [op: string, value: Value, ok: bool]
  (let [requirement (physical-predicate-requirement predicate)]
    (when (not (and (= requirement.kind .VarValueCompare)
                    requirement.is-range
                    (= requirement.var-name var-name)
                    (= requirement.value-term.kind .Value)))
      (return "" (Value {}) false))
    (return requirement.op requirement.value-term.value true)))

(defn source-var-term-equality-filter [predicate: Predicate, var-name: string] -> [term: Term, ok: bool]
  (let [requirement (physical-predicate-requirement predicate)]
    (when (not (and (= requirement.kind .VarValueCompare)
                    (= requirement.op "=")
                    (= requirement.var-name var-name)))
      (return (Term {}) false))
    (return requirement.value-term true)))

(defn source-var-term-range-filter [predicate: Predicate, var-name: string] -> [op: string, term: Term, ok: bool]
  (let [requirement (physical-predicate-requirement predicate)]
    (when (not (and (= requirement.kind .VarValueCompare)
                    requirement.is-range
                    (= requirement.var-name var-name)))
      (return "" (Term {}) false))
    (return requirement.op requirement.value-term true)))

(defn source-var-literal-equality-filter [predicate: Predicate, var-name: string] -> [value: Value, ok: bool]
  (let [[term term-ok] (source-var-term-equality-filter predicate var-name)]
    (when (not (and term-ok (= term.kind .Value)))
      (return (Value {}) false))
    (return term.value true)))

(defn source-var-literal-range-filter [predicate: Predicate, var-name: string] -> [op: string, value: Value, ok: bool]
  (let [[filter-op term term-ok] (source-var-term-range-filter predicate var-name)]
    (when (not (and term-ok (= term.kind .Value)))
      (return "" (Value {}) false))
    (return filter-op term.value true)))

(defn legacy-source-var-equality-filter [predicate: Predicate, var-name: string] -> [value: Value, ok: bool]
  (when (not (and (= predicate.op "=")
                  (= (count predicate.terms) 2)))
    (return (Value {}) false))
  (let [left predicate.terms[0]
        right predicate.terms[1]]
    (cond
      (and (= left.kind .Var)
           (= left.name var-name)
           (= right.kind .Value))
        (return right.value true)
      (and (= right.kind .Var)
           (= right.name var-name)
           (= left.kind .Value))
        (return left.value true)
      :else (return (Value {}) false))))

(defn legacy-source-var-range-filter [predicate: Predicate, var-name: string] -> [op: string, value: Value, ok: bool]
  (when (not (and (range-predicate-op? predicate.op)
                  (= (count predicate.terms) 2)))
    (return "" (Value {}) false))
  (let [left predicate.terms[0]
        right predicate.terms[1]]
    (cond
      (and (= left.kind .Var)
           (= left.name var-name)
           (= right.kind .Value))
        (return predicate.op right.value true)
      (and (= right.kind .Var)
           (= right.name var-name)
           (= left.kind .Value))
        (let [[inverted inverted-ok] (inverted-range-predicate-op predicate.op)]
          (if inverted-ok
            (return inverted left.value true)
            (return "" (Value {}) false)))
      :else (return "" (Value {}) false))))

(defn db-read-source-query-attr-filtered-value-projection [query: Query] -> [projection: Source-Attr-Filtered-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Predicate)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].index 0)))
    (return (empty-source-attr-filtered-value-projection) false))
  (let [clause-value query.clauses[0]
        [filter-value filter-ok] (source-var-equality-filter query.predicates[0] clause-value.v.name)]
    (when (or (not filter-ok)
              (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (not (= query.find[0] clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-attr-filtered-value-projection) false))
    (return (Source-Attr-Filtered-Value-Projection {attr: clause-value.a.value.text
                                                    value-var: clause-value.v.name
                                                    value: filter-value})
            true)))

(defn db-read-source-query-attr-range-value-projection [query: Query] -> [projection: Source-Attr-Range-Value-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .Predicate)
                  (= query.where-steps[0].index 0)
                  (= query.where-steps[1].index 0)))
    (return (empty-source-attr-range-value-projection) false))
  (let [clause-value query.clauses[0]
        [filter-op filter-value filter-ok] (source-var-range-filter query.predicates[0] clause-value.v.name)]
    (when (or (not filter-ok)
              (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (not (= query.find[0] clause-value.v.name))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-attr-range-value-projection) false))
    (return (Source-Attr-Range-Value-Projection {attr: clause-value.a.value.text
                                                 value-var: clause-value.v.name
                                                 op: filter-op
                                                 value: filter-value})
            true)))

(defn query-find-entity-value-vars? [query: Query, entity-var: string, value-var: string] -> bool
  (cond
    (= (count query.find) 1)
      (= query.find[0] value-var)
    (= (count query.find) 2)
      (or (and (= query.find[0] entity-var)
               (= query.find[1] value-var))
          (and (= query.find[0] value-var)
               (= query.find[1] entity-var)))
    :else false))

(defn db-read-source-query-range-filtered-entity-attr-value-projection [query: Query] -> [projection: Source-Range-Filtered-Entity-Attr-Value-Projection, ok: bool]
  (when (not (and (or (= (count query.find) 1)
                       (= (count query.find) 2))
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 2)
                  (= (count query.where-steps) 3)))
    (return (empty-source-range-filtered-entity-attr-value-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)))
      (return (empty-source-range-filtered-entity-attr-value-projection) false)))
  (let [left query.clauses[0]
        right query.clauses[1]]
    (when (or (not (= left.has-source right.has-source))
              (and left.has-source (not (= left.source right.source)))
              (not (= left.e.kind .Var))
              (not (= right.e.kind .Var))
              (not (= left.e.name right.e.name))
              (not (= left.a.kind .Value))
              (not (= right.a.kind .Value))
              (not (= left.a.value.kind .Keyword))
              (not (= right.a.value.kind .Keyword))
              (reverse-attr? left.a.value.text)
              (reverse-attr? right.a.value.text)
              (not (= left.v.kind .Var))
              (not (= right.v.kind .Var))
              (= left.v.name right.v.name)
              (not (= left.tx-term.kind .Wildcard))
              (not (= right.tx-term.kind .Wildcard))
              (not (= left.op-term.kind .Wildcard))
              (not (= right.op-term.kind .Wildcard)))
      (return (empty-source-range-filtered-entity-attr-value-projection) false))
    (let [[left-op left-value left-ok] (source-var-range-filter query.predicates[0] left.v.name)
          [right-op right-value right-ok] (source-var-range-filter query.predicates[0] right.v.name)
          filter-clause left
          value-clause right
          filter-op ""
          filter-value (Value {})
          filter-ok false]
      (cond
        (and left-ok (not right-ok))
          (do
            (set! filter-clause left)
            (set! value-clause right)
            (set! filter-op left-op)
            (set! filter-value left-value)
            (set! filter-ok true))
        (and right-ok (not left-ok))
          (do
            (set! filter-clause right)
            (set! value-clause left)
            (set! filter-op right-op)
            (set! filter-value right-value)
            (set! filter-ok true))
        :else (do))
      (when (or (not filter-ok)
                (not (query-find-entity-value-vars? query filter-clause.e.name value-clause.v.name)))
        (return (empty-source-range-filtered-entity-attr-value-projection) false))
      (return (Source-Range-Filtered-Entity-Attr-Value-Projection {entity-var: filter-clause.e.name
                                                                   filter-attr: filter-clause.a.value.text
                                                                   filter-var: filter-clause.v.name
                                                                   filter-op: filter-op
                                                                   filter-value: filter-value
                                                                   value-attr: value-clause.a.value.text
                                                                   value-var: value-clause.v.name})
              true))))

(defn query-find-var-known-for-range-star? [query: Query, entity-var: string, find-var: string] -> bool
  (when (= find-var entity-var)
    (return true))
  (for [clause-value query.clauses]
    (when (and (= clause-value.v.kind .Var)
               (= clause-value.v.name find-var))
      (return true)))
  false)

(defn query-find-vars-unique? [query: Query] -> bool
  (let [i 0]
    (while (< i (count query.find))
      (let [j (+ i 1)]
        (while (< j (count query.find))
          (when (= query.find[i] query.find[j])
            (return false))
          (set! j (+ j 1))))
      (set! i (+ i 1)))
    true))

(defn query-clause-value-var-unique-for-range-star? [query: Query, index: int] -> bool
  (let [name query.clauses[index].v.name
        i 0]
    (while (< i index)
      (when (and (= query.clauses[i].v.kind .Var)
                 (= query.clauses[i].v.name name))
        (return false))
      (set! i (+ i 1)))
    true))

(defn db-read-source-query-range-star-projection [query: Query] -> [projection: Source-Range-Star-Projection, ok: bool]
  (when (not (and (>= (count query.find) 1)
                  (>= (count query.clauses) 3)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 1)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.where-steps) (+ (count query.clauses) 1))
                  (query-find-vars-unique? query)))
    (return (empty-source-range-star-projection) false))
  (for [step query.where-steps]
    (when (not (or (= step.kind .Clause)
                   (= step.kind .Predicate)))
    (return (empty-source-range-star-projection) false)))
  (let [first query.clauses[0]
        filter-index -1
        filter-op ""
        filter-value (Value {})
        i 0]
    (when (not (and (= first.e.kind .Var)
                    (= first.a.kind .Value)
                    (= first.a.value.kind .Keyword)
                    (not (reverse-attr? first.a.value.text))
                    (= first.v.kind .Var)
                    (= first.tx-term.kind .Wildcard)
                    (= first.op-term.kind .Wildcard)))
      (return (empty-source-range-star-projection) false))
    (while (< i (count query.clauses))
      (let [clause-value query.clauses[i]
            [clause-op clause-value-filter clause-filter-ok] (source-var-range-filter query.predicates[0] clause-value.v.name)]
        (when (or (not (= clause-value.has-source first.has-source))
                  (and first.has-source
                       (not (= clause-value.source first.source)))
                  (not (= clause-value.e.kind .Var))
                  (not (= clause-value.e.name first.e.name))
                  (not (= clause-value.a.kind .Value))
                  (not (= clause-value.a.value.kind .Keyword))
                  (reverse-attr? clause-value.a.value.text)
                  (not (= clause-value.v.kind .Var))
                  (not (query-clause-value-var-unique-for-range-star? query i))
                  (not (= clause-value.tx-term.kind .Wildcard))
                  (not (= clause-value.op-term.kind .Wildcard)))
          (return (empty-source-range-star-projection) false))
        (when clause-filter-ok
          (when (not (= filter-index -1))
            (return (empty-source-range-star-projection) false))
          (set! filter-index i)
          (set! filter-op clause-op)
          (set! filter-value clause-value-filter)))
      (set! i (+ i 1)))
    (when (= filter-index -1)
      (return (empty-source-range-star-projection) false))
    (for [find-var query.find]
      (when (not (query-find-var-known-for-range-star? query first.e.name find-var))
        (return (empty-source-range-star-projection) false)))
    (return (Source-Range-Star-Projection {entity-var: first.e.name
                                           filter-index: filter-index
                                           filter-attr: query.clauses[filter-index].a.value.text
                                           filter-var: query.clauses[filter-index].v.name
                                           filter-op: filter-op
                                           filter-value: filter-value})
            true)))

(defn db-read-source-query-attr-entity-projection [query: Query] -> [projection: Source-Attr-Entity-Projection, ok: bool]
  (when (not (and (= (count query.find) 1)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 1)
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-attr-entity-projection) false))
  (let [clause-value query.clauses[0]]
    (when (or (not (= clause-value.e.kind .Var))
              (not (= query.find[0] clause-value.e.name))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (not (or (= clause-value.v.kind .Var)
                       (= clause-value.v.kind .Wildcard)))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-attr-entity-projection) false))
    (return (Source-Attr-Entity-Projection {entity-var: clause-value.e.name
                                            attr: clause-value.a.value.text})
            true)))

(defn source-entity-pull-equality-filter [predicate: Predicate, entity-var: string] -> [value: Value, ok: bool]
  (source-var-equality-filter predicate entity-var))

(defn db-read-source-query-entity-pull-projection [query: Query] -> [projection: Source-Entity-Pull-Projection, ok: bool]
  (when (not (and (or (= (count query.find) 0)
                      (= (count query.find) 1))
                  (= (count query.with) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.pulls) 1)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (or (= (count query.predicates) 0)
                      (= (count query.predicates) 1))
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 0)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) (+ 1 (count query.predicates)))
                  (= query.where-steps[0].kind .Clause)))
    (return (empty-source-entity-pull-projection) false))
  (let [clause-value query.clauses[0]
        pull-find query.pulls[0]]
    (when (or (and (not pull-find.has-pattern-var)
                   (not (and (= (count query.inputs) 0)
                             (= (count query.input-specs) 0))))
              (not (= clause-value.e.kind .Var))
              (not (= pull-find.var clause-value.e.name))
              (and (= (count query.find) 1)
                   (not (= query.find[0] clause-value.e.name)))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (or (= clause-value.v.kind .Var)
                       (= clause-value.v.kind .Wildcard)
                       (= clause-value.v.kind .Value)))
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard)))
      (return (empty-source-entity-pull-projection) false))
    (let [entity-filter (Value {})
          has-entity-filter false]
      (when (= (count query.predicates) 1)
        (when (not (= query.where-steps[1].kind .Predicate))
          (return (empty-source-entity-pull-projection) false))
        (let [[filter-value filter-ok] (source-entity-pull-equality-filter query.predicates[0] clause-value.e.name)]
          (when (not filter-ok)
            (return (empty-source-entity-pull-projection) false))
          (set! entity-filter filter-value)
          (set! has-entity-filter true)))
    (return (Source-Entity-Pull-Projection {entity-var: clause-value.e.name
                                            attr: clause-value.a.value.text
                                            value: clause-value.v.value
                                            has-value: (= clause-value.v.kind .Value)
                                            entity-filter: entity-filter
                                            has-entity-filter: has-entity-filter})
            true))))

(defn db-read-source-query-entity-get-else-projection [query: Query] -> [projection: Source-Entity-Get-Else-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
                  (= (count query.with) 0)
                  (= (count query.inputs) 0)
                  (= (count query.collection-inputs) 0)
                  (= (count query.tuple-inputs) 0)
                  (= (count query.relation-inputs) 0)
                  (= (count query.input-specs) 0)
                  (= (count query.pulls) 0)
                  (= (count query.aggregates) 0)
                  (= (count query.rules) 0)
                  (= (count query.rule-calls) 0)
                  (= (count query.predicates) 0)
                  (= (count query.function-clauses) 0)
                  (= (count query.get-elses) 1)
                  (= (count query.get-somes) 0)
                  (= (count query.grounds) 0)
                  (= (count query.not-groups) 0)
                  (= (count query.or-groups) 0)
                  (= (count query.clauses) 1)
                  (= (count query.where-steps) 2)
                  (= query.where-steps[0].kind .Clause)
                  (= query.where-steps[1].kind .GetElse)))
    (return (empty-source-entity-get-else-projection) false))
  (let [clause-value query.clauses[0]
        get-else query.get-elses[0]]
    (when (or (not (= clause-value.e.kind .Var))
              (not (= clause-value.a.kind .Value))
              (not (= clause-value.a.value.kind .Keyword))
              (reverse-attr? clause-value.a.value.text)
              (not (= clause-value.v.kind .Var))
              (= clause-value.e.name clause-value.v.name)
              (not (= clause-value.tx-term.kind .Wildcard))
              (not (= clause-value.op-term.kind .Wildcard))
              (not (= get-else.e.kind .Var))
              (not (= get-else.e.name clause-value.e.name)))
      (return (empty-source-entity-get-else-projection) false))
    (when (not (or (and (= query.find[0] clause-value.v.name)
                        (= query.find[1] get-else.out))
                   (and (= query.find[0] get-else.out)
                        (= query.find[1] clause-value.v.name))))
      (return (empty-source-entity-get-else-projection) false))
    (return (Source-Entity-Get-Else-Projection {entity-var: clause-value.e.name
                                                value-attr: clause-value.a.value.text
                                                value-var: clause-value.v.name
                                                get-else-attr: get-else.a
                                                get-else-var: get-else.out
                                                default-value: get-else.default-value})
            true)))

(defn db-read-source-query-entity-get-some-projection [query: Query] -> [projection: Source-Entity-Get-Some-Projection, ok: bool]
  (when (not (and (= (count query.find) 2)
