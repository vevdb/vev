(defmacro index-range [db attr start end]
  (quasiquote
    (index-range-with-args
      (unquote db)
      (unquote (emit-attr attr))
      (unquote (emit-index-arg start))
      (unquote (if (nil? start) (quasiquote false) (quasiquote true)))
      (unquote (emit-index-arg end))
      (unquote (if (nil? end) (quasiquote false) (quasiquote true))))))

(defmacro index-range-checked [db attr start end]
  (quasiquote
    (index-range-checked-with-args
      (unquote db)
      (unquote (emit-attr attr))
      (unquote (emit-index-arg start))
      (unquote (if (nil? start) (quasiquote false) (quasiquote true)))
      (unquote (emit-index-arg end))
      (unquote (if (nil? end) (quasiquote false) (quasiquote true))))))

(defmacro transact [conn tx-form]
  (if (vector? tx-form)
    (quasiquote
      (transact-tx-data
        (unquote conn)
        ([]Tx-Data [(splice (emit-tx-data-items tx-form))])))
    (quasiquote (transact-tx-data (unquote conn) (unquote tx-form)))))

(defmacro pull [db pattern entity]
  (if (vector? pattern)
    (if (lookup-ref? entity)
      (quasiquote
        (pull-pattern-lookup-ref
          (unquote db)
          (unquote (emit-attr (nth entity 0)))
          (unquote (emit-literal-value (nth entity 1)))
          ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
      (if (keyword? entity)
        (quasiquote
          (pull-pattern-ident
            (unquote db)
            (unquote (source entity))
            ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
        (quasiquote
          (pull-pattern-spec
            (unquote db)
            (unquote entity)
            ([]Pull-Spec [(splice (emit-pull-specs pattern))])))))
    (quasiquote (pull-pattern (unquote db) (unquote entity) (unquote pattern)))))

(defmacro pull-many [db pattern entities]
  (if (vector? pattern)
    (if (and (vector? entities)
             (> (count entities) 0)
             (lookup-ref? (first entities)))
      (quasiquote
        (pull-many-pattern-lookup-refs
          (unquote db)
          ([]string [(splice (emit-query-input-lookup-ref-attrs entities))])
          ([]Value [(splice (emit-query-input-lookup-ref-values entities))])
          ([]Pull-Spec [(splice (emit-pull-specs pattern))])))
      (quasiquote
        (pull-many-pattern-spec
          (unquote db)
          (unquote entities)
          ([]Pull-Spec [(splice (emit-pull-specs pattern))]))))
    (quasiquote (pull-many-pattern (unquote db) (unquote entities) (unquote pattern)))))
