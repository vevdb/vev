(defmacro q-scalar [query-or-db db-or-query & inputs]
  (quasiquote
    (result-scalar (q (unquote query-or-db) (unquote db-or-query) (splice inputs)))))

(defmacro q-collection [query-or-db db-or-query & inputs]
