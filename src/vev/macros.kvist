(defmacro q-keys [query-or-db db-or-query & inputs]
  (if (vector? query-or-db)
    (quasiquote
      (result-keys
        (q (unquote query-or-db) (unquote db-or-query) (splice inputs))
        .Keyword
        ([]string [(splice (emit-result-keys (datalog-return-map-items (rest query-or-db) ":keys")))])))
    (if (vector? db-or-query)
      (quasiquote
        (result-keys
          (q (unquote query-or-db) (unquote db-or-query) (splice inputs))
          .Keyword
          ([]string [(splice (emit-result-keys (datalog-return-map-items (rest db-or-query) ":keys")))])))
      (error "q-keys expects a literal datalog query"))))

