(defmacro datoms [db order & args]
  (if (keyword? order)
    (quasiquote
      (datoms-with-args
        (unquote db)
        (unquote (source order))
        ([]Index-Arg [(splice (emit-index-args args))])))
    (error "datoms index order must be a keyword")))

(defmacro datoms-checked [db order & args]
