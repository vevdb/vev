(defn edn-aggregate-op? [op: string] -> bool
  (or (= op "count")
      (= op "count-distinct")
      (= op "min")
      (= op "max")
      (= op "sum")
      (= op "avg")
      (= op "median")
      (= op "variance")
      (= op "stddev")
      (= op "aggregate")))

(defn edn-top-n-aggregate-op? [op: string] -> bool
  (or (= op "min") (= op "max")))

(defn edn-aggregate-args-from [doc: EDN-Doc, first-arg: int] -> [dynamic]Term
  (let [args (make [dynamic]Term)
        cursor first-arg]
    (while (not (= cursor -1))
      (arr.push! args (value-term-from-edn-node doc cursor))
      (set! cursor doc.nodes[cursor].next-sibling))
    args))

(defn aggregate-single-var-args [name: string] -> [dynamic]Term
  (let [args (make [dynamic]Term)]
    (arr.push! args (term-var name))
    args))

(defn append-edn-aggregate-find! [out: ^[dynamic]Aggregate-Find, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[form].first-child]
    (when (or (= op-node -1) (not (= doc.nodes[op-node].kind .Symbol)))
      (return false "aggregate find expressions must start with a symbol"))
    (let [op doc.nodes[op-node].text
          first-arg doc.nodes[op-node].next-sibling
          second-arg (if (= first-arg -1) -1 doc.nodes[first-arg].next-sibling)
          third-arg (if (= second-arg -1) -1 doc.nodes[second-arg].next-sibling)]
      (when (not (edn-aggregate-op? op))
        (return false "unsupported aggregate find expression"))
      (when (= first-arg -1)
        (return false "aggregate find expression missing variable"))
      (if (= op "aggregate")
        (do
          (when (or (= second-arg -1) (not (= third-arg -1)))
            (return false "custom aggregate expects (aggregate ?f ?x)"))
          (when (not (and (edn-var? doc first-arg)
                          (edn-var? doc second-arg)))
            (return false "custom aggregate expects (aggregate ?f ?x)"))
          (let [args (aggregate-single-var-args doc.nodes[second-arg].text)]
            (arr.push! out^ (Aggregate-Find {op: op
                                             var: doc.nodes[second-arg].text
                                             args: (slice args 0)
                                             function-var: doc.nodes[first-arg].text
                                             has-function-var: true})))
          (return true ""))
        (if (and (edn-top-n-aggregate-op? op)
                 (not (= second-arg -1))
                 (= third-arg -1))
          (do
            (when (not (edn-var? doc second-arg))
              (return false "top-n aggregate find expressions expect (min n ?x), (max n ?x), (min ?n ?x), or (max ?n ?x)"))
            (if (= doc.nodes[first-arg].kind .Int)
              (let [args (aggregate-single-var-args doc.nodes[second-arg].text)]
                (arr.push! out^ (Aggregate-Find {op: op
                                                 var: doc.nodes[second-arg].text
                                                 args: (slice args 0)
                                                 limit: (int doc.nodes[first-arg].int-value)
                                                 has-limit: true})))
              (if (edn-var? doc first-arg)
                (let [args (aggregate-single-var-args doc.nodes[second-arg].text)]
                  (arr.push! out^ (Aggregate-Find {op: op
                                                   var: doc.nodes[second-arg].text
                                                   args: (slice args 0)
                                                   limit-var: doc.nodes[first-arg].text
                                                   has-limit-var: true})))
                (return false "top-n aggregate limit must be an int or variable")))
            (return true ""))
          (do
            (when (not (edn-var? doc first-arg))
              (return false "aggregate find expression expects variable argument"))
            (let [args (edn-aggregate-args-from doc first-arg)]
              (arr.push! out^ (Aggregate-Find {op: op
                                               var: doc.nodes[first-arg].text
                                               args: (slice args 0)})))
            (return true "")))))))

(defn append-edn-find-item! [find: ^[dynamic]string, pulls: ^[dynamic]Pull-Find, aggregates: ^[dynamic]Aggregate-Find, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (cond
    (edn-var? doc item)
      (do
        (arr.push! find^ doc.nodes[item].text)
        (return true ""))
    (and (= doc.nodes[item].kind .Symbol) (= doc.nodes[item].text "."))
      (return true "")
    (= doc.nodes[item].kind .List)
      (let [head (edn-list-head-text doc item)]
        (if (= head "pull")
          (append-edn-pull-find! pulls doc item)
          (append-edn-aggregate-find! aggregates doc item)))
    :else (return false "query text :find currently supports vars, tuples, pull, and aggregates")))

(defn append-edn-find-vector! [find: ^[dynamic]string, pulls: ^[dynamic]Pull-Find, aggregates: ^[dynamic]Aggregate-Find, doc: EDN-Doc, vector-node: int] -> [ok: bool, error: string]
  (let [first-node doc.nodes[vector-node].first-child
        second-node (if (= first-node -1) -1 doc.nodes[first-node].next-sibling)]
    (when (and (not (= first-node -1))
               (edn-symbol-text? doc second-node "..."))
      (return (append-edn-find-item! find pulls aggregates doc first-node)))
    (let [cursor first-node]
      (while (not (= cursor -1))
        (let [[item-ok item-error] (append-edn-find-item! find pulls aggregates doc cursor)]
          (when (not item-ok)
            (return false item-error)))
        (set! cursor doc.nodes[cursor].next-sibling))
      (return true ""))))

(defn validate-edn-entity-term [doc: EDN-Doc, node-index: int] -> [ok: bool, error: string]
  (when (and (not (= node-index -1))
             (= doc.nodes[node-index].kind .Int)
             (< doc.nodes[node-index].int-value 0))
    (return false "query entity integer terms must be non-negative"))
  (return true ""))

(defn append-edn-data-clause! [out: ^[dynamic]Clause, doc: EDN-Doc, node-index: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[node-index].kind .Vector))
    (return false "query text where clauses must be vectors"))
  (let [source ""
        has-source false
        term-node (edn-child-at doc node-index 0)]
    (when (edn-source-var? doc term-node)
      (set! source doc.nodes[term-node].text)
      (set! has-source true)
      (set! term-node doc.nodes[term-node].next-sibling))
    (when (= term-node -1)
      (return false "Pattern could not be empty"))
    (let [e-node term-node
          a-node doc.nodes[e-node].next-sibling
          v-node -1
          tx-node -1
          op-node -1]
      (when (= a-node -1)
        (let [[entity-ok entity-error] (validate-edn-entity-term doc e-node)]
          (when (not entity-ok)
            (return false entity-error)))
        (arr.push! out^
          (Clause {e: (term-from-edn-node doc e-node false)
                   a: (term-wildcard)
                   v: (term-wildcard)
                   tx-term: (term-wildcard)
                   op-term: (term-wildcard)
                   source: source
                   has-source: has-source
                   source-width: 1}))
        (return true ""))
      (set! v-node doc.nodes[a-node].next-sibling)
      (when (= v-node -1)
        (let [[entity-ok entity-error] (validate-edn-entity-term doc e-node)]
          (when (not entity-ok)
            (return false entity-error)))
        (arr.push! out^
          (Clause {e: (term-from-edn-node doc e-node false)
                   a: (term-from-edn-node doc a-node true)
                   v: (term-wildcard)
                   source: source
                   has-source: has-source
                   source-width: 2}))
        (return true ""))
      (set! tx-node doc.nodes[v-node].next-sibling)
      (when (not (= tx-node -1))
        (set! op-node doc.nodes[tx-node].next-sibling))
      (when (and has-source (not (= op-node -1)) (not (= doc.nodes[op-node].next-sibling -1)))
        (return false "source query text clauses currently need two to five terms"))
      (when (and (not has-source) (not (= op-node -1)) (not (= doc.nodes[op-node].next-sibling -1)))
        (return false "query text clauses currently need two to five terms"))
      (let [[entity-ok entity-error] (validate-edn-entity-term doc e-node)]
        (when (not entity-ok)
          (return false entity-error)))
      (arr.push! out^
        (Clause {e: (term-from-edn-node doc e-node false)
                 a: (term-from-edn-node doc a-node true)
                 v: (value-term-from-edn-node doc v-node)
                 tx-term: (if (= tx-node -1) (term-wildcard) (value-term-from-edn-node doc tx-node))
                 op-term: (if (= op-node -1) (term-wildcard) (value-term-from-edn-node doc op-node))
                 source: source
                 has-source: has-source
                 source-width: (if (= tx-node -1) 3 (if (= op-node -1) 4 5))}))
      (return true ""))))

(defn append-edn-predicate! [out: ^[dynamic]Predicate, doc: EDN-Doc, expr: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[expr].first-child]
    (when (= op-node -1)
      (return false "predicate clauses must have shape [(op arg ...)]"))
    (let [terms (edn-terms-from-list-tail doc expr)]
      (arr.push! out^ (Predicate {op: (edn-node-text doc op-node)
                                  terms: (slice terms 0)}))
      (return true ""))))

(defn append-edn-function-clause! [out: ^[dynamic]Function-Clause, doc: EDN-Doc, expr: int, output: int] -> [ok: bool, error: string]
  (let [op-node doc.nodes[expr].first-child]
    (when (= op-node -1)
      (return false "function clauses must have shape [(op arg ...) ?out]"))
    (let [terms (edn-terms-from-list-tail doc expr)]
      (if (= doc.nodes[output].kind .Vector)
        (let [out-vars (edn-vars-from-vector doc output)
              [binding binding-ok binding-error] (edn-input-binding-from-node doc output)]
          (when (not binding-ok)
            (return false binding-error))
          (arr.push! out^
            (Function-Clause {op: (edn-node-text doc op-node)
                              terms: (slice terms 0)
                              out-vars: (slice out-vars 0)
                              out-binding: binding
                              is-tuple: true})))
        (if (edn-var? doc output)
          (arr.push! out^
            (Function-Clause {op: (edn-node-text doc op-node)
                              terms: (slice terms 0)
                              out: doc.nodes[output].text}))
          (return false "function output must be a variable or vector of variables")))
      (return true ""))))

(defn edn-ground-source-term [doc: EDN-Doc, node-index: int] -> [term: Term, ok: bool, error: string]
  (when (= node-index -1)
    (return (term-wildcard) false "ground clauses must have shape [(ground value) binding]"))
  (if (edn-var? doc node-index)
    (return (term-var doc.nodes[node-index].text) true "")
    (let [[value value-ok value-error] (edn-value-from-node doc node-index)]
      (if value-ok
        (return (term-value value) true "")
        (return (term-wildcard) false value-error)))))

(defn edn-ground-relation-output? [doc: EDN-Doc, output: int] -> bool
  (when (or (= output -1)
            (not (= doc.nodes[output].kind .Vector))
            (not (= doc.nodes[output].child-count 2)))
    (return false))
  (let [row (edn-child-at doc output 0)
        marker (edn-child-at doc output 1)]
    (and (not (= row -1))
         (= doc.nodes[row].kind .Vector)
         (edn-symbol-text? doc marker "..."))))

(defn edn-ground-collection-output? [doc: EDN-Doc, output: int] -> bool
  (when (or (= output -1)
            (not (= doc.nodes[output].kind .Vector))
            (not (= doc.nodes[output].child-count 2)))
    (return false))
  (let [item (edn-child-at doc output 0)
        marker (edn-child-at doc output 1)]
    (and (not (= item -1))
         (not (= doc.nodes[item].kind .Vector))
         (edn-symbol-text? doc marker "..."))))

(defn append-edn-ground! [out: ^[dynamic]Ground, doc: EDN-Doc, expr: int, output: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[expr].child-count 2))
    (return false "ground clauses must have shape [(ground value) binding]"))
  (when (= output -1)
    (return false "ground clauses must have shape [(ground value) binding]"))
  (let [value-node doc.nodes[doc.nodes[expr].first-child].next-sibling
        [source source-ok source-error] (edn-ground-source-term doc value-node)]
    (when (not source-ok)
      (return false source-error))
    (cond
      (edn-symbol-text? doc output "_")
        (do
          (arr.push! out^
            (Ground {source: source
                     out: ""
                     tuple-vars: ([]string [])
                     binding: (input-binding-none)}))
          (return true ""))
      (edn-var? doc output)
        (do
          (arr.push! out^
            (Ground {source: source
                     out: doc.nodes[output].text
                     tuple-vars: ([]string [])
                     binding: (input-binding-none)}))
          (return true ""))
      (= doc.nodes[output].kind .Vector)
        (let [[binding binding-ok binding-error] (edn-input-binding-from-node doc output)]
          (when (not binding-ok)
            (return false binding-error))
          (let [vars (input-binding-vars binding)]
            (cond
              (edn-ground-relation-output? doc output)
                (let [row (edn-child-at doc output 0)]
                  (arr.push! out^
                    (Ground {source: source
                             out: ""
                             tuple-vars: (slice vars 0)
                             binding: binding
                             is-relation: true
                             width: doc.nodes[row].child-count}))
                  (return true ""))
              (edn-ground-collection-output? doc output)
                (do
                  (arr.push! out^
                    (Ground {source: source
                             out: (if (> (count vars) 0) vars[0] "")
                             tuple-vars: (slice vars 0)
                             binding: binding
                             is-collection: true}))
                  (return true ""))
              :else
                (do
                  (arr.push! out^
                    (Ground {source: source
                             out: ""
                             tuple-vars: (slice vars 0)
                             binding: binding
                             is-tuple: true}))
                  (return true "")))))
      :else (return false "ground output must be a variable, _, or binding vector"))))

(defn append-edn-get-else! [out: ^[dynamic]Get-Else, doc: EDN-Doc, expr: int, output: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[expr].child-count 5))
    (return false "get-else clauses must have shape [(get-else $ ?e :attr default) ?out]"))
  (when (not (edn-var? doc output))
    (return false "get-else output must be a variable"))
  (let [db-node doc.nodes[doc.nodes[expr].first-child].next-sibling
        entity-node doc.nodes[db-node].next-sibling
        attr-node doc.nodes[entity-node].next-sibling
        default-node doc.nodes[attr-node].next-sibling
        [attr attr-ok] (edn-pull-attr-source doc attr-node)
        [default-value default-ok default-error] (edn-value-from-node doc default-node)]
    (when (not attr-ok)
      (return false "get-else attr must be a keyword or string"))
    (when (not default-ok)
      (return false default-error))
    (let [[entity-ok entity-error] (validate-edn-entity-term doc entity-node)]
      (when (not entity-ok)
        (return false entity-error)))
    (arr.push! out^
      (Get-Else {e: (term-from-edn-node doc entity-node false)
                 a: attr
                 default-value: default-value
                 out: doc.nodes[output].text}))
    (return true "")))

(defn append-edn-get-some! [out: ^[dynamic]Get-Some, doc: EDN-Doc, expr: int, output: int] -> [ok: bool, error: string]
  (when (< doc.nodes[expr].child-count 4)
    (return false "get-some clauses must have shape [(get-some $ ?e :attr ...) [?a ?v]]"))
  (when (or (= output -1)
            (not (= doc.nodes[output].kind .Vector))
            (not (= doc.nodes[output].child-count 2)))
    (return false "get-some output must be [?attr ?value]"))
  (let [first-out doc.nodes[output].first-child
        second-out doc.nodes[first-out].next-sibling]
    (when (or (not (edn-var? doc first-out))
              (not (edn-var? doc second-out)))
      (return false "get-some output must be [?attr ?value]"))
    (let [db-node doc.nodes[doc.nodes[expr].first-child].next-sibling
          entity-node doc.nodes[db-node].next-sibling
          attr-node doc.nodes[entity-node].next-sibling
          attrs (make [dynamic]string) :defer]
      (while (not (= attr-node -1))
        (let [[attr attr-ok] (edn-pull-attr-source doc attr-node)]
          (when (not attr-ok)
            (return false "get-some attrs must be keywords or strings"))
          (arr.push! attrs attr))
        (set! attr-node doc.nodes[attr-node].next-sibling))
      (let [[entity-ok entity-error] (validate-edn-entity-term doc entity-node)]
        (when (not entity-ok)
          (return false entity-error)))
      (let [owned-attrs (arr.into [dynamic]string (slice attrs 0))]
        (arr.push! out^
          (Get-Some {e: (term-from-edn-node doc entity-node false)
                     attrs: owned-attrs
                     out-attr: doc.nodes[first-out].text
                     out-value: doc.nodes[second-out].text})))
      (return true ""))))

(defn append-edn-missing-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, expr: int] -> [ok: bool, error: string]
  (when (not (= doc.nodes[expr].child-count 4))
    (return false "missing? clauses must have shape [(missing? $ ?e :attr)]"))
  (let [db-node doc.nodes[doc.nodes[expr].first-child].next-sibling
        entity-node doc.nodes[db-node].next-sibling
        attr-node doc.nodes[entity-node].next-sibling]
    (let [[entity-ok entity-error] (validate-edn-entity-term doc entity-node)]
      (when (not entity-ok)
        (return false entity-error)))
    (arr.push! out^
      (not-group-simple
        ([]Clause [(Clause {e: (term-from-edn-node doc entity-node false)
                            a: (term-from-edn-node doc attr-node true)
                            v: (term-wildcard)})])))
    (return true "")))

(defn append-clause-var-names! [vars: ^[dynamic]string, clause: Clause]
  (when (= clause.e.kind .Var)
    (append-var-once! vars clause.e.name))
  (when (= clause.a.kind .Var)
    (append-var-once! vars clause.a.name))
  (when (= clause.v.kind .Var)
    (append-var-once! vars clause.v.name))
  (when (= clause.tx-term.kind .Var)
    (append-var-once! vars clause.tx-term.name))
  (when (= clause.op-term.kind .Var)
    (append-var-once! vars clause.op-term.name)))

(defn append-not-group-var-names! [vars: ^[dynamic]string, group: Not-Group]
  (for [clause group.clauses]
    (append-clause-var-names! vars clause))
  (for [predicate group.predicates]
    (append-predicate-vars! vars predicate))
  (for [function group.function-clauses]
    (append-function-vars! vars function))
  (for [child group.not-groups]
    (append-not-group-var-names! vars child)))

(defn edn-node-has-var? [doc: EDN-Doc, node: int] -> bool
  (when (= node -1)
    (return false))
  (when (edn-var? doc node)
    (return true))
  (let [child doc.nodes[node].first-child]
    (while (not (= child -1))
      (when (edn-node-has-var? doc child)
        (return true))
      (set! child doc.nodes[child].next-sibling)))
  false)

(defn not-group-has-vars? [group: Not-Group] -> bool
  (let [vars (make [dynamic]string) :defer]
    (append-not-group-var-names! (addr vars) group)
    (> (count vars) 0)))

(defn or-branches-have-vars? [branches: []Not-Group] -> bool
  (let [vars (make [dynamic]string) :defer]
    (for [branch branches]
      (append-not-group-var-names! (addr vars) branch))
    (> (count vars) 0)))

(defn apply-default-source-to-clauses! [clauses: ^[dynamic]Clause, start-index: int, source: string, has-source: bool]
  (when (not has-source)
    (return))
  (let [index start-index]
    (while (< index (count clauses^))
      (let [item: Clause clauses^[index]]
        (when (not item.has-source)
          (set! item.source source)
          (set! item.has-source true)
          (set! clauses^[index] item)))
      (set! index (+ index 1)))))

(defn append-edn-data-clause-with-default-source! [out: ^[dynamic]Clause, doc: EDN-Doc, node-index: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [start (count out^)
        [parsed-ok parsed-error] (append-edn-data-clause! out doc node-index)]
    (when parsed-ok
      (apply-default-source-to-clauses! out start source has-source))
    (return parsed-ok parsed-error)))

(defn edn-list-head-node [doc: EDN-Doc, form: int] -> int
  doc.nodes[form].first-child)

(defn edn-list-op-node [doc: EDN-Doc, form: int] -> int
  (let [head (edn-list-head-node doc form)]
    (if (edn-source-var? doc head)
      doc.nodes[head].next-sibling
      head)))

(defn edn-list-op-text [doc: EDN-Doc, form: int] -> string
  (let [op-node (edn-list-op-node doc form)]
    (if (and (not (= op-node -1))
             (= doc.nodes[op-node].kind .Symbol))
      doc.nodes[op-node].text
      "")))

(defn edn-list-default-source [doc: EDN-Doc, form: int] -> [source: string, ok: bool]
  (let [head (edn-list-head-node doc form)]
    (if (edn-source-var? doc head)
      (return doc.nodes[head].text true)
      (return "" false))))

(defn append-edn-local-step-kind! [step-kinds: ^[dynamic]Query-Step-Kind, kind: Query-Step-Kind]
  (arr.push! step-kinds^ kind))

(defn append-edn-local-not-step-with-source! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, not-groups: ^[dynamic]Not-Group, step-kinds: ^[dynamic]Query-Step-Kind, doc: EDN-Doc, item: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (if (= doc.nodes[item].kind .List)
    (let [head (edn-list-op-text doc item)
          [child-source child-has-source] (edn-list-default-source doc item)]
      (cond
        (= head "not")
          (let [next-source (if child-has-source child-source source)
                next-has-source (or child-has-source has-source)
                [ok error] (append-edn-not-group-with-source! not-groups doc item next-source next-has-source)]
            (when (not ok)
              (return false error))
            (append-edn-local-step-kind! step-kinds .Not)
            (return true ""))
        :else (return false "query text branch lists currently support nested not")))
    (if (= doc.nodes[item].kind .Vector)
      (let [first-item (edn-child-at doc item 0)]
        (if (and (not (= first-item -1)) (= doc.nodes[first-item].kind .List))
          (let [expr first-item
                output doc.nodes[expr].next-sibling
                op (edn-list-head-text doc expr)]
            (cond
              (= op "missing?")
                (let [[ok error] (append-edn-missing-group! not-groups doc expr)]
                  (when (not ok)
                    (return false error))
                  (append-edn-local-step-kind! step-kinds .Not)
                  (return true ""))
              (not (= output -1))
                (let [[ok error] (append-edn-function-clause! function-clauses doc expr output)]
                  (when (not ok)
                    (return false error))
                  (append-edn-local-step-kind! step-kinds .Function)
                  (return true ""))
              :else
                (let [[ok error] (append-edn-predicate! predicates doc expr)]
                  (when (not ok)
                    (return false error))
                  (append-edn-local-step-kind! step-kinds .Predicate)
                  (return true ""))))
          (let [[ok error] (append-edn-data-clause-with-default-source! clauses doc item source has-source)]
            (when (and (not ok)
                       (= error "query text clause is incomplete")
                       (not (edn-node-has-var? doc item)))
              (return false "Join variables should not be empty"))
            (when (not ok)
              (return false error))
            (append-edn-local-step-kind! step-kinds .Clause)
            (return true ""))))
      (return false "query text branch clauses must be vectors or lists"))))

(defn append-edn-not-group-with-source! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [clauses (make [dynamic]Clause) :defer
        predicates (make [dynamic]Predicate) :defer
        function-clauses (make [dynamic]Function-Clause) :defer
        not-groups (make [dynamic]Not-Group) :defer
        step-kinds (make [dynamic]Query-Step-Kind) :defer
        op-node (edn-list-op-node doc form)
        cursor (if (= op-node -1) -1 doc.nodes[op-node].next-sibling)]
    (when (= cursor -1)
      (return false "Cannot parse 'not' clause"))
    (while (not (= cursor -1))
      (let [[ok error] (append-edn-local-not-step-with-source! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr step-kinds) doc cursor source has-source)]
        (when (not ok)
          (return false error)))
      (set! cursor doc.nodes[cursor].next-sibling))
    (let [group (not-group-program (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice not-groups 0) (slice step-kinds 0))]
      (when (not (not-group-has-vars? group))
        (return false "Join variables should not be empty"))
      (arr.push! out^ group))
    (return true "")))

(defn append-edn-not-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [[source has-source] (edn-list-default-source doc form)]
    (append-edn-not-group-with-source! out doc form source has-source)))

(defn append-edn-not-join-group-with-source! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [op-node (edn-list-op-node doc form)
        join-node (if (= op-node -1) -1 doc.nodes[op-node].next-sibling)]
    (when (or (= join-node -1) (not (= doc.nodes[join-node].kind .Vector)))
      (return false "not-join expects a vector of join vars"))
    (let [join-vars (edn-vars-from-vector doc join-node) :defer
          clauses (make [dynamic]Clause) :defer
          predicates (make [dynamic]Predicate) :defer
          function-clauses (make [dynamic]Function-Clause) :defer
          not-groups (make [dynamic]Not-Group) :defer
          step-kinds (make [dynamic]Query-Step-Kind) :defer
          cursor doc.nodes[join-node].next-sibling]
      (when (= (count join-vars) 0)
        (return false "Join variables should not be empty"))
      (when (= cursor -1)
        (return false "Cannot parse 'not-join' clause"))
      (while (not (= cursor -1))
        (let [[ok error] (append-edn-local-not-step-with-source! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr step-kinds) doc cursor source has-source)]
          (when (not ok)
            (return false error)))
        (set! cursor doc.nodes[cursor].next-sibling))
      (arr.push! out^ (not-join-group-program (slice join-vars 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice not-groups 0) (slice step-kinds 0)))
      (return true ""))))

(defn append-edn-not-join-group! [out: ^[dynamic]Not-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [[source has-source] (edn-list-default-source doc form)]
    (append-edn-not-join-group-with-source! out doc form source has-source)))

(defn append-edn-or-branch-with-source! [out: ^[dynamic]Not-Group, doc: EDN-Doc, branch: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [clauses (make [dynamic]Clause) :defer
        predicates (make [dynamic]Predicate) :defer
        function-clauses (make [dynamic]Function-Clause) :defer
        not-groups (make [dynamic]Not-Group) :defer
        step-kinds (make [dynamic]Query-Step-Kind) :defer]
    (if (= doc.nodes[branch].kind .List)
      (let [head (edn-list-op-text doc branch)]
        (when (not (= head "and"))
          (return false "query text or branches support data clauses or and"))
        (let [op-node (edn-list-op-node doc branch)
              cursor doc.nodes[op-node].next-sibling]
          (while (not (= cursor -1))
            (let [[ok error] (append-edn-local-not-step-with-source! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr step-kinds) doc cursor source has-source)]
              (when (not ok)
                (return false error)))
            (set! cursor doc.nodes[cursor].next-sibling))))
      (let [[ok error] (append-edn-local-not-step-with-source! (addr clauses) (addr predicates) (addr function-clauses) (addr not-groups) (addr step-kinds) doc branch source has-source)]
        (when (not ok)
          (return false error))))
    (arr.push! out^ (not-group-program (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice not-groups 0) (slice step-kinds 0)))
    (return true "")))

(defn append-edn-or-branch! [out: ^[dynamic]Not-Group, doc: EDN-Doc, branch: int] -> [ok: bool, error: string]
  (append-edn-or-branch-with-source! out doc branch "" false))

(defn append-edn-or-group-with-source! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [branches (make [dynamic]Not-Group) :defer
        op-node (edn-list-op-node doc form)
        cursor (if (= op-node -1) -1 doc.nodes[op-node].next-sibling)]
    (when (= cursor -1)
      (return false "Cannot parse 'or' clause"))
    (while (not (= cursor -1))
      (let [[ok error] (append-edn-or-branch-with-source! (addr branches) doc cursor source has-source)]
        (when (not ok)
          (return false error)))
      (set! cursor doc.nodes[cursor].next-sibling))
    (when (not (or-branches-have-vars? (slice branches 0)))
      (return false "Join variables should not be empty"))
    (arr.push! out^ (or-group (slice branches 0)))
    (return true "")))

(defn append-edn-or-group! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [[source has-source] (edn-list-default-source doc form)]
    (append-edn-or-group-with-source! out doc form source has-source)))

(defn append-edn-or-join-group-with-source! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int, source: string, has-source: bool] -> [ok: bool, error: string]
  (let [op-node (edn-list-op-node doc form)
        join-node (if (= op-node -1) -1 doc.nodes[op-node].next-sibling)]
    (when (or (= join-node -1) (not (= doc.nodes[join-node].kind .Vector)))
      (return false "or-join expects a vector of join vars"))
    (let [join-vars (edn-vars-from-vector doc join-node) :defer
          branches (make [dynamic]Not-Group) :defer
          cursor doc.nodes[join-node].next-sibling]
      (when (= (count join-vars) 0)
        (return false "Cannot parse rule-vars"))
      (when (= cursor -1)
        (return false "Cannot parse 'or-join' clause"))
      (while (not (= cursor -1))
        (let [[ok error] (append-edn-or-branch-with-source! (addr branches) doc cursor source has-source)]
          (when (not ok)
            (return false error)))
        (set! cursor doc.nodes[cursor].next-sibling))
      (arr.push! out^ (or-join-group (slice join-vars 0) (slice branches 0)))
      (return true ""))))

(defn append-edn-or-join-group! [out: ^[dynamic]Or-Group, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [[source has-source] (edn-list-default-source doc form)]
    (append-edn-or-join-group-with-source! out doc form source has-source)))

(defn rule-call-from-text-parts [name: string, source: string, has-source: bool, args: []Term] -> Rule-Call
  (let [owned-args (arr.into [dynamic]Term args)]
    (Rule-Call {name: name source: source has-source: has-source args: owned-args})))

(defn append-edn-rule-call! [out: ^[dynamic]Rule-Call, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [head doc.nodes[form].first-child]
    (when (or (= head -1) (not (= doc.nodes[head].kind .Symbol)))
      (return false "rule calls must start with a symbol"))
    (let [name-node head
          source ""
          has-source false]
      (when (edn-source-var? doc head)
        (set! source doc.nodes[head].text)
        (set! has-source true)
        (set! name-node doc.nodes[head].next-sibling)
        (when (or (= name-node -1) (not (= doc.nodes[name-node].kind .Symbol)))
          (return false "source-qualified rule calls must name a rule")))
    (let [args (make [dynamic]Term) :defer
          cursor doc.nodes[name-node].next-sibling]
      (when (= cursor -1)
        (return false "rule-expr requires at least one argument"))
      (while (not (= cursor -1))
        (arr.push! args (value-term-from-edn-node doc cursor))
        (set! cursor doc.nodes[cursor].next-sibling))
      (arr.push! out^ (rule-call-from-text-parts doc.nodes[name-node].text source has-source (slice args 0)))
      (return true "")))))

(defn append-edn-where-item! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, get-elses: ^[dynamic]Get-Else, get-somes: ^[dynamic]Get-Some, grounds: ^[dynamic]Ground, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (if (= doc.nodes[item].kind .List)
    (let [head (edn-list-op-text doc item)]
      (cond
        (= head "not") (append-edn-not-group! not-groups doc item)
        (= head "not-join") (append-edn-not-join-group! not-groups doc item)
        (= head "or") (append-edn-or-group! or-groups doc item)
        (= head "or-join") (append-edn-or-join-group! or-groups doc item)
        :else (return false "query text list where clauses currently support not, or, and rules")))
    (if (= doc.nodes[item].kind .Vector)
      (let [first-item (edn-child-at doc item 0)]
        (if (and (not (= first-item -1)) (= doc.nodes[first-item].kind .List))
          (let [expr first-item
                output doc.nodes[expr].next-sibling
                op (edn-list-head-text doc expr)]
            (cond
              (= op "missing?") (append-edn-missing-group! not-groups doc expr)
              (= op "get-else") (append-edn-get-else! get-elses doc expr output)
              (= op "get-some") (append-edn-get-some! get-somes doc expr output)
              (= op "ground") (append-edn-ground! grounds doc expr output)
              (not (= output -1)) (append-edn-function-clause! function-clauses doc expr output)
              :else (append-edn-predicate! predicates doc expr)))
          (append-edn-data-clause! clauses doc item)))
      (return false "query text where clauses must be vectors or lists"))))

(defn append-edn-where-or-rule-item! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, get-elses: ^[dynamic]Get-Else, get-somes: ^[dynamic]Get-Some, grounds: ^[dynamic]Ground, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, rule-calls: ^[dynamic]Rule-Call, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (if (= doc.nodes[item].kind .List)
    (let [head (edn-list-op-text doc item)]
      (cond
        (= head "not") (append-edn-not-group! not-groups doc item)
        (= head "not-join") (append-edn-not-join-group! not-groups doc item)
        (= head "or") (append-edn-or-group! or-groups doc item)
        (= head "or-join") (append-edn-or-join-group! or-groups doc item)
        :else (append-edn-rule-call! rule-calls doc item)))
    (append-edn-where-item! clauses predicates function-clauses get-elses get-somes grounds not-groups or-groups doc item)))

(defn append-edn-where-step! [steps: ^[dynamic]Query-Step, kind: Query-Step-Kind, index: int]
  (arr.push! steps^ (Query-Step {kind: kind index: index})))

(defn append-edn-where-or-rule-step! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, get-elses: ^[dynamic]Get-Else, get-somes: ^[dynamic]Get-Some, grounds: ^[dynamic]Ground, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, rule-calls: ^[dynamic]Rule-Call, steps: ^[dynamic]Query-Step, doc: EDN-Doc, item: int] -> [ok: bool, error: string]
  (when (and (= doc.nodes[item].kind .List)
             (= (edn-list-head-text doc item) "and"))
    (let [cursor doc.nodes[doc.nodes[item].first-child].next-sibling]
      (while (not (= cursor -1))
        (let [[child-ok child-error] (append-edn-where-or-rule-step! clauses predicates function-clauses get-elses get-somes grounds not-groups or-groups rule-calls steps doc cursor)]
          (when (not child-ok)
            (return false child-error)))
        (set! cursor doc.nodes[cursor].next-sibling))
      (return true "")))
  (let [clause-index (count clauses^)
        predicate-index (count predicates^)
        function-index (count function-clauses^)
        get-else-index (count get-elses^)
        get-some-index (count get-somes^)
        ground-index (count grounds^)
        rule-call-index (count rule-calls^)
        not-index (count not-groups^)
        or-index (count or-groups^)
        [item-ok item-error] (append-edn-where-or-rule-item! clauses predicates function-clauses get-elses get-somes grounds not-groups or-groups rule-calls doc item)]
    (when (not item-ok)
      (return false item-error))
    (cond
      (> (count clauses^) clause-index) (append-edn-where-step! steps .Clause clause-index)
      (> (count predicates^) predicate-index) (append-edn-where-step! steps .Predicate predicate-index)
      (> (count function-clauses^) function-index) (append-edn-where-step! steps .Function function-index)
      (> (count get-elses^) get-else-index) (append-edn-where-step! steps .GetElse get-else-index)
      (> (count get-somes^) get-some-index) (append-edn-where-step! steps .GetSome get-some-index)
      (> (count grounds^) ground-index) (append-edn-where-step! steps .Ground ground-index)
      (> (count rule-calls^) rule-call-index) (append-edn-where-step! steps .RuleCall rule-call-index)
      (> (count not-groups^) not-index) (append-edn-where-step! steps .Not not-index)
      (> (count or-groups^) or-index) (append-edn-where-step! steps .Or or-index)
      :else (do))
    (return true "")))

(defn rule-from-text-parts [name: string, required-param-count: int, params: []string, clauses: []Clause, predicates: []Predicate, function-clauses: []Function-Clause, get-elses: []Get-Else, get-somes: []Get-Some, grounds: []Ground, rule-calls: []Rule-Call, not-groups: []Not-Group, or-groups: []Or-Group, steps: []Query-Step] -> Rule
  (let [step-kinds (make [dynamic]Query-Step-Kind) :defer]
    (for [step steps]
      (arr.push! step-kinds step.kind))
    (make-rule-with-required name required-param-count params clauses predicates function-clauses get-elses get-somes grounds rule-calls not-groups or-groups (slice step-kinds 0))))

(defn append-edn-rule-param! [params: ^[dynamic]string, doc: EDN-Doc, node: int] -> [ok: bool, error: string]
  (when (not (edn-var? doc node))
    (return false "rule params must be variables"))
  (arr.push! params^ doc.nodes[node].text)
  (return true ""))

(defn append-edn-rule! [out: ^[dynamic]Rule, doc: EDN-Doc, rule-node: int] -> [ok: bool, error: string]
  (when (or (= rule-node -1) (not (= doc.nodes[rule-node].kind .Vector)))
    (return false "rule definitions must be vectors"))
  (let [head doc.nodes[rule-node].first-child]
    (when (or (= head -1) (not (= doc.nodes[head].kind .List)))
      (return false "rule definitions must start with a rule head"))
    (let [name-node doc.nodes[head].first-child]
      (when (or (= name-node -1) (not (= doc.nodes[name-node].kind .Symbol)))
        (return false "rule head must start with a symbol"))
        (let [params (make [dynamic]string) :defer
            required-param-count 0
            clauses (make [dynamic]Clause) :defer
            predicates (make [dynamic]Predicate) :defer
            function-clauses (make [dynamic]Function-Clause) :defer
            get-elses (make [dynamic]Get-Else) :defer
            get-somes (make [dynamic]Get-Some)
            grounds (make [dynamic]Ground) :defer
            not-groups (make [dynamic]Not-Group) :defer
            or-groups (make [dynamic]Or-Group) :defer
            rule-calls (make [dynamic]Rule-Call) :defer
            steps (make [dynamic]Query-Step) :defer
            param doc.nodes[name-node].next-sibling
            body doc.nodes[head].next-sibling]
        (defer (delete-get-somes get-somes))
        (when (= param -1)
          (return false "Cannot parse rule-vars"))
        (when (= doc.nodes[param].kind .Vector)
          (let [required doc.nodes[param].first-child]
            (when (= required -1)
              (return false "Cannot parse rule-vars"))
            (while (not (= required -1))
              (let [[param-ok param-error] (append-edn-rule-param! (addr params) doc required)]
                (when (not param-ok)
                  (return false param-error)))
              (set! required-param-count (+ required-param-count 1))
              (set! required doc.nodes[required].next-sibling)))
          (set! param doc.nodes[param].next-sibling))
        (while (not (= param -1))
          (let [[param-ok param-error] (append-edn-rule-param! (addr params) doc param)]
            (when (not param-ok)
              (return false param-error)))
          (set! param doc.nodes[param].next-sibling))
        (when (= (count params) 0)
          (return false "Cannot parse rule-vars"))
        (while (not (= body -1))
          (let [[body-ok body-error] (append-edn-where-or-rule-step! (addr clauses) (addr predicates) (addr function-clauses) (addr get-elses) (addr get-somes) (addr grounds) (addr not-groups) (addr or-groups) (addr rule-calls) (addr steps) doc body)]
            (when (not body-ok)
              (return false body-error)))
          (set! body doc.nodes[body].next-sibling))
        (arr.push! out^ (rule-from-text-parts doc.nodes[name-node].text required-param-count (slice params 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice get-elses 0) (slice get-somes 0) (slice grounds 0) (slice rule-calls 0) (slice not-groups 0) (slice or-groups 0) (slice steps 0)))
        (return true "")))))

(defn parse-rules-edn! [out: ^[dynamic]Rule, doc: EDN-Doc] -> [ok: bool, error: string]
  (when (or (= doc.root -1) (not (= doc.nodes[doc.root].kind .Vector)))
    (return false "rules text must be an EDN vector"))
  (let [cursor doc.nodes[doc.root].first-child]
    (while (not (= cursor -1))
      (let [[rule-ok rule-error] (append-edn-rule! out doc cursor)]
        (when (not rule-ok)
          (return false rule-error)))
      (set! cursor doc.nodes[cursor].next-sibling))
    (return true "")))

(defn append-edn-rules-section! [out: ^[dynamic]Rule, doc: EDN-Doc, rules-node: int] -> [ok: bool, error: string]
  (when (= rules-node -1)
    (return true ""))
  (when (not (= doc.nodes[rules-node].kind .Vector))
    (return false "rules text must be an EDN vector"))
  (let [cursor doc.nodes[rules-node].first-child]
    (while (not (= cursor -1))
      (let [[rule-ok rule-error] (append-edn-rule! out doc cursor)]
        (when (not rule-ok)
          (return false rule-error)))
      (set! cursor doc.nodes[cursor].next-sibling))
    (return true "")))

(defn parse-rules-text! [out: ^[dynamic]Rule, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-rules-edn! out doc)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn parsed-rule-params-have-duplicate? [params: []string] -> bool
  (for [param index params]
    (for [other-index (arr.range (+ index 1) (count params))]
      (when (= param params[other-index])
        (return true))))
  false)

(defn validate-parsed-rule [rules: []Rule, rule-index: int] -> [ok: bool, error: string]
  (let [rule rules[rule-index]]
    (when (= (count rule.body-steps) 0)
      (return false "Rule branch should have clauses"))
    (when (parsed-rule-params-have-duplicate? (slice rule.params 0))
      (return false "Rule variables should be distinct"))
    (for [other index rules]
      (when (and (not (= index rule-index))
                 (= other.name rule.name))
        (when (or (not (= other.required-param-count rule.required-param-count))
                  (not (= (count other.params) (count rule.params))))
          (return false (fmt.tprintf "Arity mismatch for rule: %s" rule.name)))))
    (return true "")))

(defn validate-parsed-rules [rules: []Rule] -> [ok: bool, error: string]
  (for [_ index rules]
    (let [[ok error] (validate-parsed-rule rules index)]
      (when (not ok)
        (return false error))))
  (return true ""))

(defn parse-rules-text [text: string] -> Prepared-Rules
  (let [rules (make [dynamic]Rule)
        [ok error] (parse-rules-text! (addr rules) text)]
    (when (not ok)
      (return (Prepared-Rules {ok: false error: error rules: rules})))
    (let [[valid valid-error] (validate-parsed-rules (slice rules 0))]
      (if valid
        (Prepared-Rules {ok: true error: "" rules: rules})
        (Prepared-Rules {ok: false error: valid-error rules: rules})))))

(defn parse-rules-text-checked! [out: ^[dynamic]Rule, text: string] -> [ok: bool, error: string]
  (let [[parsed-ok parsed-error] (parse-rules-text! out text)]
    (when (not parsed-ok)
      (return false parsed-error))
    (validate-parsed-rules (slice out^ 0))))

(defn edn-query-vector-section-rank [doc: EDN-Doc, node: int] -> int
  (cond
    (edn-keyword-text? doc node ":find") 1
    (edn-return-map-marker? doc node) 2
    (edn-keyword-text? doc node ":with") 3
    (edn-keyword-text? doc node ":in") 4
    (edn-keyword-text? doc node ":where") 5
    :else 0))

(defn validate-query-vector-sections [doc: EDN-Doc] -> [ok: bool, error: string]
  (let [seen-find false
        seen-return false
        seen-with false
        seen-in false
        seen-where false
        last-rank 0
        cursor doc.nodes[doc.root].first-child]
    (while (not (= cursor -1))
      (let [rank (edn-query-vector-section-rank doc cursor)]
        (when (> rank 0)
          (when (< rank last-rank)
            (return false "query sections must appear in :find :with :in :where order"))
          (set! last-rank rank)
          (cond
            (= rank 1)
              (do
                (when seen-find
                  (return false "query text has duplicate :find section"))
                (set! seen-find true))
            (= rank 2)
              (do
                (when seen-return
                  (return false "Only one of :keys/:syms/:strs must be present"))
                (set! seen-return true))
            (= rank 3)
              (do
                (when seen-with
                  (return false "query text has duplicate :with section"))
                (set! seen-with true))
            (= rank 4)
              (do
                (when seen-in
                  (return false "query text has duplicate :in section"))
                (set! seen-in true))
            (= rank 5)
              (do
                (when seen-where
                  (return false "query text has duplicate :where section"))
                (set! seen-where true)))))
      (set! cursor doc.nodes[cursor].next-sibling))
    (return true "")))

(defn edn-query-map-known-key? [doc: EDN-Doc, node: int] -> bool
  (or (edn-keyword-text? doc node ":find")
      (edn-keyword-text? doc node ":with")
      (edn-keyword-text? doc node ":in")
      (edn-keyword-text? doc node ":where")
      (edn-keyword-text? doc node ":rules")
      (edn-return-map-marker? doc node)))

(defn validate-query-map-sections [doc: EDN-Doc] -> [ok: bool, error: string]
  (let [seen-find false
        seen-with false
        seen-in false
        seen-where false
        seen-rules false
        seen-return false
        entry doc.nodes[doc.root].first-child]
    (while (not (= entry -1))
      (let [value-node doc.nodes[entry].next-sibling]
        (when (= value-node -1)
          (return false "query map entry missing value"))
        (when (not (edn-query-map-known-key? doc entry))
          (return false "query map contains unsupported key"))
        (cond
          (edn-keyword-text? doc entry ":find")
            (do
              (when seen-find
                (return false "query map has duplicate :find section"))
              (set! seen-find true))
          (edn-keyword-text? doc entry ":with")
            (do
              (when seen-with
                (return false "query map has duplicate :with section"))
              (set! seen-with true))
          (edn-keyword-text? doc entry ":in")
            (do
              (when seen-in
                (return false "query map has duplicate :in section"))
              (set! seen-in true))
          (edn-keyword-text? doc entry ":where")
            (do
              (when seen-where
                (return false "query map has duplicate :where section"))
              (set! seen-where true))
          (edn-keyword-text? doc entry ":rules")
            (do
              (when seen-rules
                (return false "query map has duplicate :rules section"))
              (set! seen-rules true))
          (edn-return-map-marker? doc entry)
            (do
              (when seen-return
                (return false "Only one of :keys/:syms/:strs must be present"))
              (set! seen-return true)))
        (set! entry doc.nodes[value-node].next-sibling)))
    (return true "")))

(defn parse-query-vector-edn-with-sources! [out: ^Query, doc: EDN-Doc, db-sources: []DB-Source] -> [ok: bool, error: string]
  (when (or (= doc.root -1)
            (not (= doc.nodes[doc.root].kind .Vector)))
    (return false "query text must be an EDN vector"))
  (let [head (edn-child-at doc doc.root 0)]
    (when (not (edn-keyword-text? doc head ":find"))
      (return false "query text must start with [:find")))
  (let [[sections-ok sections-error] (validate-query-vector-sections doc)]
    (when (not sections-ok)
      (return false sections-error)))
  (let [find (make [dynamic]string) :defer
        with (make [dynamic]string) :defer
        inputs (make [dynamic]string) :defer
        collection-inputs (make [dynamic]string) :defer
        tuple-inputs (make [dynamic]Tuple-Input) :defer
        relation-inputs (make [dynamic]Relation-Input) :defer
        input-specs (make [dynamic]Query-Input-Spec) :defer
        clauses (make [dynamic]Clause) :defer
        predicates (make [dynamic]Predicate) :defer
        function-clauses (make [dynamic]Function-Clause) :defer
        get-elses (make [dynamic]Get-Else) :defer
        get-somes (make [dynamic]Get-Some)
        grounds (make [dynamic]Ground) :defer
        rule-calls (make [dynamic]Rule-Call) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer
        where-steps (make [dynamic]Query-Step) :defer
          pulls (make [dynamic]Pull-Find) :defer
          aggregates (make [dynamic]Aggregate-Find) :defer
          return-map-allowed true
          return-map-scalar false
          has-rules-input false
          cursor (edn-child-at doc doc.root 1)]
    (defer (delete-get-somes get-somes))
    (while (and (not (= cursor -1))
                (not (edn-keyword-text? doc cursor ":in"))
                (not (edn-keyword-text? doc cursor ":where"))
                (not (edn-keyword-text? doc cursor ":with"))
                (not (edn-keyword-text? doc cursor ":keys"))
                (not (edn-keyword-text? doc cursor ":strs"))
                (not (edn-keyword-text? doc cursor ":syms")))
      (when (or (edn-symbol-text? doc cursor ".")
                  (edn-find-vector-collection? doc cursor))
          (set! return-map-allowed false))
        (when (edn-symbol-text? doc cursor ".")
          (set! return-map-scalar true))
      (if (= doc.nodes[cursor].kind .Vector)
        (let [[find-ok find-error] (append-edn-find-vector! (addr find) (addr pulls) (addr aggregates) doc cursor)]
          (when (not find-ok)
            (return false find-error)))
        (let [[find-ok find-error] (append-edn-find-item! (addr find) (addr pulls) (addr aggregates) doc cursor)]
          (when (not find-ok)
            (return false find-error))))
      (set! cursor doc.nodes[cursor].next-sibling))
    (when (or (edn-keyword-text? doc cursor ":keys")
        (edn-keyword-text? doc cursor ":strs")
        (edn-keyword-text? doc cursor ":syms"))
    (when (> (edn-vector-return-marker-count doc) 1)
      (return false "Only one of :keys/:syms/:strs must be present"))
    (let [marker (edn-return-map-marker-text doc cursor)]
      (when (not return-map-allowed)
        (return false (return-map-kind-error marker return-map-scalar)))
      (when (not (= (edn-vector-return-entry-count doc cursor)
                    (+ (count find) (count pulls) (count aggregates))))
        (return false (return-map-count-error marker))))
      (set! cursor doc.nodes[cursor].next-sibling)
      (while (and (not (= cursor -1))
                  (not (edn-keyword-text? doc cursor ":in"))
                  (not (edn-keyword-text? doc cursor ":with"))
                  (not (edn-keyword-text? doc cursor ":where"))
                  (not (edn-return-map-marker? doc cursor)))
        (set! cursor doc.nodes[cursor].next-sibling)
        (continue)))
    (when (edn-keyword-text? doc cursor ":with")
      (set! cursor doc.nodes[cursor].next-sibling)
      (while (and (not (= cursor -1))
                  (not (edn-keyword-text? doc cursor ":in"))
                  (not (edn-keyword-text? doc cursor ":where")))
        (when (not (edn-var? doc cursor))
          (return false "query text :with currently supports vars"))
        (arr.push! with doc.nodes[cursor].text)
        (set! cursor doc.nodes[cursor].next-sibling)))
    (when (edn-keyword-text? doc cursor ":in")
      (set! cursor doc.nodes[cursor].next-sibling)
      (while (and (not (= cursor -1)) (not (edn-keyword-text? doc cursor ":where")))
        (when (edn-symbol-text? doc cursor "%")
          (set! has-rules-input true))
        (let [[input-ok input-error] (append-edn-input-spec! (addr inputs) (addr collection-inputs) (addr tuple-inputs) (addr relation-inputs) (addr input-specs) doc cursor db-sources)]
          (when (not input-ok)
            (return false input-error)))
        (set! cursor doc.nodes[cursor].next-sibling)))
    (when (edn-keyword-text? doc cursor ":where")
      (set! cursor doc.nodes[cursor].next-sibling))
    (while (not (= cursor -1))
      (let [[item-ok item-error] (append-edn-where-or-rule-step! (addr clauses) (addr predicates) (addr function-clauses) (addr get-elses) (addr get-somes) (addr grounds) (addr not-groups) (addr or-groups) (addr rule-calls) (addr where-steps) doc cursor)]
        (when (not item-ok)
          (return false item-error)))
      (set! cursor doc.nodes[cursor].next-sibling))
    (let [query-value (query-with-rules-input
                        (query-with-where-steps (query-from-text-parts (slice find 0) (slice with 0) (slice inputs 0) (slice collection-inputs 0) (slice tuple-inputs 0) (slice relation-inputs 0) (slice input-specs 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice rule-calls 0) (slice get-elses 0) (slice get-somes 0) (slice grounds 0) (slice not-groups 0) (slice or-groups 0) (slice pulls 0) (slice aggregates 0)) (slice where-steps 0))
                        has-rules-input)]
      (set! out^ query-value)
      (return true ""))))

(defn edn-map-value-node [doc: EDN-Doc, map-node: int, key: string] -> int
  (when (or (= map-node -1) (not (= doc.nodes[map-node].kind .Map)))
    (return -1))
  (let [entry doc.nodes[map-node].first-child]
    (while (not (= entry -1))
      (let [value-node doc.nodes[entry].next-sibling]
        (when (= value-node -1)
          (return -1))
        (when (edn-keyword-text? doc entry key)
          (return value-node))
        (set! entry doc.nodes[value-node].next-sibling))))
  -1)

(defn edn-return-map-marker? [doc: EDN-Doc, node-index: int] -> bool
  (or (edn-keyword-text? doc node-index ":keys")
      (edn-keyword-text? doc node-index ":strs")
      (edn-keyword-text? doc node-index ":syms")))

(defn edn-return-map-marker-text [doc: EDN-Doc, node-index: int] -> string
  (when (= node-index -1)
    (return ":keys"))
  doc.nodes[node-index].text)

(defn return-map-kind-error [marker: string, scalar: bool] -> string
  (if scalar
    (fmt.tprintf "%s does not work with single-scalar :find" marker)
    (fmt.tprintf "%s does not work with collection :find" marker)))

(defn return-map-count-error [marker: string] -> string
  (fmt.tprintf "Count of %s must match count of :find" marker))

(defn edn-find-vector-collection? [doc: EDN-Doc, vector-node: int] -> bool
  (when (or (= vector-node -1)
            (not (= doc.nodes[vector-node].kind .Vector))
            (not (= doc.nodes[vector-node].child-count 2)))
    (return false))
  (let [first-node doc.nodes[vector-node].first-child
        second-node (if (= first-node -1) -1 doc.nodes[first-node].next-sibling)]
    (edn-symbol-text? doc second-node "...")))

(defn edn-find-vector-scalar? [doc: EDN-Doc, vector-node: int] -> bool
  (when (or (= vector-node -1)
            (not (= doc.nodes[vector-node].kind .Vector))
            (not (= doc.nodes[vector-node].child-count 2)))
    (return false))
  (let [first-node doc.nodes[vector-node].first-child
        second-node (if (= first-node -1) -1 doc.nodes[first-node].next-sibling)]
    (edn-symbol-text? doc second-node ".")))

(defn edn-map-return-marker-count [doc: EDN-Doc] -> int
  (let [out 0]
    (when (not (= (edn-map-value-node doc doc.root ":keys") -1))
      (set! out (+ out 1)))
    (when (not (= (edn-map-value-node doc doc.root ":strs") -1))
      (set! out (+ out 1)))
    (when (not (= (edn-map-value-node doc doc.root ":syms") -1))
      (set! out (+ out 1)))
    out))

(defn edn-map-return-node [doc: EDN-Doc] -> int
  (let [keys-node (edn-map-value-node doc doc.root ":keys")]
    (when (not (= keys-node -1))
      (return keys-node)))
  (let [strs-node (edn-map-value-node doc doc.root ":strs")]
    (when (not (= strs-node -1))
      (return strs-node)))
    (edn-map-value-node doc doc.root ":syms"))

(defn edn-map-return-marker-text [doc: EDN-Doc] -> string
  (when (not (= (edn-map-value-node doc doc.root ":keys") -1))
    (return ":keys"))
  (when (not (= (edn-map-value-node doc doc.root ":strs") -1))
    (return ":strs"))
  (when (not (= (edn-map-value-node doc doc.root ":syms") -1))
    (return ":syms"))
  ":keys")

(defn edn-return-entry-count [doc: EDN-Doc, node-index: int] -> int
  (when (= node-index -1)
    (return 0))
  (if (= doc.nodes[node-index].kind .Vector)
    doc.nodes[node-index].child-count
    1))

(defn edn-vector-return-marker-count [doc: EDN-Doc] -> int
  (let [out 0
        cursor doc.nodes[doc.root].first-child]
    (while (not (= cursor -1))
      (when (edn-return-map-marker? doc cursor)
        (set! out (+ out 1)))
      (set! cursor doc.nodes[cursor].next-sibling))
    out))

(defn edn-vector-return-entry-count [doc: EDN-Doc, marker-node: int] -> int
  (let [out 0
        cursor (if (= marker-node -1) -1 doc.nodes[marker-node].next-sibling)]
    (while (and (not (= cursor -1))
                (not (edn-keyword-text? doc cursor ":in"))
                (not (edn-keyword-text? doc cursor ":with"))
                (not (edn-keyword-text? doc cursor ":where"))
                (not (edn-return-map-marker? doc cursor)))
      (set! out (+ out 1))
      (set! cursor doc.nodes[cursor].next-sibling))
    out))

(defn append-edn-find-section! [find: ^[dynamic]string, pulls: ^[dynamic]Pull-Find, aggregates: ^[dynamic]Aggregate-Find, doc: EDN-Doc, section: int] -> [ok: bool, error: string]
  (when (= section -1)
    (return false "query map requires :find"))
  (if (= doc.nodes[section].kind .Vector)
    (append-edn-find-vector! find pulls aggregates doc section)
    (append-edn-find-item! find pulls aggregates doc section)))

(defn append-edn-with-section! [with: ^[dynamic]string, doc: EDN-Doc, section: int] -> [ok: bool, error: string]
  (when (= section -1)
    (return true ""))
  (when (not (= doc.nodes[section].kind .Vector))
    (return false "query map :with must be a vector"))
  (let [cursor doc.nodes[section].first-child]
    (while (not (= cursor -1))
      (when (not (edn-var? doc cursor))
        (return false "query text :with currently supports vars"))
      (arr.push! with^ doc.nodes[cursor].text)
      (set! cursor doc.nodes[cursor].next-sibling)))
  (return true ""))

(defn append-edn-in-section! [inputs: ^[dynamic]string, collection-inputs: ^[dynamic]string, tuple-inputs: ^[dynamic]Tuple-Input, relation-inputs: ^[dynamic]Relation-Input, input-specs: ^[dynamic]Query-Input-Spec, doc: EDN-Doc, section: int, db-sources: []DB-Source] -> [ok: bool, error: string]
  (when (= section -1)
    (return true ""))
  (when (not (= doc.nodes[section].kind .Vector))
    (return false "query map :in must be a vector"))
  (let [cursor doc.nodes[section].first-child]
    (while (not (= cursor -1))
      (let [[input-ok input-error] (append-edn-input-spec! inputs collection-inputs tuple-inputs relation-inputs input-specs doc cursor db-sources)]
        (when (not input-ok)
          (return false input-error)))
      (set! cursor doc.nodes[cursor].next-sibling)))
  (return true ""))

(defn append-edn-where-section! [clauses: ^[dynamic]Clause, predicates: ^[dynamic]Predicate, function-clauses: ^[dynamic]Function-Clause, get-elses: ^[dynamic]Get-Else, get-somes: ^[dynamic]Get-Some, grounds: ^[dynamic]Ground, not-groups: ^[dynamic]Not-Group, or-groups: ^[dynamic]Or-Group, rule-calls: ^[dynamic]Rule-Call, steps: ^[dynamic]Query-Step, doc: EDN-Doc, section: int] -> [ok: bool, error: string]
  (when (= section -1)
    (return true ""))
  (when (not (= doc.nodes[section].kind .Vector))
    (return false "query map :where must be a vector"))
  (let [cursor doc.nodes[section].first-child]
    (while (not (= cursor -1))
      (let [[item-ok item-error] (append-edn-where-or-rule-step! clauses predicates function-clauses get-elses get-somes grounds not-groups or-groups rule-calls steps doc cursor)]
        (when (not item-ok)
          (return false item-error)))
      (set! cursor doc.nodes[cursor].next-sibling)))
  (return true ""))

(defn parse-query-map-edn-with-sources! [out: ^Query, doc: EDN-Doc, db-sources: []DB-Source] -> [ok: bool, error: string]
  (when (or (= doc.root -1)
            (not (= doc.nodes[doc.root].kind .Map)))
    (return false "query text map must be an EDN map"))
  (let [[sections-ok sections-error] (validate-query-map-sections doc)]
    (when (not sections-ok)
      (return false sections-error)))
  (let [find (make [dynamic]string) :defer
        with (make [dynamic]string) :defer
        inputs (make [dynamic]string) :defer
        collection-inputs (make [dynamic]string) :defer
        tuple-inputs (make [dynamic]Tuple-Input) :defer
        relation-inputs (make [dynamic]Relation-Input) :defer
        input-specs (make [dynamic]Query-Input-Spec) :defer
        clauses (make [dynamic]Clause) :defer
        predicates (make [dynamic]Predicate) :defer
        function-clauses (make [dynamic]Function-Clause) :defer
        get-elses (make [dynamic]Get-Else) :defer
        get-somes (make [dynamic]Get-Some)
        grounds (make [dynamic]Ground) :defer
        rule-calls (make [dynamic]Rule-Call) :defer
        inline-rules (make [dynamic]Rule) :defer
        not-groups (make [dynamic]Not-Group) :defer
        or-groups (make [dynamic]Or-Group) :defer
        where-steps (make [dynamic]Query-Step) :defer
        pulls (make [dynamic]Pull-Find) :defer
        aggregates (make [dynamic]Aggregate-Find) :defer
        find-node (edn-map-value-node doc doc.root ":find")
        with-node (edn-map-value-node doc doc.root ":with")
        in-node (edn-map-value-node doc doc.root ":in")
        where-node (edn-map-value-node doc doc.root ":where")
        rules-node (edn-map-value-node doc doc.root ":rules")
        has-rules-input (edn-section-has-rules-input? doc in-node)
        [find-ok find-error] (append-edn-find-section! (addr find) (addr pulls) (addr aggregates) doc find-node)]
      (defer (delete-get-somes get-somes))
      (when (not find-ok)
        (return false find-error))
      (when (> (edn-map-return-marker-count doc) 1)
        (return false "Only one of :keys/:syms/:strs must be present"))
      (when (> (edn-map-return-marker-count doc) 0)
        (let [marker-node (edn-map-return-node doc)
              marker (edn-map-return-marker-text doc)]
          (when (or (edn-find-vector-collection? doc find-node)
                    (edn-find-vector-scalar? doc find-node))
            (return false (return-map-kind-error marker (edn-find-vector-scalar? doc find-node))))
          (when (not (= (edn-return-entry-count doc marker-node)
                        (+ (count find) (count pulls) (count aggregates))))
            (return false (return-map-count-error marker)))))
    (let [[with-ok with-error] (append-edn-with-section! (addr with) doc with-node)]
      (when (not with-ok)
        (return false with-error)))
    (let [[in-ok in-error] (append-edn-in-section! (addr inputs) (addr collection-inputs) (addr tuple-inputs) (addr relation-inputs) (addr input-specs) doc in-node db-sources)]
      (when (not in-ok)
        (return false in-error)))
    (let [[where-ok where-error] (append-edn-where-section! (addr clauses) (addr predicates) (addr function-clauses) (addr get-elses) (addr get-somes) (addr grounds) (addr not-groups) (addr or-groups) (addr rule-calls) (addr where-steps) doc where-node)]
      (when (not where-ok)
        (return false where-error)))
    (let [[rules-ok rules-error] (append-edn-rules-section! (addr inline-rules) doc rules-node)]
      (when (not rules-ok)
        (return false rules-error)))
    (let [query-value (query-with-rules-input
                        (query-with-where-steps (query-from-text-parts (slice find 0) (slice with 0) (slice inputs 0) (slice collection-inputs 0) (slice tuple-inputs 0) (slice relation-inputs 0) (slice input-specs 0) (slice clauses 0) (slice predicates 0) (slice function-clauses 0) (slice rule-calls 0) (slice get-elses 0) (slice get-somes 0) (slice grounds 0) (slice not-groups 0) (slice or-groups 0) (slice pulls 0) (slice aggregates 0)) (slice where-steps 0))
                        (or has-rules-input (> (count inline-rules) 0)))]
      (delete query-value.rules)
      (let [owned-rules (arr.into [dynamic]Rule (slice inline-rules 0))]
        (set! query-value.rules owned-rules))
      (set! out^ query-value)
      (return true ""))))

(defn parse-query-edn-with-sources! [out: ^Query, doc: EDN-Doc, db-sources: []DB-Source] -> [ok: bool, error: string]
  (when (= doc.root -1)
    (return false "query text is empty"))
  (case doc.nodes[doc.root].kind
    .Vector (parse-query-vector-edn-with-sources! out doc db-sources)
    .Map (parse-query-map-edn-with-sources! out doc db-sources)
    :else (return false "query text must be an EDN vector or map")))

(defn parse-query-edn! [out: ^Query, doc: EDN-Doc] -> [ok: bool, error: string]
  (parse-query-edn-with-sources! out doc ([]DB-Source [])))

(defn parse-query-text-with-sources! [out: ^Query, text: string, db-sources: []DB-Source] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-query-edn-with-sources! out doc db-sources)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn parse-query-text! [out: ^Query, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (let [[parsed-ok parsed-error] (parse-query-edn! out doc)]
      (delete doc.nodes)
      (return parsed-ok parsed-error))))

(defn prepare-query-text-with-sources [text: string, sources: []DB-Source] -> Prepared-Query
  (let [query-value (empty-query)
        [ok error] (parse-query-text-with-sources! (addr query-value) text sources)]
    (when ok
      (return (Prepared-Query {ok: ok error: error query: (query-with-rule-call-plans query-value)})))
    (return (Prepared-Query {ok: ok error: error query: query-value}))))

(defn prepare-query-text [text: string] -> Prepared-Query
  (prepare-query-text-with-sources text ([]DB-Source [])))

(defn prepare-query-text-with-rules [query-text: string, rules-text: string] -> Prepared-Query
  (let [query-value (empty-query)
        [query-ok query-error] (parse-query-text! (addr query-value) query-text)]
    (when (not query-ok)
      (return (Prepared-Query {ok: false error: query-error query: query-value})))
    (let [prepared-rules (parse-rules-text rules-text)]
      (when (not prepared-rules.ok)
        (delete prepared-rules.rules)
        (return (Prepared-Query {ok: false error: prepared-rules.error query: query-value})))
      (let [query-with-attached-rules (query-with-rule-call-plans (query-with-rules query-value (slice prepared-rules.rules 0)))]
        (delete prepared-rules.rules)
        (Prepared-Query {ok: true error: "" query: query-with-attached-rules})))))

(defn q-prepared [db: DB, prepared: Prepared-Query] -> Result-Set
  (if prepared.ok
    (q-query db prepared.query)
    (result-set-error prepared.error)))

(defn q-prepared-value [db: DB, prepared: Prepared-Query] -> Value
  (result-set-value db (q-prepared db prepared)))

(defn q-prepared-with-fns [db: DB, prepared: Prepared-Query, registry: []Native-Query-Fn] -> Result-Set
  (if prepared.ok
    (q-query-with-fns db prepared.query registry)
    (result-set-error prepared.error)))

(defn q-prepared-value-with-fns [db: DB, prepared: Prepared-Query, registry: []Native-Query-Fn] -> Value
  (result-set-value db (q-prepared-with-fns db prepared registry)))

(defn q-prepared-with-inputs [db: DB, prepared: Prepared-Query, inputs: []Query-Input] -> Result-Set
  (if prepared.ok
    (q-query-with-inputs db prepared.query inputs)
    (result-set-error prepared.error)))

(defn q-prepared-value-with-inputs [db: DB, prepared: Prepared-Query, inputs: []Query-Input] -> Value
  (result-set-value db (q-prepared-with-inputs db prepared inputs)))

(defn q-prepared-with-inputs-and-fns [db: DB, prepared: Prepared-Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (if prepared.ok
    (q-query-with-inputs-and-fns db prepared.query inputs registry)
    (result-set-error prepared.error)))

(defn q-prepared-value-with-inputs-and-fns [db: DB, prepared: Prepared-Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Value
  (result-set-value db (q-prepared-with-inputs-and-fns db prepared inputs registry)))

(defn q-prepared-profiled-with-inputs-and-fns [db: DB, prepared: Prepared-Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Profiled-Result-Set
  (if prepared.ok
    (q-query-profiled-with-sources-and-fns db prepared.query inputs ([]DB-Source []) registry)
    (profiled-result-set (result-set-error prepared.error) (query-stats-empty))))

(defn q-prepared-profiled-with-inputs [db: DB, prepared: Prepared-Query, inputs: []Query-Input] -> Profiled-Result-Set
  (q-prepared-profiled-with-inputs-and-fns db prepared inputs ([]Native-Query-Fn [])))

(defn q-prepared-profiled [db: DB, prepared: Prepared-Query] -> Profiled-Result-Set
  (q-prepared-profiled-with-inputs db prepared ([]Query-Input [])))

(defn q-prepared-profiled-value-with-inputs-and-fns [db: DB, prepared: Prepared-Query, inputs: []Query-Input, registry: []Native-Query-Fn] -> Value
  (profiled-result-set-value db (q-prepared-profiled-with-inputs-and-fns db prepared inputs registry)))

(defn q-prepared-profiled-value-with-inputs [db: DB, prepared: Prepared-Query, inputs: []Query-Input] -> Value
  (q-prepared-profiled-value-with-inputs-and-fns db prepared inputs ([]Native-Query-Fn [])))

(defn q-prepared-profiled-value [db: DB, prepared: Prepared-Query] -> Value
  (q-prepared-profiled-value-with-inputs db prepared ([]Query-Input [])))

(defn q-prepared-with-rules [db: DB, prepared: Prepared-Query, prepared-rules: Prepared-Rules, inputs: []Query-Input] -> Result-Set
  (cond
    (not prepared.ok) (result-set-error prepared.error)
    (not prepared-rules.ok) (result-set-error prepared-rules.error)
    :else (let [query-value (query-with-rule-call-plans (query-copy-with-rules prepared.query (slice prepared-rules.rules 0)))
                result (q-query-with-inputs db query-value inputs)]
            (delete-query-shallow query-value)
            result)))

(defn q-prepared-value-with-rules [db: DB, prepared: Prepared-Query, prepared-rules: Prepared-Rules, inputs: []Query-Input] -> Value
  (result-set-value db (q-prepared-with-rules db prepared prepared-rules inputs)))

(defn q-prepared-with-rules-and-fns [db: DB, prepared: Prepared-Query, prepared-rules: Prepared-Rules, inputs: []Query-Input, registry: []Native-Query-Fn] -> Result-Set
  (cond
    (not prepared.ok) (result-set-error prepared.error)
