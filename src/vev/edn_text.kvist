    (not prepared.ok) (profiled-result-set (result-set-error prepared.error) (query-stats-empty))
    (not prepared-rules.ok) (profiled-result-set (result-set-error prepared-rules.error) (query-stats-empty))
    :else (let [query-value (query-with-rule-call-plans (query-copy-with-rules prepared.query (slice prepared-rules.rules 0)))
                result (q-query-profiled-with-sources-and-fns db query-value inputs ([]DB-Source []) registry)]
            (delete-query-shallow query-value)
            result)))

