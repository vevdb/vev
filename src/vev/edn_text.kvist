(defn pull-many-text-with-fns [db: DB, pattern-text: string, entities: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (let [[pattern ok _] (parse-pull-pattern-text pattern-text)]
    (defer (delete pattern))
    (if ok
      (pull-many-pattern-spec-with-fns db entities (slice pattern 0) registry)
      (make [dynamic]Pull-Result))))

(defn pull-many-text [db: DB, pattern-text: string, entities: []u64] -> [dynamic]Pull-Result
