(defn q-text-with-rules [db: DB, text: string, rules-text: string, inputs: []Query-Input] -> Result-Set
  (let [query-value (empty-query)
        rules (make [dynamic]Rule) :defer
        [query-ok query-error] (parse-query-text! (addr query-value) text)]
    (when (not query-ok)
      (delete-query-shallow query-value)
      (return (result-set-error query-error)))
    (let [[rules-ok rules-error] (parse-rules-text-checked! (addr rules) rules-text)]
      (when (not rules-ok)
        (delete-query-shallow query-value)
        (return (result-set-error rules-error)))
      (let [query-with-attached-rules (query-with-rules query-value (slice rules 0))
            result (q-query-with-inputs db query-with-attached-rules inputs)]
        (delete-query-shallow query-with-attached-rules)
        result))))

(defn q-text-value-with-rules [db: DB, text: string, rules-text: string, inputs: []Query-Input] -> Value
