(package vev)

(defn db-source [name: string, db: DB] -> DB-Source
  (DB-Source {name: name db: db}))

(defn parser-string-vector-value [items: []string, as-symbols: bool] -> Value
  (let [out (make [dynamic]Value 0 (count items))]
    (for [item items]
      (arr.push! out (if as-symbols (value-symbol item) (value-string item))))
    (Value {kind: .Vector items: out})))

(defn parser-binding-kind-value [kind: Input-Binding-Kind] -> Value
  (case kind
    .Ignore (value-keyword ":ignore")
    .Var (value-keyword ":var")
    .Tuple (value-keyword ":tuple")
    .Collection (value-keyword ":collection")
    :else (value-keyword ":none")))

(defn parser-binding-value [binding: Input-Binding] -> Value
  (let [children (make [dynamic]Value 0 (count binding.items))]
    (defer (delete children))
    (for [child binding.items]
      (arr.push! children (parser-binding-value child)))
    (value-map
      ([]Value [(value-keyword ":kind") (parser-binding-kind-value binding.kind)
                (value-keyword ":name") (if (> (count binding.name) 0) (value-symbol binding.name) (value-nil))
                (value-keyword ":items") (value-vector (slice children 0))]))))

(defn parser-term-value [term: Term] -> Value
  (case term.kind
    .Var (value-map
           ([]Value [(value-keyword ":kind") (value-keyword ":var")
                     (value-keyword ":name") (value-symbol term.name)]))
    .Wildcard (value-map
                ([]Value [(value-keyword ":kind") (value-keyword ":wildcard")]))
    .LookupRef (value-map
                 ([]Value [(value-keyword ":kind") (value-keyword ":lookup-ref")
                           (value-keyword ":attr") (value-keyword term.lookup-attr)
                           (value-keyword ":value") term.lookup-value]))
    :else (value-map
            ([]Value [(value-keyword ":kind") (value-keyword ":value")
                      (value-keyword ":value") term.value]))))

(defn parser-clause-value [clause: Clause] -> Value
  (value-map
    ([]Value [(value-keyword ":source") (if clause.has-source (value-symbol clause.source) (value-nil))
              (value-keyword ":e") (parser-term-value clause.e)
              (value-keyword ":a") (parser-term-value clause.a)
              (value-keyword ":v") (parser-term-value clause.v)
              (value-keyword ":tx") (parser-term-value clause.tx-term)
              (value-keyword ":op") (parser-term-value clause.op-term)
              (value-keyword ":source-width") (value-int (i64 clause.source-width))])))

(defn parser-clauses-value [clauses: []Clause] -> Value
  (let [out (make [dynamic]Value 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (parser-clause-value clause)))
    (Value {kind: .Vector items: out})))

(defn parser-predicate-value [predicate: Predicate] -> Value
  (let [terms (make [dynamic]Value 0 (count predicate.terms))]
    (defer (delete terms))
    (for [term predicate.terms]
      (arr.push! terms (parser-term-value term)))
    (value-map
      ([]Value [(value-keyword ":op") (value-symbol predicate.op)
                (value-keyword ":terms") (value-vector (slice terms 0))]))))

(defn parser-predicates-value [predicates: []Predicate] -> Value
  (let [out (make [dynamic]Value 0 (count predicates))]
    (for [predicate predicates]
      (arr.push! out (parser-predicate-value predicate)))
    (Value {kind: .Vector items: out})))

(defn parser-function-clause-value [function: Function-Clause] -> Value
  (let [terms (make [dynamic]Value 0 (count function.terms))]
    (defer (delete terms))
    (for [term function.terms]
      (arr.push! terms (parser-term-value term)))
    (value-map
      ([]Value [(value-keyword ":op") (value-symbol function.op)
                (value-keyword ":terms") (value-vector (slice terms 0))
                (value-keyword ":out") (if (> (count function.out) 0) (value-symbol function.out) (value-nil))
                (value-keyword ":out-vars") (parser-string-vector-value function.out-vars true)
                (value-keyword ":binding") (parser-binding-value function.out-binding)
                (value-keyword ":tuple") (value-bool function.is-tuple)]))))

(defn parser-function-clauses-value [functions: []Function-Clause] -> Value
  (let [out (make [dynamic]Value 0 (count functions))]
    (for [function functions]
      (arr.push! out (parser-function-clause-value function)))
    (Value {kind: .Vector items: out})))

(defn parser-get-else-value [clause: Get-Else] -> Value
  (value-map
    ([]Value [(value-keyword ":e") (parser-term-value clause.e)
              (value-keyword ":attr") (value-keyword clause.a)
              (value-keyword ":default") clause.default-value
              (value-keyword ":out") (value-symbol clause.out)])))

(defn parser-get-elses-value [clauses: []Get-Else] -> Value
  (let [out (make [dynamic]Value 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (parser-get-else-value clause)))
    (Value {kind: .Vector items: out})))

(defn parser-get-some-value [clause: Get-Some] -> Value
  (value-map
    ([]Value [(value-keyword ":e") (parser-term-value clause.e)
              (value-keyword ":attrs") (parser-string-vector-value (slice clause.attrs 0) false)
              (value-keyword ":out-attr") (value-symbol clause.out-attr)
              (value-keyword ":out-value") (value-symbol clause.out-value)])))

(defn parser-get-somes-value [clauses: []Get-Some] -> Value
  (let [out (make [dynamic]Value 0 (count clauses))]
    (for [clause clauses]
      (arr.push! out (parser-get-some-value clause)))
    (Value {kind: .Vector items: out})))

(defn parser-ground-value [ground: Ground] -> Value
  (value-map
    ([]Value [(value-keyword ":source") (parser-term-value ground.source)
              (value-keyword ":out") (if (> (count ground.out) 0) (value-symbol ground.out) (value-nil))
              (value-keyword ":tuple-vars") (parser-string-vector-value ground.tuple-vars true)
              (value-keyword ":binding") (parser-binding-value ground.binding)
              (value-keyword ":collection") (value-bool ground.is-collection)
              (value-keyword ":tuple") (value-bool ground.is-tuple)
              (value-keyword ":relation") (value-bool ground.is-relation)
              (value-keyword ":width") (value-int (i64 ground.width))])))

(defn parser-grounds-value [grounds: []Ground] -> Value
  (let [out (make [dynamic]Value 0 (count grounds))]
    (for [ground grounds]
      (arr.push! out (parser-ground-value ground)))
    (Value {kind: .Vector items: out})))

(defn parser-not-group-value [group: Not-Group] -> Value
  (let [children (make [dynamic]Value 0 (count group.not-groups))]
    (defer (delete children))
    (for [child group.not-groups]
      (arr.push! children (parser-not-group-value child)))
    (value-map
      ([]Value [(value-keyword ":has-join") (value-bool group.has-join)
                (value-keyword ":join-vars") (parser-string-vector-value (slice group.join-vars 0) true)
                (value-keyword ":where") (parser-query-steps-value (slice group.steps 0))
                (value-keyword ":clauses") (parser-clauses-value (slice group.clauses 0))
                (value-keyword ":predicates") (parser-predicates-value group.predicates)
                (value-keyword ":functions") (parser-function-clauses-value group.function-clauses)
                (value-keyword ":not-groups") (value-vector (slice children 0))]))))

(defn parser-not-groups-value [groups: []Not-Group] -> Value
  (let [out (make [dynamic]Value 0 (count groups))]
    (for [group groups]
      (arr.push! out (parser-not-group-value group)))
    (Value {kind: .Vector items: out})))

(defn parser-or-group-value [group: Or-Group] -> Value
  (let [branches (make [dynamic]Value 0 (count group.branches))]
    (defer (delete branches))
    (for [branch group.branches]
      (arr.push! branches (parser-not-group-value branch)))
    (value-map
      ([]Value [(value-keyword ":has-join") (value-bool group.has-join)
                (value-keyword ":join-vars") (parser-string-vector-value (slice group.join-vars 0) true)
                (value-keyword ":branches") (value-vector (slice branches 0))]))))

(defn parser-or-groups-value [groups: []Or-Group] -> Value
  (let [out (make [dynamic]Value 0 (count groups))]
    (for [group groups]
      (arr.push! out (parser-or-group-value group)))
    (Value {kind: .Vector items: out})))

(defn parser-pull-spec-value [spec: Pull-Spec] -> Value
  (value-map
    ([]Value [(value-keyword ":attr") (value-keyword spec.a)
              (value-keyword ":nested-count") (value-int (i64 (count spec.pattern)))
              (value-keyword ":has-limit") (value-bool spec.has-limit)
              (value-keyword ":limit") (value-int (i64 spec.limit))
              (value-keyword ":has-default") (value-bool spec.has-default)
              (value-keyword ":has-alias") (value-bool spec.has-alias)
              (value-keyword ":alias") (if spec.has-alias (value-string spec.alias) (value-nil))
              (value-keyword ":has-xform") (value-bool spec.has-xform)
              (value-keyword ":xform") (if spec.has-xform (value-symbol spec.xform) (value-nil))
              (value-keyword ":has-recursion") (value-bool spec.has-recursion)
              (value-keyword ":recursion-depth") (value-int (i64 spec.recursion-depth))])))

(defn parser-pull-specs-value [specs: []Pull-Spec] -> Value
  (let [out (make [dynamic]Value 0 (count specs))]
    (for [spec specs]
      (arr.push! out (parser-pull-spec-value spec)))
    (Value {kind: .Vector items: out})))

(defn parser-pull-find-value [pull: Pull-Find] -> Value
  (value-map
    ([]Value [(value-keyword ":var") (value-symbol pull.var)
              (value-keyword ":source") (if pull.has-source (value-symbol pull.source) (value-nil))
              (value-keyword ":has-pattern-var") (value-bool pull.has-pattern-var)
              (value-keyword ":pattern-var") (if pull.has-pattern-var (value-symbol pull.pattern-var) (value-nil))
              (value-keyword ":attrs") (parser-string-vector-value pull.attrs false)
              (value-keyword ":pattern") (parser-pull-specs-value (slice pull.pattern 0))])))

(defn parser-pull-finds-value [pulls: []Pull-Find] -> Value
  (let [out (make [dynamic]Value 0 (count pulls))]
    (for [pull pulls]
      (arr.push! out (parser-pull-find-value pull)))
    (Value {kind: .Vector items: out})))

(defn parser-aggregate-find-value [aggregate: Aggregate-Find] -> Value
  (let [args (make [dynamic]Value 0 (count aggregate.args))]
    (defer (delete args))
    (for [arg aggregate.args]
      (arr.push! args (parser-term-value arg)))
    (value-map
      ([]Value [(value-keyword ":op") (value-symbol aggregate.op)
                (value-keyword ":var") (if (> (count aggregate.var) 0) (value-symbol aggregate.var) (value-nil))
                (value-keyword ":args") (value-vector (slice args 0))
                (value-keyword ":has-limit") (value-bool aggregate.has-limit)
                (value-keyword ":limit") (value-int (i64 aggregate.limit))
                (value-keyword ":has-limit-var") (value-bool aggregate.has-limit-var)
                (value-keyword ":limit-var") (if aggregate.has-limit-var (value-symbol aggregate.limit-var) (value-nil))
                (value-keyword ":has-function-var") (value-bool aggregate.has-function-var)
                (value-keyword ":function-var") (if aggregate.has-function-var (value-symbol aggregate.function-var) (value-nil))]))))

(defn parser-aggregate-finds-value [aggregates: []Aggregate-Find] -> Value
  (let [out (make [dynamic]Value 0 (count aggregates))]
    (for [aggregate aggregates]
      (arr.push! out (parser-aggregate-find-value aggregate)))
    (Value {kind: .Vector items: out})))

(defn parser-step-kind-value [kind: Query-Step-Kind] -> Value
  (case kind
    .Clause (value-keyword ":clause")
    .Predicate (value-keyword ":predicate")
    .Function (value-keyword ":function")
    .RuleCall (value-keyword ":rule-call")
    .GetElse (value-keyword ":get-else")
    .GetSome (value-keyword ":get-some")
    .Ground (value-keyword ":ground")
    .Not (value-keyword ":not")
    .Or (value-keyword ":or")
    :else (value-keyword ":unknown")))

(defn parser-query-step-value [step: Query-Step] -> Value
  (value-map
    ([]Value [(value-keyword ":kind") (parser-step-kind-value step.kind)
              (value-keyword ":index") (value-int (i64 step.index))])))

(defn parser-query-steps-value [steps: []Query-Step] -> Value
  (let [out (make [dynamic]Value 0 (count steps))]
    (for [step steps]
      (arr.push! out (parser-query-step-value step)))
    (Value {kind: .Vector items: out})))

(defn parser-rule-call-value [call: Rule-Call] -> Value
  (let [args (make [dynamic]Value 0 (count call.args))]
    (defer (delete args))
    (for [arg call.args]
      (arr.push! args (parser-term-value arg)))
    (value-map
      ([]Value [(value-keyword ":name") (value-symbol call.name)
                (value-keyword ":source") (if call.has-source (value-symbol call.source) (value-nil))
                (value-keyword ":args") (value-vector (slice args 0))]))))

(defn parser-rule-value [rule: Rule] -> Value
  (let [calls (make [dynamic]Value 0 (count rule.rule-calls))]
    (defer (delete calls))
    (for [call rule.rule-calls]
      (arr.push! calls (parser-rule-call-value call)))
    (value-map
      ([]Value [(value-keyword ":name") (value-symbol rule.name)
                (value-keyword ":required-param-count") (value-int (i64 rule.required-param-count))
                (value-keyword ":params") (parser-string-vector-value (slice rule.params 0) true)
                (value-keyword ":where") (parser-query-steps-value (slice rule.body-steps 0))
                (value-keyword ":clauses") (parser-clauses-value (slice rule.clauses 0))
                (value-keyword ":predicates") (parser-predicates-value rule.predicates)
                (value-keyword ":functions") (parser-function-clauses-value rule.function-clauses)
                (value-keyword ":rule-calls") (value-vector (slice calls 0))
                (value-keyword ":grounds") (parser-grounds-value (slice rule.grounds 0))
                (value-keyword ":get-elses") (parser-get-elses-value (slice rule.get-elses 0))
                (value-keyword ":get-somes") (parser-get-somes-value (slice rule.get-somes 0))
                (value-keyword ":not-groups") (parser-not-groups-value (slice rule.not-groups 0))
                (value-keyword ":or-groups") (parser-or-groups-value (slice rule.or-groups 0))]))))

(defn prepared-binding-value [prepared: Prepared-Binding] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
              (value-keyword ":error") (value-string prepared.error)
              (value-keyword ":binding") (if prepared.ok (parser-binding-value prepared.binding) (value-nil))])))

(defn prepared-in-value [prepared: Prepared-In] -> Value
  (let [bindings (make [dynamic]Value 0 (count prepared.bindings))]
    (defer (delete bindings))
    (for [binding prepared.bindings]
      (arr.push! bindings (parser-binding-value binding)))
    (value-map
      ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
                (value-keyword ":error") (value-string prepared.error)
                (value-keyword ":bindings") (value-vector (slice bindings 0))]))))

(defn prepared-with-value [prepared: Prepared-With] -> Value
  (value-map
    ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
              (value-keyword ":error") (value-string prepared.error)
              (value-keyword ":vars") (parser-string-vector-value (slice prepared.vars 0) true)])))

(defn prepared-rules-value [prepared: Prepared-Rules] -> Value
  (let [rules (make [dynamic]Value 0 (count prepared.rules))]
    (defer (delete rules))
    (for [rule prepared.rules]
      (arr.push! rules (parser-rule-value rule)))
    (value-map
      ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
                (value-keyword ":error") (value-string prepared.error)
                (value-keyword ":rules") (value-vector (slice rules 0))]))))

(defn parser-input-spec-kind-value [kind: Query-Input-Spec-Kind] -> Value
  (case kind
    .Scalar (value-keyword ":scalar")
    .Collection (value-keyword ":collection")
    .Tuple (value-keyword ":tuple")
    .Relation (value-keyword ":relation")
    .Ignore (value-keyword ":ignore")
    :else (value-keyword ":unknown")))

(defn parser-query-input-spec-value [spec: Query-Input-Spec] -> Value
  (value-map
    ([]Value [(value-keyword ":kind") (parser-input-spec-kind-value spec.kind)
              (value-keyword ":name") (if (> (count spec.name) 0) (value-symbol spec.name) (value-nil))])))

(defn prepared-query-value [prepared: Prepared-Query] -> Value
  (let [input-specs (make [dynamic]Value 0 (count prepared.query.input-specs))
        rule-calls (make [dynamic]Value 0 (count prepared.query.rule-calls))]
    (defer (delete input-specs))
    (defer (delete rule-calls))
    (for [spec prepared.query.input-specs]
      (arr.push! input-specs (parser-query-input-spec-value spec)))
    (for [call prepared.query.rule-calls]
      (arr.push! rule-calls (parser-rule-call-value call)))
    (value-map
      ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
                (value-keyword ":error") (value-string prepared.error)
                (value-keyword ":find") (parser-string-vector-value (slice prepared.query.find 0) true)
                (value-keyword ":with") (parser-string-vector-value (slice prepared.query.with 0) true)
                (value-keyword ":inputs") (parser-string-vector-value (slice prepared.query.inputs 0) true)
                (value-keyword ":input-specs") (value-vector (slice input-specs 0))
                (value-keyword ":rules-input") (value-bool prepared.query.has-rules-input)
                (value-keyword ":where") (parser-query-steps-value (slice prepared.query.where-steps 0))
                (value-keyword ":clauses") (parser-clauses-value (slice prepared.query.clauses 0))
                (value-keyword ":predicates") (parser-predicates-value prepared.query.predicates)
                (value-keyword ":functions") (parser-function-clauses-value prepared.query.function-clauses)
                (value-keyword ":rule-calls") (value-vector (slice rule-calls 0))
                (value-keyword ":grounds") (parser-grounds-value (slice prepared.query.grounds 0))
                (value-keyword ":get-elses") (parser-get-elses-value (slice prepared.query.get-elses 0))
                (value-keyword ":get-somes") (parser-get-somes-value (slice prepared.query.get-somes 0))
                (value-keyword ":not-groups") (parser-not-groups-value (slice prepared.query.not-groups 0))
                (value-keyword ":or-groups") (parser-or-groups-value (slice prepared.query.or-groups 0))
                (value-keyword ":pulls") (parser-pull-finds-value (slice prepared.query.pulls 0))
                (value-keyword ":aggregates") (parser-aggregate-finds-value (slice prepared.query.aggregates 0))
                (value-keyword ":rules-count") (value-int (i64 (count prepared.query.rules)))
                (value-keyword ":pull-count") (value-int (i64 (count prepared.query.pulls)))
                (value-keyword ":aggregate-count") (value-int (i64 (count prepared.query.aggregates)))]))))

(defn parser-tx-entity-value [data: Tx-Data] -> Value
  (cond
    data.has-tempid (value-string data.tempid)
    data.has-lookup-ref (lookup-ref-value data.lookup-attr data.lookup-value)
    data.has-ident (value-keyword data.ident)
    :else (value-entity data.e)))

(defn parser-tx-data-value [data: Tx-Data] -> Value
  (value-map
    ([]Value [(value-keyword ":op") (value-keyword data.op)
              (value-keyword ":e") (parser-tx-entity-value data)
              (value-keyword ":a") (if (> (count data.a) 0) (value-keyword data.a) (value-nil))
              (value-keyword ":v") data.v])))

(defn prepared-tx-data-value [prepared: Prepared-Tx-Data] -> Value
  (let [tx-data (make [dynamic]Value 0 (count prepared.tx-data))]
    (defer (delete tx-data))
    (for [data prepared.tx-data]
      (arr.push! tx-data (parser-tx-data-value data)))
    (value-map
      ([]Value [(value-keyword ":ok") (value-bool prepared.ok)
                (value-keyword ":error") (value-string prepared.error)
                (value-keyword ":tx-data") (value-vector (slice tx-data 0))]))))

(defn query-from-text-parts [find: []string, with: []string, inputs: []string, collection-inputs: []string, tuple-inputs: []Tuple-Input, relation-inputs: []Relation-Input, input-specs: []Query-Input-Spec, clauses: []Clause, predicates: []Predicate, function-clauses: []Function-Clause, rule-calls: []Rule-Call, get-elses: []Get-Else, get-somes: []Get-Some, grounds: []Ground, not-groups: []Not-Group, or-groups: []Or-Group, pulls: []Pull-Find, aggregates: []Aggregate-Find] -> Query
  (let [out (query find with inputs collection-inputs tuple-inputs relation-inputs clauses predicates function-clauses ([]Rule []) rule-calls get-elses get-somes grounds not-groups or-groups pulls aggregates)]
    (delete out.input-specs)
    (let [owned-input-specs (arr.into [dynamic]Query-Input-Spec input-specs)]
      (set! out.input-specs owned-input-specs))
    out))

(defn edn-section-has-rules-input? [doc: EDN-Doc, section: int] -> bool
  (when (= section -1)
    (return false))
  (let [first (if (= doc.nodes[section].kind .Vector) doc.nodes[section].first-child section)]
    (for [cursor (edn-siblings doc first)]
      (when (edn-symbol-text? doc cursor "%")
        (return true))))
  false)

(defn db-source-name? [sources: []DB-Source, name: string] -> bool
  (when (= name "$")
    (return true))
  (for [source sources]
    (when (= source.name name)
      (return true)))
  false)

(defn edn-input-binding-from-node [doc: EDN-Doc, node-index: int] -> [binding: Input-Binding, ok: bool, error: string]
  (when (= node-index -1)
    (return (input-binding-none) false "missing :in binding"))
  (let [node doc.nodes[node-index]]
    (cond
      (edn-var? doc node-index)
        (return (input-binding-var node.text) true "")
      (and (= node.kind .Symbol) (= node.text "_"))
        (return (input-binding-ignore) true "")
      (= node.kind .Vector)
        (let [first-node node.first-child
              second-node (if (= first-node -1) -1 doc.nodes[first-node].next-sibling)]
          (when (= first-node -1)
            (return (input-binding-none) false "empty :in binding vector"))
          (when (and (not (= second-node -1))
                     (= doc.nodes[second-node].next-sibling -1)
                     (edn-symbol-text? doc second-node "..."))
            (let [[item item-ok item-error] (edn-input-binding-from-node doc first-node)]
              (if item-ok
                (return (input-binding-collection item) true "")
                (return item false item-error))))
          (let [items (make [dynamic]Input-Binding) :defer]
            (for [child (edn-siblings doc first-node)]
              (let [[item item-ok item-error] (edn-input-binding-from-node doc child)]
                (when (not item-ok)
                  (return item false item-error))
                (arr.push! items item)))
            (return (input-binding-tuple (slice items 0)) true "")))
      :else (return (input-binding-none) false "unsupported :in binding form"))))

(defn prepared-binding-error [error: string] -> Prepared-Binding
  (Prepared-Binding {ok: false error: error binding: (input-binding-none)}))

(defn prepared-in-error [error: string] -> Prepared-In
  (Prepared-In {ok: false error: error bindings: (make [dynamic]Input-Binding)}))

(defn prepared-with-error [error: string] -> Prepared-With
  (Prepared-With {ok: false error: error vars: (make [dynamic]string)}))

(defn edn-in-binding-from-node [doc: EDN-Doc, node-index: int] -> [binding: Input-Binding, ok: bool, error: string]
  (when (= node-index -1)
    (return (input-binding-none) false "missing :in binding"))
  (let [node doc.nodes[node-index]]
    (if (and (= node.kind .Symbol)
             (or (= node.text "%")
                 (strings.has_prefix node.text "$")))
      (return (input-binding-var node.text) true "")
      (edn-input-binding-from-node doc node-index))))

(defn parse-binding-text [text: string] -> Prepared-Binding
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (prepared-binding-error read-error)))
    (let [[binding binding-ok binding-error] (edn-input-binding-from-node doc doc.root)]
      (delete doc.nodes)
      (if binding-ok
        (Prepared-Binding {ok: true error: "" binding: binding})
        (prepared-binding-error binding-error)))))

(defn parse-in-text [text: string] -> Prepared-In
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (prepared-in-error read-error)))
    (when (or (= doc.root -1)
              (and (not (= doc.nodes[doc.root].kind .Vector))
                   (not (= doc.nodes[doc.root].kind .List))))
      (delete doc.nodes)
      (return (prepared-in-error "Cannot parse :in clause")))
    (let [bindings (make [dynamic]Input-Binding)
          cursor doc.nodes[doc.root].first-child]
      (while (not (= cursor -1))
        (let [[binding binding-ok binding-error] (edn-in-binding-from-node doc cursor)]
          (when (not binding-ok)
            (delete bindings)
            (delete doc.nodes)
            (return (prepared-in-error binding-error)))
          (arr.push! bindings binding))
        (set! cursor doc.nodes[cursor].next-sibling))
      (delete doc.nodes)
      (Prepared-In {ok: true error: "" bindings: bindings}))))

(defn parse-with-text [text: string] -> Prepared-With
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (prepared-with-error read-error)))
    (when (or (= doc.root -1)
              (and (not (= doc.nodes[doc.root].kind .Vector))
                   (not (= doc.nodes[doc.root].kind .List))))
      (delete doc.nodes)
      (return (prepared-with-error "Cannot parse :with clause")))
    (let [vars (make [dynamic]string)
          cursor doc.nodes[doc.root].first-child]
      (while (not (= cursor -1))
        (when (not (edn-var? doc cursor))
          (delete vars)
          (delete doc.nodes)
          (return (prepared-with-error "Cannot parse :with clause")))
        (arr.push! vars doc.nodes[cursor].text)
        (set! cursor doc.nodes[cursor].next-sibling))
      (delete doc.nodes)
      (Prepared-With {ok: true error: "" vars: vars}))))

(defn append-edn-input-spec! [inputs: ^[dynamic]string, collection-inputs: ^[dynamic]string, tuple-inputs: ^[dynamic]Tuple-Input, relation-inputs: ^[dynamic]Relation-Input, input-specs: ^[dynamic]Query-Input-Spec, doc: EDN-Doc, node-index: int, db-sources: []DB-Source] -> [ok: bool, error: string]
  (let [node doc.nodes[node-index]]
    (cond
      (and (= node.kind .Symbol) (db-source-name? db-sources node.text))
        (return true "")
      (and (= node.kind .Symbol) (= node.text "%"))
        (return true "")
      (and (= node.kind .Symbol) (= node.text "_"))
        (do
          (arr.push! input-specs^ (Query-Input-Spec {kind: .Ignore}))
          (return true ""))
      (and (= node.kind .Symbol) (strings.has_prefix node.text "$"))
        (do
          (arr.push! inputs^ node.text)
          (arr.push! input-specs^ (Query-Input-Spec {kind: .Scalar name: node.text}))
          (return true ""))
      (or (edn-var? doc node-index)
          (edn-named-input-symbol? doc node-index))
        (do
          (arr.push! inputs^ node.text)
          (arr.push! input-specs^ (Query-Input-Spec {kind: .Scalar name: node.text}))
          (return true ""))
      (= node.kind .Vector)
        (let [first-node node.first-child
              second-node (if (= first-node -1) -1 doc.nodes[first-node].next-sibling)]
          (cond
            (= first-node -1)
              (return false "empty :in vector spec")
            (and (edn-var? doc first-node) (edn-symbol-text? doc second-node "..."))
              (do
                (arr.push! collection-inputs^ doc.nodes[first-node].text)
                (arr.push! input-specs^ (Query-Input-Spec {kind: .Collection name: doc.nodes[first-node].text}))
                (return true ""))
            (= doc.nodes[first-node].kind .Vector)
              (do
                (let [[parsed parsed-ok parsed-error] (edn-input-binding-from-node doc node-index)]
                  (when (not parsed-ok)
                    (return false parsed-error))
                  (let [row-binding (if (= parsed.kind .Collection)
                                      parsed.items[0]
                                      (if (and (= parsed.kind .Tuple) (= (count parsed.items) 1))
                                        parsed.items[0]
                                        parsed))
                        vars (input-binding-relation-vars row-binding)
                        relation-binding (if (= parsed.kind .Collection)
                                           parsed
                                           (input-binding-collection row-binding))
                        relation (Relation-Input {vars: (slice vars 0) binding: relation-binding})]
                    (arr.push! relation-inputs^ relation)
                    (arr.push! input-specs^ (Query-Input-Spec {kind: .Relation relation: relation}))))
                (return true ""))
            :else
              (do
                (let [[binding binding-ok binding-error] (edn-input-binding-from-node doc node-index)]
                  (when (not binding-ok)
                    (return false binding-error))
                  (let [vars (input-binding-vars binding)
                        tuple (Tuple-Input {vars: (slice vars 0) binding: binding})]
                    (arr.push! tuple-inputs^ tuple)
                    (arr.push! input-specs^ (Query-Input-Spec {kind: .Tuple tuple: tuple}))))
                (return true ""))))
      :else (return false "query text :in currently supports vars, [?x ...], [?x ?y], and [[?x ?y]]"))))

(defn edn-pull-attr-source [doc: EDN-Doc, node-index: int] -> [attr: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Keyword) (return node.text true)
      (= node.kind .String) (return node.text true)
      (and (= node.kind .Symbol) (= node.text "*")) (return "*" true)
      :else (return "" false))))

(defn edn-pull-alias-source [doc: EDN-Doc, node-index: int] -> [alias: string, kind: Key-Kind, ok: bool]
  (when (= node-index -1)
    (return "" .String false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Keyword (return node.text .Keyword true)
      .String (return node.text .String true)
      .Symbol (return node.text .Symbol true)
      :else (return "" .String false))))

(defn edn-pull-xform-source [doc: EDN-Doc, node-index: int] -> [xform: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Keyword (if (strings.has_prefix node.text ":")
                 (return (slice node.text 1) true)
                 (return node.text true))
      .Symbol (return node.text true)
      .String (return node.text true)
      :else (return "" false))))

(defn edn-pull-limit-value [doc: EDN-Doc, node-index: int] -> [limit: int, ok: bool]
  (when (= node-index -1)
    (return 0 false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Nil (return -1 true)
      .Int (return (int node.int-value) true)
      :else (return 0 false))))

(defn edn-pull-option-name? [doc: EDN-Doc, node-index: int, name: string] -> bool
  (when (= node-index -1)
    (return false))
  (let [text doc.nodes[node-index].text]
    (or (= text name) (= text (strings.concatenate ([]string [":" name]))))))

(defn edn-pull-apply-option [base: Pull-Spec, doc: EDN-Doc, option-node: int, value-node: int] -> [spec: Pull-Spec, ok: bool]
  (when (edn-pull-option-name? doc option-node "default")
    (let [[value value-ok _] (edn-value-from-node doc value-node)]
      (when (not value-ok)
        (return base false))
      (return (pull-spec-with-default base value) true)))
  (when (edn-pull-option-name? doc option-node "as")
    (let [[alias alias-kind alias-ok] (edn-pull-alias-source doc value-node)]
      (when (not alias-ok)
        (return base false))
      (return (pull-spec-with-alias-kind base alias alias-kind) true)))
  (when (edn-pull-option-name? doc option-node "xform")
    (let [[xform xform-ok] (edn-pull-xform-source doc value-node)]
      (when (not xform-ok)
        (return base false))
      (return (pull-spec-with-xform base xform) true)))
  (when (edn-pull-option-name? doc option-node "limit")
    (let [[limit limit-ok] (edn-pull-limit-value doc value-node)]
      (when (not limit-ok)
        (return base false))
      (return (pull-spec-with-limit base limit) true)))
  (return base false))

(defn edn-pull-recursion-depth [doc: EDN-Doc, node-index: int] -> [depth: int, ok: bool]
  (when (= node-index -1)
    (return 0 false))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Int (return (int node.int-value) true)
      .Symbol (if (= node.text "...")
                (return 2147483647 true)
                (return 0 false))
      .String (if (= node.text "...")
                (return 2147483647 true)
                (return 0 false))
      :else (return 0 false))))

(defn edn-pull-spec-node [doc: EDN-Doc, node-index: int] -> [spec: Pull-Spec, ok: bool]
  (let [[attr attr-ok] (edn-pull-attr-source doc node-index)]
    (when attr-ok
      (return (pull-spec attr ([]Pull-Spec [])) true)))
  (when (or (= doc.nodes[node-index].kind .Vector)
            (= doc.nodes[node-index].kind .List))
    (let [head (edn-child-at doc node-index 0)]
      (when (= head -1)
        (return (Pull-Spec {}) false))
      (when (or (edn-pull-option-name? doc head "limit")
                (edn-pull-option-name? doc head "default")
                (edn-pull-option-name? doc head "xform"))
        (when (not (= doc.nodes[node-index].child-count 3))
          (return (Pull-Spec {}) false))
        (let [attr-node (edn-child-at doc node-index 1)
              value-node (edn-child-at doc node-index 2)
              [base base-ok] (edn-pull-spec-node doc attr-node)]
          (when (not base-ok)
            (return base false))
          (return (edn-pull-apply-option base doc head value-node))))
      (let [[base base-ok] (edn-pull-spec-node doc head)]
        (when (not base-ok)
          (return base false))
        (let [spec base
              option-node doc.nodes[head].next-sibling]
          (while (not (= option-node -1))
            (let [value-node doc.nodes[option-node].next-sibling]
              (when (= value-node -1)
                (return spec false))
              (let [[next next-ok] (edn-pull-apply-option spec doc option-node value-node)]
                (when (not next-ok)
                  (return next false))
                (set! spec next)
                (set! option-node doc.nodes[value-node].next-sibling))))
          (return spec true)))))
  (return (Pull-Spec {}) false))

(defn edn-pull-specs [doc: EDN-Doc, vector-node: int] -> [pattern: [dynamic]Pull-Spec, ok: bool, error: string]
  (when (or (= vector-node -1)
            (and (not (= doc.nodes[vector-node].kind .Vector))
                 (not (= doc.nodes[vector-node].kind .List))))
    (return (make [dynamic]Pull-Spec) false "pull pattern must be a vector or list"))
  (let [out (make [dynamic]Pull-Spec)]
    (for [child (edn-children doc vector-node)]
      (if (= doc.nodes[child].kind .Map)
        (let [entry doc.nodes[child].first-child]
          (while (not (= entry -1))
            (let [pattern-node doc.nodes[entry].next-sibling
                  [base base-ok] (edn-pull-spec-node doc entry)]
              (when (not base-ok)
                (return out false "invalid pull map key"))
              (when (= pattern-node -1)
                (return out false "pull map entry expects a nested pattern or recursion depth"))
              (if (or (= doc.nodes[pattern-node].kind .Vector)
                      (= doc.nodes[pattern-node].kind .List))
                (let [[nested nested-ok nested-error] (edn-pull-specs doc pattern-node)]
                  (when (not nested-ok)
                    (return out false nested-error))
                  (arr.push! out (pull-spec-with-pattern base (slice nested 0))))
                (let [[depth depth-ok] (edn-pull-recursion-depth doc pattern-node)]
                  (when (not depth-ok)
                    (return out false "pull map value must be a pattern vector/list or recursion depth"))
                  (arr.push! out (pull-spec-with-recursion base depth))))
              (set! entry doc.nodes[pattern-node].next-sibling))))
        (let [[spec spec-ok] (edn-pull-spec-node doc child)]
          (when (not spec-ok)
            (return out false "invalid pull pattern spec"))
          (arr.push! out spec))))
    (return out true "")))

(defn append-edn-pull-find! [out: ^[dynamic]Pull-Find, doc: EDN-Doc, form: int] -> [ok: bool, error: string]
  (let [head doc.nodes[form].first-child
        first-arg doc.nodes[head].next-sibling]
    (when (= first-arg -1)
      (return false "pull find expects entity var and pattern"))
    (let [var-node first-arg
          pattern-node doc.nodes[var-node].next-sibling
          source ""
          has-source false]
      (when (edn-source-var? doc first-arg)
        (set! source doc.nodes[first-arg].text)
        (set! has-source true)
        (set! var-node doc.nodes[first-arg].next-sibling)
        (set! pattern-node doc.nodes[var-node].next-sibling))
      (when (or (= var-node -1) (not (edn-var? doc var-node)))
        (return false "pull find expects an entity variable"))
      (when (or (edn-var? doc pattern-node)
                (edn-named-input-symbol? doc pattern-node))
        (arr.push! out^
          (Pull-Find {var: doc.nodes[var-node].text
                      source: source
                      has-source: has-source
                      has-pattern-var: true
                      pattern-var: doc.nodes[pattern-node].text
                      attrs: ([]string [])
                      pattern: (make [dynamic]Pull-Spec)}))
        (return true ""))
      (when (or (= pattern-node -1) (not (= doc.nodes[pattern-node].kind .Vector)))
        (return false "pull find expects a literal vector pattern or pattern variable"))
      (let [[pattern pattern-ok pattern-error] (edn-pull-specs doc pattern-node)]
        (when (not pattern-ok)
          (return false pattern-error))
        (arr.push! out^
          (Pull-Find {var: doc.nodes[var-node].text
                      source: source
                      has-source: has-source
                      has-pattern-var: false
                      pattern-var: ""
                      attrs: ([]string [])
                      pattern: pattern}))
        (return true "")))))

(defn parse-pull-pattern-text [text: string] -> [pattern: [dynamic]Pull-Spec, ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (defer (delete doc.nodes))
    (when (not read-ok)
      (return (make [dynamic]Pull-Spec) false read-error))
    (when (or (= doc.root -1)
              (not (= doc.nodes[doc.root].kind .Vector)))
      (return (make [dynamic]Pull-Spec) false "pull text pattern must be an EDN vector"))
    (let [[out out-ok out-error] (edn-pull-specs doc doc.root)]
      (return out out-ok out-error))))

(defn prepare-pull-pattern-text [text: string] -> Prepared-Pull-Pattern
  (let [[pattern ok error] (parse-pull-pattern-text text)]
    (Prepared-Pull-Pattern {ok: ok error: error pattern: pattern})))

(defn pull-prepared-with-fns [db: DB, prepared: Prepared-Pull-Pattern, entity: u64, registry: []Native-Query-Fn] -> Pull-Result
  (if prepared.ok
    (pull-pattern-spec-with-fns db entity (slice prepared.pattern 0) registry)
    (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))

(defn pull-prepared [db: DB, prepared: Prepared-Pull-Pattern, entity: u64] -> Pull-Result
  (pull-prepared-with-fns db prepared entity ([]Native-Query-Fn [])))

(defn pull-prepared-value-with-fns [db: DB, prepared: Prepared-Pull-Pattern, entity: u64, registry: []Native-Query-Fn] -> Value
  (pull-result-value db (pull-prepared-with-fns db prepared entity registry)))

(defn pull-prepared-value [db: DB, prepared: Prepared-Pull-Pattern, entity: u64] -> Value
  (pull-prepared-value-with-fns db prepared entity ([]Native-Query-Fn [])))

(defn pull-prepared-lookup-ref-with-fns [db: DB, prepared: Prepared-Pull-Pattern, attr: string, value: Value, registry: []Native-Query-Fn] -> Pull-Result
  (if prepared.ok
    (pull-pattern-lookup-ref-with-fns db attr value (slice prepared.pattern 0) registry)
    (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)})))

(defn pull-prepared-lookup-ref [db: DB, prepared: Prepared-Pull-Pattern, attr: string, value: Value] -> Pull-Result
  (pull-prepared-lookup-ref-with-fns db prepared attr value ([]Native-Query-Fn [])))

(defn pull-prepared-lookup-ref-value-with-fns [db: DB, prepared: Prepared-Pull-Pattern, attr: string, value: Value, registry: []Native-Query-Fn] -> Value
  (pull-result-value db (pull-prepared-lookup-ref-with-fns db prepared attr value registry)))

(defn pull-prepared-lookup-ref-value [db: DB, prepared: Prepared-Pull-Pattern, attr: string, value: Value] -> Value
  (pull-prepared-lookup-ref-value-with-fns db prepared attr value ([]Native-Query-Fn [])))

(defn pull-many-prepared-with-fns [db: DB, prepared: Prepared-Pull-Pattern, entities: []u64, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (if prepared.ok
    (pull-many-pattern-spec-with-fns db entities (slice prepared.pattern 0) registry)
    (make [dynamic]Pull-Result)))

(defn pull-many-prepared [db: DB, prepared: Prepared-Pull-Pattern, entities: []u64] -> [dynamic]Pull-Result
  (pull-many-prepared-with-fns db prepared entities ([]Native-Query-Fn [])))

(defn pull-many-prepared-value-with-fns [db: DB, prepared: Prepared-Pull-Pattern, entities: []u64, registry: []Native-Query-Fn] -> Value
  (let [results (pull-many-prepared-with-fns db prepared entities registry)]
    (defer (delete results))
    (pull-many-results-value db (slice results 0))))

(defn pull-many-prepared-value [db: DB, prepared: Prepared-Pull-Pattern, entities: []u64] -> Value
  (pull-many-prepared-value-with-fns db prepared entities ([]Native-Query-Fn [])))

(defn pull-many-prepared-lookup-refs-with-fns [db: DB, prepared: Prepared-Pull-Pattern, attrs: []string, values: []Value, registry: []Native-Query-Fn] -> [dynamic]Pull-Result
  (if prepared.ok
    (pull-many-pattern-lookup-refs-with-fns db attrs values (slice prepared.pattern 0) registry)
    (make [dynamic]Pull-Result)))

(defn pull-many-prepared-lookup-refs [db: DB, prepared: Prepared-Pull-Pattern, attrs: []string, values: []Value] -> [dynamic]Pull-Result
  (pull-many-prepared-lookup-refs-with-fns db prepared attrs values ([]Native-Query-Fn [])))

(defn pull-many-prepared-lookup-refs-value-with-fns [db: DB, prepared: Prepared-Pull-Pattern, attrs: []string, values: []Value, registry: []Native-Query-Fn] -> Value
  (let [results (pull-many-prepared-lookup-refs-with-fns db prepared attrs values registry)]
    (defer (delete results))
    (pull-many-results-value db (slice results 0))))

(defn pull-many-prepared-lookup-refs-value [db: DB, prepared: Prepared-Pull-Pattern, attrs: []string, values: []Value] -> Value
  (pull-many-prepared-lookup-refs-value-with-fns db prepared attrs values ([]Native-Query-Fn [])))

(defn pull-text-with-fns [db: DB, pattern-text: string, entity: u64, registry: []Native-Query-Fn] -> Pull-Result
  (let [[pattern ok _] (parse-pull-pattern-text pattern-text)]
    (defer (delete pattern))
    (if ok
      (pull-pattern-spec-with-fns db entity (slice pattern 0) registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-text [db: DB, pattern-text: string, entity: u64] -> Pull-Result
  (pull-text-with-fns db pattern-text entity ([]Native-Query-Fn [])))

(defn pull-text-value-with-fns [db: DB, pattern-text: string, entity: u64, registry: []Native-Query-Fn] -> Value
  (pull-result-value db (pull-text-with-fns db pattern-text entity registry)))

(defn pull-text-value [db: DB, pattern-text: string, entity: u64] -> Value
