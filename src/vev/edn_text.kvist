(defn q-text-pull-scalar [db: DB, text: string] -> [pull: Pull-Result, ok: bool]
  (return (result-pull-scalar (q-text db text))))

(defn q-text-pull-scalar-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [pull: Pull-Result, ok: bool]
