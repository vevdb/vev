(defn q-text [db: DB, text: string] -> Result-Set
  (let [query-value (empty-query)
        [ok error] (parse-query-text! (addr query-value) text)]
    (defer (delete-query-shallow query-value))
    (when ok
      (return (q-query db query-value)))
    (return (result-set-error error))))

(defn q-text-value [db: DB, text: string] -> Value
  (result-set-value db (q-text db text)))

(defn q-text-with-fns [db: DB, text: string, registry: []Native-Query-Fn] -> Result-Set
