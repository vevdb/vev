(defn query-input-specs-for-query [query-value: Query] -> [dynamic]Query-Input-Spec
  (let [specs (make [dynamic]Query-Input-Spec)]
    (if (> (count query-value.input-specs) 0)
      (for [spec query-value.input-specs]
        (arr.push! specs spec))
      (append-legacy-query-input-specs! (addr specs) query-value))
    specs))

(defn relation-input-value-width [relation: Relation-Input] -> int
  (count relation.vars))

(defn query-input-relation-from-value [relation: Relation-Input, value: Value] -> Query-Input
  (cond
    (= value.kind .Map) (query-input-scalar value)
    (not (= value.kind .Vector)) (query-input-scalar value)
    (not (= relation.binding.kind .None)) (query-input-collection (slice value.items 0))
    :else
      (let [width (relation-input-value-width relation)
            flat (make [dynamic]Value)]
        (for [row value.items]
          (if (= row.kind .Vector)
            (for [item row.items]
              (arr.push! flat item))
            (arr.push! flat row)))
        (query-input-relation (slice flat 0) width))))

(defn query-input-from-value-for-spec [spec: Query-Input-Spec, value: Value] -> Query-Input
  (case spec.kind
    .Collection
      (if (= value.kind .Vector)
        (query-input-collection (slice value.items 0))
        (query-input-scalar value))
    .Tuple
      (if (= value.kind .Vector)
        (query-input-collection (slice value.items 0))
        (query-input-scalar value))
    .Relation (query-input-relation-from-value spec.relation value)
    .Ignore (query-input-scalar (value-nil))
    :else (query-input-scalar value)))

(defn query-input-spec-pull-pattern? [query-value: Query, spec: Query-Input-Spec] -> bool
  (when (not (= spec.kind .Scalar))
    (return false))
  (for [pull-find query-value.pulls]
    (when (and pull-find.has-pattern-var
               (= pull-find.pattern-var spec.name))
      (return true)))
  false)

(defn pull-spec-owned [spec: Pull-Spec] -> Pull-Spec
  (let [pattern (make [dynamic]Pull-Spec 0 (count spec.pattern))]
    (for [child spec.pattern]
      (arr.push! pattern (pull-spec-owned child)))
    (Pull-Spec {a: (string-owned spec.a)
                pattern: pattern
                limit: spec.limit
                has-limit: spec.has-limit
                has-default: spec.has-default
                default-value: (value-owned spec.default-value)
                has-alias: spec.has-alias
                alias: (string-owned spec.alias)
                alias-kind: spec.alias-kind
                has-xform: spec.has-xform
                xform: (string-owned spec.xform)
                has-recursion: spec.has-recursion
                recursion-depth: spec.recursion-depth})))

(defn pull-pattern-owned [pattern: []Pull-Spec] -> [dynamic]Pull-Spec
  (let [out (make [dynamic]Pull-Spec 0 (count pattern))]
    (for [spec pattern]
      (arr.push! out (pull-spec-owned spec)))
    out))

(defn query-input-pull-pattern-from-node [doc: EDN-Doc, node-index: int] -> [input: Query-Input, ok: bool, error: string]
  (when (or (= node-index -1) (not (= doc.nodes[node-index].kind .Vector)))
    (return (query-input-scalar (value-nil)) false "pull pattern input must be an EDN vector"))
  (let [[pattern pattern-ok pattern-error] (edn-pull-specs doc node-index)]
    (when (not pattern-ok)
      (return (query-input-scalar (value-nil)) false pattern-error))
    (let [owned (pull-pattern-owned (slice pattern 0))]
      (return (query-input-pull-pattern-owned owned) true ""))))

(defn parse-query-inputs-text-for-query [query-value: Query, text: string] -> [inputs: [dynamic]Query-Input, ok: bool, error: string]
  (let [out (make [dynamic]Query-Input)
        doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return out false read-error))
    (when (or (= doc.root -1) (not (= doc.nodes[doc.root].kind .Vector)))
      (delete doc.nodes)
      (return out false "query inputs must be an EDN vector"))
    (let [specs (query-input-specs-for-query query-value) :defer
          cursor doc.nodes[doc.root].first-child
          index 0]
      (while (not (= cursor -1))
        (let [[value value-ok value-error] (edn-value-from-node doc cursor)]
          (when (not value-ok)
            (delete doc.nodes)
            (return out false value-error))
          (if (< index (count specs))
            (if (query-input-spec-pull-pattern? query-value specs[index])
              (let [[input input-ok input-error] (query-input-pull-pattern-from-node doc cursor)]
                (when (not input-ok)
                  (delete doc.nodes)
                  (return out false input-error))
                (arr.push! out input))
              (arr.push! out (query-input-from-value-for-spec specs[index] value)))
            (arr.push! out (query-input-scalar value))))
        (set! index (+ index 1))
        (set! cursor doc.nodes[cursor].next-sibling)))
    (delete doc.nodes)
    (return out true "")))

(defn q-text-value-with-input-text [db: DB, text: string, inputs-text: string] -> Value
  (let [query-value (empty-query)
        [query-ok query-error] (parse-query-text! (addr query-value) text)]
    (defer (delete-query-shallow query-value))
    (when (not query-ok)
      (return (result-set-value db (result-set-error query-error))))
    (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query query-value inputs-text)]
      (when (not input-ok)
        (return (result-set-value db (result-set-error input-error))))
      (result-set-value db (q-query-with-inputs db query-value (slice inputs 0))))))

(defn q-prepared-with-input-text [db: DB, prepared: Prepared-Query, inputs-text: string] -> Result-Set
  (when (not prepared.ok)
    (return (result-set-error prepared.error)))
  (let [[inputs input-ok input-error] (parse-query-inputs-text-for-query prepared.query inputs-text)]
    (when (not input-ok)
      (return (result-set-error input-error)))
    (q-prepared-with-inputs db prepared (slice inputs 0))))

(defn q-prepared-value-with-input-text [db: DB, prepared: Prepared-Query, inputs-text: string] -> Value
  (result-set-value db (q-prepared-with-input-text db prepared inputs-text)))

(defn append-edn-return-keys! [out: ^[dynamic]string, doc: EDN-Doc, marker: string] -> bool
  (when (and (not (= doc.root -1)) (= doc.nodes[doc.root].kind .Map))
    (let [section (edn-map-value-node doc doc.root marker)]
      (when (= section -1)
        (return false))
      (if (= doc.nodes[section].kind .Vector)
        (let [cursor doc.nodes[section].first-child]
          (while (not (= cursor -1))
            (let [node doc.nodes[cursor]]
              (case node.kind
                .Symbol (arr.push! out^ node.text)
                .Keyword (arr.push! out^ node.text)
                .String (arr.push! out^ node.text)
                :else (return false)))
            (set! cursor doc.nodes[cursor].next-sibling))
          (return true))
        (let [node doc.nodes[section]]
          (case node.kind
            .Symbol (arr.push! out^ node.text)
            .Keyword (arr.push! out^ node.text)
            .String (arr.push! out^ node.text)
            :else (return false))
          (return true)))))
  (let [cursor (edn-child-at doc doc.root 1)]
    (while (not (= cursor -1))
      (when (edn-keyword-text? doc cursor marker)
        (set! cursor doc.nodes[cursor].next-sibling)
        (while (and (not (= cursor -1))
                    (not (edn-keyword-text? doc cursor ":in"))
                    (not (edn-keyword-text? doc cursor ":where")))
          (let [node doc.nodes[cursor]]
            (case node.kind
              .Symbol (arr.push! out^ node.text)
              .Keyword (arr.push! out^ node.text)
              .String (arr.push! out^ node.text)
              :else (return false)))
          (set! cursor doc.nodes[cursor].next-sibling))
        (return true))
      (set! cursor doc.nodes[cursor].next-sibling))
    false))

(defn query-text-return-keys [text: string, marker: string] -> [dynamic]string
  (let [out (make [dynamic]string)
        doc (empty-edn-doc)
        keys-ok false
        [read-ok _] (read-edn-text! (addr doc) text)]
    (when read-ok
      (set! keys-ok (append-edn-return-keys! (addr out) doc marker)))
    (delete doc.nodes)
    out))

(defn q-text-keys [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":keys") :defer]
    (return (result-keys (q-text db text) .Keyword (slice keys 0)))))

(defn q-text-strs [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":strs") :defer]
    (return (result-keys (q-text db text) .String (slice keys 0)))))

(defn q-text-syms [db: DB, text: string] -> [dynamic]Keyed-Row
  (let [keys (query-text-return-keys text ":syms") :defer]
    (return (result-keys (q-text db text) .Symbol (slice keys 0)))))

(defn edn-attr-text [doc: EDN-Doc, node-index: int] -> [attr: string, ok: bool]
  (when (= node-index -1)
    (return "" false))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Keyword) (return node.text true)
      (= node.kind .String) (return node.text true)
      :else (return "" false))))

(defn edn-value-from-node [doc: EDN-Doc, node-index: int] -> [value: Value, ok: bool, error: string]
  (when (= node-index -1)
    (return (Value {}) false "expected EDN value"))
  (let [node doc.nodes[node-index]]
    (case node.kind
      .Nil (return (value-nil) true "")
      .Bool (return (value-bool node.bool-value) true "")
      .Int (return (value-int node.int-value) true "")
      .Float (return (value-float node.float-value) true "")
      .String (return (value-string node.text) true "")
      .Symbol (return (value-symbol node.text) true "")
      .Keyword (return (value-keyword node.text) true "")
      .Uuid (return (value-uuid node.text) true "")
      .Vector (let [items (make [dynamic]Value) :defer]
                (for [child (edn-children doc node-index)]
                  (let [[item item-ok item-error] (edn-value-from-node doc child)]
                    (when (not item-ok)
                      (for [parsed items]
                        (delete-value-containers-shallow parsed))
                      (return (Value {}) false item-error))
                    (arr.push! items item)))
                (return (value-vector (slice items 0)) true ""))
      .Set (let [items (make [dynamic]Value) :defer]
             (for [child (edn-children doc node-index)]
               (let [[item item-ok item-error] (edn-value-from-node doc child)]
                 (when (not item-ok)
                   (for [parsed items]
                     (delete-value-containers-shallow parsed))
                   (return (Value {}) false item-error))
                 (arr.push! items item)))
             (return (value-vector (slice items 0)) true ""))
      .Map (let [items (make [dynamic]Value) :defer]
             (for [entry (edn-child-pairs doc node-index)]
               (when (= entry.value -1)
                 (for [parsed items]
                   (delete-value-containers-shallow parsed))
                 (return (Value {}) false "EDN map value missing"))
               (let [[key key-ok key-error] (edn-value-from-node doc entry.key)]
                 (when (not key-ok)
                   (for [parsed items]
                     (delete-value-containers-shallow parsed))
                   (return (Value {}) false key-error))
                 (let [[value value-ok value-error] (edn-value-from-node doc entry.value)]
                   (when (not value-ok)
                     (delete-value-containers-shallow key)
                     (for [parsed items]
                       (delete-value-containers-shallow parsed))
                     (return (Value {}) false value-error))
                   (arr.push! items key)
                   (arr.push! items value))))
             (return (value-map (slice items 0)) true ""))
      :else (return (Value {}) false "unsupported EDN value"))))

(defn edn-escaped-string-text [text: string] -> string
  (let [builder (kstr.builder)
        index 0
        n (kstr.count text)]
    (defer (kstr.destroy! (addr builder)))
    (kstr.write! (addr builder) "\"")
    (while (< index n)
      (let [ch (kstr.get text index)]
        (cond
          (= ch 34) (kstr.write! (addr builder) "\\\"")
          (= ch 92) (kstr.write! (addr builder) "\\\\")
          :else (kstr.write! (addr builder) (kstr.slice text index (+ index 1)))))
      (set! index (+ index 1)))
    (kstr.write! (addr builder) "\"")
    (kstr.finish (addr builder))))

(defn serializable-float-text [value: f64] -> string
  (cond
    (math.is_nan value) (string-owned "[:vev/float \"NaN\"]")
    (math.is_inf value 1) (string-owned "[:vev/float \"Inf\"]")
    (math.is_inf value -1) (string-owned "[:vev/float \"-Inf\"]")
    :else (string-owned (fmt.tprintf "[:vev/float \"%v\"]" value))))

(defn serializable-float-from-text [text: string] -> [value: f64, ok: bool]
  (cond
    (= text "NaN") (return (math.nan_f64) true)
    (or (= text "Inf") (= text "+Inf")) (return (math.inf_f64 1) true)
    (= text "-Inf") (return (math.inf_f64 -1) true)
    :else (strconv.parse_f64 text)))

(defn value-serializable-text [value: Value] -> string
  (case value.kind
    .Nil (string-owned "nil")
    .Bool (string-owned (if value.bool-value "true" "false"))
    .Int (string-owned (fmt.tprintf "%d" value.int-value))
    .Float (serializable-float-text value.float-value)
    .String (edn-escaped-string-text value.text)
    .Keyword (string-owned value.text)
    .Symbol (string-owned value.text)
    .Uuid (string-owned value.text)
    .Entity (string-owned (fmt.tprintf "[:vev/entity %d]" value.entity))
    .Vector
      (let [parts (make [dynamic]string) :defer
            owned-parts (make [dynamic]string) :defer]
        (arr.push! parts (string-owned "["))
        (arr.push! owned-parts parts[0])
        (for [item index value.items]
          (when (> index 0)
            (arr.push! parts (string-owned " "))
            (arr.push! owned-parts parts[(- (count parts) 1)]))
          (let [item-text (value-serializable-text item)]
            (arr.push! parts item-text)
            (arr.push! owned-parts item-text)))
        (arr.push! parts (string-owned "]"))
        (arr.push! owned-parts parts[(- (count parts) 1)])
        (let [out (strings.concatenate (slice parts 0))]
          (for [part owned-parts]
            (delete part))
          out))
    .Map
      (let [parts (make [dynamic]string) :defer
            owned-parts (make [dynamic]string) :defer]
        (arr.push! parts (string-owned "{"))
        (arr.push! owned-parts parts[0])
        (for [item index value.items]
          (when (> index 0)
            (arr.push! parts (string-owned " "))
            (arr.push! owned-parts parts[(- (count parts) 1)]))
          (let [item-text (value-serializable-text item)]
            (arr.push! parts item-text)
            (arr.push! owned-parts item-text)))
        (arr.push! parts (string-owned "}"))
        (arr.push! owned-parts parts[(- (count parts) 1)])
        (let [out (strings.concatenate (slice parts 0))]
          (for [part owned-parts]
            (delete part))
          out))
    :else (string-owned "nil")))

(defn attr-serializable-text [attr: string] -> string
  (if (strings.has_prefix attr ":")
    attr
    (edn-escaped-string-text attr)))

(defn datom-serializable-text [datom: Datom] -> string
  (let [value-text (value-serializable-text datom.v) :defer]
    (fmt.tprintf "[%d %s %s %d %v]"
                 datom.e
                 (attr-serializable-text datom.a)
                 value-text
                 datom.tx
                 datom.added)))

(defn serializable-text [db: DB] -> string
  (let [parts (make [dynamic]string) :defer]
    (arr.push! parts "[")
    (for [datom index db.datoms]
      (when (> index 0)
        (arr.push! parts " "))
      (arr.push! parts (datom-serializable-text datom)))
    (arr.push! parts "]")
    (strings.concatenate (slice parts 0))))

(defn edn-int-u64 [doc: EDN-Doc, node-index: int, label: string] -> [value: u64, ok: bool, error: string]
  (when (= node-index -1)
    (return 0 false (fmt.tprintf "expected %s" label)))
  (let [node doc.nodes[node-index]]
    (when (not (= node.kind .Int))
      (return 0 false (fmt.tprintf "expected integer %s" label)))
    (when (< node.int-value 0)
      (return 0 false (fmt.tprintf "expected non-negative %s" label)))
    (return (u64 node.int-value) true "")))

(defn serial-value-from-edn-node [doc: EDN-Doc, node-index: int] -> [value: Value, ok: bool, error: string]
  (when (= node-index -1)
    (return (Value {}) false "expected serialized value"))
  (let [node doc.nodes[node-index]]
    (when (and (= node.kind .Vector) (= node.child-count 2))
      (let [tag-node (edn-child-at doc node-index 0)
            value-node (edn-child-at doc node-index 1)]
        (when (and (not (= tag-node -1))
                   (= doc.nodes[tag-node].kind .Keyword)
                   (= doc.nodes[tag-node].text ":vev/entity"))
          (let [[entity entity-ok entity-error] (edn-int-u64 doc value-node "entity id")]
            (if entity-ok
              (return (value-entity entity) true "")
              (return (Value {}) false entity-error))))
        (when (and (not (= tag-node -1))
                   (= doc.nodes[tag-node].kind .Keyword)
                   (= doc.nodes[tag-node].text ":vev/float"))
          (when (not (= doc.nodes[value-node].kind .String))
            (return (Value {}) false "expected serialized float string"))
          (let [[parsed parsed-ok] (serializable-float-from-text doc.nodes[value-node].text)]
            (if parsed-ok
              (return (value-float parsed) true "")
              (return (Value {}) false "invalid serialized float"))))))
    (case node.kind
      .Nil (return (value-nil) true "")
      .Bool (return (value-bool node.bool-value) true "")
      .Int (return (value-int node.int-value) true "")
      .Float (return (value-float node.float-value) true "")
      .String (return (value-string node.text) true "")
      .Keyword (return (value-keyword node.text) true "")
      .Symbol (return (value-symbol node.text) true "")
      .Uuid (return (value-uuid node.text) true "")
      .Vector (let [items (make [dynamic]Value) :defer]
                (for [child (edn-children doc node-index)]
                  (let [[item item-ok item-error] (serial-value-from-edn-node doc child)]
                    (when (not item-ok)
                      (for [parsed items]
                        (delete-value-containers-shallow parsed))
                      (return (Value {}) false item-error))
                    (arr.push! items item)))
                (return (value-vector (slice items 0)) true ""))
      .Set (let [items (make [dynamic]Value) :defer]
             (for [child (edn-children doc node-index)]
               (let [[item item-ok item-error] (serial-value-from-edn-node doc child)]
                 (when (not item-ok)
                   (for [parsed items]
                     (delete-value-containers-shallow parsed))
                   (return (Value {}) false item-error))
                 (arr.push! items item)))
             (return (value-vector (slice items 0)) true ""))
      .Map (let [items (make [dynamic]Value) :defer]
             (for [entry (edn-child-pairs doc node-index)]
               (when (= entry.value -1)
                 (for [parsed items]
                   (delete-value-containers-shallow parsed))
                 (return (Value {}) false "serialized map value missing"))
               (let [[key key-ok key-error] (serial-value-from-edn-node doc entry.key)]
                 (when (not key-ok)
                   (for [parsed items]
                     (delete-value-containers-shallow parsed))
                   (return (Value {}) false key-error))
                 (let [[value value-ok value-error] (serial-value-from-edn-node doc entry.value)]
                   (when (not value-ok)
                     (delete-value-containers-shallow key)
                     (for [parsed items]
                       (delete-value-containers-shallow parsed))
                     (return (Value {}) false value-error))
                   (arr.push! items key)
                   (arr.push! items value))))
             (return (value-map (slice items 0)) true ""))
      :else (return (Value {}) false "unsupported serialized value"))))

(defn delete-parser-datom-value-containers-shallow [datom: Datom]
  (delete-value-containers-shallow datom.v))

(defn delete-parser-tx-data-value-containers-shallow [data: Tx-Data]
  (delete-value-containers-shallow data.lookup-value)
  (delete-value-containers-shallow data.v)
  (delete-value-containers-shallow data.expected)
  (delete-value-containers-shallow data.expected-lookup-value)
  (delete-value-containers-shallow data.value-lookup-value)
  (delete-value-containers-shallow data.nested-map))

(defn delete-parser-tx-edn-entity-value-containers-shallow [ref: Tx-EDN-Entity]
  (when (= ref.kind .LookupRef)
    (delete-value-containers-shallow ref.lookup-value)))

(defn datom-from-edn-node [doc: EDN-Doc, node-index: int] -> [datom: Datom, ok: bool, error: string]
  (when (or (= node-index -1)
            (not (= doc.nodes[node-index].kind .Vector))
            (not (= doc.nodes[node-index].child-count 5)))
    (return (Datom {}) false "expected serialized datom vector [e a v tx added]"))
  (let [e-node (edn-child-at doc node-index 0)
        a-node (edn-child-at doc node-index 1)
        v-node (edn-child-at doc node-index 2)
        tx-node (edn-child-at doc node-index 3)
        added-node (edn-child-at doc node-index 4)
        [e e-ok e-error] (edn-int-u64 doc e-node "entity id")
        [attr attr-ok] (edn-attr-text doc a-node)]
    (when (not e-ok)
      (return (Datom {}) false e-error))
    (when (not attr-ok)
      (return (Datom {}) false "expected datom attribute keyword or string"))
    (let [[value value-ok value-error] (serial-value-from-edn-node doc v-node)]
      (when (not value-ok)
        (return (Datom {}) false value-error))
      (let [[tx tx-ok tx-error] (edn-int-u64 doc tx-node "tx")
            added-doc-node doc.nodes[added-node]]
        (when (not tx-ok)
          (delete-value-containers-shallow value)
          (return (Datom {}) false tx-error))
        (when (not (= added-doc-node.kind .Bool))
          (delete-value-containers-shallow value)
          (return (Datom {}) false "expected datom added boolean"))
        (let [owned-value (value-owned value)]
          (delete-value-containers-shallow value)
          (return (datom-tx e (string-owned attr) owned-value tx added-doc-node.bool-value) true ""))))))

(defn delete-datom-value-containers-from! [datoms: ^[dynamic]Datom, start: int]
  (for [index (arr.range start (count datoms^))]
    (delete datoms^[index].a)
    (delete-owned-value datoms^[index].v))
  (while (> (count datoms^) start)
    (arr.remove-ordered-at! datoms^ (- (count datoms^) 1))))

(defn from-serializable-text [text: string] -> [db: DB, ok: bool, error: string]
  (let [doc (empty-edn-doc)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return (build-db (make [dynamic]Datom)) false read-error))
    (when (not (= doc.nodes[doc.root].kind .Vector))
      (delete doc.nodes)
      (return (build-db (make [dynamic]Datom)) false "expected serialized DB vector"))
    (let [datoms (make [dynamic]Datom)
          start-count (count datoms)
          child doc.nodes[doc.root].first-child]
      (while (not (= child -1))
        (let [[datom datom-ok datom-error] (datom-from-edn-node doc child)]
          (when (not datom-ok)
            (delete-datom-value-containers-from! (addr datoms) start-count)
            (delete datoms)
            (delete doc.nodes)
            (return (build-db (make [dynamic]Datom)) false datom-error))
          (arr.push! datoms datom))
        (set! child doc.nodes[child].next-sibling))
      (delete doc.nodes)
      (return (build-db datoms) true ""))))

(defn edn-lookup-ref-node? [doc: EDN-Doc, node-index: int] -> bool
  (when (or (= node-index -1)
            (not (= doc.nodes[node-index].kind .Vector))
            (not (= doc.nodes[node-index].child-count 2)))
    (return false))
  (let [attr-node (edn-child-at doc node-index 0)
        [attr attr-ok] (edn-attr-text doc attr-node)]
    (and attr-ok (strings.has_prefix attr ":"))))

(defn edn-entity-ref-from-node [doc: EDN-Doc, node-index: int] -> [ref: Tx-EDN-Entity, ok: bool, error: string]
  (when (= node-index -1)
    (return (Tx-EDN-Entity {}) false "expected entity id"))
  (let [node doc.nodes[node-index]]
    (cond
      (= node.kind .Int)
        (if (< node.int-value 0)
          (return (Tx-EDN-Entity {kind: .Tempid tempid: (fmt.tprintf "%d" node.int-value)}) true "")
          (return (Tx-EDN-Entity {kind: .Id e: (u64 node.int-value)}) true ""))
      (= node.kind .String)
        (return (Tx-EDN-Entity {kind: .Tempid tempid: node.text}) true "")
      (= node.kind .Keyword)
        (if (current-tx-tempid? node.text)
          (return (Tx-EDN-Entity {kind: .Tempid tempid: node.text}) true "")
          (return (Tx-EDN-Entity {kind: .Ident ident: node.text}) true ""))
      (edn-lookup-ref-node? doc node-index)
        (let [attr-node (edn-child-at doc node-index 0)
              value-node (edn-child-at doc node-index 1)
              [attr attr-ok] (edn-attr-text doc attr-node)
              [value value-ok value-error] (edn-value-from-node doc value-node)]
          (when (not attr-ok)
            (return (Tx-EDN-Entity {}) false "lookup ref attribute must be keyword or string"))
          (when (not value-ok)
            (return (Tx-EDN-Entity {}) false value-error))
          (return (Tx-EDN-Entity {kind: .LookupRef lookup-attr: attr lookup-value: value}) true ""))
      :else (return (Tx-EDN-Entity {}) false "entity id must be int, tempid string, ident keyword, or lookup ref"))))

(defn tx-add-from-ref [ref: Tx-EDN-Entity, a: string, v: Value] -> Tx-Data
  (case ref.kind
    .Id (add ref.e a v)
    .Tempid (add-tempid ref.tempid a v)
    .LookupRef (add-lookup-ref ref.lookup-attr ref.lookup-value a v)
    .Ident (add-ident ref.ident a v)
    :else (Tx-Data {})))

(defn tx-add-map-collection-from-ref [ref: Tx-EDN-Entity, a: string, v: Value] -> Tx-Data
  (let [data (tx-add-from-ref ref a v)]
    (set! data.from-map-collection true)
    data))

(defn tx-add-value-tempid-from-ref [ref: Tx-EDN-Entity, a: string, value-tempid: string] -> Tx-Data
  (case ref.kind
    .Id (add-value-tempid ref.e a value-tempid)
    .Tempid (add-tempid-value-tempid ref.tempid a value-tempid)
    .LookupRef (add-lookup-ref-value-tempid ref.lookup-attr ref.lookup-value a value-tempid)
    .Ident (add-ident-value-tempid ref.ident a value-tempid)
    :else (Tx-Data {})))

(defn tx-add-value-lookup-ref-from-ref [ref: Tx-EDN-Entity, a: string, value-attr: string, value-value: Value] -> Tx-Data
  (case ref.kind
    .Id (add-value-lookup-ref ref.e a value-attr value-value)
    .Tempid (add-tempid-value-lookup-ref ref.tempid a value-attr value-value)
    .LookupRef (Tx-Data {op: ":db/add"
                         lookup-attr: ref.lookup-attr
                         lookup-value: ref.lookup-value
                         has-lookup-ref: true
                         a: a
                         value-lookup-attr: value-attr
                         value-lookup-value: value-value
                         has-value-lookup-ref: true})
    .Ident (Tx-Data {op: ":db/add"
                     ident: ref.ident
                     has-ident: true
                     a: a
                     value-lookup-attr: value-attr
                     value-lookup-value: value-value
                     has-value-lookup-ref: true})
    :else (Tx-Data {})))

(defn tx-add-nested-map-from-ref [ref: Tx-EDN-Entity, a: string, nested-map: Value, nested-tempid: string] -> Tx-Data
  (case ref.kind
    .Id (add-nested-map ref.e a nested-map nested-tempid)
    .Tempid (add-tempid-nested-map ref.tempid a nested-map nested-tempid)
    .LookupRef (add-lookup-ref-nested-map ref.lookup-attr ref.lookup-value a nested-map nested-tempid)
    .Ident (add-ident-nested-map ref.ident a nested-map nested-tempid)
    :else (Tx-Data {})))

(defn tx-add-ref-value-from-ref [ref: Tx-EDN-Entity, a: string, value-ref: Tx-EDN-Entity] -> Tx-Data
  (case value-ref.kind
    .Id (tx-add-from-ref ref a (value-entity value-ref.e))
    .Tempid (tx-add-value-tempid-from-ref ref a value-ref.tempid)
    .LookupRef (tx-add-value-lookup-ref-from-ref ref a value-ref.lookup-attr value-ref.lookup-value)
    .Ident (tx-add-from-ref ref a (value-keyword value-ref.ident))
    :else (Tx-Data {})))

(defn tx-retract-from-ref [ref: Tx-EDN-Entity, a: string, v: Value] -> Tx-Data
  (case ref.kind
    .Id (retract ref.e a v)
    .Tempid (retract-tempid ref.tempid a v)
    .LookupRef (retract-lookup-ref ref.lookup-attr ref.lookup-value a v)
    .Ident (retract-ident ref.ident a v)
    :else (Tx-Data {})))

(defn tx-retract-value-lookup-ref-from-ref [ref: Tx-EDN-Entity, a: string, value-attr: string, value-value: Value] -> Tx-Data
  (case ref.kind
    .Id (retract-value-lookup-ref ref.e a value-attr value-value)
    .Tempid (Tx-Data {op: ":db/retract"
                      tempid: ref.tempid
                      has-tempid: true
                      a: a
                      value-lookup-attr: value-attr
                      value-lookup-value: value-value
                      has-value-lookup-ref: true})
    .LookupRef (Tx-Data {op: ":db/retract"
                         lookup-attr: ref.lookup-attr
                         lookup-value: ref.lookup-value
                         has-lookup-ref: true
                         a: a
                         value-lookup-attr: value-attr
                         value-lookup-value: value-value
                         has-value-lookup-ref: true})
    .Ident (Tx-Data {op: ":db/retract"
                     ident: ref.ident
                     has-ident: true
                     a: a
                     value-lookup-attr: value-attr
                     value-lookup-value: value-value
                     has-value-lookup-ref: true})
    :else (Tx-Data {})))

(defn tx-retract-attr-from-ref [ref: Tx-EDN-Entity, a: string] -> Tx-Data
  (case ref.kind
    .Id (retract-attr ref.e a)
    .Tempid (retract-attr-tempid ref.tempid a)
    .LookupRef (retract-attr-lookup-ref ref.lookup-attr ref.lookup-value a)
    .Ident (retract-attr-ident ref.ident a)
    :else (Tx-Data {})))

(defn tx-retract-entity-from-ref [ref: Tx-EDN-Entity] -> Tx-Data
  (case ref.kind
    .Id (retract-entity ref.e)
    .Tempid (retract-entity-tempid ref.tempid)
    .LookupRef (retract-entity-lookup-ref ref.lookup-attr ref.lookup-value)
    .Ident (retract-entity-ident ref.ident)
    :else (Tx-Data {})))

(defn tx-cas-from-ref [ref: Tx-EDN-Entity, a: string, expected: Value, v: Value] -> Tx-Data
  (case ref.kind
    .Id (cas ref.e a expected v)
    .Tempid (cas-tempid ref.tempid a expected v)
    .LookupRef (cas-lookup-ref ref.lookup-attr ref.lookup-value a expected v)
    .Ident (Tx-Data {op: ":db.fn/cas" ident: ref.ident has-ident: true a: a expected: expected v: v})
    :else (Tx-Data {})))

(defn tx-cas-lookup-values-from-ref [ref: Tx-EDN-Entity, a: string, expected: Value, has-expected-lookup: bool, expected-attr: string, expected-value: Value, v: Value, has-value-lookup: bool, value-attr: string, value-value: Value] -> Tx-Data
  (let [data (tx-cas-from-ref ref a expected v)]
    (when has-expected-lookup
      (set! data.expected-lookup-attr expected-attr)
      (set! data.expected-lookup-value expected-value)
      (set! data.has-expected-lookup-ref true))
    (when has-value-lookup
      (set! data.value-lookup-attr value-attr)
      (set! data.value-lookup-value value-value)
      (set! data.has-value-lookup-ref true))
    data))

(defn edn-lookup-ref-parts [doc: EDN-Doc, node-index: int] -> [attr: string, value: Value, ok: bool, error: string]
  (when (not (edn-lookup-ref-node? doc node-index))
    (return "" (Value {}) false "expected lookup ref"))
  (let [attr-node (edn-child-at doc node-index 0)
        lookup-value-node (edn-child-at doc node-index 1)
        [lookup-attr attr-ok] (edn-attr-text doc attr-node)
        [lookup-value value-ok value-error] (edn-value-from-node doc lookup-value-node)]
    (when (not attr-ok)
      (return "" (Value {}) false "lookup ref attribute must be keyword or string"))
    (when (not value-ok)
      (return "" (Value {}) false value-error))
    (return lookup-attr lookup-value true "")))

(defn append-edn-tx-add-value! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, ref: Tx-EDN-Entity, a: string, value-node: int, map-group: string] -> [ok: bool, error: string]
  (if (and (= doc.nodes[value-node].kind .String)
           (not (edn-lookup-ref-node? doc value-node)))
    (do
      (arr.push! out^ (tx-data-with-map-group (tx-add-from-ref ref a (value-string doc.nodes[value-node].text)) map-group))
      (return true ""))
    (if (edn-lookup-ref-node? doc value-node)
      (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc value-node)]
        (when (not lookup-ok)
          (return false lookup-error))
        (arr.push! out^ (tx-data-with-map-group (tx-add-value-lookup-ref-from-ref ref a lookup-attr lookup-value) map-group))
        (return true ""))
      (let [[value value-ok value-error] (edn-value-from-node doc value-node)]
        (when (not value-ok)
          (return false value-error))
        (arr.push! out^ (tx-data-with-map-group (tx-add-from-ref ref a value) map-group))
        (return true "")))))

(defn append-edn-tx-map-attr! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, ref: Tx-EDN-Entity, attr-node: int, value-node: int, map-group: string] -> [ok: bool, error: string]
  (let [[attr attr-ok] (edn-attr-text doc attr-node)]
    (when (not attr-ok)
      (return false "tx map attributes must be keywords or strings"))
    (when (= attr ":db/id")
      (return true ""))
    (if (or (= doc.nodes[value-node].kind .Vector)
            (= doc.nodes[value-node].kind .Set))
      (if (edn-lookup-ref-node? doc value-node)
        (append-edn-tx-add-value! out doc ref attr value-node map-group)
        (let [[value value-ok value-error] (edn-value-from-node doc value-node)]
          (when (not value-ok)
            (return false value-error))
          (arr.push! out^ (tx-data-with-map-group (tx-add-map-collection-from-ref ref attr value) map-group))
          (return true "")))
      (if (= doc.nodes[value-node].kind .Map)
        (let [nested-tempid (fmt.tprintf "__vev_tx_map_%d" value-node)
              [nested-value nested-ok nested-error] (edn-value-from-node doc value-node)]
          (when (not nested-ok)
            (return false nested-error))
          (arr.push! out^ (tx-data-with-map-group (tx-add-nested-map-from-ref ref attr nested-value nested-tempid) map-group))
          (return true ""))
        (append-edn-tx-add-value! out doc ref attr value-node map-group)))))

(defn edn-tx-map-entity-ref [doc: EDN-Doc, map-node: int, generated-tempid: string] -> [ref: Tx-EDN-Entity, ok: bool, error: string]
  (let [child doc.nodes[map-node].first-child]
    (while (not (= child -1))
      (let [value-node doc.nodes[child].next-sibling]
        (when (= value-node -1)
          (return (Tx-EDN-Entity {}) false "tx map value missing"))
        (when (edn-keyword-text? doc child ":db/id")
          (return (edn-entity-ref-from-node doc value-node)))
        (set! child doc.nodes[value-node].next-sibling)))
    (return (Tx-EDN-Entity {kind: .Tempid tempid: generated-tempid}) true "")))

(defn append-edn-tx-map-items! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, map-node: int, ref: Tx-EDN-Entity, map-group: string] -> [ok: bool, error: string]
  (do
    (for [entry (edn-child-pairs doc map-node)]
      (when (= entry.value -1)
        (return false "tx map value missing"))
      (let [[item-ok item-error] (append-edn-tx-map-attr! out doc ref entry.key entry.value map-group)]
        (when (not item-ok)
          (return false item-error))))
    (return true "")))

(defn append-edn-tx-map! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, map-node: int] -> [ok: bool, error: string]
  (let [generated-tempid (fmt.tprintf "__vev_tx_map_%d" map-node)
        map-group (fmt.tprintf "__vev_tx_map_group_%d" map-node)
        [ref ref-ok ref-error] (edn-tx-map-entity-ref doc map-node generated-tempid)]
    (when (not ref-ok)
      (return false ref-error))
    (let [[items-ok items-error] (append-edn-tx-map-items! out doc map-node ref map-group)]
      (when (not items-ok)
        (delete-parser-tx-edn-entity-value-containers-shallow ref)
        (return false items-error))
      (return true ""))))

(defn edn-tx-call-args [doc: EDN-Doc, vector-node: int, start-index: int] -> [value: Value, ok: bool, error: string]
  (let [items (make [dynamic]Value)]
    (for [index (arr.range start-index doc.nodes[vector-node].child-count)]
      (let [arg-node (edn-child-at doc vector-node index)
            [arg arg-ok arg-error] (edn-value-from-node doc arg-node)]
        (when (not arg-ok)
          (for [parsed items]
            (delete-value-containers-shallow parsed))
          (delete items)
          (return (Value {}) false arg-error))
        (arr.push! items arg)))
    (let [out (value-vector (slice items 0))]
      (delete items)
      (return out true ""))))

(defn delete-tx-data-value-containers-from! [items: ^[dynamic]Tx-Data, start: int]
  (for [index (arr.range start (count items^))]
    (delete-parser-tx-data-value-containers-shallow items^[index]))
  (while (> (count items^) start)
    (arr.remove-ordered-at! items^ (- (count items^) 1))))

(defn append-edn-tx-vector! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, vector-node: int] -> [ok: bool, error: string]
  (let [op-node (edn-child-at doc vector-node 0)]
    (when (= op-node -1)
      (return true ""))
    (when (not (= doc.nodes[op-node].kind .Keyword))
      (return false "tx-data operation must be a keyword"))
    (let [op doc.nodes[op-node].text]
      (cond
        (or (= op ":db/add") (= op ":db/retract"))
          (do
            (when (and (= op ":db/add") (not (= doc.nodes[vector-node].child-count 4)))
              (return false ":db/add expects [op e a v]"))
            (when (and (= op ":db/retract")
                       (not (= doc.nodes[vector-node].child-count 3))
                       (not (= doc.nodes[vector-node].child-count 4)))
              (return false ":db/retract expects [op e a] or [op e a v]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  v-node (edn-child-at doc vector-node 3)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (delete-parser-tx-edn-entity-value-containers-shallow ref)
                (return false "tx-data attributes must be keywords or strings"))
              (if (= v-node -1)
                (do
                  (arr.push! out^ (tx-retract-attr-from-ref ref attr))
                  (return true ""))
                (if (= op ":db/add")
                  (let [[add-ok add-error] (append-edn-tx-add-value! out doc ref attr v-node "")]
                    (when (not add-ok)
                      (delete-parser-tx-edn-entity-value-containers-shallow ref)
                      (return false add-error))
                    (return true ""))
                  (if (edn-lookup-ref-node? doc v-node)
                    (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc v-node)]
                      (when (not lookup-ok)
                        (delete-parser-tx-edn-entity-value-containers-shallow ref)
                        (return false lookup-error))
                      (arr.push! out^ (tx-retract-value-lookup-ref-from-ref ref attr lookup-attr lookup-value))
                      (return true ""))
                    (let [[value value-ok value-error] (edn-value-from-node doc v-node)]
                      (when (not value-ok)
                        (delete-parser-tx-edn-entity-value-containers-shallow ref)
                        (return false value-error))
                      (arr.push! out^ (tx-retract-from-ref ref attr value))
                      (return true "")))))))
        (or (= op ":db/retractEntity") (= op ":db.fn/retractEntity"))
          (do
            (when (not (= doc.nodes[vector-node].child-count 2))
              (return false ":db/retractEntity expects [op e]"))
            (let [[ref ref-ok ref-error] (edn-entity-ref-from-node doc (edn-child-at doc vector-node 1))]
              (when (not ref-ok)
                (return false ref-error))
              (arr.push! out^ (tx-retract-entity-from-ref ref))
              (return true "")))
        (= op ":db.fn/retractAttribute")
          (do
            (when (not (= doc.nodes[vector-node].child-count 3))
              (return false ":db.fn/retractAttribute expects [op e a]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (delete-parser-tx-edn-entity-value-containers-shallow ref)
                (return false "tx-data attributes must be keywords or strings"))
              (arr.push! out^ (tx-retract-attr-from-ref ref attr))
              (return true "")))
        (or (= op ":db.fn/cas") (= op ":db/cas"))
          (do
            (when (not (= doc.nodes[vector-node].child-count 5))
              (return false ":db.fn/cas expects [op e a old new]"))
            (let [e-node (edn-child-at doc vector-node 1)
                  a-node (edn-child-at doc vector-node 2)
                  old-node (edn-child-at doc vector-node 3)
                  new-node (edn-child-at doc vector-node 4)
                  [ref ref-ok ref-error] (edn-entity-ref-from-node doc e-node)
                  [attr attr-ok] (edn-attr-text doc a-node)
                  expected (Value {})
                  expected-ok true
                  expected-error ""
                  expected-lookup-attr ""
                  expected-lookup-value (Value {})
                  has-expected-lookup false
                  value (Value {})
                  value-ok true
                  value-error ""
                  value-lookup-attr ""
                  value-lookup-value (Value {})
                  has-value-lookup false]
              (when (not ref-ok)
                (return false ref-error))
              (when (not attr-ok)
                (delete-parser-tx-edn-entity-value-containers-shallow ref)
                (return false "tx-data attributes must be keywords or strings"))
              (if (edn-lookup-ref-node? doc old-node)
                (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc old-node)]
                  (set! expected-lookup-attr lookup-attr)
                  (set! expected-lookup-value lookup-value)
                  (set! has-expected-lookup true)
                  (set! expected-ok lookup-ok)
                  (set! expected-error lookup-error))
                (let [[plain-value plain-ok plain-error] (edn-value-from-node doc old-node)]
                  (set! expected plain-value)
                  (set! expected-ok plain-ok)
                  (set! expected-error plain-error)))
              (if (edn-lookup-ref-node? doc new-node)
                (let [[lookup-attr lookup-value lookup-ok lookup-error] (edn-lookup-ref-parts doc new-node)]
                  (set! value-lookup-attr lookup-attr)
                  (set! value-lookup-value lookup-value)
                  (set! has-value-lookup true)
                  (set! value-ok lookup-ok)
                  (set! value-error lookup-error))
                (let [[plain-value plain-ok plain-error] (edn-value-from-node doc new-node)]
                  (set! value plain-value)
                  (set! value-ok plain-ok)
                  (set! value-error plain-error)))
              (when (not expected-ok)
                (when value-ok
                  (if has-value-lookup
                    (delete-value-containers-shallow value-lookup-value)
                    (delete-value-containers-shallow value)))
                (delete-parser-tx-edn-entity-value-containers-shallow ref)
                (return false expected-error))
              (when (not value-ok)
                (when expected-ok
                  (if has-expected-lookup
                    (delete-value-containers-shallow expected-lookup-value)
                    (delete-value-containers-shallow expected)))
                (delete-parser-tx-edn-entity-value-containers-shallow ref)
                (return false value-error))
              (arr.push! out^ (tx-cas-lookup-values-from-ref ref attr expected has-expected-lookup expected-lookup-attr expected-lookup-value value has-value-lookup value-lookup-attr value-lookup-value))
              (return true "")))
        (= op ":db.fn/call")
          (do
            (when (< doc.nodes[vector-node].child-count 2)
              (return false ":db.fn/call text form expects [op ident arg ...]"))
            (let [ident-node (edn-child-at doc vector-node 1)]
              (when (not (= doc.nodes[ident-node].kind .Keyword))
                (return false ":db.fn/call text form expects keyword function ident"))
              (let [[args args-ok args-error] (edn-tx-call-args doc vector-node 2)]
                (when (not args-ok)
                  (return false args-error))
                (arr.push! out^ (call-ident-arg-vector doc.nodes[ident-node].text args))
                (return true ""))))
        (and (not (or (= op ":db/add")
                      (= op ":db/retract")
                      (= op ":db/retractEntity")
                      (= op ":db.fn/retractEntity")
                      (= op ":db.fn/retractAttribute")
                      (= op ":db.fn/cas")
                      (= op ":db/cas")
                      (= op ":db.fn/call")))
             (>= doc.nodes[vector-node].child-count 1))
          (do
            (let [[args args-ok args-error] (edn-tx-call-args doc vector-node 1)]
              (when (not args-ok)
                (return false args-error))
              (arr.push! out^ (call-ident-arg-vector op args))
              (return true "")))
        :else (return false "unknown tx-data operation")))))

(defn append-edn-tx-item! [out: ^[dynamic]Tx-Data, doc: EDN-Doc, node-index: int] -> [ok: bool, error: string]
  (case doc.nodes[node-index].kind
    .Nil (return true "")
    .Vector (append-edn-tx-vector! out doc node-index)
    .Map (append-edn-tx-map! out doc node-index)
    :else (return false "tx-data expects vector or map items")))

(defn parse-tx-text! [out: ^[dynamic]Tx-Data, text: string] -> [ok: bool, error: string]
  (let [doc (empty-edn-doc)
        start-count (count out^)
        [read-ok read-error] (read-edn-text! (addr doc) text)]
    (when (not read-ok)
      (delete doc.nodes)
      (return false read-error))
    (when (or (= doc.root -1) (not (= doc.nodes[doc.root].kind .Vector)))
      (delete doc.nodes)
      (return false "tx text must be an EDN vector"))
    (let [root-child doc.nodes[doc.root].first-child]
      (when (and (not (= root-child -1))
                 (= doc.nodes[root-child].kind .Keyword))
        (let [[item-ok item-error] (append-edn-tx-vector! out doc doc.root)]
          (delete doc.nodes)
          (when (not item-ok)
            (delete-tx-data-value-containers-from! out start-count))
          (return item-ok item-error))))
    (let [child doc.nodes[doc.root].first-child]
      (while (not (= child -1))
        (let [[item-ok item-error] (append-edn-tx-item! out doc child)]
          (when (not item-ok)
            (delete-tx-data-value-containers-from! out start-count)
            (delete doc.nodes)
            (return false item-error)))
        (set! child doc.nodes[child].next-sibling)))
    (delete doc.nodes)
    (return true "")))

(defn prepare-tx-text [text: string] -> Prepared-Tx-Data
  (let [tx-data (make [dynamic]Tx-Data)
        [ok error] (parse-tx-text! (addr tx-data) text)]
    (Prepared-Tx-Data {ok: ok error: error tx-data: tx-data})))

(defn transact-prepared [conn: ^Conn, prepared: Prepared-Tx-Data] -> Tx-Report
  (if prepared.ok
    (transact-tx-data conn (slice prepared.tx-data 0))
    (failed-tx-report conn^.db prepared.error)))

(defn transact-prepared-value [conn: ^Conn, prepared: Prepared-Tx-Data] -> Value
  (tx-report-value (transact-prepared conn prepared)))

(defn with-prepared [db: DB, prepared: Prepared-Tx-Data] -> Tx-Report
  (if prepared.ok
    (with-tx-data db (slice prepared.tx-data 0))
    (failed-tx-report db prepared.error)))

(defn with-prepared-value [db: DB, prepared: Prepared-Tx-Data] -> Value
  (tx-report-value (with-prepared db prepared)))

(defn db-with-prepared [db: DB, prepared: Prepared-Tx-Data] -> DB
  (let [report (with-prepared db prepared)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn transact-prepared-with-string-fns [conn: ^Conn, prepared: Prepared-Tx-Data, registry: []Tx-Fn-String] -> Tx-Report
  (if prepared.ok
    (transact-tx-data-with-string-fns conn (slice prepared.tx-data 0) registry)
    (failed-tx-report conn^.db prepared.error)))

(defn transact-prepared-value-with-string-fns [conn: ^Conn, prepared: Prepared-Tx-Data, registry: []Tx-Fn-String] -> Value
  (tx-report-value (transact-prepared-with-string-fns conn prepared registry)))

(defn with-prepared-with-string-fns [db: DB, prepared: Prepared-Tx-Data, registry: []Tx-Fn-String] -> Tx-Report
  (if prepared.ok
    (let [conn (conn-from-db db)]
      (transact-tx-data-with-string-fns (addr conn) (slice prepared.tx-data 0) registry))
    (failed-tx-report db prepared.error)))

(defn with-prepared-value-with-string-fns [db: DB, prepared: Prepared-Tx-Data, registry: []Tx-Fn-String] -> Value
  (tx-report-value (with-prepared-with-string-fns db prepared registry)))

(defn db-with-prepared-with-string-fns [db: DB, prepared: Prepared-Tx-Data, registry: []Tx-Fn-String] -> DB
  (let [report (with-prepared-with-string-fns db prepared registry)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn transact-text [conn: ^Conn, text: string] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report conn^.db parse-error)))
    (transact-tx-data conn (slice tx-data 0))))

(defn transact-text-value [conn: ^Conn, text: string] -> Value
  (tx-report-value (transact-text conn text)))

(defn with-text [db: DB, text: string] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report db parse-error)))
    (with-tx-data db (slice tx-data 0))))

(defn with-text-value [db: DB, text: string] -> Value
  (tx-report-value (with-text db text)))

(defn db-with-text [db: DB, text: string] -> DB
  (let [report (with-text db text)]
    (if report.ok
      report.db-after
      report.db-before)))

(defn transact-text-with-string-fns [conn: ^Conn, text: string, registry: []Tx-Fn-String] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report conn^.db parse-error)))
    (transact-tx-data-with-string-fns conn (slice tx-data 0) registry)))

(defn transact-text-value-with-string-fns [conn: ^Conn, text: string, registry: []Tx-Fn-String] -> Value
  (tx-report-value (transact-text-with-string-fns conn text registry)))

(defn with-text-with-string-fns [db: DB, text: string, registry: []Tx-Fn-String] -> Tx-Report
  (let [tx-data (make [dynamic]Tx-Data) :defer
        [parse-ok parse-error] (parse-tx-text! (addr tx-data) text)]
    (when (not parse-ok)
      (return (failed-tx-report db parse-error)))
    (let [conn (conn-from-db db)]
      (transact-tx-data-with-string-fns (addr conn) (slice tx-data 0) registry))))

(defn with-text-value-with-string-fns [db: DB, text: string, registry: []Tx-Fn-String] -> Value
  (tx-report-value (with-text-with-string-fns db text registry)))

(defn db-with-text-with-string-fns [db: DB, text: string, registry: []Tx-Fn-String] -> DB
  (let [report (with-text-with-string-fns db text registry)]
    (if report.ok
      report.db-after
      report.db-before)))
