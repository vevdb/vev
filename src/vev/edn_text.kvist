(defn q-text-scalar [db: DB, text: string] -> [value: Value, ok: bool]
  (return (result-scalar (q-text db text))))

(defn q-text-scalar-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [value: Value, ok: bool]
  (return (result-scalar (q-text-with-inputs db text inputs))))

(defn q-text-collection [db: DB, text: string] -> [dynamic]Value
  (return (result-collection (q-text db text))))

(defn q-text-collection-with-inputs [db: DB, text: string, inputs: []Query-Input] -> [dynamic]Value
  (return (result-collection (q-text-with-inputs db text inputs))))

(defn q-text-tuple [db: DB, text: string] -> [dynamic]Value
