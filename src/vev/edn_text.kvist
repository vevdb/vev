    (defer (delete pattern))
    (if ok
      (pull-pattern-lookup-ref-with-fns db attr value (slice pattern 0) registry)
      (Pull-Result {e: 0 attrs: (make [dynamic]Pull-Attr)}))))

(defn pull-text-lookup-ref [db: DB, pattern-text: string, attr: string, value: Value] -> Pull-Result
  (pull-text-lookup-ref-with-fns db pattern-text attr value ([]Native-Query-Fn [])))

(defn pull-text-lookup-ref-value-with-fns [db: DB, pattern-text: string, attr: string, value: Value, registry: []Native-Query-Fn] -> Value
