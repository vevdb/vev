(t.deftest datascript-query-aggregates-relation-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        with-result (vev.q conn.db
                      [:find ?heads
                       :with ?monster
                       :in [[?monster ?heads]]]
                      [["Cerberus" 3]
                       ["Medusa" 1]
                       ["Cyclops" 1]
                       ["Chimera" 1]])
        aggregate-result (vev.q conn.db
                           [:find (sum ?heads) (min ?heads) (max ?heads) (count ?heads) (count-distinct ?heads) (avg ?heads)
                            :with ?monster
                            :in [[?monster ?heads]]]
                           [["Cerberus" 3]
                            ["Medusa" 1]
                            ["Cyclops" 1]
                            ["Chimera" 1]])
        deduped-aggregate-result (vev.q conn.db
                                   [:find (sum ?heads)
                                    :in [[?monster ?heads]]]
                                   [["Cerberus" 3]
                                    ["Medusa" 1]
                                    ["Cyclops" 1]
                                    ["Chimera" 1]])
        median-result (vev.q conn.db
                        [:find (median ?x)
                         :in [?x ...]]
                        [10 15 20 35 75])
        variance-result (vev.q conn.db
                          [:find (variance ?x)
                           :in [?x ...]]
                          [10 15 20 35 75])
        stddev-result (vev.q conn.db
                         [:find (stddev ?x)
                          :in [?x ...]]
                          [10 15 20 35 75])]
    (t.is (= (count with-result.rows) 4))
    (t.is (= with-result.rows[0].values[0].int_value 3))
    (t.is (= with-result.rows[1].values[0].int_value 1))
    (t.is (= with-result.rows[2].values[0].int_value 1))
    (t.is (= with-result.rows[3].values[0].int_value 1))
    (t.is (= (count aggregate-result.rows) 1))
    (t.is (= aggregate-result.rows[0].values[0].int_value 6))
    (t.is (= aggregate-result.rows[0].values[1].int_value 1))
    (t.is (= aggregate-result.rows[0].values[2].int_value 3))
    (t.is (= aggregate-result.rows[0].values[3].int_value 4))
    (t.is (= aggregate-result.rows[0].values[4].int_value 2))
    (t.is (= aggregate-result.rows[0].values[5].int_value 1))
    (t.is (= (count deduped-aggregate-result.rows) 1))
    (t.is (= deduped-aggregate-result.rows[0].values[0].int_value 4))
    (t.is (= median-result.rows[0].values[0].int_value 20))
    (t.is (= variance-result.rows[0].values[0].int_value 554))
    (t.is (> stddev-result.rows[0].values[0].float_value 23.5))
    (t.is (< stddev-result.rows[0].values[0].float_value 23.6))))

