            (addr conn)
            [{:db/id 100 :db/ident :friend :db/valueType :db.type/ref}
             {:db/id 1 :name "Ada" :friend 2}
             {:db/id 2 :name "Grace" :friend 3}
             {:db/id 3 :name "Katherine" :friend 4}
             {:db/id 4 :name "Margaret"}])
        pulled (vev.pull conn.db [:db/id :name {:friend 2}] 1)
        first-friend pulled.attrs[2]
        second-friend first-friend.attrs[2]]
    (t.is (= (count pulled.attrs) 3))
    (t.is (= pulled.attrs[0].v.entity 1))
    (t.is (= pulled.attrs[1].v.text "Ada"))
    (t.is (= first-friend.v.entity 2))
    (t.is (= first-friend.attrs[0].v.entity 2))
    (t.is (= first-friend.attrs[1].v.text "Grace"))
    (t.is (= second-friend.v.entity 3))
    (t.is (= second-friend.attrs[0].v.entity 3))
    (t.is (= second-friend.attrs[1].v.text "Katherine"))
    (t.is (= (count second-friend.attrs) 2))))

(t.deftest datascript-pull-bounded-reverse-recursion-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
