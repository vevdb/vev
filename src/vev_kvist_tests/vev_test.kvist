(package vev-tests)

(import t "kvist:test")
(import vev "../vev_kvist")

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                    (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})
                    (vev.Tx-Meta {a: ":tx/reason" v: (vev.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next_tx 2))
    (t.is (= (count report.db_before.datoms) 0))
    (t.is (= (count report.db_after.datoms) 2))
    (t.is (= (count report.tx_data) 2))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (let [meta-value report.tx_meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (vev.q-strings report.db_after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-var "name"))
                   (vev.clause (vev.term-var "e") ":user/age" (vev.term-var "age"))
                   (vev.clause (vev.term-var "e") ":user/active" (vev.term-bool true))])]
    (let [query (vev.query ([]string ["e" "name" "age"]) clauses)
          result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 1))
      (t.is (= result.rows[0].values[1].text "Ada"))
      (t.is (= result.rows[0].values[2].kind .Int))
      (t.is (= result.rows[0].values[2].int_value 37)))))

(t.deftest query-follows-ref-values
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-string "Ada"))
                   (vev.clause (vev.term-var "e") ":user/friend" (vev.term-var "friend"))
                   (vev.clause (vev.term-var "friend") ":user/name" (vev.term-var "friend-name"))])]
    (let [query (vev.query ([]string ["friend" "friend-name"]) clauses)
          result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace")))))

(t.deftest query-can-bind-attributes
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.Clause {e: (vev.term-entity 1)
                                a: (vev.term-var "attr")
                                v: (vev.term-string "Ada")})])]
    (let [query (vev.query ([]string ["attr"]) clauses)
          result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Keyword))
      (t.is (= result.rows[0].values[0].text ":user/name")))))

(t.deftest pull-returns-current-entity-attrs
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [report (vev.transact
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-retract 1 ":user/name" (vev.value-string "Ada"))]))
        pulled (vev.pull report.db_after 1 ([]string [":user/name" ":user/age"]))]
      (t.is (= pulled.e 1))
      (t.is (= (count pulled.attrs) 1))
      (t.is (= pulled.attrs[0].a ":user/age"))
      (t.is (= pulled.attrs[0].v.int_value 37)))))

(t.deftest retract-hides-fact-from-current-queries
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)
        add-report (vev.transact
                     (addr conn)
                     ([]vev.Tx-Op
                       [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                        (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        retract-report (vev.transact
                         (addr conn)
                         ([]vev.Tx-Op
                           [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))]))
        old-results (vev.q-strings add-report.db_after (vev.query-name-by-email "a@example.com"))
        current-results (vev.q-strings retract-report.db_after (vev.query-name-by-email "a@example.com"))]
    (t.is (= (count old-results) 1))
    (t.is (= old-results[0] "Andreas"))
    (t.is (= (count current-results) 0))
    (t.is (= (count retract-report.db_after.datoms) 3))
    (t.is (= retract-report.tx_data[0].added false))))

(t.deftest readd-after-retract-makes-fact-current-once
  (defer (free_all context.allocator))
  (let [conn: vev.Conn (vev.create-conn)]
    (discard (vev.transact
               (addr conn)
               ([]vev.Tx-Op
                 [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                  (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])))
    (discard (vev.transact
               (addr conn)
               ([]vev.Tx-Op
                 [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))])))
    (let [report (vev.transact
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
          results (vev.q-strings report.db_after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas"))
      (t.is (= (count report.db_after.datoms) 4)))))
