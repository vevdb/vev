(t.deftest datascript-query-source-relation-join-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan"}
             {:db/id 2 :name "Petr"}
             {:db/id 3 :name "Ivan"}])
        result (vev.q conn.db
                 [:find ?e ?email
                  :in $ $b
                  :where
                  [?e :name ?n]
                  [$b ?n ?email]]
                 [["Ivan" "ivan@mail.ru"]
                  ["Petr" "petr@gmail.com"]])]
    (t.is (= (count result.rows) 3))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].text "ivan@mail.ru"))
    (t.is (= result.rows[1].values[0].entity 2))
    (t.is (= result.rows[1].values[1].text "petr@gmail.com"))
    (t.is (= result.rows[2].values[0].entity 3))
    (t.is (= result.rows[2].values[1].text "ivan@mail.ru"))))

