(package vev-tests)

(import t "kvist:test")
(import vev "../vev_kvist")

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                    (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})
                    (vev.Tx-Meta {a: ":tx/reason" v: (vev.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next_tx 2))
    (t.is (= (count report.db_before.datoms) 0))
    (t.is (= (count report.db_after.datoms) 2))
    (t.is (= (count report.tx_data) 2))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (let [meta-value report.tx_meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (vev.q-strings report.db_after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest tx-data-supports-datomic-tx-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id "datomic.tx"
                   :request/id "req-1"
                   :tx/reason :profile-edit}
                  [:db/add 1 :user/name "Ada"]])]
    (t.is report.ok)
    (t.is (= (count report.tx_data) 1))
    (t.is (= report.tx_data[0].e 1))
    (t.is (= (count report.tempids) 0))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (t.is (= report.tx_meta[0].v.text "req-1"))
    (t.is (= report.tx_meta[1].a ":tx/reason"))
    (t.is (= report.tx_meta[1].v.text ":profile-edit"))))

(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-var "name"))
                   (vev.clause (vev.term-var "e") ":user/age" (vev.term-var "age"))
                   (vev.clause (vev.term-var "e") ":user/active" (vev.term-bool true))])
        query (vev.query ([]string ["e" "name" "age"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 1))
      (t.is (= result.rows[0].values[1].text "Ada"))
      (t.is (= result.rows[0].values[2].kind .Int))
      (t.is (= result.rows[0].values[2].int_value 37))))

(t.deftest datascript-query-test-joins-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 15}
                  {:db/id 2 :name "Petr" :age 37}
                  {:db/id 3 :name "Ivan" :age 37}
                  {:db/id 4 :age 15}])
        ivans (vev.q report.db_after
                [:find ?e ?age
                 :where
                 [?e :name "Ivan"]
                 [?e :age ?age]])
        same-names (vev.q report.db_after
                     [:find ?e1 ?e2
                      :where
                      [?e1 :name ?name]
                      [?e2 :name ?name]])]
    (t.is (= (count ivans.rows) 2))
    (t.is (= ivans.rows[0].values[0].entity 1))
    (t.is (= ivans.rows[0].values[1].int_value 15))
    (t.is (= ivans.rows[1].values[0].entity 3))
    (t.is (= ivans.rows[1].values[1].int_value 37))
    (t.is (= (count same-names.rows) 5))))

(t.deftest datalog-macro-builds-query-from-data-literal
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db_after
                 [:find ?e ?name
                  :where
                  [?e :user/name ?name]
                  [?e :user/active true]])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].kind .Entity))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].kind .String))
    (t.is (= result.rows[0].values[1].text "Ada"))))

