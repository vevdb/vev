               (addr conn)
               [[:db/add 100 :db/ident :user/friend]
                [:db/add 100 :db/valueType :db.type/ref]])
        _ (vev.seed-people (addr conn))
        result (vev.q conn.db
                   [:find ?name
                    :where
                    [1 :user/friend 2]
                    [2 :user/name ?name]])]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text "Grace"))))

