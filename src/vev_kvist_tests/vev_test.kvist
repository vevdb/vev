                             [:find ?name .
                              :where
                              [?e :user/email "ada@example.com"]
                              [?e :user/name ?name]])
        collection (vev.q-collection report.db_after
                     [:find [?name ...]
                      :where
                      [?e :user/name ?name]])
        tuple (vev.q-tuple report.db_after
                [:find [?name ?age]
                 :where
                 [?e :user/email "ada@example.com"]
                 [?e :user/name ?name]
                 [?e :user/age ?age]])]
    (t.is scalar-ok)
    (t.is (= scalar.text "Ada"))
    (t.is (= (count collection) 2))
    (t.is (= collection[0].text "Ada"))
    (t.is (= collection[1].text "Grace"))
    (t.is (= (count tuple) 2))
    (t.is (= tuple[0].text "Ada"))
    (t.is (= tuple[1].int_value 37))))

(t.deftest datascript-query-find-specs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Petr" :age 44}
                  {:db/id 2 :name "Ivan" :age 25}
                  {:db/id 3 :name "Sergey" :age 11}])
        names (vev.q-collection report.db_after
                [:find [?name ...]
                 :where
                 [?e :name ?name]])
        tuple (vev.q-tuple report.db_after
                [:find [?name ?age]
                 :where
                 [1 :name ?name]
                 [1 :age ?age]])
        [scalar scalar-ok] (vev.q-scalar report.db_after
                             [:find ?name .
                              :where
                              [1 :name ?name]])
        count-coll (vev.q-collection report.db_after
                     [:find [(count ?name) ...]
                      :where
                      [?e :name ?name]])
        count-tuple (vev.q-tuple report.db_after
                      [:find [(count ?name)]
                       :where
                       [?e :name ?name]])
        [count-scalar count-scalar-ok] (vev.q-scalar report.db_after
                                         [:find (count ?name) .
                                          :where
                                          [?e :name ?name]])]
    (t.is (= (count names) 3))
    (t.is (= names[0].text "Petr"))
    (t.is (= names[1].text "Ivan"))
    (t.is (= names[2].text "Sergey"))
    (t.is (= (count tuple) 2))
    (t.is (= tuple[0].text "Petr"))
    (t.is (= tuple[1].int_value 44))
    (t.is scalar-ok)
    (t.is (= scalar.text "Petr"))
    (t.is (= (count count-coll) 1))
    (t.is (= count-coll[0].int_value 3))
    (t.is (= (count count-tuple) 1))
    (t.is (= count-tuple[0].int_value 3))
    (t.is count-scalar-ok)
    (t.is (= count-scalar.int_value 3))))

