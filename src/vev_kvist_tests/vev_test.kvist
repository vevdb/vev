                [:db/add 100 :db/cardinality :db.cardinality/many]
                [:db/add 1 :user/friend (vev.value-entity 3)]
                [:db/add 1 :user/friend (vev.value-entity 4)]])
        limit-first (vev.pull conn.db [[:user/friend :limit 1 :as :friends]] 1)
        as-first (vev.pull conn.db [[:user/friend :as :friends :limit 1]] 1)]
      (t.is (= (count limit-first.attrs) 1))
      (t.is (= limit-first.attrs[0].a ":friends"))
      (t.is (= limit-first.attrs[0].v.entity 2))
      (t.is (= (count as-first.attrs) 1))
      (t.is (= as-first.attrs[0].a ":friends"))
      (t.is (= as-first.attrs[0].v.entity 2))))

(t.deftest datascript-pull-bounded-recursion-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
