(t.deftest datascript-query-parameterized-top-n-aggregate-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        result (vev.q conn.db
                 [:find ?color (max ?amount ?x) (min ?amount ?x)
                  :in [[?color ?x]] ?amount]
                 [[:red 1] [:red 2] [:red 3] [:red 4] [:red 5]
                  [:blue 7] [:blue 8]]
                 3)]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text ":red"))
    (t.is (= result.rows[0].values[1].items[0].int_value 3))
