(package vev-tests)

(import t "kvist:test")
(import v "../vev_kvist")

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)
        report (v.transact-with-meta
                 (addr conn)
                 ([]v.Tx-Op
                   [(v.tx-add 1 ":user/email" (v.value-string "a@example.com"))
                    (v.tx-add 1 ":user/name" (v.value-string "Andreas"))])
                 ([]v.Tx-Meta
                   [(v.Tx-Meta {a: ":request/id" v: (v.value-string "req-1")})
                    (v.Tx-Meta {a: ":tx/reason" v: (v.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next_tx 2))
    (t.is (= (count report.db_before.datoms) 0))
    (t.is (= (count report.db_after.datoms) 2))
    (t.is (= (count report.tx_data) 2))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (let [meta-value report.tx_meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (v.q-strings report.db_after (v.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)
        report (v.seed-people (addr conn))
        clauses ([]v.Clause
                  [(v.clause (v.term-var "e") ":user/name" (v.term-var "name"))
                   (v.clause (v.term-var "e") ":user/age" (v.term-var "age"))
                   (v.clause (v.term-var "e") ":user/active" (v.term-bool true))])]
    (let [query (v.query ([]string ["e" "name" "age"]) clauses)
          result (v.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 1))
      (t.is (= result.rows[0].values[1].text "Ada"))
      (t.is (= result.rows[0].values[2].kind .Int))
      (t.is (= result.rows[0].values[2].int_value 37)))))

(t.deftest query-follows-ref-values
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)
        report (v.seed-people (addr conn))
        clauses ([]v.Clause
                  [(v.clause (v.term-var "e") ":user/name" (v.term-string "Ada"))
                   (v.clause (v.term-var "e") ":user/friend" (v.term-var "friend"))
                   (v.clause (v.term-var "friend") ":user/name" (v.term-var "friend-name"))])]
    (let [query (v.query ([]string ["friend" "friend-name"]) clauses)
          result (v.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace")))))

(t.deftest query-can-bind-attributes
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)
        report (v.seed-people (addr conn))
        clauses ([]v.Clause
                  [(v.Clause {e: (v.term-entity 1)
                              a: (v.term-var "attr")
                              v: (v.term-string "Ada")})])]
    (let [query (v.query ([]string ["attr"]) clauses)
          result (v.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Keyword))
      (t.is (= result.rows[0].values[0].text ":user/name")))))

(t.deftest retract-hides-fact-from-current-queries
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)
        add-report (v.transact
                     (addr conn)
                     ([]v.Tx-Op
                       [(v.tx-add 1 ":user/email" (v.value-string "a@example.com"))
                        (v.tx-add 1 ":user/name" (v.value-string "Andreas"))]))
        retract-report (v.transact
                         (addr conn)
                         ([]v.Tx-Op
                           [(v.tx-retract 1 ":user/name" (v.value-string "Andreas"))]))
        old-results (v.q-strings add-report.db_after (v.query-name-by-email "a@example.com"))
        current-results (v.q-strings retract-report.db_after (v.query-name-by-email "a@example.com"))]
    (t.is (= (count old-results) 1))
    (t.is (= old-results[0] "Andreas"))
    (t.is (= (count current-results) 0))
    (t.is (= (count retract-report.db_after.datoms) 3))
    (t.is (= retract-report.tx_data[0].added false))))

(t.deftest readd-after-retract-makes-fact-current-once
  (defer (free_all context.allocator))
  (let [conn: v.Conn (v.create-conn)]
    (discard (v.transact
               (addr conn)
               ([]v.Tx-Op
                 [(v.tx-add 1 ":user/email" (v.value-string "a@example.com"))
                  (v.tx-add 1 ":user/name" (v.value-string "Andreas"))])))
    (discard (v.transact
               (addr conn)
               ([]v.Tx-Op
                 [(v.tx-retract 1 ":user/name" (v.value-string "Andreas"))])))
    (let [report (v.transact
                   (addr conn)
                   ([]v.Tx-Op
                     [(v.tx-add 1 ":user/name" (v.value-string "Andreas"))]))
          results (v.q-strings report.db_after (v.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas"))
      (t.is (= (count report.db_after.datoms) 4)))))
