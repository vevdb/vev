(t.deftest datascript-query-empty-inputs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan"}
             {:db/id 2 :name "Petr"}])
        empty-coll (vev.q-collection conn.db
                     [:find [?id ...]
                      :in [?id ...]
                      :where
                      [?id :age _]]
                     [])
        empty-rel (vev.q-collection conn.db
                    [:find [?id ...]
                     :in [[?id]]
                     :where
                     [?id :age _]]
                    [])]
    (t.is (= (count empty-coll) 0))
    (t.is (= (count empty-rel) 0))))

