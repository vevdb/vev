                 (addr conn)
                 [{:db/id "sergey" :name "Sergey" :friend ["ivan" "petr"]}
                  {:db/id "ivan" :name "Ivan"}
                  {:db/id "petr" :name "Petr"}
                  {:db/id "boris" :name "Boris" :friend "oleg"}
                  {:db/id "oleg" :name "Oleg" :friend "boris"}])
        sergey-friends (vev.q-collection report.db_after
                         [:find [?friend-name ...]
                          :where
                          [?e :name "Sergey"]
                          [?e :friend ?friend]
                          [?friend :name ?friend-name]])
        boris-friends (vev.q-collection report.db_after
                        [:find [?friend-name ...]
                         :where
                         [?e :name "Boris"]
                         [?e :friend ?friend]
                         [?friend :name ?friend-name]])
        oleg-friends (vev.q-collection report.db_after
                       [:find [?friend-name ...]
                        :where
                        [?e :name "Oleg"]
                        [?e :friend ?friend]
                        [?friend :name ?friend-name]])]
    (t.is report.ok)
