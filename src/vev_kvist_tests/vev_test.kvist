(t.deftest datascript-pull-many-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Petr"}
             {:db/id 5 :name "Elizabeth"}
             {:db/id 7 :name "Eunan"}
             {:db/id 9 :name "Rebecca"}])
        pulled (vev.pull-many conn.db [:name] ([]u64 [1 5 7 9]))]
    (t.is (= (count pulled) 4))
    (t.is (= pulled[0].attrs[0].v.text "Petr"))
    (t.is (= pulled[1].attrs[0].v.text "Elizabeth"))
    (t.is (= pulled[2].attrs[0].v.text "Eunan"))
    (t.is (= pulled[3].attrs[0].v.text "Rebecca"))))

(t.deftest datascript-pull-many-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"]}
             {:db/id 5 :name "Elizabeth"}
             {:db/id 7 :name "Eunan"}
             {:db/id 9 :name "Rebecca"}])
        pulled (vev.pull-many
                 conn.db
                 [:aka]
                 [[:name "Elizabeth"]
                  [:name "Petr"]
                  [:name "Eunan"]
                  [:name "Rebecca"]
                  [:name "Unknown"]])]
    (t.is (= (count pulled) 5))
    (t.is (= (count pulled[0].attrs) 0))
    (t.is (= (count pulled[1].attrs) 2))
    (t.is (= pulled[1].attrs[0].v.text "Devil"))
    (t.is (= pulled[1].attrs[1].v.text "Tupen"))
    (t.is (= (count pulled[2].attrs) 0))
    (t.is (= (count pulled[3].attrs) 0))
    (t.is (= (count pulled[4].attrs) 0))))

(t.deftest datascript-pull-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"]}])
        found (vev.pull conn.db [:name :aka] [:name "Petr"])
        missing (vev.pull conn.db [:name :aka] [:name "NotInDatabase"])
        missing-wildcard (vev.pull conn.db [*] [:name "No such name"])]
    (t.is (= (count found.attrs) 3))
    (t.is (= found.attrs[0].v.text "Petr"))
    (t.is (= found.attrs[1].v.text "Devil"))
    (t.is (= found.attrs[2].v.text "Tupen"))
    (t.is (= (count missing.attrs) 0))
    (t.is (= (count missing-wildcard.attrs) 0))))

(t.deftest pull-supports-wildcard
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-retract 1 ":user/name" (vev.value-string "Ada"))]))
        pulled (vev.pull report.db_after [*] 1)]
      (t.is (= (count pulled.attrs) 5))
      (t.is (= pulled.attrs[0].a ":db/id"))
      (t.is (= pulled.attrs[0].v.entity 1))
      (t.is (= pulled.attrs[1].a ":user/active"))
      (t.is (= pulled.attrs[2].a ":user/age"))
      (t.is (= pulled.attrs[3].a ":user/email"))
      (t.is (= pulled.attrs[4].a ":user/friend"))))

(t.deftest pull-wildcard-does-not-duplicate-db-id
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        wildcard-only (vev.pull conn.db [*] 1)
        wildcard-first (vev.pull conn.db [* :db/id] 1)
        id-first (vev.pull conn.db [:db/id *] 1)]
      (t.is (= (count wildcard-first.attrs) (count wildcard-only.attrs)))
      (t.is (= (count id-first.attrs) (count wildcard-only.attrs)))
      (t.is (= wildcard-first.attrs[0].a ":db/id"))
      (t.is (= id-first.attrs[0].a ":db/id"))))

(t.deftest pull-supports-reverse-ref-attrs
  (defer (free_all context.allocator))
