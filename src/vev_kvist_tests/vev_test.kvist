                  {:db/id 4 :ref "B"}
                  {:db/id "A" :name "Alice"}
                  {:db/id "B" :name "Bob"}])
        [first-ref first-ok] (vev.q-scalar report.db_after
                               [:find ?ref .
                                :where
                                [3 :ref ?ref]])
        [second-ref second-ok] (vev.q-scalar report.db_after
                                  [:find ?ref .
                                   :where
                                   [4 :ref ?ref]])]
    (t.is report.ok)
    (t.is (= (count report.tempids) 2))
    (t.is (= report.tempids[0].tempid "A"))
    (t.is (= report.tempids[0].e 1))
    (t.is (= report.tempids[1].tempid "B"))
    (t.is (= report.tempids[1].e 2))
    (t.is first-ok)
    (t.is (= first-ref.entity 1))
    (t.is second-ok)
    (t.is (= second-ref.entity 2))))

