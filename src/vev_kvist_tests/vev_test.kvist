    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[1].values[0].text "Grace"))))

(t.deftest datalog-macro-supports-and-branches-in-or
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db_after
                 [:find ?name
                  :where
                  (or (and [?e :user/active true]
                           [?e :user/age 37])
                      [?e :user/email "grace@example.com"])
                  [?e :user/name ?name]])]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[1].values[0].text "Grace"))))

(t.deftest datalog-macro-supports-top-level-and
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
