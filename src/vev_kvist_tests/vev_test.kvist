(t.deftest datascript-pull-default-limit-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        ops (make [dynamic]vev.Tx-Op)
        idx 0
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :aka :db/cardinality :db.cardinality/many}])]
    (defer (delete ops))
    (while (< idx 1001)
      (arr.push! ops (vev.tx-add 1 ":aka" (vev.value-int (i64 idx))))
      (set! idx (+ idx 1)))
    (vev.transact-ops (addr conn) (slice ops 0))
    (let [default-limit (vev.pull conn.db [:aka] 1)
          explicit-limit (vev.pull conn.db [[:aka :limit 1001]] 1)
          nil-limit (vev.pull conn.db [[:aka :limit nil]] 1)]
      (t.is (= (count default-limit.attrs) 1000))
      (t.is (= (count explicit-limit.attrs) 1001))
      (t.is (= (count nil-limit.attrs) 1001)))))

