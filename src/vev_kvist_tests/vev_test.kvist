(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-var "name"))
                   (vev.clause (vev.term-var "e") ":user/age" (vev.term-var "age"))
                   (vev.clause (vev.term-var "e") ":user/active" (vev.term-bool true))])
        query (vev.query ([]string ["e" "name" "age"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 1))
      (t.is (= result.rows[0].values[1].text "Ada"))
      (t.is (= result.rows[0].values[2].kind .Int))
      (t.is (= result.rows[0].values[2].int_value 37))))

(t.deftest datascript-query-test-joins-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 15}
                  {:db/id 2 :name "Petr" :age 37}
                  {:db/id 3 :name "Ivan" :age 37}
                  {:db/id 4 :age 15}])
        ivans (vev.q report.db_after
                [:find ?e ?age
                 :where
                 [?e :name "Ivan"]
                 [?e :age ?age]])
        same-names (vev.q report.db_after
                     [:find ?e1 ?e2
                      :where
                      [?e1 :name ?name]
                      [?e2 :name ?name]])]
    (t.is (= (count ivans.rows) 2))
    (t.is (= ivans.rows[0].values[0].entity 1))
    (t.is (= ivans.rows[0].values[1].int_value 15))
    (t.is (= ivans.rows[1].values[0].entity 3))
    (t.is (= ivans.rows[1].values[1].int_value 37))
    (t.is (= (count same-names.rows) 5))))

(t.deftest datascript-query-cardinality-many-join-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :aka]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Ivan" :aka ["ivolga" "pi"]}
             {:db/id 2 :name "Petr" :aka ["porosenok" "pi"]}])
        result (vev.q conn.db
                 [:find ?n1 ?n2
                  :where
                  [?e1 :aka ?x]
                  [?e2 :aka ?x]
                  [?e1 :name ?n1]
                  [?e2 :name ?n2]])]
    (t.is (= (count result.rows) 4))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].text "Ivan"))
    (t.is (= result.rows[1].values[0].text "Ivan"))
    (t.is (= result.rows[1].values[1].text "Petr"))
    (t.is (= result.rows[2].values[0].text "Petr"))
    (t.is (= result.rows[2].values[1].text "Ivan"))
    (t.is (= result.rows[3].values[0].text "Petr"))
    (t.is (= result.rows[3].values[1].text "Petr"))))

