    (t.is (= result.rows[0].values[1].items[2].int_value 5))
    (t.is (= result.rows[0].values[2].items[0].int_value 1))
    (t.is (= result.rows[0].values[2].items[1].int_value 2))
    (t.is (= result.rows[0].values[2].items[2].int_value 3))
    (t.is (= result.rows[1].values[0].text ":blue"))
    (t.is (= result.rows[1].values[1].items[0].int_value 7))
    (t.is (= result.rows[1].values[1].items[1].int_value 8))
    (t.is (= result.rows[1].values[2].items[0].int_value 7))
    (t.is (= result.rows[1].values[2].items[1].int_value 8))))

