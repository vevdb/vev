(t.deftest pull-supports-combined-limit-and-as-options
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        _ (vev.transact
               (addr conn)
               [[:db/add 1 :user/friend (vev.value-entity 3)]
                [:db/add 1 :user/friend (vev.value-entity 4)]])
        limit-first (vev.pull conn.db [[:user/friend :limit 1 :as :friends]] 1)
        as-first (vev.pull conn.db [[:user/friend :as :friends :limit 1]] 1)]
      (t.is (= (count limit-first.attrs) 1))
      (t.is (= limit-first.attrs[0].a ":friends"))
      (t.is (= limit-first.attrs[0].v.entity 2))
      (t.is (= (count as-first.attrs) 1))
      (t.is (= as-first.attrs[0].a ":friends"))
      (t.is (= as-first.attrs[0].v.entity 2))))

(t.deftest pull-many-returns-multiple-entities
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        pulled (vev.pull-many conn.db [:db/id :user/name] ([]u64 [1 2]))]
      (t.is (= (count pulled) 2))
      (t.is (= pulled[0].attrs[0].v.entity 1))
      (t.is (= pulled[0].attrs[1].v.text "Ada"))
      (t.is (= pulled[1].attrs[0].v.entity 2))
      (t.is (= pulled[1].attrs[1].v.text "Grace"))))

(t.deftest pull-supports-wildcard
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-retract 1 ":user/name" (vev.value-string "Ada"))]))
        pulled (vev.pull report.db_after [*] 1)]
      (t.is (= (count pulled.attrs) 5))
      (t.is (= pulled.attrs[0].a ":db/id"))
      (t.is (= pulled.attrs[0].v.entity 1))
      (t.is (= pulled.attrs[1].a ":user/active"))
      (t.is (= pulled.attrs[2].a ":user/age"))
      (t.is (= pulled.attrs[3].a ":user/email"))
      (t.is (= pulled.attrs[4].a ":user/friend"))))

(t.deftest pull-wildcard-does-not-duplicate-db-id
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        wildcard-only (vev.pull conn.db [*] 1)
        wildcard-first (vev.pull conn.db [* :db/id] 1)
        id-first (vev.pull conn.db [:db/id *] 1)]
      (t.is (= (count wildcard-first.attrs) (count wildcard-only.attrs)))
      (t.is (= (count id-first.attrs) (count wildcard-only.attrs)))
      (t.is (= wildcard-first.attrs[0].a ":db/id"))
      (t.is (= id-first.attrs[0].a ":db/id"))))

