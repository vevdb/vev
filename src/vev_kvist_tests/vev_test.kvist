      (t.is (= parent.rows[0].values[0].text ":name"))
      (t.is (= parent.rows[0].values[1].text "Ivan"))
      (t.is (= (count child.rows) 0))
      (t.is (= (count unrelated.rows) 1))
      (t.is (= unrelated.rows[0].values[0].text "@4"))))

(t.deftest datascript-components-multival-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :profile]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 1 :name "Ivan"]
              [:db/add 1 :profile (vev.value-entity 3)]
              [:db/add 1 :profile (vev.value-entity 4)]
              [:db/add 3 :email "@3"]
              [:db/add 4 :email "@4"]])
        pulled (vev.pull conn.db [:name :profile] 1)
        profile-parents (vev.entity-refs (vev.db-entity conn.db 3) ":_profile")
        retract-entity (vev.transact (addr conn) [[:db.fn/retractEntity 1]])
        after-entity-retract (vev.q retract-entity.db_after
                               [:find ?a ?v
                                :in [?e ...]
                                :where
                                [?e ?a ?v]]
                               [1 3 4])]
    (t.is (= (count pulled.attrs) 3))
    (t.is (= pulled.attrs[0].v.text "Ivan"))
    (t.is (= pulled.attrs[1].v.entity 3))
    (t.is (= pulled.attrs[1].attrs[1].v.text "@3"))
    (t.is (= pulled.attrs[2].v.entity 4))
    (t.is (= pulled.attrs[2].attrs[1].v.text "@4"))
    (t.is (= (count profile-parents) 1))
    (t.is (= profile-parents[0].e 1))
    (t.is retract-entity.ok)
    (t.is (= (count after-entity-retract.rows) 0)))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :profile]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 1 :name "Ivan"]
              [:db/add 1 :profile (vev.value-entity 3)]
              [:db/add 1 :profile (vev.value-entity 4)]
              [:db/add 3 :email "@3"]
              [:db/add 4 :email "@4"]])
        retract-attr (vev.transact (addr conn) [[:db.fn/retractAttribute 1 :profile]])
        children-after (vev.q retract-attr.db_after
                         [:find ?a ?v
                          :in [?e ...]
                          :where
                          [?e ?a ?v]]
                         [3 4])
        parent-after (vev.q retract-attr.db_after
                       [:find ?a ?v
                        :where
                        [1 ?a ?v]])]
    (t.is retract-attr.ok)
    (t.is (= (count children-after.rows) 0))
    (t.is (= (count parent-after.rows) 1))
    (t.is (= parent-after.rows[0].values[0].text ":name"))
    (t.is (= parent-after.rows[0].values[1].text "Ivan"))))

(t.deftest transact-data-resolves-string-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/name "Existing"]
                  [:db/add "user" :user/email "ada@example.com"]
                  [:db/add "user" :user/name "Ada"]])
        e report.tempids[0].e
        results (vev.q report.db_after
                  [:find ?name
                   :where
                   [?e :user/email "ada@example.com"]
                   [?e :user/name ?name]])]
    (t.is (= (count report.tempids) 1))
    (t.is (= report.tempids[0].tempid "user"))
    (t.is (> e 1))
    (t.is (= report.tx_data[1].e e))
    (t.is (= report.tx_data[2].e e))
    (t.is (= (count results.rows) 1))
    (t.is (= results.rows[0].values[0].text "Ada"))))

(t.deftest schema-enforces-value-type-cardinality-and-unique
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :user/email]
                  [:db/add 100 :db/valueType :db.type/string]
                  [:db/add 100 :db/cardinality :db.cardinality/one]
                  [:db/add 100 :db/unique :db.unique/identity]
                  [:db/add 101 :db/ident :user/age]
                  [:db/add 101 :db/valueType :db.type/long]
                  [:db/add 102 :db/ident :user/status]
                  [:db/add 102 :db/valueType :db.type/keyword]
                  [:db/add 103 :db/ident :user/admin]
                  [:db/add 103 :db/valueType :db.type/boolean]])
        ok-report (vev.transact
                    (addr conn)
                    [[:db/add 1 :user/email "ada@example.com"]
                     [:db/add 1 :user/age 37]
                     [:db/add 1 :user/status :user.status/active]
                     [:db/add 1 :user/admin true]])
        bad-type (vev.transact
                   (addr conn)
                   [[:db/add 2 :user/age "old"]])
        bad-keyword (vev.transact
                      (addr conn)
                      [[:db/add 2 :user/status "active"]])
        bad-bool (vev.transact
                   (addr conn)
                   [[:db/add 2 :user/admin "true"]])
        duplicate-email (vev.transact
                          (addr conn)
                          [[:db/add 2 :user/email "ada@example.com"]])
        second-email (vev.transact
                       (addr conn)
                       [[:db/add 1 :user/email "ada2@example.com"]])
        current-email (vev.q second-email.db_after
                        [:find ?email
                         :where
                         [1 :user/email ?email]])]
    (t.is schema.ok)
    (t.is ok-report.ok)
    (t.is (not bad-type.ok))
    (t.is (= bad-type.error "schema value type mismatch"))
    (t.is (not bad-keyword.ok))
    (t.is (= bad-keyword.error "schema value type mismatch"))
    (t.is (not bad-bool.ok))
    (t.is (= bad-bool.error "schema value type mismatch"))
    (t.is (not duplicate-email.ok))
    (t.is (= duplicate-email.error "schema unique conflict"))
    (t.is second-email.ok)
    (t.is (= (count current-email.rows) 1))
    (t.is (= current-email.rows[0].values[0].text "ada2@example.com"))))

(t.deftest datascript-unique-value-does-not-upsert
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/value]
             [:db/add 1 :name "Ivan"]])
        conflict (vev.transact
                   (addr conn)
                   [{:name "Ivan" :age 35}])
        lookup-ref (vev.transact
                     (addr conn)
                     [[:db/add [:name "Ivan"] :age 36]])
        [age age-ok] (vev.q-scalar lookup-ref.db_after
                       [:find ?age .
                        :where
                        [1 :age ?age]])]
    (t.is (not conflict.ok))
    (t.is (= conflict.error "schema unique conflict"))
    (t.is lookup-ref.ok)
    (t.is age-ok)
    (t.is (= age.int_value 36))))

(t.deftest datascript-validation-rejects-nil-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact (addr conn) [[:db/add 1 :name nil]])]
    (t.is (not report.ok))
    (t.is (= report.error "cannot store nil"))
    (t.is (= (count conn.db.datoms) 0))))

(t.deftest datascript-tuple-attrs-derived-tx-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        schema (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]])
        [after-a after-a-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-and-b ?tuple]])
        _ (vev.transact (addr conn) [[:db/add 1 :b "B"]])
        [after-b after-b-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-and-b ?tuple]])
        direct (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.add 2 ":a-and-b"
                      (vev.value-vector2
                        (vev.value-string "A")
                        (vev.value-string "B")))]))
        _ (vev.transact (addr conn) [[:db/retract 1 :a "A"]
                                     [:db/retract 1 :b "B"]])
        gone (vev.q conn.db
               [:find ?tuple
                :where
                [1 :a-and-b ?tuple]])]
    (t.is schema.ok)
    (t.is after-a-ok)
    (t.is (= after-a.kind .Vector))
    (t.is (= after-a.items[0].text "A"))
    (t.is (= after-a.items[1].kind .Nil))
    (t.is after-b-ok)
    (t.is (= after-b.items[0].text "A"))
    (t.is (= after-b.items[1].text "B"))
    (t.is (not direct.ok))
    (t.is (= direct.error "cannot modify tuple attrs directly"))
    (t.is (= (count gone.rows) 0))))

(t.deftest datascript-tuple-attrs-maintains-multiple-tuples-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        two-schema (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice two-schema 0))
        three-schema (vev.transact
                       (addr conn)
                       ([]vev.Tx-Data
                         [(vev.add 101 ":db/ident" (vev.value-keyword ":a-c-d"))
                          (vev.add 101 ":db/tupleAttrs"
                            (vev.value-vector
                              ([]vev.Value
                                [(vev.value-keyword ":a")
                                 (vev.value-keyword ":c")
                                 (vev.value-keyword ":d")])))]))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]])
        [after-a after-a-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/add 1 :b "B"]
                                     [:db/add 1 :c "C"]
                                     [:db/add 1 :d "D"]])
        [after-all after-all-ok] (vev.q-scalar conn.db
                                   [:find ?tuple .
                                    :where
                                    [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/retract 1 :a "A"]])
        [after-retract-a after-retract-a-ok] (vev.q-scalar conn.db
                                               [:find ?tuple .
                                                :where
                                                [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/retract 1 :c "C"]
                                     [:db/retract 1 :d "D"]])
        gone (vev.q conn.db
               [:find ?tuple
                :where
                [1 :a-c-d ?tuple]])]
    (t.is three-schema.ok)
    (t.is after-a-ok)
    (t.is (= after-a.items[0].text "A"))
    (t.is (= after-a.items[1].kind .Nil))
    (t.is (= after-a.items[2].kind .Nil))
    (t.is after-all-ok)
    (t.is (= after-all.items[0].text "A"))
    (t.is (= after-all.items[1].text "C"))
    (t.is (= after-all.items[2].text "D"))
    (t.is after-retract-a-ok)
    (t.is (= after-retract-a.items[0].kind .Nil))
    (t.is (= after-retract-a.items[1].text "C"))
    (t.is (= after-retract-a.items[2].text "D"))
    (t.is (= (count gone.rows) 0))))

(t.deftest datascript-tuple-attrs-ignore-correct-direct-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]
                                     [:db/add 1 :b "B"]])
        ok (vev.transact
             (addr conn)
             ([]vev.Tx-Data
               [(vev.add 1 ":a-and-b"
                  (vev.value-vector2
                    (vev.value-string "A")
                    (vev.value-string "B")))]))
        bad (vev.transact
              (addr conn)
              ([]vev.Tx-Data
                [(vev.add 1 ":a-and-b"
                   (vev.value-vector2
                     (vev.value-string "A")
                     (vev.value-string "wrong")))]))]
    (t.is ok.ok)
    (t.is (= (count ok.tx_data) 0))
    (t.is (not bad.ok))
    (t.is (= bad.error "cannot modify tuple attrs directly"))))

(t.deftest datascript-tuple-attrs-rejects-direct-retract-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]
                                     [:db/add 1 :b "B"]])
        direct (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.retract 1 ":a-and-b"
                      (vev.value-vector2
                        (vev.value-string "A")
                        (vev.value-string "B")))]))
        attr (vev.transact (addr conn) [[:db.fn/retractAttribute 1 :a-and-b]])
        still-there (vev.q conn.db
                      [:find ?tuple
                       :where
                       [1 :a-and-b ?tuple]])]
    (t.is (not direct.ok))
    (t.is (= direct.error "cannot modify tuple attrs directly"))
    (t.is (not attr.ok))
    (t.is (= attr.error "cannot modify tuple attrs directly"))
    (t.is (= (count still-there.rows) 1))))

(t.deftest datascript-tuple-attrs-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]
                                     [:db/add 1 :b "B"]])
        report (vev.transact
                 (addr conn)
                 [[:db/add [:a-and-b ["A" "B"]] :c "C"]])
        [c c-ok] (vev.q-scalar report.db_after
