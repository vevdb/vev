                [:db/add 1 :user/friend (vev.value-entity 2)])]
    (t.is (= (count items) 5))
    (t.is (= items[0].op ":db/add"))
    (t.is (= items[0].a ":user/name"))
    (t.is (= items[0].v.kind .String))
    (t.is (= items[1].v.kind .Int))
    (t.is (= items[1].v.int_value 37))
    (t.is (= items[2].v.kind .Bool))
    (t.is (= items[2].v.bool_value true))
    (t.is (= items[3].v.kind .Keyword))
    (t.is (= items[3].v.text ":user.status/active"))
    (t.is (= items[4].v.kind .Entity))
    (t.is (= items[4].v.entity 2))))

(t.deftest query-follows-ref-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-string "Ada"))
                   (vev.clause (vev.term-var "e") ":user/friend" (vev.term-var "friend"))
                   (vev.clause (vev.term-var "friend") ":user/name" (vev.term-var "friend-name"))])
        query (vev.query ([]string ["friend" "friend-name"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace"))))

