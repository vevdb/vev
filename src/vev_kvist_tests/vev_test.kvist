        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :ref]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 101 :db/unique :db.unique/identity]])
        report (vev.transact
                 (addr conn)
                 [{:db/id "igor" :name "Igor"}
                  {:db/id "anna" :name "Anna" :ref "igor"}])
        [igor igor-ok] (vev.q-scalar report.db_after
                         [:find ?e .
                          :where
                          [?e :name "Igor"]])
        [anna-ref anna-ref-ok] (vev.q-scalar report.db_after
                                  [:find ?ref .
                                   :where
                                   [?e :name "Anna"]
                                   [?e :ref ?ref]])]
    (t.is report.ok)
    (t.is igor-ok)
    (t.is anna-ref-ok)
    (t.is (= anna-ref.entity igor.entity))))

(t.deftest datascript-upsert-string-tempid-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :ref]
             [:db/add 101 :db/valueType :db.type/ref]
             {:name "Alice"}])
        report (vev.transact
                 (addr conn)
                 [{:db/id "user" :name "Alice"}
                  {:age 36 :ref "user"}])
        [ref ref-ok] (vev.q-scalar report.db_after
                       [:find ?ref .
                        :where
                        [?e :age 36]
                        [?e :ref ?ref]])
        [alice alice-ok] (vev.q-scalar report.db_after
                           [:find ?alice .
                            :where
                            [?alice :name "Alice"]])]
    (t.is report.ok)
    (t.is (= (count report.tempids) 2))
    (t.is (= report.tempids[0].tempid "user"))
    (t.is ref-ok)
    (t.is alice-ok)
    (t.is (= report.tempids[0].e alice.entity))
    (t.is (= ref.entity alice.entity))))

(t.deftest datascript-upsert-string-tempid-ref-vector-subset
  (defer (free_all context.allocator))
