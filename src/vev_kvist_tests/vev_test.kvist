(t.deftest transact-data-uses-datomic-shaped-ops
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/email "ada@example.com"]
                  [:db/add 1 :user/name "Ada"]
                  [:db/retract 1 :user/name "Ada"]])
        results (vev.q-strings report.db_after (vev.query-name-by-email "ada@example.com"))]
    (t.is (= (count report.tx_data) 3))
    (t.is (= report.tx_data[0].added true))
    (t.is (= report.tx_data[2].added false))
    (t.is (= (count results) 0))))

(t.deftest transact-data-supports-retract-without-value
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [report (vev.transact (addr conn) [[:db/retract 1 :user/name]])
          result (vev.q report.db_after
                   [:find ?age
                    :where
                    [1 :user/age ?age]])
          names (vev.q report.db_after
                  [:find ?name
                   :where
                   [1 :user/name ?name]])]
      (t.is report.ok)
      (t.is (= (count report.tx_data) 1))
      (t.is (= report.tx_data[0].a ":user/name"))
      (t.is (= report.tx_data[0].v.text "Ada"))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].int_value 37))
      (t.is (= (count names.rows) 0)))))

(t.deftest transact-data-supports-retract-entity
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
