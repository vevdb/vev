(t.deftest datascript-ident-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :ref]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :db/ident :ent1]
             [:db/add 2 :db/ident :ent2]])
        _ (vev.transact
            (addr conn)
            [[:db/add 2 :ref :ent1]])
        [ref-value ref-ok] (vev.q-scalar conn.db
                             [:find ?v .
                              :where
                              [:ent2 :ref ?v]])
        [ref-entity ref-entity-ok] (vev.q-scalar conn.db
                                      [:find ?f .
                                       :where
                                       [?f :ref :ent1]])
        report (vev.transact
                 (addr conn)
                 [[:db/add :ent1 :ref :ent2]])
        pulled (vev.pull report.db_after [*] :ent1)]
    (t.is ref-ok)
    (t.is (= ref-value.entity 1))
    (t.is ref-entity-ok)
    (t.is (= ref-entity.entity 2))
    (t.is report.ok)
    (t.is (= (count pulled.attrs) 3))
    (t.is (= pulled.attrs[0].a ":db/id"))
    (t.is (= pulled.attrs[0].v.entity 1))
    (t.is (= pulled.attrs[1].a ":db/ident"))))

