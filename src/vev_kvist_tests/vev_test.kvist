(t.deftest datascript-index-avet-schema-filter-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :age]
             [:db/add 100 :db/index true]
             [:db/add 101 :db/ident :name]
             [:db/add 102 :db/ident :email]
             [:db/add 102 :db/unique :db.unique/identity]])
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :name "Petr"]
             [:db/add 1 :age 44]
             [:db/add 1 :email "petr@example.com"]])
        age (vev.datoms conn.db :avet :age)
        email (vev.datoms conn.db :avet :email)
        name (vev.datoms conn.db :avet :name)
        name-range (vev.index-range conn.db :name nil nil)
        avet-ok (vev.datoms-checked conn.db :avet)
        name-error (vev.datoms-checked conn.db :avet :name)
        alias-error (vev.datoms-checked conn.db :avet :alias)
        name-value-error (vev.datoms-checked conn.db :avet :name "Petr")
        seek-alias-error (vev.seek-datoms-checked conn.db :avet :alias)
        rseek-alias-error (vev.rseek-datoms-checked conn.db :avet :alias)
        range-alias-error (vev.index-range-checked conn.db :alias "a" "z")]
    (t.is (= (count age) 1))
    (t.is (= age[0].v.int_value 44))
    (t.is (= (count email) 1))
    (t.is (= email[0].v.text "petr@example.com"))
    (t.is (= (count name) 0))
    (t.is (= (count name-range) 0))
    (t.is avet-ok.ok)
    (t.is (= (count avet-ok.datoms) 2))
    (t.is (not name-error.ok))
    (t.is (= name-error.error "attribute should be marked as :db/index true"))
    (t.is (not alias-error.ok))
    (t.is (= alias-error.error "attribute should be marked as :db/index true"))
    (t.is (not name-value-error.ok))
    (t.is (not seek-alias-error.ok))
    (t.is (not rseek-alias-error.ok))
    (t.is (not range-alias-error.ok))))

(t.deftest datascript-index-sequence-compare-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :path]
             [:db/add 100 :db/index true]])
        _ (vev.transact
            (addr conn)
            ([]vev.Tx-Data
              [(vev.add 1 ":path"
                 (vev.value-vector
                   ([]vev.Value [(vev.value-int 1)
                                  (vev.value-int 2)])))
               (vev.add 2 ":path"
                 (vev.value-vector
                   ([]vev.Value [(vev.value-int 1)
                                  (vev.value-int 2)
                                  (vev.value-int 3)])))]))
        prefix (vev.datoms conn.db :avet :path [1])
        exact-short (vev.datoms conn.db :avet :path [1 2])
        between (vev.datoms conn.db :avet :path [1 2 2])
        exact-long (vev.datoms conn.db :avet :path [1 2 3])
        too-long (vev.datoms conn.db :avet :path [1 2 3 4])]
    (t.is (= (count prefix) 0))
    (t.is (= (count exact-short) 1))
    (t.is (= exact-short[0].e 1))
    (t.is (= (count between) 0))
    (t.is (= (count exact-long) 1))
    (t.is (= exact-long[0].e 2))
    (t.is (= (count too-long) 0))))

(t.deftest datalog-macro-supports-ground
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        scalar (vev.q report.db_after
                 [:find ?name
                  :where
                  [(ground "Ada") ?name]
                  [?e :user/name ?name]])
        coll (vev.q report.db_after
               [:find ?name
                :where
                [(ground ["Ada" "Grace"]) [?name ...]]
                [?e :user/name ?name]])]
    (t.is (= (count scalar.rows) 1))
    (t.is (= scalar.rows[0].values[0].text "Ada"))
    (t.is (= (count coll.rows) 2))))

(t.deftest datascript-query-fns-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :parent :db/valueType :db.type/ref}
             {:db/id 1 :name "Ivan" :age 15}
             {:db/id 2 :name "Petr" :age 22 :height 240 :parent 1}
             {:db/id 3 :name "Slava" :age 37 :parent 2}
             {:db/id 10 :mixed 0}
             {:db/id 11 :mixed 1}
             {:db/id 12 :mixed ""}
             {:db/id 20 :score -1}
             {:db/id 21 :score 0}
             {:db/id 22 :score 2}
             {:db/id 23 :score 3}])
        pred-no-free-vars (vev.q-collection conn.db
                            [:find [?x ...]
                             :in [?x ...]
                             :where
                             [(> 2 1)]]
                            [:a :b :c])
        ground-vowels (vev.q-collection conn.db
                        [:find [?vowel ...]
                         :where
                         [(ground [:a :e :i :o :u]) [?vowel ...]]])
        ground-tuple (vev.q conn.db
                       [:find ?a ?c
                        :where
                        [(ground [:a :b :c]) [?a _ ?c]]])
        get-else (vev.q conn.db
                   [:find ?e ?age ?height
                    :where
                    [?e :age ?age]
                    [(get-else $ ?e :height 300) ?height]])
        get-some (vev.q conn.db
                   [:find ?e ?a ?v
                    :where
                    [?e :name _]
                    [(get-some $ ?e :height :age) [?a ?v]]])
        missing (vev.q conn.db
                  [:find ?e ?age
                   :where
                   [?e :age ?age]
                   [(missing? $ ?e :height)]])
        missing-back-ref (vev.q-collection conn.db
                           [:find [?e ...]
                            :where
                            [?e :age ?age]
                            [(missing? $ ?e :_parent)]])
        less-than (vev.q conn.db
                    [:find ?e1 ?e2
                     :where
                     [?e1 :age ?a1]
                     [?e2 :age ?a2]
                     [(< ?a1 18 ?a2)]])
        greater-equal (vev.q-collection conn.db
                        [:find [?age ...]
                         :where
                         [_ :age ?age]
                         [(>= ?age 22)]])
        plain-predicate (vev.q conn.db
                          [:find ?e ?age
                           :where
                           [?e :age ?age]
                           [(> ?age 20)]])
        predicate-join (vev.q conn.db
                         [:find ?e ?e2
                          :where
                          [?e :name]
                          [?e2 :name]
                          [(< ?e ?e2)]])
        const-true (vev.q-collection conn.db
                     [:find [?e ...]
                      :where
                      [?e :name "Petr"]
                      [?e :age 22]
                      [(= ?e 2)]])
        const-false (vev.q-collection conn.db
                      [:find [?e ...]
                       :where
                       [?e :name "Petr"]
                       [?e :age 22]
                       [(= ?e 1)]])
        mixed-greater (vev.q-collection conn.db
                        [:find [?value ...]
                         :where
                         [_ :mixed ?value]
                         [(> ?value 1)]])
        mixed-less-equal (vev.q-collection conn.db
                           [:find [?value ...]
                            :where
                            [_ :mixed ?value]
                            [(<= ?value 1)]])
        even-scores (vev.q-collection conn.db
                      [:find [?score ...]
                       :where
                       [_ :score ?score]
                       [(even? ?score)]])
        odd-scores (vev.q-collection conn.db
                     [:find [?score ...]
                      :where
                      [_ :score ?score]
                      [(odd? ?score)]])
        zero-scores (vev.q-collection conn.db
                      [:find [?score ...]
                       :where
                       [_ :score ?score]
                       [(zero? ?score)]])
        pos-scores (vev.q-collection conn.db
                     [:find [?score ...]
                      :where
                      [_ :score ?score]
                      [(pos? ?score)]])
        neg-scores (vev.q-collection conn.db
                     [:find [?score ...]
                      :where
                      [_ :score ?score]
                      [(neg? ?score)]])]
    (t.is (= (count pred-no-free-vars) 3))
    (t.is (= pred-no-free-vars[0].text ":a"))
    (t.is (= pred-no-free-vars[2].text ":c"))
    (t.is (= (count ground-vowels) 5))
    (t.is (= ground-vowels[0].text ":a"))
    (t.is (= ground-vowels[4].text ":u"))
    (t.is (= (count ground-tuple.rows) 1))
    (t.is (= ground-tuple.rows[0].values[0].text ":a"))
    (t.is (= ground-tuple.rows[0].values[1].text ":c"))
    (t.is (= (count get-else.rows) 3))
    (t.is (= get-else.rows[0].values[2].int_value 300))
    (t.is (= get-else.rows[1].values[2].int_value 240))
    (t.is (= get-else.rows[2].values[2].int_value 300))
    (t.is (= (count get-some.rows) 3))
    (t.is (= get-some.rows[0].values[1].text ":age"))
    (t.is (= get-some.rows[1].values[1].text ":height"))
    (t.is (= get-some.rows[2].values[1].text ":age"))
    (t.is (= (count missing.rows) 2))
    (t.is (= missing.rows[0].values[0].entity 1))
    (t.is (= missing.rows[1].values[0].entity 3))
    (t.is (= (count missing-back-ref) 1))
    (t.is (= missing-back-ref[0].entity 3))
    (t.is (= (count less-than.rows) 2))
    (t.is (= less-than.rows[0].values[0].entity 1))
    (t.is (= less-than.rows[0].values[1].entity 2))
    (t.is (= (count greater-equal) 2))
    (t.is (= greater-equal[0].int_value 22))
    (t.is (= greater-equal[1].int_value 37))
    (t.is (= (count plain-predicate.rows) 2))
    (t.is (= plain-predicate.rows[0].values[0].entity 2))
    (t.is (= plain-predicate.rows[0].values[1].int_value 22))
    (t.is (= plain-predicate.rows[1].values[0].entity 3))
    (t.is (= plain-predicate.rows[1].values[1].int_value 37))
    (t.is (= (count predicate-join.rows) 3))
    (t.is (= predicate-join.rows[0].values[0].entity 1))
    (t.is (= predicate-join.rows[0].values[1].entity 2))
    (t.is (= predicate-join.rows[2].values[0].entity 2))
    (t.is (= predicate-join.rows[2].values[1].entity 3))
    (t.is (= (count const-true) 1))
    (t.is (= const-true[0].entity 2))
    (t.is (= (count const-false) 0))
    (t.is (= (count mixed-greater) 1))
    (t.is (= mixed-greater[0].text ""))
    (t.is (= (count mixed-less-equal) 2))
    (t.is (= mixed-less-equal[0].int_value 0))
    (t.is (= mixed-less-equal[1].int_value 1))
    (t.is (= (count even-scores) 2))
    (t.is (= even-scores[0].int_value 0))
    (t.is (= even-scores[1].int_value 2))
    (t.is (= (count odd-scores) 2))
    (t.is (= odd-scores[0].int_value -1))
    (t.is (= odd-scores[1].int_value 3))
    (t.is (= (count zero-scores) 1))
    (t.is (= zero-scores[0].int_value 0))
    (t.is (= (count pos-scores) 2))
    (t.is (= pos-scores[0].int_value 2))
    (t.is (= pos-scores[1].int_value 3))
    (t.is (= (count neg-scores) 1))
    (t.is (= neg-scores[0].int_value -1))))

(t.deftest datascript-query-fns-lookup-ref-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :name :db/valueType :db.type/string :db/unique :db.unique/identity}
             {:db/id 101 :db/ident :age}
             {:db/id 102 :db/ident :height}])
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 15}
             {:db/id 2 :name "Petr" :age 22 :height 240}])
        [height height-ok] (vev.q-scalar conn.db
                             [:find ?height .
                              :in ?e
                              :where
                              [(get-else $ ?e :height "Unknown") ?height]]
                             [:name "Ivan"])
        some (vev.q conn.db
               [:find ?e ?a ?v
                :in ?e
                :where
                [(get-some $ ?e :weight :age :height) [?a ?v]]]
               [:name "Petr"])]
    (t.is height-ok)
    (t.is (= height.text "Unknown"))
    (t.is (= (count some.rows) 1))
    (t.is (= some.rows[0].values[0].entity 2))
    (t.is (= some.rows[0].values[1].text ":age"))
    (t.is (= some.rows[0].values[2].int_value 22))))

(t.deftest datascript-query-function-result-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :age 15}
             {:db/id 2 :age 22}
             {:db/id 3 :age 37}])
        counted (vev.q conn.db
                  [:find ?x ?c
                   :in [?x ...]
                   :where
                   [(count ?x) ?c]]
                  ["a" "abc"])
        vector-tx (vev.q-collection conn.db
                    [:find [?tx-data ...]
                     :where
                     [(ground :db/add) ?op]
                     [(vector ?op -1 :attr 12) ?tx-data]])
        map-tx (vev.q-collection conn.db
                 [:find [?tx-data ...]
                  :where
                  [(hash-map :db/id -1 :age 92 :name "Aaron") ?tx-data]])
        map-order (vev.q-collection conn.db
                    [:find [?m ...]
                     :where
                     [(hash-map :a 1 :b 2) ?m]
                     [(hash-map :b 2 :a 1) ?m]])
        map-get (vev.q conn.db
                  [:find ?m ?v
                   :where
                   [(hash-map :b 1 :d 2) ?m]
                   [(get ?m :d) ?v]])
        summed (vev.q conn.db
                 [:find ?e1 ?e2 ?e3
                  :where
                  [?e1 :age ?a1]
                  [?e2 :age ?a2]
                  [?e3 :age ?a3]
                  [(+ ?a1 ?a2) ?a12]
                  [(= ?a12 ?a3)]])
        incremented (vev.q conn.db
                      [:find ?age ?next
                       :where
                       [_ :age ?age]
                       [(inc ?age) ?next]])
        conflicting (vev.q conn.db
                      [:find ?n
                       :in ?n
                       :where
                       [(+ 1 2) ?n]]
                      4)
        identity-conflict (vev.q conn.db
                            [:find ?n
                             :where
                             [(identity 1) ?n]
                             [(identity 2) ?n]])
        destructured (vev.q conn.db
                       [:find ?n ?x
                        :where
                        [(identity [3 4]) [?n ?x]]])
        destructured-conflict (vev.q conn.db
                                [:find ?n ?x
                                 :where
                                 [(identity [3 4]) [?n ?x]]
                                 [(identity [1 2]) [?n ?x]]])
        pair-unification (vev.q conn.db
                           [:find ?pair ?x
                            :in [[?e ?attr ?pair]]
                            :where
                            [(first ?pair) ?x]
                            [(second ?pair) ?x]]
                           [[1 :pair [:a :a]]
                            [2 :pair [:b :c]]])
        rel-function-conflict (vev.q conn.db
                                [:find ?age
                                 :where
                                 [_ :age ?age]
                                 [(identity 100) ?age]])
        nil-result-filtered (vev.q conn.db
                              [:find ?x
                               :where
                               [(first []) ?x]])
        ground-scalar-output (vev.q conn.db
                               [:find ?in
                                :in ?in
                                :where
                                [(ground ?in) _]]
                               :a)
        ground-relation-output (vev.q conn.db
                                 [:find ?x ?z
                                  :in ?in
                                  :where
                                  [(ground ?in) [[?x _ ?z] ...]]]
                                 [[:a :b :c]
                                  [:d :e :f]])]
    (t.is (= (count counted.rows) 2))
    (t.is (= counted.rows[0].values[0].text "a"))
    (t.is (= counted.rows[0].values[1].int_value 1))
    (t.is (= counted.rows[1].values[0].text "abc"))
    (t.is (= counted.rows[1].values[1].int_value 3))
    (t.is (= (count vector-tx) 1))
    (t.is (= vector-tx[0].kind .Vector))
    (t.is (= (count vector-tx[0].items) 4))
    (t.is (= vector-tx[0].items[0].text ":db/add"))
    (t.is (= vector-tx[0].items[1].int_value -1))
    (t.is (= vector-tx[0].items[2].text ":attr"))
    (t.is (= vector-tx[0].items[3].int_value 12))
    (t.is (= (count map-tx) 1))
    (t.is (= map-tx[0].kind .Map))
    (t.is (= (count map-tx[0].items) 6))
    (t.is (= map-tx[0].items[0].text ":db/id"))
    (t.is (= map-tx[0].items[1].int_value -1))
    (t.is (= map-tx[0].items[2].text ":age"))
    (t.is (= map-tx[0].items[3].int_value 92))
    (t.is (= map-tx[0].items[4].text ":name"))
    (t.is (= map-tx[0].items[5].text "Aaron"))
    (t.is (= (count map-order) 1))
    (t.is (= map-order[0].kind .Map))
    (t.is (= (count map-get.rows) 1))
    (t.is (= map-get.rows[0].values[0].kind .Map))
    (t.is (= map-get.rows[0].values[1].int_value 2))
    (t.is (= (count summed.rows) 2))
    (t.is (= summed.rows[0].values[0].entity 1))
    (t.is (= summed.rows[0].values[1].entity 2))
    (t.is (= summed.rows[0].values[2].entity 3))
    (t.is (= summed.rows[1].values[0].entity 2))
    (t.is (= summed.rows[1].values[1].entity 1))
    (t.is (= summed.rows[1].values[2].entity 3))
    (t.is (= (count incremented.rows) 3))
    (t.is (= incremented.rows[0].values[0].int_value 15))
    (t.is (= incremented.rows[0].values[1].int_value 16))
    (t.is (= incremented.rows[2].values[0].int_value 37))
    (t.is (= incremented.rows[2].values[1].int_value 38))
    (t.is (= (count conflicting.rows) 0))
    (t.is (= (count identity-conflict.rows) 0))
    (t.is (= (count destructured.rows) 1))
    (t.is (= destructured.rows[0].values[0].int_value 3))
    (t.is (= destructured.rows[0].values[1].int_value 4))
    (t.is (= (count destructured-conflict.rows) 0))
    (t.is (= (count pair-unification.rows) 1))
    (t.is (= pair-unification.rows[0].values[0].kind .Vector))
    (t.is (= pair-unification.rows[0].values[0].items[0].text ":a"))
    (t.is (= pair-unification.rows[0].values[0].items[1].text ":a"))
    (t.is (= pair-unification.rows[0].values[1].text ":a"))
    (t.is (= (count rel-function-conflict.rows) 0))
    (t.is (= (count nil-result-filtered.rows) 0))
    (t.is (= (count ground-scalar-output.rows) 1))
    (t.is (= ground-scalar-output.rows[0].values[0].text ":a"))
    (t.is (= (count ground-relation-output.rows) 2))
    (t.is (= ground-relation-output.rows[0].values[0].text ":a"))
    (t.is (= ground-relation-output.rows[0].values[1].text ":c"))
    (t.is (= ground-relation-output.rows[1].values[0].text ":d"))
    (t.is (= ground-relation-output.rows[1].values[1].text ":f"))))

