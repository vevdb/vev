                 [:find ?a ?v
                  :where
                  [1 ?a ?v]])
        child (vev.q report.db_after
                [:find ?a ?v
                 :where
                 [3 ?a ?v]])
        unrelated (vev.q report.db_after
                    [:find ?email
                     :where
                     [4 :email ?email]])]
      (t.is report.ok)
