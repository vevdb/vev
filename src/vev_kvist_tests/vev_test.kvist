        [alice alice-ok] (vev.q-scalar report.db_after
                           [:find ?alice .
                            :where
                            [?alice :name "Alice"]])]
    (t.is report.ok)
    (t.is ref-ok)
    (t.is alice-ok)
    (t.is (= ref.entity alice.entity))))

(t.deftest datascript-upsert-forward-string-tempid-refs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
