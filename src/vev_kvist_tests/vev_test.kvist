(t.deftest datascript-query-constant-substitution-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 5 :a "5a"]
             [:db/add 5 :b "5b"]
             [:db/add 5 :c "5c"]
             [:db/add 6 :b "6b"]])
        value (vev.q conn.db
                [:find ?v
                 :where
                 [5 :b ?v]])
        attr (vev.q conn.db
               [:find ?a
                :where
                [5 ?a "5b"]])
        entity (vev.q conn.db
                 [:find ?e
                  :where
                  [?e :b "5b"]])
        input-entity (vev.q conn.db
                       [:find ?a ?v
                        :in ?e
                        :where
                        [?e ?a ?v]]
                       5)
        input-value (vev.q conn.db
                      [:find ?e ?a
                       :in ?v
                       :where
                       [?e ?a ?v]]
                      "5b")]
    (t.is (= (count value.rows) 1))
    (t.is (= value.rows[0].values[0].text "5b"))
    (t.is (= (count attr.rows) 1))
    (t.is (= attr.rows[0].values[0].text ":b"))
    (t.is (= (count entity.rows) 1))
    (t.is (= entity.rows[0].values[0].entity 5))
    (t.is (= (count input-entity.rows) 3))
    (t.is (= input-entity.rows[0].values[0].text ":a"))
    (t.is (= input-entity.rows[0].values[1].text "5a"))
    (t.is (= input-entity.rows[1].values[0].text ":b"))
    (t.is (= input-entity.rows[1].values[1].text "5b"))
    (t.is (= input-entity.rows[2].values[0].text ":c"))
    (t.is (= input-entity.rows[2].values[1].text "5c"))
    (t.is (= (count input-value.rows) 1))
    (t.is (= input-value.rows[0].values[0].entity 5))
    (t.is (= input-value.rows[0].values[1].text ":b"))))

