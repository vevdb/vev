      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace")))))

(t.deftest transact-data-resolves-string-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/name "Existing"]
                  [:db/add "user" :user/email "ada@example.com"]
                  [:db/add "user" :user/name "Ada"]])
        e report.tempids[0].e
        results (vev.q report.db_after
                  [:find ?name
                   :where
                   [?e :user/email "ada@example.com"]
                   [?e :user/name ?name]])]
    (t.is (= (count report.tempids) 1))
    (t.is (= report.tempids[0].tempid "user"))
    (t.is (> e 1))
    (t.is (= report.tx_data[1].e e))
    (t.is (= report.tx_data[2].e e))
    (t.is (= (count results.rows) 1))
    (t.is (= results.rows[0].values[0].text "Ada"))))

(t.deftest schema-enforces-value-type-cardinality-and-unique
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :user/email]
                  [:db/add 100 :db/valueType :db.type/string]
                  [:db/add 100 :db/cardinality :db.cardinality/one]
                  [:db/add 100 :db/unique :db.unique/identity]
                  [:db/add 101 :db/ident :user/age]
                  [:db/add 101 :db/valueType :db.type/long]])
        ok-report (vev.transact
                    (addr conn)
                    [[:db/add 1 :user/email "ada@example.com"]
                     [:db/add 1 :user/age 37]])
        bad-type (vev.transact
                   (addr conn)
                   [[:db/add 2 :user/age "old"]])
        duplicate-email (vev.transact
                          (addr conn)
                          [[:db/add 2 :user/email "ada@example.com"]])
        second-email (vev.transact
                       (addr conn)
                       [[:db/add 1 :user/email "ada2@example.com"]])]
    (t.is schema.ok)
    (t.is ok-report.ok)
    (t.is (not bad-type.ok))
    (t.is (= bad-type.error "schema value type mismatch"))
    (t.is (not duplicate-email.ok))
    (t.is (= duplicate-email.error "schema unique conflict"))
    (t.is (not second-email.ok))
    (t.is (= second-email.error "schema cardinality one conflict"))))

(t.deftest transact-data-resolves-lookup-refs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :user/email]
                [:db/add 100 :db/valueType :db.type/string]
                [:db/add 100 :db/unique :db.unique/identity]]))
    (discard (vev.transact
               (addr conn)
               [[:db/add 1 :user/email "ada@example.com"]]))
    (let [report (vev.transact
                   (addr conn)
                   [[:db/add [:user/email "ada@example.com"] :user/name "Ada"]])
          missing (vev.transact
                    (addr conn)
                    [[:db/add [:user/email "missing@example.com"] :user/name "Missing"]])
          result (vev.q report.db_after
                   [:find ?name
                    :where
                    [1 :user/name ?name]])]
      (t.is report.ok)
      (t.is (= report.tx_data[0].e 1))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text "Ada"))
      (t.is (not missing.ok))
      (t.is (= missing.error "lookup ref not found")))))

(t.deftest transact-data-resolves-ident-entities
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.transact
               (addr conn)
               [[:db/add 10 :db/ident :user/ada]]))
    (let [report (vev.transact
                   (addr conn)
                   [[:db/add :user/ada :user/name "Ada"]])
          missing (vev.transact
                    (addr conn)
                    [[:db/add :user/missing :user/name "Missing"]])
          result (vev.q report.db_after
                   [:find ?name
                    :where
                    [10 :user/name ?name]])]
      (t.is report.ok)
      (t.is (= report.tx_data[0].e 10))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text "Ada"))
      (t.is (not missing.ok))
      (t.is (= missing.error "ident not found")))))

(t.deftest transact-data-supports-map-forms
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1
                   :user/email "ada@example.com"
                   :user/name "Ada"}
                  {:db/id "friend"
                   :user/name "Grace"}])
        result (vev.q report.db_after
                 [:find ?name
                  :where
                  [?e :user/email "ada@example.com"]
                  [?e :user/name ?name]])]
    (t.is report.ok)
    (t.is (= (count report.tx_data) 3))
    (t.is (= (count report.tempids) 1))
    (t.is (= report.tempids[0].tempid "friend"))
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ada"))))

(t.deftest transact-data-supports-map-forms-with-db-id-last
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:user/email "ada@example.com"
                   :user/name "Ada"
                   :db/id 1}])
        result (vev.q report.db_after
                 [:find ?name
                  :where
                  [?e :user/email "ada@example.com"]
                  [?e :user/name ?name]])]
    (t.is report.ok)
    (t.is (= (count report.tx_data) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))))

(t.deftest tx-data-macro-coerces-literal-values
  (defer (free_all context.allocator))
  (let [items (vev.tx-data
                [:db/add 1 :user/name "Ada"]
                [:db/add 1 :user/age 37]
                [:db/add 1 :user/active true]
                [:db/add 1 :user/status :user.status/active]
                [:db/add 1 :user/friend (vev.value-entity 2)])]
    (t.is (= (count items) 5))
    (t.is (= items[0].op ":db/add"))
    (t.is (= items[0].a ":user/name"))
    (t.is (= items[0].v.kind .String))
    (t.is (= items[1].v.kind .Int))
    (t.is (= items[1].v.int_value 37))
    (t.is (= items[2].v.kind .Bool))
    (t.is (= items[2].v.bool_value true))
    (t.is (= items[3].v.kind .Keyword))
    (t.is (= items[3].v.text ":user.status/active"))
    (t.is (= items[4].v.kind .Entity))
    (t.is (= items[4].v.entity 2))))

(t.deftest query-follows-ref-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-string "Ada"))
                   (vev.clause (vev.term-var "e") ":user/friend" (vev.term-var "friend"))
                   (vev.clause (vev.term-var "friend") ":user/name" (vev.term-var "friend-name"))])]
    (let [query (vev.query ([]string ["friend" "friend-name"]) ([]string []) ([]string []) clauses ([]vev.Predicate []) ([]vev.Pull-Find []))
          result (vev.q report.db_after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace")))))

