                [:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.seed-people (addr conn))
        pulled (vev.pull conn.db [:db/id :user/name] [:user/email "ada@example.com"])]
      (t.is (= (count pulled.attrs) 2))
      (t.is (= pulled.attrs[0].v.entity 1))
      (t.is (= pulled.attrs[1].v.text "Ada"))))

