(package vev-tests)

(import arr "kvist:arr")
(import t "kvist:test")
(import vev "../vev_kvist")

(defn result-has-entity-pair? [result: vev.Result-Set, left: u64, right: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].entity left)
               (= row.values[1].entity right))
      (return true)))
  false)

(defn values-has-entity? [values: []vev.Value, entity: u64] -> bool
  (for [value values]
    (when (and (= value.kind .Entity)
               (= value.entity entity))
      (return true)))
  false)

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                    (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})
                    (vev.Tx-Meta {a: ":tx/reason" v: (vev.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next_tx 2))
    (t.is (= (count report.db_before.datoms) 0))
    (t.is (= (count report.db_after.datoms) 2))
    (t.is (= (count report.tx_data) 2))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (let [meta-value report.tx_meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (vev.q-strings report.db_after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest tx-data-supports-datomic-tx-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id "datomic.tx"
                   :request/id "req-1"
                   :tx/reason :profile-edit}
                  [:db/add 1 :user/name "Ada"]])
        tx-e report.tempids[0].e
        tx-props (vev.q report.db_after
                   [:find ?a ?v
                    :where
                    [?tx :request/id "req-1"]
                    [?tx ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx_data) 3))
    (t.is (= report.tx_data[0].e tx-e))
    (t.is (= report.tx_data[1].e tx-e))
    (t.is (= report.tx_data[2].e 1))
    (t.is (= (count report.tempids) 1))
    (t.is (= (count tx-props.rows) 2))
    (t.is (= (count report.tx_meta) 2))
    (t.is (= report.tx_meta[0].a ":request/id"))
    (t.is (= report.tx_meta[0].v.text "req-1"))
    (t.is (= report.tx_meta[1].a ":tx/reason"))
    (t.is (= report.tx_meta[1].v.text ":profile-edit"))))

(t.deftest transact-defaults-unschematized-attrs-to-cardinality-one
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        first-report (vev.transact
                       (addr conn)
                       [[:db/add 1 :name "Ivan"]])
        second-report (vev.transact
                        (addr conn)
                        [[:db/add 1 :name "Oleg"]])
        names (vev.q-collection second-report.db_after
                [:find [?name ...]
                 :where
                 [1 :name ?name]])]
    (t.is first-report.ok)
    (t.is second-report.ok)
    (t.is (= (count names) 1))
    (t.is (= names[0].text "Oleg"))))

