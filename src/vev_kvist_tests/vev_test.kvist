  (let [component-conn (vev.create-conn)
        component-report (vev.transact
                           (addr component-conn)
                           [[:db/add 100 :db/ident :profile]
                            [:db/add 100 :db/valueType :db.type/ref]
                            [:db/add 100 :db/isComponent "true"]])
        index-conn (vev.create-conn)
        index-report (vev.transact
                       (addr index-conn)
                       [[:db/add 100 :db/ident :name]
                        [:db/add 100 :db/index "true"]])]
    (t.is (not component-report.ok))
    (t.is (= component-report.error "schema boolean value must be boolean"))
    (t.is (not index-report.ok))
    (t.is (= index-report.error "schema boolean value must be boolean"))))

(t.deftest datascript-schema-keywords-require-known-values-subset
  (defer (free_all context.allocator))
  (let [value-type-string-conn (vev.create-conn)
        value-type-string (vev.transact
                            (addr value-type-string-conn)
                            [[:db/add 100 :db/ident :age]
                             [:db/add 100 :db/valueType "long"]])
        value-type-unknown-conn (vev.create-conn)
        value-type-unknown (vev.transact
                             (addr value-type-unknown-conn)
                             [[:db/add 100 :db/ident :age]
                              [:db/add 100 :db/valueType :db.type/instant]])
        cardinality-unknown-conn (vev.create-conn)
        cardinality-unknown (vev.transact
                              (addr cardinality-unknown-conn)
                              [[:db/add 100 :db/ident :name]
                               [:db/add 100 :db/cardinality :db.cardinality/sometimes]])
        unique-unknown-conn (vev.create-conn)
        unique-unknown (vev.transact
                         (addr unique-unknown-conn)
                         [[:db/add 100 :db/ident :email]
                          [:db/add 100 :db/unique :db.unique/maybe]])]
    (t.is (not value-type-string.ok))
    (t.is (= value-type-string.error "invalid schema keyword value"))
    (t.is (not value-type-unknown.ok))
    (t.is (= value-type-unknown.error "invalid schema keyword value"))
    (t.is (not cardinality-unknown.ok))
    (t.is (= cardinality-unknown.error "invalid schema keyword value"))
    (t.is (not unique-unknown.ok))
    (t.is (= unique-unknown.error "invalid schema keyword value"))))

