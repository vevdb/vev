        retract-attr (vev.transact (addr conn) [[:db.fn/retractAttribute :user/missing :user/name]])
        retract-entity (vev.transact (addr conn) [[:db.fn/retractEntity :user/missing]])
        names (vev.q-collection retract-entity.db_after
                [:find [?name ...]
                 :where
                 [?e :user/name ?name]])]
    (t.is retract.ok)
    (t.is retract-attr.ok)
    (t.is retract-entity.ok)
    (t.is (= (count names) 1))
    (t.is (= names[0].text "Ada"))))

