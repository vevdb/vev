(t.deftest pull-many-returns-multiple-entities
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [pulled (vev.pull-many conn.db [:db/id :user/name] ([]u64 [1 2]))]
      (t.is (= (count pulled) 2))
      (t.is (= pulled[0].attrs[0].v.entity 1))
      (t.is (= pulled[0].attrs[1].v.text "Ada"))
      (t.is (= pulled[1].attrs[0].v.entity 2))
      (t.is (= pulled[1].attrs[1].v.text "Grace")))))

(t.deftest pull-supports-wildcard
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-retract 1 ":user/name" (vev.value-string "Ada"))]))
          pulled (vev.pull report.db_after [*] 1)]
      (t.is (= (count pulled.attrs) 4))
      (t.is (= pulled.attrs[0].a ":user/active"))
      (t.is (= pulled.attrs[1].a ":user/age"))
      (t.is (= pulled.attrs[2].a ":user/email"))
      (t.is (= pulled.attrs[3].a ":user/friend")))))

(t.deftest pull-supports-reverse-ref-attrs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [pulled (vev.pull conn.db [:_user/friend] 2)]
      (t.is (= (count pulled.attrs) 1))
      (t.is (= pulled.attrs[0].a ":_user/friend"))
      (t.is (= pulled.attrs[0].v.kind .Entity))
      (t.is (= pulled.attrs[0].v.entity 1)))))

(t.deftest pull-supports-limited-reverse-ref-maps
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (discard (vev.transact
               (addr conn)
               [[:db/add 3 :user/name "Alan"]
                [:db/add 3 :user/friend (vev.value-entity 2)]
                [:db/add 4 :user/name "Barbara"]
                [:db/add 4 :user/friend (vev.value-entity 2)]]))
    (let [pulled (vev.pull conn.db [{:_user/friend [:user/name :limit 2]}] 2)]
      (t.is (= (count pulled.attrs) 2))
      (t.is (= pulled.attrs[0].v.entity 1))
      (t.is (= pulled.attrs[0].attrs[0].v.text "Ada"))
      (t.is (= pulled.attrs[1].v.entity 3))
      (t.is (= pulled.attrs[1].attrs[0].v.text "Alan")))))

(t.deftest pull-supports-nested-ref-maps
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.seed-people (addr conn)))
    (let [pulled (vev.pull conn.db [{:user/friend [:user/name]}] 1)
          result (vev.q conn.db
                   [:find (pull ?e [{:user/friend [:user/name]}])
                    :where
                    [?e :user/email "ada@example.com"]])]
      (t.is (= (count pulled.attrs) 1))
      (t.is (= pulled.attrs[0].a ":user/friend"))
      (t.is (= pulled.attrs[0].v.entity 2))
      (t.is (= (count pulled.attrs[0].attrs) 1))
      (t.is (= pulled.attrs[0].attrs[0].a ":user/name"))
      (t.is (= pulled.attrs[0].attrs[0].v.text "Grace"))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].pulls[0].attrs[0].attrs[0].v.text "Grace")))))

(t.deftest db-snapshot-survives-later-transacts
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))])))
    (let [snapshot (vev.db (addr conn))]
      (discard (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])))
      (let [old-results (vev.q-strings snapshot (vev.query-name-by-email "a@example.com"))
            current-results (vev.q-strings conn.db (vev.query-name-by-email "a@example.com"))]
        (t.is (= (count old-results) 0))
        (t.is (= (count current-results) 1))
        (t.is (= current-results[0] "Andreas"))))))

(t.deftest retract-hides-fact-from-current-queries
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        add-report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                       [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                        (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        retract-report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                           [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))]))
        old-results (vev.q-strings add-report.db_after (vev.query-name-by-email "a@example.com"))
        current-results (vev.q-strings retract-report.db_after (vev.query-name-by-email "a@example.com"))]
    (t.is (= (count old-results) 1))
    (t.is (= old-results[0] "Andreas"))
    (t.is (= (count current-results) 0))
    (t.is (= (count retract-report.db_after.datoms) 3))
    (t.is (= (count retract-report.db_after.current) 1))
    (t.is (= retract-report.tx_data[0].added false))))

(t.deftest readd-after-retract-makes-fact-current-once
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)]
    (discard (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                  (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])))
    (discard (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))])))
    (let [report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
          results (vev.q-strings report.db_after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas"))
      (t.is (= (count report.db_after.current) 2))
      (t.is (= (count report.db_after.datoms) 4)))))
