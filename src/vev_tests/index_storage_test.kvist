(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(defn shared-index-values-match? [index: vev.Shared-Int-Index, expected: []int] -> bool
  (when (not (= (vev.shared-int-index-count index) (count expected)))
    (return false))
  (for [value position expected]
    (let [[actual ok] (vev.shared-int-index-at index position)]
      (when (or (not ok)
                (not (= actual value)))
        (return false))))
  true)

(defn shared-index-view-matches-slice? [view: vev.DB-Index-View, expected: []int] -> bool
  (when (not (= (vev.db-index-view-count view) (count expected)))
    (return false))
  (for [value position expected]
    (when (not (= (vev.db-index-view-at view position) value))
      (return false)))
  true)

(defn result-has-entity-string-row? [result: vev.Result-Set, entity: u64, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity)
               (= row.values[1].kind .String)
               (= row.values[1].text text))
      (return true)))
  false)

(defn shared-datom-log-has? [log: vev.Shared-Datom-Log, position: int, entity: u64, attr: string] -> bool
  (let [[datom ok] (vev.shared-datom-log-at log position)]
    (when (not ok)
      (return false))
    (defer (vev.delete-owned-datom datom))
    (and (= datom.e entity)
         (= datom.a attr))))

(t.deftest shared-int-index-retains-old-chunks
  (defer (free_all context.allocator))
  (let [base (vev.shared-int-index-from-slice ([]int [1 3 5 7 9]) 2)
        retained (vev.retain-shared-int-index base)
        appended (vev.shared-int-index-with-appended-slice base ([]int [11 13 15]))
        [base-first-refs base-first-ok] (vev.shared-int-index-ref-count-at base 0)
        [appended-first-refs appended-first-ok] (vev.shared-int-index-ref-count-at appended 0)
        [appended-new-refs appended-new-ok] (vev.shared-int-index-ref-count-at appended 3)
        [_ missing-ok] (vev.shared-int-index-at appended 8)]
    (t.is (shared-index-values-match? base ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? retained ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (t.is base-first-ok)
    (t.is appended-first-ok)
    (t.is appended-new-ok)
    (t.is (= base-first-refs 3))
    (t.is (= appended-first-refs 3))
    (t.is (= appended-new-refs 1))
    (t.is (not missing-ok))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? retained ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (vev.delete-shared-int-index retained)
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (vev.delete-shared-int-index appended)))

(t.deftest shared-int-index-appends-contiguous-ranges
  (defer (free_all context.allocator))
  (let [base (vev.shared-int-index-from-slice ([]int [0 1]) 2)
        appended (vev.shared-int-index-with-appended-range base 2 7)
        [base-refs base-refs-ok] (vev.shared-int-index-ref-count-at appended 0)
        [new-refs new-refs-ok] (vev.shared-int-index-ref-count-at appended 1)]
    (t.is (shared-index-values-match? appended ([]int [0 1 2 3 4 5 6])))
    (t.is base-refs-ok)
    (t.is new-refs-ok)
    (t.is (= base-refs 2))
    (t.is (= new-refs 1))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? appended ([]int [0 1 2 3 4 5 6])))
    (vev.delete-shared-int-index appended)))

(t.deftest shared-int-index-appends-sorted-new-datoms
  (defer (free_all context.allocator))
  (let [db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                      (vev.datom-tx 2 ":item/z" (vev.value-string "z") 2 true)
                                      (vev.datom-tx 2 ":item/a" (vev.value-string "a") 2 true)
                                      (vev.datom-tx 3 ":item/name" (vev.value-string "c") 2 true)]))
        base (vev.shared-int-index-from-slice (slice db.eavt 0 1) 2)
        appended (vev.shared-int-index-with-appended-sorted-datoms base (slice db.datoms 0) 1 "eavt")
        [base-refs base-refs-ok] (vev.shared-int-index-ref-count-at appended 0)]
    (t.is (shared-index-values-match? appended (slice db.eavt 0)))
    (t.is base-refs-ok)
    (t.is (= base-refs 2))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? appended (slice db.eavt 0)))
    (vev.delete-shared-int-index appended)
    (vev.delete-owned-db db)))

(t.deftest shared-int-index-appends-sorted-datom-slice
  (defer (free_all context.allocator))
  (let [after-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                            (vev.datom-tx 4 ":item/z" (vev.value-string "z") 2 true)
                                            (vev.datom-tx 4 ":item/a" (vev.value-string "a") 2 true)
                                            (vev.datom-tx 5 ":item/name" (vev.value-string "c") 2 true)]))
        base (vev.shared-int-index-from-slice (slice after-db.eavt 0 1) 2)
        appended (slice after-db.datoms 1)
        merged (vev.shared-int-index-with-appended-sorted-datom-slice base appended 1 "eavt")
        [base-refs base-refs-ok] (vev.shared-int-index-ref-count-at merged 0)]
    (t.is (shared-index-values-match? merged (slice after-db.eavt 0)))
    (t.is base-refs-ok)
    (t.is (= base-refs 2))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? merged (slice after-db.eavt 0)))
    (vev.delete-shared-int-index merged)
    (vev.delete-owned-db after-db)))

(t.deftest shared-int-index-retains-unchanged-pages
  (defer (free_all context.allocator))
  (let [base (vev.shared-int-index-from-slice ([]int [1 2 3 4 5 6]) 2)
        changed (vev.shared-int-index-from-base-pages-or-slice base ([]int [1 2 30 40 5 6 7]))
        [changed-first-refs first-ok] (vev.shared-int-index-ref-count-at changed 0)
        [changed-middle-refs middle-ok] (vev.shared-int-index-ref-count-at changed 1)
        [changed-last-refs last-ok] (vev.shared-int-index-ref-count-at changed 2)
        [changed-new-refs new-ok] (vev.shared-int-index-ref-count-at changed 3)
        [base-middle-refs base-middle-ok] (vev.shared-int-index-ref-count-at base 1)]
    (t.is (shared-index-values-match? changed ([]int [1 2 30 40 5 6 7])))
    (t.is first-ok)
    (t.is middle-ok)
    (t.is last-ok)
    (t.is new-ok)
    (t.is base-middle-ok)
    (t.is (= changed-first-refs 2))
    (t.is (= changed-middle-refs 1))
    (t.is (= changed-last-refs 2))
    (t.is (= changed-new-refs 1))
    (t.is (= base-middle-refs 1))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? changed ([]int [1 2 30 40 5 6 7])))
    (vev.delete-shared-int-index changed)))

(t.deftest shared-int-index-merge-retains-contiguous-old-chunks
  (defer (free_all context.allocator))
  (let [base-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/a" (vev.value-string "a") 1 true)
                                           (vev.datom-tx 2 ":item/b" (vev.value-string "b") 1 true)]))
        after-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/a" (vev.value-string "a") 1 true)
                                            (vev.datom-tx 2 ":item/b" (vev.value-string "b") 1 true)
                                            (vev.datom-tx 3 ":item/a" (vev.value-string "c") 2 true)
                                            (vev.datom-tx 4 ":item/b" (vev.value-string "d") 2 true)]))
        base-aevt (vev.shared-int-index-from-slice (slice base-db.aevt 0) 1)
        merged-aevt (vev.shared-int-index-with-merged-appended-datoms base-aevt (slice after-db.datoms 0) 2 "aevt")
        [first-refs first-ok] (vev.shared-int-index-ref-count-at merged-aevt 0)
        [second-refs second-ok] (vev.shared-int-index-ref-count-at merged-aevt 2)]
    (t.is (shared-index-values-match? merged-aevt (slice after-db.aevt 0)))
    (t.is first-ok)
    (t.is second-ok)
    (t.is (= first-refs 2))
    (t.is (= second-refs 2))
    (vev.delete-shared-int-index base-aevt)
    (t.is (shared-index-values-match? merged-aevt (slice after-db.aevt 0)))
    (vev.delete-shared-int-index merged-aevt)
    (vev.delete-owned-db base-db)
    (vev.delete-owned-db after-db)))

(t.deftest shared-int-index-direct-merge-uses-shared-log-and-tx-slice
  (defer (free_all context.allocator))
  (let [base-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/a" (vev.value-string "a") 1 true)
                                           (vev.datom-tx 2 ":item/b" (vev.value-string "b") 1 true)]))
        after-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/a" (vev.value-string "a") 1 true)
                                            (vev.datom-tx 2 ":item/b" (vev.value-string "b") 1 true)
                                            (vev.datom-tx 3 ":item/a" (vev.value-string "c") 2 true)
                                            (vev.datom-tx 4 ":item/b" (vev.value-string "d") 2 true)]))
        log (vev.shared-datom-log-from-slice (slice base-db.datoms 0) 1)
        base-aevt (vev.shared-int-index-from-slice (slice base-db.aevt 0) 1)
        appended (slice after-db.datoms 2)
        merged-aevt (vev.shared-int-index-with-merged-appended-datom-slice-direct base-aevt log appended 2 "aevt")
        [first-refs first-ok] (vev.shared-int-index-ref-count-at merged-aevt 0)
        [second-refs second-ok] (vev.shared-int-index-ref-count-at merged-aevt 2)]
    (t.is (shared-index-values-match? merged-aevt (slice after-db.aevt 0)))
    (t.is first-ok)
    (t.is second-ok)
    (t.is (= first-refs 2))
    (t.is (= second-refs 2))
    (vev.delete-shared-int-index base-aevt)
    (t.is (shared-index-values-match? merged-aevt (slice after-db.aevt 0)))
    (vev.delete-shared-int-index merged-aevt)
    (vev.delete-shared-datom-log log)
    (vev.delete-owned-db base-db)
    (vev.delete-owned-db after-db)))

(t.deftest shared-datom-log-at-borrowed-uses-chunk-starts
  (defer (free_all context.allocator))
  (let [db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/a" (vev.value-string "a") 1 true)
                                      (vev.datom-tx 2 ":item/b" (vev.value-string "b") 1 true)
                                      (vev.datom-tx 3 ":item/c" (vev.value-string "c") 1 true)]))
        log (vev.shared-datom-log-from-slice (slice db.datoms 0) 2)
        [first-datom first-ok] (vev.shared-datom-log-at-borrowed log 0)
        [third-datom third-ok] (vev.shared-datom-log-at-borrowed log 2)
        [_ missing-ok] (vev.shared-datom-log-at-borrowed log 3)]
    (t.is first-ok)
    (t.is (= first-datom.e 1))
    (t.is third-ok)
    (t.is (= third-datom.e 3))
    (t.is (not missing-ok))
    (vev.delete-shared-datom-log log)
    (vev.delete-owned-db db)))

(t.deftest shared-db-int-indexes-can-back-index-views
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 1 ":item/rank" (vev.value-int 10) 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)])
        db (vev.init-db datoms)
        shared (vev.shared-db-int-indexes-from-db db 2)
        retained (vev.retain-shared-db-int-indexes shared)
        eavt-view (vev.shared-db-int-index-view (addr shared) .EAVT)
        aevt-view (vev.shared-db-int-index-view (addr shared) .AEVT)
        avet-view (vev.shared-db-int-index-view (addr shared) .AVET)
        vaet-view (vev.shared-db-int-index-view (addr shared) .VAET)]
    (t.is (shared-index-view-matches-slice? eavt-view (slice db.eavt 0)))
    (t.is (shared-index-view-matches-slice? aevt-view (slice db.aevt 0)))
    (t.is (shared-index-view-matches-slice? avet-view (slice db.avet 0)))
    (t.is (shared-index-view-matches-slice? vaet-view (slice db.vaet 0)))
    (vev.delete-shared-db-int-indexes shared)
    (let [retained-eavt-view (vev.shared-db-int-index-view (addr retained) .EAVT)]
      (t.is (shared-index-view-matches-slice? retained-eavt-view (slice db.eavt 0))))
    (vev.delete-shared-db-int-indexes retained)
    (vev.delete-owned-db db)))

(t.deftest shared-datom-log-retains-old-chunks
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)])
        log (vev.shared-datom-log-from-slice datoms 2)
        retained (vev.retain-shared-datom-log log)]
    (t.is (shared-datom-log-has? log 0 1 ":item/name"))
    (t.is (shared-datom-log-has? retained 2 3 ":item/name"))
    (vev.delete-shared-datom-log log)
    (t.is (shared-datom-log-has? retained 1 2 ":item/name"))
    (vev.delete-shared-datom-log retained)))

(t.deftest shared-datom-log-indexes-appended-chunk-starts
  (defer (free_all context.allocator))
  (let [base (vev.shared-datom-log-from-slice ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                                            (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                                                            (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)]) 2)
        appended (vev.shared-datom-log-with-appended-slice base ([]vev.Datom [(vev.datom-tx 4 ":item/name" (vev.value-string "d") 2 true)
                                                                              (vev.datom-tx 5 ":item/name" (vev.value-string "e") 2 true)
                                                                              (vev.datom-tx 6 ":item/name" (vev.value-string "f") 2 true)]))
        [chunk0 chunk0-ok] (vev.shared-datom-log-chunk-index-at appended 0)
        [chunk2 chunk2-ok] (vev.shared-datom-log-chunk-index-at appended 2)
        [chunk3 chunk3-ok] (vev.shared-datom-log-chunk-index-at appended 3)
        [chunk5 chunk5-ok] (vev.shared-datom-log-chunk-index-at appended 5)]
    (t.is chunk0-ok)
    (t.is chunk2-ok)
    (t.is chunk3-ok)
    (t.is chunk5-ok)
    (t.is (= chunk0 0))
    (t.is (= chunk2 1))
    (t.is (= chunk3 2))
    (t.is (= chunk5 3))
    (t.is (shared-datom-log-has? appended 0 1 ":item/name"))
    (t.is (shared-datom-log-has? appended 3 4 ":item/name"))
    (t.is (shared-datom-log-has? appended 5 6 ":item/name"))
    (vev.delete-shared-datom-log base)
    (t.is (shared-datom-log-has? appended 2 3 ":item/name"))
    (vev.delete-shared-datom-log appended)))

(t.deftest shared-resident-index-source-runs-source-backed-query
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 1 ":item/rank" (vev.value-int 10) 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 2 false)])
        db (vev.init-db datoms)
        shared (vev.shared-db-int-indexes-from-db db 2)
        source (vev.shared-resident-index-db-read-source (addr db) (addr shared))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (t.is (not (result-has-entity-string-row? result 4 "old")))
    (vev.delete-result-set-owned-values result)
    (vev.delete-shared-db-int-indexes shared)
    (vev.delete-owned-db db)))

(t.deftest shared-resident-datom-source-runs-source-backed-query
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 2 false)])
        db (vev.init-db datoms)
        shared (vev.shared-db-snapshot-from-db db 2)
        retained (vev.retain-shared-db-snapshot shared)]
    (vev.delete-shared-db-snapshot shared)
    (let [source (vev.shared-db-snapshot-read-source (addr retained))
          result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
      (t.is (= (count result.rows) 2))
      (t.is (result-has-entity-string-row? result 1 "a"))
      (t.is (result-has-entity-string-row? result 2 "b"))
      (t.is (not (result-has-entity-string-row? result 4 "old")))
      (vev.delete-result-set-owned-values result))
    (vev.delete-shared-db-snapshot retained)
    (vev.delete-owned-db db)))

(t.deftest shared-db-snapshot-append-shares-datom-log
  (defer (free_all context.allocator))
  (let [base-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                           (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)]))
        after-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                            (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                                            (vev.datom-tx 3 ":item/name" (vev.value-string "c") 2 true)]))
        base-snapshot (vev.shared-db-snapshot-from-db base-db 2)
        tx-data (arr.into [dynamic]vev.Datom (slice after-db.datoms 2))
        tx-meta (make [dynamic]vev.Tx-Meta)
        tempids (make [dynamic]vev.Tempid)
        report (vev.Tx-Report {ok: true
                                error: ""
                                db-before: base-db
                                db-after: after-db
                                tx-data: tx-data
                                tx: 2
                                tx-meta: tx-meta
                                tempids: tempids
                                datom-start-index: 2
                                append-only: true
                                new-entities-after-existing: true
                                publish-plan: (vev.tx-publish-plan-for-append (slice tx-data 0) 2 true)})
        appended-snapshot (vev.shared-db-snapshot-with-tx-report base-snapshot after-db report)
        [base-datom-refs base-datom-refs-ok] (vev.shared-datom-log-ref-count-at base-snapshot.datoms 0)
        [base-current-refs base-current-refs-ok] (vev.shared-int-index-ref-count-at base-snapshot.indexes.current 0)
        [base-eavt-refs base-eavt-refs-ok] (vev.shared-int-index-ref-count-at base-snapshot.indexes.eavt 0)
        source (vev.shared-db-snapshot-read-source (addr appended-snapshot))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is base-datom-refs-ok)
    (t.is base-current-refs-ok)
    (t.is base-eavt-refs-ok)
    (t.is (= base-datom-refs 2))
    (t.is (= base-current-refs 2))
    (t.is (= base-eavt-refs 2))
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-shared-db-snapshot base-snapshot)
    (vev.delete-shared-db-snapshot appended-snapshot)
    (delete tx-data)
    (delete tx-meta)
    (delete tempids)
    (vev.delete-owned-db base-db)
    (vev.delete-owned-db after-db)))

(t.deftest shared-conn-publishes-shared-snapshots
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        tx1 ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))
                             (vev.add 2 ":item/name" (vev.value-string "b"))])
        report1 (vev.shared-conn-transact (addr conn) tx1)
        [datom-refs-before datom-refs-before-ok] (vev.shared-datom-log-ref-count-at conn.snapshot.datoms 0)
        [current-refs-before current-refs-before-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.current 0)
        [eavt-refs-before eavt-refs-before-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.eavt 0)
        tx2 ([]vev.Tx-Data [(vev.add 3 ":item/name" (vev.value-string "c"))])
        report2 (vev.shared-conn-transact (addr conn) tx2)
        [datom-refs-after datom-refs-after-ok] (vev.shared-datom-log-ref-count-at conn.snapshot.datoms 0)
        [current-refs-after current-refs-after-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.current 0)
        [eavt-refs-after eavt-refs-after-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.eavt 0)
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is (= report1.datom-start-index 0))
    (t.is (= report2.datom-start-index 2))
    (t.is report1.append-only)
    (t.is report1.new-entities-after-existing)
    (t.is report2.append-only)
    (t.is report2.new-entities-after-existing)
    (t.is datom-refs-before-ok)
    (t.is current-refs-before-ok)
    (t.is eavt-refs-before-ok)
    (t.is datom-refs-after-ok)
    (t.is current-refs-after-ok)
    (t.is eavt-refs-after-ok)
    (t.is (= datom-refs-before 1))
    (t.is (= current-refs-before 1))
    (t.is (= eavt-refs-before 1))
    (t.is (= datom-refs-after 1))
    (t.is (= current-refs-after 1))
    (t.is (= eavt-refs-after 1))
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-report-retains-shared-db-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact-report
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        before-source (vev.shared-db-snapshot-read-source (addr report.db-before))
        after-source (vev.shared-db-snapshot-read-source (addr report.db-after))
        before-result (vev.q-text-db-read-source before-source "[:find ?e ?name :where [?e :item/name ?name]]")
        after-result (vev.q-text-db-read-source after-source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 1))
    (t.is (= report.datom-start-index 0))
    (t.is report.append-only)
    (t.is report.new-entities-after-existing)
    (t.is (= (count before-result.rows) 0))
    (t.is (= (count after-result.rows) 1))
    (t.is (result-has-entity-string-row? after-result 1 "a"))
    (t.is (not (result-has-entity-string-row? after-result 2 "b")))
    (vev.delete-result-set-owned-values before-result)
    (vev.delete-result-set-owned-values after-result)
    (vev.delete-live-tx-report-shallow report2)
    (vev.delete-shared-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-db-queries-retained-shared-snapshot
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report1 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        snapshot (vev.shared-store-db (addr conn))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        result (vev.q-result-store-db-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is result.result.ok)
    (t.is (= (count result.result.rows) 1))
    (t.is (result-has-entity-string-row? result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? result.result 2 "b")))
    (vev.delete-query-result result)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-conn-uses-storage-neutral-api
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"a\"}]")
        prepared (vev.prepare-query-text "[:find ?e ?name :where [?e :item/name ?name]]")
        direct-result (vev.q-result-store-prepared (addr store) prepared)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report2 (vev.transact-store-text (addr store) "[{:db/id 2 :item/name \"b\"}]")
        snapshot-result (vev.q-result-store-db-prepared (addr snapshot) prepared)
        [snapshot-value snapshot-value-ok snapshot-value-error] (vev.q-store-db-value-text-with-input-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]" "[]")
        [pull-value pull-value-ok pull-value-error] (vev.pull-store-db-value-text (addr snapshot) "[:db/id :item/name]" 1)
        [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
    (t.is report1.ok)
    (t.is prepared.ok)
    (t.is direct-result.result.ok)
    (t.is (= (count direct-result.result.rows) 1))
    (t.is (result-has-entity-string-row? direct-result.result 1 "a"))
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is report2.ok)
    (t.is snapshot-result.result.ok)
    (t.is (= (count snapshot-result.result.rows) 1))
    (t.is (result-has-entity-string-row? snapshot-result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? snapshot-result.result 2 "b")))
    (t.is snapshot-value-ok)
    (t.is (= snapshot-value-error ""))
    (t.is (= snapshot-value.kind .Map))
    (t.is pull-value-ok)
    (t.is (= pull-value-error ""))
    (t.is (= pull-value.kind .Map))
    (t.is tx-count-ok)
    (t.is (= tx-count-error ""))
    (t.is (= tx-count 3))
    (t.is (not (vev.store-read-only? (addr store))))
    (t.is (vev.store-resident-db-available? (addr store)))
    (vev.delete-query-result direct-result)
    (vev.delete-query-result snapshot-result)
    (vev.delete-owned-value snapshot-value)
    (vev.delete-owned-value pull-value)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store store)))
