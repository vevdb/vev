(t.deftest shared-conn-resolves-current-tx-values-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 1 ":item/tx" (vev.value-keyword ":db/current-tx"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?tx :where [1 :item/tx ?tx]]")]
    (t.is report.ok)
    (t.is report.append-only)
    (t.is (= (count report.tx-data) 1))
    (t.is (= report.tx-data[0].v.kind .Entity))
    (t.is (= report.tx-data[0].v.entity report.tx))
    (t.is (= (count report.tempids) 1))
    (t.is (= report.tempids[0].tempid ":db/current-tx"))
    (t.is (= report.tempids[0].e report.tx))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].kind .Entity))
    (t.is (= result.rows[0].values[0].entity report.tx))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-schema-only-tx-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                  (vev.add 101 ":db/ident" (vev.value-keyword ":user/friend"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))
                                  (vev.add 101 ":db/isComponent" (vev.value-bool false))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "ada" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "grace" ":user/email" (vev.value-string "grace@example.com"))
                                  (vev.add-tempid "ada" ":user/friend" (vev.value-string "grace"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?friend :where [?e :user/email \"ada@example.com\"] [?e :user/friend ?f] [?f :user/email ?friend]]")]
    (t.is schema.ok)
    (t.is (= (count schema.tx-data) 5))
    (t.is report.ok)
    (t.is report.append-only)
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "grace@example.com"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

