(t.deftest shared-conn-resolves-same-tx-tuple-lookup-ref-targets-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email+code"))
                                  (vev.add 100 ":db/valueType" (vev.value-keyword ":db.type/tuple"))
                                  (vev.add 100 ":db/tupleAttrs" (vev.value-keyword-vector ([]string [":user/email" ":user/code"])))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                  (vev.add 101 ":db/ident" (vev.value-keyword ":user/friend"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))]))
        lookup-value (vev.value-vector2 (vev.value-string "ada@example.com") (vev.value-string "ada-code"))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-value-lookup-ref 1 ":user/friend" ":user/email+code" lookup-value)
                                  (vev.add-tempid "ada" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "ada" ":user/code" (vev.value-string "ada-code"))
                                  (vev.add-tempid "ada" ":user/name" (vev.value-string "Ada"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?name :where [1 :user/friend ?friend] [?friend :user/name ?name]]")
        [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")]
    (t.is schema.ok)
    (t.is report.ok)
    (t.is (= conn.write.source-resolves 2))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is ada-ok)
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (vev.delete-owned-value lookup-value)
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

