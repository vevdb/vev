    (t.is grace-ok)
    (t.is (= ada-e 1))
    (t.is (= grace-e 2))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[0].values[1].text "grace@example.com"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

