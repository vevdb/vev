(t.deftest shared-conn-resolves-later-same-tx-tempid-lookup-targets-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                  (vev.add 101 ":db/ident" (vev.value-keyword ":user/friend"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))
                                  (vev.add-lookup-ref ":user/email" (vev.value-string "ada@example.com") ":user/name" (vev.value-string "Ada"))
                                  (vev.Tx-Data {op: ":db/add"
                                                lookup-attr: ":user/email"
                                                lookup-value: (vev.value-string "ada@example.com")
                                                has-lookup-ref: true
                                                a: ":user/friend"
                                                value-lookup-attr: ":user/email"
                                                value-lookup-value: (vev.value-string "grace@example.com")
                                                has-value-lookup-ref: true})
                                  (vev.add-tempid "ada" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "grace" ":user/email" (vev.value-string "grace@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        name-result (vev.q-text-db-read-source source "[:find ?name :where [?e :user/name ?name]]")
        friend-result (vev.q-text-db-read-source source "[:find ?email :where [?e :user/name \"Ada\"] [?e :user/friend ?friend] [?friend :user/email ?email]]")
        [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")
        [grace-e grace-ok] (vev.tempid-lookup (slice report.tempids 0) "grace")]
    (t.is report.ok)
    (t.is (= conn.write.source-resolves 1))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is ada-ok)
    (t.is grace-ok)
    (t.is (not (= ada-e grace-e)))
    (t.is name-result.ok)
    (t.is (= (count name-result.rows) 1))
    (t.is (= name-result.rows[0].values[0].text "Ada"))
    (t.is friend-result.ok)
    (t.is (= (count friend-result.rows) 1))
    (t.is (= friend-result.rows[0].values[0].text "grace@example.com"))
    (vev.delete-result-set-owned-values name-result)
    (vev.delete-result-set-owned-values friend-result)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

