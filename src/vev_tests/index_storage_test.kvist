    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-report-retains-shared-db-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact-report
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        before-source (vev.shared-db-snapshot-read-source (addr report.db-before))
        after-source (vev.shared-db-snapshot-read-source (addr report.db-after))
        before-result (vev.q-text-db-read-source before-source "[:find ?e ?name :where [?e :item/name ?name]]")
        after-result (vev.q-text-db-read-source after-source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 1))
    (t.is (= report.datom-start-index 0))
    (t.is report.append-only)
    (t.is report.new-entities-after-existing)
    (t.is (= (count before-result.rows) 0))
    (t.is (= (count after-result.rows) 1))
    (t.is (result-has-entity-string-row? after-result 1 "a"))
    (t.is (not (result-has-entity-string-row? after-result 2 "b")))
    (vev.delete-result-set-owned-values before-result)
    (vev.delete-result-set-owned-values after-result)
    (vev.delete-live-tx-report-shallow report2)
    (vev.delete-shared-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-db-queries-retained-shared-snapshot
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report1 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        snapshot (vev.shared-store-db (addr conn))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        result (vev.q-result-store-db-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is result.result.ok)
    (t.is (= (count result.result.rows) 1))
    (t.is (result-has-entity-string-row? result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? result.result 2 "b")))
    (vev.delete-query-result result)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-conn-uses-storage-neutral-api
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        schema-report (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :item/friend :db/valueType :db.type/ref}]")
        report1 (vev.transact-store-tx-data
                  (addr store)
                  ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))
                                  (vev.add 1 ":item/friend" (vev.value-entity 2))
                                  (vev.add 2 ":item/name" (vev.value-string "b"))]))
        prepared (vev.prepare-query-text "[:find ?e ?name :where [?e :item/name ?name]]")
        direct-result (vev.q-result-store-prepared (addr store) prepared)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report2 (vev.transact-store-text (addr store) "[{:db/id 3 :item/name \"c\"}]")
        snapshot-result (vev.q-result-store-db-prepared (addr snapshot) prepared)
        [snapshot-value snapshot-value-ok snapshot-value-error] (vev.q-store-db-value-text-with-input-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]" "[]")
        friend-result (vev.q-result-store-db-text-with-input-text (addr snapshot) "[:find ?friend :where [1 :item/friend ?friend]]" "[]")
        [pull-value pull-value-ok pull-value-error] (vev.pull-store-db-value-text (addr snapshot) "[:db/id :item/name]" 1)
        [child-pull-value child-pull-value-ok child-pull-value-error] (vev.pull-store-db-value-text (addr snapshot) "[:item/name]" 2)
        [child-name child-name-ok] (vev.map-get-value child-pull-value (vev.value-keyword ":item/name"))
        [nested-pull-value nested-pull-value-ok nested-pull-value-error] (vev.pull-store-db-value-text (addr snapshot) "[:item/name {:item/friend [:item/name]}]" 1)
        [nested-name nested-name-ok] (vev.map-get-value nested-pull-value (vev.value-keyword ":item/name"))
        [nested-friend nested-friend-ok] (vev.map-get-value nested-pull-value (vev.value-keyword ":item/friend"))
        [nested-friend-name nested-friend-name-ok] (vev.map-get-value nested-friend (vev.value-keyword ":item/name"))
        [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
    (t.is schema-report.ok)
    (t.is report1.ok)
    (t.is prepared.ok)
    (t.is direct-result.result.ok)
    (t.is (= (count direct-result.result.rows) 2))
    (t.is (result-has-entity-string-row? direct-result.result 1 "a"))
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is report2.ok)
    (t.is snapshot-result.result.ok)
    (t.is (= (count snapshot-result.result.rows) 2))
    (t.is (result-has-entity-string-row? snapshot-result.result 1 "a"))
    (t.is (result-has-entity-string-row? snapshot-result.result 2 "b"))
    (t.is (not (result-has-entity-string-row? snapshot-result.result 3 "c")))
    (t.is snapshot-value-ok)
    (t.is (= snapshot-value-error ""))
    (t.is (= snapshot-value.kind .Map))
    (t.is friend-result.result.ok)
    (t.is (= friend-result.result.error ""))
    (t.is (= (count friend-result.result.rows) 1))
    (t.is (= friend-result.result.rows[0].values[0].kind .Entity))
    (t.is (= friend-result.result.rows[0].values[0].entity 2))
    (t.is pull-value-ok)
    (t.is (= pull-value-error ""))
    (t.is (= pull-value.kind .Map))
    (t.is child-pull-value-ok)
    (t.is (= child-pull-value-error ""))
    (t.is child-name-ok)
    (t.is (= child-name.text "b"))
    (t.is nested-pull-value-ok)
    (t.is (= nested-pull-value-error ""))
    (t.is (= nested-pull-value.kind .Map))
    (t.is nested-name-ok)
    (t.is (= nested-name.kind .String))
    (t.is (= nested-name.text "a"))
    (t.is nested-friend-ok)
    (t.is (= nested-friend.kind .Map))
    (t.is nested-friend-name-ok)
    (t.is (= nested-friend-name.kind .String))
    (t.is (= nested-friend-name.text "b"))
    (t.is tx-count-ok)
    (t.is (= tx-count-error ""))
    (t.is (= tx-count 4))
    (t.is (not (vev.store-read-only? (addr store))))
    (t.is (vev.store-resident-db-available? (addr store)))
    (vev.delete-query-result direct-result)
    (vev.delete-query-result snapshot-result)
    (vev.delete-query-result friend-result)
    (vev.delete-owned-value snapshot-value)
    (vev.delete-owned-value pull-value)
    (vev.delete-owned-value child-pull-value)
    (vev.delete-owned-value nested-pull-value)
    (vev.delete-live-tx-report-shallow schema-report)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-prepared-query-shallow prepared)
    (vev.close-store store)))
