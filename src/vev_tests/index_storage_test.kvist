        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report (vev.with-store-db-report-text (addr snapshot) "[{:db/id 1 :user/address {:db/id \"addr\" :address/city \"London\"}}]")
        before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?city :where [1 :user/address ?address] [?address :address/city ?city]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?city :where [1 :user/address ?address] [?address :address/city ?city]]")]
