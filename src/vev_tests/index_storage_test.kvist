(t.deftest shared-conn-validates-unique-value-tempids-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/value"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "a" ":user/name" (vev.value-string "Ada"))]))
        conflict (vev.shared-conn-transact
                   (addr conn)
                   ([]vev.Tx-Data [(vev.add-tempid "b" ":user/email" (vev.value-string "ada@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :user/name ?name]]")
        [a-e a-ok] (vev.tempid-lookup (slice report.tempids 0) "a")]
    (t.is schema.ok)
    (t.is report.ok)
    (t.is a-ok)
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (result-has-entity-string-row? result a-e "Ada"))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "schema unique conflict"))
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-live-tx-report-shallow conflict)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-cas-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":item/weight" (vev.value-int 200))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.cas 1 ":item/weight" (vev.value-int 200) (vev.value-int 300))]))
        failed (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.cas 1 ":item/weight" (vev.value-int 200) (vev.value-int 400))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?weight :where [1 :item/weight ?weight]]")]
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= (count report.tx-data) 2))
    (t.is (not failed.ok))
    (t.is (= failed.error ":db.fn/cas failed on datom [1 :item/weight 300], expected 200"))
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].int-value 300))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-live-tx-report-shallow failed)
    (vev.delete-shared-conn conn)))

