        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "a" ":user/name" (vev.value-string "Ada"))]))
        conflict (vev.shared-conn-transact
                   (addr conn)
                   ([]vev.Tx-Data [(vev.add-tempid "b" ":user/email" (vev.value-string "ada@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :user/name ?name]]")
        [a-e a-ok] (vev.tempid-lookup (slice report.tempids 0) "a")]
    (t.is schema.ok)
    (t.is report.ok)
    (t.is a-ok)
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (result-has-entity-string-row? result a-e "Ada"))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "schema unique conflict"))
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-live-tx-report-shallow conflict)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-updates-schema-unique-retractions-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/value"))]))
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":user/email" (vev.value-string "ada@example.com"))]))
        unique-retract (vev.shared-conn-transact
                         (addr conn)
                         ([]vev.Tx-Data [(vev.retract 100 ":db/unique" (vev.value-keyword ":db.unique/value"))]))
        duplicate (vev.shared-conn-transact
                    (addr conn)
                    ([]vev.Tx-Data [(vev.add 2 ":user/email" (vev.value-string "ada@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e :where [?e :user/email \"ada@example.com\"]]")]
    (t.is schema.ok)
    (t.is seed.ok)
    (t.is unique-retract.ok)
    (t.is duplicate.ok)
    (t.is (not (vev.shared-write-state-schema-unique? (addr conn.write) ":user/email")))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 2))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow unique-retract)
    (vev.delete-live-tx-report-shallow duplicate)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-cas-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":item/weight" (vev.value-int 200))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.cas 1 ":item/weight" (vev.value-int 200) (vev.value-int 300))]))
        failed (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.cas 1 ":item/weight" (vev.value-int 200) (vev.value-int 400))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?weight :where [1 :item/weight ?weight]]")]
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= (count report.tx-data) 2))
    (t.is (not failed.ok))
    (t.is (= failed.error ":db.fn/cas failed on datom [1 :item/weight 300], expected 200"))
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].int-value 300))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-live-tx-report-shallow failed)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-cas-lookup-refs-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                  (vev.add 101 ":db/ident" (vev.value-keyword ":user/friend"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))]))
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":user/email" (vev.value-string "ada@example.com"))
                                (vev.add 2 ":user/email" (vev.value-string "grace@example.com"))
                                (vev.add 3 ":user/email" (vev.value-string "barbara@example.com"))
                                (vev.add 1 ":user/friend" (vev.value-entity 2))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.cas-expected-lookup-ref
                                    1
                                    ":user/friend"
                                    ":user/email"
                                    (vev.value-string "grace@example.com")
                                    (vev.value-entity 3))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?email :where [1 :user/friend ?friend] [?friend :user/email ?email]]")]
    (t.is schema.ok)
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "barbara@example.com"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-report-retains-shared-db-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact-report
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        before-source (vev.shared-db-snapshot-read-source (addr report.db-before))
        after-source (vev.shared-db-snapshot-read-source (addr report.db-after))
        before-result (vev.q-text-db-read-source before-source "[:find ?e ?name :where [?e :item/name ?name]]")
        after-result (vev.q-text-db-read-source after-source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 1))
    (t.is (= report.datom-start-index 0))
    (t.is report.append-only)
    (t.is report.new-entities-after-existing)
    (t.is (= (count before-result.rows) 0))
    (t.is (= (count after-result.rows) 1))
    (t.is (result-has-entity-string-row? after-result 1 "a"))
    (t.is (not (result-has-entity-string-row? after-result 2 "b")))
    (vev.delete-result-set-owned-values before-result)
    (vev.delete-result-set-owned-values after-result)
    (vev.delete-live-tx-report-shallow report2)
    (vev.delete-shared-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-db-queries-retained-shared-snapshot
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report1 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))]))
        snapshot (vev.shared-store-db (addr conn))
        report2 (vev.shared-conn-transact
                  (addr conn)
                  ([]vev.Tx-Data [(vev.add 2 ":item/name" (vev.value-string "b"))]))
        result (vev.q-result-store-db-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is result.result.ok)
    (t.is (= (count result.result.rows) 1))
    (t.is (result-has-entity-string-row? result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? result.result 2 "b")))
    (vev.delete-query-result result)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-shared-conn conn)))

(t.deftest shared-store-db-with-keeps-shared-immutable-db-values
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"a\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text (addr snapshot) "[{:db/id 2 :item/name \"b\"}]")
        original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")
        next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .Shared-Snapshot))
    (t.is (= next-snapshot.kind .Shared-Snapshot))
    (t.is original-result.result.ok)
    (t.is (= (count original-result.result.rows) 1))
    (t.is (result-has-entity-string-row? original-result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? original-result.result 2 "b")))
    (t.is next-result.result.ok)
    (t.is (= (count next-result.result.rows) 2))
    (t.is (result-has-entity-string-row? next-result.result 1 "a"))
    (t.is (result-has-entity-string-row? next-result.result 2 "b"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 1))
    (t.is (result-has-entity-string-row? live-result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? live-result.result 2 "b")))
    (vev.delete-query-result original-result)
    (vev.delete-query-result next-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.delete-tx-report-shallow report1)
    (vev.close-store store)))

(t.deftest shared-store-db-with-source-append-uses-log-tx-basis
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"a\"} {:db/id 2 :item/name \"b\"}]")
        report2 (vev.transact-store-text (addr store) "[[:db/add 1 :item/age 37]]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text (addr snapshot) "[[:db/add 1 :item/color \"red\"] [:db/add 3 :item/name \"c\"]]")
        tx-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?tx :where [3 :item/name \"c\" ?tx :db/add]]")
        color-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?color :where [1 :item/color ?color]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is (= report1.tx 1))
    (t.is (= report2.tx 2))
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= next-snapshot.kind .Shared-Snapshot))
    (t.is tx-result.result.ok)
    (t.is (= (count tx-result.result.rows) 1))
    (t.is (= tx-result.result.rows[0].values[0].kind .Entity))
    (t.is (= tx-result.result.rows[0].values[0].entity 3))
    (t.is color-result.result.ok)
    (t.is (= (count color-result.result.rows) 1))
    (t.is (= color-result.result.rows[0].values[0].text "red"))
    (vev.delete-query-result tx-result)
    (vev.delete-query-result color-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.delete-tx-report-shallow report1)
    (vev.delete-tx-report-shallow report2)
    (vev.close-store store)))

(t.deftest shared-store-db-with-cardinality-one-replacement-keeps-current-semantics
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"a\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text (addr snapshot) "[[:db/add 1 :item/name \"aa\"]]")
        original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")
        next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?e ?name :where [?e :item/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?e ?name :where [?e :item/name ?name]]")
        [pull-value pull-ok pull-error] (vev.pull-store-db-value-text (addr next-snapshot) "[:item/name]" 1)
        [pull-name pull-name-ok] (vev.map-get-value pull-value (vev.value-keyword ":item/name"))
        chained-snapshot (vev.db-with-store-db-text (addr next-snapshot) "[[:db/add 1 :item/color \"red\"]]")
        chained-result (vev.q-result-store-db-text (addr chained-snapshot) "[:find ?e ?name :where [?e :item/name ?name] [1 :item/color \"red\"]]")]
    (t.is report1.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .Shared-Snapshot))
    (t.is (= next-snapshot.kind .Shared-Tx-Ops-Overlay))
    (t.is original-result.result.ok)
    (t.is (= (count original-result.result.rows) 1))
    (t.is (result-has-entity-string-row? original-result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? original-result.result 1 "aa")))
    (t.is next-result.result.ok)
    (t.is (= (count next-result.result.rows) 1))
    (t.is (not (result-has-entity-string-row? next-result.result 1 "a")))
    (t.is (result-has-entity-string-row? next-result.result 1 "aa"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 1))
    (t.is (result-has-entity-string-row? live-result.result 1 "a"))
    (t.is (not (result-has-entity-string-row? live-result.result 1 "aa")))
    (t.is pull-ok)
    (t.is (= pull-error ""))
    (t.is pull-name-ok)
    (t.is (= pull-name.kind .String))
    (t.is (= pull-name.text "aa"))
    (t.is chained-result.result.ok)
    (t.is (= (count chained-result.result.rows) 1))
    (t.is (result-has-entity-string-row? chained-result.result 1 "aa"))
    (vev.delete-owned-value pull-value)
    (vev.delete-query-result original-result)
    (vev.delete-query-result next-result)
    (vev.delete-query-result live-result)
    (vev.delete-query-result chained-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.close-store-db! (addr chained-snapshot))
    (vev.delete-tx-report-shallow report1)
    (vev.close-store store)))

(t.deftest shared-store-with-report-keeps-store-db-before-after
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"a\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report (vev.with-store-db-report-text (addr snapshot) "[[:db/add 1 :item/name \"aa\"]]")
        before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?e ?name :where [?e :item/name ?name]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?e ?name :where [?e :item/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?e ?name :where [?e :item/name ?name]]")
        report-value (vev.store-tx-report-value report)
        [tx-value tx-ok] (vev.map-get-value report-value (vev.value-keyword ":tx"))]
    (t.is report1.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is report.ok)
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Tx-Ops-Overlay))
    (t.is (= (count report.tx-data) 2))
    (t.is before-result.result.ok)
    (t.is (= (count before-result.result.rows) 1))
    (t.is (result-has-entity-string-row? before-result.result 1 "a"))
    (t.is after-result.result.ok)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (result-has-entity-string-row? after-result.result 1 "aa"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 1))
    (t.is (result-has-entity-string-row? live-result.result 1 "a"))
    (t.is tx-ok)
    (t.is (= tx-value.kind .Entity))
    (t.is (= tx-value.entity 2))
    (vev.delete-owned-value report-value)
    (vev.delete-query-result before-result)
    (vev.delete-query-result after-result)
    (vev.delete-query-result live-result)
    (vev.delete-store-tx-report report)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-tx-report-shallow report1)
    (vev.close-store store)))

(t.deftest shared-store-with-report-same-tx-reverse-ref-keeps-source-dbs
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report (vev.with-store-db-report-text
                 (addr snapshot)
                 "[{:db/id 100 :db/ident :user/friend :db/valueType :db.type/ref} [:db/add 2 :_user/friend 1]]")
        before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?friend :where [1 :user/friend ?friend]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?friend :where [1 :user/friend ?friend]]")
        reverse-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?source :where [2 :_user/friend ?source]]")]
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is report.ok report.error)
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Tx-Ops-Overlay))
    (t.is before-result.result.ok)
    (t.is (= (count before-result.result.rows) 0))
    (t.is after-result.result.ok)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (= after-result.result.rows[0].values[0].kind .Entity))
    (t.is (= after-result.result.rows[0].values[0].entity 2))
    (t.is reverse-result.result.ok)
    (t.is (= (count reverse-result.result.rows) 1))
    (t.is (= reverse-result.result.rows[0].values[0].kind .Entity))
    (t.is (= reverse-result.result.rows[0].values[0].entity 1))
    (vev.delete-query-result before-result)
    (vev.delete-query-result after-result)
    (vev.delete-query-result reverse-result)
    (vev.delete-store-tx-report report)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store store)))

(t.deftest shared-store-db-with-nested-map-keeps-shared-db
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        schema-report (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :user/address :db/valueType :db.type/ref}]")
        report1 (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text (addr snapshot) "[{:db/id 1 :user/address {:db/id \"addr\" :address/city \"London\"}}]")
        original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?city :where [1 :user/address ?address] [?address :address/city ?city]]")
        next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?city :where [1 :user/address ?address] [?address :address/city ?city]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?city :where [1 :user/address ?address] [?address :address/city ?city]]")]
    (t.is schema-report.ok)
    (t.is report1.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .Shared-Snapshot))
    (t.is (not (= next-snapshot.kind .Resident)))
    (t.is original-result.result.ok)
    (t.is (= (count original-result.result.rows) 0))
    (t.is next-result.result.ok)
    (t.is (= (count next-result.result.rows) 1))
    (t.is (= next-result.result.rows[0].values[0].text "London"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 0))
    (vev.delete-query-result original-result)
    (vev.delete-query-result next-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.delete-tx-report-shallow schema-report)
    (vev.delete-tx-report-shallow report1)
    (vev.close-store store)))

(t.deftest shared-store-with-report-nested-map-keeps-source-dbs
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        schema-report (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :user/address :db/valueType :db.type/ref}]")
