(t.deftest shared-store-db-with-same-tx-ref-schema-tempid-values-keeps-shared-db
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text
                        (addr snapshot)
                        "[{:db/id 100 :db/ident :item/friend :db/valueType :db.type/ref} {:db/id \"a\" :item/name \"Ada\" :item/friend \"b\"} {:db/id \"b\" :item/name \"Babbage\"}]")
        result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?friend :where [?e :item/name \"Ada\"] [?e :item/friend ?f] [?f :item/name ?friend]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?friend :where [?e :item/friend ?friend]]")]
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (not (= next-snapshot.kind .Resident)))
    (t.is result.result.ok result.result.error)
    (t.is (= (count result.result.rows) 1))
    (t.is (= result.result.rows[0].values[0].text "Babbage"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 0))
    (vev.delete-query-result result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.close-store store)))

(t.deftest shared-store-db-with-unique-ref-value-tempid-upsert-keeps-shared-db
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        schema (vev.transact-store-text
                 (addr store)
                 "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref :db/unique :db.unique/identity}]")
        seed (vev.transact-store-text (addr store) "[{:db/id 2 :user/email \"grace@example.com\"} {:db/id 1 :user/friend 2}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        next-snapshot (vev.db-with-store-db-text
                        (addr snapshot)
                        "[{:db/id \"friend\" :user/email \"grace@example.com\"} {:db/id \"ada\" :user/friend \"friend\" :user/name \"Ada\"}]")
        result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?e ?name ?friend :where [?e :user/name ?name] [?e :user/friend ?friend]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?name :where [1 :user/name ?name]]")]
    (t.is schema.ok)
    (t.is seed.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (not (= next-snapshot.kind .Resident)))
    (t.is result.result.ok result.result.error)
    (t.is (= (count result.result.rows) 1))
    (t.is (= result.result.rows[0].values[0].entity 1))
    (t.is (= result.result.rows[0].values[1].text "Ada"))
    (t.is (= result.result.rows[0].values[2].entity 2))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 0))
    (vev.delete-query-result result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.delete-tx-report-shallow schema)
    (vev.delete-tx-report-shallow seed)
    (vev.close-store store)))

