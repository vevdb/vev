(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(defn shared-index-values-match? [index: vev.Shared-Int-Index, expected: []int] -> bool
  (when (not (= (vev.shared-int-index-count index) (count expected)))
    (return false))
  (for [value position expected]
    (let [[actual ok] (vev.shared-int-index-at index position)]
      (when (or (not ok)
                (not (= actual value)))
        (return false))))
  true)

(defn shared-index-view-matches-slice? [view: vev.DB-Index-View, expected: []int] -> bool
  (when (not (= (vev.db-index-view-count view) (count expected)))
    (return false))
  (for [value position expected]
    (when (not (= (vev.db-index-view-at view position) value))
      (return false)))
  true)

(defn result-has-entity-string-row? [result: vev.Result-Set, entity: u64, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity)
               (= row.values[1].kind .String)
               (= row.values[1].text text))
      (return true)))
  false)

(defn shared-datom-log-has? [log: vev.Shared-Datom-Log, position: int, entity: u64, attr: string] -> bool
  (let [[datom ok] (vev.shared-datom-log-at log position)]
    (when (not ok)
      (return false))
    (defer (vev.delete-owned-datom datom))
    (and (= datom.e entity)
         (= datom.a attr))))

(t.deftest shared-int-index-retains-old-chunks
  (defer (free_all context.allocator))
  (let [base (vev.shared-int-index-from-slice ([]int [1 3 5 7 9]) 2)
        retained (vev.retain-shared-int-index base)
        appended (vev.shared-int-index-with-appended-slice base ([]int [11 13 15]))
        [base-first-refs base-first-ok] (vev.shared-int-index-ref-count-at base 0)
        [appended-first-refs appended-first-ok] (vev.shared-int-index-ref-count-at appended 0)
        [appended-new-refs appended-new-ok] (vev.shared-int-index-ref-count-at appended 3)
        [_ missing-ok] (vev.shared-int-index-at appended 8)]
    (t.is (shared-index-values-match? base ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? retained ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (t.is base-first-ok)
    (t.is appended-first-ok)
    (t.is appended-new-ok)
    (t.is (= base-first-refs 3))
    (t.is (= appended-first-refs 3))
    (t.is (= appended-new-refs 1))
    (t.is (not missing-ok))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? retained ([]int [1 3 5 7 9])))
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (vev.delete-shared-int-index retained)
    (t.is (shared-index-values-match? appended ([]int [1 3 5 7 9 11 13 15])))
    (vev.delete-shared-int-index appended)))

(t.deftest shared-int-index-retains-unchanged-pages
  (defer (free_all context.allocator))
  (let [base (vev.shared-int-index-from-slice ([]int [1 2 3 4 5 6]) 2)
        changed (vev.shared-int-index-from-base-pages-or-slice base ([]int [1 2 30 40 5 6 7]))
        [changed-first-refs first-ok] (vev.shared-int-index-ref-count-at changed 0)
        [changed-middle-refs middle-ok] (vev.shared-int-index-ref-count-at changed 1)
        [changed-last-refs last-ok] (vev.shared-int-index-ref-count-at changed 2)
        [changed-new-refs new-ok] (vev.shared-int-index-ref-count-at changed 3)
        [base-middle-refs base-middle-ok] (vev.shared-int-index-ref-count-at base 1)]
    (t.is (shared-index-values-match? changed ([]int [1 2 30 40 5 6 7])))
    (t.is first-ok)
    (t.is middle-ok)
    (t.is last-ok)
    (t.is new-ok)
    (t.is base-middle-ok)
    (t.is (= changed-first-refs 2))
    (t.is (= changed-middle-refs 1))
    (t.is (= changed-last-refs 2))
    (t.is (= changed-new-refs 1))
    (t.is (= base-middle-refs 1))
    (vev.delete-shared-int-index base)
    (t.is (shared-index-values-match? changed ([]int [1 2 30 40 5 6 7])))
    (vev.delete-shared-int-index changed)))

(t.deftest shared-db-int-indexes-can-back-index-views
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 1 ":item/rank" (vev.value-int 10) 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)])
        db (vev.init-db datoms)
        shared (vev.shared-db-int-indexes-from-db db 2)
        retained (vev.retain-shared-db-int-indexes shared)
        eavt-view (vev.shared-db-int-index-view (addr shared) .EAVT)
        aevt-view (vev.shared-db-int-index-view (addr shared) .AEVT)
        avet-view (vev.shared-db-int-index-view (addr shared) .AVET)
        vaet-view (vev.shared-db-int-index-view (addr shared) .VAET)]
    (t.is (shared-index-view-matches-slice? eavt-view (slice db.eavt 0)))
    (t.is (shared-index-view-matches-slice? aevt-view (slice db.aevt 0)))
    (t.is (shared-index-view-matches-slice? avet-view (slice db.avet 0)))
    (t.is (shared-index-view-matches-slice? vaet-view (slice db.vaet 0)))
    (vev.delete-shared-db-int-indexes shared)
    (let [retained-eavt-view (vev.shared-db-int-index-view (addr retained) .EAVT)]
      (t.is (shared-index-view-matches-slice? retained-eavt-view (slice db.eavt 0))))
    (vev.delete-shared-db-int-indexes retained)
    (vev.delete-owned-db db)))

(t.deftest shared-datom-log-retains-old-chunks
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)])
        log (vev.shared-datom-log-from-slice datoms 2)
        retained (vev.retain-shared-datom-log log)]
    (t.is (shared-datom-log-has? log 0 1 ":item/name"))
    (t.is (shared-datom-log-has? retained 2 3 ":item/name"))
    (vev.delete-shared-datom-log log)
    (t.is (shared-datom-log-has? retained 1 2 ":item/name"))
    (vev.delete-shared-datom-log retained)))

(t.deftest shared-resident-index-source-runs-source-backed-query
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 1 ":item/rank" (vev.value-int 10) 1 true)
                              (vev.datom-tx 3 ":item/name" (vev.value-string "c") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 2 false)])
        db (vev.init-db datoms)
        shared (vev.shared-db-int-indexes-from-db db 2)
        source (vev.shared-resident-index-db-read-source (addr db) (addr shared))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (t.is (not (result-has-entity-string-row? result 4 "old")))
    (vev.delete-result-set-owned-values result)
    (vev.delete-shared-db-int-indexes shared)
    (vev.delete-owned-db db)))

(t.deftest shared-resident-datom-source-runs-source-backed-query
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom [(vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                              (vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 1 true)
                              (vev.datom-tx 4 ":item/name" (vev.value-string "old") 2 false)])
        db (vev.init-db datoms)
        shared (vev.shared-db-snapshot-from-db db 2)
        retained (vev.retain-shared-db-snapshot shared)]
    (vev.delete-shared-db-snapshot shared)
    (let [source (vev.shared-db-snapshot-read-source (addr retained))
          result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
      (t.is (= (count result.rows) 2))
      (t.is (result-has-entity-string-row? result 1 "a"))
      (t.is (result-has-entity-string-row? result 2 "b"))
      (t.is (not (result-has-entity-string-row? result 4 "old")))
      (vev.delete-result-set-owned-values result))
    (vev.delete-shared-db-snapshot retained)
    (vev.delete-owned-db db)))

(t.deftest shared-db-snapshot-append-shares-datom-log
  (defer (free_all context.allocator))
  (let [base-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                           (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)]))
        after-db (vev.init-db ([]vev.Datom [(vev.datom-tx 1 ":item/name" (vev.value-string "a") 1 true)
                                            (vev.datom-tx 2 ":item/name" (vev.value-string "b") 1 true)
                                            (vev.datom-tx 3 ":item/name" (vev.value-string "c") 2 true)]))
        base-snapshot (vev.shared-db-snapshot-from-db base-db 2)
        appended-snapshot (vev.shared-db-snapshot-with-appended-db base-snapshot after-db 2)
        [base-datom-refs base-datom-refs-ok] (vev.shared-datom-log-ref-count-at base-snapshot.datoms 0)
        [base-current-refs base-current-refs-ok] (vev.shared-int-index-ref-count-at base-snapshot.indexes.current 0)
        [base-eavt-refs base-eavt-refs-ok] (vev.shared-int-index-ref-count-at base-snapshot.indexes.eavt 0)
        source (vev.shared-db-snapshot-read-source (addr appended-snapshot))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is base-datom-refs-ok)
    (t.is base-current-refs-ok)
    (t.is base-eavt-refs-ok)
    (t.is (= base-datom-refs 2))
    (t.is (= base-current-refs 2))
    (t.is (= base-eavt-refs 2))
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-shared-db-snapshot base-snapshot)
    (vev.delete-shared-db-snapshot appended-snapshot)
    (vev.delete-owned-db base-db)
    (vev.delete-owned-db after-db)))

(t.deftest shared-conn-publishes-shared-snapshots
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        tx1 ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "a"))
                             (vev.add 2 ":item/name" (vev.value-string "b"))])
        report1 (vev.shared-conn-transact (addr conn) tx1)
        [datom-refs-before datom-refs-before-ok] (vev.shared-datom-log-ref-count-at conn.snapshot.datoms 0)
        [current-refs-before current-refs-before-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.current 0)
        [eavt-refs-before eavt-refs-before-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.eavt 0)
        tx2 ([]vev.Tx-Data [(vev.add 3 ":item/name" (vev.value-string "c"))])
        report2 (vev.shared-conn-transact (addr conn) tx2)
        [datom-refs-after datom-refs-after-ok] (vev.shared-datom-log-ref-count-at conn.snapshot.datoms 0)
        [current-refs-after current-refs-after-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.current 0)
        [eavt-refs-after eavt-refs-after-ok] (vev.shared-int-index-ref-count-at conn.snapshot.indexes.eavt 0)
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")]
    (t.is report1.ok)
    (t.is report2.ok)
    (t.is datom-refs-before-ok)
    (t.is current-refs-before-ok)
    (t.is eavt-refs-before-ok)
    (t.is datom-refs-after-ok)
    (t.is current-refs-after-ok)
    (t.is eavt-refs-after-ok)
    (t.is (= datom-refs-before 1))
    (t.is (= current-refs-before 1))
    (t.is (= eavt-refs-before 1))
    (t.is (= datom-refs-after 1))
    (t.is (= current-refs-after 1))
    (t.is (= eavt-refs-after 1))
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 1 "a"))
    (t.is (result-has-entity-string-row? result 2 "b"))
    (t.is (result-has-entity-string-row? result 3 "c"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow report1)
    (vev.delete-live-tx-report-shallow report2)
    (vev.delete-shared-conn conn)))
