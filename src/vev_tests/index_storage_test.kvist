(t.deftest shared-conn-resolves-same-tx-ref-schema-literal-tempids-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":item/friend"))
                                  (vev.add 100 ":db/valueType" (vev.value-keyword ":db.type/ref"))
                                  (vev.add-tempid "a" ":item/friend" (vev.value-string "b"))
                                  (vev.add-tempid "b" ":item/name" (vev.value-string "Babbage"))]))
        [a-e a-ok] (vev.tempid-lookup (slice report.tempids 0) "a")
        [b-e b-ok] (vev.tempid-lookup (slice report.tempids 0) "b")
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?friend :where [?e :item/friend ?friend]]")]
    (t.is report.ok)
    (t.is a-ok)
    (t.is b-ok)
    (t.is (= conn.write.source-resolves 1))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity b-e))
    (t.is (not (= a-e b-e)))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-same-tx-ref-schema-value-lookup-ref-through-write-state
