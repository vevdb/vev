(t.deftest shared-conn-resolves-literal-ref-tempids-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":item/friend"))
                                  (vev.add 100 ":db/valueType" (vev.value-keyword ":db.type/ref"))]))
        string-report (vev.shared-conn-transact
                        (addr conn)
                        ([]vev.Tx-Data [(vev.add-tempid "a" ":item/name" (vev.value-string "Ada"))
                                         (vev.add-tempid "b" ":item/name" (vev.value-string "Babbage"))
                                         (vev.add-tempid "a" ":item/friend" (vev.value-string "b"))]))
        negative-report (vev.shared-conn-transact
                          (addr conn)
                          ([]vev.Tx-Data [(vev.add-tempid "-1" ":item/name" (vev.value-string "Grace"))
                                           (vev.add 20 ":item/name" (vev.value-string "Hopper"))
                                           (vev.add 20 ":item/friend" (vev.value-int -1))]))
        source (vev.shared-conn-read-source (addr conn))
        string-result (vev.q-text-db-read-source source "[:find ?friend :where [?e :item/name \"Ada\"] [?e :item/friend ?f] [?f :item/name ?friend]]")
        negative-result (vev.q-text-db-read-source source "[:find ?friend :where [?e :item/name \"Hopper\"] [?e :item/friend ?f] [?f :item/name ?friend]]")
        [b-e b-ok] (vev.tempid-lookup (slice string-report.tempids 0) "b")
        [neg-e neg-ok] (vev.tempid-lookup (slice negative-report.tempids 0) "-1")]
    (t.is schema.ok)
    (t.is string-report.ok)
    (t.is string-report.append-only)
    (t.is negative-report.ok)
    (t.is negative-report.append-only)
    (t.is b-ok)
    (t.is neg-ok)
    (t.is (not (= b-e neg-e)))
    (t.is string-result.ok)
    (t.is (= (count string-result.rows) 1))
    (t.is (= string-result.rows[0].values[0].text "Babbage"))
    (t.is negative-result.ok)
    (t.is (= (count negative-result.rows) 1))
    (t.is (= negative-result.rows[0].values[0].text "Grace"))
    (vev.delete-result-set-owned-values string-result)
    (vev.delete-result-set-owned-values negative-result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow string-report)
    (vev.delete-live-tx-report-shallow negative-report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-expands-retract-attr-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "Ada"))
                                (vev.add 1 ":item/age" (vev.value-int 37))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.retract-attr 1 ":item/name")]))
        source (vev.shared-conn-read-source (addr conn))
        names (vev.q-text-db-read-source source "[:find ?name :where [1 :item/name ?name]]")
        ages (vev.q-text-db-read-source source "[:find ?age :where [1 :item/age ?age]]")]
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= (count report.tx-data) 1))
    (t.is (= report.tx-data[0].added false))
    (t.is names.ok)
    (t.is (= (count names.rows) 0))
    (t.is ages.ok)
    (t.is (= (count ages.rows) 1))
    (t.is (= ages.rows[0].values[0].int-value 37))
    (vev.delete-result-set-owned-values names)
    (vev.delete-result-set-owned-values ages)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-expands-retract-entity-through-write-state
  (defer (free_all context.allocator))
