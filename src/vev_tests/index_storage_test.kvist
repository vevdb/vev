(t.deftest shared-conn-rejects-conflicting-tuple-tempid-upserts-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email+code"))
                                  (vev.add 100 ":db/valueType" (vev.value-keyword ":db.type/tuple"))
                                  (vev.add 100 ":db/tupleAttrs" (vev.value-keyword-vector ([]string [":user/email" ":user/code"])))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                  (vev.add 101 ":db/ident" (vev.value-keyword ":user/handle+code"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/tuple"))
                                  (vev.add 101 ":db/tupleAttrs" (vev.value-keyword-vector ([]string [":user/handle" ":user/code"])))
                                  (vev.add 101 ":db/unique" (vev.value-keyword ":db.unique/identity"))]))
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":user/email" (vev.value-string "ada@example.com"))
                                (vev.add 1 ":user/code" (vev.value-string "same-code"))
                                (vev.add 2 ":user/handle" (vev.value-string "grace"))
                                (vev.add 2 ":user/code" (vev.value-string "same-code"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "a" ":user/handle" (vev.value-string "grace"))
                                  (vev.add-tempid "a" ":user/code" (vev.value-string "same-code"))]))]
    (t.is schema.ok)
    (t.is seed.ok)
    (t.is (not report.ok))
    (t.is (= report.error "conflicting upsert"))
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

