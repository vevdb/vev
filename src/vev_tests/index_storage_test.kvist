    (t.is report.ok report.error)
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Tx-Ops-Overlay))
    (t.is before-result.result.ok)
    (t.is (= (count before-result.result.rows) 0))
    (t.is after-result.result.ok)
