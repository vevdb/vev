(t.deftest shared-conn-resolves-simple-tempids-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 10 ":item/name" (vev.value-string "explicit"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":item/name" (vev.value-string "Ada"))
                                  (vev.add-tempid "a" ":item/age" (vev.value-int 37))
                                  (vev.add-tempid "b" ":item/name" (vev.value-string "Babbage"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?e ?name :where [?e :item/name ?name]]")
        [a-e a-ok] (vev.tempid-lookup (slice report.tempids 0) "a")
        [b-e b-ok] (vev.tempid-lookup (slice report.tempids 0) "b")]
    (t.is seed.ok)
    (t.is report.ok)
    (t.is report.append-only)
    (t.is (= (count report.tx-data) 3))
    (t.is a-ok)
    (t.is b-ok)
    (t.is (not (= a-e b-e)))
    (t.is (> a-e 10))
    (t.is (> b-e 10))
    (t.is result.ok)
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-string-row? result 10 "explicit"))
    (t.is (result-has-entity-string-row? result a-e "Ada"))
    (t.is (result-has-entity-string-row? result b-e "Babbage"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

