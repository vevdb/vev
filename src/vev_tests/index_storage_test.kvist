(t.deftest shared-conn-rejects-conflicting-scalar-tempid-upserts-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                (vev.add 101 ":db/ident" (vev.value-keyword ":user/handle"))
                                (vev.add 101 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                (vev.add 1 ":user/email" (vev.value-string "ada@example.com"))
                                (vev.add 2 ":user/handle" (vev.value-string "grace"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "a" ":user/handle" (vev.value-string "grace"))]))]
    (t.is seed.ok)
    (t.is (not report.ok))
    (t.is (= report.error "conflicting upsert"))
    (t.is (= conn.write.source-resolves 2))
    (t.is (= conn.write.resident-fallbacks 0))
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

(t.deftest shared-conn-resolves-tuple-tempid-upsert-through-write-state
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        schema (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email+code"))
                                  (vev.add 100 ":db/valueType" (vev.value-keyword ":db.type/tuple"))
                                  (vev.add 100 ":db/tupleAttrs" (vev.value-keyword-vector ([]string [":user/email" ":user/code"])))
                                  (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))]))
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":user/email" (vev.value-string "ada@example.com"))
                                (vev.add 1 ":user/code" (vev.value-string "ada-code"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-tempid "a" ":user/name" (vev.value-string "Ada"))
                                  (vev.add-tempid "a" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "a" ":user/code" (vev.value-string "ada-code"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?name :where [1 :user/name ?name]]")
        [a-e a-ok] (vev.tempid-lookup (slice report.tempids 0) "a")]
    (t.is schema.ok)
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= conn.write.source-resolves 3))
    (t.is (= conn.write.resident-fallbacks 0))
    (t.is a-ok)
    (t.is (= a-e 1))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (vev.delete-result-set-owned-values result)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow report)
    (vev.delete-shared-conn conn)))

