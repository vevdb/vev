    (t.is child.ok)
    (t.is (= (count child.rows) 0))
    (t.is friend.ok)
    (t.is (= (count friend.rows) 1))
    (t.is (= friend.rows[0].values[0].text "Grace"))
    (vev.delete-result-set-owned-values parent)
    (vev.delete-result-set-owned-values child)
    (vev.delete-result-set-owned-values friend)
