                                (vev.add 2 ":user/email" (vev.value-string "grace@example.com"))]))
        report (vev.shared-conn-transact
                 (addr conn)
                 ([]vev.Tx-Data [(vev.add-lookup-ref ":user/email" (vev.value-string "ada@example.com") ":user/name" (vev.value-string "Ada"))
                                  (vev.add-value-lookup-ref 1 ":user/friend" ":user/email" (vev.value-string "grace@example.com"))
                                  (vev.add-tempid "ada" ":user/email" (vev.value-string "ada@example.com"))
                                  (vev.add-tempid "grace" ":user/email" (vev.value-string "grace@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?name ?friend-email :where [1 :user/name ?name] [1 :user/friend ?friend] [?friend :user/email ?friend-email]]")
        [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")
        [grace-e grace-ok] (vev.tempid-lookup (slice report.tempids 0) "grace")]
    (t.is seed.ok)
    (t.is report.ok)
    (t.is (= conn.write.source-resolves 2))
    (t.is (= conn.write.resident-fallbacks 0))
