(t.deftest shared-conn-resolves-simple-lookup-ref-writes-through-source
  (defer (free_all context.allocator))
  (let [conn (vev.create-shared-conn 2)
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 100 ":db/ident" (vev.value-keyword ":user/email"))
                                (vev.add 100 ":db/unique" (vev.value-keyword ":db.unique/identity"))
                                (vev.add 101 ":db/ident" (vev.value-keyword ":user/friend"))
                                (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))
                                (vev.add 1 ":user/email" (vev.value-string "ada@example.com"))
                                (vev.add 1 ":user/name" (vev.value-string "Ada"))
                                (vev.add 2 ":user/email" (vev.value-string "grace@example.com"))
                                (vev.add 2 ":user/name" (vev.value-string "Grace"))]))
        link (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.Tx-Data {op: ":db/add"
                                              lookup-attr: ":user/email"
                                              lookup-value: (vev.value-string "ada@example.com")
                                              has-lookup-ref: true
                                              a: ":user/friend"
                                              value-lookup-attr: ":user/email"
                                              value-lookup-value: (vev.value-string "grace@example.com")
                                              has-value-lookup-ref: true})]))
        missing-retract (vev.shared-conn-transact
                          (addr conn)
                          ([]vev.Tx-Data [(vev.retract-value-lookup-ref 1 ":user/friend" ":user/email" (vev.value-string "missing@example.com"))]))
        source (vev.shared-conn-read-source (addr conn))
        result (vev.q-text-db-read-source source "[:find ?friend-name :where [1 :user/friend ?f] [?f :user/name ?friend-name]]")
        profiled (vev.q-text-db-read-source-profiled source "[:find ?friend-name :where [1 :user/friend ?f] [?f :user/name ?friend-name]]")]
    (t.is seed.ok)
    (t.is link.ok)
    (t.is link.append-only)
    (t.is (= (count link.tx-data) 1))
    (t.is missing-retract.ok)
    (t.is (= (count missing-retract.tx-data) 0))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].kind .String))
    (t.is (= result.rows[0].values[0].text "Grace"))
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (> profiled.stats.source-index-scans 0))
    (t.is (= profiled.stats.binding-materializations 0))
    (vev.delete-result-set-owned-values result)
    (vev.delete-profiled-result-set-owned-values profiled)
    (vev.delete-live-tx-report-shallow seed)
    (vev.delete-live-tx-report-shallow link)
    (vev.delete-live-tx-report-shallow missing-retract)
    (vev.delete-shared-conn conn)))

