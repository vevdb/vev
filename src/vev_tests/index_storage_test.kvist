                                  (vev.add 101 ":db/ident" (vev.value-keyword ":item/profile"))
                                  (vev.add 101 ":db/valueType" (vev.value-keyword ":db.type/ref"))
                                  (vev.add 101 ":db/isComponent" (vev.value-bool true))]))
        seed (vev.shared-conn-transact
               (addr conn)
               ([]vev.Tx-Data [(vev.add 1 ":item/name" (vev.value-string "Ada"))
