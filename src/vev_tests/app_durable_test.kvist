(package main)

(import os "core:os")
(import thread "core:thread")
(import test "kvist:test")
(import kdata "kvist:data")
(import d "../vev_app")

(def app-test-path "/tmp/vev-app-durable-test.sqlite")
(def concurrent-app-test-path "/tmp/vev-app-concurrent-test.sqlite")

(defstruct Concurrent-Reader {
  conn: d.Conn
  iterations: int
  ok: bool
})

(def concurrent-value-query
  '[:find ?value .
    :where [?e :entity/id "counter"]
           [?e :entity/value ?value]])

(defn concurrent-read-loop [reader: ^Concurrent-Reader]
  (let [remaining reader^.iterations]
    (while (> remaining 0)
      (let [db (d.db reader^.conn)
            value (d.q concurrent-value-query db)]
        (when (not (kdata.int? value))
          (set! reader^.ok false))
        (d.close db))
      (dec! remaining))))

(def ref-join-query
  '[:find ?workspace-id .
    :in $ ?project-id
    :where [?project :entity/id ?project-id]
           [?project :project/workspace ?workspace]
           [?workspace :entity/id ?workspace-id]])

(defn remove-app-test-db []
  (os.remove app-test-path)
  (os.remove "/tmp/vev-app-durable-test.sqlite-wal")
  (os.remove "/tmp/vev-app-durable-test.sqlite-shm"))

(defn remove-concurrent-app-test-db []
  (os.remove concurrent-app-test-path)
  (os.remove "/tmp/vev-app-concurrent-test.sqlite-wal")
  (os.remove "/tmp/vev-app-concurrent-test.sqlite-shm"))

(test.deftest durable-app-query-input-joins-through-ref
  (remove-app-test-db)
  (let [conn (d.connect app-test-path)]
    (d.transact conn
      '[[:db/add 10 :db/ident :entity/id]
        [:db/add 10 :db/valueType :db.type/string]
        [:db/add 10 :db/unique :db.unique/identity]
        [:db/add 11 :db/ident :project/workspace]
        [:db/add 11 :db/valueType :db.type/ref]])
    (d.transact conn
      '[{:db/id "workspace" :entity/id "workspace-main"}])
    ;; Materialize and close a snapshot before the next transaction. Durable
    ;; connection reads must advance after a successful write.
    (let [before (d.db conn)
          workspace (d.q '[:find ?id .
                           :where [?e :entity/id ?id]] before)]
      (test.is (= (kdata.string workspace) "workspace-main"))
      (d.close before))
    (d.transact conn
      '[{:db/id "project"
         :entity/id "project-main"
         :project/workspace [:entity/id "workspace-main"]}])
    (let [db (d.db conn)
          project-with-input (d.q '[:find ?project .
                                     :in $ ?project-id
                                     :where [?project :entity/id ?project-id]] db "project-main")
          project-workspace-with-input (d.q '[:find ?workspace .
                                               :in $ ?project-id
                                               :where [?project :entity/id ?project-id]
                                                      [?project :project/workspace ?workspace]] db "project-main")
          result (d.q ref-join-query db "project-main")]
      (test.is (not (kdata.nil? project-with-input)))
      (test.is (not (kdata.nil? project-workspace-with-input)))
      (test.is (kdata.string? result))
      (test.is (= (kdata.string result) "workspace-main"))
      (d.close db))
    (d.close conn))
  (remove-app-test-db))

(test.deftest durable-app-connection-serializes-concurrent-reads-and-writes
  (remove-concurrent-app-test-db)
  (let [conn (d.connect concurrent-app-test-path)]
    (d.transact conn
      '[[:db/add 10 :db/ident :entity/id]
        [:db/add 10 :db/valueType :db.type/string]
        [:db/add 10 :db/unique :db.unique/identity]
        [:db/add 11 :db/ident :entity/value]
        [:db/add 11 :db/valueType :db.type/long]])
    (d.transact conn
      '[{:db/id "counter" :entity/id "counter" :entity/value 0}])
    ;; Holding an immutable DB value must not block a later connection
    ;; transaction, and the held value must retain its original basis.
    (let [held (d.db conn)]
      (d.transact conn
        '[[:db/add [:entity/id "counter"] :entity/value 1]])
      (let [held-value (d.q concurrent-value-query held)]
        (test.is (= (kdata.int held-value) 0)))
      (d.close held))
    (let [reader (Concurrent-Reader {conn: conn iterations: 30 ok: true})
          worker (thread.create-and-start-with-poly-data (addr reader) concurrent-read-loop)
          index 0]
      (while (< index 30)
        (d.transact conn
          `[[:db/add [:entity/id "counter"] :entity/value ~index]])
        (inc! index))
      (thread.join worker)
      (thread.destroy worker)
      (test.is reader.ok))
    (d.close conn))
  (remove-concurrent-app-test-db))
