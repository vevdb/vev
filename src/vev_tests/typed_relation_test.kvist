(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(def typed-relation-rules
  "[[(person ?e ?name) [?e :name ?name]] [(has-age ?e) [?e :age ?age]]]")

(defn has-text-int-row? [result: vev.Result-Set, text: string, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value value))
      (return true)))
  false)

(defn has-text-row? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(t.deftest typed-rule-projection-materializes-for-binding-fallback-operators
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Bob\"] [:db/add 2 :blocked true]]")
        get-else-result (vev.q-text-with-rules
                          conn.db
                          "[:find ?name ?age :in $ % :where (person ?e ?name) [(get-else $ ?e :age 0) ?age]]"
                          typed-relation-rules
                          ([]vev.Query-Input []))
        function-result (vev.q-text-with-rules
                          conn.db
                          "[:find ?name ?len :in $ % :where (person ?e ?name) [(count ?name) ?len]]"
                          typed-relation-rules
                          ([]vev.Query-Input []))
        not-result (vev.q-text-with-rules
                     conn.db
                     "[:find ?name :in $ % :where (person ?e ?name) (not [?e :blocked true])]"
                     typed-relation-rules
                     ([]vev.Query-Input []))
        rule-fallback-result (vev.q-text-with-rules
                               conn.db
                               "[:find ?name :in $ % :where (person ?e ?name) (has-age ?e)]"
                               typed-relation-rules
                               ([]vev.Query-Input []))]
    (t.is get-else-result.ok)
    (t.is (= (count get-else-result.rows) 2))
    (t.is (has-text-int-row? get-else-result "Ada" 37))
    (t.is (has-text-int-row? get-else-result "Bob" 0))
    (t.is function-result.ok)
    (t.is (= (count function-result.rows) 2))
    (t.is (has-text-int-row? function-result "Ada" 3))
    (t.is (has-text-int-row? function-result "Bob" 3))
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 1))
    (t.is (has-text-row? not-result "Ada"))
    (t.is rule-fallback-result.ok)
    (t.is (= (count rule-fallback-result.rows) 1))
    (t.is (has-text-row? rule-fallback-result "Ada"))))
