(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(def typed-relation-rules
  "[[(person ?e ?name) [?e :name ?name]] [(has-age ?e) [?e :age ?age]]]")

(defn has-text-int-row? [result: vev.Result-Set, text: string, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value value))
      (return true)))
  false)

(defn has-text-row? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(defn has-text-pair-row? [result: vev.Result-Set, left: string, right: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text left)
               (= row.values[1].kind .String)
               (= row.values[1].text right))
      (return true)))
  false)

(defn has-text-keyword-row? [result: vev.Result-Set, text: string, keyword: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Keyword)
               (= row.values[1].text keyword))
      (return true)))
  false)

(defn has-keyword-row? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Keyword)
               (= row.values[0].text text))
      (return true)))
  false)

(defn has-text-entity-row? [result: vev.Result-Set, text: string, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Entity)
               (= row.values[1].entity entity))
      (return true)))
  false)

(defn has-text-keyword-int-row? [result: vev.Result-Set, text: string, attr: string, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Keyword)
               (= row.values[1].text attr)
               (= row.values[2].kind .Int)
               (= row.values[2].int-value value))
      (return true)))
  false)

(defn has-text-keyword-bool-row? [result: vev.Result-Set, text: string, attr: string, value: bool] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Keyword)
               (= row.values[1].text attr)
               (= row.values[2].kind .Bool)
               (= row.values[2].bool-value value))
      (return true)))
  false)

(t.deftest singleton-relation-is-typed-only
  (defer (free_all context.allocator))
  (let [rel (vev.query-relation-singleton)
        materialized (vev.query-relation-materialized-bindings rel)]
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 1))
    (t.is (= (count rel.tuples) 0))
    (t.is (= (count materialized) 1))
    (t.is (= (count materialized[0].items) 0))
    (for [binding materialized]
      (delete binding.items))
    (delete materialized)
    (vev.delete-query-relation rel)))

(t.deftest scalar-input-initial-relation-is-typed-only
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        prepared (vev.prepare-query-text "[:find ?e :in ?name :where [?e :name ?name]]")
        inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Ada"))])
        [rel binding-count] (vev.query-relation-initial-from-inputs conn.db prepared.query inputs)
        materialized (vev.query-relation-materialized-bindings rel)]
    (t.is prepared.ok)
    (t.is (= binding-count 1))
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 1))
    (t.is (= (count rel.tuples) 0))
    (t.is (= (count rel.attrs) 1))
    (t.is (= rel.attrs[0] "?name"))
    (t.is (= rel.typed-columns[0].texts[0] "Ada"))
    (t.is (= (count materialized) 1))
    (t.is (= (count materialized[0].items) 1))
    (for [binding materialized]
      (delete binding.items))
    (delete materialized)
    (vev.delete-query-relation rel)
    (vev.delete-prepared-query-shallow prepared)))

