(t.deftest map-relation-input-initial-relation-is-typed-only
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        prepared (vev.prepare-query-text "[:find ?e :in [[?name ?email]] :where [?e :name ?name]]")
        map-input (vev.value-map
                    ([]vev.Value [(vev.value-string "Ada") (vev.value-string "ada@example.com")
                                  (vev.value-string "Grace") (vev.value-string "grace@example.com")]))
        inputs ([]vev.Query-Input [(vev.query-input-scalar map-input)])
        [rel binding-count] (vev.query-relation-initial-from-inputs conn.db prepared.query inputs)
        materialized (vev.query-relation-materialized-bindings rel)]
    (t.is prepared.ok)
    (t.is (= binding-count 2))
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 2))
    (t.is (= (count rel.tuples) 0))
    (t.is (= rel.typed-columns[0].texts[0] "Ada"))
    (t.is (= rel.typed-columns[0].texts[1] "Grace"))
    (t.is (= rel.typed-columns[1].texts[0] "ada@example.com"))
    (t.is (= rel.typed-columns[1].texts[1] "grace@example.com"))
    (t.is (= (count materialized) 2))
    (for [binding materialized]
      (delete binding.items))
    (delete materialized)
    (vev.delete-query-relation rel)
    (vev.delete-prepared-query-shallow prepared)))

(t.deftest db-clause-with-bound-entity-and-value-builds-typed-relation
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clause (vev.Clause {e: (vev.term-entity 1)
                            a: (vev.term-var "attr")
                            v: (vev.term-string "Ada")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)})
        rel (vev.query-relation-from-db-clause report.db-after clause "")]
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 1))
    (t.is (= (count rel.attrs) 1))
    (t.is (= rel.attrs[0] "attr"))
    (t.is (= rel.typed-columns[0].kind .Keyword))
    (t.is (= rel.typed-columns[0].texts[0] ":user/name"))
    (vev.delete-query-relation rel)))

(t.deftest singleton-product-with-db-clause-keeps-typed-row
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clause (vev.Clause {e: (vev.term-entity 1)
                            a: (vev.term-var "attr")
                            v: (vev.term-string "Ada")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)})
        left (vev.query-relation-singleton)
        right (vev.query-relation-from-db-clause report.db-after clause "")
        joined (vev.query-relation-join report.db-after ([]vev.DB-Source []) left right)]
    (t.is joined.has-typed-columns)
    (t.is (= joined.typed-rows 1))
    (t.is (= (count joined.attrs) 1))
    (t.is (= joined.attrs[0] "attr"))
    (t.is (= joined.typed-columns[0].kind .Keyword))
    (t.is (= joined.typed-columns[0].texts[0] ":user/name"))
    (vev.delete-query-relation joined)
    (vev.delete-query-relation right)
    (vev.delete-query-relation left)))

(t.deftest typed-db-clause-relation-projects-find-row
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clause (vev.Clause {e: (vev.term-entity 1)
                            a: (vev.term-var "attr")
                            v: (vev.term-string "Ada")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)})
        left (vev.query-relation-singleton)
        right (vev.query-relation-from-db-clause report.db-after clause "")
        joined (vev.query-relation-join report.db-after ([]vev.DB-Source []) left right)
        query (vev.query ([]string ["attr"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) ([]vev.Clause [clause]) ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        [rows rows-ok] (vev.result-rows-for-typed-relation query joined)]
    (t.is rows-ok)
    (t.is (= (count rows) 1))
    (t.is (= rows[0].values[0].kind .Keyword))
    (t.is (= rows[0].values[0].text ":user/name"))
    (vev.delete-result-rows-shallow rows)
    (vev.delete-query-relation joined)
    (vev.delete-query-relation right)
    (vev.delete-query-relation left)))

(t.deftest relation-engine-projects-bound-entity-attr-query
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clause (vev.Clause {e: (vev.term-entity 1)
                            a: (vev.term-var "attr")
                            v: (vev.term-string "Ada")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)})
        query (vev.query ([]string ["attr"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) ([]vev.Clause [clause]) ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        stats (vev.query-stats-empty)
        rel (vev.relation-engine-relation-profiled report.db-after query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr stats))
        [rows rows-ok] (vev.result-rows-for-typed-relation query rel)]
    (t.is rows-ok)
    (t.is (= rel.typed-rows 1))
    (t.is (= (count rows) 1))
    (t.is (= rows[0].values[0].text ":user/name"))
    (vev.delete-result-rows-shallow rows)
    (vev.delete-query-relation rel)))

(t.deftest source-input-clause-producer-is-typed-only
  (defer (free_all context.allocator))
  (let [source (vev.value-vector
                 ([]vev.Value [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))
                               (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Bob"))]))
        clause (vev.Clause {e: (vev.term-var "?e")
                            a: (vev.term-keyword ":name")
                            v: (vev.term-var "?name")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)
                            source: "$rows"
                            has-source: true
                            source-width: 3})
        rel (vev.query-relation-from-source-value-clause source clause)]
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 2))
    (t.is (= (count rel.tuples) 0))
    (t.is (= (count rel.typed-columns) 2))
    (t.is (= rel.typed-columns[0].ints[0] 1))
    (t.is (= rel.typed-columns[0].ints[1] 2))
    (t.is (= rel.typed-columns[1].texts[0] "Ada"))
    (t.is (= rel.typed-columns[1].texts[1] "Bob"))
    (vev.delete-query-relation rel)))

(t.deftest source-input-clause-producer-preserves-repeated-var-semantics
  (defer (free_all context.allocator))
  (let [source (vev.value-vector
                 ([]vev.Value [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":same") (vev.value-int 1))
                               (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":same") (vev.value-int 3))
                               (vev.value-vector3 (vev.value-int 4) (vev.value-keyword ":other") (vev.value-int 4))]))
        clause (vev.Clause {e: (vev.term-var "?e")
                            a: (vev.term-keyword ":same")
                            v: (vev.term-var "?e")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)
                            source: "$rows"
                            has-source: true
                            source-width: 3})
        rel (vev.query-relation-from-source-value-clause source clause)]
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 1))
    (t.is (= (count rel.tuples) 0))
    (t.is (= (count rel.typed-columns) 1))
    (t.is (= rel.typed-columns[0].ints[0] 1))
    (vev.delete-query-relation rel)))

(t.deftest bound-source-input-clause-uses-typed-indexed-operator
  (defer (free_all context.allocator))
  (let [people-source (vev.value-vector
                        ([]vev.Value [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))
                                      (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Bob"))
                                      (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":name") (vev.value-string "Cy"))]))
        status-source (vev.value-vector
                        ([]vev.Value [(vev.value-vector3 (vev.value-int 99) (vev.value-keyword ":status") (vev.value-keyword ":ignored"))
                                      (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":status") (vev.value-keyword ":active"))
                                      (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":status") (vev.value-keyword ":inactive"))
                                      (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":status") (vev.value-keyword ":active"))]))
        people-clause (vev.Clause {e: (vev.term-var "?e")
                                   a: (vev.term-keyword ":name")
                                   v: (vev.term-var "?name")
                                   tx-term: (vev.term-wildcard)
                                   op-term: (vev.term-wildcard)
                                   source: "$people"
                                   has-source: true
                                   source-width: 3})
        status-clause (vev.Clause {e: (vev.term-var "?e")
                                   a: (vev.term-keyword ":status")
                                   v: (vev.term-var "?status")
                                   tx-term: (vev.term-wildcard)
                                   op-term: (vev.term-wildcard)
                                   source: "$status"
                                   has-source: true
                                   source-width: 3})
        people-rel (vev.query-relation-from-source-value-clause people-source people-clause)
        [out out-ok] (vev.query-relation-apply-source-input-clause-indexed-typed status-source people-rel status-clause)]
    (t.is out-ok)
    (t.is out.has-typed-columns)
    (t.is (= out.typed-rows 3))
    (t.is (= (count out.tuples) 0))
    (t.is (= (count out.attrs) 3))
    (t.is (= out.typed-columns[0].ints[0] 1))
    (t.is (= out.typed-columns[1].texts[0] "Ada"))
    (t.is (= out.typed-columns[2].texts[0] ":active"))
    (t.is (= out.typed-columns[0].ints[1] 2))
    (t.is (= out.typed-columns[1].texts[1] "Bob"))
    (t.is (= out.typed-columns[2].texts[1] ":inactive"))
    (t.is (= out.typed-columns[0].ints[2] 3))
    (t.is (= out.typed-columns[1].texts[2] "Cy"))
    (t.is (= out.typed-columns[2].texts[2] ":active"))
    (vev.delete-query-relation out)
    (vev.delete-query-relation people-rel)))

(t.deftest two-attr-materialized-rule-producer-is-typed-only
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Bob\"] [:db/add 2 :age 41]]")
        prepared-rules (vev.parse-rules-text "[[(name-age ?name ?age) [?e :name ?name] [?e :age ?age]]]")
        stats (vev.query-stats-empty)
        [rel rel-ok] (vev.query-relation-from-two-attr-same-entity-rule conn.db prepared-rules.rules[0] ":name" ":age" (addr stats))]
    (t.is prepared-rules.ok)
    (t.is rel-ok)
    (t.is rel.has-typed-columns)
    (t.is (= rel.typed-rows 2))
    (t.is (= (count rel.tuples) 0))
    (t.is (= rel.typed-columns[0].texts[0] "Ada"))
    (t.is (= rel.typed-columns[1].ints[0] 37))
    (t.is (= rel.typed-columns[0].texts[1] "Bob"))
    (t.is (= rel.typed-columns[1].ints[1] 41))
    (vev.delete-query-relation rel)
    (delete prepared-rules.rules)))

(t.deftest typed-relation-dedupe-stays-typed
  (defer (free_all context.allocator))
  (let [source (vev.value-vector
                 ([]vev.Value [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))
                               (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))
                               (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Bob"))]))
        clause (vev.Clause {e: (vev.term-var "?e")
                            a: (vev.term-keyword ":name")
                            v: (vev.term-var "?name")
                            tx-term: (vev.term-wildcard)
                            op-term: (vev.term-wildcard)
                            source: "$rows"
                            has-source: true
                            source-width: 3})
        rel (vev.query-relation-from-source-value-clause source clause)
        deduped (vev.query-relation-dedupe-step rel)]
    (t.is deduped.has-typed-columns)
    (t.is (= deduped.typed-rows 2))
    (t.is (= (count deduped.tuples) 0))
    (t.is (= deduped.typed-columns[0].ints[0] 1))
    (t.is (= deduped.typed-columns[0].ints[1] 2))
    (vev.delete-query-relation deduped)
    (vev.delete-query-relation rel)))

(t.deftest typed-join-with-incompatible-common-column-is-empty
  (defer (free_all context.allocator))
  (let [left-source (vev.value-vector
                      ([]vev.Value [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))]))
        right-source (vev.value-vector
                       ([]vev.Value [(vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":status") (vev.value-keyword ":active"))]))
        left-clause (vev.Clause {e: (vev.term-var "?e")
                                 a: (vev.term-keyword ":name")
                                 v: (vev.term-var "?x")
                                 tx-term: (vev.term-wildcard)
                                 op-term: (vev.term-wildcard)
                                 source: "$left"
                                 has-source: true
                                 source-width: 3})
        right-clause (vev.Clause {e: (vev.term-var "?other")
                                  a: (vev.term-keyword ":status")
                                  v: (vev.term-var "?x")
                                  tx-term: (vev.term-wildcard)
                                  op-term: (vev.term-wildcard)
                                  source: "$right"
                                  has-source: true
                                  source-width: 3})
        left-rel (vev.query-relation-from-source-value-clause left-source left-clause)
        right-rel (vev.query-relation-from-source-value-clause right-source right-clause)
        joined (vev.query-relation-join (vev.DB {}) ([]vev.DB-Source []) left-rel right-rel)]
    (t.is left-rel.has-typed-columns)
    (t.is right-rel.has-typed-columns)
    (t.is (= left-rel.typed-columns[1].kind .String))
    (t.is (= right-rel.typed-columns[1].kind .Keyword))
    (t.is joined.has-typed-columns)
    (t.is (= joined.typed-rows 0))
    (t.is (= (count joined.tuples) 0))
    (t.is (= (count joined.attrs) 3))
    (vev.delete-query-relation joined)
    (vev.delete-query-relation right-rel)
    (vev.delete-query-relation left-rel)))

(t.deftest nested-ground-binding-stays-typed
  (defer (free_all context.allocator))
  (let [rel (vev.query-relation-singleton)
        nested (vev.value-vector2 (vev.value-int 2) (vev.value-int 3))
        source (vev.value-vector2 (vev.value-int 1) nested)
        binding (vev.input-binding-tuple
                  ([]vev.Input-Binding [(vev.input-binding-var "?a")
                                        (vev.input-binding-tuple
                                          ([]vev.Input-Binding [(vev.input-binding-var "?b")
                                                               (vev.input-binding-var "?c")]))]))
        ground (vev.Ground {source: (vev.term-value source)
                            binding: binding})
        [out out-ok] (vev.query-relation-apply-ground-typed rel ground)]
    (t.is out-ok)
    (t.is out.has-typed-columns)
    (t.is (= out.typed-rows 1))
    (t.is (= (count out.tuples) 0))
    (t.is (= (count out.attrs) 3))
    (t.is (= out.typed-columns[0].ints[0] 1))
    (t.is (= out.typed-columns[1].ints[0] 2))
    (t.is (= out.typed-columns[2].ints[0] 3))
    (vev.delete-query-relation out)
    (vev.delete-query-relation rel)
    (delete binding.items[1].items)
    (delete binding.items)))

(t.deftest nested-function-binding-stays-typed
  (defer (free_all context.allocator))
  (let [rel (vev.query-relation-singleton)
        nested (vev.value-vector2 (vev.value-int 2) (vev.value-int 3))
        binding (vev.input-binding-tuple
                  ([]vev.Input-Binding [(vev.input-binding-var "?a")
                                        (vev.input-binding-tuple
                                          ([]vev.Input-Binding [(vev.input-binding-var "?b")
                                                               (vev.input-binding-var "?c")]))]))
        function (vev.Function-Clause {op: "vector"
                                       terms: ([]vev.Term [(vev.term-int 1) (vev.term-value nested)])
                                       out-binding: binding})
        [out out-ok] (vev.query-relation-extend-function-typed rel function ([]vev.Native-Query-Fn []))]
    (t.is out-ok)
    (t.is out.has-typed-columns)
    (t.is (= out.typed-rows 1))
    (t.is (= (count out.tuples) 0))
    (t.is (= (count out.attrs) 3))
    (t.is (= out.typed-columns[0].ints[0] 1))
    (t.is (= out.typed-columns[1].ints[0] 2))
    (t.is (= out.typed-columns[2].ints[0] 3))
    (vev.delete-query-relation out)
    (vev.delete-query-relation rel)
    (delete binding.items[1].items)
    (delete binding.items)))

(t.deftest repeated-nested-ground-binding-filters-typed
  (defer (free_all context.allocator))
  (let [rel (vev.query-relation-singleton)
        source (vev.value-vector2 (vev.value-int 1)
                                  (vev.value-vector2 (vev.value-int 1) (vev.value-int 2)))
        binding (vev.input-binding-tuple
                  ([]vev.Input-Binding [(vev.input-binding-var "?a")
                                        (vev.input-binding-tuple
                                          ([]vev.Input-Binding [(vev.input-binding-var "?a")
                                                               (vev.input-binding-var "?a")]))]))
        ground (vev.Ground {source: (vev.term-value source)
                            binding: binding})
        [out out-ok] (vev.query-relation-apply-ground-typed rel ground)]
    (t.is out-ok)
    (t.is out.has-typed-columns)
    (t.is (= out.typed-rows 0))
    (t.is (= (count out.tuples) 0))
    (t.is (= (count out.attrs) 1))
    (vev.delete-query-relation out)
    (vev.delete-query-relation rel)
    (delete binding.items[1].items)
    (delete binding.items)))

(t.deftest typed-rule-projection-materializes-for-binding-fallback-operators
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[{:db/id 10 :db/ident :self :db/valueType :db.type/ref} [:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 1 :role \"engineer\"] [:db/add 1 :self 1] [:db/add 2 :name \"Bob\"] [:db/add 2 :role \"admin\"] [:db/add 2 :blocked true] [:db/add 2 :self 1]]")
        get-else-result (vev.q-text-with-rules
                          conn.db
                          "[:find ?name ?age :in $ % :where (person ?e ?name) [(get-else $ ?e :age 0) ?age]]"
                          typed-relation-rules
                          ([]vev.Query-Input []))
        function-result (vev.q-text-with-rules
                          conn.db
                          "[:find ?name ?len :in $ % :where (person ?e ?name) [(count ?name) ?len]]"
                          typed-relation-rules
                          ([]vev.Query-Input []))
        function-tuple-result (vev.q-text-with-rules
                                conn.db
                                "[:find ?name ?len :in $ % :where (person ?e ?raw-name) [(vector ?raw-name 3) [?name ?len]]]"
                                typed-relation-rules
                                ([]vev.Query-Input []))
        function-collection-result (vev.q-text-with-rules
                                     conn.db
                                     "[:find ?name ?tag :in $ % :where (person ?e ?name) [(vector :x :y) [?tag ...]]]"
                                     typed-relation-rules
                                     ([]vev.Query-Input []))
        not-result (vev.q-text-with-rules
                     conn.db
                     "[:find ?name :in $ % :where (person ?e ?name) (not [?e :blocked true])]"
                     typed-relation-rules
                     ([]vev.Query-Input []))
        get-some-result (vev.q-text-with-rules
                          conn.db
                          "[:find ?name ?attr ?value :in $ % :where (person ?e ?name) [(get-some $ ?e :age :blocked) [?attr ?value]]]"
                          typed-relation-rules
                          ([]vev.Query-Input []))
        ground-scalar-result (vev.q-text-with-rules
                               conn.db
                               "[:find ?name ?tag :in $ % :where (person ?e ?name) [(ground :seen) ?tag]]"
                               typed-relation-rules
                               ([]vev.Query-Input []))
        ground-collection-result (vev.q-text-with-rules
                                   conn.db
                                   "[:find ?name ?tag :in $ % :where (person ?e ?name) [(ground [:x :y]) [?tag ...]]]"
                                   typed-relation-rules
                                   ([]vev.Query-Input []))
        or-result (vev.q-text-with-rules
                    conn.db
                    "[:find ?name :in $ % :where (person ?e ?name) (or [?e :age 37] [?e :blocked true])]"
                    typed-relation-rules
                    ([]vev.Query-Input []))
        multi-clause-or-result (vev.q-text-with-rules
                                 conn.db
                                 "[:find ?name ?marker :in $ % :where (person ?e ?name) (or (and [?e :role ?marker] [?e :self 1]) (and [?e :name ?marker] [?e :blocked true]))]"
                                 typed-relation-rules
                                 ([]vev.Query-Input []))
        value-bound-clause-result (vev.q-text-with-rules
                                    conn.db
                                    "[:find ?name ?other :in $ % :where (person ?e ?name) [?other :name ?name]]"
                                    typed-relation-rules
                                    ([]vev.Query-Input []))
        repeated-var-clause-result (vev.q-text-with-rules
                                     conn.db
                                     "[:find ?name :in $ % :where (person ?e ?name) [?e :self ?e]]"
                                     typed-relation-rules
                                     ([]vev.Query-Input []))
        reverse-clause-result (vev.q-text-with-rules
                                conn.db
                                "[:find ?name ?owner-name :in $ % :where (person ?e ?name) [?e :_self ?owner] [?owner :name ?owner-name]]"
                                typed-relation-rules
                                ([]vev.Query-Input []))
        constant-rule-projection-result (vev.q-text-with-rules
                                          conn.db
                                          "[:find ?name :in $ % :where (person 1 ?name)]"
                                          typed-relation-rules
                                          ([]vev.Query-Input []))
        wildcard-rule-projection-result (vev.q-text-with-rules
                                          conn.db
                                          "[:find ?tag :in $ % :where (person ?e _) [(ground :seen) ?tag]]"
                                          typed-relation-rules
                                          ([]vev.Query-Input []))
        rule-fallback-result (vev.q-text-with-rules
                               conn.db
                               "[:find ?name :in $ % :where (person ?e ?name) (has-age ?e)]"
                               typed-relation-rules
                               ([]vev.Query-Input []))]
    (t.is get-else-result.ok)
    (t.is (= (count get-else-result.rows) 2))
    (t.is (has-text-int-row? get-else-result "Ada" 37))
    (t.is (has-text-int-row? get-else-result "Bob" 0))
    (t.is function-result.ok)
    (t.is (= (count function-result.rows) 2))
    (t.is (has-text-int-row? function-result "Ada" 3))
    (t.is (has-text-int-row? function-result "Bob" 3))
    (t.is function-tuple-result.ok)
    (t.is (= (count function-tuple-result.rows) 2))
    (t.is (has-text-int-row? function-tuple-result "Ada" 3))
    (t.is (has-text-int-row? function-tuple-result "Bob" 3))
    (t.is function-collection-result.ok)
    (t.is (= (count function-collection-result.rows) 4))
    (t.is (has-text-keyword-row? function-collection-result "Ada" ":x"))
    (t.is (has-text-keyword-row? function-collection-result "Ada" ":y"))
    (t.is (has-text-keyword-row? function-collection-result "Bob" ":x"))
    (t.is (has-text-keyword-row? function-collection-result "Bob" ":y"))
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 1))
    (t.is (has-text-row? not-result "Ada"))
    (t.is get-some-result.ok)
    (t.is (= (count get-some-result.rows) 2))
    (t.is (has-text-keyword-int-row? get-some-result "Ada" ":age" 37))
    (t.is (has-text-keyword-bool-row? get-some-result "Bob" ":blocked" true))
    (t.is ground-scalar-result.ok)
    (t.is (= (count ground-scalar-result.rows) 2))
    (t.is ground-collection-result.ok)
    (t.is (= (count ground-collection-result.rows) 4))
    (t.is or-result.ok)
    (t.is (= (count or-result.rows) 2))
    (t.is (has-text-row? or-result "Ada"))
    (t.is (has-text-row? or-result "Bob"))
    (t.is multi-clause-or-result.ok)
    (t.is (= (count multi-clause-or-result.rows) 3))
    (t.is (has-text-pair-row? multi-clause-or-result "Ada" "engineer"))
    (t.is (has-text-pair-row? multi-clause-or-result "Bob" "admin"))
    (t.is (has-text-pair-row? multi-clause-or-result "Bob" "Bob"))
    (t.is value-bound-clause-result.ok)
    (t.is (= (count value-bound-clause-result.rows) 2))
    (t.is (has-text-entity-row? value-bound-clause-result "Ada" 1))
    (t.is (has-text-entity-row? value-bound-clause-result "Bob" 2))
    (t.is repeated-var-clause-result.ok)
    (t.is (= (count repeated-var-clause-result.rows) 1))
    (t.is (has-text-row? repeated-var-clause-result "Ada"))
    (t.is reverse-clause-result.ok)
    (t.is (= (count reverse-clause-result.rows) 2))
    (t.is (has-text-pair-row? reverse-clause-result "Ada" "Ada"))
    (t.is (has-text-pair-row? reverse-clause-result "Ada" "Bob"))
    (t.is constant-rule-projection-result.ok)
    (t.is (= (count constant-rule-projection-result.rows) 1))
    (t.is (has-text-row? constant-rule-projection-result "Ada"))
    (t.is wildcard-rule-projection-result.ok)
    (t.is (= (count wildcard-rule-projection-result.rows) 1))
    (t.is (has-keyword-row? wildcard-rule-projection-result ":seen"))
    (t.is rule-fallback-result.ok)
    (t.is (= (count rule-fallback-result.rows) 1))
    (t.is (has-text-row? rule-fallback-result "Ada"))))
