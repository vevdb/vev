(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(t.deftest prepared-pull-pattern-has-deterministic-explicit-lifetime
  (let [prepared (vev.prepare-pull-pattern-text "[:user/name]")]
    (defer (vev.delete-prepared-pull-pattern-shallow prepared))
    (t.is prepared.ok prepared.error)
    (t.is (= (count prepared.pattern) 1))
    (t.is (= prepared.pattern[0].a ":user/name"))))

(t.deftest prepared-pull-pattern-error-has-safe-explicit-cleanup
  (let [prepared (vev.prepare-pull-pattern-text "not-edn [")]
    (defer (vev.delete-prepared-pull-pattern-shallow prepared))
    (t.is (not prepared.ok))
    (t.is (= (count prepared.pattern) 0))))

(t.deftest prepared-rule-literals-have-deterministic-explicit-lifetime
  (let [prepared
          (vev.parse-rules-text
            "[[(label ?e ?value) [?e :name ?name] [(str ?name \"!\") ?value] [(get-else $ ?e :kind :kind/default) ?kind]]]")]
    (defer (vev.delete-prepared-rules-shallow prepared))
    (t.is prepared.ok prepared.error)
    (t.is (= (count prepared.rules) 1))))
