          [store-pull-aggregate-batch store-pull-aggregate-batch-ok store-pull-aggregate-batch-error] (vev.materialize-source-typed-pull-aggregate-batch store-source ([]vev.DB-Read-Named-Source []) pull-aggregate-grouped-prepared.query ([]vev.Query-Input []) store-pull-aggregate-rel ([]vev.Native-Query-Fn []))]
