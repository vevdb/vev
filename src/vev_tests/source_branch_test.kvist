    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-rules-shallow prepared-rules)))

(t.deftest source-backed-recursive-rules-reject-recursive-calls-inside-negation
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source (vev.resident-db-read-source (addr conn.db))
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":follow") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":follow") (vev.value-int 3))]))
        row-source (vev.relation-value-db-read-source (addr rows))
        named-sources ([]vev.DB-Read-Named-Source [(vev.db-read-named-source "$rows" row-source)])
        prepared (vev.prepare-query-text "[:find ?e1 ?e2 :in $rows % :where ($rows route ?e1 ?e2)]")
        prepared-rules (vev.parse-rules-text "[[(route ?e1 ?e2) [?e1 :follow ?e2]] [(route ?e1 ?e2) [?e1 :follow ?t] (not (route ?t ?e2))]]")
        query-value (vev.query-with-rule-call-plans (vev.query-copy-with-rules prepared.query (slice prepared-rules.rules 0)))
        result (vev.db-read-source-q-query-with-sources-inputs-and-fns
                 source
                 named-sources
                 query-value
                 ([]vev.Query-Input [])
                 ([]vev.Native-Query-Fn []))]
    (t.is prepared.ok prepared.error)
    (t.is prepared-rules.ok prepared-rules.error)
    (t.is (not result.ok))
    (t.is (= result.error "source-backed recursive negation is not supported; recursive rule calls inside not/not-join require stratified semantics"))
    (vev.delete-query-shallow query-value)
    (vev.delete-result-set-owned-values result)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-rules-shallow prepared-rules)))

(t.deftest source-backed-rules-plan-expression-bodies
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 42] [:db/add 2 :height 180] [:db/add 3 :name \"Barbara\"] [:db/add 3 :age 49]]")
        source (vev.resident-db-read-source (addr conn.db))
        function-prepared (vev.prepare-query-text "[:find ?label :in $ % :where (name-label ?e ?label)]")
        function-rules (vev.parse-rules-text "[[(name-label ?e ?label) [?e :name ?name] [(str ?name \"!\") ?label]]]")
        get-else-prepared (vev.prepare-query-text "[:find ?name ?height :in $ % :where (height-or-zero ?e ?name ?height)]")
        get-else-rules (vev.parse-rules-text "[[(height-or-zero ?e ?name ?height) [?e :name ?name] [(get-else $ ?e :height 0) ?height]]]")
        get-some-prepared (vev.prepare-query-text "[:find ?name ?attr ?value :in $ % :where (first-present ?e ?name ?attr ?value)]")
        get-some-rules (vev.parse-rules-text "[[(first-present ?e ?name ?attr ?value) [?e :name ?name] [(get-some $ ?e :height :age) [?attr ?value]]]]")
        ground-prepared (vev.prepare-query-text "[:find ?name :in $ % :where (target-name ?e ?name)]")
        ground-rules (vev.parse-rules-text "[[(target-name ?e ?name) [(ground \"Grace\") ?target] [?e :name ?target] [?e :name ?name]]]")
        not-prepared (vev.prepare-query-text "[:find ?name :in $ % :where (without-height ?e ?name)]")
        not-rules (vev.parse-rules-text "[[(without-height ?e ?name) [?e :name ?name] (not [?e :height])]]")
        or-prepared (vev.prepare-query-text "[:find ?name :in $ % :where (selected-name ?e ?name)]")
        or-rules (vev.parse-rules-text "[[(selected-name ?e ?name) [?e :name ?name] (or [?e :age 37] [?e :height 180])]]")
        function-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules function-prepared.query (slice function-rules.rules 0)))
        get-else-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules get-else-prepared.query (slice get-else-rules.rules 0)))
        get-some-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules get-some-prepared.query (slice get-some-rules.rules 0)))
        ground-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules ground-prepared.query (slice ground-rules.rules 0)))
        not-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules not-prepared.query (slice not-rules.rules 0)))
        or-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules or-prepared.query (slice or-rules.rules 0)))
        [function-rel function-stats function-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                       source
                                                       ([]vev.DB-Read-Named-Source [])
                                                       function-query
                                                       ([]vev.Query-Input [])
                                                       ([]vev.Native-Query-Fn []))
        [get-else-rel get-else-stats get-else-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                       source
                                                       ([]vev.DB-Read-Named-Source [])
                                                       get-else-query
                                                       ([]vev.Query-Input [])
                                                       ([]vev.Native-Query-Fn []))
        [get-some-rel get-some-stats get-some-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                       source
                                                       ([]vev.DB-Read-Named-Source [])
                                                       get-some-query
                                                       ([]vev.Query-Input [])
                                                       ([]vev.Native-Query-Fn []))
        [ground-rel ground-stats ground-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                source
                                                ([]vev.DB-Read-Named-Source [])
                                                ground-query
                                                ([]vev.Query-Input [])
                                                ([]vev.Native-Query-Fn []))
        [not-rel not-stats not-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                       source
                                       ([]vev.DB-Read-Named-Source [])
                                       not-query
                                       ([]vev.Query-Input [])
                                       ([]vev.Native-Query-Fn []))
        [or-rel or-stats or-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                    source
                                    ([]vev.DB-Read-Named-Source [])
                                    or-query
                                    ([]vev.Query-Input [])
                                    ([]vev.Native-Query-Fn []))
        function-result (vev.q-prepared-db-read-source-with-rules
                          source
                          function-prepared
                          function-rules
                          ([]vev.Query-Input []))
        get-else-result (vev.q-prepared-db-read-source-with-rules
                          source
                          get-else-prepared
                          get-else-rules
                          ([]vev.Query-Input []))
        get-some-result (vev.q-prepared-db-read-source-with-rules
                          source
                          get-some-prepared
                          get-some-rules
                          ([]vev.Query-Input []))
        ground-result (vev.q-prepared-db-read-source-with-rules
                        source
                        ground-prepared
                        ground-rules
                        ([]vev.Query-Input []))
        not-result (vev.q-prepared-db-read-source-with-rules
                     source
                     not-prepared
                     not-rules
                     ([]vev.Query-Input []))
        or-result (vev.q-prepared-db-read-source-with-rules
                    source
                    or-prepared
                    or-rules
                    ([]vev.Query-Input []))]
    (t.is function-prepared.ok function-prepared.error)
    (t.is function-rules.ok function-rules.error)
    (t.is function-used)
    (t.is function-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count function-rel) 3))
    (t.is (> function-stats.rule-calls 0))
    (t.is (= function-stats.binding-materializations 0))
    (t.is function-result.ok function-result.error)
    (t.is (source-branch-has-text? function-result "Ada!"))
    (t.is (source-branch-has-text? function-result "Grace!"))
    (t.is (source-branch-has-text? function-result "Barbara!"))
    (t.is get-else-prepared.ok get-else-prepared.error)
    (t.is get-else-rules.ok get-else-rules.error)
    (t.is get-else-used)
    (t.is get-else-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count get-else-rel) 3))
    (t.is (> get-else-stats.rule-calls 0))
    (t.is (= get-else-stats.binding-materializations 0))
    (t.is get-else-result.ok get-else-result.error)
    (t.is (= (count get-else-result.rows) 3))
    (t.is get-some-prepared.ok get-some-prepared.error)
    (t.is get-some-rules.ok get-some-rules.error)
    (t.is get-some-used)
    (t.is get-some-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count get-some-rel) 3))
    (t.is (> get-some-stats.rule-calls 0))
    (t.is (= get-some-stats.binding-materializations 0))
    (t.is get-some-result.ok get-some-result.error)
    (t.is (= (count get-some-result.rows) 3))
    (t.is ground-prepared.ok ground-prepared.error)
    (t.is ground-rules.ok ground-rules.error)
    (t.is ground-used)
    (t.is ground-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count ground-rel) 1))
    (t.is (> ground-stats.rule-calls 0))
    (t.is (= ground-stats.binding-materializations 0))
    (t.is ground-result.ok ground-result.error)
    (t.is (= (count ground-result.rows) 1))
    (t.is (source-branch-has-text? ground-result "Grace"))
    (t.is not-prepared.ok not-prepared.error)
    (t.is not-rules.ok not-rules.error)
    (t.is not-used)
    (t.is not-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count not-rel) 2))
    (t.is (> not-stats.rule-calls 0))
    (t.is (= not-stats.binding-materializations 0))
    (t.is not-result.ok not-result.error)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-text? not-result "Ada"))
    (t.is (source-branch-has-text? not-result "Barbara"))
    (t.is or-prepared.ok or-prepared.error)
    (t.is or-rules.ok or-rules.error)
    (t.is or-used)
    (t.is or-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count or-rel) 2))
    (t.is (> or-stats.rule-calls 0))
    (t.is (= or-stats.binding-materializations 0))
    (t.is or-result.ok or-result.error)
    (t.is (= (count or-result.rows) 2))
    (t.is (source-branch-has-text? or-result "Ada"))
    (t.is (source-branch-has-text? or-result "Grace"))
    (vev.delete-query-relation function-rel)
    (vev.delete-query-relation get-else-rel)
    (vev.delete-query-relation get-some-rel)
    (vev.delete-query-relation ground-rel)
    (vev.delete-query-relation not-rel)
    (vev.delete-query-relation or-rel)
    (vev.delete-query-shallow function-query)
    (vev.delete-query-shallow get-else-query)
    (vev.delete-query-shallow get-some-query)
    (vev.delete-query-shallow ground-query)
    (vev.delete-query-shallow not-query)
    (vev.delete-query-shallow or-query)
    (vev.delete-result-set-owned-values function-result)
    (vev.delete-result-set-owned-values get-else-result)
    (vev.delete-result-set-owned-values get-some-result)
    (vev.delete-result-set-owned-values ground-result)
    (vev.delete-result-set-owned-values not-result)
    (vev.delete-result-set-owned-values or-result)
    (vev.delete-prepared-query-shallow function-prepared)
    (vev.delete-prepared-query-shallow get-else-prepared)
    (vev.delete-prepared-query-shallow get-some-prepared)
