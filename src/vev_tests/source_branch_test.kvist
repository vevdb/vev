(t.deftest branch-local-rule-calls-use-rule-engine
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :active true] [:db/add 2 :name \"Grace\"] [:db/add 2 :active false] [:db/add 3 :name \"Oleg\"]]")
        rules "[[(active ?e) [?e :active true]] [(named ?e ?name) [?e :name ?name]]]"
        not-result (vev.q-text-profiled-with-rules
                     conn.db
                     "[:find ?e :in $ % :where [?e :name] (not (active ?e))]"
                     rules
                     ([]vev.Query-Input []))
        or-result (vev.q-text-profiled-with-rules
                    conn.db
                    "[:find ?e :in $ % :where (or (and (active ?e)) (and (named ?e \"Oleg\")))]"
                    rules
                    ([]vev.Query-Input []))]
    (t.is not-result.result.ok not-result.result.error)
    (t.is (= (count not-result.result.rows) 2))
    (t.is (source-branch-has-entity? not-result.result 2))
    (t.is (source-branch-has-entity? not-result.result 3))
    (t.is or-result.result.ok or-result.result.error)
    (t.is (= (count or-result.result.rows) 2))
    (t.is (source-branch-has-entity? or-result.result 1))
    (t.is (source-branch-has-entity? or-result.result 3))
    (vev.delete-profiled-result-set-owned-values not-result)
    (vev.delete-profiled-result-set-owned-values or-result)))

