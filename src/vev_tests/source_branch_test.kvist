(t.deftest literal-range-predicate-tightens-resident-and-source-scans
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :salary 40000] [:db/add 2 :salary 60000] [:db/add 3 :salary 80000]]")
        source (vev.resident-db-read-source (addr conn.db))
        resident (vev.q-text-profiled
                   conn.db
                   "[:find ?e ?s :where [?e :salary ?s] [(> ?s 50000)]]")
        source-result (vev.q-text-db-read-source-profiled
                        source
                        "[:find ?e ?s :where [?e :salary ?s] [(> ?s 50000)]]")]
    (t.is resident.result.ok resident.result.error)
    (t.is (= (count resident.result.rows) 2))
    (t.is (= resident.stats.clause-candidates 2))
    (t.is (= resident.stats.binding-materializations 0))
    (t.is source-result.result.ok source-result.result.error)
    (t.is (= (count source-result.result.rows) 2))
    (t.is (= source-result.stats.clause-candidates 2))
    (t.is (= source-result.stats.binding-materializations 0))
    (vev.delete-profiled-result-set-owned-values resident)
    (vev.delete-profiled-result-set-owned-values source-result)))

(t.deftest input-bound-range-predicate-tightens-resident-and-source-scans
  (defer (free_all context.allocator))
  (let [prepared (vev.prepare-query-text "[:find ?e ?s :in $ ?min :where [?e :salary ?s] [(> ?s ?min)]]")
        plan (vev.physical-plan-from-query prepared.query)
        conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :salary 40000] [:db/add 2 :salary 60000] [:db/add 3 :salary 80000]]")
        source (vev.resident-db-read-source (addr conn.db))
        inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 50000))])
        resident (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?e ?s :in $ ?min :where [?e :salary ?s] [(> ?s ?min)]]"
                   inputs)
        source-result (vev.q-text-db-read-source-profiled-with-inputs
                        source
                        "[:find ?e ?s :in $ ?min :where [?e :salary ?s] [(> ?s ?min)]]"
                        inputs)]
    (t.is prepared.ok prepared.error)
    (t.is plan.ops[0].has-pushdown-scalar)
    (t.is (= plan.ops[0].pushdown-scalar-requirement.kind .VarVarCompare))
    (t.is (= plan.ops[0].pushdown-scalar-requirement.var-name "?s"))
    (t.is (= plan.ops[0].pushdown-scalar-requirement.other-var "?min"))
    (t.is resident.result.ok resident.result.error)
    (t.is (= (count resident.result.rows) 2))
    (t.is (= resident.stats.clause-candidates 2))
    (t.is (= resident.stats.binding-materializations 0))
    (t.is source-result.result.ok source-result.result.error)
    (t.is (= (count source-result.result.rows) 2))
    (t.is (= source-result.stats.clause-candidates 2))
    (t.is (= source-result.stats.binding-materializations 0))
    (vev.delete-physical-plan plan)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-profiled-result-set-owned-values resident)
    (vev.delete-profiled-result-set-owned-values source-result)))

(t.deftest map-relation-input-query-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 2 :name \"Grace\"]]")
        map-input (vev.value-map
                    ([]vev.Value [(vev.value-string "Ada") (vev.value-string "primary")
                                  (vev.value-string "Grace") (vev.value-string "secondary")]))
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?label :in $ [[?name ?label]] :where [?e :name ?name]]"
                   ([]vev.Query-Input [(vev.query-input-scalar map-input)]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 2))
    (t.is (source-branch-has-text? profiled.result "primary"))
    (t.is (source-branch-has-text? profiled.result "secondary"))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (= profiled.stats.input-bindings 2))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest plain-not-join-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        adult-result (vev.q-text
                       conn.db
                       "[:find ?e :where [?e :id] (not-join [?e] [?e :age ?age] [(> ?age 40)])]")
        shadow-result (vev.q-text
                        conn.db
                        "[:find ?e :where [?e :id] [?e :name ?name] (not-join [?e] [?e :age ?name])]")]
    (t.is adult-result.ok adult-result.error)
    (t.is (= (count adult-result.rows) 1))
    (t.is (source-branch-has-entity? adult-result 1))
    (t.is shadow-result.ok shadow-result.error)
    (t.is (= (count shadow-result.rows) 0))))

(t.deftest db-read-source-relation-source-input-branches-work
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source (vev.resident-db-read-source (addr conn.db))
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":id") (vev.value-int 1))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan"))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 30))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":id") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr"))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 41))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":id") (vev.value-int 3))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":name") (vev.value-string "Oleg"))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":age") (vev.value-int 50))]))
        inputs ([]vev.Query-Input [(vev.query-input-scalar rows)])
        scalar-inputs ([]vev.Query-Input [(vev.query-input-scalar rows)
                                          (vev.query-input-scalar (vev.value-int 40))])
        aggregate-inputs ([]vev.Query-Input [(vev.query-input-scalar rows)
                                             (vev.query-input-scalar (vev.value-string "sort-reverse"))])
        not-result (vev.q-text-db-read-source-with-inputs
                     source
                     "[:find ?e :in $rows :where [$rows ?e :id ?id] (not [$rows ?e :name \"Petr\"])]"
                     inputs)
        or-join-result (vev.q-text-db-read-source-with-inputs
                         source
                         "[:find ?e :in $rows :where [$rows ?e :id ?id] (or-join [?e] (and [$rows ?e :name ?name] [(= ?name \"Ivan\")]) (and [$rows ?e :age ?age] [(> ?age 45)]))]"
                         inputs)
        profiled-or-join (vev.q-text-db-read-source-profiled-with-inputs
                           source
                           "[:find ?e :in $rows :where [$rows ?e :id ?id] (or-join [?e] (and [$rows ?e :name ?name] [(= ?name \"Ivan\")]) (and [$rows ?e :age ?age] [(> ?age 45)]))]"
                           inputs)
        scalar-result (vev.q-text-db-read-source-with-inputs
                        source
                        "[:find ?e :in $rows ?min :where [$rows ?e :age ?age] [(> ?age ?min)]]"
                        scalar-inputs)
        profiled-aggregate (vev.q-text-db-read-source-profiled-with-inputs
                             source
                             "[:find (sum ?age) (count ?age) (max ?age) :in $rows :where [$rows ?e :age ?age]]"
                             inputs)
        profiled-grouped-aggregate (vev.q-text-db-read-source-profiled-with-inputs
                                     source
                                     "[:find ?name (count ?age) :in $rows :where [$rows ?e :name ?name] [$rows ?e :age ?age]]"
                                     inputs)
        profiled-custom-aggregate (vev.q-text-db-read-source-profiled-with-inputs
                                    source
                                    "[:find (aggregate ?agg ?age) :in $rows ?agg :where [$rows ?e :age ?age]]"
                                    aggregate-inputs)
        profiled-top-aggregate (vev.q-text-db-read-source-profiled-with-inputs
                                 source
                                 "[:find [(min 2 ?age) (max 2 ?age)] :in $rows :where [$rows ?e :age ?age]]"
                                 inputs)
        profiled-not (vev.q-text-db-read-source-profiled-with-inputs
                       source
                       "[:find ?e :in $rows :where [$rows ?e :id ?id] (not [$rows ?e :name \"Petr\"])]"
                       inputs)
        profiled-not-join (vev.q-text-db-read-source-profiled-with-inputs
                            source
                            "[:find ?e :in $rows :where [$rows ?e :id ?id] (not-join [?e] [$rows ?e :name \"Petr\"])]"
                            inputs)
        profiled (vev.q-text-db-read-source-profiled-with-inputs
                   source
                   "[:find ?name :in $rows ?min :where [$rows ?e :age ?age] [(> ?age ?min)] [$rows ?e :name ?name]]"
                   scalar-inputs)]
    (t.is not-result.ok not-result.error)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-int? not-result 1))
    (t.is (source-branch-has-int? not-result 3))
    (t.is or-join-result.ok or-join-result.error)
    (t.is (= (count or-join-result.rows) 2))
    (t.is (source-branch-has-int? or-join-result 1))
    (t.is (source-branch-has-int? or-join-result 3))
    (t.is profiled-or-join.result.ok profiled-or-join.result.error)
    (t.is (= (count profiled-or-join.result.rows) 2))
    (t.is (source-branch-has-int? profiled-or-join.result 1))
    (t.is (source-branch-has-int? profiled-or-join.result 3))
    (t.is (= profiled-or-join.stats.binding-materializations 0))
    (t.is scalar-result.ok scalar-result.error)
    (t.is (= (count scalar-result.rows) 2))
    (t.is (source-branch-has-int? scalar-result 2))
    (t.is (source-branch-has-int? scalar-result 3))
    (t.is profiled-aggregate.result.ok profiled-aggregate.result.error)
    (t.is (= (count profiled-aggregate.result.rows) 1))
    (t.is (= profiled-aggregate.result.rows[0].values[0].int-value 121))
    (t.is (= profiled-aggregate.result.rows[0].values[1].int-value 3))
    (t.is (= profiled-aggregate.result.rows[0].values[2].int-value 50))
    (t.is (= profiled-aggregate.stats.binding-materializations 0))
    (t.is profiled-grouped-aggregate.result.ok profiled-grouped-aggregate.result.error)
    (t.is (= (count profiled-grouped-aggregate.result.rows) 3))
    (t.is (= profiled-grouped-aggregate.stats.binding-materializations 0))
    (t.is profiled-custom-aggregate.result.ok profiled-custom-aggregate.result.error)
    (t.is (= (count profiled-custom-aggregate.result.rows) 1))
    (t.is (= profiled-custom-aggregate.result.rows[0].values[0].kind .Vector))
    (t.is (= profiled-custom-aggregate.result.rows[0].values[0].items[0].int-value 50))
    (t.is (= profiled-custom-aggregate.result.rows[0].values[0].items[2].int-value 30))
    (t.is (= profiled-custom-aggregate.stats.binding-materializations 0))
    (t.is profiled-top-aggregate.result.ok profiled-top-aggregate.result.error)
    (t.is (= (count profiled-top-aggregate.result.rows) 1))
    (t.is (= (count profiled-top-aggregate.result.rows[0].values) 2))
    (t.is (= profiled-top-aggregate.result.rows[0].values[0].kind .Vector))
    (t.is (= (count profiled-top-aggregate.result.rows[0].values[0].items) 2))
    (t.is (= profiled-top-aggregate.result.rows[0].values[0].items[0].int-value 30))
    (t.is (= profiled-top-aggregate.result.rows[0].values[0].items[1].int-value 41))
    (t.is (= profiled-top-aggregate.result.rows[0].values[1].kind .Vector))
    (t.is (= (count profiled-top-aggregate.result.rows[0].values[1].items) 2))
    (t.is (= profiled-top-aggregate.result.rows[0].values[1].items[0].int-value 50))
    (t.is (= profiled-top-aggregate.result.rows[0].values[1].items[1].int-value 41))
    (t.is (= profiled-top-aggregate.stats.binding-materializations 0))
    (t.is profiled-not.result.ok profiled-not.result.error)
    (t.is (= (count profiled-not.result.rows) 2))
    (t.is (source-branch-has-int? profiled-not.result 1))
    (t.is (source-branch-has-int? profiled-not.result 3))
    (t.is (= profiled-not.stats.binding-materializations 0))
    (t.is profiled-not-join.result.ok profiled-not-join.result.error)
    (t.is (= (count profiled-not-join.result.rows) 2))
    (t.is (source-branch-has-int? profiled-not-join.result 1))
    (t.is (source-branch-has-int? profiled-not-join.result 3))
    (t.is (= profiled-not-join.stats.binding-materializations 0))
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 2))
    (t.is (source-branch-has-text? profiled.result "Petr"))
    (t.is (source-branch-has-text? profiled.result "Oleg"))
    (t.is (= profiled.stats.input-bindings 1))
    (t.is (> profiled.stats.source-index-scans 0))
    (t.is (= profiled.stats.max-intermediate-bindings 2))
    (t.is (= profiled.stats.binding-materializations 0))))
