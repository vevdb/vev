(package vev-tests)

(import arr "kvist:arr")
(import t "kvist:test")
(import vev "../vev")

(defn source-branch-has-entity? [result: vev.Result-Set, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity))
      (return true)))
  false)

(defn source-branch-has-entity-pair? [result: vev.Result-Set, left: u64, right: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity left)
               (= row.values[1].kind .Entity)
               (= row.values[1].entity right))
      (return true)))
  false)

(defn source-branch-has-text? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(defn source-branch-has-track-release-row? [result: vev.Result-Set, title: string, album: string, year: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text title)
               (= row.values[1].kind .String)
               (= row.values[1].text album)
               (= row.values[2].kind .Int)
               (= row.values[2].int-value year))
      (return true)))
  false)

(defn source-branch-has-text-any-column? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (for [value row.values]
      (when (and (= value.kind .String)
                 (= value.text text))
        (return true))))
  false)

(defn source-branch-has-int? [result: vev.Result-Set, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Int)
               (= row.values[0].int-value value))
      (return true)))
  false)

(defn source-branch-mixed-composite-relation [] -> vev.Query-Relation
  (let [attrs (arr.into [dynamic]string ([]string ["?v"]))
        sources (arr.into [dynamic]string ([]string [""]))
        column (vev.relation-column-empty)
        columns (make [dynamic]vev.Relation-Column 0 1)]
    (set! column.kind .Mixed)
    (set! column.has-kind true)
    (arr.push! column.values (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2)])))
    (arr.push! column.values (vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":b")])))
    (arr.push! columns column)
    (vev.Query-Relation {attrs: attrs
                         attr-sources: sources
                         attr-index: (vev.query-relation-attr-index (slice attrs 0))
                         tuples: (make [dynamic]vev.Binding)
                         typed-columns: columns
                         typed-rows: 2
                         has-typed-columns: true})))

(defn delete-source-branch-mixed-composite-relation [rel: vev.Query-Relation]
  (vev.delete-query-relation rel))

(t.deftest source-db-multi-clause-not-or-branches-stay-typed
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[{:db/id 100 :db/ident :name :db/unique :db.unique/identity} [:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3]]")
        _ (vev.transact-text
            (addr right)
            "[{:db/id 100 :db/ident :name :db/unique :db.unique/identity} [:db/add 3 :name \"Ivan\"] [:db/add 3 :id 3] [:db/add 1 :name \"Petr\"] [:db/add 1 :id 1] [:db/add 2 :name \"Oleg\"] [:db/add 2 :id 2]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$1" left.db)
                                  (vev.db-source "$2" right.db)])
        not-result (vev.q-text-with-sources
                     left.db
                     "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 not-join [?e] [?e :id ?id] [?e :name \"Petr\"])]"
                     inputs
                     sources)
        or-result (vev.q-text-with-sources
                    left.db
                    "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 or-join [?e] (and [?e :id ?id] [?e :name \"Ivan\"]) (and [?e :id ?id] [?e :name \"Oleg\"]))]"
                    inputs
                    sources)]
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-entity? not-result 2))
    (t.is (source-branch-has-entity? not-result 3))
    (t.is or-result.ok)
    (t.is (= (count or-result.rows) 2))
    (t.is (source-branch-has-entity? or-result 2))
    (t.is (source-branch-has-entity? or-result 3))))

(t.deftest source-db-bound-entity-attr-clause-stays-profiled
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :id 1] [:db/add 2 :name \"Grace\"] [:db/add 2 :id 2] [:db/add 3 :name \"Barbara\"] [:db/add 3 :id 3]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$left" left.db)])
        profiled (vev.q-text-profiled-with-sources
                   left.db
                   "[:find ?name :in $left :where [$left ?e :id 2] [$left ?e :name ?name]]"
                   inputs
                   sources)]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (= profiled.result.rows[0].values[0].text "Grace"))
    (t.is (= profiled.stats.steps 2))
    (t.is (= profiled.stats.output-rows 1))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (or (> profiled.stats.source-index-scans 0)
              (> profiled.stats.typed-index-scans 0)))
    (t.is (> profiled.stats.source-operators 0))
    (t.is (= profiled.stats.binding-materializations 0))
    (t.is (= profiled.stats.generic-materialization-steps 0))
    (t.is (> profiled.stats.clause-candidates 0))))

(t.deftest named-db-read-source-clauses-use-typed-operator
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 10 :name \"left-only\"]]")
        _ (vev.transact-text
            (addr right)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :id 1] [:db/add 2 :name \"Grace\"] [:db/add 2 :id 2]]")
        prepared (vev.prepare-query-text "[:find ?name :where [$right ?e :id 2] [$right ?e :name ?name]]")
        left-source (vev.resident-db-read-source (addr left.db))
        right-source (vev.resident-db-read-source (addr right.db))
        named-sources ([]vev.DB-Read-Named-Source [(vev.db-read-named-source "$right" right-source)])
        [typed-rel typed-stats typed-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                             left-source
                                             named-sources
                                             prepared.query
                                             ([]vev.Query-Input [])
                                             ([]vev.Native-Query-Fn []))
        profiled (vev.q-prepared-db-read-source-profiled-with-sources-inputs-and-fns
                   left-source
                   named-sources
                   prepared
                   ([]vev.Query-Input [])
                   ([]vev.Native-Query-Fn []))]
    (t.is prepared.ok prepared.error)
    (t.is typed-used)
    (t.is typed-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count typed-rel) 1))
    (t.is (= typed-rel.typed-columns[0].kind .Entity))
    (t.is (= typed-rel.typed-columns[0].entities[0] 2))
    (t.is (= typed-rel.typed-columns[1].kind .String))
    (t.is (= typed-rel.typed-columns[1].texts[0] "Grace"))
    (t.is (> typed-stats.source-index-scans 0))
    (t.is (= typed-stats.binding-materializations 0))
    (t.is (= typed-stats.generic-materialization-steps 0))
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (= profiled.result.rows[0].values[0].text "Grace"))
    (t.is (= profiled.stats.binding-materializations 0))
    (t.is (= profiled.stats.generic-materialization-steps 0))
    (vev.delete-query-relation typed-rel)
    (vev.delete-profiled-result-set-owned-values profiled)
    (vev.delete-prepared-query-shallow prepared)))

(t.deftest named-db-read-source-get-else-get-some-use-typed-operator
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 10 :name \"left-only\"]]")
        _ (vev.transact-text
            (addr right)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :id 1] [:db/add 2 :name \"Grace\"] [:db/add 2 :id 2] [:db/add 2 :height 180]]")
        get-else-prepared (vev.prepare-query-text "[:find ?name :where [(ground 2) ?e] [(get-else $right ?e :name \"fallback\") ?name]]")
        get-some-prepared (vev.prepare-query-text "[:find ?attr ?value :where [(ground 2) ?e] [(get-some $right ?e :height :name) [?attr ?value]]]")
        left-source (vev.resident-db-read-source (addr left.db))
        right-source (vev.resident-db-read-source (addr right.db))
        named-sources ([]vev.DB-Read-Named-Source [(vev.db-read-named-source "$right" right-source)])
        [get-else-rel get-else-stats get-else-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                       left-source
                                                       named-sources
                                                       get-else-prepared.query
                                                       ([]vev.Query-Input [])
                                                       ([]vev.Native-Query-Fn []))
        [get-some-rel get-some-stats get-some-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                       left-source
                                                       named-sources
                                                       get-some-prepared.query
                                                       ([]vev.Query-Input [])
                                                       ([]vev.Native-Query-Fn []))
        get-else-profiled (vev.q-prepared-db-read-source-profiled-with-sources-inputs-and-fns
                            left-source
                            named-sources
                            get-else-prepared
                            ([]vev.Query-Input [])
                            ([]vev.Native-Query-Fn []))
        get-some-profiled (vev.q-prepared-db-read-source-profiled-with-sources-inputs-and-fns
                            left-source
                            named-sources
                            get-some-prepared
                            ([]vev.Query-Input [])
                            ([]vev.Native-Query-Fn []))]
    (t.is get-else-prepared.ok get-else-prepared.error)
    (t.is get-else-used)
    (t.is get-else-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count get-else-rel) 1))
    (t.is (= get-else-rel.typed-columns[1].kind .String))
    (t.is (= get-else-rel.typed-columns[1].texts[0] "Grace"))
    (t.is (> get-else-stats.source-index-scans 0))
    (t.is (= get-else-stats.binding-materializations 0))
    (t.is (= get-else-stats.generic-materialization-steps 0))
    (t.is get-some-prepared.ok get-some-prepared.error)
    (t.is get-some-used)
    (t.is get-some-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count get-some-rel) 1))
    (t.is (= get-some-rel.typed-columns[1].kind .Keyword))
    (t.is (= get-some-rel.typed-columns[1].texts[0] ":height"))
    (t.is (= get-some-rel.typed-columns[2].kind .Int))
    (t.is (= get-some-rel.typed-columns[2].ints[0] 180))
    (t.is (> get-some-stats.source-index-scans 0))
    (t.is (= get-some-stats.binding-materializations 0))
    (t.is (= get-some-stats.generic-materialization-steps 0))
    (t.is get-else-profiled.result.ok get-else-profiled.result.error)
    (t.is (= (count get-else-profiled.result.rows) 1))
    (t.is (= get-else-profiled.result.rows[0].values[0].text "Grace"))
    (t.is (= get-else-profiled.stats.binding-materializations 0))
    (t.is (= get-else-profiled.stats.generic-materialization-steps 0))
    (t.is get-some-profiled.result.ok get-some-profiled.result.error)
    (t.is (= (count get-some-profiled.result.rows) 1))
    (t.is (= get-some-profiled.result.rows[0].values[0].text ":height"))
    (t.is (= get-some-profiled.result.rows[0].values[1].int-value 180))
    (t.is (= get-some-profiled.stats.binding-materializations 0))
    (t.is (= get-some-profiled.stats.generic-materialization-steps 0))
    (vev.delete-query-relation get-else-rel)
    (vev.delete-query-relation get-some-rel)
    (vev.delete-profiled-result-set-owned-values get-else-profiled)
    (vev.delete-profiled-result-set-owned-values get-some-profiled)
    (vev.delete-prepared-query-shallow get-else-prepared)
    (vev.delete-prepared-query-shallow get-some-prepared)))

(t.deftest source-query-result-ownership-is-query-shape-aware
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 41]]")
        source (vev.resident-db-read-source (addr conn.db))
        plain (vev.q-result-text-db-read-source source "[:find ?name :where [?e :name ?name]]")
        aggregate (vev.q-result-text-db-read-source source "[:find (count ?e) :where [?e :name ?name]]")
        function-result (vev.q-result-text-db-read-source source "[:find ?label :where [?e :name ?name] [(str ?name \"!\") ?label]]")]
    (t.is plain.result.ok plain.result.error)
    (t.is (not (vev.query-result-owns-values? plain)))
    (t.is aggregate.result.ok aggregate.result.error)
    (t.is (vev.query-result-owns-values? aggregate))
    (t.is function-result.result.ok function-result.result.error)
    (t.is (vev.query-result-owns-values? function-result))
    (vev.delete-query-result plain)
    (vev.delete-query-result aggregate)
    (vev.delete-query-result function-result)))

(t.deftest source-db-not-existence-uses-clause-source
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 1 :id 1] [:db/add 1 :name \"Ada\"] [:db/add 2 :id 2] [:db/add 2 :name \"Grace\"]]")
        _ (vev.transact-text
            (addr right)
            "[[:db/add 1 :blocked true]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$left" left.db)
                                  (vev.db-source "$right" right.db)])
        prepared (vev.prepare-query-text-with-sources
                   "[:find ?name :in $left $right :where [$left ?e :name ?name] ($right not [?e :blocked])]"
                   sources)
        result (vev.q-text-with-sources
                 left.db
                 "[:find ?name :in $left $right :where [$left ?e :name ?name] ($right not [?e :blocked])]"
                 inputs
                 sources)
        prepared-result (vev.q-prepared-with-sources left.db prepared inputs sources)]
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Grace"))
    (t.is prepared-result.ok prepared-result.error)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].text "Grace"))
    (vev.delete-query-shallow prepared.query)))

(t.deftest branch-local-predicates-and-functions-from-edn-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        not-result (vev.q-text
                     conn.db
                     "[:find ?e :where [?e :id] (not [?e :age ?age] [(> ?age 40)])]")
        or-result (vev.q-text
                    conn.db
                    "[:find ?label :where [?e :name ?name] (or (and [?e :id 1] [(str ?name \"!\") ?label]) (and [?e :id 2] [(str ?name \"?\") ?label]))]")
        literal-result (vev.q conn.db
                         [:find ?label
                          :where
                          [?e :name ?name]
                          (or
                            (and [?e :id 1]
                                 [(str ?name "!") ?label])
                            (and [?e :id 2]
                                 [(str ?name "?") ?label]))])]
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 1))
    (t.is (source-branch-has-entity? not-result 1))
    (t.is or-result.ok)
    (t.is (= (count or-result.rows) 2))
    (t.is (source-branch-has-text? or-result "Ivan!"))
    (t.is (source-branch-has-text? or-result "Petr?"))
    (t.is literal-result.ok)
    (t.is (= (count literal-result.rows) 2))
    (t.is (source-branch-has-text? literal-result "Ivan!"))
    (t.is (source-branch-has-text? literal-result "Petr?"))))

(t.deftest source-backed-branch-local-get-else-and-get-some-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :id 1] [:db/add 2 :name \"Grace\"] [:db/add 2 :id 2] [:db/add 2 :height 180] [:db/add 3 :name \"Barbara\"] [:db/add 3 :id 3]]")
        source (vev.resident-db-read-source (addr conn.db))
        not-profiled (vev.q-text-db-read-source-profiled
                       source
                       "[:find ?e :where [?e :id] (not [(get-else $ ?e :height 0) ?height] [(= ?height 0)])]")
        or-profiled (vev.q-text-db-read-source-profiled
                      source
                      "[:find ?value :where [?e :id] (or (and [?e :id 1] [(get-some $ ?e :height :name) [?attr ?value]]) (and [?e :id 2] [(get-some $ ?e :height :name) [?attr ?value]]))]")]
    (t.is not-profiled.result.ok not-profiled.result.error)
    (t.is (= (count not-profiled.result.rows) 1))
    (t.is (source-branch-has-entity? not-profiled.result 2))
    (t.is (> not-profiled.stats.typed-index-scans 0))
    (t.is (= not-profiled.stats.binding-materializations 0))
    (t.is (= not-profiled.stats.generic-materialization-steps 0))
    (t.is or-profiled.result.ok or-profiled.result.error)
    (t.is (= (count or-profiled.result.rows) 2))
    (t.is (source-branch-has-text? or-profiled.result "Ada"))
    (t.is (source-branch-has-int? or-profiled.result 180))
    (t.is (> or-profiled.stats.typed-index-scans 0))
    (t.is (= or-profiled.stats.binding-materializations 0))
    (t.is (= or-profiled.stats.generic-materialization-steps 0))
    (vev.delete-profiled-result-set-owned-values not-profiled)
    (vev.delete-profiled-result-set-owned-values or-profiled)))

(t.deftest branch-local-ground-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3]]")
        source (vev.resident-db-read-source (addr conn.db))
        resident-not (vev.q-text-profiled
                       conn.db
                       "[:find ?e :where [?e :id] (not [(ground \"Petr\") ?blocked] [?e :name ?blocked])]")
        resident-or (vev.q-text-profiled
                      conn.db
                      "[:find ?e :where [?e :id] (or (and [(ground \"Ivan\") ?target] [?e :name ?target]) (and [(ground \"Oleg\") ?target] [?e :name ?target]))]")
        source-not (vev.q-text-db-read-source-profiled
                     source
                     "[:find ?e :where [?e :id] (not [(ground \"Petr\") ?blocked] [?e :name ?blocked])]")
        source-or (vev.q-text-db-read-source-profiled
                    source
                    "[:find ?e :where [?e :id] (or (and [(ground \"Ivan\") ?target] [?e :name ?target]) (and [(ground \"Oleg\") ?target] [?e :name ?target]))]")]
    (t.is resident-not.result.ok resident-not.result.error)
    (t.is (= (count resident-not.result.rows) 2))
    (t.is (source-branch-has-entity? resident-not.result 1))
    (t.is (source-branch-has-entity? resident-not.result 3))
    (t.is (= resident-not.stats.binding-materializations 0))
    (t.is resident-or.result.ok resident-or.result.error)
    (t.is (= (count resident-or.result.rows) 2))
    (t.is (source-branch-has-entity? resident-or.result 1))
    (t.is (source-branch-has-entity? resident-or.result 3))
    (t.is (= resident-or.stats.binding-materializations 0))
    (t.is source-not.result.ok source-not.result.error)
    (t.is (= (count source-not.result.rows) 2))
    (t.is (source-branch-has-entity? source-not.result 1))
    (t.is (source-branch-has-entity? source-not.result 3))
    (t.is (= source-not.stats.binding-materializations 0))
    (t.is (= source-not.stats.generic-materialization-steps 0))
    (t.is source-or.result.ok source-or.result.error)
    (t.is (= (count source-or.result.rows) 2))
    (t.is (source-branch-has-entity? source-or.result 1))
    (t.is (source-branch-has-entity? source-or.result 3))
    (t.is (= source-or.stats.binding-materializations 0))
    (t.is (= source-or.stats.generic-materialization-steps 0))
    (vev.delete-profiled-result-set-owned-values resident-not)
    (vev.delete-profiled-result-set-owned-values resident-or)
    (vev.delete-profiled-result-set-owned-values source-not)
    (vev.delete-profiled-result-set-owned-values source-or)))

(t.deftest source-backed-ground-composite-values-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source (vev.resident-db-read-source (addr conn.db))
        text "[:find ?tags :where [(ground [1 2]) ?tags]]"
