  (defer (free_all context.allocator))
  (let [text "[:find ?name :in $ ?target :where [?anchor :name ?target] [?e :friend ?anchor] [?e :name ?name]]"
        prepared (vev.prepare-query-text text)
        conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[{:db/id 100 :db/ident :friend :db/valueType :db.type/ref} [:db/add 1 :name \"Ada\"] [:db/add 2 :name \"Grace\"] [:db/add 3 :name \"Barbara\"] [:db/add 1 :friend 2] [:db/add 3 :friend 2] [:db/add 4 :friend 1]]")
        source (vev.resident-db-read-source (addr conn.db))
        inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Grace"))])
        [typed-rel typed-stats typed-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                             source
                                             ([]vev.DB-Read-Named-Source [])
                                             prepared.query
                                             inputs
                                             ([]vev.Native-Query-Fn []))]
    (t.is prepared.ok prepared.error)
    (t.is typed-used)
    (t.is typed-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count typed-rel) 2))
    (t.is (= (count typed-rel.typed-columns) 1))
    (t.is (= typed-rel.typed-columns[0].kind .String))
    (t.is (> typed-stats.source-operators 0))
    (t.is (> typed-stats.source-index-scans 0))
    (t.is (= typed-stats.binding-materializations 0))
    (t.is (= typed-stats.generic-materialization-steps 0))
    (vev.delete-query-relation typed-rel)
    (vev.delete-prepared-query-shallow prepared)))

