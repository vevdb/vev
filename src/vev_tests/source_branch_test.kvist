(t.deftest physical-plan-records-result-shape
  (defer (free_all context.allocator))
  (let [flat-prepared (vev.prepare-query-text "[:find ?e ?name :where [?e :name ?name]]")
        flat-plan (vev.physical-plan-from-query flat-prepared.query)
        pull-prepared (vev.prepare-query-text "[:find (pull ?e [:name]) :where [?e :name]]")
        pull-plan (vev.physical-plan-from-query pull-prepared.query)
        aggregate-prepared (vev.prepare-query-text "[:find (count ?e) :where [?e :name]]")
        aggregate-plan (vev.physical-plan-from-query aggregate-prepared.query)
        top-aggregate-prepared (vev.prepare-query-text "[:find (max 1 ?age) :where [?e :age ?age]]")
        top-aggregate-plan (vev.physical-plan-from-query top-aggregate-prepared.query)
        grouped-top-aggregate-prepared (vev.prepare-query-text "[:find ?e (max 1 ?age) :where [?e :age ?age]]")
        pull-aggregate-prepared (vev.prepare-query-text "[:find (pull ?e [:name]) (count ?a) :where [?e :name] [?e :age ?a]]")
        pull-aggregate-plan (vev.physical-plan-from-query pull-aggregate-prepared.query)
        pull-aggregate-grouped-prepared (vev.prepare-query-text "[:find ?e (pull ?e [:name]) (count ?a) :where [?e :name] [?e :age ?a]]")
        pull-aggregate-pattern-prepared (vev.prepare-query-text "[:find ?e (pull ?e ?pattern) (count ?a) :in $ ?pattern :where [?e :name] [?e :age ?a]]")
        with-prepared (vev.prepare-query-text "[:find ?name :with ?e :where [?e :name ?name]]")
        with-plan (vev.physical-plan-from-query with-prepared.query)
        conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 41]]")
        stats (vev.query-stats-empty)
        rel (vev.relation-engine-relation-profiled conn.db flat-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr stats))
        pull-stats (vev.query-stats-empty)
        pull-rel (vev.relation-engine-relation-profiled conn.db pull-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr pull-stats))
        top-aggregate-stats (vev.query-stats-empty)
        top-aggregate-rel (vev.relation-engine-relation-profiled conn.db top-aggregate-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr top-aggregate-stats))
        grouped-top-aggregate-stats (vev.query-stats-empty)
        grouped-top-aggregate-rel (vev.relation-engine-relation-profiled conn.db grouped-top-aggregate-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr grouped-top-aggregate-stats))
        pull-aggregate-stats (vev.query-stats-empty)
        pull-aggregate-rel (vev.relation-engine-relation-profiled conn.db pull-aggregate-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr pull-aggregate-stats))
        pull-aggregate-grouped-stats (vev.query-stats-empty)
        pull-aggregate-grouped-rel (vev.relation-engine-relation-profiled conn.db pull-aggregate-grouped-prepared.query ([]vev.Query-Input []) ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr pull-aggregate-grouped-stats))
        pattern-input (vev.query-input-pull-pattern ([]vev.Pull-Spec [(vev.pull-spec ":name" ([]vev.Pull-Spec []))]))
        pattern-inputs ([]vev.Query-Input [pattern-input])
        pull-aggregate-pattern-stats (vev.query-stats-empty)
        pull-aggregate-pattern-rel (vev.relation-engine-relation-profiled conn.db pull-aggregate-pattern-prepared.query pattern-inputs ([]vev.DB-Source []) ([]vev.Native-Query-Fn []) (addr pull-aggregate-pattern-stats))
        typed-plan (vev.query-typed-flat-result-plan-from-physical-plan flat-prepared.query rel flat-plan)
        resolved (vev.resolve-typed-flat-materialization rel flat-plan.materialization)
        source (vev.resident-db-read-source (addr conn.db))
        [projected-rel projected-ok] (vev.query-relation-apply-physical-project-op rel flat-plan.project-op flat-plan.materialization)
        [projected-rows projected-rows-ok] (vev.result-rows-for-typed-flat-relation-with-materialization flat-prepared.query projected-rel flat-plan.materialization)
        [with-projected-rel with-projected-ok] (vev.query-relation-apply-physical-project-op rel with-plan.project-op with-plan.materialization)
        [flat-materialize-batch flat-materialize-ok flat-materialize-error] (vev.db-read-source-apply-physical-materialize-op source ([]vev.DB-Read-Named-Source []) flat-prepared.query ([]vev.Query-Input []) rel flat-plan.materialize-op flat-plan.materialization ([]vev.Native-Query-Fn []))
        [pull-materialize-batch pull-materialize-ok pull-materialize-error] (vev.db-read-source-apply-physical-materialize-op source ([]vev.DB-Read-Named-Source []) pull-prepared.query ([]vev.Query-Input []) pull-rel pull-plan.materialize-op pull-plan.materialization ([]vev.Native-Query-Fn []))
        [aggregate-materialize-batch aggregate-materialize-ok aggregate-materialize-error] (vev.db-read-source-apply-physical-materialize-op source ([]vev.DB-Read-Named-Source []) top-aggregate-prepared.query ([]vev.Query-Input []) top-aggregate-rel top-aggregate-plan.materialize-op top-aggregate-plan.materialization ([]vev.Native-Query-Fn []))
        [pull-aggregate-materialize-batch pull-aggregate-materialize-ok pull-aggregate-materialize-error] (vev.db-read-source-apply-physical-materialize-op source ([]vev.DB-Read-Named-Source []) pull-aggregate-prepared.query ([]vev.Query-Input []) pull-aggregate-rel pull-aggregate-plan.materialize-op pull-aggregate-plan.materialization ([]vev.Native-Query-Fn []))
        [pull-aggregate-pattern-batch pull-aggregate-pattern-ok pull-aggregate-pattern-error] (vev.materialize-source-typed-pull-aggregate-batch source ([]vev.DB-Read-Named-Source []) pull-aggregate-pattern-prepared.query pattern-inputs pull-aggregate-pattern-rel ([]vev.Native-Query-Fn []))
        [materialized-rows materialized-ok] (vev.result-rows-for-typed-flat-relation-with-materialization flat-prepared.query rel flat-plan.materialization)]
    (t.is flat-prepared.ok flat-prepared.error)
    (t.is pull-prepared.ok pull-prepared.error)
    (t.is aggregate-prepared.ok aggregate-prepared.error)
    (t.is top-aggregate-prepared.ok top-aggregate-prepared.error)
    (t.is grouped-top-aggregate-prepared.ok grouped-top-aggregate-prepared.error)
    (t.is pull-aggregate-prepared.ok pull-aggregate-prepared.error)
    (t.is pull-aggregate-grouped-prepared.ok pull-aggregate-grouped-prepared.error)
    (t.is pull-aggregate-pattern-prepared.ok pull-aggregate-pattern-prepared.error)
    (t.is with-prepared.ok with-prepared.error)
    (t.is (= flat-plan.materialization.shape.kind .FlatPrimitiveResult))
    (t.is (= flat-plan.materialization.shape.value-column-count 2))
    (t.is (= flat-plan.materialization.shape.pull-count 0))
    (t.is (= flat-plan.materialization.shape.aggregate-count 0))
    (t.is flat-plan.materialization.shape.has-distinct)
    (t.is (not flat-plan.materialization.trust-unique-bindings))
    (t.is flat-plan.has-project)
    (t.is (= flat-plan.project-op.kind .Project))
    (t.is (= (count flat-plan.project-op.output-vars) 2))
    (t.is (= flat-plan.project-op.output-vars[0] "?e"))
    (t.is (= flat-plan.project-op.output-vars[1] "?name"))
    (t.is flat-plan.has-materialize)
    (t.is (= flat-plan.materialize-op.kind .Materialize))
    (t.is (= (count flat-plan.materialize-op.output-vars) 2))
    (t.is (not pull-plan.has-project))
    (t.is pull-plan.has-materialize)
    (t.is (not aggregate-plan.has-project))
    (t.is aggregate-plan.has-materialize)
    (t.is top-aggregate-plan.has-materialize)
    (t.is pull-aggregate-plan.has-materialize)
    (t.is (= pull-plan.materialization.shape.kind .PullResult))
    (t.is (= pull-plan.materialization.shape.value-column-count 0))
    (t.is (= pull-plan.materialization.shape.pull-count 1))
    (t.is (= aggregate-plan.materialization.shape.kind .AggregateResult))
    (t.is (= aggregate-plan.materialization.shape.value-column-count 1))
    (t.is (= aggregate-plan.materialization.shape.aggregate-count 1))
    (t.is (= pull-aggregate-plan.materialization.shape.kind .PullAggregateResult))
    (t.is (= pull-aggregate-plan.materialization.shape.pull-count 1))
    (t.is (= pull-aggregate-plan.materialization.shape.aggregate-count 1))
    (t.is (= (count flat-plan.materialization.columns) 2))
    (t.is (= flat-plan.materialization.columns[0].kind .ValueResultColumn))
    (t.is (= flat-plan.materialization.columns[0].var-name "?e"))
    (t.is (= flat-plan.materialization.columns[0].source-index 0))
    (t.is (= flat-plan.materialization.columns[0].output-index 0))
    (t.is (= flat-plan.materialization.columns[1].kind .ValueResultColumn))
    (t.is (= flat-plan.materialization.columns[1].var-name "?name"))
    (t.is (= flat-plan.materialization.columns[1].source-index 1))
    (t.is (= flat-plan.materialization.columns[1].output-index 1))
    (t.is typed-plan.ok)
    (t.is (= (count typed-plan.find-indexes) 2))
    (t.is (= rel.attrs[typed-plan.find-indexes[0]] "?e"))
    (t.is (= rel.attrs[typed-plan.find-indexes[1]] "?name"))
    (t.is (= (count typed-plan.column-kinds) 2))
    (t.is resolved.ok)
    (t.is (= (vev.resolved-typed-flat-materialization-row-count resolved) 2))
    (t.is (= (vev.resolved-typed-flat-materialization-column-count resolved) 2))
    (t.is (= (count resolved.plan.find-indexes) 2))
    (t.is (= resolved.trust-unique-bindings flat-plan.materialization.trust-unique-bindings))
    (t.is projected-ok)
    (t.is (= (count projected-rel.attrs) 2))
    (t.is (= projected-rel.attrs[0] "?e"))
    (t.is (= projected-rel.attrs[1] "?name"))
    (t.is (= projected-rel.typed-rows 2))
    (t.is projected-rows-ok)
    (t.is (= (count projected-rows) 2))
    (t.is (= (count projected-rows[0].values) 2))
    (t.is flat-materialize-ok flat-materialize-error)
    (t.is flat-materialize-batch.ok)
    (t.is (= flat-materialize-batch.rows 2))
    (t.is (= (count flat-materialize-batch.columns) 2))
    (t.is (not flat-materialize-batch.owns-values))
    (t.is pull-materialize-ok pull-materialize-error)
    (t.is pull-materialize-batch.ok)
    (t.is (= pull-materialize-batch.rows 2))
    (t.is (= (count pull-materialize-batch.columns) 1))
    (t.is pull-materialize-batch.owns-values)
    (t.is aggregate-materialize-ok aggregate-materialize-error)
    (t.is aggregate-materialize-batch.ok)
    (t.is (= aggregate-materialize-batch.rows 1))
    (t.is (= (count aggregate-materialize-batch.columns) 1))
    (t.is aggregate-materialize-batch.owns-values)
    (t.is pull-aggregate-materialize-ok pull-aggregate-materialize-error)
    (t.is pull-aggregate-materialize-batch.ok)
    (t.is (= pull-aggregate-materialize-batch.rows 2))
    (t.is (= (count pull-aggregate-materialize-batch.columns) 2))
    (t.is pull-aggregate-materialize-batch.owns-values)
    (t.is pull-aggregate-pattern-ok pull-aggregate-pattern-error)
    (t.is pull-aggregate-pattern-batch.ok)
    (t.is (= pull-aggregate-pattern-batch.rows 2))
    (t.is (= (count pull-aggregate-pattern-batch.columns) 3))
    (t.is (not pull-aggregate-pattern-batch.value-columns[0]))
    (t.is pull-aggregate-pattern-batch.value-columns[1])
    (t.is (not pull-aggregate-pattern-batch.value-columns[2]))
    (let [[pattern-pull-cell pattern-pull-cell-ok] (vev.typed-materialized-batch-cell-value pull-aggregate-pattern-batch 0 1)]
      (t.is pattern-pull-cell-ok)
      (t.is (= pattern-pull-cell.kind .Map)))
    (let [[first-output-index first-output-index-ok] (vev.resolved-typed-flat-materialization-output-column-index resolved 0)
          [second-output-kind second-output-kind-ok] (vev.resolved-typed-flat-materialization-output-column-kind rel resolved 1)
          [second-cell second-cell-ok] (vev.resolved-typed-flat-materialization-output-cell-value rel resolved 0 1)]
      (t.is first-output-index-ok)
      (t.is (= rel.attrs[first-output-index] "?e"))
      (t.is second-output-kind-ok)
      (t.is (= second-output-kind .String))
      (t.is second-cell-ok)
      (t.is (= second-cell.kind .String)))
    (let [cursor (vev.typed-flat-materialization-cursor resolved)]
      (let [[first-row first-found first-ok] (vev.typed-flat-materialization-cursor-next! (addr cursor) rel resolved)
            [second-row second-found second-ok] (vev.typed-flat-materialization-cursor-next! (addr cursor) rel resolved)
            [_ done-found done-ok] (vev.typed-flat-materialization-cursor-next! (addr cursor) rel resolved)]
        (t.is first-ok)
        (t.is first-found)
        (t.is (= first-row 0))
        (t.is second-ok)
        (t.is second-found)
        (t.is (= second-row 1))
        (t.is done-ok)
        (t.is (not done-found)))
      (vev.delete-typed-flat-materialization-cursor cursor))
    (let [batch (vev.materialize-typed-flat-batch rel resolved)]
      (t.is batch.ok)
      (t.is (= batch.rows 2))
      (t.is (= (count batch.names) 2))
      (t.is (= batch.names[0] "?e"))
      (t.is (= batch.names[1] "?name"))
      (t.is (= (count batch.sources) 2))
      (t.is (= (count batch.columns) 2))
      (t.is (= (count batch.value-columns) 2))
      (t.is (not batch.value-columns[0]))
      (t.is (= batch.columns[1].kind .String))
      (let [[batch-cell batch-cell-ok] (vev.typed-materialized-batch-cell-value batch 0 1)]
        (t.is batch-cell-ok)
        (t.is (= batch-cell.kind .String)))
      (vev.delete-typed-materialized-batch batch))
    (let [mixed-prepared (vev.prepare-query-text "[:find ?v :where [(ground 1) ?v]]")
          mixed-plan (vev.physical-plan-from-query mixed-prepared.query)
          mixed-rel (source-branch-mixed-composite-relation)
          mixed-resolved (vev.resolve-typed-flat-materialization mixed-rel mixed-plan.materialization)
          mixed-batch (vev.materialize-typed-flat-batch mixed-rel mixed-resolved)]
      (t.is mixed-prepared.ok mixed-prepared.error)
      (t.is mixed-resolved.ok)
      (t.is mixed-batch.ok)
      (t.is mixed-batch.owns-values)
      (t.is (= mixed-batch.rows 2))
      (t.is (= (count mixed-batch.value-columns) 1))
      (t.is mixed-batch.value-columns[0])
      (let [[first-mixed-cell first-mixed-cell-ok] (vev.typed-materialized-batch-cell-value mixed-batch 0 0)
