(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(defn source-branch-has-entity? [result: vev.Result-Set, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity))
      (return true)))
  false)

(defn source-branch-has-text? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(defn source-branch-has-int? [result: vev.Result-Set, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Int)
               (= row.values[0].int-value value))
      (return true)))
  false)

(t.deftest source-db-multi-clause-not-or-branches-stay-typed
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[{:db/id 100 :db/ident :name :db/unique :db.unique/identity} [:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3]]")
        _ (vev.transact-text
            (addr right)
            "[{:db/id 100 :db/ident :name :db/unique :db.unique/identity} [:db/add 3 :name \"Ivan\"] [:db/add 3 :id 3] [:db/add 1 :name \"Petr\"] [:db/add 1 :id 1] [:db/add 2 :name \"Oleg\"] [:db/add 2 :id 2]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$1" left.db)
                                  (vev.db-source "$2" right.db)])
        not-result (vev.q-text-with-sources
                     left.db
                     "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 not-join [?e] [?e :id ?id] [?e :name \"Petr\"])]"
                     inputs
                     sources)
        or-result (vev.q-text-with-sources
                    left.db
                    "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 or-join [?e] (and [?e :id ?id] [?e :name \"Ivan\"]) (and [?e :id ?id] [?e :name \"Oleg\"]))]"
                    inputs
                    sources)]
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-entity? not-result 2))
    (t.is (source-branch-has-entity? not-result 3))
    (t.is or-result.ok)
    (t.is (= (count or-result.rows) 2))
    (t.is (source-branch-has-entity? or-result 2))
    (t.is (source-branch-has-entity? or-result 3))))

(t.deftest source-db-bound-entity-attr-clause-stays-profiled
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :id 1] [:db/add 2 :name \"Grace\"] [:db/add 2 :id 2] [:db/add 3 :name \"Barbara\"] [:db/add 3 :id 3]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$left" left.db)])
        profiled (vev.q-text-profiled-with-sources
                   left.db
                   "[:find ?name :in $left :where [$left ?e :id 2] [$left ?e :name ?name]]"
                   inputs
                   sources)]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (= profiled.result.rows[0].values[0].text "Grace"))
    (t.is (= profiled.stats.steps 2))
    (t.is (= profiled.stats.output-rows 1))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (> profiled.stats.source-index-scans 0))
    (t.is (= profiled.stats.binding-materializations 0))
    (t.is (> profiled.stats.clause-candidates 0))))

(t.deftest source-db-not-existence-uses-clause-source
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact-text
            (addr left)
            "[[:db/add 1 :id 1] [:db/add 1 :name \"Ada\"] [:db/add 2 :id 2] [:db/add 2 :name \"Grace\"]]")
        _ (vev.transact-text
            (addr right)
            "[[:db/add 1 :blocked true]]")
        inputs ([]vev.Query-Input [])
        sources ([]vev.DB-Source [(vev.db-source "$left" left.db)
                                  (vev.db-source "$right" right.db)])
        result (vev.q-text-with-sources
                 left.db
                 "[:find ?name :in $left $right :where [$left ?e :name ?name] ($right not [?e :blocked])]"
                 inputs
                 sources)]
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Grace"))))

(t.deftest branch-local-predicates-and-functions-from-edn-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        not-result (vev.q-text
                     conn.db
                     "[:find ?e :where [?e :id] (not [?e :age ?age] [(> ?age 40)])]")
        or-result (vev.q-text
                    conn.db
                    "[:find ?label :where [?e :name ?name] (or (and [?e :id 1] [(str ?name \"!\") ?label]) (and [?e :id 2] [(str ?name \"?\") ?label]))]")
        literal-result (vev.q conn.db
                         [:find ?label
                          :where
                          [?e :name ?name]
                          (or
                            (and [?e :id 1]
                                 [(str ?name "!") ?label])
                            (and [?e :id 2]
                                 [(str ?name "?") ?label]))])]
    (t.is not-result.ok)
    (t.is (= (count not-result.rows) 1))
    (t.is (source-branch-has-entity? not-result 1))
    (t.is or-result.ok)
    (t.is (= (count or-result.rows) 2))
    (t.is (source-branch-has-text? or-result "Ivan!"))
    (t.is (source-branch-has-text? or-result "Petr?"))
    (t.is literal-result.ok)
    (t.is (= (count literal-result.rows) 2))
    (t.is (source-branch-has-text? literal-result "Ivan!"))
    (t.is (source-branch-has-text? literal-result "Petr?"))))

(t.deftest nested-branch-local-not-from-edn-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        nested-not (vev.q-text
                     conn.db
                     "[:find ?e :where [?e :id] (not [?e :age ?age] (not [?e :name \"Petr\"]))]")
        nested-or (vev.q-text
                    conn.db
                    "[:find ?e :where [?e :id] (or (and [?e :age ?age] (not [?e :name \"Petr\"])) (and [?e :age ?age] [?e :name \"Petr\"]))]")]
    (t.is nested-not.ok)
    (t.is (= (count nested-not.rows) 1))
    (t.is (source-branch-has-entity? nested-not 2))
    (t.is nested-or.ok nested-or.error)
    (t.is (= (count nested-or.rows) 3))
    (t.is (source-branch-has-entity? nested-or 1))
    (t.is (source-branch-has-entity? nested-or 2))
    (t.is (source-branch-has-entity? nested-or 3))))

(t.deftest plain-or-join-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        result (vev.q-text
                 conn.db
                 "[:find ?e :where [?e :id] (or-join [?e] (and [?e :age ?age] [(> ?age 40)]) [?e :name \"Ivan\"])]")
        leaked-local (vev.q-text
                       conn.db
                       "[:find ?age :where [?e :id] (or-join [?e] (and [?e :age ?age] [(> ?age 40)]) [?e :name \"Ivan\"])]")]
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 3))
    (t.is (source-branch-has-entity? result 1))
    (t.is (source-branch-has-entity? result 2))
    (t.is (source-branch-has-entity? result 3))
    (t.is (not leaked-local.ok))))

(t.deftest source-input-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":id") (vev.value-int 1))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan"))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 30))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":id") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr"))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 41))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":id") (vev.value-int 3))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":name") (vev.value-string "Oleg"))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":age") (vev.value-int 50))]))
        inputs ([]vev.Query-Input [(vev.query-input-scalar rows)])
        not-result (vev.q-text-with-inputs
                     conn.db
                     "[:find ?e :in $rows :where [$rows ?e :id ?id] (not [$rows ?e :name \"Petr\"])]"
                     inputs)
        or-join-result (vev.q-text-with-inputs
                         conn.db
                         "[:find ?e :in $rows :where [$rows ?e :id ?id] (or-join [?e] (and [$rows ?e :name ?name] [(= ?name \"Ivan\")]) (and [$rows ?e :age ?age] [(> ?age 45)]))]"
                         inputs)]
    (t.is not-result.ok not-result.error)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-int? not-result 1))
    (t.is (source-branch-has-int? not-result 3))
    (t.is or-join-result.ok or-join-result.error)
    (t.is (= (count or-join-result.rows) 2))
    (t.is (source-branch-has-int? or-join-result 1))
    (t.is (source-branch-has-int? or-join-result 3))))

(t.deftest top-level-relation-source-input-avoids-input-binding-materialization
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":id") (vev.value-int 1))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada"))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":id") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Grace"))]))
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?name :in $rows :where [$rows ?e :id 2] [$rows ?e :name ?name]]"
                   ([]vev.Query-Input [(vev.query-input-scalar rows)]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (= profiled.result.rows[0].values[0].text "Grace"))
    (t.is (= profiled.stats.input-bindings 1))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest scalar-input-predicate-query-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :salary 40000] [:db/add 2 :salary 60000] [:db/add 3 :salary 80000]]")
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?e ?s :in $ ?min :where [?e :salary ?s] [(> ?s ?min)]]"
                   ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 50000))]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 2))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (= profiled.stats.input-bindings 1))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest tuple-input-predicate-query-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 41]]")
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?name :in $ [?target ?min] :where [?target :name ?name] [?target :age ?age] [(> ?age ?min)]]"
                   ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-entity 1) (vev.value-int 30)]))]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (= profiled.result.rows[0].values[0].text "Ada"))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (= profiled.stats.input-bindings 1))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest relation-input-predicate-query-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 41] [:db/add 3 :name \"Barbara\"] [:db/add 3 :age 24]]")
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?name :in $ [[?target ?min]] :where [?target :name ?name] [?target :age ?age] [(> ?age ?min)]]"
                   ([]vev.Query-Input [(vev.query-input-relation
                                         ([]vev.Value [(vev.value-entity 1) (vev.value-int 30)
                                                       (vev.value-entity 2) (vev.value-int 50)
                                                       (vev.value-entity 3) (vev.value-int 20)])
                                         2)]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 2))
    (t.is (source-branch-has-text? profiled.result "Ada"))
    (t.is (source-branch-has-text? profiled.result "Barbara"))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (= profiled.stats.input-bindings 3))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest map-relation-input-query-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 2 :name \"Grace\"]]")
        map-input (vev.value-map
                    ([]vev.Value [(vev.value-string "Ada") (vev.value-string "primary")
                                  (vev.value-string "Grace") (vev.value-string "secondary")]))
        profiled (vev.q-text-profiled-with-inputs
                   conn.db
                   "[:find ?label :in $ [[?name ?label]] :where [?e :name ?name]]"
                   ([]vev.Query-Input [(vev.query-input-scalar map-input)]))]
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 2))
    (t.is (source-branch-has-text? profiled.result "primary"))
    (t.is (source-branch-has-text? profiled.result "secondary"))
    (t.is (> profiled.stats.typed-index-scans 0))
    (t.is (= profiled.stats.input-bindings 2))
    (t.is (= profiled.stats.binding-materializations 0))))

(t.deftest plain-not-join-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        adult-result (vev.q-text
                       conn.db
                       "[:find ?e :where [?e :id] (not-join [?e] [?e :age ?age] [(> ?age 40)])]")
        shadow-result (vev.q-text
                        conn.db
                        "[:find ?e :where [?e :id] [?e :name ?name] (not-join [?e] [?e :age ?name])]")]
    (t.is adult-result.ok adult-result.error)
    (t.is (= (count adult-result.rows) 1))
    (t.is (source-branch-has-entity? adult-result 1))
    (t.is shadow-result.ok shadow-result.error)
    (t.is (= (count shadow-result.rows) 0))))
