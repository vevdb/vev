(t.deftest source-backed-branch-rule-calls-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :active true] [:db/add 2 :name \"Grace\"] [:db/add 2 :active false] [:db/add 3 :name \"Oleg\"]]")
        source (vev.resident-db-read-source (addr conn.db))
        prepared (vev.prepare-query-text "[:find ?e :in $ % :where [?e :name] (not (active ?e))]")
        prepared-rules (vev.parse-rules-text "[[(active ?e) [?e :active true]] [(named ?e ?name) [?e :name ?name]]]")
        result (vev.q-prepared-db-read-source-with-rules
                 source
                 prepared
                 prepared-rules
                 ([]vev.Query-Input []))
        typed-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules prepared.query (slice prepared-rules.rules 0)))
        [typed-rel typed-stats typed-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                             source
                                             ([]vev.DB-Read-Named-Source [])
                                             typed-query
                                             ([]vev.Query-Input [])
                                             ([]vev.Native-Query-Fn []))]
    (t.is prepared.ok prepared.error)
    (t.is prepared-rules.ok prepared-rules.error)
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 2))
    (t.is (source-branch-has-entity? result 2))
    (t.is (source-branch-has-entity? result 3))
    (t.is typed-used)
    (t.is typed-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count typed-rel) 2))
    (t.is (= typed-stats.rule-calls 0))
    (t.is (= typed-stats.binding-materializations 0))
    (vev.delete-query-relation typed-rel)
    (vev.delete-query-shallow typed-query)
    (vev.delete-result-set-owned-values result)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-rules-shallow prepared-rules)))

(t.deftest source-backed-bound-reverse-derived-rule-preserves-left-bound-rows
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 10 :artist/name \"John Lennon\"] [:db/add 100 :track/artists 10] [:db/add 100 :track/name \"A\"] [:db/add 101 :track/artists 10] [:db/add 101 :track/name \"B\"] [:db/add 102 :track/artists 10] [:db/add 102 :track/name \"C\"] [:db/add 200 :medium/tracks 100] [:db/add 201 :medium/tracks 101] [:db/add 202 :medium/tracks 102] [:db/add 300 :release/media 200] [:db/add 300 :release/name \"Album A\"] [:db/add 300 :release/year 1968] [:db/add 301 :release/media 201] [:db/add 301 :release/name \"Album B\"] [:db/add 301 :release/year 1969] [:db/add 302 :release/media 202] [:db/add 302 :release/name \"Album C\"] [:db/add 302 :release/year 1970]]")
        source (vev.resident-db-read-source (addr conn.db))
        prepared (vev.prepare-query-text "[:find ?title ?album ?year :in $ % ?artist-name :where [?a :artist/name ?artist-name] [?t :track/artists ?a] [?t :track/name ?title] (track-release ?t ?r) [?r :release/name ?album] [?r :release/year ?year]]")
        prepared-rules (vev.parse-rules-text "[[(track-release ?t ?r) [?m :medium/tracks ?t] [?r :release/media ?m]]]")
        inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "John Lennon"))])
        result (vev.q-prepared-db-read-source-with-rules
                 source
                 prepared
                 prepared-rules
                 inputs)]
    (t.is prepared.ok prepared.error)
    (t.is prepared-rules.ok prepared-rules.error)
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 3))
    (t.is (source-branch-has-track-release-row? result "A" "Album A" 1968))
    (t.is (source-branch-has-track-release-row? result "B" "Album B" 1969))
    (t.is (source-branch-has-track-release-row? result "C" "Album C" 1970))
    (vev.delete-result-set-owned-values result)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-rules-shallow prepared-rules)))

(t.deftest source-backed-pull-results-render-from-typed-relation
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ada\"] [:db/add 1 :friend 2] [:db/add 2 :name \"Grace\"]]")
        source (vev.resident-db-read-source (addr conn.db))
        prepared (vev.prepare-query-text "[:find ?e (pull ?e [:name]) :where [?e :name \"Ada\"]]")
        prepared-pull-only (vev.prepare-query-text "[:find (pull ?e [:name]) :where [?e :name \"Ada\"]]")
        prepared-pull-aggregate (vev.prepare-query-text "[:find ?e (pull ?e [:name]) (count ?a) :where [?e :name \"Ada\"] [?e :friend ?a]]")
        [typed-result typed-stats typed-used] (vev.db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns
                                                source
                                                ([]vev.DB-Read-Named-Source [])
                                                prepared.query
                                                ([]vev.Query-Input [])
                                                ([]vev.Native-Query-Fn []))
        [typed-pull-only typed-pull-only-stats typed-pull-only-used] (vev.db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns
                                                                       source
                                                                       ([]vev.DB-Read-Named-Source [])
                                                                       prepared-pull-only.query
                                                                       ([]vev.Query-Input [])
                                                                       ([]vev.Native-Query-Fn []))
        [typed-pull-aggregate typed-pull-aggregate-stats typed-pull-aggregate-used] (vev.db-read-source-q-query-relation-value-typed-with-sources-inputs-and-fns
                                                                                      source
                                                                                      ([]vev.DB-Read-Named-Source [])
                                                                                      prepared-pull-aggregate.query
                                                                                      ([]vev.Query-Input [])
                                                                       ([]vev.Native-Query-Fn []))]
    (t.is prepared.ok prepared.error)
    (t.is prepared-pull-only.ok prepared-pull-only.error)
    (t.is prepared-pull-aggregate.ok prepared-pull-aggregate.error)
    (t.is typed-used)
    (t.is typed-result.ok typed-result.error)
    (t.is (= (count typed-result.rows) 1))
    (t.is (= (count typed-result.rows[0].values) 1))
    (t.is (= typed-result.rows[0].values[0].kind .Entity))
    (t.is (= typed-result.rows[0].values[0].entity 1))
    (t.is (= (count typed-result.rows[0].pulls) 1))
    (t.is (= typed-result.rows[0].pulls[0].e 1))
    (t.is (= (count typed-result.rows[0].pulls[0].attrs) 1))
    (t.is (= typed-result.rows[0].pulls[0].attrs[0].a ":name"))
    (t.is (= typed-result.rows[0].pulls[0].attrs[0].v.text "Ada"))
    (t.is (= typed-stats.binding-materializations 0))
    (t.is typed-pull-only-used)
    (t.is typed-pull-only.ok typed-pull-only.error)
    (t.is (= (count typed-pull-only.rows) 1))
    (t.is (= (count typed-pull-only.rows[0].values) 0))
    (t.is (= (count typed-pull-only.rows[0].pulls) 1))
    (t.is (= typed-pull-only.rows[0].pulls[0].e 1))
    (t.is (= typed-pull-only-stats.binding-materializations 0))
    (t.is typed-pull-aggregate-used)
    (t.is typed-pull-aggregate.ok typed-pull-aggregate.error)
    (t.is (= (count typed-pull-aggregate.rows) 1))
    (t.is (= (count typed-pull-aggregate.rows[0].values) 2))
    (t.is (= typed-pull-aggregate.rows[0].values[0].entity 1))
    (t.is (= typed-pull-aggregate.rows[0].values[1].int-value 1))
    (t.is (= (count typed-pull-aggregate.rows[0].pulls) 1))
    (t.is (= typed-pull-aggregate.rows[0].pulls[0].attrs[0].v.text "Ada"))
    (t.is (= typed-pull-aggregate-stats.binding-materializations 0))
    (vev.delete-result-set-owned-values typed-result)
    (vev.delete-result-set-owned-values typed-pull-only)
    (vev.delete-result-set-owned-values typed-pull-aggregate)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-query-shallow prepared-pull-only)
    (vev.delete-prepared-query-shallow prepared-pull-aggregate)))

(t.deftest nested-branch-local-not-from-edn-stays-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        nested-not (vev.q-text
                     conn.db
                     "[:find ?e :where [?e :id] (not [?e :age ?age] (not [?e :name \"Petr\"]))]")
        nested-or (vev.q-text
                    conn.db
                    "[:find ?e :where [?e :id] (or (and [?e :age ?age] (not [?e :name \"Petr\"])) (and [?e :age ?age] [?e :name \"Petr\"]))]")]
    (t.is nested-not.ok)
    (t.is (= (count nested-not.rows) 1))
    (t.is (source-branch-has-entity? nested-not 2))
    (t.is nested-or.ok nested-or.error)
    (t.is (= (count nested-or.rows) 3))
    (t.is (source-branch-has-entity? nested-or 1))
    (t.is (source-branch-has-entity? nested-or 2))
    (t.is (source-branch-has-entity? nested-or 3))))

(t.deftest plain-or-join-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 1 :name \"Ivan\"] [:db/add 1 :id 1] [:db/add 1 :age 30] [:db/add 2 :name \"Petr\"] [:db/add 2 :id 2] [:db/add 2 :age 41] [:db/add 3 :name \"Oleg\"] [:db/add 3 :id 3] [:db/add 3 :age 50]]")
        result (vev.q-text
                 conn.db
                 "[:find ?e :where [?e :id] (or-join [?e] (and [?e :age ?age] [(> ?age 40)]) [?e :name \"Ivan\"])]")
        leaked-local (vev.q-text
                       conn.db
                       "[:find ?age :where [?e :id] (or-join [?e] (and [?e :age ?age] [(> ?age 40)]) [?e :name \"Ivan\"])]")]
    (t.is result.ok result.error)
    (t.is (= (count result.rows) 3))
    (t.is (source-branch-has-entity? result 1))
    (t.is (source-branch-has-entity? result 2))
    (t.is (source-branch-has-entity? result 3))
    (t.is (not leaked-local.ok))))

(t.deftest source-input-branch-pipelines-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":id") (vev.value-int 1))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan"))
                  (vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 30))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":id") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr"))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 41))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":id") (vev.value-int 3))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":name") (vev.value-string "Oleg"))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":age") (vev.value-int 50))]))
        inputs ([]vev.Query-Input [(vev.query-input-scalar rows)])
        not-result (vev.q-text-with-inputs
                     conn.db
                     "[:find ?e :in $rows :where [$rows ?e :id ?id] (not [$rows ?e :name \"Petr\"])]"
                     inputs)
        or-join-result (vev.q-text-with-inputs
                         conn.db
                         "[:find ?e :in $rows :where [$rows ?e :id ?id] (or-join [?e] (and [$rows ?e :name ?name] [(= ?name \"Ivan\")]) (and [$rows ?e :age ?age] [(> ?age 45)]))]"
                         inputs)]
    (t.is not-result.ok not-result.error)
    (t.is (= (count not-result.rows) 2))
    (t.is (source-branch-has-int? not-result 1))
    (t.is (source-branch-has-int? not-result 3))
    (t.is or-join-result.ok or-join-result.error)
    (t.is (= (count or-join-result.rows) 2))
    (t.is (source-branch-has-int? or-join-result 1))
    (t.is (source-branch-has-int? or-join-result 3))))

(t.deftest source-backed-named-source-recursive-rule-calls-stay-typed
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source (vev.resident-db-read-source (addr conn.db))
        rows (vev.value-vector
               ([]vev.Value
                 [(vev.value-vector3 (vev.value-int 1) (vev.value-keyword ":next") (vev.value-int 2))
                  (vev.value-vector3 (vev.value-int 2) (vev.value-keyword ":next") (vev.value-int 3))
                  (vev.value-vector3 (vev.value-int 3) (vev.value-keyword ":next") (vev.value-int 4))]))
        row-source (vev.relation-value-db-read-source (addr rows))
        named-sources ([]vev.DB-Read-Named-Source [(vev.db-read-named-source "$rows" row-source)])
        direct-query (vev.prepare-query-text "[:find ?x ?y :in $rows :where [$rows ?x :next ?y]]")
        [direct-rel direct-stats direct-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                                source
                                                named-sources
                                                direct-query.query
                                                ([]vev.Query-Input [])
                                                ([]vev.Native-Query-Fn []))
        prepared (vev.prepare-query-text "[:find ?x ?y :in $ % :where ($rows route ?x ?y)]")
        prepared-rules (vev.parse-rules-text "[[(route ?x ?y) [?x :next ?y]] [(route ?x ?y) [?x :next ?z] (route ?z ?y)]]")
        base-query (vev.prepare-query-text "[:find ?x ?y :in $ % :where ($rows edge ?x ?y)]")
        base-rules (vev.parse-rules-text "[[(edge ?x ?y) [?x :next ?y]]]")
        base-typed-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules base-query.query (slice base-rules.rules 0)))
        body-stats (vev.query-stats-empty)
        [body-rel body-ok] (vev.db-read-source-query-relation-from-rule-body-typed-depth
                             row-source
                             ([]vev.DB-Read-Named-Source [])
                             (slice base-rules.rules 0)
                             base-rules.rules[0]
                             ([]vev.Native-Query-Fn [])
                             (addr body-stats)
                             20)
        [base-rel base-stats base-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                          source
                                          named-sources
                                          base-typed-query
                                          ([]vev.Query-Input [])
                                          ([]vev.Native-Query-Fn []))
        typed-query (vev.query-with-rule-call-plans (vev.query-copy-with-rules prepared.query (slice prepared-rules.rules 0)))
        [typed-rel typed-stats typed-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns
                                             source
                                             named-sources
                                             typed-query
                                             ([]vev.Query-Input [])
                                             ([]vev.Native-Query-Fn []))]
    (t.is direct-query.ok direct-query.error)
    (t.is direct-used)
    (t.is (= (vev.query-relation-row-count direct-rel) 3))
    (t.is body-ok)
    (t.is (= (vev.query-relation-row-count body-rel) 3))
    (t.is base-query.ok base-query.error)
    (t.is base-rules.ok base-rules.error)
    (t.is base-used)
    (t.is (= (vev.query-relation-row-count base-rel) 3))
    (t.is prepared.ok prepared.error)
    (t.is prepared-rules.ok prepared-rules.error)
    (t.is typed-used)
    (t.is typed-rel.has-typed-columns)
    (t.is (= (vev.query-relation-row-count typed-rel) 6))
    (t.is (> typed-stats.rule-calls 0))
    (t.is (= typed-stats.binding-materializations 0))
    (t.is (= typed-stats.generic-materialization-steps 0))
    (vev.delete-query-relation direct-rel)
    (vev.delete-prepared-query-shallow direct-query)
    (vev.delete-query-relation body-rel)
    (vev.delete-query-relation base-rel)
    (vev.delete-query-shallow base-typed-query)
    (vev.delete-prepared-query-shallow base-query)
    (vev.delete-prepared-rules-shallow base-rules)
    (vev.delete-query-relation typed-rel)
    (vev.delete-query-shallow typed-query)
    (vev.delete-prepared-query-shallow prepared)
    (vev.delete-prepared-rules-shallow prepared-rules)))

