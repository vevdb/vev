(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(defn relation-db-rows [] -> vev.Value
  (vev.value-vector
    ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                  (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
                  (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr")]))
                  (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 17)]))])))

(t.deftest relation-db-uses-relation-engine-with-predicates-fns-and-rules
  (defer (free_all context.allocator))
  (let [rows (relation-db-rows)
        predicate-result (vev.q-text-relation-db
                           rows
                           "[:find ?name :where [?e :age ?age] [(>= ?age 18)] [?e :name ?name]]")
        registry ([]vev.Native-Query-Fn [(vev.query-fn "adult-age?" ">=")
                                         (vev.query-fn "mk-keyword" "keyword")])
        function-result (vev.q-text-relation-db-with-fns
                          rows
                          "[:find ?tag :where [?e :age ?age] [(adult-age? ?age 18)] [(mk-keyword \"adult\") ?tag]]"
                          registry)
        rule-result (vev.q-text-relation-db-with-rules
                      rows
                      "[:find ?name :in % :where (adult ?e) [?e :name ?name]]"
                      "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]]]"
                      ([]vev.Query-Input []))]
    (t.is predicate-result.ok)
    (t.is (= (count predicate-result.rows) 1))
    (t.is (= predicate-result.rows[0].values[0].text "Ivan"))
    (t.is function-result.ok)
    (t.is (= (count function-result.rows) 1))
    (t.is (= function-result.rows[0].values[0].text ":adult"))
    (t.is rule-result.ok)
    (t.is (= (count rule-result.rows) 1))
    (t.is (= rule-result.rows[0].values[0].text "Ivan"))))

(t.deftest named-relation-source-uses-direct-source-operator
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (relation-db-rows)
        named (vev.q-text-with-inputs
                conn.db
                "[:find ?name :in $rows :where [$rows ?e :age ?age] [(>= ?age 18)] [$rows ?e :name ?name]]"
                ([]vev.Query-Input [(vev.query-input-scalar rows)]))
        sourced-rule (vev.q-text-with-rules
                       conn.db
                       "[:find ?name :in $rows % :where ($rows adult-name ?e ?name)]"
                       "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) ($rows adult ?e) [?e :name ?name]]]"
                       ([]vev.Query-Input [(vev.query-input-scalar rows)]))]
    (t.is named.ok)
    (t.is (= (count named.rows) 1))
    (t.is (= named.rows[0].values[0].text "Ivan"))
    (t.is sourced-rule.ok)
    (t.is (= (count sourced-rule.rows) 1))
    (t.is (= sourced-rule.rows[0].values[0].text "Ivan"))))
