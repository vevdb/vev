(package vev-tests)

(import fmt "core:fmt")
(import os "core:os")
(import t "kvist:test")
(import vev "../vev")

(defn remove-storage-with-sqlite-files [path: string]
  (os.remove path)
  (os.remove (fmt.tprintf "%s-wal" path))
  (os.remove (fmt.tprintf "%s-shm" path)))

(defn seed-cas-lookup-ref-store [path: string] -> [ok: bool, error: string]
  (let [[store opened-ok opened-error] (vev.open-store path)
        schema (vev.transact-store-text
                 (addr store)
                 "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/one}]")
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/email \"ada@example.com\"} {:db/id 2 :user/email \"grace@example.com\"}]")]
    (vev.close-store store)
    (when (not opened-ok)
      (vev.delete-tx-report-shallow schema)
      (vev.delete-tx-report-shallow seed)
      (return false opened-error))
    (when (not schema.ok)
      (let [error schema.error]
        (vev.delete-tx-report-shallow schema)
        (vev.delete-tx-report-shallow seed)
        (return false error)))
    (when (not seed.ok)
      (let [error seed.error]
        (vev.delete-tx-report-shallow schema)
        (vev.delete-tx-report-shallow seed)
        (return false error)))
    (vev.delete-tx-report-shallow schema)
    (vev.delete-tx-report-shallow seed)
    (return true "")))

(t.deftest sqlite-source-store-initial-schema-tempid-maps
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.initial-schema-tempid-maps.sqlite")
  (let [path "tmp.vev.initial-schema-tempid-maps.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          report (vev.transact-store-report-text
                   (addr store)
                   "[{:db/id \"schema-name\" :db/ident :object/name :db/doc \"Name.\" :db/valueType :db.type/string :db/index true :db/cardinality :db.cardinality/one}
                     {:db/id \"schema-radius\" :db/ident :object/meanRadius :db/doc \"Radius.\" :db/valueType :db.type/double :db/index true :db/cardinality :db.cardinality/one}]")]
      (t.is opened-ok opened-error)
      (t.is report.ok report.error)
      (vev.delete-store-tx-report report)
      (vev.close-store store))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          result (vev.q-result-store-db-text (addr snapshot) "[:find ?ident :where [?e :db/ident ?ident]]")]
      (t.is read-opened-ok read-opened-error)
      (t.is snapshot-ok snapshot-error)
      (t.is result.result.ok result.result.error)
      (t.is (= (count result.result.rows) 2))
      (vev.delete-query-result result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))))

(t.deftest sqlite-store-db-with-cas-expected-lookup-ref-uses-same-tx-overlay
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.store-db-with-cas-expected-lookup-ref.sqlite")
  (let [path "tmp.vev.store-db-with-cas-expected-lookup-ref.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[seed-ok seed-error] (seed-cas-lookup-ref-store path)]
      (t.is seed-ok seed-error))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          next-snapshot (vev.db-with-store-db-text
                          (addr snapshot)
                          "[{:db/id \"temp\" :user/email \"temp@example.com\"} [:db/add 1 :user/friend \"temp\"] [:db/cas 1 :user/friend [:user/email \"temp@example.com\"] [:user/email \"grace@example.com\"]]]")
          friend-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?email :where [1 :user/friend ?friend] [?friend :user/email ?email]]")
          temp-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?e :where [?e :user/email \"temp@example.com\"]]")
          original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?friend :where [1 :user/friend ?friend]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (vev.source-backed-store-db? (addr snapshot)))
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is friend-result.result.ok friend-result.result.error)
      (t.is (= (count friend-result.result.rows) 1))
      (t.is (= friend-result.result.rows[0].values[0].text "grace@example.com"))
      (t.is temp-result.result.ok temp-result.result.error)
      (t.is (= (count temp-result.result.rows) 1))
      (t.is original-result.result.ok)
      (t.is (= (count original-result.result.rows) 0))
      (vev.delete-query-result friend-result)
      (vev.delete-query-result temp-result)
      (vev.delete-query-result original-result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store read-store))))

(t.deftest sqlite-source-store-db-with-text-resident-helper-fails-without-materializing
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.store-db-with-text-resident-helper.sqlite")
  (let [path "tmp.vev.store-db-with-text-resident-helper.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[seed-ok seed-error] (seed-cas-lookup-ref-store path)]
      (t.is seed-ok seed-error))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-text (addr snapshot) "[{:db/id 3 :user/email \"barbara@example.com\"}]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (vev.source-backed-store-db? (addr snapshot)))
      (t.is (not report.ok))
      (t.is (= report.error "with-store-db-text is resident-only; use with-store-db-report-text for source-backed Store-DB values"))
      (vev.delete-store-db-temp-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))))

(t.deftest sqlite-source-store-db-pull-many-lookup-refs-text
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.store-db-pull-many-lookup-refs-text.sqlite")
  (let [path "tmp.vev.store-db-pull-many-lookup-refs-text.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[seed-ok seed-error] (seed-cas-lookup-ref-store path)]
      (t.is seed-ok seed-error))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          attrs ([]string [":user/email" ":user/email" ":user/email"])
          lookup-values ([]vev.Value [(vev.value-string "ada@example.com")
                                      (vev.value-string "missing@example.com")
                                      (vev.value-string "grace@example.com")])
          [pulled pulled-ok pulled-error] (vev.pull-many-store-db-lookup-refs-value-text (addr snapshot) "[:user/email]" attrs lookup-values)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (vev.source-backed-store-db? (addr snapshot)))
      (t.is pulled-ok pulled-error)
      (t.is (= pulled.kind .Vector))
      (t.is (= (count pulled.items) 3))
      (t.is (= pulled.items[0].kind .Map))
      (t.is (= pulled.items[1].kind .Nil))
      (t.is (= pulled.items[2].kind .Map))
      (let [[first-email first-email-ok] (vev.map-get-value pulled.items[0] (vev.value-keyword ":user/email"))
            [last-email last-email-ok] (vev.map-get-value pulled.items[2] (vev.value-keyword ":user/email"))]
        (t.is first-email-ok)
        (t.is (= first-email.kind .String))
        (t.is (= first-email.text "ada@example.com"))
        (t.is last-email-ok)
        (t.is (= last-email.kind .String))
        (t.is (= last-email.text "grace@example.com")))
      (vev.delete-owned-value pulled)
      (for [value lookup-values]
        (vev.delete-owned-value value))
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))))

(t.deftest sqlite-source-store-db-collection-lookup-ref-input-stays-source-backed
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.store-db-collection-lookup-ref-input.sqlite")
  (let [path "tmp.vev.store-db-collection-lookup-ref-input.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[seed-ok seed-error] (seed-cas-lookup-ref-store path)]
      (t.is seed-ok seed-error))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          [source source-ok source-error] (vev.store-db-read-source (addr snapshot))
          input (vev.query-input-collection-lookup-refs
                  ([]string [":user/email" ":user/email" ":user/email"])
                  ([]vev.Value [(vev.value-string "ada@example.com")
                                (vev.value-string "missing@example.com")
                                (vev.value-string "grace@example.com")]))
          profiled (vev.q-text-db-read-source-profiled-with-inputs
                     source
                     "[:find ?email :in $ [?e ...] :where [?e :user/email ?email]]"
                     ([]vev.Query-Input [input]))]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is source-ok source-error)
      (t.is (vev.source-backed-store-db? (addr snapshot)))
      (t.is profiled.result.ok profiled.result.error)
      (t.is (= (count profiled.result.rows) 2))
      (t.is (= profiled.stats.input-bindings 2))
      (t.is (= profiled.stats.binding-materializations 0))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (vev.delete-profiled-result-set-owned-values profiled)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))))

(t.deftest sqlite-store-db-text-collection-lookup-ref-input-stays-source-backed
  (defer (free_all context.allocator))
  (remove-storage-with-sqlite-files "tmp.vev.store-db-text-collection-lookup-ref-input.sqlite")
  (let [path "tmp.vev.store-db-text-collection-lookup-ref-input.sqlite"]
    (defer (remove-storage-with-sqlite-files path))
    (let [[seed-ok seed-error] (seed-cas-lookup-ref-store path)]
      (t.is seed-ok seed-error))
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          profiled (vev.q-profiled-store-db-text-with-input-text
                     (addr snapshot)
                     "[:find ?email :in $ [?e ...] :where [?e :user/email ?email]]"
                     "[[[:user/email \"ada@example.com\"] [:user/email \"missing@example.com\"] [:user/email \"grace@example.com\"]]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (vev.source-backed-store-db? (addr snapshot)))
      (t.is profiled.result.ok profiled.result.error)
      (t.is (= (count profiled.result.rows) 2))
      (t.is (= profiled.stats.input-bindings 2))
      (t.is (= profiled.stats.binding-materializations 0))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (vev.delete-profiled-result-set-owned-values profiled)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))))
