(package vev-tests)

(import t "kvist:test")
(import vev "../vev")

(defn has-entity-pair? [result: vev.Result-Set, left: u64, right: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity left)
               (= row.values[1].kind .Entity)
               (= row.values[1].entity right))
      (return true)))
  false)

(defn has-entity? [result: vev.Result-Set, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity))
      (return true)))
  false)

(defn has-text? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(t.deftest recursive-rules-use-relation-native-clause-steps
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]
             [:db/add 3 :follow (vev.value-entity 4)]
             [:db/add 4 :follow (vev.value-entity 5)]])
        reachable (vev.q-text-with-rules
                    conn.db
                    "[:find ?e2 :in $ % ?e1 :where (follow ?e1 ?e2)]"
                    "[[(follow ?e1 ?e2) [?e1 :follow ?e2]] [(follow ?e1 ?e2) [?e1 :follow ?t] (follow ?t ?e2)]]"
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))]))
        all-pairs (vev.q-text-with-rules
                    conn.db
                    "[:find ?e1 ?e2 :in $ % :where (follow ?e1 ?e2)]"
                    "[[(follow ?e1 ?e2) [?e1 :follow ?e2]] [(follow ?e1 ?e2) [?e1 :follow ?t] (follow ?t ?e2)]]"
                    ([]vev.Query-Input []))]
    (t.is reachable.ok)
    (t.is (= (count reachable.rows) 4))
    (t.is (has-entity? reachable 2))
    (t.is (has-entity? reachable 3))
    (t.is (has-entity? reachable 4))
    (t.is (has-entity? reachable 5))
    (t.is all-pairs.ok)
    (t.is (= (count all-pairs.rows) 10))
    (t.is (has-entity-pair? all-pairs 1 2))
    (t.is (has-entity-pair? all-pairs 1 5))
    (t.is (has-entity-pair? all-pairs 3 5))))

(t.deftest mutual-recursive-rules-use-relation-native-clause-steps
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 0 :f1 (vev.value-entity 1)]
             [:db/add 1 :f2 (vev.value-entity 2)]
             [:db/add 2 :f1 (vev.value-entity 3)]
             [:db/add 3 :f2 (vev.value-entity 4)]
             [:db/add 4 :f1 (vev.value-entity 5)]
             [:db/add 5 :f2 (vev.value-entity 6)]])
        result (vev.q-text-with-rules
                 conn.db
                 "[:find ?e1 ?e2 :in $ % :where (f1 ?e1 ?e2)]"
                 "[[(f1 ?e1 ?e2) [?e1 :f1 ?e2]] [(f1 ?e1 ?e2) [?t :f1 ?e2] (f2 ?e1 ?t)] [(f2 ?e1 ?e2) [?e1 :f2 ?e2]] [(f2 ?e1 ?e2) [?t :f2 ?e2] (f1 ?e1 ?t)]]"
                 ([]vev.Query-Input []))]
    (t.is result.ok)
    (t.is (= (count result.rows) 9))
    (t.is (has-entity-pair? result 0 1))
    (t.is (has-entity-pair? result 0 3))
    (t.is (has-entity-pair? result 0 5))
    (t.is (has-entity-pair? result 4 5))))

(t.deftest memo-rule-call-projection-preserves-argument-semantics
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :link (vev.value-entity 1)]
             [:db/add 1 :link (vev.value-entity 2)]
             [:db/add 2 :link (vev.value-entity 2)]
             [:db/add 3 :link (vev.value-entity 3)]
             [:db/add 1 :name (vev.value-string "Ada")]
             [:db/add 2 :name (vev.value-string "Grace")]])
        self-links (vev.q-text-with-rules
                     conn.db
                     "[:find ?e :in $ % :where (edge ?e ?e)]"
                     "[[(edge ?a ?b) [?a :link ?b]]]"
                     ([]vev.Query-Input []))
        wildcard-links (vev.q-text-with-rules
                         conn.db
                         "[:find ?e :in $ % :where (edge ?e _)]"
                         "[[(edge ?a ?b) [?a :link ?b]]]"
                         ([]vev.Query-Input []))
        constant-name (vev.q-text-with-rules
                        conn.db
                        "[:find ?name :in $ % :where (named ?e \"Ada\") [?e :name ?name]]"
                        "[[(named ?e ?name) [?e :name ?name]]]"
                        ([]vev.Query-Input []))]
    (t.is self-links.ok)
    (t.is (= (count self-links.rows) 2))
    (t.is (has-entity? self-links 2))
    (t.is (has-entity? self-links 3))
    (t.is wildcard-links.ok)
    (t.is (= (count wildcard-links.rows) 3))
    (t.is (has-entity? wildcard-links 1))
    (t.is (has-entity? wildcard-links 2))
    (t.is (has-entity? wildcard-links 3))
    (t.is constant-name.ok)
    (t.is (= (count constant-name.rows) 1))
    (t.is (has-text? constant-name "Ada"))))
