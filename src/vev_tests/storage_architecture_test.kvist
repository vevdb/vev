        seed (vev.transact-store-text
               (addr store)
               "[{:db/id 1 :item/name \"Ada\" :item/friend 2 :item/profile 3} {:db/id 2 :item/name \"Grace\"} {:db/id 3 :item/email \"ada@example.com\"}]")]
