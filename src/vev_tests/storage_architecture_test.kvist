    (t.is (= opened-error ""))
    (t.is schema.ok schema.error)
    (t.is seed.ok seed.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text (addr snapshot) "[[:db/retractEntity 1]]")
          before-parent (vev.q-result-store-db-text (addr report.db-before) "[:find ?a ?v :where [1 ?a ?v]]")
          after-parent (vev.q-result-store-db-text (addr report.db-after) "[:find ?a ?v :where [1 ?a ?v]]")
          after-child (vev.q-result-store-db-text (addr report.db-after) "[:find ?a ?v :where [3 ?a ?v]]")
          after-friend (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [2 :item/name ?name]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-parent.result.ok before-parent.result.error)
      (t.is (> (count before-parent.result.rows) 0))
      (t.is after-parent.result.ok after-parent.result.error)
      (t.is (= (count after-parent.result.rows) 0))
      (t.is after-child.result.ok after-child.result.error)
      (t.is (= (count after-child.result.rows) 0))
      (t.is after-friend.result.ok after-friend.result.error)
      (t.is (= (count after-friend.result.rows) 1))
      (t.is (= after-friend.result.rows[0].values[0].kind .String))
      (t.is (= after-friend.result.rows[0].values[0].text "Grace"))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (vev.delete-query-result before-parent)
      (vev.delete-query-result after-parent)
      (vev.delete-query-result after-child)
      (vev.delete-query-result after-friend)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow schema)
    (vev.delete-tx-report-shallow seed)))

(t.deftest sqlite-store-with-report-cas-and-retract-attr-keep-source-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-cas-retract-attr.sqlite")
  (let [path "tmp.vev.store-with-report-cas-retract-attr.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :item/name \"Ada\" :item/weight 200 :item/label \"old\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text
                   (addr snapshot)
                   "[[:db/cas 1 :item/weight 200 300] [:db.fn/retractAttribute 1 :item/label]]")
          before (vev.q-result-store-db-text (addr report.db-before) "[:find ?weight ?label :where [1 :item/weight ?weight] [1 :item/label ?label]]")
          after-weight (vev.q-result-store-db-text (addr report.db-after) "[:find ?weight :where [1 :item/weight ?weight]]")
          after-label (vev.q-result-store-db-text (addr report.db-after) "[:find ?label :where [1 :item/label ?label]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before.result.ok before.result.error)
      (t.is (= (count before.result.rows) 1))
      (t.is (= before.result.rows[0].values[0].kind .Int))
      (t.is (= before.result.rows[0].values[0].int-value 200))
      (t.is (= before.result.rows[0].values[1].kind .String))
      (t.is (= before.result.rows[0].values[1].text "old"))
      (t.is after-weight.result.ok after-weight.result.error)
      (t.is (= (count after-weight.result.rows) 1))
      (t.is (= after-weight.result.rows[0].values[0].kind .Int))
      (t.is (= after-weight.result.rows[0].values[0].int-value 300))
      (t.is after-label.result.ok after-label.result.error)
      (t.is (= (count after-label.result.rows) 0))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (vev.delete-query-result before)
      (vev.delete-query-result after-weight)
      (vev.delete-query-result after-label)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow seed)))

(t.deftest sqlite-store-with-report-overlay-uses-source-merge-operators
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-merge.sqlite")
  (let [path "tmp.vev.store-with-report-merge.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[[:db/add 1 :user/name \"Ada\"] [:db/add 1 :user/age 40] [:db/add 1 :user/code 10] [:db/add 1 :user/friend 2]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
      (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text
                   (addr snapshot)
                   "[{:db/id 100 :db/ident :user/tag :db/cardinality :db.cardinality/many} {:db/id 101 :db/ident :user/mentor :db/valueType :db.type/ref} [:db/add 3 :user/name \"Grace\"] [:db/add 3 :user/age 41] [:db/add 3 :user/code 20] [:db/add 3 :user/friend 1] [:db/add 3 :user/mentor 1] [:db/add 3 :user/tag \"admin\"] [:db/add 3 :user/tag \"lead\"]]")
          two-attr (vev.q-profiled-store-db-text
                    (addr report.db-after)
                    "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]")
          three-attr (vev.q-profiled-store-db-text
                      (addr report.db-after)
                      "[:find ?name ?age ?code :where [?e :user/name ?name] [?e :user/age ?age] [?e :user/code ?code]]")
          star (vev.q-profiled-store-db-text
                (addr report.db-after)
                "[:find ?name ?age ?code ?friend :where [?e :user/name ?name] [?e :user/age ?age] [?e :user/code ?code] [?e :user/friend ?friend]]")
          star-many (vev.q-profiled-store-db-text
                     (addr report.db-after)
                     "[:find ?name ?age ?tag ?friend :where [?e :user/name ?name] [?e :user/age ?age] [?e :user/tag ?tag] [?e :user/friend ?friend]]")
          range-star (vev.q-profiled-store-db-text
                      (addr report.db-after)
                      "[:find ?name ?code ?friend :where [?e :user/age ?age] [(> ?age 40)] [?e :user/name ?name] [?e :user/code ?code] [?e :user/friend ?friend]]")
          range-star-many (vev.q-profiled-store-db-text
                           (addr report.db-after)
                           "[:find ?name ?tag ?friend :where [?e :user/age ?age] [(> ?age 40)] [?e :user/name ?name] [?e :user/tag ?tag] [?e :user/friend ?friend]]")
          value-ref-attr (vev.q-profiled-store-db-text
                           (addr report.db-after)
                           "[:find ?name :where [?mentor :user/name \"Ada\"] [?e :user/mentor ?mentor] [?e :user/name ?name]]")
          value-ref-star (vev.q-profiled-store-db-text
                           (addr report.db-after)
                           "[:find ?name ?age ?tag :where [?mentor :user/name \"Ada\"] [?e :user/mentor ?mentor] [?e :user/name ?name] [?e :user/age ?age] [?e :user/tag ?tag]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is report.ok report.error)
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is two-attr.result.ok two-attr.result.error)
      (t.is (= (count two-attr.result.rows) 2))
      (t.is (result-has-string-int-row? two-attr.result "Ada" 40))
      (t.is (result-has-string-int-row? two-attr.result "Grace" 41))
      (t.is (> two-attr.stats.source-operators 0))
      (t.is (= two-attr.stats.binding-materializations 0))
      (t.is three-attr.result.ok three-attr.result.error)
      (t.is (= (count three-attr.result.rows) 2))
      (t.is (result-has-string-int-int-row? three-attr.result "Ada" 40 10))
      (t.is (result-has-string-int-int-row? three-attr.result "Grace" 41 20))
      (t.is (> three-attr.stats.source-operators 0))
      (t.is (= three-attr.stats.binding-materializations 0))
      (t.is star.result.ok star.result.error)
      (t.is (= (count star.result.rows) 2))
      (t.is (result-has-string-int-int-int-row? star.result "Ada" 40 10 2))
      (t.is (result-has-string-int-int-int-row? star.result "Grace" 41 20 1))
      (t.is (> star.stats.source-operators 0))
      (t.is (= star.stats.binding-materializations 0))
      (t.is star-many.result.ok star-many.result.error)
      (t.is (= (count star-many.result.rows) 2))
      (t.is (result-has-string-int-string-int-row? star-many.result "Grace" 41 "admin" 1))
      (t.is (result-has-string-int-string-int-row? star-many.result "Grace" 41 "lead" 1))
      (t.is (> star-many.stats.source-operators 0))
      (t.is (= star-many.stats.binding-materializations 0))
      (t.is (= star-many.stats.generic-materialization-steps 0))
      (t.is range-star.result.ok range-star.result.error)
      (t.is (= (count range-star.result.rows) 1))
      (t.is (result-has-string-int-int-row? range-star.result "Grace" 20 1))
      (t.is (> range-star.stats.source-operators 0))
      (t.is (= range-star.stats.binding-materializations 0))
      (t.is range-star-many.result.ok range-star-many.result.error)
      (t.is (= (count range-star-many.result.rows) 2))
      (t.is (result-has-string-string-int-row? range-star-many.result "Grace" "admin" 1))
      (t.is (result-has-string-string-int-row? range-star-many.result "Grace" "lead" 1))
      (t.is (> range-star-many.stats.source-operators 0))
      (t.is (= range-star-many.stats.binding-materializations 0))
      (t.is value-ref-attr.result.ok value-ref-attr.result.error)
      (t.is (= (count value-ref-attr.result.rows) 1))
      (t.is (result-has-string-row? value-ref-attr.result "Grace"))
      (t.is (> value-ref-attr.stats.source-operators 0))
      (t.is (= value-ref-attr.stats.binding-materializations 0))
      (t.is (= value-ref-attr.stats.generic-materialization-steps 0))
      (t.is value-ref-star.result.ok value-ref-star.result.error)
      (t.is (= (count value-ref-star.result.rows) 2))
      (t.is (result-has-string-int-string-row? value-ref-star.result "Grace" 41 "admin"))
      (t.is (result-has-string-int-string-row? value-ref-star.result "Grace" 41 "lead"))
      (t.is (> value-ref-star.stats.source-operators 0))
      (t.is (= value-ref-star.stats.binding-materializations 0))
      (t.is (= value-ref-star.stats.generic-materialization-steps 0))
      (vev.delete-profiled-result-set-owned-values two-attr)
      (vev.delete-profiled-result-set-owned-values three-attr)
      (vev.delete-profiled-result-set-owned-values star)
      (vev.delete-profiled-result-set-owned-values star-many)
      (vev.delete-profiled-result-set-owned-values range-star)
      (vev.delete-profiled-result-set-owned-values range-star-many)
      (vev.delete-profiled-result-set-owned-values value-ref-attr)
      (vev.delete-profiled-result-set-owned-values value-ref-star)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-validates-source-schema-value-types
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-schema-type.sqlite")
  (let [path "tmp.vev.store-with-report-schema-type.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[{:db/id 100 :db/ident :item/count :db/valueType :db.type/long} {:db/id 1 :item/count 42}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok write-report.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text (addr snapshot) "[[:db/add 1 :item/count \"bad\"]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?count :where [1 :item/count ?count]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not report.ok))
      (t.is (= report.error "schema value type mismatch"))
      (t.is (sqlite-durable-store-db? report.db-after))
      (t.is after-result.result.ok)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (= after-result.result.rows[0].values[0].kind .Int))
      (t.is (= after-result.result.rows[0].values[0].int-value 42))
      (vev.delete-query-result after-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-unsupported-source-shape-fails-with-store-db-values
