(package vev-tests)

(import arr "kvist:arr")
(import fmt "core:fmt")
(import os "core:os")
(import t "kvist:test")
(import vev "../vev")

(defn remove-sqlite-files [path: string]
  (os.remove path)
  (os.remove (fmt.tprintf "%s-wal" path))
  (os.remove (fmt.tprintf "%s-shm" path)))

(defn int-slices-equal? [left: []int, right: []int] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(t.deftest sqlite-initializes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture.sqlite")
  (let [path "tmp.vev.storage-architecture.sqlite"
        [architecture architecture-ok architecture-error] (vev.sqlite-storage-architecture path)
        [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
        [_ latest-ok latest-error] (vev.sqlite-latest-index-root-basis path)]
    (defer (remove-sqlite-files path))
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 0))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 0))
    (t.is (not latest-ok))
    (t.is (= latest-error "sqlite DB has no Vev index roots"))))

(t.deftest sqlite-live-connection-exposes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-live.sqlite")
  (let [path "tmp.vev.storage-architecture-live.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\"} {:db/id 2 :user/name \"Grace\"}]")
        second-report (vev.transact-sqlite-text
                        (addr store)
                        "[{:db/id 3 :user/name \"Frances\"}]")
        [architecture architecture-ok architecture-error] (vev.sqlite-conn-storage-architecture (addr store))
        [root-count root-count-ok root-count-error] (vev.sqlite-conn-index-root-count (addr store))
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-conn-index-chunk-count (addr store))
        [basis basis-ok basis-error] (vev.sqlite-conn-latest-index-root-basis (addr store))
        [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":eavt")
        [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":aevt")
        [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":avet")
        [vaet-basis vaet-rows vaet-ok vaet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":vaet")
        [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-conn-latest-index-entries (addr store) ":eavt")
        [datom-count datom-count-ok datom-count-error] (vev.sqlite-conn-datom-count (addr store))
        [first-datom first-datom-ok first-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 0)
        [last-datom last-datom-ok last-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 2)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is second-report.ok)
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 2))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 8))
    (t.is basis-ok)
    (t.is (= basis-error ""))
    (t.is (= basis 2))
    (t.is eavt-ok)
    (t.is (= eavt-error ""))
    (t.is (= eavt-basis 2))
    (t.is (= eavt-rows (u64 (count store.conn.db.eavt))))
    (t.is aevt-ok)
    (t.is (= aevt-error ""))
    (t.is (= aevt-basis 2))
    (t.is (= aevt-rows (u64 (count store.conn.db.aevt))))
    (t.is avet-ok)
    (t.is (= avet-error ""))
    (t.is (= avet-basis 2))
    (t.is (= avet-rows (u64 (count store.conn.db.avet))))
    (t.is vaet-ok)
    (t.is (= vaet-error ""))
    (t.is (= vaet-basis 2))
    (t.is (= vaet-rows (u64 (count store.conn.db.vaet))))
    (t.is loaded-eavt-ok)
    (t.is (= loaded-eavt-error ""))
    (t.is (int-slices-equal? (slice loaded-eavt 0) (slice store.conn.db.eavt 0)))
    (t.is datom-count-ok)
    (t.is (= datom-count-error ""))
    (t.is (= datom-count 3))
    (t.is first-datom-ok)
    (t.is (= first-datom-error ""))
    (t.is (= first-datom.e 1))
    (t.is (= first-datom.a ":user/name"))
    (t.is last-datom-ok)
    (t.is (= last-datom-error ""))
    (t.is (= last-datom.e 3))
    (t.is (= last-datom.a ":user/name"))
    (delete loaded-eavt)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-persist-writes-bounded-index-chunks
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-chunks.sqlite")
  (let [path "tmp.vev.storage-architecture-chunks.sqlite"
        datoms (make [dynamic]vev.Datom) :defer]
    (for [i (arr.range 1 301)]
      (arr.push! datoms (vev.datom-tx (u64 i) ":item/value" (vev.value-int (i64 i)) 1 true)))
    (arr.push! datoms (vev.datom-tx 301 ":item/name" (vev.value-string "item-301") 1 true))
    (let [db (vev.init-db (slice datoms 0))
          [saved-ok saved-error] (vev.save-db-sqlite path db)
          [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
          [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
          [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-latest-index-chunk-row-count path ":eavt")
          [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-latest-index-chunk-row-count path ":aevt")
          [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-latest-index-chunk-row-count path ":avet")
          [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
          [loaded-aevt loaded-aevt-ok loaded-aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
          [eavt-page-first eavt-page-first-ok eavt-page-first-error] (vev.sqlite-latest-index-entry-page path ":eavt" 0 128)
          [eavt-page-cross eavt-page-cross-ok eavt-page-cross-error] (vev.sqlite-latest-index-entry-page path ":eavt" 120 32)
          [eavt-page-tail eavt-page-tail-ok eavt-page-tail-error] (vev.sqlite-latest-index-entry-page path ":eavt" 280 64)
          [eavt-page-count eavt-page-count-ok eavt-page-count-error] (vev.sqlite-latest-index-entry-pages-count path ":eavt" 128)
          [cursor cursor-ok cursor-error] (vev.sqlite-open-index-cursor path ":eavt" 64)
          [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-index-snapshot path 64)
          [db-snapshot db-snapshot-ok db-snapshot-error] (vev.sqlite-open-db-snapshot path 64)
          [reopened reopened-ok reopened-error] (vev.open-conn-sqlite path)]
      (defer (remove-sqlite-files path))
      (t.is saved-ok)
      (t.is (= saved-error ""))
      (t.is root-count-ok)
      (t.is (= root-count-error ""))
      (t.is (= root-count 1))
      (t.is chunk-count-ok)
      (t.is (= chunk-count-error ""))
      (t.is (> chunk-count 4))
      (t.is eavt-ok)
      (t.is (= eavt-error ""))
      (t.is (= eavt-basis 1))
      (t.is (= eavt-rows (u64 (count db.eavt))))
      (t.is aevt-ok)
      (t.is (= aevt-error ""))
      (t.is (= aevt-basis 1))
      (t.is (= aevt-rows (u64 (count db.aevt))))
      (t.is avet-ok)
      (t.is (= avet-error ""))
      (t.is (= avet-basis 1))
      (t.is (= avet-rows (u64 (count db.avet))))
      (t.is loaded-eavt-ok)
      (t.is (= loaded-eavt-error ""))
      (t.is (int-slices-equal? (slice loaded-eavt 0) (slice db.eavt 0)))
      (t.is loaded-aevt-ok)
      (t.is (= loaded-aevt-error ""))
      (t.is (int-slices-equal? (slice loaded-aevt 0) (slice db.aevt 0)))
      (t.is eavt-page-first-ok)
      (t.is (= eavt-page-first-error ""))
      (t.is (int-slices-equal? (slice eavt-page-first 0) (slice db.eavt 0 128)))
      (t.is eavt-page-cross-ok)
      (t.is (= eavt-page-cross-error ""))
      (t.is (int-slices-equal? (slice eavt-page-cross 0) (slice db.eavt 120 152)))
      (t.is eavt-page-tail-ok)
      (t.is (= eavt-page-tail-error ""))
      (t.is (int-slices-equal? (slice eavt-page-tail 0) (slice db.eavt 280 (count db.eavt))))
      (t.is eavt-page-count-ok)
      (t.is (= eavt-page-count-error ""))
      (t.is (= eavt-page-count (count db.eavt)))
      (t.is cursor-ok)
      (t.is (= cursor-error ""))
      (t.is (= (vev.sqlite-index-cursor-count cursor) (count db.eavt)))
      (let [view (vev.db-index-view-from-sqlite-cursor (vev.public-index-order ":eavt") (addr cursor))
            low (vev.lower-bound-index-view db view "eavt-ea" 42 ":item/value" (vev.Value {}))
            high (vev.upper-bound-index-view db view "eavt-ea" 42 ":item/value" (vev.Value {}))]
        (t.is (= (vev.db-index-view-count view) (count db.eavt)))
        (t.is (= (vev.db-index-view-at view 0) db.eavt[0]))
        (t.is (= (vev.db-index-view-at view 129) db.eavt[129]))
        (t.is (= (- high low) 1))
        (t.is (= db.datoms[(vev.db-index-view-at view low)].e 42)))
      (let [[first-entry first-entry-ok first-entry-error] (vev.sqlite-index-cursor-at (addr cursor) 0)
            [middle-entry middle-entry-ok middle-entry-error] (vev.sqlite-index-cursor-at (addr cursor) 129)
            [tail-entry tail-entry-ok tail-entry-error] (vev.sqlite-index-cursor-at (addr cursor) (- (count db.eavt) 1))]
        (t.is first-entry-ok)
        (t.is (= first-entry-error ""))
        (t.is (= first-entry db.eavt[0]))
        (t.is middle-entry-ok)
        (t.is (= middle-entry-error ""))
        (t.is (= middle-entry db.eavt[129]))
        (t.is tail-entry-ok)
        (t.is (= tail-entry-error ""))
        (t.is (= tail-entry db.eavt[(- (count db.eavt) 1)])))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (let [snapshot-view (vev.sqlite-index-snapshot-view (addr snapshot) (vev.public-index-order ":eavt"))
            [snapshot-datom snapshot-datom-ok snapshot-datom-error] (vev.sqlite-index-snapshot-datom-at-log-index (addr snapshot) 42)
            [snapshot-string-datom snapshot-string-datom-ok snapshot-string-datom-error] (vev.sqlite-index-snapshot-datom-at-log-index (addr snapshot) 300)]
        (t.is (= (vev.db-index-view-count snapshot-view) (count db.eavt)))
        (t.is (= (vev.db-index-view-at snapshot-view 0) db.eavt[0]))
        (t.is snapshot-datom-ok)
        (t.is (= snapshot-datom-error ""))
        (t.is (= snapshot-datom.e 43))
        (t.is (= snapshot-datom.a ":item/value"))
        (t.is (= snapshot-datom.v.kind .Int))
        (t.is (= snapshot-datom.v.int-value 43))
        (t.is snapshot-string-datom-ok)
        (t.is (= snapshot-string-datom-error ""))
        (t.is (= snapshot-string-datom.e 301))
        (t.is (= snapshot-string-datom.a ":item/name"))
        (t.is (= snapshot-string-datom.v.kind .String))
        (t.is (= snapshot-string-datom.v.text "item-301"))
        (vev.delete-owned-datom snapshot-datom)
        (vev.delete-owned-datom snapshot-string-datom))
      (t.is db-snapshot-ok)
      (t.is (= db-snapshot-error ""))
      (t.is (= db-snapshot.basis-tx 1))
      (t.is (= db-snapshot.datom-count (count db.datoms)))
      (let [db-snapshot-view (vev.sqlite-db-snapshot-index-view (addr db-snapshot) (vev.public-index-order ":eavt"))
            db-snapshot-source (vev.sqlite-db-read-source (addr db-snapshot))
            [db-snapshot-datom db-snapshot-datom-ok db-snapshot-datom-error] (vev.sqlite-db-snapshot-datom-at-log-index (addr db-snapshot) 300)
            [entity-low entity-high entity-range-ok entity-range-error] (vev.sqlite-db-snapshot-eavt-entity-range (addr db-snapshot) 301)
            [missing-low missing-high missing-range-ok missing-range-error] (vev.sqlite-db-snapshot-eavt-entity-range (addr db-snapshot) 999)
            [entity-datoms entity-datoms-ok entity-datoms-error] (vev.sqlite-db-snapshot-entity-datoms (addr db-snapshot) 301)
            [attr-low attr-high attr-range-ok attr-range-error] (vev.sqlite-db-snapshot-aevt-attr-range (addr db-snapshot) ":item/name")
            [missing-attr-low missing-attr-high missing-attr-range-ok missing-attr-range-error] (vev.sqlite-db-snapshot-aevt-attr-range (addr db-snapshot) ":item/missing")
            [attr-datoms attr-datoms-ok attr-datoms-error] (vev.sqlite-db-snapshot-attr-datoms (addr db-snapshot) ":item/name")
            [entity-attr-datoms entity-attr-datoms-ok entity-attr-datoms-error] (vev.sqlite-db-snapshot-entity-attr-datoms (addr db-snapshot) 301 ":item/name")
            [source-attr-datoms source-attr-ok source-attr-error] (vev.db-read-source-datoms-by-attr db-snapshot-source ":item/name")
            [source-entity-attr-datoms source-entity-attr-ok source-entity-attr-error] (vev.db-read-source-datoms-by-entity-attr db-snapshot-source 301 ":item/name")
            [source-pull source-pull-ok source-pull-error] (vev.db-read-source-pull-attrs-value db-snapshot-source 301 ([]string [":db/id" ":item/name"]))
            source-query-by-attr (vev.q-text-db-read-source db-snapshot-source "[:find ?e :where [?e :item/name]]")
            source-query-by-entity-attr (vev.q-text-db-read-source db-snapshot-source "[:find ?name :where [301 :item/name ?name]]")]
        (t.is (= (vev.db-index-view-count db-snapshot-view) (count db.eavt)))
        (t.is (= (vev.db-index-view-at db-snapshot-view 0) db.eavt[0]))
        (t.is db-snapshot-datom-ok)
        (t.is (= db-snapshot-datom-error ""))
        (t.is (= db-snapshot-datom.e 301))
        (t.is (= db-snapshot-datom.a ":item/name"))
        (t.is (= db-snapshot-datom.v.kind .String))
        (t.is (= db-snapshot-datom.v.text "item-301"))
        (t.is entity-range-ok)
        (t.is (= entity-range-error ""))
        (t.is (= (- entity-high entity-low) 1))
        (t.is missing-range-ok)
        (t.is (= missing-range-error ""))
        (t.is (= missing-low missing-high))
        (t.is entity-datoms-ok)
        (t.is (= entity-datoms-error ""))
        (t.is (= (count entity-datoms) 1))
        (t.is (= entity-datoms[0].e 301))
        (t.is (= entity-datoms[0].a ":item/name"))
        (t.is (= entity-datoms[0].v.kind .String))
        (t.is (= entity-datoms[0].v.text "item-301"))
        (t.is attr-range-ok)
        (t.is (= attr-range-error ""))
        (t.is (= (- attr-high attr-low) 1))
        (t.is missing-attr-range-ok)
        (t.is (= missing-attr-range-error ""))
        (t.is (= missing-attr-low missing-attr-high))
        (t.is attr-datoms-ok)
        (t.is (= attr-datoms-error ""))
        (t.is (= (count attr-datoms) 1))
        (t.is (= attr-datoms[0].e 301))
        (t.is (= attr-datoms[0].a ":item/name"))
        (t.is (= attr-datoms[0].v.kind .String))
        (t.is (= attr-datoms[0].v.text "item-301"))
        (t.is entity-attr-datoms-ok)
        (t.is (= entity-attr-datoms-error ""))
        (t.is (= (count entity-attr-datoms) 1))
        (t.is (= entity-attr-datoms[0].e 301))
        (t.is (= entity-attr-datoms[0].a ":item/name"))
        (t.is (= entity-attr-datoms[0].v.kind .String))
        (t.is (= entity-attr-datoms[0].v.text "item-301"))
        (t.is source-attr-ok)
        (t.is (= source-attr-error ""))
        (t.is (= (count source-attr-datoms) 1))
        (t.is (= source-attr-datoms[0].e 301))
        (t.is (= source-attr-datoms[0].a ":item/name"))
        (t.is source-entity-attr-ok)
        (t.is (= source-entity-attr-error ""))
        (t.is (= (count source-entity-attr-datoms) 1))
        (t.is (= source-entity-attr-datoms[0].e 301))
        (t.is (= source-entity-attr-datoms[0].a ":item/name"))
        (t.is source-pull-ok)
        (t.is (= source-pull-error ""))
        (t.is (= source-pull.kind .Map))
        (t.is (= (count source-pull.items) 4))
        (t.is (= source-pull.items[0].kind .Keyword))
        (t.is (= source-pull.items[0].text ":db/id"))
        (t.is (= source-pull.items[1].kind .Entity))
        (t.is (= source-pull.items[1].entity 301))
        (t.is (= source-pull.items[2].kind .Keyword))
        (t.is (= source-pull.items[2].text ":item/name"))
        (t.is (= source-pull.items[3].kind .String))
        (t.is (= source-pull.items[3].text "item-301"))
        (t.is source-query-by-attr.ok)
        (t.is (= source-query-by-attr.error ""))
        (t.is (= (count source-query-by-attr.rows) 1))
        (t.is (= (count source-query-by-attr.rows[0].values) 1))
        (t.is (= source-query-by-attr.rows[0].values[0].kind .Entity))
        (t.is (= source-query-by-attr.rows[0].values[0].entity 301))
        (t.is source-query-by-entity-attr.ok)
        (t.is (= source-query-by-entity-attr.error ""))
        (t.is (= (count source-query-by-entity-attr.rows) 1))
        (t.is (= source-query-by-entity-attr.rows[0].values[0].kind .String))
        (t.is (= source-query-by-entity-attr.rows[0].values[0].text "item-301"))
        (vev.delete-owned-datom db-snapshot-datom)
        (vev.delete-owned-datoms entity-datoms)
        (vev.delete-owned-datoms attr-datoms)
        (vev.delete-owned-datoms entity-attr-datoms)
        (vev.delete-owned-datoms source-attr-datoms)
        (vev.delete-owned-datoms source-entity-attr-datoms)
        (vev.delete-owned-value source-pull)
        (vev.delete-result-set-shallow source-query-by-attr)
        (vev.delete-result-set-shallow source-query-by-entity-attr))
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (int-slices-equal? (slice reopened.db.eavt 0) (slice db.eavt 0)))
      (t.is (int-slices-equal? (slice reopened.db.aevt 0) (slice db.aevt 0)))
      (delete loaded-eavt)
      (delete loaded-aevt)
      (delete eavt-page-first)
      (delete eavt-page-cross)
      (delete eavt-page-tail)
      (vev.close-sqlite-index-cursor! (addr cursor))
      (vev.close-sqlite-index-snapshot! (addr snapshot))
      (vev.close-sqlite-db-snapshot! (addr db-snapshot))
      (vev.delete-owned-db reopened.db)
      (delete reopened.listeners)
      (vev.delete-owned-db db))))

(t.deftest sqlite-db-read-source-filters-retracted-datoms
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-source.sqlite")
  (let [path "tmp.vev.storage-architecture-source.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\"} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\"}]")
        retract-report (vev.transact-sqlite-text
                         (addr store)
                         "[[:db/retract 2 :user/email \"grace@example.com\"]]")
        [snapshot snapshot-ok snapshot-error] (vev.sqlite-conn-open-db-snapshot (addr store) 32)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is retract-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (let [source (vev.sqlite-db-read-source (addr snapshot))
          [emails emails-ok emails-error] (vev.db-read-source-datoms-by-attr source ":user/email")
          [ada-email ada-ok ada-error] (vev.db-read-source-datoms-by-entity-attr source 1 ":user/email")
          [grace-email grace-ok grace-error] (vev.db-read-source-datoms-by-entity-attr source 2 ":user/email")]
      (t.is emails-ok)
      (t.is (= emails-error ""))
      (t.is (= (count emails) 1))
      (t.is (= emails[0].e 1))
      (t.is (= emails[0].v.kind .String))
      (t.is (= emails[0].v.text "ada@example.com"))
      (t.is ada-ok)
      (t.is (= ada-error ""))
      (t.is (= (count ada-email) 1))
      (t.is (= ada-email[0].e 1))
      (t.is grace-ok)
      (t.is (= grace-error ""))
      (t.is (= (count grace-email) 0))
      (vev.delete-owned-datoms emails)
      (vev.delete-owned-datoms ada-email)
      (vev.delete-owned-datoms grace-email))
    (vev.close-sqlite-db-snapshot! (addr snapshot))
    (vev.close-sqlite-conn store)))
