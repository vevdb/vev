      (t.is (= reopened-error ""))
      (t.is (int-slices-equal? (slice reopened.db.eavt 0) (slice db.eavt 0)))
      (t.is (int-slices-equal? (slice reopened.db.aevt 0) (slice db.aevt 0)))
      (delete loaded-eavt)
      (delete loaded-aevt)
      (delete eavt-page-first)
      (delete eavt-page-cross)
      (delete eavt-page-tail)
      (vev.close-sqlite-index-cursor! (addr cursor))
      (vev.close-sqlite-index-snapshot! (addr snapshot))
      (vev.close-sqlite-db-snapshot! (addr db-snapshot))
      (vev.delete-owned-db reopened.db)
      (delete reopened.listeners)
      (vev.delete-owned-db db))))

(t.deftest store-db-source-single-clause-aggregates-use-current-facts
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-source-aggregates.sqlite")
  (let [path "tmp.vev.storage-architecture-source-aggregates.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\" :user/age 37} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\" :user/age 41}]")
        retract-report (vev.transact-sqlite-text
                         (addr store)
                         "[[:db/retract 2 :user/email \"grace@example.com\"]]")
        [source-store source-store-ok source-store-error] (vev.open-store-read-only path)
        [source-store-db source-store-db-ok source-store-db-error] (vev.store-db (addr source-store))
        aggregate-result (vev.q-result-store-db-text (addr source-store-db) "[:find (count ?name) (count-distinct ?name) :with ?e :where [?e :user/name ?name]]")
        profiled-aggregate-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find (count ?name) (count-distinct ?name) :with ?e :where [?e :user/name ?name]]")
        grouped-count-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (count ?e) :where [?e :user/age ?age]]")
        profiled-grouped-count-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?age (count ?e) :where [?e :user/age ?age]]")
        grouped-count-distinct-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (count-distinct ?e) :where [?e :user/age ?age]]")
        grouped-min-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (min ?age) :where [?e :user/age ?age]]")
        grouped-max-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (max ?age) :where [?e :user/age ?age]]")
        grouped-sum-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (sum ?age) :where [?e :user/age ?age]]")
        grouped-avg-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (avg ?age) :where [?e :user/age ?age]]")
        grouped-top-max-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (max 1 ?age) :where [?e :user/age ?age]]")
        profiled-grouped-top-max-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?age (max 1 ?age) :where [?e :user/age ?age]]")
        grouped-top-min-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?age (min 1 ?age) :where [?e :user/age ?age]]")
        current-result (vev.q-result-store-db-text (addr source-store-db) "[:find (count ?email) :with ?e :where [?e :user/email ?email]]")
        min-max-result (vev.q-result-store-db-text (addr source-store-db) "[:find (max ?age) (min ?age) :where [?e :user/age ?age]]")
        profiled-min-max-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find (max ?age) (min ?age) :where [?e :user/age ?age]]")
        top-n-result (vev.q-result-store-db-text (addr source-store-db) "[:find (max 1 ?age) (min 1 ?age) :where [?e :user/age ?age]]")
        profiled-top-n-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find (max 1 ?age) (min 1 ?age) :where [?e :user/age ?age]]")
        all-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?a ?v :where [?e ?a ?v]]")
        fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name :where [1 :user/name ?name]]")
        retracted-fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?email :where [2 :user/email ?email]]")
        attr-value-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/name \"Ada\"]]")
        retracted-attr-value-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/email \"grace@example.com\"]]")
        attr-value-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name :where [?e :user/name ?name]]")
        retracted-attr-value-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?email :where [?e :user/email ?email]]")
        attr-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/name ?name]]")
        retracted-attr-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/email ?email]]")
        fixed-entity-star-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?a ?v :where [1 ?a ?v]]")
        retracted-fixed-entity-star-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?a ?v :where [2 ?a ?v]]")
        profiled-direct-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name :where [?e :user/name ?name]]")
        profiled-filtered-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
        profiled-range-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?age :where [?e :user/age ?age] [(> ?age 37)]]")
        profiled-upper-range-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?age :where [?e :user/age ?age] [(<= ?age 37)]]")
        profiled-inverted-range-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?age :where [?e :user/age ?age] [(< 38 ?age)]]")
        profiled-range-join-result (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name :where [?e :user/age ?age] [(> ?age 37)] [?e :user/name ?name]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (t.is report.ok report.error)
    (t.is retract-report.ok retract-report.error)
    (t.is source-store-ok source-store-error)
    (t.is (= source-store-error ""))
    (t.is source-store-db-ok source-store-db-error)
    (t.is (= source-store-db-error ""))
    (t.is aggregate-result.result.ok aggregate-result.result.error)
    (t.is (= aggregate-result.result.error ""))
    (t.is (= (count aggregate-result.result.rows) 1))
    (t.is (= (count aggregate-result.result.rows[0].values) 2))
    (t.is (= aggregate-result.result.rows[0].values[0].kind .Int))
    (t.is (= aggregate-result.result.rows[0].values[0].int-value 2))
    (t.is (= aggregate-result.result.rows[0].values[1].kind .Int))
    (t.is (= aggregate-result.result.rows[0].values[1].int-value 2))
    (t.is profiled-aggregate-result.result.ok profiled-aggregate-result.result.error)
    (t.is (= (count profiled-aggregate-result.result.rows) 1))
    (t.is (> profiled-aggregate-result.stats.source-operators 0))
    (t.is (= profiled-aggregate-result.stats.generic-materialization-steps 0))
    (t.is grouped-count-result.result.ok grouped-count-result.result.error)
    (t.is (= grouped-count-result.result.error ""))
    (t.is (= (count grouped-count-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-count-result.result 37 1))
    (t.is (result-has-int-int-row? grouped-count-result.result 41 1))
    (t.is profiled-grouped-count-result.result.ok profiled-grouped-count-result.result.error)
    (t.is (= (count profiled-grouped-count-result.result.rows) 2))
    (t.is (> profiled-grouped-count-result.stats.source-operators 0))
    (t.is (= profiled-grouped-count-result.stats.generic-materialization-steps 0))
    (t.is grouped-count-distinct-result.result.ok grouped-count-distinct-result.result.error)
    (t.is (= (count grouped-count-distinct-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-count-distinct-result.result 37 1))
    (t.is (result-has-int-int-row? grouped-count-distinct-result.result 41 1))
    (t.is grouped-min-result.result.ok grouped-min-result.result.error)
    (t.is (= (count grouped-min-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-min-result.result 37 37))
    (t.is (result-has-int-int-row? grouped-min-result.result 41 41))
    (t.is grouped-max-result.result.ok grouped-max-result.result.error)
    (t.is (= (count grouped-max-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-max-result.result 37 37))
    (t.is (result-has-int-int-row? grouped-max-result.result 41 41))
    (t.is grouped-sum-result.result.ok grouped-sum-result.result.error)
    (t.is (= (count grouped-sum-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-sum-result.result 37 37))
    (t.is (result-has-int-int-row? grouped-sum-result.result 41 41))
    (t.is grouped-avg-result.result.ok grouped-avg-result.result.error)
    (t.is (= (count grouped-avg-result.result.rows) 2))
    (t.is (result-has-int-int-row? grouped-avg-result.result 37 37))
    (t.is (result-has-int-int-row? grouped-avg-result.result 41 41))
    (t.is grouped-top-max-result.result.ok grouped-top-max-result.result.error)
    (t.is (= (count grouped-top-max-result.result.rows) 2))
    (t.is (result-has-int-int-vector-row? grouped-top-max-result.result 37 37))
    (t.is (result-has-int-int-vector-row? grouped-top-max-result.result 41 41))
    (t.is profiled-grouped-top-max-result.result.ok profiled-grouped-top-max-result.result.error)
    (t.is (= (count profiled-grouped-top-max-result.result.rows) 2))
    (t.is (> profiled-grouped-top-max-result.stats.source-operators 0))
    (t.is (= profiled-grouped-top-max-result.stats.generic-materialization-steps 0))
    (t.is grouped-top-min-result.result.ok grouped-top-min-result.result.error)
    (t.is (= (count grouped-top-min-result.result.rows) 2))
    (t.is (result-has-int-int-vector-row? grouped-top-min-result.result 37 37))
    (t.is (result-has-int-int-vector-row? grouped-top-min-result.result 41 41))
    (t.is current-result.result.ok current-result.result.error)
    (t.is (= current-result.result.error ""))
    (t.is (= (count current-result.result.rows) 1))
    (t.is (= (count current-result.result.rows[0].values) 1))
    (t.is (= current-result.result.rows[0].values[0].kind .Int))
    (t.is (= current-result.result.rows[0].values[0].int-value 1))
    (t.is min-max-result.result.ok min-max-result.result.error)
    (t.is (= min-max-result.result.error ""))
    (t.is (= (count min-max-result.result.rows) 1))
    (t.is (= min-max-result.result.rows[0].values[0].kind .Int))
    (t.is (= min-max-result.result.rows[0].values[1].kind .Int))
    (t.is (= min-max-result.result.rows[0].values[0].int-value 41))
    (t.is (= min-max-result.result.rows[0].values[1].int-value 37))
    (t.is profiled-min-max-result.result.ok profiled-min-max-result.result.error)
    (t.is (= (count profiled-min-max-result.result.rows) 1))
    (t.is (> profiled-min-max-result.stats.source-operators 0))
    (t.is (= profiled-min-max-result.stats.generic-materialization-steps 0))
    (t.is top-n-result.result.ok top-n-result.result.error)
    (t.is (= top-n-result.result.error ""))
    (t.is (= (count top-n-result.result.rows) 1))
    (t.is (= top-n-result.result.rows[0].values[0].kind .Vector))
    (t.is (= top-n-result.result.rows[0].values[1].kind .Vector))
    (t.is (= (count top-n-result.result.rows[0].values[0].items) 1))
    (t.is (= (count top-n-result.result.rows[0].values[1].items) 1))
    (t.is (= top-n-result.result.rows[0].values[0].items[0].int-value 41))
    (t.is (= top-n-result.result.rows[0].values[1].items[0].int-value 37))
    (t.is profiled-top-n-result.result.ok profiled-top-n-result.result.error)
    (t.is (= (count profiled-top-n-result.result.rows) 1))
    (t.is (> profiled-top-n-result.stats.source-operators 0))
    (t.is (= profiled-top-n-result.stats.generic-materialization-steps 0))
    (t.is all-attr-result.result.ok all-attr-result.result.error)
    (t.is (= all-attr-result.result.error ""))
    (let [has-ada-name false
          has-grace-age false
          has-retracted-grace-email false]
      (for [row all-attr-result.result.rows]
        (when (= (count row.values) 3)
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 1)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/name")
                     (= row.values[2].kind .String)
                     (= row.values[2].text "Ada"))
            (set! has-ada-name true))
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 2)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/age")
                     (= row.values[2].kind .Int)
                     (= row.values[2].int-value 41))
            (set! has-grace-age true))
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 2)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/email")
                     (= row.values[2].kind .String)
                     (= row.values[2].text "grace@example.com"))
            (set! has-retracted-grace-email true))))
      (t.is has-ada-name)
      (t.is has-grace-age)
      (t.is (not has-retracted-grace-email)))
    (t.is fixed-entity-result.result.ok fixed-entity-result.result.error)
    (t.is (= fixed-entity-result.result.error ""))
    (t.is (= (count fixed-entity-result.result.rows) 1))
    (t.is (= fixed-entity-result.result.rows[0].values[0].kind .String))
    (t.is (= fixed-entity-result.result.rows[0].values[0].text "Ada"))
    (t.is retracted-fixed-entity-result.result.ok retracted-fixed-entity-result.result.error)
    (t.is (= retracted-fixed-entity-result.result.error ""))
    (t.is (= (count retracted-fixed-entity-result.result.rows) 0))
    (t.is attr-value-entity-result.result.ok attr-value-entity-result.result.error)
    (t.is (= attr-value-entity-result.result.error ""))
    (t.is (= (count attr-value-entity-result.result.rows) 1))
    (t.is (= attr-value-entity-result.result.rows[0].values[0].kind .Entity))
    (t.is (= attr-value-entity-result.result.rows[0].values[0].entity 1))
    (t.is retracted-attr-value-entity-result.result.ok retracted-attr-value-entity-result.result.error)
    (t.is (= retracted-attr-value-entity-result.result.error ""))
    (t.is (= (count retracted-attr-value-entity-result.result.rows) 0))
    (t.is attr-value-result.result.ok attr-value-result.result.error)
    (t.is (= attr-value-result.result.error ""))
    (t.is (= (count attr-value-result.result.rows) 2))
    (let [has-ada false
          has-grace false]
      (for [row attr-value-result.result.rows]
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .String)
                   (= row.values[0].text "Ada"))
          (set! has-ada true))
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .String)
                   (= row.values[0].text "Grace"))
          (set! has-grace true)))
      (t.is has-ada)
      (t.is has-grace))
    (t.is retracted-attr-value-result.result.ok retracted-attr-value-result.result.error)
    (t.is (= retracted-attr-value-result.result.error ""))
    (t.is (= (count retracted-attr-value-result.result.rows) 1))
    (t.is (= retracted-attr-value-result.result.rows[0].values[0].kind .String))
    (t.is (= retracted-attr-value-result.result.rows[0].values[0].text "ada@example.com"))
    (t.is attr-entity-result.result.ok attr-entity-result.result.error)
    (t.is (= attr-entity-result.result.error ""))
    (t.is (= (count attr-entity-result.result.rows) 2))
    (let [has-ada-entity false
          has-grace-entity false]
      (for [row attr-entity-result.result.rows]
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .Entity)
                   (= row.values[0].entity 1))
          (set! has-ada-entity true))
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .Entity)
                   (= row.values[0].entity 2))
          (set! has-grace-entity true)))
      (t.is has-ada-entity)
      (t.is has-grace-entity))
    (t.is retracted-attr-entity-result.result.ok retracted-attr-entity-result.result.error)
    (t.is (= retracted-attr-entity-result.result.error ""))
    (t.is (= (count retracted-attr-entity-result.result.rows) 1))
    (t.is (= retracted-attr-entity-result.result.rows[0].values[0].kind .Entity))
    (t.is (= retracted-attr-entity-result.result.rows[0].values[0].entity 1))
    (t.is fixed-entity-star-result.result.ok fixed-entity-star-result.result.error)
    (t.is (= fixed-entity-star-result.result.error ""))
    (let [has-ada-name false
          has-ada-email false
          has-ada-age false]
      (for [row fixed-entity-star-result.result.rows]
        (when (= (count row.values) 2)
          (when (and (= row.values[0].kind .Keyword)
                     (= row.values[0].text ":user/name")
                     (= row.values[1].kind .String)
                     (= row.values[1].text "Ada"))
            (set! has-ada-name true))
          (when (and (= row.values[0].kind .Keyword)
                     (= row.values[0].text ":user/email")
                     (= row.values[1].kind .String)
                     (= row.values[1].text "ada@example.com"))
            (set! has-ada-email true))
          (when (and (= row.values[0].kind .Keyword)
                     (= row.values[0].text ":user/age")
                     (= row.values[1].kind .Int)
                     (= row.values[1].int-value 37))
            (set! has-ada-age true))))
      (t.is has-ada-name)
      (t.is has-ada-email)
      (t.is has-ada-age))
    (t.is retracted-fixed-entity-star-result.result.ok retracted-fixed-entity-star-result.result.error)
    (t.is (= retracted-fixed-entity-star-result.result.error ""))
    (let [has-grace-email false]
      (for [row retracted-fixed-entity-star-result.result.rows]
        (when (and (= (count row.values) 2)
                   (= row.values[0].kind .Keyword)
                   (= row.values[0].text ":user/email")
                   (= row.values[1].kind .String)
                   (= row.values[1].text "grace@example.com"))
          (set! has-grace-email true)))
      (t.is (not has-grace-email)))
    (t.is profiled-direct-result.result.ok profiled-direct-result.result.error)
    (t.is (= (count profiled-direct-result.result.rows) 2))
    (t.is (= profiled-direct-result.stats.clauses 1))
    (t.is (= profiled-direct-result.stats.output-rows 2))
    (t.is (> profiled-direct-result.stats.source-index-scans 0))
    (t.is (> profiled-direct-result.stats.source-operators 0))
    (t.is (= profiled-direct-result.stats.binding-materializations 0))
    (t.is (= profiled-direct-result.stats.generic-materialization-steps 0))
    (t.is profiled-filtered-result.result.ok profiled-filtered-result.result.error)
    (t.is (= (count profiled-filtered-result.result.rows) 1))
    (t.is (= profiled-filtered-result.stats.clauses 1))
    (t.is (= profiled-filtered-result.stats.output-rows 1))
    (t.is (> profiled-filtered-result.stats.source-index-scans 0))
    (t.is (= profiled-filtered-result.stats.binding-materializations 0))
    (t.is profiled-range-result.result.ok profiled-range-result.result.error)
    (t.is (= (count profiled-range-result.result.rows) 1))
    (t.is (= profiled-range-result.result.rows[0].values[0].kind .Int))
    (t.is (= profiled-range-result.result.rows[0].values[0].int-value 41))
    (t.is (= profiled-range-result.stats.clauses 1))
    (t.is (= profiled-range-result.stats.output-rows 1))
    (t.is (> profiled-range-result.stats.source-index-scans 0))
    (t.is (= profiled-range-result.stats.binding-materializations 0))
    (t.is profiled-upper-range-result.result.ok profiled-upper-range-result.result.error)
    (t.is (= (count profiled-upper-range-result.result.rows) 1))
    (t.is (= profiled-upper-range-result.result.rows[0].values[0].kind .Int))
    (t.is (= profiled-upper-range-result.result.rows[0].values[0].int-value 37))
    (t.is (= profiled-upper-range-result.stats.clauses 1))
    (t.is (= profiled-upper-range-result.stats.output-rows 1))
    (t.is (> profiled-upper-range-result.stats.source-index-scans 0))
    (t.is (= profiled-upper-range-result.stats.binding-materializations 0))
    (t.is profiled-inverted-range-result.result.ok profiled-inverted-range-result.result.error)
    (t.is (= (count profiled-inverted-range-result.result.rows) 1))
    (t.is (= profiled-inverted-range-result.result.rows[0].values[0].kind .Int))
    (t.is (= profiled-inverted-range-result.result.rows[0].values[0].int-value 41))
    (t.is (= profiled-inverted-range-result.stats.clauses 1))
    (t.is (= profiled-inverted-range-result.stats.output-rows 1))
    (t.is (> profiled-inverted-range-result.stats.source-index-scans 0))
    (t.is (= profiled-inverted-range-result.stats.binding-materializations 0))
    (t.is profiled-range-join-result.result.ok profiled-range-join-result.result.error)
    (t.is (= (count profiled-range-join-result.result.rows) 1))
    (t.is (= profiled-range-join-result.result.rows[0].values[0].kind .String))
    (t.is (= profiled-range-join-result.result.rows[0].values[0].text "Grace"))
    (t.is (= profiled-range-join-result.stats.clauses 2))
    (t.is (= profiled-range-join-result.stats.output-rows 1))
    (t.is (> profiled-range-join-result.stats.source-index-scans 0))
    (t.is (> profiled-range-join-result.stats.source-operators 0))
    (t.is (= profiled-range-join-result.stats.binding-materializations 0))
    (t.is (= profiled-range-join-result.stats.generic-materialization-steps 0))
    (vev.delete-query-result aggregate-result)
    (vev.delete-profiled-result-set-owned-values profiled-aggregate-result)
    (vev.delete-query-result grouped-count-result)
    (vev.delete-profiled-result-set-owned-values profiled-grouped-count-result)
    (vev.delete-query-result grouped-count-distinct-result)
    (vev.delete-query-result grouped-min-result)
    (vev.delete-query-result grouped-max-result)
    (vev.delete-query-result grouped-sum-result)
    (vev.delete-query-result grouped-avg-result)
    (vev.delete-query-result grouped-top-max-result)
    (vev.delete-profiled-result-set-owned-values profiled-grouped-top-max-result)
    (vev.delete-query-result grouped-top-min-result)
    (vev.delete-query-result current-result)
    (vev.delete-query-result min-max-result)
    (vev.delete-profiled-result-set-owned-values profiled-min-max-result)
    (vev.delete-query-result top-n-result)
    (vev.delete-profiled-result-set-owned-values profiled-top-n-result)
    (vev.delete-query-result all-attr-result)
    (vev.delete-query-result fixed-entity-result)
    (vev.delete-query-result retracted-fixed-entity-result)
    (vev.delete-query-result attr-value-entity-result)
    (vev.delete-query-result retracted-attr-value-entity-result)
    (vev.delete-query-result attr-value-result)
    (vev.delete-query-result retracted-attr-value-result)
    (vev.delete-query-result attr-entity-result)
    (vev.delete-query-result retracted-attr-entity-result)
    (vev.delete-query-result fixed-entity-star-result)
    (vev.delete-query-result retracted-fixed-entity-star-result)
    (vev.delete-profiled-result-set-owned-values profiled-direct-result)
    (vev.delete-profiled-result-set-owned-values profiled-filtered-result)
    (vev.delete-profiled-result-set-owned-values profiled-range-result)
    (vev.delete-profiled-result-set-owned-values profiled-upper-range-result)
    (vev.delete-profiled-result-set-owned-values profiled-inverted-range-result)
    (vev.delete-profiled-result-set-owned-values profiled-range-join-result)
    (vev.close-store-db! (addr source-store-db))
    (vev.close-store source-store)
    (vev.delete-tx-report-shallow report)
    (vev.delete-tx-report-shallow retract-report)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-db-read-source-filters-retracted-datoms
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-source.sqlite")
  (let [path "tmp.vev.storage-architecture-source.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/email-name :db/valueType :db.type/tuple :db/tupleAttrs [:user/email :user/name] :db/unique :db.unique/identity} {:db/id 102 :db/ident :user/friend :db/valueType :db.type/ref} {:db/id 103 :db/ident :user/friend-code :db/valueType :db.type/tuple :db/tupleAttrs [:user/friend :user/code] :db/unique :db.unique/identity} {:db/id 104 :db/ident :user/code} {:db/id 105 :db/ident :user/tag :db/cardinality :db.cardinality/many} {:db/id 106 :db/ident :node/name :db/valueType :db.type/string} {:db/id 107 :db/ident :node/anchor :db/valueType :db.type/ref} {:db/id 108 :db/ident :node/next :db/valueType :db.type/ref} {:db/id 109 :db/ident :node/ref :db/valueType :db.type/ref} {:db/id 110 :db/ident :node/score :db/valueType :db.type/long} {:db/id 1 :user/name \"Ada\" :user/age 37 :user/email \"ada@example.com\"} {:db/id 2 :user/name \"Grace\" :user/age 41 :user/email \"grace@example.com\" :user/code \"grace-code\" :user/friend 1 :user/tag [\"admin\" \"lead\"]} {:db/id 10 :node/name \"Anchor\"} {:db/id 11 :node/name \"Branch\" :node/score 41 :node/anchor 10 :node/next 12} {:db/id 12 :node/name \"Middle\" :node/ref 13} {:db/id 13 :node/name \"Leaf\" :node/anchor 10}]")
        retract-report (vev.transact-sqlite-text
                         (addr store)
                         "[[:db/retract 2 :user/email \"grace@example.com\"]]")
        [snapshot snapshot-ok snapshot-error] (vev.sqlite-conn-open-db-snapshot (addr store) 32)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is retract-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (let [source (vev.sqlite-db-read-source (addr snapshot))
          [emails emails-ok emails-error] (vev.db-read-source-datoms-by-attr source ":user/email")
          [ada-email ada-ok ada-error] (vev.db-read-source-datoms-by-entity-attr source 1 ":user/email")
          [grace-email grace-ok grace-error] (vev.db-read-source-datoms-by-entity-attr source 2 ":user/email")
          [ada-range-low ada-range-high ada-range-exists ada-range-ok ada-range-error] (vev.db-read-source-eavt-entity-range source 1)
          [ada-name-value ada-name-value-ok ada-name-value-error] (vev.db-read-source-cardinality-one-value-fast-all-current source 1 ":user/name")
          [ada-age-value ada-age-value-ok ada-age-value-error] (vev.db-read-source-cardinality-one-int-value-fast-all-current source 1 ":user/age")
          [ada-name-matches ada-name-matches-ok ada-name-matches-error] (vev.db-read-source-cardinality-one-value-matches-fast-all-current? source 1 ":user/name" (vev.value-string "Ada"))
          prepared (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
          prepared-input (vev.prepare-query-text "[:find ?name :in $ ?email :where [?e :user/email ?email] [?e :user/name ?name]]")
          durable-text-result (vev.q-result-sqlite-conn-text (addr store) "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
          durable-prepared-result (vev.q-result-sqlite-conn-prepared (addr store) prepared)
          durable-input-result (vev.q-result-sqlite-conn-text-with-input-text (addr store) "[:find ?name :in $ ?email :where [?e :user/email ?email] [?e :user/name ?name]]" "[\"ada@example.com\"]")
          durable-prepared-input-result (vev.q-result-sqlite-conn-prepared-with-input-text (addr store) prepared-input "[\"ada@example.com\"]")
          durable-pull-result (vev.q-result-sqlite-conn-text (addr store) "[:find (pull ?e [:user/name]) :where [?e :user/email \"ada@example.com\"]]")
          durable-aggregate-result (vev.q-result-sqlite-conn-text (addr store) "[:find (count ?e) :where [?e :user/name ?name]]")
          [source-store source-store-ok source-store-error] (vev.open-store-read-only path)
          source-only-result (vev.q-result-store-prepared (addr source-store) prepared)
          source-only-input-result (vev.q-result-store-text-with-input-text (addr source-store) "[:find ?name :in $ ?email :where [?e :user/email ?email] [?e :user/name ?name]]" "[\"ada@example.com\"]")
          source-only-prepared-input-result (vev.q-result-store-prepared-with-input-text (addr source-store) prepared-input "[\"ada@example.com\"]")
          [source-store-db source-store-db-ok source-store-db-error] (vev.store-db (addr source-store))
          source-store-db-result (vev.q-result-store-db-prepared (addr source-store-db) prepared)
          source-store-db-one-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/name ?name]]")
          source-store-db-filtered-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/email \"ada@example.com\"] [?e :user/name ?name]]")
          source-store-db-filtered-retracted-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/email \"grace@example.com\"] [?e :user/name ?name]]")
          source-store-db-fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [1 :user/name ?name] [1 :user/age ?age]]")
          source-store-db-fixed-entity-missing-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [9 :user/name ?name] [9 :user/age ?age]]")
          source-store-db-two-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]")
          source-store-db-selective-two-attr-profiled (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name ?email :where [?e :user/name ?name] [?e :user/email ?email]]")
          source-store-db-value-ref-attr-profiled (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name :where [?friend :user/name \"Ada\"] [?e :user/friend ?friend] [?e :user/name ?name]]")
          source-store-db-value-ref-attr-input-profiled (vev.q-profiled-store-db-text-with-input-text (addr source-store-db) "[:find ?name :in $ ?friend-name :where [?friend :user/name ?friend-name] [?e :user/friend ?friend] [?e :user/name ?name]]" "[\"Ada\"]")
          source-store-db-value-ref-star-profiled (vev.q-profiled-store-db-text (addr source-store-db) "[:find ?name ?age ?tag :where [?friend :user/name \"Ada\"] [?e :user/friend ?friend] [?e :user/name ?name] [?e :user/age ?age] [?e :user/tag ?tag]]")
          source-store-db-value-ref-star-input-profiled (vev.q-profiled-store-db-text-with-input-text (addr source-store-db) "[:find ?name ?age ?tag :in $ ?friend-name :where [?friend :user/name ?friend-name] [?e :user/friend ?friend] [?e :user/name ?name] [?e :user/age ?age] [?e :user/tag ?tag]]" "[\"Ada\"]")
          source-store-db-multi-hop-input-profiled (vev.q-profiled-store-db-text-with-input-text (addr source-store-db) "[:find ?name ?score ?leaf-name :in $ ?anchor-name :where [?anchor :node/name ?anchor-name] [?e :node/anchor ?anchor] [?e :node/score ?score] [(> ?score 40)] [?e :node/name ?name] [?e :node/next ?mid] [?mid :node/ref ?leaf] [?leaf :node/name ?leaf-name]]" "[\"Anchor\"]")
          source-store-db-multi-hop-shuffled-input-profiled (vev.q-profiled-store-db-text-with-input-text (addr source-store-db) "[:find ?name ?score ?leaf-name :in $ ?anchor-name :where [?e :node/name ?name] [?mid :node/ref ?leaf] [(> ?score 40)] [?anchor :node/name ?anchor-name] [?leaf :node/name ?leaf-name] [?e :node/next ?mid] [?e :node/score ?score] [?e :node/anchor ?anchor]]" "[\"Anchor\"]")
          source-store-db-two-branch-input-profiled (vev.q-profiled-store-db-text-with-input-text (addr source-store-db) "[:find ?name ?score ?leaf-name :in $ ?anchor-name :where [?anchor :node/name ?anchor-name] [?leaf :node/anchor ?anchor] [?leaf :node/name ?leaf-name] [?e :node/anchor ?anchor] [?e :node/score ?score] [(> ?score 40)] [?e :node/name ?name] [?e :node/next ?mid] [?mid :node/ref ?leaf]]" "[\"Anchor\"]")
