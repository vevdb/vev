(t.deftest sqlite-store-with-report-overlay-keeps-retraction-tx-data
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-retract.sqlite")
  (let [path "tmp.vev.store-with-report-retract.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text (addr snapshot) "[[:db/add 1 :user/name \"Ada Lovelace\"]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [1 :user/name ?name]]")
          saw-retract false
          saw-add false]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is report.ok report.error)
      (for [datom report.tx-data]
        (when (and (= datom.a ":user/name")
                   (= datom.v.kind .String)
                   (= datom.v.text "Ada")
                   (not datom.added))
          (set! saw-retract true))
        (when (and (= datom.a ":user/name")
                   (= datom.v.kind .String)
                   (= datom.v.text "Ada Lovelace")
                   datom.added)
          (set! saw-add true)))
      (t.is saw-retract)
      (t.is saw-add)
      (t.is after-result.result.ok)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (result-has-string-row? after-result.result "Ada Lovelace"))
      (vev.delete-query-result after-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-retain-keeps-original-basis-after-writer-advances
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-retain-basis.sqlite")
  (let [path "tmp.vev.store-db-retain-basis.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        first-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        second-report (vev.transact-store-text (addr store) "[{:db/id 2 :user/name \"Grace\"}]")
        retained (vev.retain-store-db snapshot)
        old-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
        retained-result (vev.q-result-store-db-text (addr retained) "[:find ?name :where [?e :user/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is first-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .SQLite-Snapshot))
    (t.is second-report.ok)
    (t.is (= retained.kind .SQLite-Snapshot))
    (t.is old-result.result.ok)
    (t.is (= (count old-result.result.rows) 1))
    (t.is (result-has-string-row? old-result.result "Ada"))
    (t.is (not (result-has-string-row? old-result.result "Grace")))
    (t.is retained-result.result.ok)
    (t.is (= (count retained-result.result.rows) 1))
    (t.is (result-has-string-row? retained-result.result "Ada"))
    (t.is (not (result-has-string-row? retained-result.result "Grace")))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 2))
    (t.is (result-has-string-row? live-result.result "Ada"))
    (t.is (result-has-string-row? live-result.result "Grace"))
    (vev.delete-query-result old-result)
    (vev.delete-query-result retained-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr retained))
    (vev.close-store store)
    (vev.delete-tx-report-shallow first-report)
    (vev.delete-tx-report-shallow second-report)))

(t.deftest sqlite-store-report-retained-db-values-survive-later-commits
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-retained-db-values.sqlite")
  (let [path "tmp.vev.store-report-retained-db-values.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        first-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        first-after (vev.retain-store-db first-report.db-after)
        second-report (vev.transact-store-report-text (addr store) "[{:db/id 2 :user/name \"Grace\"}]")
        second-before (vev.retain-store-db second-report.db-before)
        second-after (vev.retain-store-db second-report.db-after)
        third-report (vev.transact-store-report-text (addr store) "[{:db/id 3 :user/name \"Hedy\"}]")
        first-after-result (vev.q-result-store-db-text (addr first-after) "[:find ?name :where [?e :user/name ?name]]")
        second-before-result (vev.q-result-store-db-text (addr second-before) "[:find ?name :where [?e :user/name ?name]]")
        second-after-result (vev.q-result-store-db-text (addr second-after) "[:find ?name :where [?e :user/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is first-report.ok first-report.error)
    (t.is second-report.ok second-report.error)
    (t.is third-report.ok third-report.error)
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (t.is (sqlite-durable-store-db? first-after))
    (t.is (sqlite-durable-store-db? second-before))
    (t.is (sqlite-durable-store-db? second-after))
    (t.is first-after-result.result.ok first-after-result.result.error)
    (t.is (= (count first-after-result.result.rows) 1))
    (t.is (result-has-string-row? first-after-result.result "Ada"))
    (t.is (not (result-has-string-row? first-after-result.result "Grace")))
    (t.is (not (result-has-string-row? first-after-result.result "Hedy")))
    (t.is second-before-result.result.ok second-before-result.result.error)
    (t.is (= (count second-before-result.result.rows) 1))
    (t.is (result-has-string-row? second-before-result.result "Ada"))
    (t.is (not (result-has-string-row? second-before-result.result "Grace")))
    (t.is (not (result-has-string-row? second-before-result.result "Hedy")))
    (t.is second-after-result.result.ok second-after-result.result.error)
    (t.is (= (count second-after-result.result.rows) 2))
    (t.is (result-has-string-row? second-after-result.result "Ada"))
    (t.is (result-has-string-row? second-after-result.result "Grace"))
    (t.is (not (result-has-string-row? second-after-result.result "Hedy")))
    (t.is live-result.result.ok live-result.result.error)
    (t.is (= (count live-result.result.rows) 3))
    (t.is (result-has-string-row? live-result.result "Ada"))
    (t.is (result-has-string-row? live-result.result "Grace"))
    (t.is (result-has-string-row? live-result.result "Hedy"))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (vev.delete-query-result first-after-result)
    (vev.delete-query-result second-before-result)
    (vev.delete-query-result second-after-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr first-after))
    (vev.close-store-db! (addr second-before))
    (vev.close-store-db! (addr second-after))
    (vev.delete-store-tx-report first-report)
    (vev.delete-store-tx-report second-report)
    (vev.delete-store-tx-report third-report)
    (vev.close-store store)))

(t.deftest sqlite-persist-writes-bounded-index-chunks
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-chunks.sqlite")
  (let [path "tmp.vev.storage-architecture-chunks.sqlite"
        datoms (make [dynamic]vev.Datom) :defer]
    (for [i (arr.range 1 301)]
      (arr.push! datoms (vev.datom-tx (u64 i) ":item/value" (vev.value-int (i64 i)) 1 true)))
    (arr.push! datoms (vev.datom-tx 301 ":item/name" (vev.value-string "item-301") 1 true))
    (arr.push! datoms (vev.datom-tx 301 ":name" (vev.value-string "parent-name") 1 true))
    (arr.push! datoms (vev.datom-tx 302 ":item/parent" (vev.value-entity 301) 1 true))
    (arr.push! datoms (vev.datom-tx 303 ":item/parent" (vev.value-entity 301) 1 true))
    (arr.push! datoms (vev.datom-tx 302 ":item/child-name" (vev.value-string "child-302") 1 true))
    (arr.push! datoms (vev.datom-tx 303 ":item/child-name" (vev.value-string "child-303") 1 true))
    (arr.push! datoms (vev.datom-tx 304 ":item/parent" (vev.value-entity 302) 1 true))
    (arr.push! datoms (vev.datom-tx 304 ":item/child-name" (vev.value-string "child-304") 1 true))
    (let [db (vev.init-db (slice datoms 0))
          [saved-ok saved-error] (vev.save-db-sqlite path db)
          [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
          [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
          [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-latest-index-chunk-row-count path ":eavt")
          [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-latest-index-chunk-row-count path ":aevt")
          [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-latest-index-chunk-row-count path ":avet")
          [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
          [loaded-aevt loaded-aevt-ok loaded-aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
          [eavt-page-first eavt-page-first-ok eavt-page-first-error] (vev.sqlite-latest-index-entry-page path ":eavt" 0 128)
          [eavt-page-cross eavt-page-cross-ok eavt-page-cross-error] (vev.sqlite-latest-index-entry-page path ":eavt" 120 32)
          [eavt-page-tail eavt-page-tail-ok eavt-page-tail-error] (vev.sqlite-latest-index-entry-page path ":eavt" 280 64)
          [eavt-page-count eavt-page-count-ok eavt-page-count-error] (vev.sqlite-latest-index-entry-pages-count path ":eavt" 128)
          [cursor cursor-ok cursor-error] (vev.sqlite-open-index-cursor path ":eavt" 64)
          [page-cursor page-cursor-ok page-cursor-error] (vev.sqlite-open-index-cursor path ":eavt" 64)
          [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-index-snapshot path 64)
          [db-snapshot db-snapshot-ok db-snapshot-error] (vev.sqlite-open-db-snapshot path 64)
          [reopened reopened-ok reopened-error] (vev.open-conn-sqlite-resident path)]
      (defer (remove-sqlite-files path))
      (t.is saved-ok)
      (t.is (= saved-error ""))
      (t.is root-count-ok)
      (t.is (= root-count-error ""))
      (t.is (= root-count 1))
      (t.is chunk-count-ok)
      (t.is (= chunk-count-error ""))
