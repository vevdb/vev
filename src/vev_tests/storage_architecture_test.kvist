    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          [configured-ok configured-error] (vev.configure-store-auto-maintenance! (addr reopened) 64 0)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is configured-ok configured-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
