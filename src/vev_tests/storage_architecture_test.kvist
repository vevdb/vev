    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          next-snapshot (vev.db-with-store-db-text (addr snapshot) "[{:db/id 100 :db/ident :user/profile :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 1 :user/profile [{:db/id 10 :profile/email \"a@example.com\"} {:db/id 11 :profile/email \"b@example.com\"}]}]")
          original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?profile :where [1 :user/profile ?profile]]")
          next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?profile ?email :where [1 :user/profile ?profile] [?profile :profile/email ?email]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= snapshot.kind .SQLite-Snapshot))
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is original-result.result.ok)
      (t.is (= (count original-result.result.rows) 0))
      (t.is next-result.result.ok)
      (t.is (= (count next-result.result.rows) 2))
      (t.is (= next-result.result.rows[0].values[0].entity 10))
      (t.is (= next-result.result.rows[0].values[1].text "a@example.com"))
      (t.is (= next-result.result.rows[1].values[0].entity 11))
      (t.is (= next-result.result.rows[1].values[1].text "b@example.com"))
      (vev.delete-query-result original-result)
      (vev.delete-query-result next-result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-with-same-tx-lookup-refs-keeps-source-overlay
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-with-lookup-refs.sqlite")
  (let [path "tmp.vev.store-db-with-lookup-refs.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        opened-report (vev.transact-store-text (addr store) "[{:db/id 900 :store/initialized true}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is opened-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok _] (vev.open-store-read-only path)]
      (t.is read-opened-ok)
      (let [[snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
            next-snapshot (vev.db-with-store-db-text
                            (addr snapshot)
                            "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref} [:db/add [:user/email \"ada@example.com\"] :user/name \"Ada\"] [:db/add 1 :user/friend [:user/email \"grace@example.com\"]] {:db/id 1 :user/email \"ada@example.com\"} {:db/id 2 :user/email \"grace@example.com\"}]")
            name-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?name :where [1 :user/name ?name]]")
            friend-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?friend-email :where [1 :user/friend ?friend] [?friend :user/email ?friend-email]]")
            original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is snapshot-ok)
        (t.is (= snapshot-error ""))
        (delete snapshot-error)
        (t.is (= snapshot.kind .SQLite-Snapshot))
        (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
        (t.is name-result.result.ok)
        (t.is (= (count name-result.result.rows) 1))
        (t.is (= name-result.result.rows[0].values[0].text "Ada"))
        (t.is friend-result.result.ok)
        (t.is (= (count friend-result.result.rows) 1))
        (t.is (= friend-result.result.rows[0].values[0].text "grace@example.com"))
        (t.is original-result.result.ok)
        (t.is (= (count original-result.result.rows) 0))
        (vev.delete-query-result name-result)
        (vev.delete-query-result friend-result)
        (vev.delete-query-result original-result)
        (vev.close-store-db! (addr snapshot))
        (vev.close-store-db! (addr next-snapshot)))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow opened-report)))

