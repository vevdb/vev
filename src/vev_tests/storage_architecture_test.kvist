(defn result-has-string-int-int-int-row? [result: vev.Result-Set, text: string, first: i64, second: i64, third: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 4)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
