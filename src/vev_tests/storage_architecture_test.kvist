                  (and (= triples.entities[1] 1) (= triples.strings[1] "ada@example.test") (= triples.ints[1] 42))))
        (t.is (or (and (= triples.entities[0] 3) (= triples.strings[0] "ada-2@example.test") (= triples.ints[0] 42))
                  (and (= triples.entities[1] 3) (= triples.strings[1] "ada-2@example.test") (= triples.ints[1] 42))))
        (t.is wide-used)
        (t.is wide-rel.has-typed-columns)
        (t.is (= wide-rel.typed-rows 3))
        (t.is (= (count wide-rel.typed-columns) 4))
        (t.is (= wide-stats.binding-materializations 0))
        (t.is (= wide-stats.generic-materialization-steps 0))
        (t.is wide-plan.ok)
        (t.is (= wide-plan.rows 3))
        (t.is (= (count wide-plan.find-indexes) 4))
        (t.is (= wide-plan.column-kinds[0] .Entity))
        (t.is (= wide-plan.column-kinds[1] .String))
        (t.is (= wide-plan.column-kinds[2] .String))
        (t.is (= wide-plan.column-kinds[3] .Int))
        (t.is reverse-used)
        (t.is reverse-rel.has-typed-columns)
        (t.is (= reverse-rel.typed-rows 2))
        (t.is (= reverse-stats.binding-materializations 0))
        (t.is (= reverse-stats.generic-materialization-steps 0))
        (t.is (= reverse-rel.typed-columns[0].kind .Entity))
        (t.is (= reverse-rel.typed-columns[1].kind .Entity))
