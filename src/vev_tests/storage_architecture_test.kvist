(t.deftest sqlite-store-report-direct-write-supports-unique-ref-value-tempid-upsert
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-unique-ref-tempid-upsert.sqlite")
  (let [path "tmp.vev.store-report-direct-unique-ref-tempid-upsert.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        schema (vev.transact-store-text
                 (addr store)
                 "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref :db/unique :db.unique/identity}]")
        seed (vev.transact-store-text (addr store) "[{:db/id 2 :user/email \"grace@example.com\"} {:db/id 1 :user/friend 2}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is schema.ok schema.error)
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow schema)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id \"friend\" :user/email \"grace@example.com\"} {:db/id \"ada\" :user/friend \"friend\" :user/name \"Ada\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?e ?name ?friend :where [?e :user/name ?name] [?e :user/friend ?friend]]")
            [friend-e friend-ok] (vev.tempid-lookup (slice report.tempids 0) "friend")
            [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is friend-ok)
        (t.is (= friend-e 2))
        (t.is ada-ok)
        (t.is (= ada-e 1))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (= result.result.rows[0].values[0].entity 1))
        (t.is (= result.result.rows[0].values[1].text "Ada"))
        (t.is (= result.result.rows[0].values[2].entity 2))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-supports-intermediate-upsert-convergence
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-intermediate-upsert.sqlite")
  (let [path "tmp.vev.store-report-direct-intermediate-upsert.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text
               (addr store)
               "[{:db/id 100 :db/ident :user/name :db/valueType :db.type/string :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id \"igor-1\" :user/name \"Igor\" :user/age 35} {:db/id \"igor-2\" :user/name \"Igor\" :user/age 36}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?age :where [?e :user/name \"Igor\"] [?e :user/age ?age]]")
            [igor-1 igor-1-ok] (vev.tempid-lookup (slice report.tempids 0) "igor-1")
            [igor-2 igor-2-ok] (vev.tempid-lookup (slice report.tempids 0) "igor-2")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is (= (count report.tx-data) 4))
        (t.is igor-1-ok)
        (t.is igor-2-ok)
        (t.is (= igor-1 igor-2))
        (t.is (= report.tx-data[0].e igor-1))
        (t.is (= report.tx-data[1].e igor-1))
        (t.is (= report.tx-data[2].e igor-1))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (= result.result.rows[0].values[0].int-value 36))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

