                     registry)
            live-result (vev.q-result-store-text (addr reopened) "[:find ?age ?adjusted ?label :where [1 :user/age ?age] [1 :user/age-adjusted ?adjusted] [1 :user/label ?label]]")
            before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?age :where [1 :user/age ?age]]")
            after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age ?adjusted ?label :where [1 :user/age ?age] [1 :user/age-adjusted ?adjusted] [1 :user/label ?label]]")]
        (t.is report.ok report.error)
