(t.deftest sqlite-store-with-report-validates-source-unique-conflicts
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-unique.sqlite")
  (let [path "tmp.vev.store-with-report-unique.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/value} {:db/id 1 :user/email \"ada@example.com\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok write-report.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          existing-conflict (vev.with-store-db-report-text (addr snapshot) "[[:db/add 2 :user/email \"ada@example.com\"]]")
          overlay-conflict (vev.with-store-db-report-text (addr snapshot) "[[:db/add 2 :user/email \"grace@example.com\"] [:db/add 3 :user/email \"grace@example.com\"]]")
          ok-report (vev.with-store-db-report-text (addr snapshot) "[[:db/add 1 :user/email \"ada@example.com\"]]")
          ok-result (vev.q-result-store-db-text (addr ok-report.db-after) "[:find ?email :where [1 :user/email ?email]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not existing-conflict.ok))
      (t.is (= existing-conflict.error "schema unique conflict"))
      (t.is (sqlite-durable-store-db? existing-conflict.db-after))
      (t.is (not overlay-conflict.ok))
      (t.is (= overlay-conflict.error "schema unique conflict"))
      (t.is (sqlite-durable-store-db? overlay-conflict.db-after))
      (t.is ok-report.ok ok-report.error)
      (t.is (= ok-report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is ok-result.result.ok)
      (t.is (= (count ok-result.result.rows) 1))
      (t.is (= ok-result.result.rows[0].values[0].kind .String))
      (t.is (= ok-result.result.rows[0].values[0].text "ada@example.com"))
      (vev.delete-query-result ok-result)
      (vev.delete-store-tx-report existing-conflict)
      (vev.delete-store-tx-report overlay-conflict)
      (vev.delete-store-tx-report ok-report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-validates-source-identity-conflicts
