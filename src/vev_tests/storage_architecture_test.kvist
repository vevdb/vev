                 "[[:db/add 100 :db/ident :inc-age-by] [:db.fn/call :inc-age-by \"Ada\" 5] [:db/add 1 :user/label \"after-value-call\"]]"
                 registry)
        before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?age :where [1 :user/age ?age]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/age-adjusted true] [1 :user/label ?label]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/age-adjusted true] [1 :user/label ?label]]")]
    (t.is write-report.ok)
    (t.is report.ok report.error)
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Snapshot))
    (t.is before-result.result.ok before-result.result.error)
    (t.is (= (count before-result.result.rows) 1))
    (t.is (= before-result.result.rows[0].values[0].int-value 40))
    (t.is after-result.result.ok after-result.result.error)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (= after-result.result.rows[0].values[0].int-value 45))
    (t.is (= after-result.result.rows[0].values[1].text "after-value-call"))
    (t.is live-result.result.ok live-result.result.error)
    (t.is (= (count live-result.result.rows) 1))
    (t.is (= live-result.result.rows[0].values[0].int-value 45))
    (t.is (= live-result.result.rows[0].values[1].text "after-value-call"))
    (vev.delete-query-result before-result)
    (vev.delete-query-result after-result)
    (vev.delete-query-result live-result)
    (vev.delete-store-tx-report report)
    (vev.delete-tx-report-shallow write-report)
    (vev.close-store store)))

(t.deftest shared-store-report-source-fn-failure-keeps-shared-db-values
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")
        registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])
        report (vev.transact-store-report-text-with-source-string-fns
                 (addr store)
                 "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Grace\"]]"
                 registry)
        before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?age :where [1 :user/age ?age]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age :where [1 :user/age ?age]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?flag :where [1 :user/had-birthday ?flag]]")]
    (t.is write-report.ok)
    (t.is (not report.ok))
    (t.is (= report.error "No entity with name"))
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Snapshot))
    (t.is before-result.result.ok before-result.result.error)
    (t.is (= (count before-result.result.rows) 1))
    (t.is (= before-result.result.rows[0].values[0].int-value 40))
    (t.is after-result.result.ok after-result.result.error)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (= after-result.result.rows[0].values[0].int-value 40))
    (t.is live-result.result.ok live-result.result.error)
    (t.is (= (count live-result.result.rows) 0))
    (vev.delete-query-result before-result)
    (vev.delete-query-result after-result)
    (vev.delete-query-result live-result)
    (vev.delete-store-tx-report report)
    (vev.delete-tx-report-shallow write-report)
    (vev.close-store store)))

(t.deftest shared-store-with-report-unsupported-source-shape-fails-with-store-db-values
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        report (vev.with-store-db-report-text (addr snapshot) "[[:db.fn/call :missing \"Ada\"]]")
        after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [1 :user/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?name :where [1 :user/name ?name]]")]
    (t.is write-report.ok write-report.error)
    (t.is snapshot-ok snapshot-error)
    (t.is (not report.ok))
    (t.is (= report.error "transaction fn not registered"))
    (t.is (= report.db-before.kind .Shared-Snapshot))
    (t.is (= report.db-after.kind .Shared-Snapshot))
    (t.is after-result.result.ok after-result.result.error)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (result-has-string-row? after-result.result "Ada"))
    (t.is live-result.result.ok live-result.result.error)
    (t.is (= (count live-result.result.rows) 1))
    (t.is (result-has-string-row? live-result.result "Ada"))
    (vev.delete-query-result after-result)
    (vev.delete-query-result live-result)
    (vev.delete-store-tx-report report)
    (vev.close-store-db! (addr snapshot))
    (vev.delete-tx-report-shallow write-report)
    (vev.close-store store)))

(t.deftest sqlite-store-db-with-source-fns-keeps-source-overlay
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-with-source-fns.sqlite")
  (let [path "tmp.vev.store-db-with-source-fns.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])
          next-snapshot (vev.db-with-store-db-text-with-source-string-fns
                          (addr snapshot)
                          "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"] [:db/add 1 :user/label \"after-call\"]]"
                          registry)
          before-result (vev.q-result-store-db-text (addr snapshot) "[:find ?age :where [1 :user/age ?age]]")
          after-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/had-birthday true] [1 :user/label ?label]]")
          original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?label :where [1 :user/label ?label]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= snapshot.kind .SQLite-Snapshot))
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-result.result.ok)
      (t.is (= (count before-result.result.rows) 1))
      (t.is (= before-result.result.rows[0].values[0].int-value 40))
      (t.is after-result.result.ok)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (= after-result.result.rows[0].values[0].int-value 41))
      (t.is (= after-result.result.rows[0].values[1].text "after-call"))
      (t.is original-result.result.ok)
      (t.is (= (count original-result.result.rows) 0))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-query-result original-result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

