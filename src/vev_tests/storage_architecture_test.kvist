(t.deftest sqlite-store-with-report-text-keeps-source-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report.sqlite")
  (let [path "tmp.vev.store-with-report.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text (addr snapshot) "[{:db/id 2 :user/name \"Grace\"}]")
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?name :where [?e :user/name ?name]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-result.result.ok)
      (t.is (= (count before-result.result.rows) 1))
      (t.is (result-has-string-row? before-result.result "Ada"))
      (t.is (not (result-has-string-row? before-result.result "Grace")))
      (t.is after-result.result.ok)
      (t.is (= (count after-result.result.rows) 2))
      (t.is (result-has-string-row? after-result.result "Ada"))
      (t.is (result-has-string-row? after-result.result "Grace"))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

