      (t.is (= result.result.rows[0].values[1].text "Ada"))
      (t.is (= result.result.rows[0].values[2].entity 2))
      (t.is original-result.result.ok)
      (t.is (= (count original-result.result.rows) 0))
      (vev.delete-query-result result)
      (vev.delete-query-result original-result)
