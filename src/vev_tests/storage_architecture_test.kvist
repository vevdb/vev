(package vev-tests)

(import arr "kvist:arr")
(import fmt "core:fmt")
(import os "core:os")
(import t "kvist:test")
(import vev "../vev")

(defn remove-sqlite-files [path: string]
  (os.remove path)
  (let [wal-path (fmt.tprintf "%s-wal" path) :defer
        shm-path (fmt.tprintf "%s-shm" path) :defer]
    (os.remove wal-path)
    (os.remove shm-path))
  (return))

(defn int-slices-equal? [left: []int, right: []int] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn u64-slices-equal? [left: []u64, right: []u64] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn string-slices-equal? [left: []string, right: []string] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn result-has-string-row? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(defn sqlite-durable-store-db? [snapshot: vev.Store-DB] -> bool
  (or (= snapshot.kind .SQLite-Snapshot)
      (= snapshot.kind .SQLite-Lazy-Snapshot)
      (= snapshot.kind .SQLite-Root-Snapshot)))

(t.deftest sqlite-map-db-id-lookup-ref-update-preserves-unrelated-entities
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.lookup-map-update.sqlite")
  (let [path "tmp.vev.lookup-map-update.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text
               (addr store)
               "[{:db/id 100 :db/ident :ro/id :db/valueType :db.type/string :db/unique :db.unique/identity} {:db/id 101 :db/ident :item/collection :db/valueType :db.type/ref} {:db/id 102 :db/ident :property-value/option :db/valueType :db.type/ref} {:db/id 200 :ro/id \"collection\"} {:db/id 201 :ro/id \"todo\"} {:db/id 202 :ro/id \"done\"} {:db/id 1 :ro/id \"inserted\" :item/collection 200} {:db/id 2 :ro/id \"beta\" :item/collection 200} {:db/id 3 :ro/id \"status-beta\" :property-value/option 201}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (let [report (vev.transact-store-report-tx-data
                   (addr store)
                   (vev.tx-data
                     {:db/id [:ro/id "status-beta"]
                      :property-value/option [:ro/id "done"]}))
          items (vev.q-result-store-text
                  (addr store)
                  "[:find ?id :where [?item :item/collection 200] [?item :ro/id ?id]]")
          status (vev.q-result-store-text
                   (addr store)
                   "[:find ?option-id :where [?value :ro/id \"status-beta\"] [?value :property-value/option ?option] [?option :ro/id ?option-id]]")]
      (t.is report.ok report.error)
      (t.is items.result.ok items.result.error)
      (t.is (= (count items.result.rows) 2))
      (t.is (result-has-string-row? items.result "inserted"))
      (t.is (result-has-string-row? items.result "beta"))
      (t.is status.result.ok status.result.error)
      (t.is (= (count status.result.rows) 1))
      (t.is (result-has-string-row? status.result "done"))
      (vev.delete-query-result items)
      (vev.delete-query-result status)
      (vev.delete-store-tx-report report))
    (vev.close-store store)))

(t.deftest sqlite-direct-frontier-log-indexes-preserve-prefix-order
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.direct-frontier-log-indexes.sqlite")
  (let [path "tmp.vev.direct-frontier-log-indexes.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-tx-data
               (addr store)
               ([]vev.Tx-Data [(vev.add 1 ":item/rank" (vev.value-int 10))
                                (vev.add 2 ":item/rank" (vev.value-int 20))
                                (vev.add 2 ":item/friend" (vev.value-entity 1))
                                (vev.add 3 ":item/friend" (vev.value-entity 1))
                                (vev.add 4 ":item/friend" (vev.value-entity 2))]))]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is seed.ok seed.error)
    (let [[eavt-entries eavt-ok eavt-error] (vev.sqlite-direct-frontier-log-indexes-for-test (addr store) ":eavt" ([]u64 [2 1]) ":item/rank")
          [eavt-ordinals eavt-entities eavt-attrs eavt-values eavt-txs eavt-added eavt-parts-ok eavt-parts-error] (vev.sqlite-load-datoms-by-log-indexes-parts-for-test (addr store) (slice eavt-entries 0))
          [eavt-datoms eavt-datoms-ok eavt-datoms-error] (vev.sqlite-direct-frontier-datoms-for-test (addr store) ":eavt" ([]u64 [2 1]) ":item/rank")
          [eavt-ref-datoms eavt-ref-datoms-ok eavt-ref-datoms-error] (vev.sqlite-direct-frontier-datoms-for-test (addr store) ":eavt" ([]u64 [2 4]) ":item/friend")
          [duplicate-entries duplicate-ok duplicate-error] (vev.sqlite-direct-frontier-log-indexes-for-test (addr store) ":eavt" ([]u64 [1 1]) ":item/rank")
          [duplicate-ordinals duplicate-entities duplicate-attrs duplicate-values duplicate-txs duplicate-added duplicate-parts-ok duplicate-parts-error] (vev.sqlite-load-datoms-by-log-indexes-parts-for-test (addr store) (slice duplicate-entries 0))
          [duplicate-datoms duplicate-datoms-ok duplicate-datoms-error] (vev.sqlite-direct-frontier-datoms-for-test (addr store) ":eavt" ([]u64 [1 1]) ":item/rank")
          [vaet-entries vaet-ok vaet-error] (vev.sqlite-direct-frontier-log-indexes-for-test (addr store) ":vaet" ([]u64 [2 1]) ":item/friend")
          [vaet-ordinals vaet-entities vaet-attrs vaet-values vaet-txs vaet-added vaet-parts-ok vaet-parts-error] (vev.sqlite-load-datoms-by-log-indexes-parts-for-test (addr store) (slice vaet-entries 0))
          [vaet-datoms vaet-datoms-ok vaet-datoms-error] (vev.sqlite-direct-frontier-datoms-for-test (addr store) ":vaet" ([]u64 [2 1]) ":item/friend")
          [missing-entries missing-ok missing-error] (vev.sqlite-direct-frontier-log-indexes-for-test (addr store) ":eavt" ([]u64 [42]) ":item/rank")
          [bad-entries bad-ok _bad-error] (vev.sqlite-direct-frontier-log-indexes-for-test (addr store) ":avet" ([]u64 [1]) ":item/rank")]
      (defer (delete eavt-entries))
      (defer (delete eavt-ordinals))
      (defer (delete eavt-entities))
      (defer (vev.delete-owned-strings-array eavt-attrs))
      (defer (vev.delete-owned-strings-array eavt-values))
      (defer (delete eavt-txs))
      (defer (delete eavt-added))
      (defer (vev.delete-owned-datoms eavt-datoms))
      (defer (vev.delete-owned-datoms eavt-ref-datoms))
      (defer (delete duplicate-entries))
      (defer (delete duplicate-ordinals))
      (defer (delete duplicate-entities))
      (defer (vev.delete-owned-strings-array duplicate-attrs))
      (defer (vev.delete-owned-strings-array duplicate-values))
      (defer (delete duplicate-txs))
      (defer (delete duplicate-added))
      (defer (vev.delete-owned-datoms duplicate-datoms))
      (defer (delete vaet-entries))
      (defer (delete vaet-ordinals))
      (defer (delete vaet-entities))
      (defer (vev.delete-owned-strings-array vaet-attrs))
      (defer (vev.delete-owned-strings-array vaet-values))
      (defer (delete vaet-txs))
      (defer (delete vaet-added))
      (defer (vev.delete-owned-datoms vaet-datoms))
      (defer (delete missing-entries))
      (defer (delete bad-entries))
      (t.is eavt-ok eavt-error)
      (t.is eavt-parts-ok eavt-parts-error)
      (t.is (u64-slices-equal? (slice eavt-entities 0) ([]u64 [2 1])))
      (t.is (string-slices-equal? (slice eavt-attrs 0) ([]string [":item/rank" ":item/rank"])))
      (t.is eavt-datoms-ok eavt-datoms-error)
      (t.is (= (count eavt-datoms) 2))
      (t.is (= eavt-datoms[0].e 2))
      (t.is (= eavt-datoms[1].e 1))
      (t.is (= eavt-datoms[0].a ":item/rank"))
      (t.is eavt-ref-datoms-ok eavt-ref-datoms-error)
      (t.is (= (count eavt-ref-datoms) 2))
      (t.is (= eavt-ref-datoms[0].v.kind .Entity))
      (t.is (= eavt-ref-datoms[0].v.entity 1))
      (t.is (= eavt-ref-datoms[1].v.kind .Entity))
      (t.is (= eavt-ref-datoms[1].v.entity 2))
      (t.is duplicate-ok duplicate-error)
      (t.is duplicate-parts-ok duplicate-parts-error)
      (t.is (u64-slices-equal? (slice duplicate-entities 0) ([]u64 [1 1])))
      (t.is (string-slices-equal? (slice duplicate-attrs 0) ([]string [":item/rank" ":item/rank"])))
      (t.is duplicate-datoms-ok duplicate-datoms-error)
      (t.is (= (count duplicate-datoms) 2))
      (t.is (= duplicate-datoms[0].e 1))
      (t.is (= duplicate-datoms[1].e 1))
      (t.is vaet-ok vaet-error)
      (t.is vaet-parts-ok vaet-parts-error)
      (t.is (u64-slices-equal? (slice vaet-entities 0) ([]u64 [4 2 3])))
      (t.is (string-slices-equal? (slice vaet-attrs 0) ([]string [":item/friend" ":item/friend" ":item/friend"])))
      (t.is vaet-datoms-ok vaet-datoms-error)
      (t.is (= (count vaet-datoms) 3))
      (t.is (= vaet-datoms[0].e 4))
      (t.is (= vaet-datoms[1].e 2))
      (t.is (= vaet-datoms[2].e 3))
      (t.is missing-ok missing-error)
      (t.is (= (count missing-entries) 0))
      (t.is (not bad-ok)))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-tiered-merge-compaction-range-prefers-equal-sized-runs
  (let [[small-start small-end small-compact] (vev.sqlite-tiered-merge-compaction-range ([]int [2 2 2 2]))
        [equal-start equal-end equal-compact] (vev.sqlite-tiered-merge-compaction-range ([]int [5 8 2 2 2 2]))
        [defer-start defer-end defer-compact] (vev.sqlite-tiered-merge-compaction-range ([]int [5 8 2 2 2]))
        [fallback-start fallback-end fallback-compact] (vev.sqlite-tiered-merge-compaction-range ([]int [5 8 16 32 2 4]))
        [maintenance-start maintenance-end maintenance-compact] (vev.sqlite-maintenance-merge-compaction-range ([]int [5 8 2 2 2]))
        small-inline (vev.sqlite-foreground-merge-compaction-inline? ([]int [128 128 128 128]) 0 4)
        large-inline (vev.sqlite-foreground-merge-compaction-inline? ([]int [256 256 256 256]) 0 4)]
    (t.is (not small-compact))
    (t.is (= small-start 0))
    (t.is (= small-end 0))
    (t.is equal-compact)
    (t.is (= equal-start 2))
    (t.is (= equal-end 6))
    (t.is (not defer-compact))
    (t.is (= defer-start 0))
    (t.is (= defer-end 0))
    (t.is fallback-compact)
    (t.is (= fallback-start 2))
    (t.is (= fallback-end 6))
    (t.is maintenance-compact)
    (t.is (= maintenance-start 1))
    (t.is (= maintenance-end 5))
    (t.is small-inline)
    (t.is (not large-inline))))

(t.deftest store-durability-configuration-accepts-known-modes
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-durability-config.sqlite")
  (let [path "tmp.vev.store-durability-config.sqlite"
        [store opened-ok opened-error] (vev.open-store path)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (let [[strict-ok strict-error] (vev.configure-store-durability! (addr store) ":strict")
          [normal-ok normal-error] (vev.configure-store-durability! (addr store) ":normal")
          [relaxed-ok relaxed-error] (vev.configure-store-durability! (addr store) ":relaxed")
          [bad-ok _bad-error] (vev.configure-store-durability! (addr store) ":unknown")]
      (t.is strict-ok strict-error)
      (t.is normal-ok normal-error)
      (t.is relaxed-ok relaxed-error)
      (t.is (not bad-ok)))
    (vev.close-store store))
  (let [shared (vev.create-shared-store 128)]
    (let [[shared-ok shared-error] (vev.configure-store-durability! (addr shared) ":normal")
          [shared-bad-ok _shared-bad-error] (vev.configure-store-durability! (addr shared) ":unknown")]
      (t.is shared-ok shared-error)
      (t.is (not shared-bad-ok)))
    (vev.close-store shared)))

(t.deftest sqlite-store-report-tx-data-groups-commit-as-one-bulk-transaction
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-tx-data-groups.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [first-tx ([]vev.Tx-Data [(vev.add 1 ":user/name" (vev.value-string "Ada"))])
            second-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            first-group (vev.store-tx-data-group first-tx)
            second-group (vev.store-tx-data-group second-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group second-group])
            report (vev.transact-store-report-tx-data-groups (addr store) groups)
            result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
        (t.is report.ok report.error)
        (t.is (= (count report.tx-data) 3))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 2))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (result-has-string-row? result.result "Grace"))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 1))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report report)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group second-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 2))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-commit-many-logical-transactions-once
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
        (t.is seed-report.ok seed-report.error)
        (vev.delete-store-tx-report seed-report))
      (let [first-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            second-tx ([]vev.Tx-Data [(vev.add 3 ":user/name" (vev.value-string "Hedy"))])
            first-group (vev.store-tx-data-group first-tx)
            second-group (vev.store-tx-data-group second-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group second-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is reports[0].ok reports[0].error)
        (t.is reports[1].ok reports[1].error)
        (t.is (= reports[0].tx (+ vev.tx-partition-base 1)))
        (t.is (= reports[1].tx (+ vev.tx-partition-base 2)))
        (t.is (= (count reports[0].tx-data) 2))
        (t.is (= (count reports[1].tx-data) 2))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 3))
        (t.is (not (vev.store-resident-db-available? (addr store))))
        (let [first-before (vev.q-result-store-db-text (addr reports[0].db-before) "[:find ?name :where [?e :user/name ?name]]")
              first-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?name :where [?e :user/name ?name]]")
              second-before (vev.q-result-store-db-text (addr reports[1].db-before) "[:find ?name :where [?e :user/name ?name]]")
              second-after (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is first-before.result.ok first-before.result.error)
          (t.is first-after.result.ok first-after.result.error)
          (t.is second-before.result.ok second-before.result.error)
          (t.is second-after.result.ok second-after.result.error)
          (t.is (= (count first-before.result.rows) 1))
          (t.is (= (count first-after.result.rows) 2))
          (t.is (= (count second-before.result.rows) 2))
          (t.is (= (count second-after.result.rows) 3))
          (t.is (result-has-string-row? first-before.result "Ada"))
          (t.is (result-has-string-row? first-after.result "Grace"))
          (t.is (result-has-string-row? second-before.result "Grace"))
          (t.is (result-has-string-row? second-after.result "Hedy"))
          (vev.delete-query-result first-before)
          (vev.delete-query-result first-after)
          (vev.delete-query-result second-before)
          (vev.delete-query-result second-after))
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group second-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 3))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is (result-has-string-row? reopened-result.result "Hedy"))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 3))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-return-path-backed-report-dbs
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-report-db-lifetime.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
        (t.is seed-report.ok seed-report.error)
        (vev.delete-store-tx-report seed-report))
      (let [first-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            second-tx ([]vev.Tx-Data [(vev.add 3 ":user/name" (vev.value-string "Hedy"))])
            first-group (vev.store-tx-data-group first-tx)
            second-group (vev.store-tx-data-group second-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group second-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)]
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is (sqlite-durable-store-db? reports[0].db-before))
        (t.is (sqlite-durable-store-db? reports[0].db-after))
        (t.is (sqlite-durable-store-db? reports[1].db-before))
        (t.is (sqlite-durable-store-db? reports[1].db-after))
        (vev.close-store store)
        (let [first-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?name :where [?e :user/name ?name]]")
              second-before (vev.q-result-store-db-text (addr reports[1].db-before) "[:find ?name :where [?e :user/name ?name]]")
              second-after (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is first-after.result.ok first-after.result.error)
          (t.is second-before.result.ok second-before.result.error)
          (t.is second-after.result.ok second-after.result.error)
          (t.is (= (count first-after.result.rows) 2))
          (t.is (= (count second-before.result.rows) 2))
          (t.is (= (count second-after.result.rows) 3))
          (t.is (result-has-string-row? first-after.result "Grace"))
          (t.is (result-has-string-row? second-before.result "Grace"))
          (t.is (result-has-string-row? second-after.result "Hedy"))
          (vev.delete-query-result first-after)
          (vev.delete-query-result second-before)
          (vev.delete-query-result second-after))
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group second-group)))))

(t.deftest sqlite-store-report-logical-tx-data-groups-bootstrap-empty-store
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-empty.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [first-tx ([]vev.Tx-Data [(vev.add 1 ":user/name" (vev.value-string "Ada"))])
            second-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            first-group (vev.store-tx-data-group first-tx)
            second-group (vev.store-tx-data-group second-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group second-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is reports[0].ok reports[0].error)
        (t.is reports[1].ok reports[1].error)
        (t.is (= reports[0].tx vev.tx-partition-base))
        (t.is (= reports[1].tx (+ vev.tx-partition-base 1)))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 2))
        (t.is (not (vev.store-resident-db-available? (addr store))))
        (let [result (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is result.result.ok result.result.error)
          (t.is (= (count result.result.rows) 2))
          (t.is (result-has-string-row? result.result "Ada"))
          (t.is (result-has-string-row? result.result "Grace"))
          (vev.delete-query-result result))
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group second-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 2))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 2))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-preserves-noop-logical-transaction
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-noop.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
        (t.is seed-report.ok seed-report.error)
        (vev.delete-store-tx-report seed-report))
      (let [[root-count-before root-count-before-ok root-count-before-error] (vev.sqlite-index-root-count path)
            [root-page-count-before root-page-count-before-ok root-page-count-before-error] (vev.sqlite-index-root-page-count path)
            [chunk-count-before chunk-count-before-ok chunk-count-before-error] (vev.sqlite-index-chunk-count path)
            [datom-count-before datom-count-before-ok datom-count-before-error] (vev.sqlite-conn-datom-count (addr store.sqlite))
            noop-tx ([]vev.Tx-Data [(vev.retract 1 ":user/name" (vev.value-string "Ada"))
                                    (vev.add 1 ":user/name" (vev.value-string "Ada"))])
            add-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            noop-group (vev.store-tx-data-group noop-tx)
            add-group (vev.store-tx-data-group add-tx)
            groups ([]vev.Store-Tx-Data-Group [noop-group add-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))
            [root-count-after root-count-after-ok root-count-after-error] (vev.sqlite-index-root-count path)
            [root-page-count-after root-page-count-after-ok root-page-count-after-error] (vev.sqlite-index-root-page-count path)
            [chunk-count-after chunk-count-after-ok chunk-count-after-error] (vev.sqlite-index-chunk-count path)
            [datom-count-after datom-count-after-ok datom-count-after-error] (vev.sqlite-conn-datom-count (addr store.sqlite))]
        (t.is root-count-before-ok root-count-before-error)
        (t.is root-page-count-before-ok root-page-count-before-error)
        (t.is chunk-count-before-ok chunk-count-before-error)
        (t.is datom-count-before-ok datom-count-before-error)
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is reports[0].ok reports[0].error)
        (t.is reports[1].ok reports[1].error)
        (t.is (= reports[0].tx (+ vev.tx-partition-base 1)))
        (t.is (= reports[1].tx (+ vev.tx-partition-base 2)))
        (t.is (= (count reports[0].tx-data) 1))
        (t.is (= (count reports[1].tx-data) 2))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 3))
        (t.is (not (vev.store-resident-db-available? (addr store))))
        (t.is root-count-after-ok root-count-after-error)
        (t.is (= root-count-after (+ root-count-before 2)))
        (t.is root-page-count-after-ok root-page-count-after-error)
        (t.is (= root-page-count-after (+ root-page-count-before 8)))
        (t.is chunk-count-after-ok chunk-count-after-error)
        (t.is (= chunk-count-after (+ chunk-count-before 8)))
        (t.is datom-count-after-ok datom-count-after-error)
        (t.is (= datom-count-after (+ datom-count-before 3)))
        (let [noop-before (vev.q-result-store-db-text (addr reports[0].db-before) "[:find ?name :where [?e :user/name ?name]]")
              noop-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?name :where [?e :user/name ?name]]")
              final-result (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is noop-before.result.ok noop-before.result.error)
          (t.is noop-after.result.ok noop-after.result.error)
          (t.is final-result.result.ok final-result.result.error)
          (t.is (= (count noop-before.result.rows) 1))
          (t.is (= (count noop-after.result.rows) 1))
          (t.is (= (count final-result.result.rows) 2))
          (t.is (result-has-string-row? noop-before.result "Ada"))
          (t.is (result-has-string-row? noop-after.result "Ada"))
          (t.is (result-has-string-row? final-result.result "Ada"))
          (t.is (result-has-string-row? final-result.result "Grace"))
          (vev.delete-query-result noop-before)
          (vev.delete-query-result noop-after)
          (vev.delete-query-result final-result))
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group noop-group)
        (vev.delete-store-tx-data-group add-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 2))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 3))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-supports-sequential-cas-bases
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-cas.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 37}]")]
        (t.is seed-report.ok seed-report.error)
        (vev.delete-store-tx-report seed-report))
      (let [first-tx ([]vev.Tx-Data [(vev.cas 1 ":user/age" (vev.value-int 37) (vev.value-int 38))])
            second-tx ([]vev.Tx-Data [(vev.cas 1 ":user/age" (vev.value-int 38) (vev.value-int 39))])
            first-group (vev.store-tx-data-group first-tx)
            second-group (vev.store-tx-data-group second-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group second-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is reports[0].ok reports[0].error)
        (t.is reports[1].ok reports[1].error)
        (t.is (= reports[0].tx (+ vev.tx-partition-base 1)))
        (t.is (= reports[1].tx (+ vev.tx-partition-base 2)))
        (t.is (= (count reports[0].tx-data) 3))
        (t.is (= (count reports[1].tx-data) 3))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 3))
        (t.is (not (vev.store-resident-db-available? (addr store))))
        (let [first-before (vev.q-result-store-db-text (addr reports[0].db-before) "[:find ?age :where [1 :user/age ?age]]")
              first-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?age :where [1 :user/age ?age]]")
              second-before (vev.q-result-store-db-text (addr reports[1].db-before) "[:find ?age :where [1 :user/age ?age]]")
              second-after (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?age :where [1 :user/age ?age]]")]
          (t.is first-before.result.ok first-before.result.error)
          (t.is first-after.result.ok first-after.result.error)
          (t.is second-before.result.ok second-before.result.error)
          (t.is second-after.result.ok second-after.result.error)
          (t.is (= (count first-before.result.rows) 1))
          (t.is (= (count first-after.result.rows) 1))
          (t.is (= (count second-before.result.rows) 1))
          (t.is (= (count second-after.result.rows) 1))
          (t.is (= first-before.result.rows[0].values[0].int-value 37))
          (t.is (= first-after.result.rows[0].values[0].int-value 38))
          (t.is (= second-before.result.rows[0].values[0].int-value 38))
          (t.is (= second-after.result.rows[0].values[0].int-value 39))
          (vev.delete-query-result first-before)
          (vev.delete-query-result first-after)
          (vev.delete-query-result second-before)
          (vev.delete-query-result second-after))
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group second-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?age :where [1 :user/age ?age]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (= reopened-result.result.rows[0].values[0].int-value 39))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 3))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-rolls-back-on-later-cas-failure
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-rollback.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 37}]")]
        (t.is seed-report.ok seed-report.error)
        (vev.delete-store-tx-report seed-report))
      (let [[root-count-before root-count-before-ok root-count-before-error] (vev.sqlite-index-root-count path)
            [datom-count-before datom-count-before-ok datom-count-before-error] (vev.sqlite-conn-datom-count (addr store.sqlite))
            first-tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
            failing-tx ([]vev.Tx-Data [(vev.cas 1 ":user/age" (vev.value-int 99) (vev.value-int 38))])
            first-group (vev.store-tx-data-group first-tx)
            failing-group (vev.store-tx-data-group failing-tx)
            groups ([]vev.Store-Tx-Data-Group [first-group failing-group])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))
            [root-count-after root-count-after-ok root-count-after-error] (vev.sqlite-index-root-count path)
            [datom-count-after datom-count-after-ok datom-count-after-error] (vev.sqlite-conn-datom-count (addr store.sqlite))
            result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is root-count-before-ok root-count-before-error)
        (t.is datom-count-before-ok datom-count-before-error)
        (t.is (not reports-ok))
        (t.is (not (= reports-error "")))
        (t.is (= (count reports) 0))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 1))
        (t.is (not (vev.store-resident-db-available? (addr store))))
        (t.is root-count-after-ok root-count-after-error)
        (t.is (= root-count-after root-count-before))
        (t.is datom-count-after-ok datom-count-after-error)
        (t.is (= datom-count-after datom-count-before))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (not (result-has-string-row? result.result "Grace")))
        (vev.delete-query-result result)
        (vev.delete-store-tx-reports reports)
        (vev.delete-store-tx-data-group first-group)
        (vev.delete-store-tx-data-group failing-group))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (not (result-has-string-row? reopened-result.result "Grace")))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 1))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-tx-data-groups-read-only-fails-clearly
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-read-only.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
      (t.is opened-ok opened-error)
      (t.is seed-report.ok seed-report.error)
      (vev.delete-store-tx-report seed-report)
      (vev.close-store store))
    (let [[read-store read-ok read-error] (vev.open-store-read-only path)
          tx ([]vev.Tx-Data [(vev.add 2 ":user/name" (vev.value-string "Grace"))])
          group (vev.store-tx-data-group tx)
          groups ([]vev.Store-Tx-Data-Group [group])
          [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr read-store) groups)
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr read-store))
          result (vev.q-result-store-text (addr read-store) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is read-ok read-error)
      (t.is (vev.store-read-only? (addr read-store)))
      (t.is (not reports-ok))
      (t.is (= reports-error "SQLite source connection is read-only; open a writable SQLite connection to transact"))
      (t.is (= (count reports) 0))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 1))
      (t.is result.result.ok result.result.error)
      (t.is (= (count result.result.rows) 1))
      (t.is (result-has-string-row? result.result "Ada"))
      (t.is (not (result-has-string-row? result.result "Grace")))
      (vev.delete-query-result result)
      (vev.delete-store-tx-reports reports)
      (vev.delete-store-tx-data-group group)
      (vev.close-store read-store))))

(t.deftest sqlite-store-report-logical-tx-data-groups-shared-store-fails-clearly
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 128)
        tx ([]vev.Tx-Data [(vev.add 1 ":user/name" (vev.value-string "Ada"))])
        group (vev.store-tx-data-group tx)
        groups ([]vev.Store-Tx-Data-Group [group])
        [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)]
    (t.is (not reports-ok))
    (t.is (= reports-error "logical group commit is only implemented for durable SQLite stores"))
    (t.is (= (count reports) 0))
    (vev.delete-store-tx-reports reports)
    (vev.delete-store-tx-data-group group)
    (vev.close-store store)))

(t.deftest sqlite-store-report-logical-tx-data-groups-empty-list-is-noop
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-tx-data-groups-empty-list.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          groups ([]vev.Store-Tx-Data-Group [])
          [reports reports-ok reports-error] (vev.transact-store-report-logical-tx-data-groups (addr store) groups)
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
      (t.is opened-ok opened-error)
      (t.is reports-ok reports-error)
      (t.is (= (count reports) 0))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 0))
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-store-tx-reports reports)
      (vev.close-store store))))

(t.deftest sqlite-store-report-logical-text-groups-commit-many-logical-transactions-once
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-text-groups.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)]
      (t.is opened-ok opened-error)
      (let [texts ([]string ["[{:db/id 1 :user/name \"Ada\"}]"
                             "[{:db/id 2 :user/name \"Grace\"}]"])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-text-groups (addr store) texts)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))
            result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is reports-ok reports-error)
        (t.is (= (count reports) 2))
        (t.is reports[0].ok reports[0].error)
        (t.is reports[1].ok reports[1].error)
        (t.is (= reports[0].tx vev.tx-partition-base))
        (t.is (= reports[1].tx (+ vev.tx-partition-base 1)))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 2))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 2))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (result-has-string-row? result.result "Grace"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-reports reports))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 2))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 2))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-text-groups-invalidates-current-root-cache
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-text-groups-cache.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
          [primed primed-ok primed-error] (vev.store-db (addr store))
          texts ([]string ["[{:db/id 2 :user/name \"Grace\"}]"
                           "[{:db/id 3 :user/name \"Barbara\"}]"])
          [reports reports-ok reports-error] (vev.transact-store-report-logical-text-groups (addr store) texts)
          [after after-ok after-error] (vev.store-db (addr store))
          result (vev.q-result-store-db-text (addr after) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is opened-ok opened-error)
      (t.is seed.ok seed.error)
      (t.is primed-ok primed-error)
      (t.is (sqlite-durable-store-db? primed))
      (t.is reports-ok reports-error)
      (t.is (= (count reports) 2))
      (t.is after-ok after-error)
      (t.is (sqlite-durable-store-db? after))
      (t.is result.result.ok result.result.error)
      (t.is (= (count result.result.rows) 3))
      (t.is (result-has-string-row? result.result "Ada"))
      (t.is (result-has-string-row? result.result "Grace"))
      (t.is (result-has-string-row? result.result "Barbara"))
      (vev.delete-query-result result)
      (vev.close-store-db! (addr primed))
      (vev.close-store-db! (addr after))
      (vev.delete-store-tx-report seed)
      (vev.delete-store-tx-reports reports)
      (vev.close-store store))))

(t.deftest sqlite-store-report-logical-text-groups-parse-failure-commits-nothing
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-text-groups-parse-failure.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          seed-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
      (t.is opened-ok opened-error)
      (t.is seed-report.ok seed-report.error)
      (vev.delete-store-tx-report seed-report)
      (let [texts ([]string ["[{:db/id 2 :user/name \"Grace\"}]"
                             "[{:db/id 3 :user/name"])
            [reports reports-ok reports-error] (vev.transact-store-report-logical-text-groups (addr store) texts)
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))
            result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is (not reports-ok))
        (t.is (= (count reports) 0))
        (t.is (not (= reports-error "")))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 1))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (not (result-has-string-row? result.result "Grace")))
        (vev.delete-query-result result)
        (vev.delete-store-tx-reports reports))
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
          [reopened-tx-count reopened-tx-count-ok reopened-tx-count-error] (vev.store-tx-count (addr reopened))]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (not (result-has-string-row? reopened-result.result "Grace")))
      (t.is reopened-tx-count-ok reopened-tx-count-error)
      (t.is (= reopened-tx-count 1))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-logical-text-groups-source-fn-sees-prior-logical-transaction
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-text-groups-source-fn.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])
          texts ([]string ["[{:db/id 1 :user/name \"Ada\" :user/age 37}]"
                           "[[:db.fn/call :birthday \"Ada\"]]"])
          [reports reports-ok reports-error] (vev.transact-store-report-logical-text-groups-with-source-string-fns (addr store) texts registry)
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
      (t.is opened-ok opened-error)
      (t.is reports-ok reports-error)
      (t.is (= reports-error ""))
      (t.is (= (count reports) 2))
      (t.is reports[0].ok reports[0].error)
      (t.is reports[1].ok reports[1].error)
      (t.is (= reports[0].tx vev.tx-partition-base))
      (t.is (= reports[1].tx (+ vev.tx-partition-base 1)))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 2))
      (let [first-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?age :where [1 :user/age ?age]]")
            second-before (vev.q-result-store-db-text (addr reports[1].db-before) "[:find ?age :where [1 :user/age ?age]]")
            second-after (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?age :where [1 :user/age ?age]]")
            live-result (vev.q-result-store-text (addr store) "[:find ?age :where [1 :user/age ?age]]")]
        (t.is first-after.result.ok first-after.result.error)
        (t.is second-before.result.ok second-before.result.error)
        (t.is second-after.result.ok second-after.result.error)
        (t.is live-result.result.ok live-result.result.error)
        (t.is (result-has-int-row? first-after.result 37))
        (t.is (result-has-int-row? second-before.result 37))
        (t.is (result-has-int-row? second-after.result 38))
        (t.is (result-has-int-row? live-result.result 38))
        (vev.delete-query-result first-after)
        (vev.delete-query-result second-before)
        (vev.delete-query-result second-after)
        (vev.delete-query-result live-result))
      (vev.delete-store-tx-reports reports)
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?age :where [1 :user/age ?age]]")]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (result-has-int-row? reopened-result.result 38))
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

