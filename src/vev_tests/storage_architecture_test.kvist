(t.deftest shared-store-db-with-source-fns-keeps-source-overlay
  (defer (free_all context.allocator))
  (let [store (vev.create-shared-store 2)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])
        next-snapshot (vev.db-with-store-db-text-with-source-string-fns
                        (addr snapshot)
                        "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"] [:db/add 1 :user/label \"after-call\"]]"
                        registry)
        before-result (vev.q-result-store-db-text (addr snapshot) "[:find ?age :where [1 :user/age ?age]]")
        after-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/had-birthday true] [1 :user/label ?label]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?label :where [1 :user/label ?label]]")]
    (t.is write-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .Shared-Snapshot))
    (t.is (= next-snapshot.kind .Shared-Tx-Ops-Overlay))
    (t.is before-result.result.ok)
    (t.is (= (count before-result.result.rows) 1))
    (t.is (= before-result.result.rows[0].values[0].int-value 40))
    (t.is after-result.result.ok)
    (t.is (= (count after-result.result.rows) 1))
    (t.is (= after-result.result.rows[0].values[0].int-value 41))
    (t.is (= after-result.result.rows[0].values[1].text "after-call"))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 0))
    (vev.delete-query-result before-result)
    (vev.delete-query-result after-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr next-snapshot))
    (vev.delete-tx-report-shallow write-report)
    (vev.close-store store)))

