          result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?parent ?name ?email :where [?parent :user/profile ?profile] [?parent :user/name ?name] [?profile :user/email ?email]]")
          original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?parent ?profile :where [?parent :user/profile ?profile]]")]
