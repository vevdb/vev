      (t.is (result-has-string-int-string-entity-row? source-store-db-star-many-profiled.result "Grace" 41 "admin" 1))
      (t.is (result-has-string-int-string-entity-row? source-store-db-star-many-profiled.result "Grace" 41 "lead" 1))
