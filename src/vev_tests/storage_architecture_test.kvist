        (t.is (= reverse-rel.typed-columns[0].entities[1] 1))
        (t.is (or (= reverse-rel.typed-columns[1].entities[0] 2)
                  (= reverse-rel.typed-columns[1].entities[1] 2)))
        (t.is (or (= reverse-rel.typed-columns[1].entities[0] 3)
                  (= reverse-rel.typed-columns[1].entities[1] 3)))
        (t.is reverse-bound-used)
        (t.is reverse-bound-rel.has-typed-columns)
        (t.is (= reverse-bound-rel.typed-rows 2))
        (t.is (= reverse-bound-stats.binding-materializations 0))
        (t.is (= reverse-bound-stats.generic-materialization-steps 0))
        (t.is (= reverse-bound-rel.typed-columns[0].kind .Entity))
        (t.is (or (= reverse-bound-rel.typed-columns[0].entities[0] 2)
                  (= reverse-bound-rel.typed-columns[0].entities[1] 2)))
        (t.is (or (= reverse-bound-rel.typed-columns[0].entities[0] 3)
                  (= reverse-bound-rel.typed-columns[0].entities[1] 3)))
        (t.is int-entity-used)
        (t.is int-entity-rel.has-typed-columns)
        (t.is (= int-entity-rel.typed-rows 1))
        (t.is (= int-entity-stats.binding-materializations 0))
        (t.is (= int-entity-stats.generic-materialization-steps 0))
        (t.is (= int-entity-rel.typed-columns[0].kind .String))
        (t.is (= int-entity-rel.typed-columns[0].texts[0] "Ada"))
        (t.is ref-literal-used)
        (t.is ref-literal-rel.has-typed-columns)
        (t.is (= ref-literal-rel.typed-rows 2))
        (t.is (= ref-literal-stats.binding-materializations 0))
        (t.is (= ref-literal-stats.generic-materialization-steps 0))
        (t.is (= ref-literal-rel.typed-columns[0].kind .Entity))
        (t.is (or (= ref-literal-rel.typed-columns[0].entities[0] 2)
                  (= ref-literal-rel.typed-columns[0].entities[1] 2)))
        (t.is (or (= ref-literal-rel.typed-columns[0].entities[0] 3)
                  (= ref-literal-rel.typed-columns[0].entities[1] 3)))
        (t.is lookup-ref-used)
        (t.is lookup-ref-rel.has-typed-columns)
        (t.is (= lookup-ref-rel.typed-rows 1))
        (t.is (= lookup-ref-stats.binding-materializations 0))
        (t.is (= lookup-ref-stats.generic-materialization-steps 0))
        (t.is (= lookup-ref-rel.typed-columns[0].kind .String))
        (t.is (= lookup-ref-rel.typed-columns[0].texts[0] "Ada"))
        (t.is not-used)
        (t.is not-rel.has-typed-columns)
        (t.is (= not-rel.typed-rows 1))
        (t.is (= (count not-rel.typed-columns) 2))
        (t.is (= not-stats.binding-materializations 0))
        (t.is (= not-stats.generic-materialization-steps 0))
        (t.is (= not-rel.typed-columns[0].kind .Entity))
        (t.is (= not-rel.typed-columns[0].entities[0] 1))
        (t.is (= not-rel.typed-columns[1].kind .String))
        (t.is (= not-rel.typed-columns[1].texts[0] "Ada"))
        (t.is or-used)
        (t.is or-rel.has-typed-columns)
        (t.is (= or-rel.typed-rows 2))
        (t.is (= (count or-rel.typed-columns) 2))
        (t.is (= or-stats.binding-materializations 0))
        (t.is (= or-stats.generic-materialization-steps 0))
        (t.is (= or-rel.typed-columns[0].kind .Entity))
        (t.is (= or-rel.typed-columns[1].kind .String))
        (t.is (or (and (= or-rel.typed-columns[0].entities[0] 1)
                       (= or-rel.typed-columns[1].texts[0] "Ada"))
                  (and (= or-rel.typed-columns[0].entities[1] 1)
                       (= or-rel.typed-columns[1].texts[1] "Ada"))))
        (t.is (or (and (= or-rel.typed-columns[0].entities[0] 2)
                       (= or-rel.typed-columns[1].texts[0] "Grace"))
                  (and (= or-rel.typed-columns[0].entities[1] 2)
                       (= or-rel.typed-columns[1].texts[1] "Grace"))))
        (t.is aggregate-used)
        (t.is aggregate-base-rel.has-typed-columns)
        (t.is (= aggregate-stats.binding-materializations 0))
        (t.is (= aggregate-stats.generic-materialization-steps 0))
        (t.is aggregate-rel-ok)
        (t.is aggregate-rel.has-typed-columns)
        (t.is (= aggregate-rel.typed-rows 2))
        (t.is (= (count aggregate-rel.typed-columns) 2))
        (t.is (= aggregate-rel.typed-columns[0].kind .String))
        (t.is (= aggregate-rel.typed-columns[1].kind .Int))
        (t.is aggregate-plan.ok)
        (t.is (= aggregate-plan.rows 2))
        (t.is (= (count aggregate-plan.find-indexes) 2))
        (t.is (or (and (= aggregate-rel.typed-columns[0].texts[0] "Ada")
                       (= aggregate-rel.typed-columns[1].ints[0] 2))
                  (and (= aggregate-rel.typed-columns[0].texts[1] "Ada")
                       (= aggregate-rel.typed-columns[1].ints[1] 2))))
        (t.is (or (and (= aggregate-rel.typed-columns[0].texts[0] "Grace")
                       (= aggregate-rel.typed-columns[1].ints[0] 1))
                  (and (= aggregate-rel.typed-columns[0].texts[1] "Grace")
                       (= aggregate-rel.typed-columns[1].ints[1] 1))))
        (t.is pull-used)
        (t.is (= pull-stats.binding-materializations 0))
        (t.is pull-batch-ok pull-batch-error)
        (t.is pull-batch.ok)
        (t.is pull-batch.owns-values)
        (t.is (= pull-batch.rows 2))
        (t.is (= (count pull-batch.columns) 1))
        (t.is pull-batch.value-columns[0])
        (let [[pull-cell pull-cell-ok] (vev.typed-materialized-batch-cell-value pull-batch 0 0)]
          (t.is pull-cell-ok)
          (t.is (= pull-cell.kind .Map)))
        (t.is pull-aggregate-result.result.ok pull-aggregate-result.result.error)
        (t.is (= (count pull-aggregate-result.result.rows) 1))
        (t.is (= (count pull-aggregate-result.result.rows[0].values) 2))
        (t.is (= pull-aggregate-result.result.rows[0].values[0].kind .Entity))
        (t.is (= pull-aggregate-result.result.rows[0].values[0].entity 3))
        (t.is (= pull-aggregate-result.result.rows[0].values[1].kind .Int))
        (t.is (= pull-aggregate-result.result.rows[0].values[1].int-value 1))
        (t.is (= (count pull-aggregate-result.result.rows[0].pulls) 1))
        (t.is (= pull-aggregate-result.result.rows[0].pulls[0].e 3))
        (t.is (= (count pull-aggregate-result.result.rows[0].pulls[0].attrs) 1))
        (t.is (= pull-aggregate-result.result.rows[0].pulls[0].attrs[0].a ":user/name"))
        (t.is (= pull-aggregate-result.result.rows[0].pulls[0].attrs[0].v.kind .String))
        (t.is (= pull-aggregate-result.result.rows[0].pulls[0].attrs[0].v.text "Ada"))
        (t.is range-pairs-ok range-pairs-error)
        (t.is (= (count range-pairs.entities) 1))
        (t.is (= (count range-pairs.values) 1))
        (t.is (= range-pairs.entities[0] 2))
        (t.is (= range-pairs.values[0] 71))
        (delete entities)
        (for [name names]
          (delete name))
        (delete names)
        (for [name filtered-names]
          (delete name))
        (delete filtered-names)
        (delete ages)
        (vev.delete-entity-int-pair-columns pairs)
        (vev.delete-entity-string-pair-columns string-pairs)
        (vev.delete-entity-string-int-triples string-int-pairs)
        (vev.delete-string-string-pair-columns string-string-pairs)
        (vev.delete-entity-int-pair-columns range-pairs)
        (vev.delete-entity-string-int-triples triples)
        (vev.delete-typed-flat-result-plan wide-plan)
        (vev.delete-query-relation reverse-rel)
        (vev.delete-query-relation reverse-bound-rel)
        (vev.delete-query-relation int-entity-rel)
        (vev.delete-query-relation ref-literal-rel)
        (vev.delete-query-relation lookup-ref-rel)
        (vev.delete-query-relation not-rel)
        (vev.delete-query-relation or-rel)
        (vev.delete-typed-materialized-batch pull-batch)
        (vev.delete-query-relation pull-rel)
        (vev.delete-query-result pull-aggregate-result)
        (vev.delete-typed-flat-result-plan aggregate-plan)
        (vev.delete-query-relation aggregate-rel)
        (vev.delete-query-relation aggregate-base-rel)
        (vev.delete-query-relation wide-rel)
        (vev.delete-query-shallow entity-query.query)
        (vev.delete-query-shallow text-query.query)
        (vev.delete-query-shallow filtered-text-query.query)
        (vev.delete-query-shallow int-query.query)
        (vev.delete-query-shallow pair-query.query)
        (vev.delete-query-shallow string-pair-query.query)
        (vev.delete-query-shallow string-int-query.query)
        (vev.delete-query-shallow string-string-query.query)
        (vev.delete-query-shallow triple-query.query)
        (vev.delete-query-shallow wide-query.query)
        (vev.delete-query-shallow reverse-query.query)
        (vev.delete-query-shallow reverse-bound-query.query)
        (vev.delete-query-shallow int-entity-query.query)
        (vev.delete-query-shallow ref-literal-query.query)
        (vev.delete-query-shallow lookup-ref-query.query)
        (vev.delete-query-shallow not-query.query)
        (vev.delete-query-shallow or-query.query)
        (vev.delete-query-shallow aggregate-query.query)
        (vev.delete-query-shallow pull-query.query)
        (vev.delete-query-shallow pull-aggregate-query.query)
        (vev.delete-query-shallow predicate-query.query))
      (vev.close-store-db! (addr snapshot))
      (vev.delete-store-tx-report report))
    (vev.close-store store)
    (remove-sqlite-files path)))

(t.deftest unopened-store-report-failures-are-storage-neutral
  (defer (free_all context.allocator))
  (let [store (vev.Store-Conn {})
        report-text (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        report-tx-data (vev.transact-store-report-tx-data
                         (addr store)
                         ([]vev.Tx-Data [(vev.add 1 ":user/name" (vev.value-string "Ada"))]))
        report-source-fn (vev.transact-store-report-text-with-source-string-fns
                           (addr store)
                           "[[:db.fn/call :missing]]"
                           ([]vev.Tx-Fn-Source-String []))]
    (t.is (not report-text.ok))
    (t.is (= report-text.error "store is not open"))
    (t.is (= report-text.db-before.kind .Empty))
    (t.is (= report-text.db-after.kind .Empty))
    (t.is (not report-tx-data.ok))
    (t.is (= report-tx-data.error "store is not open"))
    (t.is (= report-tx-data.db-before.kind .Empty))
    (t.is (= report-tx-data.db-after.kind .Empty))
    (t.is (not report-source-fn.ok))
    (t.is (= report-source-fn.error "store is not open"))
    (t.is (= report-source-fn.db-before.kind .Empty))
    (t.is (= report-source-fn.db-after.kind .Empty))
    (vev.delete-store-tx-report report-text)
    (vev.delete-store-tx-report report-tx-data)
    (vev.delete-store-tx-report report-source-fn)))

(t.deftest uninitialized-sqlite-store-report-failures-are-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.uninitialized-store-report-failure.sqlite")
  (let [path "tmp.vev.uninitialized-store-report-failure.sqlite"
        [store store-ok store-error] (vev.open-store path)]
    (t.is store-ok)
    (t.is (= store-error ""))
    (let [parse-report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name")
          source-fn-report (vev.transact-store-report-text-with-source-string-fns
                             (addr store)
                             "[[:db.fn/call :missing]]"
                             ([]vev.Tx-Fn-Source-String []))
          source-fn-before (vev.q-result-store-db-text (addr source-fn-report.db-before) "[:find ?e :where [?e :user/name ?name]]")
          source-fn-after (vev.q-result-store-db-text (addr source-fn-report.db-after) "[:find ?e :where [?e :user/name ?name]]")]
      (t.is (not parse-report.ok))
      (t.is (= parse-report.db-before.kind .Empty))
      (t.is (= parse-report.db-after.kind .Empty))
      (t.is (not source-fn-report.ok))
      (t.is (= source-fn-report.db-before.kind .Shared-Snapshot))
      (t.is (= source-fn-report.db-after.kind .Shared-Snapshot))
      (t.is source-fn-before.result.ok source-fn-before.result.error)
      (t.is (= (count source-fn-before.result.rows) 0))
      (t.is source-fn-after.result.ok source-fn-after.result.error)
      (t.is (= (count source-fn-after.result.rows) 0))
      (vev.delete-query-result source-fn-before)
      (vev.delete-query-result source-fn-after)
      (vev.delete-store-tx-report parse-report)
      (vev.delete-store-tx-report source-fn-report))
    (vev.close-store store)
    (remove-sqlite-files path)))
