        (t.is (= live-result.result.rows[0].values[0].kind .Int))
        (t.is (= live-result.result.rows[0].values[0].int-value 45))
        (t.is (= live-result.result.rows[0].values[1].kind .Bool))
        (t.is live-result.result.rows[0].values[1].bool-value)
        (t.is (= live-result.result.rows[0].values[2].kind .String))
        (t.is (= live-result.result.rows[0].values[2].text "after-value-call"))
        (t.is before-result.result.ok before-result.result.error)
        (t.is (= (count before-result.result.rows) 1))
        (t.is (= before-result.result.rows[0].values[0].int-value 40))
        (t.is after-result.result.ok after-result.result.error)
        (t.is (= (count after-result.result.rows) 1))
        (t.is (= after-result.result.rows[0].values[0].int-value 45))
        (t.is after-result.result.rows[0].values[1].bool-value)
        (t.is (= after-result.result.rows[0].values[2].text "after-value-call"))
        (vev.delete-query-result live-result)
        (vev.delete-query-result before-result)
        (vev.delete-query-result after-result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

