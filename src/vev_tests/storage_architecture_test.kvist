(t.deftest sqlite-store-report-logical-text-groups-value-source-fn-sees-prior-logical-transaction
  (defer (free_all context.allocator))
  (let [path "tmp.vev.store-report-logical-text-groups-value-source-fn.sqlite"]
    (remove-sqlite-files path)
    (defer (remove-sqlite-files path))
    (let [[store opened-ok opened-error] (vev.open-store path)
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-values ":inc-age-by" store-source-increase-age-by-values)])
          texts ([]string ["[{:db/id 1 :user/name \"Ada\" :user/age 37}]"
                           "[[:db.fn/call :inc-age-by \"Ada\" 5]]"])
          [reports reports-ok reports-error] (vev.transact-store-report-logical-text-groups-with-source-string-fns (addr store) texts registry)
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
      (t.is opened-ok opened-error)
      (t.is reports-ok reports-error)
      (t.is (= reports-error ""))
      (t.is (= (count reports) 2))
      (t.is reports[0].ok reports[0].error)
      (t.is reports[1].ok reports[1].error)
      (t.is (= reports[0].tx vev.tx-partition-base))
      (t.is (= reports[1].tx (+ vev.tx-partition-base 1)))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 2))
      (let [first-after (vev.q-result-store-db-text (addr reports[0].db-after) "[:find ?age :where [1 :user/age ?age]]")
            second-before (vev.q-result-store-db-text (addr reports[1].db-before) "[:find ?age :where [1 :user/age ?age]]")
            second-after (vev.q-result-store-db-text (addr reports[1].db-after) "[:find ?age ?adjusted :where [1 :user/age ?age] [1 :user/age-adjusted ?adjusted]]")
            live-result (vev.q-result-store-text (addr store) "[:find ?age ?adjusted :where [1 :user/age ?age] [1 :user/age-adjusted ?adjusted]]")]
        (t.is first-after.result.ok first-after.result.error)
        (t.is second-before.result.ok second-before.result.error)
        (t.is second-after.result.ok second-after.result.error)
        (t.is live-result.result.ok live-result.result.error)
        (t.is (result-has-int-row? first-after.result 37))
        (t.is (result-has-int-row? second-before.result 37))
        (t.is (= (count second-after.result.rows) 1))
        (t.is (= second-after.result.rows[0].values[0].int-value 42))
        (t.is second-after.result.rows[0].values[1].bool-value)
        (t.is (= (count live-result.result.rows) 1))
        (t.is (= live-result.result.rows[0].values[0].int-value 42))
        (t.is live-result.result.rows[0].values[1].bool-value)
        (vev.delete-query-result first-after)
        (vev.delete-query-result second-before)
        (vev.delete-query-result second-after)
        (vev.delete-query-result live-result))
      (vev.delete-store-tx-reports reports)
      (vev.close-store store))
    (let [[reopened reopened-ok reopened-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr reopened) "[:find ?age ?adjusted :where [1 :user/age ?age] [1 :user/age-adjusted ?adjusted]]")]
      (t.is reopened-ok reopened-error)
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (= reopened-result.result.rows[0].values[0].int-value 42))
      (t.is reopened-result.result.rows[0].values[1].bool-value)
      (vev.delete-query-result reopened-result)
      (vev.close-store reopened))))

(defn result-has-string-int-row? [result: vev.Result-Set, text: string, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value value))
      (return true)))
  false)

(defn result-has-int-row? [result: vev.Result-Set, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Int)
               (= row.values[0].int-value value))
      (return true)))
  false)

(defn result-has-string-int-int-row? [result: vev.Result-Set, text: string, first: i64, second: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value first)
               (= row.values[2].kind .Int)
               (= row.values[2].int-value second))
      (return true)))
  false)

(defn result-has-int-int-row? [result: vev.Result-Set, first: i64, second: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Int)
               (= row.values[0].int-value first)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value second))
      (return true)))
  false)

(defn result-has-int-int-vector-row? [result: vev.Result-Set, first: i64, second: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Int)
               (= row.values[0].int-value first)
               (= row.values[1].kind .Vector)
               (= (count row.values[1].items) 1)
               (= row.values[1].items[0].kind .Int)
               (= row.values[1].items[0].int-value second))
      (return true)))
  false)

(defn result-has-string-string-row? [result: vev.Result-Set, first: string, second: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text first)
               (= row.values[1].kind .String)
               (= row.values[1].text second))
      (return true)))
  false)

(defn result-has-string-string-entity-row? [result: vev.Result-Set, first: string, second: string, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text first)
               (= row.values[1].kind .String)
               (= row.values[1].text second)
               (= row.values[2].kind .Entity)
               (= row.values[2].entity entity))
      (return true)))
  false)

(defn result-has-string-string-int-row? [result: vev.Result-Set, first: string, second: string, int-value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 3)
               (= row.values[0].kind .String)
               (= row.values[0].text first)
