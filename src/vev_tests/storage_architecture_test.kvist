      (t.is source-store-db-range-star-many-profiled.result.ok)
      (t.is (= source-store-db-range-star-many-profiled.result.error ""))
      (t.is (= (count source-store-db-range-star-many-profiled.result.rows) 2))
      (t.is (result-has-string-string-entity-row? source-store-db-range-star-many-profiled.result "Grace" "admin" 1))
      (t.is (result-has-string-string-entity-row? source-store-db-range-star-many-profiled.result "Grace" "lead" 1))
      (t.is (= source-store-db-range-star-many-profiled.stats.clauses 4))
      (t.is (> source-store-db-range-star-many-profiled.stats.source-index-scans 0))
      (t.is (> source-store-db-range-star-many-profiled.stats.source-operators 0))
