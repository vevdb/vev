      (t.is (= source-store-db-range-star-profiled.stats.clauses 4))
      (t.is (> source-store-db-range-star-profiled.stats.source-index-scans 0))
      (t.is (> source-store-db-range-star-profiled.stats.source-operators 0))
      (t.is (= source-store-db-range-star-profiled.stats.binding-materializations 0))
