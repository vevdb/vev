(t.deftest sqlite-store-with-report-validates-new-unique-schema-against-source
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-new-unique-existing-dupes.sqlite")
  (let [path "tmp.vev.store-with-report-new-unique-existing-dupes.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[{:db/id 100 :db/ident :user/email} {:db/id 1 :user/email \"ada@example.com\"} {:db/id 2 :user/email \"ada@example.com\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok write-report.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text (addr snapshot) "[[:db/add 100 :db/unique :db.unique/value]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not report.ok))
      (t.is (= report.error "schema unique conflict"))
      (t.is (sqlite-durable-store-db? report.db-after))
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-same-tx-reverse-ref-keeps-source-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-reverse-ref.sqlite")
  (let [path "tmp.vev.store-with-report-reverse-ref.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 900 :store/initialized true}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text
                   (addr snapshot)
                   "[{:db/id 100 :db/ident :user/friend :db/valueType :db.type/ref} [:db/add 2 :_user/friend 1]]")
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?friend :where [1 :user/friend ?friend]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?friend :where [1 :user/friend ?friend]]")
          reverse-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?source :where [2 :_user/friend ?source]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-result.result.ok)
      (t.is (= (count before-result.result.rows) 0))
      (t.is after-result.result.ok)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (= after-result.result.rows[0].values[0].kind .Entity))
      (t.is (= after-result.result.rows[0].values[0].entity 2))
      (t.is reverse-result.result.ok)
      (t.is (= (count reverse-result.result.rows) 1))
      (t.is (= reverse-result.result.rows[0].values[0].kind .Entity))
      (t.is (= reverse-result.result.rows[0].values[0].entity 1))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-query-result reverse-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-tuple-maintenance-keeps-source-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-report-tuple-maintenance.sqlite")
  (let [path "tmp.vev.store-with-report-tuple-maintenance.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/name} {:db/id 102 :db/ident :user/email+name :db/valueType :db.type/tuple :db/tupleAttrs [:user/email :user/name] :db/unique :db.unique/identity} {:db/id 900 :store/initialized true}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok write-report.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          report (vev.with-store-db-report-text
                   (addr snapshot)
                   "[{:db/id \"ada\" :user/email \"ada@example.com\" :user/name \"Ada\"}]")
          tuple-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?tuple :where [?e :user/email+name ?tuple]]")
          lookup-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [[:user/email+name [\"ada@example.com\" \"Ada\"]] :user/name ?name]]")
          [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is ada-ok)
      (t.is (> ada-e 0))
      (t.is tuple-result.result.ok tuple-result.result.error)
      (t.is (= (count tuple-result.result.rows) 1))
      (t.is (= tuple-result.result.rows[0].values[0].kind .Vector))
      (t.is (= tuple-result.result.rows[0].values[0].items[0].kind .String))
      (t.is (= tuple-result.result.rows[0].values[0].items[0].text "ada@example.com"))
      (t.is (= tuple-result.result.rows[0].values[0].items[1].kind .String))
      (t.is (= tuple-result.result.rows[0].values[0].items[1].text "Ada"))
      (t.is lookup-result.result.ok lookup-result.result.error)
      (t.is (= (count lookup-result.result.rows) 1))
      (t.is (= lookup-result.result.rows[0].values[0].kind .String))
      (t.is (= lookup-result.result.rows[0].values[0].text "Ada"))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (vev.delete-query-result tuple-result)
      (vev.delete-query-result lookup-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-with-report-source-fns-keeps-source-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-with-source-fns.sqlite")
  (let [path "tmp.vev.store-with-source-fns.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])
          report (vev.with-store-db-report-text-with-source-string-fns
                   (addr snapshot)
                   "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"] [:db/add 1 :user/label \"after-call\"]]"
                   registry)
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?age :where [1 :user/age ?age]]")
          after-age-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age :where [1 :user/age ?age]]")
          after-birthday-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?birthday :where [1 :user/had-birthday ?birthday]]")
          after-label-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?label :where [1 :user/label ?label]]")
          combined-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/had-birthday true] [1 :user/label ?label]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-result.result.ok)
      (t.is (= (count before-result.result.rows) 1))
      (t.is (= before-result.result.rows[0].values[0].kind .Int))
      (t.is (= before-result.result.rows[0].values[0].int-value 40))
      (t.is after-age-result.result.ok)
      (t.is (= (count after-age-result.result.rows) 1))
      (t.is (= after-age-result.result.rows[0].values[0].kind .Int))
      (t.is (= after-age-result.result.rows[0].values[0].int-value 41))
      (t.is after-birthday-result.result.ok)
      (t.is (= (count after-birthday-result.result.rows) 1))
      (t.is (= after-birthday-result.result.rows[0].values[0].kind .Bool))
      (t.is after-birthday-result.result.rows[0].values[0].bool-value)
      (t.is after-label-result.result.ok)
      (t.is (= (count after-label-result.result.rows) 1))
      (t.is (= after-label-result.result.rows[0].values[0].kind .String))
      (t.is (= after-label-result.result.rows[0].values[0].text "after-call"))
      (t.is combined-result.result.ok)
      (t.is (= (count combined-result.result.rows) 1))
      (t.is (= combined-result.result.rows[0].values[0].kind .Int))
      (t.is (= combined-result.result.rows[0].values[0].int-value 41))
      (t.is (= combined-result.result.rows[0].values[1].kind .String))
      (t.is (= combined-result.result.rows[0].values[1].text "after-call"))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-age-result)
      (vev.delete-query-result after-birthday-result)
      (vev.delete-query-result after-label-result)
      (vev.delete-query-result combined-result)
      (vev.delete-store-tx-report report)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

