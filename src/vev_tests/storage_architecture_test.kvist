(t.deftest sqlite-store-report-direct-write-supports-tx-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-tx-metadata.sqlite")
  (let [path "tmp.vev.store-report-direct-tx-metadata.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id \"datomic.tx\" :request/id \"req-1\" :tx/reason :profile-edit} [:db/add 2 :user/name \"Grace\"]]")
            tx-props (vev.q-result-store-text (addr reopened) "[:find ?a ?v :where [?tx :request/id \"req-1\"] [?tx ?a ?v]]")
            tx-instant (vev.q-result-store-text-with-input-text
                         (addr reopened)
                         "[:find ?instant . :in $ ?tx :where [?tx :db/txInstant ?instant]]"
                         (fmt.tprintf "[%d]" report.tx))
            [current-tx current-tx-ok] (vev.tempid-lookup (slice report.tempids 0) ":db/current-tx")
            [datomic-tx datomic-tx-ok] (vev.tempid-lookup (slice report.tempids 0) "datomic.tx")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is current-tx-ok)
        (t.is datomic-tx-ok)
        (t.is (= current-tx report.tx))
        (t.is (= datomic-tx report.tx))
        (t.is (= (count report.tx-meta) 3))
        (t.is (= report.tx-meta[0].a ":request/id"))
        (t.is (= report.tx-meta[0].v.text "req-1"))
        (t.is (= report.tx-meta[1].a ":tx/reason"))
        (t.is (= report.tx-meta[1].v.text ":profile-edit"))
        (t.is tx-props.result.ok tx-props.result.error)
        (t.is (>= (count tx-props.result.rows) 3))
        (t.is (result-has-keyword-string-row? tx-props.result ":request/id" "req-1"))
        (t.is (result-has-keyword-string-row? tx-props.result ":tx/reason" ":profile-edit"))
        (t.is tx-instant.result.ok tx-instant.result.error)
        (t.is (= (count tx-instant.result.rows) 1))
        (t.is (= tx-instant.result.rows[0].values[0].kind .Instant))
        (vev.delete-query-result tx-props)
        (vev.delete-query-result tx-instant)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-supports-current-tx-tempids
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-current-tx-tempids.sqlite")
  (let [path "tmp.vev.store-report-direct-current-tx-tempids.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :created-at :db/valueType :db.type/ref}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[[:db/add 10 :user/name \"X\"] [:db/add 10 :created-at :db/current-tx] [:db/add :db/current-tx :prop1 \"prop1\"] [:db/add \"datomic.tx\" :prop2 \"prop2\"] [:db/add \"datascript.tx\" :prop3 \"prop3\"]]")
            tx-result (vev.q-result-store-text (addr reopened) "[:find ?tx :where [10 :created-at ?tx]]")
            props-result (vev.q-result-store-text (addr reopened) "[:find ?p :where [?tx :prop1 \"prop1\"] [?tx ?p _]]")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (for [tempid report.tempids]
          (t.is (= tempid.e report.tx)))
        (t.is tx-result.result.ok tx-result.result.error)
        (t.is (= (count tx-result.result.rows) 1))
        (t.is (= tx-result.result.rows[0].values[0].entity report.tx))
        (t.is props-result.result.ok props-result.result.error)
        (t.is (= (count props-result.result.rows) 4))
        (vev.delete-query-result tx-result)
        (vev.delete-query-result props-result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-supports-tuple-upsert-with-tempid-component
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-tuple-tempid-upsert.sqlite")
  (let [path "tmp.vev.store-report-direct-tuple-tempid-upsert.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text
               (addr store)
               "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref} {:db/id 102 :db/ident :user/friend+code :db/valueType :db.type/tuple :db/tupleAttrs [:user/friend :user/code] :db/unique :db.unique/identity} {:db/id 1 :user/email \"ada@example.com\"} {:db/id 2 :user/friend 1 :user/code \"grace-code\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id \"grace\" :user/name \"Grace\" :user/friend \"ada\" :user/code \"grace-code\"} {:db/id \"ada\" :user/email \"ada@example.com\"}]")
            after-write (vev.q-result-store-text (addr reopened) "[:find ?name :where [2 :user/name ?name]]")
            [ada-e ada-ok] (vev.tempid-lookup (slice report.tempids 0) "ada")
            [grace-e grace-ok] (vev.tempid-lookup (slice report.tempids 0) "grace")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is ada-ok)
        (t.is (= ada-e 1))
        (t.is grace-ok)
        (t.is (= grace-e 2))
        (t.is after-write.result.ok after-write.result.error)
        (t.is (= (count after-write.result.rows) 1))
        (t.is (result-has-string-row? after-write.result "Grace"))
        (vev.delete-query-result after-write)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-db-with-text-keeps-source-overlay-next-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-with.sqlite")
  (let [path "tmp.vev.store-db-with.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          next-snapshot (vev.db-with-store-db-text (addr snapshot) "[{:db/id 2 :user/name \"Grace\"}]")
          retained-next (vev.retain-store-db next-snapshot)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= snapshot.kind .SQLite-Snapshot))
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is (= retained-next.kind .SQLite-Tx-Ops-Overlay))
      (t.is (not (= retained-next.sqlite-root-path "")))
      (t.is (= retained-next.sqlite-snapshot.path ""))
      (let [original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
            next-result (vev.q-result-store-db-text (addr retained-next) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is (= retained-next.kind .SQLite-Tx-Ops-Overlay))
        (t.is (not (= retained-next.sqlite-root-path "")))
        (t.is (not (= retained-next.sqlite-snapshot.path "")))
        (t.is (> (vev.store-db-sqlite-page-cache-count (addr retained-next)) 0))
        (t.is original-result.result.ok)
        (t.is (= (count original-result.result.rows) 1))
        (t.is (result-has-string-row? original-result.result "Ada"))
        (t.is next-result.result.ok)
        (t.is (= (count next-result.result.rows) 2))
        (t.is (result-has-string-row? next-result.result "Ada"))
        (t.is (result-has-string-row? next-result.result "Grace"))
        (vev.delete-query-result original-result)
        (vev.delete-query-result next-result))
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store-db! (addr retained-next))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-with-chained-overlays-preserves-tx-identity
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-with-chained-overlays.sqlite")
  (let [path "tmp.vev.store-db-with-chained-overlays.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          first-overlay (vev.db-with-store-db-text (addr snapshot) "[[:db/add 2 :user/name \"Grace\"]]")
          second-overlay (vev.db-with-store-db-text (addr first-overlay) "[[:db/add 3 :user/name \"Barbara\"]]")
          third-overlay (vev.db-with-store-db-text (addr second-overlay) "[[:db/add 4 :user/name \"Dorothy\"]]")
          tx-result (vev.q-result-store-db-text (addr third-overlay) "[:find ?name ?tx :where [?e :user/name ?name ?tx]]")
          [second-log-refs second-log-refs-ok] (vev.shared-datom-log-ref-count-at second-overlay.overlay-log 0)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= first-overlay.kind .SQLite-Tx-Ops-Overlay))
      (t.is (= second-overlay.kind .SQLite-Datom-Log-Overlay))
      (t.is (= third-overlay.kind .SQLite-Datom-Log-Overlay))
      (t.is second-log-refs-ok)
      (t.is (= second-log-refs 2))
      (t.is tx-result.result.ok)
      (t.is (= (count tx-result.result.rows) 4))
      (t.is (result-has-string-entity-row? tx-result.result "Ada" write-report.tx))
      (t.is (result-has-string-entity-row? tx-result.result "Grace" (+ write-report.tx 1)))
      (t.is (result-has-string-entity-row? tx-result.result "Barbara" (+ write-report.tx 2)))
      (t.is (result-has-string-entity-row? tx-result.result "Dorothy" (+ write-report.tx 3)))
      (vev.delete-query-result tx-result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr first-overlay))
      (vev.close-store-db! (addr second-overlay))
      (vev.close-store-db! (addr third-overlay))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-with-same-tx-cardinality-many-map-collection-keeps-source-overlay
