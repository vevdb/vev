      (t.is (= lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= lookup-ref-result.rows[0].values[0].text "Ada"))
      (t.is (not non-unique-lookup-ref-result.ok))
      (t.is (= non-unique-lookup-ref-result.error "lookup ref attribute must be unique"))
      (t.is tuple-lookup-ref-result.ok)
      (t.is (= tuple-lookup-ref-result.error ""))
      (t.is (= (count tuple-lookup-ref-result.rows) 1))
      (t.is (= tuple-lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= tuple-lookup-ref-result.rows[0].values[0].text "ada@example.com"))
      (t.is tuple-ref-direct-result.ok)
      (t.is (= tuple-ref-direct-result.error ""))
      (t.is (= (count tuple-ref-direct-result.rows) 1))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].kind .Vector))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[0].kind .Entity))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[0].entity 1))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[1].kind .String))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[1].text "grace-code"))
      (t.is tuple-ref-lookup-ref-result.ok)
      (t.is (= tuple-ref-lookup-ref-result.error ""))
      (t.is (= (count tuple-ref-lookup-ref-result.rows) 1))
      (t.is (= tuple-ref-lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= tuple-ref-lookup-ref-result.rows[0].values[0].text "Grace"))
      (t.is bound-entity-result.ok)
      (t.is (= bound-entity-result.error ""))
      (t.is (= (count bound-entity-result.rows) 1))
      (t.is (= bound-entity-result.rows[0].values[0].kind .String))
      (t.is (= bound-entity-result.rows[0].values[0].text "ada@example.com"))
      (t.is function-result.ok)
      (t.is (= function-result.error ""))
      (t.is (= (count function-result.rows) 1))
      (t.is (= (count function-result.rows[0].values) 2))
      (t.is (= function-result.rows[0].values[0].kind .String))
      (t.is (= function-result.rows[0].values[0].text "Ada"))
      (t.is (= function-result.rows[0].values[1].kind .Int))
      (t.is (= function-result.rows[0].values[1].int-value 3))
      (t.is tuple-function-result.ok)
      (t.is (= tuple-function-result.error ""))
      (t.is (= (count tuple-function-result.rows) 1))
      (t.is (= (count tuple-function-result.rows[0].values) 2))
      (t.is (= tuple-function-result.rows[0].values[0].kind .String))
      (t.is (= tuple-function-result.rows[0].values[0].text "Ada"))
      (t.is (= tuple-function-result.rows[0].values[1].kind .Entity))
      (t.is (= tuple-function-result.rows[0].values[1].entity 1))
      (t.is or-result.ok)
      (t.is (= or-result.error ""))
      (t.is (= (count or-result.rows) 2))
      (t.is (result-has-string-row? or-result "Ada"))
      (t.is (result-has-string-row? or-result "Grace"))
      (t.is or-join-result.ok)
      (t.is (= or-join-result.error ""))
      (t.is (= (count or-join-result.rows) 2))
      (t.is (result-has-string-row? or-join-result "Ada"))
      (t.is (result-has-string-row? or-join-result "Grace"))
      (t.is named-source-result.ok)
      (t.is (= named-source-result.error ""))
      (t.is (= (count named-source-result.rows) 1))
      (t.is (= named-source-result.rows[0].values[0].kind .String))
      (t.is (= named-source-result.rows[0].values[0].text "Ada"))
      (vev.delete-owned-datoms emails)
      (vev.delete-owned-datoms ada-email)
      (vev.delete-owned-datoms grace-email)
      (vev.delete-owned-value ada-name-value)
      (vev.delete-result-set-owned-values join-result)
      (vev.delete-result-set-owned-values source-qualified-result)
      (vev.delete-result-set-owned-values predicate-result)
      (vev.delete-result-set-owned-values predicate-empty-result)
      (vev.delete-result-set-owned-values lookup-ref-result)
      (vev.delete-result-set-owned-values non-unique-lookup-ref-result)
      (vev.delete-result-set-owned-values tuple-lookup-ref-result)
      (vev.delete-result-set-owned-values tuple-ref-direct-result)
      (vev.delete-result-set-owned-values tuple-ref-lookup-ref-result)
      (vev.delete-result-set-owned-values bound-entity-result)
      (vev.delete-query-shallow prepared.query)
      (vev.delete-query-shallow prepared-input.query)
      (vev.delete-query-result durable-text-result)
      (vev.delete-query-result durable-prepared-result)
      (vev.delete-query-result durable-input-result)
      (vev.delete-query-result durable-prepared-input-result)
      (vev.delete-query-result durable-pull-result)
      (vev.delete-query-result durable-aggregate-result)
      (vev.delete-query-result source-only-result)
      (vev.delete-query-result source-only-input-result)
      (vev.delete-query-result source-only-prepared-input-result)
      (vev.delete-query-result source-store-db-result)
      (vev.delete-query-result source-store-db-one-attr-result)
      (vev.delete-query-result source-store-db-filtered-result)
      (vev.delete-query-result source-store-db-filtered-retracted-result)
      (vev.delete-query-result source-store-db-fixed-entity-result)
      (vev.delete-query-result source-store-db-fixed-entity-missing-result)
      (vev.delete-query-result source-store-db-two-attr-result)
      (vev.delete-profiled-result-set-owned-values source-store-db-selective-two-attr-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-value-ref-attr-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-value-ref-attr-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-value-ref-star-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-value-ref-star-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-multi-hop-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-multi-hop-shuffled-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-two-branch-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-two-branch-shuffled-input-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-three-attr-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-star-attr-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-star-many-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-range-star-profiled)
      (vev.delete-profiled-result-set-owned-values source-store-db-range-star-many-profiled)
      (vev.delete-owned-value source-store-db-pull)
      (vev.close-store-db! (addr source-store-db))
      (vev.delete-tx-report-shallow source-only-tx-report)
      (vev.close-store source-store)
      (vev.delete-result-set-owned-values function-result)
      (vev.delete-result-set-owned-values tuple-function-result)
      (vev.delete-result-set-owned-values or-result)
      (vev.delete-result-set-owned-values or-join-result)
      (vev.delete-result-set-owned-values named-source-result))
    (vev.close-sqlite-db-snapshot! (addr snapshot))
    (vev.close-sqlite-conn store)))

(t.deftest store-db-source-typed-column-batches-avoid-row-materialization
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.source-typed-column-batches.sqlite")
  (let [path "tmp.vev.source-typed-column-batches.sqlite"
        [store store-ok store-error] (vev.open-store path)]
    (t.is store-ok)
    (t.is (= store-error ""))
      (let [report (vev.transact-store-report-text
                   (addr store)
                   "[{:db/id 100 :db/ident :user/friend :db/valueType :db.type/ref}
                     {:db/id 101 :db/ident :user/email :db/valueType :db.type/string :db/unique :db.unique/identity}
                     {:db/id 1 :user/name \"Ada\" :user/email \"ada@example.test\" :user/age 42}
                     {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.test\" :user/age 71 :user/friend 1}
                     {:db/id 3 :user/name \"Ada\" :user/email \"ada-2@example.test\" :user/age 42 :user/friend 1}]")
          snapshot (vev.retain-store-db report.db-after)]
      (t.is report.ok report.error)
      (let [[source source-ok source-error] (vev.store-db-read-source (addr snapshot))
            entity-query (vev.prepare-query-text "[:find ?e :where [?e :user/name \"Ada\"]]")
            text-query (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name]]")
            filtered-text-query (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
            int-query (vev.prepare-query-text "[:find ?age :where [?e :user/age ?age]]")
            pair-query (vev.prepare-query-text "[:find ?e ?age :where [?e :user/name \"Ada\"] [?e :user/age ?age]]")
            string-pair-query (vev.prepare-query-text "[:find ?e ?email :where [?e :user/name \"Ada\"] [?e :user/email ?email]]")
            string-int-query (vev.prepare-query-text "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]")
            string-string-query (vev.prepare-query-text "[:find ?name ?email :where [?e :user/name ?name] [?e :user/email ?email]]")
            triple-query (vev.prepare-query-text "[:find ?e ?email ?age :where [?e :user/name \"Ada\"] [?e :user/email ?email] [?e :user/age ?age]]")
            wide-query (vev.prepare-query-text "[:find ?e ?name ?email ?age :where [?e :user/name ?name] [?e :user/email ?email] [?e :user/age ?age]]")
            predicate-query (vev.prepare-query-text "[:find ?e ?age :where [?e :user/age ?age] [(> ?age 50)]]")
            reverse-query (vev.prepare-query-text "[:find ?parent ?child :where [?parent :_user/friend ?child]]")
            reverse-bound-query (vev.prepare-query-text "[:find ?child :where [1 :_user/friend ?child]]")
            int-entity-query (vev.prepare-query-text "[:find ?name :where [1 :user/name ?name]]")
            ref-literal-query (vev.prepare-query-text "[:find ?e :where [?e :user/friend 1]]")
            lookup-ref-query (vev.prepare-query-text "[:find ?name :where [[:user/email \"ada@example.test\"] :user/name ?name]]")
            not-query (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name] (not [?e :user/friend])]")
            or-query (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name] (or-join [?e] [?e :user/email \"ada@example.test\"] [?e :user/age 71])]")
            aggregate-query (vev.prepare-query-text "[:find ?name (count ?e) :where [?e :user/name ?name]]")
            pull-query (vev.prepare-query-text "[:find (pull ?e [:user/name {:user/friend [:user/name]}]) :where [?e :user/name \"Ada\"]]")
            pull-aggregate-query (vev.prepare-query-text "[:find ?e (pull ?e [:user/name]) (count ?friend) :where [?e :user/name \"Ada\"] [?e :user/friend ?friend]]")
            [entities entities-ok entities-error] (vev.q-db-read-source-entity-column source entity-query.query ([]vev.Query-Input []))
            [names names-ok names-error] (vev.q-db-read-source-string-column source text-query.query ([]vev.Query-Input []))
            [filtered-names filtered-names-ok filtered-names-error] (vev.q-db-read-source-string-column source filtered-text-query.query ([]vev.Query-Input []))
            [ages ages-ok ages-error] (vev.q-db-read-source-int-column source int-query.query ([]vev.Query-Input []))
            [pairs pairs-ok pairs-error] (vev.q-db-read-source-entity-int-pair-columns source pair-query.query ([]vev.Query-Input []))
            [string-pairs string-pairs-ok string-pairs-error] (vev.q-db-read-source-entity-string-pair-columns source string-pair-query.query ([]vev.Query-Input []))
            [string-int-pairs string-int-pairs-ok string-int-pairs-error] (vev.q-db-read-source-string-int-pair-columns source string-int-query.query ([]vev.Query-Input []))
            [string-string-pairs string-string-pairs-ok string-string-pairs-error] (vev.q-db-read-source-string-string-pair-columns source string-string-query.query ([]vev.Query-Input []))
            [triples triples-ok triples-error] (vev.q-db-read-source-entity-string-int-triples source triple-query.query ([]vev.Query-Input []))
            [wide-rel wide-stats wide-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) wide-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            wide-plan (vev.query-typed-flat-result-plan wide-query.query wide-rel)
            [reverse-rel reverse-stats reverse-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) reverse-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [reverse-bound-rel reverse-bound-stats reverse-bound-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) reverse-bound-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [int-entity-rel int-entity-stats int-entity-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) int-entity-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [ref-literal-rel ref-literal-stats ref-literal-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) ref-literal-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [lookup-ref-rel lookup-ref-stats lookup-ref-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) lookup-ref-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [not-rel not-stats not-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) not-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [or-rel or-stats or-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) or-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [aggregate-base-rel aggregate-stats aggregate-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) aggregate-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [pull-rel pull-stats pull-used] (vev.db-read-source-query-relation-value-typed-with-sources-inputs-and-fns source ([]vev.DB-Read-Named-Source []) pull-query.query ([]vev.Query-Input []) ([]vev.Native-Query-Fn []))
            [pull-batch pull-batch-ok pull-batch-error] (vev.materialize-source-typed-pull-batch source ([]vev.DB-Read-Named-Source []) pull-query.query ([]vev.Query-Input []) pull-rel ([]vev.Native-Query-Fn []))
            [aggregate-rel aggregate-rel-ok] (vev.aggregate-query-relation-for-typed-relation aggregate-query.query aggregate-base-rel)
            aggregate-plan (vev.typed-flat-result-plan-for-output-relation aggregate-rel)
            pull-aggregate-result (vev.q-result-store-db-text (addr snapshot) "[:find ?e (pull ?e [:user/name]) (count ?friend) :where [?e :user/name \"Ada\"] [?e :user/friend ?friend]]")
            [range-pairs range-pairs-ok range-pairs-error] (vev.q-db-read-source-entity-int-range-pair-columns source predicate-query.query ([]vev.Query-Input []))]
        (t.is source-ok source-error)
        (t.is entity-query.ok entity-query.error)
        (t.is text-query.ok text-query.error)
        (t.is filtered-text-query.ok filtered-text-query.error)
        (t.is int-query.ok int-query.error)
        (t.is pair-query.ok pair-query.error)
        (t.is string-pair-query.ok string-pair-query.error)
        (t.is string-int-query.ok string-int-query.error)
        (t.is string-string-query.ok string-string-query.error)
        (t.is triple-query.ok triple-query.error)
        (t.is wide-query.ok wide-query.error)
        (t.is predicate-query.ok predicate-query.error)
        (t.is reverse-query.ok reverse-query.error)
        (t.is reverse-bound-query.ok reverse-bound-query.error)
        (t.is int-entity-query.ok int-entity-query.error)
        (t.is ref-literal-query.ok ref-literal-query.error)
        (t.is lookup-ref-query.ok lookup-ref-query.error)
        (t.is not-query.ok not-query.error)
        (t.is or-query.ok or-query.error)
        (t.is aggregate-query.ok aggregate-query.error)
        (t.is pull-query.ok pull-query.error)
        (t.is pull-aggregate-query.ok pull-aggregate-query.error)
        (t.is entities-ok entities-error)
        (t.is (= (count entities) 2))
        (t.is (or (= entities[0] 1) (= entities[1] 1)))
        (t.is (or (= entities[0] 3) (= entities[1] 3)))
        (t.is names-ok names-error)
        (t.is (= (count names) 2))
        (t.is (or (= names[0] "Ada") (= names[1] "Ada")))
        (t.is (or (= names[0] "Grace") (= names[1] "Grace")))
        (t.is filtered-names-ok filtered-names-error)
        (t.is (= (count filtered-names) 1))
        (t.is (= filtered-names[0] "Ada"))
        (t.is ages-ok ages-error)
        (t.is (= (count ages) 2))
        (t.is (or (= ages[0] 42) (= ages[1] 42)))
        (t.is (or (= ages[0] 71) (= ages[1] 71)))
        (t.is pairs-ok pairs-error)
        (t.is (= (count pairs.entities) 2))
        (t.is (= (count pairs.values) 2))
        (t.is (or (and (= pairs.entities[0] 1) (= pairs.values[0] 42))
                  (and (= pairs.entities[1] 1) (= pairs.values[1] 42))))
        (t.is (or (and (= pairs.entities[0] 3) (= pairs.values[0] 42))
