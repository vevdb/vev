(defn result-has-keyword-string-row? [result: vev.Result-Set, attr: string, value: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (or (= row.values[0].kind .String)
                   (= row.values[0].kind .Keyword))
               (= row.values[0].text attr)
               (or (= row.values[1].kind .String)
                   (= row.values[1].kind .Keyword))
               (= row.values[1].text value))
      (return true)))
  false)

(defn native-tag-value [value: vev.Value] -> vev.Native-Query-Function-Result
  (when (not (= value.kind .String))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result
    (vev.value-string (fmt.tprintf "tag:%s" value.text))))

(defn store-source-birthday-by-name [source: vev.DB-Read-Source, name: string] -> vev.Tx-Fn-Source-Result
  (let [[datoms datoms-ok datoms-error] (vev.db-read-source-datoms-by-attr source ":user/name")]
    (when (not datoms-ok)
      (return (vev.tx-fn-source-error datoms-error)))
    (defer (vev.delete-owned-datoms datoms))
    (for [datom datoms]
      (when (and (= datom.v.kind .String)
                 (= datom.v.text name))
        (let [[age age-ok age-error] (vev.db-read-source-cardinality-one-value-fast-all-current source datom.e ":user/age")]
          (when (not age-ok)
            (return (vev.tx-fn-source-error (if (= age-error "") "No age for entity" age-error))))
          (defer (vev.delete-owned-value age))
          (let [tx-data (make [dynamic]vev.Tx-Data) :defer
                _ (arr.push! tx-data (vev.add datom.e ":user/age" (vev.value-int (+ age.int-value 1))))
                _ (arr.push! tx-data (vev.add datom.e ":user/had-birthday" (vev.value-bool true)))]
            (return (vev.tx-fn-source-ok (slice tx-data 0)))))))
    (vev.tx-fn-source-error "No entity with name")))

(defn store-source-increase-age-by-values [source: vev.DB-Read-Source, args: []vev.Value] -> vev.Tx-Fn-Source-Result
  (when (not (= (count args) 2))
    (return (vev.tx-fn-source-error "inc-age-by expects name and delta")))
  (when (not (= args[0].kind .String))
    (return (vev.tx-fn-source-error "inc-age-by expects string name")))
  (when (not (= args[1].kind .Int))
    (return (vev.tx-fn-source-error "inc-age-by expects int delta")))
  (let [name args[0].text
        delta args[1].int-value
        [datoms datoms-ok datoms-error] (vev.db-read-source-datoms-by-attr source ":user/name")]
    (when (not datoms-ok)
      (return (vev.tx-fn-source-error datoms-error)))
    (defer (vev.delete-owned-datoms datoms))
    (for [datom datoms]
      (when (and (= datom.v.kind .String)
                 (= datom.v.text name))
        (let [[age age-ok age-error] (vev.db-read-source-cardinality-one-value-fast-all-current source datom.e ":user/age")]
          (when (not age-ok)
            (return (vev.tx-fn-source-error (if (= age-error "") "No age for entity" age-error))))
          (defer (vev.delete-owned-value age))
          (let [tx-data (make [dynamic]vev.Tx-Data) :defer
                _ (arr.push! tx-data (vev.add datom.e ":user/age" (vev.value-int (+ age.int-value delta))))
                _ (arr.push! tx-data (vev.add datom.e ":user/age-adjusted" (vev.value-bool true)))]
            (return (vev.tx-fn-source-ok (slice tx-data 0)))))))
    (vev.tx-fn-source-error "No entity with name")))

(defn store-source-add-user [source: vev.DB-Read-Source, name: string] -> vev.Tx-Fn-Source-Result
  (let [tx-data (make [dynamic]vev.Tx-Data) :defer
        _ (arr.push! tx-data (vev.add-tempid "new-user" ":user/name" (vev.value-string name)))]
    (vev.tx-fn-source-ok (slice tx-data 0))))

(defn store-source-noop [source: vev.DB-Read-Source, name: string] -> vev.Tx-Fn-Source-Result
  (let [tx-data (make [dynamic]vev.Tx-Data) :defer]
    (vev.tx-fn-source-ok (slice tx-data 0))))

(t.deftest resident-query-result-wrappers-own-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :user/name "Ada" :user/age 37}])
        prepared (vev.prepare-query-text "[:find ?name :where [1 :user/name ?name]]")
        text-result (vev.q-result-text conn.db "[:find ?name :where [1 :user/name ?name]]")
        prepared-result (vev.q-result-prepared conn.db prepared)
        text-profiled (vev.q-text-profiled conn.db "[:find ?name :where [1 :user/name ?name]]")
        prepared-profiled (vev.q-prepared-profiled conn.db prepared)
        resident-source (vev.resident-db-read-source (addr conn.db))
        [range-low range-high range-exists range-ok range-error] (vev.db-read-source-eavt-entity-range resident-source 1)
        [name-value name-value-ok name-value-error] (vev.db-read-source-cardinality-one-value-fast-all-current resident-source 1 ":user/name")
        [age-value age-value-ok age-value-error] (vev.db-read-source-cardinality-one-int-value-fast-all-current resident-source 1 ":user/age")
        [name-matches name-matches-ok name-matches-error] (vev.db-read-source-cardinality-one-value-matches-fast-all-current? resident-source 1 ":user/name" (vev.value-string "Ada"))]
    (t.is report.ok)
    (t.is prepared.ok)
    (t.is range-ok)
    (t.is (= range-error ""))
    (t.is range-exists)
    (t.is (> range-high range-low))
    (t.is name-value-ok)
    (t.is (= name-value-error ""))
    (t.is (= name-value.kind .String))
    (t.is (= name-value.text "Ada"))
    (t.is age-value-ok)
    (t.is (= age-value-error ""))
    (t.is (= age-value 37))
    (t.is name-matches-ok)
    (t.is (= name-matches-error ""))
    (t.is name-matches)
    (t.is (vev.query-result-owns-values? text-result))
    (t.is (= (count text-result.result.rows) 1))
    (t.is (= text-result.result.rows[0].values[0].kind .String))
    (t.is (= text-result.result.rows[0].values[0].text "Ada"))
    (t.is (vev.query-result-owns-values? prepared-result))
    (t.is (= (count prepared-result.result.rows) 1))
    (t.is (= prepared-result.result.rows[0].values[0].kind .String))
    (t.is (= prepared-result.result.rows[0].values[0].text "Ada"))
    (t.is text-profiled.result.ok text-profiled.result.error)
    (t.is (= (count text-profiled.result.rows) 1))
    (t.is (> text-profiled.stats.typed-index-scans 0))
    (t.is (= text-profiled.stats.generic-materialization-steps 0))
    (t.is prepared-profiled.result.ok prepared-profiled.result.error)
    (t.is (= (count prepared-profiled.result.rows) 1))
    (t.is (> prepared-profiled.stats.typed-index-scans 0))
    (t.is (= prepared-profiled.stats.generic-materialization-steps 0))
    (vev.delete-query-result text-result)
    (vev.delete-query-result prepared-result)
    (vev.delete-profiled-result-set-owned-values text-profiled)
    (vev.delete-profiled-result-set-owned-values prepared-profiled)
    (vev.delete-owned-value name-value)
    (vev.delete-query-shallow prepared.query)
    (vev.delete-owned-db conn.db)
    (delete conn.listeners)))

(t.deftest resident-transact-validates-new-unique-schema-against-existing-duplicates
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        seed (vev.transact-text
               (addr conn)
               "[{:db/id 100 :db/ident :user/email} {:db/id 1 :user/email \"ada@example.com\"} {:db/id 2 :user/email \"ada@example.com\"}]")
        unique (vev.transact-text (addr conn) "[[:db/add 100 :db/unique :db.unique/value]]")]
    (t.is seed.ok seed.error)
    (t.is (not unique.ok))
    (t.is (= unique.error "schema unique conflict"))
    (vev.delete-tx-report-shallow seed)
    (vev.delete-tx-report-shallow unique)
    (vev.delete-owned-db conn.db)
    (delete conn.listeners)))

(t.deftest sqlite-initializes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture.sqlite")
  (let [path "tmp.vev.storage-architecture.sqlite"
        [architecture architecture-ok architecture-error] (vev.sqlite-storage-architecture path)
        [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
        [root-page-count root-page-count-ok root-page-count-error] (vev.sqlite-index-root-page-count path)
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
        [manifest-count manifest-count-ok manifest-count-error] (vev.sqlite-index-run-manifest-count path)
        [_ latest-ok latest-error] (vev.sqlite-latest-index-root-basis path)]
    (defer (remove-sqlite-files path))
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 0))
    (t.is root-page-count-ok)
    (t.is (= root-page-count-error ""))
    (t.is (= root-page-count 0))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 0))
    (t.is manifest-count-ok)
    (t.is (= manifest-count-error ""))
    (t.is (= manifest-count 0))
    (t.is (not latest-ok))
    (t.is (= latest-error "sqlite DB has no Vev index roots"))))

(t.deftest fresh-sqlite-store-has-readable-empty-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.fresh-readable-store.sqlite")
  (let [path "tmp.vev.fresh-readable-store.sqlite"
        [store store-ok store-error] (vev.open-store path)]
    (defer (remove-sqlite-files path))
    (t.is store-ok store-error)
    (let [[snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
      (t.is snapshot-ok snapshot-error)
      (t.is (= snapshot.kind .Shared-Snapshot))
      (let [result (vev.q-result-store-db-text (addr snapshot) "[:find ?e :where [?e :item/name ?name]]")]
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 0))
        (vev.delete-query-result result))
      (vev.close-store-db! (addr snapshot)))
    (vev.close-store store)))

(t.deftest sqlite-index-run-manifest-schema-stores-base-and-runs
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-run-manifest.sqlite")
  (let [path "tmp.vev.storage-architecture-run-manifest.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\"} {:db/id 2 :user/name \"Grace\"}]")
        [before before-ok before-error] (vev.sqlite-index-run-manifest-count path)
        [manifest-id manifest-ok manifest-error] (vev.sqlite-create-index-run-manifest-for-test path ":aevt")
        [after after-ok after-error] (vev.sqlite-index-run-manifest-count path)
        [run-count run-count-ok run-count-error] (vev.sqlite-index-run-manifest-run-count-for-test path manifest-id)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok report.error)
    (t.is before-ok)
    (t.is (= before-error ""))
    (t.is (= before 0))
    (t.is manifest-ok)
    (t.is (= manifest-error ""))
    (t.is (> manifest-id 0))
    (t.is after-ok)
    (t.is (= after-error ""))
    (t.is (= after 1))
    (t.is run-count-ok)
    (t.is (= run-count-error ""))
    (t.is (= run-count 1))
    (vev.delete-tx-report-shallow report)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-live-connection-exposes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-live.sqlite")
  (let [path "tmp.vev.storage-architecture-live.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\"} {:db/id 2 :user/name \"Grace\"}]")
        second-report (vev.transact-sqlite-text
                        (addr store)
                        "[{:db/id 3 :user/name \"Frances\"}]")
        [architecture architecture-ok architecture-error] (vev.sqlite-conn-storage-architecture (addr store))
        [root-count root-count-ok root-count-error] (vev.sqlite-conn-index-root-count (addr store))
        [root-page-count root-page-count-ok root-page-count-error] (vev.sqlite-conn-index-root-page-count (addr store))
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-conn-index-chunk-count (addr store))
        [basis basis-ok basis-error] (vev.sqlite-conn-latest-index-root-basis (addr store))
        [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":eavt")
        [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":aevt")
        [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":avet")
        [vaet-basis vaet-rows vaet-ok vaet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":vaet")
        [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-conn-latest-index-entries (addr store) ":eavt")
        [datom-count datom-count-ok datom-count-error] (vev.sqlite-conn-datom-count (addr store))
        [first-datom first-datom-ok first-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 0)
        [last-datom last-datom-ok last-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 4)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is second-report.ok)
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 2))
    (t.is root-page-count-ok)
    (t.is (= root-page-count-error ""))
    (t.is (= root-page-count 8))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 8))
    (t.is basis-ok)
    (t.is (= basis-error ""))
    (t.is (= basis second-report.tx))
    (t.is eavt-ok)
    (t.is (= eavt-error ""))
    (t.is (= eavt-basis second-report.tx))
    (t.is (= eavt-rows (u64 (count store.conn.db.eavt))))
    (t.is aevt-ok)
    (t.is (= aevt-error ""))
    (t.is (= aevt-basis second-report.tx))
    (t.is (= aevt-rows (u64 (count store.conn.db.aevt))))
    (t.is avet-ok)
    (t.is (= avet-error ""))
    (t.is (= avet-basis second-report.tx))
    (t.is (= avet-rows (u64 (count store.conn.db.avet))))
    (t.is vaet-ok)
    (t.is (= vaet-error ""))
    (t.is (= vaet-basis second-report.tx))
    (t.is (= vaet-rows (u64 (count store.conn.db.vaet))))
    (t.is loaded-eavt-ok)
    (t.is (= loaded-eavt-error ""))
    (t.is (int-slices-equal? (slice loaded-eavt 0) (slice store.conn.db.eavt 0)))
    (t.is datom-count-ok)
    (t.is (= datom-count-error ""))
    (t.is (= datom-count 5))
    (t.is first-datom-ok)
    (t.is (= first-datom-error ""))
    (t.is (= first-datom.e 1))
    (t.is (= first-datom.a ":user/name"))
    (t.is last-datom-ok)
    (t.is (= last-datom-error ""))
    (t.is (= last-datom.e second-report.tx))
    (t.is (= last-datom.a ":db/txInstant"))
    (t.is (= last-datom.v.kind .Instant))
    (delete loaded-eavt)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-store-db-retain-keeps-durable-snapshot-queryable
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-retain.sqlite")
  (let [path "tmp.vev.store-db-retain.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          retained (vev.retain-store-db snapshot)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= retained.kind .SQLite-Root-Snapshot))
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store)
      (let [retained-result (vev.q-result-store-db-text (addr retained) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is (= retained.kind .SQLite-Snapshot))
        (t.is retained-result.result.ok)
        (t.is (= retained-result.result.error ""))
        (t.is (= (count retained-result.result.rows) 1))
        (t.is (= retained-result.result.rows[0].values[0].kind .String))
        (t.is (= retained-result.result.rows[0].values[0].text "Ada"))
        (vev.delete-query-result retained-result)
        (vev.close-store-db! (addr retained))))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-at-basis-prefers-root-backed-snapshot
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-at-basis-root.sqlite")
  (let [path "tmp.vev.store-db-at-basis-root.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        first (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        second (vev.transact-store-report-text (addr store) "[{:db/id 2 :user/name \"Grace\"}]")
        [first-basis first-basis-ok first-basis-error] (vev.sqlite-conn-store-db-at-basis (addr store.sqlite) first.tx)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (t.is first.ok first.error)
    (t.is second.ok second.error)
    (t.is first-basis-ok first-basis-error)
    (t.is (= first-basis-error ""))
    (t.is (= first-basis.kind .SQLite-Root-Snapshot))
    (let [first-basis-result (vev.q-result-store-db-text (addr first-basis) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is first-basis-result.result.ok first-basis-result.result.error)
      (t.is (= (count first-basis-result.result.rows) 1))
      (t.is (result-has-string-row? first-basis-result.result "Ada"))
      (t.is (not (result-has-string-row? first-basis-result.result "Grace")))
      (vev.delete-query-result first-basis-result))
    (vev.close-store-db! (addr first-basis))
    (vev.delete-store-tx-report second)
    (vev.delete-store-tx-report first)
    (vev.close-store store)))

(t.deftest sqlite-source-backed-bound-ea-clause-tightens-value-range
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.source-bound-ea-range.sqlite")
  (let [path "tmp.vev.source-bound-ea-range.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text
                       (addr store)
                       "[[:db/add 1 :name \"Ada\"] [:db/add 1 :age 37] [:db/add 2 :name \"Grace\"] [:db/add 2 :age 41]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (t.is write-report.ok write-report.error)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          profiled (vev.q-profiled-store-db-text (addr snapshot) "[:find ?name :where [?e :name ?name] [?e :age ?age] [(> ?age 40)]]")]
      (t.is read-opened-ok read-opened-error)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok snapshot-error)
      (t.is (= snapshot-error ""))
      (t.is profiled.result.ok profiled.result.error)
      (t.is (= (count profiled.result.rows) 1))
      (t.is (= (count profiled.result.rows[0].values) 1))
      (t.is (= profiled.result.rows[0].values[0].kind .String))
      (t.is (= profiled.result.rows[0].values[0].text "Grace"))
      ;; The physical planner should choose the range-backed :age clause first,
      ;; then do one bound entity/attr lookup for :name.
      (t.is (= profiled.stats.clause-candidates 2))
      (t.is (> profiled.stats.source-index-scans 0))
      (t.is (= profiled.stats.binding-materializations 0))
      (vev.delete-profiled-result-set-owned-values profiled)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-writable-open-is-lazy-until-first-write
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-lazy-open.sqlite")
  (let [path "tmp.vev.store-db-lazy-open.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr reopened))
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr reopened))
          before-write (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [1 :user/name ?name]]")]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-read-only? (addr reopened))))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is tx-count-ok)
      (t.is (= tx-count-error ""))
      (t.is (= tx-count 1))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is before-write.result.ok before-write.result.error)
      (t.is (= (count before-write.result.rows) 1))
      (t.is (= before-write.result.rows[0].values[0].text "Ada"))
      (vev.delete-query-result before-write)
      (vev.close-store-db! (addr snapshot))
      (let [legacy-write (vev.transact-store-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            write (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            after-write (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is (not legacy-write.ok))
        (t.is (= legacy-write.error "transact-sqlite-tx-data is resident-only for reopened durable SQLite stores; use transact-sqlite-store-report-tx-data"))
        (t.is write.ok write.error)
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is after-write.result.ok after-write.result.error)
        (t.is (= (count after-write.result.rows) 2))
        (t.is (result-has-string-row? after-write.result "Ada"))
        (t.is (result-has-string-row? after-write.result "Grace"))
        (vev.delete-query-result after-write)
        (vev.delete-live-tx-report-shallow legacy-write)
        (vev.delete-store-tx-report write))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-first-write-stays-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-first-write.sqlite")
  (let [path "tmp.vev.store-report-first-write.sqlite"
        [store opened-ok opened-error] (vev.open-store path)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (let [report (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
          report-after-kind report.db-after.kind
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?name :where [?e :user/name ?name]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [?e :user/name ?name]]")
          live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
      (t.is report.ok report.error)
      (t.is (= report.db-before.kind .Shared-Snapshot))
      (t.is (= report-after-kind .SQLite-Root-Snapshot))
      (t.is report.source-append-metadata-known)
      (t.is report.source-published-root-known)
      (t.is (> report.source-published-root.root-row-id 0))
      (t.is report.source-eavt-append-mode)
      (t.is report.source-aevt-append-mode)
      (t.is report.source-avet-append-mode)
      (t.is report.source-vaet-append-mode)
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (t.is before-result.result.ok before-result.result.error)
      (t.is (= (count before-result.result.rows) 0))
      (t.is after-result.result.ok after-result.result.error)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (result-has-string-row? after-result.result "Ada"))
      (t.is live-result.result.ok live-result.result.error)
      (t.is (= (count live-result.result.rows) 1))
      (t.is (result-has-string-row? live-result.result "Ada"))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 1))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-query-result live-result)
      (vev.delete-store-tx-report report))
    (vev.close-store store)
    (let [[again again-ok again-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr again) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is again-ok)
      (t.is (= again-error ""))
      (t.is (not (vev.store-resident-db-available? (addr again))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (vev.delete-query-result reopened-result)
      (vev.close-store again))))

(t.deftest sqlite-store-live-current-root-cache-reuses-pages-across-queries
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-live-root-cache.sqlite")
  (let [path "tmp.vev.store-live-root-cache.sqlite"
        [store opened-ok opened-error] (vev.open-store path)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (t.is (= (vev.store-current-root-page-cache-count (addr store)) 0))
    (let [seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"} {:db/id 2 :user/name \"Grace\"} {:db/id 3 :user/name \"Hedy\"}]")]
      (t.is seed.ok seed.error)
      (vev.delete-store-tx-report seed))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (t.is (= (vev.store-current-root-page-cache-count (addr store)) 0))
    (let [first (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is first.result.ok first.result.error)
      (t.is (= (count first.result.rows) 3))
      (t.is (result-has-string-row? first.result "Ada"))
      (t.is (> (vev.store-current-root-page-cache-count (addr store)) 0))
      (t.is (> (vev.store-current-root-page-cache-miss-count (addr store)) 0))
      (let [hits-before-second (vev.store-current-root-page-cache-hit-count (addr store))
            second (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is second.result.ok second.result.error)
        (t.is (= (count second.result.rows) 3))
        (t.is (result-has-string-row? second.result "Grace"))
        (t.is (> (vev.store-current-root-page-cache-hit-count (addr store)) hits-before-second))
        (vev.delete-query-result second))
      (vev.delete-query-result first))
    (let [write (vev.transact-store-report-text (addr store) "[{:db/id 4 :user/name \"Barbara\"}]")]
      (t.is write.ok write.error)
      (vev.delete-store-tx-report write))
    (t.is (= (vev.store-current-root-page-cache-count (addr store)) 0))
    (t.is (= (vev.store-current-root-page-cache-hit-count (addr store)) 0))
    (t.is (= (vev.store-current-root-page-cache-miss-count (addr store)) 0))
    (let [after-write (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is after-write.result.ok after-write.result.error)
      (t.is (= (count after-write.result.rows) 4))
      (t.is (result-has-string-row? after-write.result "Barbara"))
      (t.is (> (vev.store-current-root-page-cache-miss-count (addr store)) 0))
      (vev.delete-query-result after-write))
    (vev.close-store store)))

(t.deftest sqlite-store-source-fn-write-invalidates-current-root-cache
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-source-fn-root-cache.sqlite")
  (let [path "tmp.vev.store-source-fn-root-cache.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (let [seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")]
      (t.is seed.ok seed.error)
      (vev.delete-store-tx-report seed))
    (let [first (vev.q-result-store-text (addr store) "[:find ?age :where [1 :user/age ?age]]")]
      (t.is first.result.ok first.result.error)
      (t.is (= (count first.result.rows) 1))
      (t.is (> (vev.store-current-root-page-cache-count (addr store)) 0))
      (vev.delete-query-result first))
    (let [report (vev.transact-store-report-text-with-source-string-fns
                   (addr store)
                   "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"]]"
                   registry)]
      (t.is report.ok report.error)
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-store-tx-report report))
    (t.is (= (vev.store-current-root-page-cache-count (addr store)) 0))
    (t.is (= (vev.store-current-root-page-cache-hit-count (addr store)) 0))
    (t.is (= (vev.store-current-root-page-cache-miss-count (addr store)) 0))
    (let [after-write (vev.q-result-store-text (addr store) "[:find ?age :where [1 :user/age ?age]]")]
      (t.is after-write.result.ok after-write.result.error)
      (t.is (= (count after-write.result.rows) 1))
      (t.is (= after-write.result.rows[0].values[0].kind .Int))
      (t.is (= after-write.result.rows[0].values[0].int-value 41))
      (t.is (> (vev.store-current-root-page-cache-miss-count (addr store)) 0))
      (vev.delete-query-result after-write))
    (vev.close-store store)))

(t.deftest sqlite-store-current-root-tracks-root-row-id-separately-from-basis
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-root-row-id-vs-basis.sqlite")
  (let [path "tmp.vev.store-root-row-id-vs-basis.sqlite"
        [store opened-ok opened-error] (vev.open-store path)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (let [seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
      (t.is seed.ok seed.error)
      (vev.delete-store-tx-report seed))
    (let [[basis basis-ok basis-error] (vev.sqlite-conn-latest-index-root-basis (addr store.sqlite))
          [republished-row republish-ok republish-error] (vev.sqlite-republish-latest-index-root-set! store.sqlite.handle basis)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))]
      (t.is basis-ok basis-error)
      (t.is republish-ok republish-error)
      (t.is (> republished-row basis))
      (t.is snapshot-ok snapshot-error)
      (t.is (= snapshot.kind .SQLite-Root-Snapshot))
      (t.is (= snapshot.sqlite-root-published.root-row-id republished-row))
      (t.is (= snapshot.sqlite-root-published.basis-tx basis))
      (let [result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (= result.result.rows[0].values[0].text "Ada"))
        (vev.delete-query-result result))
      (t.is (= snapshot.kind .SQLite-Snapshot))
      (t.is (= snapshot.sqlite-snapshot.root-row-id republished-row))
      (t.is (= snapshot.sqlite-snapshot.basis-tx basis))
      (t.is (> (vev.store-db-sqlite-page-cache-count (addr snapshot)) 0))
      (let [retained (vev.retain-store-db snapshot)]
        (t.is (= retained.kind .SQLite-Root-Snapshot))
        (t.is (= retained.sqlite-root-published.root-row-id republished-row))
        (t.is (= retained.sqlite-root-published.basis-tx basis))
        (t.is (> (vev.store-db-sqlite-page-cache-count (addr retained)) 0))
        (vev.close-store-db retained))
      (let [overlay (vev.db-with-store-db-text (addr snapshot) "[{:db/id 2 :user/name \"Grace\"}]")]
        (t.is (= overlay.kind .SQLite-Tx-Ops-Overlay))
        (t.is (= overlay.sqlite-root-published.root-row-id republished-row))
        (t.is (= overlay.sqlite-root-published.basis-tx basis))
        (t.is (> (vev.store-db-sqlite-page-cache-count (addr overlay)) 0))
        (let [overlay-result (vev.q-result-store-db-text (addr overlay) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is overlay-result.result.ok overlay-result.result.error)
          (t.is (= (count overlay-result.result.rows) 2))
          (t.is (result-has-string-row? overlay-result.result "Ada"))
          (t.is (result-has-string-row? overlay-result.result "Grace"))
          (vev.delete-query-result overlay-result))
        (vev.close-store-db overlay))
      (vev.close-store-db snapshot))
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-db-with-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-db-with.sqlite")
  (let [path "tmp.vev.store-report-lazy-db-with.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is (= seed.db-after.kind .SQLite-Root-Snapshot))
    (let [next-snapshot (vev.db-with-store-db-text (addr seed.db-after) "[{:db/id 2 :user/name \"Grace\"}]")
          seed-result (vev.q-result-store-db-text (addr seed.db-after) "[:find ?name :where [?e :user/name ?name]]")
          next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?name :where [?e :user/name ?name]]")
          live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is seed-result.result.ok seed-result.result.error)
      (t.is (= (count seed-result.result.rows) 1))
      (t.is (result-has-string-row? seed-result.result "Ada"))
      (t.is next-result.result.ok next-result.result.error)
      (t.is (= (count next-result.result.rows) 2))
      (t.is (result-has-string-row? next-result.result "Ada"))
      (t.is (result-has-string-row? next-result.result "Grace"))
      (t.is live-result.result.ok live-result.result.error)
      (t.is (= (count live-result.result.rows) 1))
      (t.is (result-has-string-row? live-result.result "Ada"))
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-query-result seed-result)
      (vev.delete-query-result next-result)
      (vev.delete-query-result live-result)
      (vev.close-store-db! (addr next-snapshot)))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-with-report-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-with-report.sqlite")
  (let [path "tmp.vev.store-report-lazy-with-report.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is (= seed.db-after.kind .SQLite-Root-Snapshot))
    (let [report (vev.with-store-db-report-text (addr seed.db-after) "[{:db/id 2 :user/name \"Grace\"}]")
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?name :where [?e :user/name ?name]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [?e :user/name ?name]]")
          live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is report.ok report.error)
      (t.is (sqlite-durable-store-db? report.db-before))
      (t.is (= report.db-after.kind .SQLite-Tx-Ops-Overlay))
      (t.is before-result.result.ok before-result.result.error)
      (t.is (= (count before-result.result.rows) 1))
      (t.is (result-has-string-row? before-result.result "Ada"))
      (t.is after-result.result.ok after-result.result.error)
      (t.is (= (count after-result.result.rows) 2))
      (t.is (result-has-string-row? after-result.result "Ada"))
      (t.is (result-has-string-row? after-result.result "Grace"))
      (t.is live-result.result.ok live-result.result.error)
      (t.is (= (count live-result.result.rows) 1))
      (t.is (result-has-string-row? live-result.result "Ada"))
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-query-result live-result)
      (vev.delete-store-tx-report report))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-direct-pull-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-pull.sqlite")
  (let [path "tmp.vev.store-report-lazy-pull.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is (= seed.db-after.kind .SQLite-Root-Snapshot))
    (let [[pulled pulled-ok pulled-error] (vev.pull-store-db-value-text (addr seed.db-after) "[:user/name :user/email]" 1)
          [lookup-pulled lookup-ok lookup-error] (vev.pull-store-db-lookup-ref-value-text (addr seed.db-after) "[:user/name]" ":user/email" (vev.value-string "ada@example.com"))]
      (t.is pulled-ok pulled-error)
      (t.is (= pulled.kind .Map))
      (let [[name name-ok] (vev.map-get-value pulled (vev.value-keyword ":user/name"))
            [email email-ok] (vev.map-get-value pulled (vev.value-keyword ":user/email"))]
        (t.is name-ok)
        (t.is (= name.kind .String))
        (t.is (= name.text "Ada"))
        (t.is email-ok)
        (t.is (= email.kind .String))
        (t.is (= email.text "ada@example.com")))
      (t.is lookup-ok lookup-error)
      (t.is (= lookup-pulled.kind .Map))
      (let [[lookup-name lookup-name-ok] (vev.map-get-value lookup-pulled (vev.value-keyword ":user/name"))]
        (t.is lookup-name-ok)
        (t.is (= lookup-name.kind .String))
        (t.is (= lookup-name.text "Ada")))
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-owned-value pulled)
      (vev.delete-owned-value lookup-pulled))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-query-inputs-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-input-query.sqlite")
  (let [path "tmp.vev.store-report-lazy-input-query.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\"} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\"}]")
        prepared (vev.prepare-query-text "[:find ?name :in $ ?email :where [?e :user/email ?email] [?e :user/name ?name]]")
        report-after-kind seed.db-after.kind
        text-result (vev.q-result-store-db-text-with-input-text (addr seed.db-after) "[:find ?name :in $ ?email :where [?e :user/email ?email] [?e :user/name ?name]]" "[\"ada@example.com\"]")
        prepared-result (vev.q-result-store-db-prepared-with-input-text (addr seed.db-after) prepared "[\"grace@example.com\"]")
        profiled (vev.q-profiled-store-db-prepared-with-input-text (addr seed.db-after) prepared "[\"grace@example.com\"]")]
    (defer (remove-sqlite-files path))
    (defer (vev.delete-prepared-query-shallow prepared))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is (= report-after-kind .SQLite-Root-Snapshot))
    (t.is prepared.ok prepared.error)
    (t.is text-result.result.ok text-result.result.error)
    (t.is (= (count text-result.result.rows) 1))
    (t.is (result-has-string-row? text-result.result "Ada"))
    (t.is prepared-result.result.ok prepared-result.result.error)
    (t.is (= (count prepared-result.result.rows) 1))
    (t.is (result-has-string-row? prepared-result.result "Grace"))
    (t.is profiled.result.ok profiled.result.error)
    (t.is (= (count profiled.result.rows) 1))
    (t.is (result-has-string-row? profiled.result "Grace"))
    (t.is (= profiled.stats.input-bindings 1))
    (t.is (> profiled.stats.source-operators 0))
    (t.is (= profiled.stats.binding-materializations 0))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (vev.delete-query-result text-result)
    (vev.delete-query-result prepared-result)
    (vev.delete-profiled-result-set-owned-values profiled)
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-store-entity-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-entity.sqlite")
  (let [path "tmp.vev.store-report-lazy-entity.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\" :user/friend [2 3]} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\"} {:db/id 3 :user/name \"Barbara\" :user/email \"barbara@example.com\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is (= seed.db-after.kind .SQLite-Root-Snapshot))
    (let [[ada ada-ok ada-error] (vev.store-db-entity (addr seed.db-after) 1)
          [ada-lookup ada-lookup-ok ada-lookup-error] (vev.store-db-entity-lookup-ref (addr seed.db-after) ":user/email" (vev.value-string "ada@example.com"))
          [email-ident email-ident-ok email-ident-error] (vev.store-db-entity-ident (addr seed.db-after) ":user/email")
          name-value (vev.store-entity-get (addr ada) ":user/name")
          [friend friend-ok friend-error] (vev.store-entity-ref (addr ada) ":user/friend")
          friend-name (vev.store-entity-get (addr friend) ":user/name")
          [friends friends-ok friends-error] (vev.store-entity-refs (addr ada) ":user/friend")
          [reverse-values reverse-ok reverse-error] (vev.store-entity-values (addr friend) ":_user/friend")
          [reverse-refs reverse-refs-ok reverse-refs-error] (vev.store-entity-refs (addr friend) ":_user/friend")
          [touched touched-ok touched-error] (vev.touch-store-entity (addr ada))]
      (t.is ada-ok ada-error)
      (t.is (vev.store-entity-found? ada))
      (t.is (= (vev.store-entity-id ada) 1))
      (t.is ada-lookup-ok ada-lookup-error)
      (t.is (vev.store-entity-found? ada-lookup))
      (t.is (= (vev.store-entity-id ada-lookup) 1))
      (t.is email-ident-ok email-ident-error)
      (t.is (vev.store-entity-found? email-ident))
      (t.is (= (vev.store-entity-id email-ident) 100))
      (t.is (= name-value.kind .String))
      (t.is (= name-value.text "Ada"))
      (t.is friend-ok friend-error)
      (t.is (vev.store-entity-found? friend))
      (t.is (= (vev.store-entity-id friend) 2))
      (t.is (= friend-name.kind .String))
      (t.is (= friend-name.text "Grace"))
      (t.is friends-ok friends-error)
      (t.is (= (count friends) 2))
      (t.is (or (= (vev.store-entity-id friends[0]) 2)
                (= (vev.store-entity-id friends[1]) 2)))
      (t.is (or (= (vev.store-entity-id friends[0]) 3)
                (= (vev.store-entity-id friends[1]) 3)))
      (t.is reverse-ok reverse-error)
      (t.is (= (count reverse-values) 1))
      (t.is (= reverse-values[0].kind .Entity))
      (t.is (= reverse-values[0].entity 1))
      (t.is reverse-refs-ok reverse-refs-error)
      (t.is (= (count reverse-refs) 1))
      (t.is (= (vev.store-entity-id reverse-refs[0]) 1))
      (t.is touched-ok touched-error)
      (t.is (= touched.kind .Map))
      (let [[touched-name touched-name-ok] (vev.map-get-value touched (vev.value-keyword ":user/name"))]
        (t.is touched-name-ok)
        (t.is (= touched-name.kind .String))
        (t.is (= touched-name.text "Ada")))
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (vev.delete-owned-value name-value)
      (vev.delete-owned-value friend-name)
      (vev.close-store-entities friends)
      (for [value reverse-values]
        (vev.delete-owned-value value))
      (delete reverse-values)
      (vev.close-store-entities reverse-refs)
      (vev.delete-owned-value touched)
      (vev.close-store-entity! (addr ada))
      (vev.close-store-entity! (addr ada-lookup))
      (vev.close-store-entity! (addr email-ident))
      (vev.close-store-entity! (addr friend)))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-rules-source-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-rules.sqlite")
  (let [path "tmp.vev.store-report-lazy-rules.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 1 :user/name \"Ada\" :user/active true} {:db/id 2 :user/name \"Grace\" :user/active false}]")
        result (vev.q-result-store-db-text-with-rules
                 (addr seed.db-after)
                 "[:find ?name :where (active-user ?e ?name)]"
                 "[[(active-user ?e ?name) [?e :user/active true] [?e :user/name ?name]]]")
        input-result (vev.q-result-store-db-text-with-rules-input-text
                       (addr seed.db-after)
                       "[:find ?name :in $ ?flag :where (active-user ?e ?name ?flag)]"
                       "[[(active-user ?e ?name ?flag) [?e :user/active ?flag] [?e :user/name ?name]]]"
                       "[false]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is result.result.ok result.result.error)
    (t.is (= (count result.result.rows) 1))
    (t.is (result-has-string-row? result.result "Ada"))
    (t.is (not (result-has-string-row? result.result "Grace")))
    (t.is input-result.result.ok input-result.result.error)
    (t.is (= (count input-result.result.rows) 1))
    (t.is (result-has-string-row? input-result.result "Grace"))
    (t.is (not (result-has-string-row? input-result.result "Ada")))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (vev.delete-query-result result)
    (vev.delete-query-result input-result)
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-recursive-rules-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-recursive-rules.sqlite")
  (let [path "tmp.vev.store-report-lazy-recursive-rules.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-tx-data
               (addr store)
               ([]vev.Tx-Data [(vev.add 1 ":follow" (vev.value-entity 2))
                                (vev.add 2 ":follow" (vev.value-entity 3))
                                (vev.add 3 ":follow" (vev.value-entity 4))
                                (vev.add 4 ":follow" (vev.value-entity 5))
                                (vev.add 1 ":alt" (vev.value-entity 3))
                                (vev.add 3 ":alt" (vev.value-entity 5))
                                (vev.add 1 ":rank" (vev.value-int 1))
                                (vev.add 2 ":rank" (vev.value-int 2))
                                (vev.add 3 ":rank" (vev.value-int 3))
                                (vev.add 4 ":rank" (vev.value-int 4))
                                (vev.add 5 ":rank" (vev.value-int 5))]))
        result (vev.q-result-store-db-text-with-rules
                 (addr seed.db-after)
                 "[:find ?e1 ?e2 :where (follow ?e1 ?e2)]"
                 "[[(follow ?e1 ?e2) [?e1 :follow ?e2]] [(follow ?e1 ?e2) [?e1 :follow ?t] (follow ?t ?e2)]]")
        predicate-result (vev.q-result-store-db-text-with-rules
                           (addr seed.db-after)
                           "[:find ?e1 ?e2 :where (follow-over ?e1 ?e2)]"
                           "[[(follow-over ?e1 ?e2) [?e1 :follow ?e2] [?e2 :rank ?rank] [(> ?rank 2)]] [(follow-over ?e1 ?e2) [?e1 :follow ?t] [?t :rank ?rank] [(> ?rank 2)] (follow-over ?t ?e2)]]")
        or-result (vev.q-result-store-db-text-with-rules
                    (addr seed.db-after)
                    "[:find ?e1 ?e2 :where (route ?e1 ?e2)]"
                    "[[(route ?e1 ?e2) (or [?e1 :follow ?e2] [?e1 :alt ?e2])] [(route ?e1 ?e2) (or [?e1 :follow ?t] [?e1 :alt ?t]) (route ?t ?e2)]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is result.result.ok result.result.error)
    (t.is (= (count result.result.rows) 10))
    (t.is (result-has-entity-entity-row? result.result 1 2))
    (t.is (result-has-entity-entity-row? result.result 1 5))
    (t.is (result-has-entity-entity-row? result.result 3 5))
    (t.is predicate-result.result.ok predicate-result.result.error)
    (t.is (= (count predicate-result.result.rows) 6))
    (t.is (result-has-entity-entity-row? predicate-result.result 2 3))
    (t.is (result-has-entity-entity-row? predicate-result.result 2 5))
    (t.is (result-has-entity-entity-row? predicate-result.result 3 5))
    (t.is or-result.result.ok or-result.result.error)
    (t.is (= (count or-result.result.rows) 10))
    (t.is (result-has-entity-entity-row? or-result.result 1 2))
    (t.is (result-has-entity-entity-row? or-result.result 1 5))
    (t.is (result-has-entity-entity-row? or-result.result 3 5))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (vev.delete-query-result result)
    (vev.delete-query-result predicate-result)
    (vev.delete-query-result or-result)
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-lazy-db-after-supports-expression-rule-bodies-without-resident-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-lazy-expression-rules.sqlite")
  (let [path "tmp.vev.store-report-lazy-expression-rules.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 1 :user/name \"Ada\" :user/age 37} {:db/id 2 :user/name \"Grace\" :user/age 42 :user/height 180} {:db/id 3 :user/name \"Barbara\" :user/age 49}]")
        function-result (vev.q-result-store-db-text-with-rules
                          (addr seed.db-after)
                          "[:find ?label :where (name-label ?e ?label)]"
                          "[[(name-label ?e ?label) [?e :user/name ?name] [(str ?name \"!\") ?label]]]")
        get-else-result (vev.q-result-store-db-text-with-rules
                          (addr seed.db-after)
                          "[:find ?name ?height :where (height-or-zero ?e ?name ?height)]"
                          "[[(height-or-zero ?e ?name ?height) [?e :user/name ?name] [(get-else $ ?e :user/height 0) ?height]]]")
        ground-result (vev.q-result-store-db-text-with-rules
                        (addr seed.db-after)
                        "[:find ?name :where (target-name ?e ?name)]"
                        "[[(target-name ?e ?name) [(ground \"Grace\") ?target] [?e :user/name ?target] [?e :user/name ?name]]]")
        not-result (vev.q-result-store-db-text-with-rules
                     (addr seed.db-after)
                     "[:find ?name :where (without-height ?e ?name)]"
                     "[[(without-height ?e ?name) [?e :user/name ?name] (not [?e :user/height])]]")
        or-result (vev.q-result-store-db-text-with-rules
                    (addr seed.db-after)
                    "[:find ?name :where (selected-name ?e ?name)]"
                    "[[(selected-name ?e ?name) [?e :user/name ?name] (or [?e :user/age 37] [?e :user/height 180])]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (t.is function-result.result.ok function-result.result.error)
    (t.is (= (count function-result.result.rows) 3))
    (t.is (result-has-string-row? function-result.result "Ada!"))
    (t.is (result-has-string-row? function-result.result "Grace!"))
    (t.is (result-has-string-row? function-result.result "Barbara!"))
    (t.is get-else-result.result.ok get-else-result.result.error)
    (t.is (= (count get-else-result.result.rows) 3))
    (t.is ground-result.result.ok ground-result.result.error)
    (t.is (= (count ground-result.result.rows) 1))
    (t.is (result-has-string-row? ground-result.result "Grace"))
    (t.is not-result.result.ok not-result.result.error)
    (t.is (= (count not-result.result.rows) 2))
    (t.is (result-has-string-row? not-result.result "Ada"))
    (t.is (result-has-string-row? not-result.result "Barbara"))
    (t.is or-result.result.ok or-result.result.error)
    (t.is (= (count or-result.result.rows) 2))
    (t.is (result-has-string-row? or-result.result "Ada"))
    (t.is (result-has-string-row? or-result.result "Grace"))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (vev.delete-query-result function-result)
    (vev.delete-query-result get-else-result)
    (vev.delete-query-result ground-result)
    (vev.delete-query-result not-result)
    (vev.delete-query-result or-result)
    (vev.delete-store-tx-report seed)
    (vev.close-store store)))

(t.deftest sqlite-store-report-source-fn-first-write-stays-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-source-fn-first-write.sqlite")
  (let [path "tmp.vev.store-report-source-fn-first-write.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":add-user" store-source-add-user)])]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is (not (vev.store-resident-db-available? (addr store))))
    (let [report (vev.transact-store-report-text-with-source-string-fns
                   (addr store)
                   "[[:db.fn/call :add-user \"Ada\"]]"
                   registry)
          report-after-kind report.db-after.kind
          before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?name :where [?e :user/name ?name]]")
          after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [?e :user/name ?name]]")
          live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")
          [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr store))]
      (t.is report.ok report.error)
      (t.is (= report.db-before.kind .Shared-Snapshot))
      (t.is (= report-after-kind .SQLite-Root-Snapshot))
      (t.is report.source-append-metadata-known)
      (t.is report.source-eavt-append-mode)
      (t.is report.source-aevt-append-mode)
      (t.is report.source-avet-append-mode)
      (t.is report.source-vaet-append-mode)
      (t.is (not (vev.store-resident-db-available? (addr store))))
      (t.is before-result.result.ok before-result.result.error)
      (t.is (= (count before-result.result.rows) 0))
      (t.is after-result.result.ok after-result.result.error)
      (t.is (= (count after-result.result.rows) 1))
      (t.is (result-has-string-row? after-result.result "Ada"))
      (t.is live-result.result.ok live-result.result.error)
      (t.is (= (count live-result.result.rows) 1))
      (t.is (result-has-string-row? live-result.result "Ada"))
      (t.is tx-count-ok tx-count-error)
      (t.is (= tx-count 1))
      (vev.delete-query-result before-result)
      (vev.delete-query-result after-result)
      (vev.delete-query-result live-result)
      (vev.delete-store-tx-report report))
    (vev.close-store store)
    (let [[again again-ok again-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr again) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is again-ok)
      (t.is (= again-error ""))
      (t.is (not (vev.store-resident-db-available? (addr again))))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 1))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (vev.delete-query-result reopened-result)
      (vev.close-store again))))

(t.deftest sqlite-store-report-transact-stays-lazy-for-source-direct-write
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-write.sqlite")
  (let [path "tmp.vev.store-report-direct-write.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")]
        (t.is report.ok report.error)
        (t.is (= report.db-before.kind .SQLite-Root-Snapshot))
        (t.is (= report.db-after.kind .SQLite-Root-Snapshot))
        (t.is report.source-published-root-known)
        (t.is (> report.source-published-root.root-row-id 0))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (let [report-after (vev.q-result-store-db-text (addr report.db-after) "[:find ?name :where [?e :user/name ?name]]")
              after-write (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is (= report.db-after.kind .SQLite-Snapshot))
          (t.is report-after.result.ok report-after.result.error)
          (t.is (= (count report-after.result.rows) 2))
          (t.is (result-has-string-row? report-after.result "Ada"))
          (t.is (result-has-string-row? report-after.result "Grace"))
          (t.is after-write.result.ok after-write.result.error)
          (t.is (= (count after-write.result.rows) 2))
          (t.is (result-has-string-row? after-write.result "Ada"))
          (t.is (result-has-string-row? after-write.result "Grace"))
          (vev.delete-query-result report-after)
          (vev.delete-query-result after-write))
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-source-direct-write-accepts-unordered-new-entities
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-unordered.sqlite")
  (let [path "tmp.vev.store-report-direct-unordered.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text
                     (addr reopened)
                     "[[:db/add 3 :user/name \"Katherine\"] [:db/add 2 :user/name \"Grace\"] [:db/add 3 :user/email \"katherine@example.com\"]]")
            names (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
            emails (vev.q-result-store-text (addr reopened) "[:find ?email :where [?e :user/email ?email]]")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is report.source-append-metadata-known)
        (t.is report.source-eavt-append-mode)
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is names.result.ok names.result.error)
        (t.is (= (count names.result.rows) 3))
        (t.is (result-has-string-row? names.result "Ada"))
        (t.is (result-has-string-row? names.result "Grace"))
        (t.is (result-has-string-row? names.result "Katherine"))
        (t.is emails.result.ok emails.result.error)
        (t.is (= (count emails.result.rows) 1))
        (t.is (result-has-string-row? emails.result "katherine@example.com"))
        (vev.delete-query-result names)
        (vev.delete-query-result emails)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-source-direct-write-cache-preserves-value-type-validation
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-cache-type.sqlite")
  (let [path "tmp.vev.store-report-direct-cache-type.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :user/age :db/valueType :db.type/long}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 1 :user/age 37}]")
            invalid (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/age \"old\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?age :where [?e :user/age ?age]]")]
        (t.is first.ok first.error)
        (t.is (not invalid.ok))
        (t.is (= invalid.error "schema value type mismatch"))
        (t.is (sqlite-durable-store-db? first.db-after))
        (t.is (sqlite-durable-store-db? invalid.db-before))
        (t.is (sqlite-durable-store-db? invalid.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (= result.result.rows[0].values[0].kind .Int))
        (t.is (= result.result.rows[0].values[0].int-value 37))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report invalid))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-source-direct-write-cache-preserves-unique-conflicts
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-cache-unique.sqlite")
  (let [path "tmp.vev.store-report-direct-cache-unique.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 100 :db/ident :user/email :db/valueType :db.type/string :db/unique :db.unique/value}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 1 :user/email \"ada@example.com\"}]")
            duplicate (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/email \"ada@example.com\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?email :where [?e :user/email ?email]]")]
        (t.is first.ok first.error)
        (t.is (not duplicate.ok))
        (t.is (= duplicate.error "schema unique conflict"))
        (t.is (sqlite-durable-store-db? first.db-after))
        (t.is (sqlite-durable-store-db? duplicate.db-before))
        (t.is (sqlite-durable-store-db? duplicate.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (result-has-string-row? result.result "ada@example.com"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report duplicate))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-listeners-use-storage-neutral-db-values
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-listener.sqlite")
  (let [path "tmp.vev.store-report-listener.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          listener-reports (make [dynamic]vev.Store-Tx-Report)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is (vev.listen-store-report! (addr reopened) "audit" (addr listener-reports)))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            listener-after (vev.q-result-store-db-text (addr listener-reports[0].db-after) "[:find ?name :where [?e :user/name ?name]]")
            failed (vev.transact-store-report-text (addr reopened) "[{:db/id")
            _ (vev.unlisten-store-report! (addr reopened) "audit")
            after-unlisten (vev.transact-store-report-text (addr reopened) "[{:db/id 3 :user/name \"Barbara\"}]")]
        (t.is report.ok report.error)
        (t.is (= (count listener-reports) 1))
        (t.is (= listener-reports[0].tx report.tx))
        (t.is (sqlite-durable-store-db? listener-reports[0].db-before))
        (t.is (sqlite-durable-store-db? listener-reports[0].db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is listener-after.result.ok listener-after.result.error)
        (t.is (= (count listener-after.result.rows) 2))
        (t.is (result-has-string-row? listener-after.result "Ada"))
        (t.is (result-has-string-row? listener-after.result "Grace"))
        (t.is (not failed.ok))
        (t.is (= (count listener-reports) 1))
        (t.is after-unlisten.ok after-unlisten.error)
        (t.is (= (count listener-reports) 1))
        (vev.delete-query-result listener-after)
        (vev.delete-store-tx-report report)
        (vev.delete-store-tx-report failed)
        (vev.delete-store-tx-report after-unlisten))
      (for [listener-report listener-reports]
        (vev.delete-store-tx-report listener-report))
      (delete listener-reports)
      (vev.close-store reopened))))

(t.deftest sqlite-legacy-tx-report-refuses-reopened-durable-store
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.legacy-tx-report-reopened.sqlite")
  (let [path "tmp.vev.legacy-tx-report-reopened.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-store-tx-report seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [legacy-report (vev.transact-store-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            durable-report (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            after-write (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is (not legacy-report.ok))
        (t.is (= legacy-report.error "transact-sqlite-tx-data is resident-only for reopened durable SQLite stores; use transact-sqlite-store-report-tx-data"))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is durable-report.ok durable-report.error)
        (t.is (sqlite-durable-store-db? durable-report.db-before))
        (t.is (sqlite-durable-store-db? durable-report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is after-write.result.ok after-write.result.error)
        (t.is (= (count after-write.result.rows) 2))
        (t.is (result-has-string-row? after-write.result "Ada"))
        (t.is (result-has-string-row? after-write.result "Grace"))
        (vev.delete-tx-report-shallow legacy-report)
        (vev.delete-query-result after-write)
        (vev.delete-store-tx-report durable-report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-source-direct-appends-share-eavt-roots
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-append-roots.sqlite")
  (let [path "tmp.vev.store-report-direct-append-roots.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Grace\"}]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 3 :user/name \"Ivan\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 4 :user/name \"Oleg\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
            [eavt eavt-ok eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
            [aevt aevt-ok aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
            [avet avet-ok avet-error] (vev.sqlite-latest-index-entries path ":avet")
            [vaet vaet-ok vaet-error] (vev.sqlite-latest-index-entries path ":vaet")
            [eavt-root-children eavt-root-children-ok eavt-root-children-error] (vev.sqlite-latest-index-root-child-count path ":eavt")
            [eavt-root-level eavt-root-level-ok eavt-root-level-error] (vev.sqlite-latest-index-root-level path ":eavt")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
      (t.is (sqlite-durable-store-db? first.db-after))
      (t.is (sqlite-durable-store-db? second.db-after))
      (t.is (sqlite-durable-store-db? third.db-after))
      (t.is first.source-append-metadata-known)
      (t.is first.source-eavt-append-mode)
        (t.is (not first.source-aevt-append-mode))
        (t.is (not first.source-avet-append-mode))
        (t.is (not first.source-vaet-append-mode))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 4))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (result-has-string-row? result.result "Grace"))
        (t.is (result-has-string-row? result.result "Ivan"))
        (t.is (result-has-string-row? result.result "Oleg"))
        (t.is eavt-ok eavt-error)
        (t.is aevt-ok aevt-error)
        (t.is avet-ok avet-error)
        (t.is vaet-ok vaet-error)
        (t.is (= (count eavt) 8))
        (t.is (= (count aevt) 8))
        (t.is (= (count avet) 8))
        (t.is (= (count vaet) 8))
        (t.is eavt-root-children-ok eavt-root-children-error)
        (t.is (= eavt-root-children 0))
        (t.is eavt-root-level-ok eavt-root-level-error)
        (t.is (= eavt-root-level (i64 0)))
        (delete eavt)
        (delete aevt)
        (delete avet)
        (delete vaet)
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third))
      (vev.close-store reopened))
    (let [[again again-ok again-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr again) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is again-ok)
      (t.is (= again-error ""))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 4))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is (result-has-string-row? reopened-result.result "Ivan"))
      (t.is (result-has-string-row? reopened-result.result "Oleg"))
      (vev.delete-query-result reopened-result)
      (vev.close-store again))))

(t.deftest sqlite-store-report-source-direct-appends-tier-segmented-eavt-root-after-fanout
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-append-tiered-roots.sqlite")
  (let [path "tmp.vev.store-report-direct-append-tiered-roots.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/age 1}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (let [entity-id 2]
        (while (<= entity-id 71)
          (let [report (vev.transact-store-report-tx-data
                         (addr reopened)
                         ([]vev.Tx-Data [(vev.add (u64 entity-id) ":user/age" (vev.value-int (i64 entity-id)))]))]
            (t.is report.ok report.error)
            (vev.delete-store-tx-report report))
          (set! entity-id (+ entity-id 1))))
      (let [[eavt-root-children eavt-root-children-ok eavt-root-children-error] (vev.sqlite-latest-index-root-child-count path ":eavt")
            [eavt-root-level eavt-root-level-ok eavt-root-level-error] (vev.sqlite-latest-index-root-level path ":eavt")
            [eavt-tree-nodes eavt-tree-leaves eavt-tree-level eavt-tree-ok eavt-tree-error] (vev.sqlite-latest-index-root-tree-stats path ":eavt")
            result (vev.q-result-store-text (addr reopened) "[:find ?age ?age :where [?e :user/age ?age]]")]
        (t.is eavt-root-children-ok eavt-root-children-error)
        (t.is (= eavt-root-children 0))
        (t.is eavt-root-level-ok eavt-root-level-error)
        (t.is (= eavt-root-level (i64 0)))
        (t.is eavt-tree-ok eavt-tree-error)
        (t.is (= eavt-tree-level (i64 0)))
        (t.is (= eavt-tree-nodes 1))
        (t.is (= eavt-tree-leaves 1))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 71))
        (t.is (result-has-int-int-row? result.result 1 1))
        (t.is (result-has-int-int-row? result.result 71 71))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (vev.delete-query-result result))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-source-direct-streams-non-append-index-roots
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-non-append-roots.sqlite")
  (let [path "tmp.vev.store-report-direct-non-append-roots.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [[maintenance-before maintenance-before-ok maintenance-before-error] (vev.sqlite-index-maintenance-count path)
            report (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Ada\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
            [avet avet-ok avet-error] (vev.sqlite-latest-index-entries path ":avet")
            [avet-root-children avet-root-children-ok avet-root-children-error] (vev.sqlite-latest-index-root-child-count path ":avet")
            [vaet-root-children vaet-root-children-ok vaet-root-children-error] (vev.sqlite-latest-index-root-child-count path ":vaet")
            [manifest-count manifest-count-ok manifest-count-error] (vev.sqlite-index-run-manifest-count path)
            [maintenance-after maintenance-after-ok maintenance-after-error] (vev.sqlite-index-maintenance-count path)]
        (t.is maintenance-before-ok maintenance-before-error)
        (t.is report.ok report.error)
        (t.is report.source-append-metadata-known)
        (t.is report.source-eavt-append-mode)
        (t.is (not report.source-aevt-append-mode))
        (t.is (not report.source-avet-append-mode))
        (t.is (not report.source-vaet-append-mode))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 2))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (t.is avet-ok avet-error)
        (t.is (= (count avet) 4))
        (t.is avet-root-children-ok avet-root-children-error)
        (t.is vaet-root-children-ok vaet-root-children-error)
        (t.is (= avet-root-children 0))
        (t.is (= vaet-root-children 0))
        (t.is manifest-count-ok manifest-count-error)
        (t.is (>= manifest-count 4))
        (t.is maintenance-after-ok maintenance-after-error)
        (t.is (= maintenance-after maintenance-before))
        (delete avet)
        (vev.delete-query-result result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))
    (let [[again again-ok again-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr again) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is again-ok)
      (t.is (= again-error ""))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 2))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Zoe"))
      (vev.delete-query-result reopened-result)
      (vev.close-store again))))

(t.deftest sqlite-store-report-non-append-index-roots-publish-run-manifests
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-merge-compact.sqlite")
  (let [path "tmp.vev.store-report-direct-merge-compact.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Yara\"}]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 3 :user/name \"Xena\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 4 :user/name \"Walt\"}]")
            fourth (vev.transact-store-report-text (addr reopened) "[{:db/id 5 :user/name \"Vera\"}]")
            fifth (vev.transact-store-report-text (addr reopened) "[{:db/id 6 :user/name \"Uma\"}]")
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
            [avet-root-children avet-root-children-ok avet-root-children-error] (vev.sqlite-latest-index-root-child-count path ":avet")
            [vaet-root-children vaet-root-children-ok vaet-root-children-error] (vev.sqlite-latest-index-root-child-count path ":vaet")
            [manifest-count manifest-count-ok manifest-count-error] (vev.sqlite-index-run-manifest-count path)
            [snapshot snapshot-ok snapshot-error] (vev.sqlite-store-db (addr reopened.sqlite))]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is fourth.ok fourth.error)
        (t.is fifth.ok fifth.error)
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 6))
        (t.is (result-has-string-row? result.result "Uma"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (t.is avet-root-children-ok avet-root-children-error)
        (t.is vaet-root-children-ok vaet-root-children-error)
        (t.is (= avet-root-children 0))
        (t.is (= vaet-root-children 0))
        (t.is manifest-count-ok manifest-count-error)
        (t.is (>= manifest-count 10))
        (t.is snapshot-ok snapshot-error)
        (let [root-db (vev.retain-store-db snapshot)
              retained-root (vev.retain-store-db root-db)
              root-result (vev.q-result-store-db-text (addr root-db) "[:find ?name :where [?e :user/name ?name]]")]
          (t.is root-result.result.ok root-result.result.error)
          (t.is (= (count root-result.result.rows) 6))
          (t.is (result-has-string-row? root-result.result "Uma"))
          (t.is (> (vev.store-db-sqlite-page-cache-count (addr root-db)) 0))
          (t.is (> (vev.store-db-sqlite-page-cache-count (addr retained-root)) 0))
          (let [retained-result (vev.q-result-store-db-text (addr retained-root) "[:find ?name :where [?e :user/name ?name]]")]
            (t.is retained-result.result.ok retained-result.result.error)
            (t.is (= (count retained-result.result.rows) 6))
            (t.is (result-has-string-row? retained-result.result "Zoe"))
            (vev.delete-query-result retained-result))
          (vev.delete-query-result root-result)
          (vev.close-store-db! (addr retained-root))
          (vev.close-store-db! (addr root-db)))
        (vev.close-store-db! (addr snapshot))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third)
        (vev.delete-store-tx-report fourth)
        (vev.delete-store-tx-report fifth))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-enqueues-and-drains-index-maintenance
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-index-maintenance-queue.sqlite")
  (let [path "tmp.vev.store-report-index-maintenance-queue.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Yara-1\"} {:db/id 3 :user/name \"Yara-2\"} {:db/id 4 :user/name \"Yara-3\"} {:db/id 5 :user/name \"Yara-4\"} {:db/id 6 :user/name \"Yara-5\"}]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 7 :user/name \"Xena-1\"} {:db/id 8 :user/name \"Xena-2\"} {:db/id 9 :user/name \"Xena-3\"} {:db/id 10 :user/name \"Xena-4\"} {:db/id 11 :user/name \"Xena-5\"} {:db/id 12 :user/name \"Xena-6\"} {:db/id 13 :user/name \"Xena-7\"} {:db/id 14 :user/name \"Xena-8\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 15 :user/name \"Walt-1\"} {:db/id 16 :user/name \"Walt-2\"}]")
            fourth (vev.transact-store-report-text (addr reopened) "[{:db/id 17 :user/name \"Vera-1\"} {:db/id 18 :user/name \"Vera-2\"}]")
            fifth (vev.transact-store-report-text (addr reopened) "[{:db/id 19 :user/name \"Uma-1\"}]")
            [queued-before queued-before-ok queued-before-error] (vev.sqlite-index-maintenance-count path)
            [steps maintained maintained-ok maintained-error] (vev.maintain-store-indexes! (addr reopened) 8)
            [queued-after queued-after-ok queued-after-error] (vev.sqlite-index-maintenance-count path)
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is fourth.ok fourth.error)
        (t.is fifth.ok fifth.error)
        (t.is queued-before-ok queued-before-error)
        (t.is (= queued-before 0))
        (t.is (> steps 0))
        (t.is maintained)
        (t.is maintained-ok maintained-error)
        (t.is queued-after-ok queued-after-error)
        (t.is (= queued-after 0))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 19))
        (t.is (result-has-string-row? result.result "Uma-1"))
        (t.is (result-has-string-row? result.result "Vera-2"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third)
        (vev.delete-store-tx-report fourth)
        (vev.delete-store-tx-report fifth))
      (vev.close-store reopened))))

(t.deftest sqlite-store-auto-maintenance-keeps-index-queue-bounded
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-auto-index-maintenance.sqlite")
  (let [path "tmp.vev.store-report-auto-index-maintenance.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
