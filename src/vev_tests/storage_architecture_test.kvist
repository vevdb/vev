    (t.is seed.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          next-snapshot (vev.db-with-store-db-text (addr snapshot) "[[:db/retractEntity 1]]")
          parent (vev.q-result-store-db-text (addr next-snapshot) "[:find ?a ?v :where [1 ?a ?v]]")
          child (vev.q-result-store-db-text (addr next-snapshot) "[:find ?a ?v :where [3 ?a ?v]]")
          friend (vev.q-result-store-db-text (addr next-snapshot) "[:find ?name :where [2 :item/name ?name]]")
          original-parent (vev.q-result-store-db-text (addr snapshot) "[:find ?a ?v :where [1 ?a ?v]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= snapshot.kind .SQLite-Snapshot))
      (t.is (= next-snapshot.kind .SQLite-Tx-Ops-Overlay))
      (t.is parent.result.ok)
      (t.is (= (count parent.result.rows) 0))
      (t.is child.result.ok)
      (t.is (= (count child.result.rows) 0))
      (t.is friend.result.ok)
      (t.is (= (count friend.result.rows) 1))
      (t.is (= friend.result.rows[0].values[0].text "Grace"))
      (t.is original-parent.result.ok)
      (t.is (> (count original-parent.result.rows) 0))
      (vev.delete-query-result parent)
      (vev.delete-query-result child)
      (vev.delete-query-result friend)
      (vev.delete-query-result original-parent)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow schema)
    (vev.delete-tx-report-shallow seed)))

