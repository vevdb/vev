            second (vev.transact-store-report-text (addr reopened) "[{:db/id 7 :user/name \"Xena-1\"} {:db/id 8 :user/name \"Xena-2\"} {:db/id 9 :user/name \"Xena-3\"} {:db/id 10 :user/name \"Xena-4\"} {:db/id 11 :user/name \"Xena-5\"} {:db/id 12 :user/name \"Xena-6\"} {:db/id 13 :user/name \"Xena-7\"} {:db/id 14 :user/name \"Xena-8\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 15 :user/name \"Walt-1\"} {:db/id 16 :user/name \"Walt-2\"}]")
            fourth (vev.transact-store-report-text (addr reopened) "[{:db/id 17 :user/name \"Vera-1\"} {:db/id 18 :user/name \"Vera-2\"}]")
            [queued queued-ok queued-error] (vev.sqlite-index-maintenance-count path)
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is fourth.ok fourth.error)
        (t.is queued-ok queued-error)
        (t.is (= queued 0))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 18))
        (t.is (result-has-string-row? result.result "Vera-2"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third)
        (vev.delete-store-tx-report fourth))
      (vev.close-store reopened))))

(t.deftest sqlite-store-auto-maintenance-threshold-tolerates-and-drains-queue
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-auto-index-maintenance-threshold.sqlite")
  (let [path "tmp.vev.store-report-auto-index-maintenance-threshold.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          [configured-ok configured-error] (vev.configure-store-auto-maintenance-threshold! (addr reopened) 64 0 100)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is configured-ok configured-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Yara-1\"} {:db/id 3 :user/name \"Yara-2\"} {:db/id 4 :user/name \"Yara-3\"} {:db/id 5 :user/name \"Yara-4\"} {:db/id 6 :user/name \"Yara-5\"}]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 7 :user/name \"Xena-1\"} {:db/id 8 :user/name \"Xena-2\"} {:db/id 9 :user/name \"Xena-3\"} {:db/id 10 :user/name \"Xena-4\"} {:db/id 11 :user/name \"Xena-5\"} {:db/id 12 :user/name \"Xena-6\"} {:db/id 13 :user/name \"Xena-7\"} {:db/id 14 :user/name \"Xena-8\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 15 :user/name \"Walt-1\"} {:db/id 16 :user/name \"Walt-2\"}]")
            fourth (vev.transact-store-report-text (addr reopened) "[{:db/id 17 :user/name \"Vera-1\"} {:db/id 18 :user/name \"Vera-2\"}]")
            [queued-before queued-before-ok queued-before-error] (vev.sqlite-index-maintenance-count path)
            [reconfigured-ok reconfigured-error] (vev.configure-store-auto-maintenance-threshold! (addr reopened) 64 0 1)
            fifth (vev.transact-store-report-text (addr reopened) "[{:db/id 19 :user/name \"Uma\"}]")
            [queued-after queued-after-ok queued-after-error] (vev.sqlite-index-maintenance-count path)
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is fourth.ok fourth.error)
        (t.is queued-before-ok queued-before-error)
        (t.is (= queued-before 0))
        (t.is reconfigured-ok reconfigured-error)
        (t.is fifth.ok fifth.error)
        (t.is queued-after-ok queued-after-error)
        (t.is (= queued-after 0))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 19))
        (t.is (result-has-string-row? result.result "Uma"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third)
        (vev.delete-store-tx-report fourth)
        (vev.delete-store-tx-report fifth))
      (vev.close-store reopened))))

(t.deftest sqlite-store-explicit-index-compaction-leaves-run-manifests-queryable
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-explicit-index-compact.sqlite")
  (let [path "tmp.vev.store-report-explicit-index-compact.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Zoe\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (let [first (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Yara\"}]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 3 :user/name \"Xena\"}]")
            third (vev.transact-store-report-text (addr reopened) "[{:db/id 4 :user/name \"Walt\"}]")
            [before-children before-children-ok before-children-error] (vev.sqlite-latest-index-root-child-count path ":avet")
            [manifest-before manifest-before-ok manifest-before-error] (vev.sqlite-index-run-manifest-count path)
            [compacted compact-ok compact-error] (vev.compact-store-indexes! (addr reopened))
            [after-children after-children-ok after-children-error] (vev.sqlite-latest-index-root-child-count path ":avet")
            [manifest-after manifest-after-ok manifest-after-error] (vev.sqlite-index-run-manifest-count path)
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is before-children-ok before-children-error)
        (t.is (= before-children 0))
        (t.is manifest-before-ok manifest-before-error)
        (t.is (> manifest-before 0))
        (discard compacted)
        (t.is compact-ok compact-error)
        (t.is after-children-ok after-children-error)
        (t.is (= after-children 0))
        (t.is manifest-after-ok manifest-after-error)
        (t.is (= manifest-after manifest-before))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 4))
        (t.is (result-has-string-row? result.result "Walt"))
        (t.is (result-has-string-row? result.result "Zoe"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
      (vev.delete-store-tx-report third))
      (vev.close-store reopened))))

(t.deftest sqlite-store-reopen-append-source-query-does-not-duplicate-manifest-entries
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-reopen-append-no-duplicate-manifest-entries.sqlite")
  (let [path "tmp.vev.store-reopen-append-no-duplicate-manifest-entries.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        first (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Durable Ada\" :user/email \"durable-ada@example.com\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is first.ok first.error)
    (vev.delete-live-tx-report-shallow first)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (let [listener (vev.transact-store-report-text (addr reopened) "[[:db/add 1 :user/listener \"heard\"]]")
            listener-replace (vev.transact-store-report-text (addr reopened) "[[:db/add 1 :user/listener \"after-unlisten\"]]")
            second (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name \"Durable Grace\" :user/email \"durable-grace@example.com\"}]")]
        (t.is listener.ok listener.error)
        (t.is listener-replace.ok listener-replace.error)
        (t.is second.ok second.error)
        (vev.delete-store-tx-report listener)
        (vev.delete-store-tx-report listener-replace)
        (vev.delete-store-tx-report second))
      (vev.close-store reopened))
    (let [[final-store final-ok final-error] (vev.open-store path)]
      (t.is final-ok)
      (t.is (= final-error ""))
      (let [result (vev.q-result-store-text (addr final-store) "[:find ?email :where [?e :user/email ?email]]")]
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 2))
        (t.is (result-has-string-row? result.result "durable-ada@example.com"))
        (t.is (result-has-string-row? result.result "durable-grace@example.com"))
        (vev.delete-query-result result))
      (let [third (vev.transact-store-report-text (addr final-store) "[{:db/id 3 :user/name \"Durable Katherine\" :user/email \"durable-katherine@example.com\"}]")
            [eavt eavt-ok eavt-error] (vev.sqlite-conn-latest-index-entries (addr final-store.sqlite) ":eavt")
            [aevt aevt-ok aevt-error] (vev.sqlite-conn-latest-index-entries (addr final-store.sqlite) ":aevt")
            [avet avet-ok avet-error] (vev.sqlite-conn-latest-index-entries (addr final-store.sqlite) ":avet")
            [vaet vaet-ok vaet-error] (vev.sqlite-conn-latest-index-entries (addr final-store.sqlite) ":vaet")
            [compacted compact-ok compact-error] (vev.compact-store-indexes! (addr final-store))]
        (discard compacted)
        (t.is third.ok third.error)
        (t.is eavt-ok eavt-error)
        (t.is aevt-ok aevt-error)
        (t.is avet-ok avet-error)
        (t.is vaet-ok vaet-error)
        (delete eavt)
        (delete aevt)
        (delete avet)
        (delete vaet)
        (t.is compact-ok compact-error)
        (vev.delete-store-tx-report third))
      (vev.close-store final-store))))

(t.deftest sqlite-store-report-append-mode-publishes-manifest-deltas
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-child-count-fallback.sqlite")
  (let [path "tmp.vev.store-report-child-count-fallback.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/age 1}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (let [entity-id 2]
        (while (<= entity-id 130)
          (let [report (vev.transact-store-report-tx-data
                         (addr reopened)
                         ([]vev.Tx-Data [(vev.add (u64 entity-id) ":user/age" (vev.value-int (i64 entity-id)))]))]
            (t.is report.ok report.error)
            (vev.delete-store-tx-report report))
          (set! entity-id (+ entity-id 1))))
      (let [[children-before children-before-ok children-before-error] (vev.sqlite-latest-index-root-child-count path ":eavt")
            [level-before level-before-ok level-before-error] (vev.sqlite-latest-index-root-level path ":eavt")
            [manifest-before manifest-before-ok manifest-before-error] (vev.sqlite-index-run-manifest-count path)]
        (t.is children-before-ok children-before-error)
        (t.is (= children-before 0))
        (t.is level-before-ok level-before-error)
        (t.is (= level-before (i64 0)))
        (t.is manifest-before-ok manifest-before-error)
        (t.is (> manifest-before 0)))
      (vev.close-store reopened))
    (let [[clear-ok clear-error] (vev.sqlite-clear-latest-index-root-child-count-for-test path ":eavt")
          [fallback-children fallback-children-ok fallback-children-error] (vev.sqlite-latest-index-root-child-count path ":eavt")]
      (t.is clear-ok clear-error)
      (t.is fallback-children-ok fallback-children-error)
      (t.is (= fallback-children 0)))
    (let [[again again-ok again-error] (vev.open-store path)]
      (t.is again-ok)
      (t.is (= again-error ""))
      (let [next (vev.transact-store-report-tx-data
                   (addr again)
                   ([]vev.Tx-Data [(vev.add (u64 131) ":user/age" (vev.value-int (i64 131)))]))
            [children-after children-after-ok children-after-error] (vev.sqlite-latest-index-root-child-count path ":eavt")
            [level-after level-after-ok level-after-error] (vev.sqlite-latest-index-root-level path ":eavt")
            [manifest-after manifest-after-ok manifest-after-error] (vev.sqlite-index-run-manifest-count path)
            result (vev.q-result-store-text (addr again) "[:find ?age ?age :where [?e :user/age ?age]]")]
        (t.is next.ok next.error)
        (t.is children-after-ok children-after-error)
        (t.is (= children-after 0))
        (t.is level-after-ok level-after-error)
        (t.is (= level-after (i64 0)))
        (t.is manifest-after-ok manifest-after-error)
        (t.is (> manifest-after 0))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 131))
        (t.is (result-has-int-int-row? result.result 131 131))
        (t.is (not (vev.store-resident-db-available? (addr again))))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report next))
      (vev.close-store again))))

(t.deftest sqlite-store-report-small-append-deltas-use-entry-backed-runs
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-entry-backed-deltas.sqlite")
  (let [path "tmp.vev.store-report-entry-backed-deltas.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (let [tx-data (make [dynamic]vev.Tx-Data) :defer
            entity-id 2]
        (while (<= entity-id 150)
          (arr.push! tx-data (vev.add (u64 entity-id) ":user/name" (vev.value-string "Grace")))
          (set! entity-id (+ entity-id 1)))
        (let [report (vev.transact-store-report-tx-data (addr reopened) (slice tx-data 0))]
          (t.is report.ok report.error)
          (vev.delete-store-tx-report report)))
      (let [
            [entry-backed entry-backed-ok entry-backed-error] (vev.sqlite-entry-backed-index-chunk-count-for-test path)
            live-result (vev.q-result-store-text (addr reopened) "[:find ?e ?name :where [?e :user/name ?name]]")]
        (t.is entry-backed-ok entry-backed-error)
        (t.is (>= entry-backed 8))
        (t.is live-result.result.ok live-result.result.error)
        (t.is (= (count live-result.result.rows) 150))
        (t.is (result-has-entity-string-row? live-result.result 1 "Ada"))
        (t.is (result-has-entity-string-row? live-result.result 2 "Grace"))
        (vev.delete-query-result live-result))
      (vev.close-store reopened))
    (let [[again again-ok again-error] (vev.open-store path)]
      (t.is again-ok)
      (t.is (= again-error ""))
      (let [reopened-result (vev.q-result-store-text (addr again) "[:find ?e ?name :where [?e :user/name ?name]]")]
        (t.is reopened-result.result.ok reopened-result.result.error)
        (t.is (= (count reopened-result.result.rows) 150))
        (t.is (result-has-entity-string-row? reopened-result.result 1 "Ada"))
        (t.is (result-has-entity-string-row? reopened-result.result 2 "Grace"))
        (vev.delete-query-result reopened-result))
      (vev.close-store again))))

(t.deftest sqlite-store-report-source-fn-appends-share-eavt-roots
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-source-fn-append-roots.sqlite")
  (let [path "tmp.vev.store-report-source-fn-append-roots.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":add-user" store-source-add-user)])]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [first (vev.transact-store-report-text-with-source-string-fns
                    (addr reopened)
                    "[[:db.fn/call :add-user \"Grace\"]]"
                    registry)
            second (vev.transact-store-report-text-with-source-string-fns
                     (addr reopened)
                     "[[:db.fn/call :add-user \"Ivan\"]]"
                     registry)
            third (vev.transact-store-report-text-with-source-string-fns
                    (addr reopened)
                    "[[:db.fn/call :add-user \"Oleg\"]]"
                    registry)
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")
            [eavt eavt-ok eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
            [aevt aevt-ok aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
            [avet avet-ok avet-error] (vev.sqlite-latest-index-entries path ":avet")
            [vaet vaet-ok vaet-error] (vev.sqlite-latest-index-entries path ":vaet")]
        (t.is first.ok first.error)
        (t.is second.ok second.error)
        (t.is third.ok third.error)
        (t.is (sqlite-durable-store-db? first.db-after))
        (t.is (sqlite-durable-store-db? second.db-after))
        (t.is (sqlite-durable-store-db? third.db-after))
        (t.is first.source-append-metadata-known)
        (t.is first.source-eavt-append-mode)
        (t.is (not first.source-aevt-append-mode))
        (t.is (not first.source-avet-append-mode))
        (t.is (not first.source-vaet-append-mode))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 4))
        (t.is (result-has-string-row? result.result "Ada"))
        (t.is (result-has-string-row? result.result "Grace"))
        (t.is (result-has-string-row? result.result "Ivan"))
        (t.is (result-has-string-row? result.result "Oleg"))
        (t.is eavt-ok eavt-error)
        (t.is aevt-ok aevt-error)
        (t.is avet-ok avet-error)
        (t.is vaet-ok vaet-error)
        (t.is (= (count eavt) 8))
        (t.is (= (count aevt) 8))
        (t.is (= (count avet) 8))
        (t.is (= (count vaet) 8))
        (delete eavt)
        (delete aevt)
        (delete avet)
        (delete vaet)
        (vev.delete-query-result result)
        (vev.delete-store-tx-report first)
        (vev.delete-store-tx-report second)
        (vev.delete-store-tx-report third))
      (vev.close-store reopened))
    (let [[again again-ok again-error] (vev.open-store-read-only path)
          reopened-result (vev.q-result-store-text (addr again) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is again-ok)
      (t.is (= again-error ""))
      (t.is reopened-result.result.ok reopened-result.result.error)
      (t.is (= (count reopened-result.result.rows) 4))
      (t.is (result-has-string-row? reopened-result.result "Ada"))
      (t.is (result-has-string-row? reopened-result.result "Grace"))
      (t.is (result-has-string-row? reopened-result.result "Ivan"))
      (t.is (result-has-string-row? reopened-result.result "Oleg"))
      (vev.delete-query-result reopened-result)
      (vev.close-store again))))

(t.deftest sqlite-store-report-source-fn-empty-tx-publishes-root-only
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-source-fn-empty-tx.sqlite")
  (let [path "tmp.vev.store-report-source-fn-empty-tx.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":noop" store-source-noop)])]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (vev.reset-store-direct-write-profile! (addr reopened))
      (let [[root-count-before root-count-before-ok root-count-before-error] (vev.sqlite-index-root-count path)
            [root-page-count-before root-page-count-before-ok root-page-count-before-error] (vev.sqlite-index-root-page-count path)
            [chunk-count-before chunk-count-before-ok chunk-count-before-error] (vev.sqlite-index-chunk-count path)
            [maintenance-before maintenance-before-ok maintenance-before-error] (vev.sqlite-index-maintenance-count path)
            [datom-count-before datom-count-before-ok datom-count-before-error] (vev.sqlite-conn-datom-count (addr reopened.sqlite))
            [eavt-root-before eavt-root-before-ok eavt-root-before-error] (vev.sqlite-latest-index-root-id path ":eavt")
            [aevt-root-before aevt-root-before-ok aevt-root-before-error] (vev.sqlite-latest-index-root-id path ":aevt")
            [avet-root-before avet-root-before-ok avet-root-before-error] (vev.sqlite-latest-index-root-id path ":avet")
            [vaet-root-before vaet-root-before-ok vaet-root-before-error] (vev.sqlite-latest-index-root-id path ":vaet")
            report (vev.transact-store-report-text-with-source-string-fns
                     (addr reopened)
                     "[[:db.fn/call :noop \"ignored\"]]"
                     registry)
            [root-count-after root-count-after-ok root-count-after-error] (vev.sqlite-index-root-count path)
            [root-page-count-after root-page-count-after-ok root-page-count-after-error] (vev.sqlite-index-root-page-count path)
            [chunk-count-after chunk-count-after-ok chunk-count-after-error] (vev.sqlite-index-chunk-count path)
            [maintenance-after maintenance-after-ok maintenance-after-error] (vev.sqlite-index-maintenance-count path)
            [datom-count-after datom-count-after-ok datom-count-after-error] (vev.sqlite-conn-datom-count (addr reopened.sqlite))
            [eavt-root-after eavt-root-after-ok eavt-root-after-error] (vev.sqlite-latest-index-root-id path ":eavt")
            [aevt-root-after aevt-root-after-ok aevt-root-after-error] (vev.sqlite-latest-index-root-id path ":aevt")
            [avet-root-after avet-root-after-ok avet-root-after-error] (vev.sqlite-latest-index-root-id path ":avet")
            [vaet-root-after vaet-root-after-ok vaet-root-after-error] (vev.sqlite-latest-index-root-id path ":vaet")
            profile (vev.store-direct-write-profile (addr reopened))
            result (vev.q-result-store-text (addr reopened) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is root-count-before-ok root-count-before-error)
        (t.is root-page-count-before-ok root-page-count-before-error)
        (t.is chunk-count-before-ok chunk-count-before-error)
        (t.is maintenance-before-ok maintenance-before-error)
        (t.is datom-count-before-ok datom-count-before-error)
        (t.is eavt-root-before-ok eavt-root-before-error)
        (t.is aevt-root-before-ok aevt-root-before-error)
        (t.is avet-root-before-ok avet-root-before-error)
        (t.is vaet-root-before-ok vaet-root-before-error)
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is report.source-published-root-known)
        (t.is (> report.source-published-root.root-row-id 0))
        (t.is (= report.source-published-root.roots.eavt.root-id eavt-root-after))
        (t.is (= report.source-published-root.roots.aevt.root-id aevt-root-after))
        (t.is (= report.source-published-root.roots.avet.root-id avet-root-after))
        (t.is (= report.source-published-root.roots.vaet.root-id vaet-root-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is (= (count report.tx-data) 1))
        (t.is (= report.tx-data[0].e report.tx))
        (t.is (= report.tx-data[0].a ":db/txInstant"))
        (t.is (= report.tx-data[0].v.kind .Instant))
        (t.is root-count-after-ok root-count-after-error)
        (t.is (= root-count-after (+ root-count-before 1)))
        (t.is root-page-count-after-ok root-page-count-after-error)
        (t.is (= root-page-count-after (+ root-page-count-before 4)))
        (t.is chunk-count-after-ok chunk-count-after-error)
        (t.is (= chunk-count-after (+ chunk-count-before 4)))
        (t.is maintenance-after-ok maintenance-after-error)
        (t.is (= maintenance-after maintenance-before))
        (t.is (= profile.append-root-sort-us 0.0))
        (t.is datom-count-after-ok datom-count-after-error)
        (t.is (= datom-count-after (+ datom-count-before 1)))
        (t.is eavt-root-after-ok eavt-root-after-error)
        (t.is aevt-root-after-ok aevt-root-after-error)
        (t.is avet-root-after-ok avet-root-after-error)
        (t.is vaet-root-after-ok vaet-root-after-error)
        (t.is (= eavt-root-after eavt-root-before))
        (t.is (= aevt-root-after aevt-root-before))
        (t.is (= avet-root-after avet-root-before))
        (t.is (= vaet-root-after vaet-root-before))
        (t.is result.result.ok result.result.error)
        (t.is (= (count result.result.rows) 1))
        (t.is (result-has-string-row? result.result "Ada"))
        (vev.delete-query-result result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-fails-without-resident-fallback
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-unsupported.sqlite")
  (let [path "tmp.vev.store-report-direct-unsupported.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[[:db.fn/call :birthday \"Ada\"]]")
            [tx-count tx-count-ok tx-count-error] (vev.store-tx-count (addr reopened))
            after-result (vev.q-result-store-text (addr reopened) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is (not report.ok))
        (t.is (= report.error "transaction fn not registered"))
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is tx-count-ok tx-count-error)
        (t.is (= tx-count 1))
        (t.is after-result.result.ok after-result.result.error)
        (t.is (= (count after-result.result.rows) 1))
        (t.is (result-has-string-row? after-result.result "Ada"))
        (vev.delete-query-result after-result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-parse-failure-stays-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-parse-failure.sqlite")
  (let [path "tmp.vev.store-report-parse-failure.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [report (vev.transact-store-report-text (addr reopened) "[{:db/id 2 :user/name")]
        (t.is (not report.ok))
        (t.is (not (= report.error "")))
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-read-only-failure-stays-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-read-only-failure.sqlite")
  (let [path "tmp.vev.store-report-read-only-failure.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is (vev.store-read-only? (addr read-store)))
      (t.is (not (vev.store-resident-db-available? (addr read-store))))
      (let [warm (vev.q-result-store-text (addr read-store) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is warm.result.ok warm.result.error)
        (t.is (= (count warm.result.rows) 1))
        (t.is (> (vev.store-current-root-page-cache-count (addr read-store)) 0))
        (vev.delete-query-result warm))
      (let [report (vev.transact-store-report-text (addr read-store) "[{:db/id 2 :user/name \"Grace\"}]")]
        (t.is (not report.ok))
        (t.is (= report.error "SQLite source connection is read-only; open a writable SQLite connection to transact"))
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (= report.db-before.kind .SQLite-Root-Snapshot))
        (t.is (= report.db-after.kind .SQLite-Root-Snapshot))
        (t.is (> (vev.store-db-sqlite-page-cache-count (addr report.db-before)) 0))
        (t.is (not (vev.store-resident-db-available? (addr read-store))))
        (vev.delete-store-tx-report report))
      (vev.close-store read-store))))

(t.deftest sqlite-durable-db-value-gate-normal-apis-stay-storage-neutral
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.durable-db-value-gate.sqlite")
  (let [path "tmp.vev.durable-db-value-gate.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-report-text
               (addr store)
               "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/many} {:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\" :user/age 40 :user/friend [2]} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\" :user/age 35}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is seed.ok seed.error)
    (t.is (= seed.db-after.kind .SQLite-Root-Snapshot))
    (vev.delete-store-tx-report seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr reopened))
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])]
      (t.is reopened-ok reopened-error)
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (t.is snapshot-ok snapshot-error)
      (t.is (= snapshot.kind .SQLite-Root-Snapshot))
      (let [query-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
            rules-result (vev.q-result-store-db-text-with-rules
                           (addr snapshot)
                           "[:find ?name :where (friend-name 1 ?name)]"
                           "[[(friend-name ?e ?name) [?e :user/friend ?friend] [?friend :user/name ?name]]]")
            [pulled pulled-ok pulled-error] (vev.pull-store-db-value-text (addr snapshot) "[:user/name {:user/friend [:user/name]}]" 1)
            [lookup-entity lookup-ok lookup-error] (vev.store-db-entity-lookup-ref (addr snapshot) ":user/email" (vev.value-string "ada@example.com"))
            with-report (vev.with-store-db-report-text (addr snapshot) "[{:db/id 3 :user/name \"Barbara\"}]")
            overlay (vev.db-with-store-db-text (addr snapshot) "[{:db/id 4 :user/name \"Dorothy\"}]")
            source-report (vev.transact-store-report-text-with-source-string-fns
                            (addr reopened)
                            "[[:db/add 102 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"] [:db/add 1 :user/label \"after-birthday\"]]"
                            registry)
            later-report (vev.transact-store-report-text (addr reopened) "[{:db/id 5 :user/name \"Hedy\"}]")
            snapshot-after-later (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
            with-after (vev.q-result-store-db-text (addr with-report.db-after) "[:find ?name :where [?e :user/name ?name]]")
            overlay-result (vev.q-result-store-db-text (addr overlay) "[:find ?name :where [?e :user/name ?name]]")
            source-before (vev.q-result-store-db-text (addr source-report.db-before) "[:find ?age :where [1 :user/age ?age]]")
            source-after (vev.q-result-store-db-text (addr source-report.db-after) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/label ?label]]")
            later-live (vev.q-result-store-text (addr reopened) "[:find ?name :where [?e :user/name ?name]]")]
        (t.is query-result.result.ok query-result.result.error)
        (t.is (= (count query-result.result.rows) 2))
        (t.is (result-has-string-row? query-result.result "Ada"))
        (t.is (result-has-string-row? query-result.result "Grace"))
        (t.is rules-result.result.ok rules-result.result.error)
        (t.is (= (count rules-result.result.rows) 1))
        (t.is (result-has-string-row? rules-result.result "Grace"))
        (t.is pulled-ok pulled-error)
        (t.is (= pulled.kind .Map))
        (t.is lookup-ok lookup-error)
        (t.is (vev.store-entity-found? lookup-entity))
        (t.is (= (vev.store-entity-id lookup-entity) 1))
        (t.is with-report.ok with-report.error)
        (t.is (sqlite-durable-store-db? with-report.db-before))
        (t.is (= with-report.db-after.kind .SQLite-Tx-Ops-Overlay))
        (t.is (= overlay.kind .SQLite-Tx-Ops-Overlay))
        (t.is source-report.ok source-report.error)
        (t.is later-report.ok later-report.error)
        (t.is (sqlite-durable-store-db? source-report.db-before))
        (t.is (sqlite-durable-store-db? source-report.db-after))
        (t.is (sqlite-durable-store-db? later-report.db-before))
        (t.is (sqlite-durable-store-db? later-report.db-after))
        (t.is snapshot-after-later.result.ok snapshot-after-later.result.error)
        (t.is (= (count snapshot-after-later.result.rows) 2))
        (t.is (not (result-has-string-row? snapshot-after-later.result "Hedy")))
        (t.is with-after.result.ok with-after.result.error)
        (t.is (= (count with-after.result.rows) 3))
        (t.is (result-has-string-row? with-after.result "Barbara"))
        (t.is overlay-result.result.ok overlay-result.result.error)
        (t.is (= (count overlay-result.result.rows) 3))
        (t.is (result-has-string-row? overlay-result.result "Dorothy"))
        (t.is source-before.result.ok source-before.result.error)
        (t.is (= source-before.result.rows[0].values[0].int-value 40))
        (t.is source-after.result.ok source-after.result.error)
        (t.is (= source-after.result.rows[0].values[0].int-value 41))
        (t.is (= source-after.result.rows[0].values[1].text "after-birthday"))
        (t.is later-live.result.ok later-live.result.error)
        (t.is (result-has-string-row? later-live.result "Hedy"))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (vev.delete-query-result query-result)
        (vev.delete-query-result rules-result)
        (vev.delete-owned-value pulled)
        (vev.close-store-entity! (addr lookup-entity))
        (vev.delete-query-result snapshot-after-later)
        (vev.delete-query-result with-after)
        (vev.delete-query-result overlay-result)
        (vev.delete-query-result source-before)
        (vev.delete-query-result source-after)
        (vev.delete-query-result later-live)
        (vev.delete-store-tx-report with-report)
        (vev.close-store-db overlay)
        (vev.delete-store-tx-report source-report)
        (vev.delete-store-tx-report later-report))
      (vev.close-store-db snapshot)
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-supports-source-transaction-functions
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-source-fns.sqlite")
  (let [path "tmp.vev.store-report-direct-source-fns.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        seed (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\" :user/age 40}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is seed.ok seed.error)
    (vev.delete-live-tx-report-shallow seed)
    (vev.close-store store)
    (let [[reopened reopened-ok reopened-error] (vev.open-store path)
          registry ([]vev.Tx-Fn-Source-String [(vev.tx-fn-source-string ":birthday" store-source-birthday-by-name)])]
      (t.is reopened-ok)
      (t.is (= reopened-error ""))
      (t.is (not (vev.store-resident-db-available? (addr reopened))))
      (let [warm (vev.q-result-store-text (addr reopened) "[:find ?age :where [1 :user/age ?age]]")]
        (t.is warm.result.ok warm.result.error)
        (t.is (= (count warm.result.rows) 1))
        (t.is (> (vev.store-current-root-page-cache-count (addr reopened)) 0))
        (vev.delete-query-result warm))
      (let [report (vev.transact-store-report-text-with-source-string-fns
                     (addr reopened)
                     "[[:db/add 100 :db/ident :birthday] [:db.fn/call :birthday \"Ada\"] [:db/add 1 :user/label \"after-call\"]]"
                     registry)
            live-result (vev.q-result-store-text (addr reopened) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/had-birthday true] [1 :user/label ?label]]")
            before-result (vev.q-result-store-db-text (addr report.db-before) "[:find ?age :where [1 :user/age ?age]]")
            after-result (vev.q-result-store-db-text (addr report.db-after) "[:find ?age ?label :where [1 :user/age ?age] [1 :user/had-birthday true] [1 :user/label ?label]]")]
        (t.is report.ok report.error)
        (t.is (sqlite-durable-store-db? report.db-before))
        (t.is (sqlite-durable-store-db? report.db-after))
        (t.is (> (vev.store-db-sqlite-page-cache-count (addr report.db-before)) 0))
        (t.is (not (vev.store-resident-db-available? (addr reopened))))
        (t.is live-result.result.ok live-result.result.error)
        (t.is (= (count live-result.result.rows) 1))
        (t.is (= live-result.result.rows[0].values[0].kind .Int))
        (t.is (= live-result.result.rows[0].values[0].int-value 41))
        (t.is (= live-result.result.rows[0].values[1].kind .String))
        (t.is (= live-result.result.rows[0].values[1].text "after-call"))
        (t.is before-result.result.ok before-result.result.error)
        (t.is (= (count before-result.result.rows) 1))
        (t.is (= before-result.result.rows[0].values[0].int-value 40))
        (t.is after-result.result.ok after-result.result.error)
        (t.is (= (count after-result.result.rows) 1))
        (t.is (= after-result.result.rows[0].values[0].int-value 41))
        (t.is (= after-result.result.rows[0].values[1].text "after-call"))
        (vev.delete-query-result live-result)
        (vev.delete-query-result before-result)
        (vev.delete-query-result after-result)
        (vev.delete-store-tx-report report))
      (vev.close-store reopened))))

(t.deftest sqlite-store-report-direct-write-supports-value-arg-source-transaction-functions
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-report-direct-source-value-fns.sqlite")
