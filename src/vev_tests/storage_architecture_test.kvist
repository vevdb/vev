      (t.is (= (count result.result.rows) 2))
      (t.is (= result.result.rows[0].values[1].text "Ada"))
      (t.is (= result.result.rows[0].values[2].text "ada@example.com"))
      (t.is (= result.result.rows[1].values[1].text "Grace"))
      (t.is (= result.result.rows[1].values[2].text "ada@example.com"))
