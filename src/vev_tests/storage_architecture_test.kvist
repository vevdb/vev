      (t.is (= reopened-error ""))
      (t.is (int-slices-equal? (slice reopened.db.eavt 0) (slice db.eavt 0)))
      (t.is (int-slices-equal? (slice reopened.db.aevt 0) (slice db.aevt 0)))
      (delete loaded-eavt)
      (delete loaded-aevt)
      (delete eavt-page-first)
      (delete eavt-page-cross)
      (delete eavt-page-tail)
      (vev.close-sqlite-index-cursor! (addr cursor))
      (vev.close-sqlite-index-snapshot! (addr snapshot))
      (vev.close-sqlite-db-snapshot! (addr db-snapshot))
      (vev.delete-owned-db reopened.db)
      (delete reopened.listeners)
      (vev.delete-owned-db db))))

(t.deftest store-db-source-single-clause-aggregates-use-current-facts
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-source-aggregates.sqlite")
  (let [path "tmp.vev.storage-architecture-source-aggregates.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\" :user/age 37} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\" :user/age 41}]")
        retract-report (vev.transact-sqlite-text
                         (addr store)
                         "[[:db/retract 2 :user/email \"grace@example.com\"]]")
        [source-store source-store-ok source-store-error] (vev.open-store-read-only path)
        [source-store-db source-store-db-ok source-store-db-error] (vev.store-db (addr source-store))
        aggregate-result (vev.q-result-store-db-text (addr source-store-db) "[:find (count ?name) (count-distinct ?name) :with ?e :where [?e :user/name ?name]]")
        current-result (vev.q-result-store-db-text (addr source-store-db) "[:find (count ?email) :with ?e :where [?e :user/email ?email]]")
        top-n-result (vev.q-result-store-db-text (addr source-store-db) "[:find (max 1 ?age) (min 1 ?age) :where [?e :user/age ?age]]")
        all-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?a ?v :where [?e ?a ?v]]")
        fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name :where [1 :user/name ?name]]")
        retracted-fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?email :where [2 :user/email ?email]]")
        attr-value-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/name \"Ada\"]]")
        retracted-attr-value-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e :where [?e :user/email \"grace@example.com\"]]")
        attr-value-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name :where [?e :user/name ?name]]")
        retracted-attr-value-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?email :where [?e :user/email ?email]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok opened-error)
    (t.is (= opened-error ""))
    (t.is report.ok report.error)
    (t.is retract-report.ok retract-report.error)
    (t.is source-store-ok source-store-error)
    (t.is (= source-store-error ""))
    (t.is source-store-db-ok source-store-db-error)
    (t.is (= source-store-db-error ""))
    (t.is aggregate-result.result.ok aggregate-result.result.error)
    (t.is (= aggregate-result.result.error ""))
    (t.is (= (count aggregate-result.result.rows) 1))
    (t.is (= (count aggregate-result.result.rows[0].values) 2))
    (t.is (= aggregate-result.result.rows[0].values[0].kind .Int))
    (t.is (= aggregate-result.result.rows[0].values[0].int-value 2))
    (t.is (= aggregate-result.result.rows[0].values[1].kind .Int))
    (t.is (= aggregate-result.result.rows[0].values[1].int-value 2))
    (t.is current-result.result.ok current-result.result.error)
    (t.is (= current-result.result.error ""))
    (t.is (= (count current-result.result.rows) 1))
    (t.is (= (count current-result.result.rows[0].values) 1))
    (t.is (= current-result.result.rows[0].values[0].kind .Int))
    (t.is (= current-result.result.rows[0].values[0].int-value 1))
    (t.is top-n-result.result.ok top-n-result.result.error)
    (t.is (= top-n-result.result.error ""))
    (t.is (= (count top-n-result.result.rows) 1))
    (t.is (= top-n-result.result.rows[0].values[0].kind .Vector))
    (t.is (= top-n-result.result.rows[0].values[1].kind .Vector))
    (t.is (= (count top-n-result.result.rows[0].values[0].items) 1))
    (t.is (= (count top-n-result.result.rows[0].values[1].items) 1))
    (t.is (= top-n-result.result.rows[0].values[0].items[0].int-value 41))
    (t.is (= top-n-result.result.rows[0].values[1].items[0].int-value 37))
    (t.is all-attr-result.result.ok all-attr-result.result.error)
    (t.is (= all-attr-result.result.error ""))
    (let [has-ada-name false
          has-grace-age false
          has-retracted-grace-email false]
      (for [row all-attr-result.result.rows]
        (when (= (count row.values) 3)
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 1)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/name")
                     (= row.values[2].kind .String)
                     (= row.values[2].text "Ada"))
            (set! has-ada-name true))
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 2)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/age")
                     (= row.values[2].kind .Int)
                     (= row.values[2].int-value 41))
            (set! has-grace-age true))
          (when (and (= row.values[0].kind .Entity)
                     (= row.values[0].entity 2)
                     (= row.values[1].kind .Keyword)
                     (= row.values[1].text ":user/email")
                     (= row.values[2].kind .String)
                     (= row.values[2].text "grace@example.com"))
            (set! has-retracted-grace-email true))))
      (t.is has-ada-name)
      (t.is has-grace-age)
      (t.is (not has-retracted-grace-email)))
    (t.is fixed-entity-result.result.ok fixed-entity-result.result.error)
    (t.is (= fixed-entity-result.result.error ""))
    (t.is (= (count fixed-entity-result.result.rows) 1))
    (t.is (= fixed-entity-result.result.rows[0].values[0].kind .String))
    (t.is (= fixed-entity-result.result.rows[0].values[0].text "Ada"))
    (t.is retracted-fixed-entity-result.result.ok retracted-fixed-entity-result.result.error)
    (t.is (= retracted-fixed-entity-result.result.error ""))
    (t.is (= (count retracted-fixed-entity-result.result.rows) 0))
    (t.is attr-value-entity-result.result.ok attr-value-entity-result.result.error)
    (t.is (= attr-value-entity-result.result.error ""))
    (t.is (= (count attr-value-entity-result.result.rows) 1))
    (t.is (= attr-value-entity-result.result.rows[0].values[0].kind .Entity))
    (t.is (= attr-value-entity-result.result.rows[0].values[0].entity 1))
    (t.is retracted-attr-value-entity-result.result.ok retracted-attr-value-entity-result.result.error)
    (t.is (= retracted-attr-value-entity-result.result.error ""))
    (t.is (= (count retracted-attr-value-entity-result.result.rows) 0))
    (t.is attr-value-result.result.ok attr-value-result.result.error)
    (t.is (= attr-value-result.result.error ""))
    (t.is (= (count attr-value-result.result.rows) 2))
    (let [has-ada false
          has-grace false]
      (for [row attr-value-result.result.rows]
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .String)
                   (= row.values[0].text "Ada"))
          (set! has-ada true))
        (when (and (= (count row.values) 1)
                   (= row.values[0].kind .String)
                   (= row.values[0].text "Grace"))
          (set! has-grace true)))
      (t.is has-ada)
      (t.is has-grace))
    (t.is retracted-attr-value-result.result.ok retracted-attr-value-result.result.error)
    (t.is (= retracted-attr-value-result.result.error ""))
    (t.is (= (count retracted-attr-value-result.result.rows) 1))
    (t.is (= retracted-attr-value-result.result.rows[0].values[0].kind .String))
    (t.is (= retracted-attr-value-result.result.rows[0].values[0].text "ada@example.com"))
    (vev.delete-query-result aggregate-result)
    (vev.delete-query-result current-result)
    (vev.delete-query-result top-n-result)
    (vev.delete-query-result all-attr-result)
    (vev.delete-query-result fixed-entity-result)
    (vev.delete-query-result retracted-fixed-entity-result)
    (vev.delete-query-result attr-value-entity-result)
    (vev.delete-query-result retracted-attr-value-entity-result)
    (vev.delete-query-result attr-value-result)
    (vev.delete-query-result retracted-attr-value-result)
    (vev.close-store-db! (addr source-store-db))
    (vev.close-store source-store)
    (vev.delete-tx-report-shallow report)
    (vev.delete-tx-report-shallow retract-report)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-db-read-source-filters-retracted-datoms
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-source.sqlite")
  (let [path "tmp.vev.storage-architecture-source.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 100 :db/ident :user/email :db/unique :db.unique/identity} {:db/id 101 :db/ident :user/email-name :db/valueType :db.type/tuple :db/tupleAttrs [:user/email :user/name] :db/unique :db.unique/identity} {:db/id 102 :db/ident :user/friend :db/valueType :db.type/ref} {:db/id 103 :db/ident :user/friend-code :db/valueType :db.type/tuple :db/tupleAttrs [:user/friend :user/code] :db/unique :db.unique/identity} {:db/id 104 :db/ident :user/code} {:db/id 1 :user/name \"Ada\" :user/age 37 :user/email \"ada@example.com\"} {:db/id 2 :user/name \"Grace\" :user/age 41 :user/email \"grace@example.com\" :user/code \"grace-code\" :user/friend 1}]")
        retract-report (vev.transact-sqlite-text
                         (addr store)
                         "[[:db/retract 2 :user/email \"grace@example.com\"]]")
        [snapshot snapshot-ok snapshot-error] (vev.sqlite-conn-open-db-snapshot (addr store) 32)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is retract-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (let [source (vev.sqlite-db-read-source (addr snapshot))
          [emails emails-ok emails-error] (vev.db-read-source-datoms-by-attr source ":user/email")
          [ada-email ada-ok ada-error] (vev.db-read-source-datoms-by-entity-attr source 1 ":user/email")
          [grace-email grace-ok grace-error] (vev.db-read-source-datoms-by-entity-attr source 2 ":user/email")
          [ada-range-low ada-range-high ada-range-exists ada-range-ok ada-range-error] (vev.db-read-source-eavt-entity-range source 1)
          [ada-name-value ada-name-value-ok ada-name-value-error] (vev.db-read-source-cardinality-one-value-fast-all-current source 1 ":user/name")
          [ada-age-value ada-age-value-ok ada-age-value-error] (vev.db-read-source-cardinality-one-int-value-fast-all-current source 1 ":user/age")
          [ada-name-matches ada-name-matches-ok ada-name-matches-error] (vev.db-read-source-cardinality-one-value-matches-fast-all-current? source 1 ":user/name" (vev.value-string "Ada"))
          prepared (vev.prepare-query-text "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
          durable-text-result (vev.q-result-sqlite-conn-text (addr store) "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
          durable-prepared-result (vev.q-result-sqlite-conn-prepared (addr store) prepared)
          [source-store source-store-ok source-store-error] (vev.open-store-read-only path)
          source-only-result (vev.q-result-store-prepared (addr source-store) prepared)
          [source-store-db source-store-db-ok source-store-db-error] (vev.store-db (addr source-store))
          source-store-db-result (vev.q-result-store-db-prepared (addr source-store-db) prepared)
          source-store-db-one-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/name ?name]]")
          source-store-db-filtered-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/email \"ada@example.com\"] [?e :user/name ?name]]")
          source-store-db-filtered-retracted-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?e ?name :where [?e :user/email \"grace@example.com\"] [?e :user/name ?name]]")
          source-store-db-fixed-entity-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [1 :user/name ?name] [1 :user/age ?age]]")
          source-store-db-fixed-entity-missing-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [9 :user/name ?name] [9 :user/age ?age]]")
          source-store-db-two-attr-result (vev.q-result-store-db-text (addr source-store-db) "[:find ?name ?age :where [?e :user/name ?name] [?e :user/age ?age]]")
          [source-store-db-pull source-store-db-pull-ok source-store-db-pull-error] (vev.pull-store-db-value-text (addr source-store-db) "[:user/name {:user/friend [:user/name]}]" 2)
          [source-store-db-pull-name source-store-db-pull-name-ok] (vev.map-get-value source-store-db-pull (vev.value-keyword ":user/name"))
          [source-store-db-pull-friend source-store-db-pull-friend-ok] (vev.map-get-value source-store-db-pull (vev.value-keyword ":user/friend"))
          [source-store-db-pull-friend-name source-store-db-pull-friend-name-ok] (vev.map-get-value source-store-db-pull-friend (vev.value-keyword ":user/name"))
          source-only-tx-report (vev.transact-store-text (addr source-store) "[{:db/id 3 :user/name \"Should Fail\"}]")
          join-result (vev.q-text-db-read-source source "[:find ?name ?email :where [?e :user/name ?name] [?e :user/email ?email]]")
          source-qualified-result (vev.q-text-db-read-source source "[:find ?name :where [$ 1 :user/name ?name]]")
          predicate-result (vev.q-text-db-read-source source "[:find ?name :where [?e :user/name ?name] [(= ?name \"Ada\")]]")
          predicate-empty-result (vev.q-text-db-read-source source "[:find ?name :where [?e :user/name ?name] [(= ?name \"Missing\")]]")
          lookup-ref-result (vev.q-text-db-read-source source "[:find ?name :where [[:user/email \"ada@example.com\"] :user/name ?name]]")
          non-unique-lookup-ref-result (vev.q-text-db-read-source source "[:find ?email :where [[:user/name \"Ada\"] :user/email ?email]]")
          tuple-lookup-ref-result (vev.q-text-db-read-source source "[:find ?email :where [[:user/email-name [\"ada@example.com\" \"Ada\"]] :user/email ?email]]")
          tuple-ref-direct-result (vev.q-text-db-read-source source "[:find ?tuple :where [2 :user/friend-code ?tuple]]")
          tuple-ref-lookup-ref-result (vev.q-text-db-read-source source "[:find ?name :where [[:user/friend-code [[:user/email \"ada@example.com\"] \"grace-code\"]] :user/name ?name]]")
          bound-entity-result (vev.q-text-db-read-source source "[:find ?email :where [1 :user/email ?email]]")
          function-result (vev.q-text-db-read-source source "[:find ?name ?len :where [?e :user/name ?name] [(count ?name) ?len] [(= ?len 3)]]")
          tuple-function-result (vev.q-text-db-read-source source "[:find ?tuple-name ?id :where [?e :user/name ?name] [(= ?name \"Ada\")] [(vector ?name ?e) [?tuple-name ?id]]]")
          or-result (vev.q-text-db-read-source source "[:find ?name :where (or [?e :user/name \"Ada\"] [?e :user/name \"Grace\"]) [?e :user/name ?name]]")
          or-join-result (vev.q-text-db-read-source source "[:find ?name :where [?e :user/name ?name] (or-join [?e] [?e :user/email \"ada@example.com\"] [?e :user/name \"Grace\"])]")
          named-source-result (vev.q-text-db-read-source source "[:find ?name :where [$other 1 :user/name ?name]]")]
      (t.is emails-ok)
      (t.is (= emails-error ""))
      (t.is (= (count emails) 1))
      (t.is (= emails[0].e 1))
      (t.is (= emails[0].v.kind .String))
      (t.is (= emails[0].v.text "ada@example.com"))
      (t.is ada-ok)
      (t.is (= ada-error ""))
      (t.is (= (count ada-email) 1))
      (t.is (= ada-email[0].e 1))
      (t.is grace-ok)
      (t.is (= grace-error ""))
      (t.is (= (count grace-email) 0))
      (t.is ada-range-ok)
      (t.is (= ada-range-error ""))
      (t.is ada-range-exists)
      (t.is (> ada-range-high ada-range-low))
      (t.is ada-name-value-ok)
      (t.is (= ada-name-value-error ""))
      (t.is (= ada-name-value.kind .String))
      (t.is (= ada-name-value.text "Ada"))
      (t.is ada-age-value-ok)
      (t.is (= ada-age-value-error ""))
      (t.is (= ada-age-value 37))
      (t.is ada-name-matches-ok)
      (t.is (= ada-name-matches-error ""))
      (t.is ada-name-matches)
      (t.is prepared.ok)
      (t.is durable-text-result.result.ok)
      (t.is (= durable-text-result.result.error ""))
      (t.is (= (count durable-text-result.result.rows) 1))
      (t.is (= durable-text-result.result.rows[0].values[0].kind .String))
      (t.is (= durable-text-result.result.rows[0].values[0].text "Ada"))
      (t.is durable-prepared-result.result.ok)
      (t.is (= durable-prepared-result.result.error ""))
      (t.is (= (count durable-prepared-result.result.rows) 1))
      (t.is (= durable-prepared-result.result.rows[0].values[0].kind .String))
      (t.is (= durable-prepared-result.result.rows[0].values[0].text "Ada"))
      (t.is source-store-ok)
      (t.is (= source-store-error ""))
      (t.is (vev.store-read-only? (addr source-store)))
      (t.is (not (vev.store-resident-db-available? (addr source-store))))
      (t.is source-store-db-ok)
      (t.is (= source-store-db-error ""))
      (t.is source-only-result.result.ok)
      (t.is (= source-only-result.result.error ""))
      (t.is (= (count source-only-result.result.rows) 1))
      (t.is (= source-only-result.result.rows[0].values[0].kind .String))
      (t.is (= source-only-result.result.rows[0].values[0].text "Ada"))
      (t.is source-store-db-result.result.ok)
      (t.is (= source-store-db-result.result.error ""))
      (t.is (= (count source-store-db-result.result.rows) 1))
      (t.is (= source-store-db-result.result.rows[0].values[0].kind .String))
      (t.is (= source-store-db-result.result.rows[0].values[0].text "Ada"))
      (t.is source-store-db-one-attr-result.result.ok)
      (t.is (= source-store-db-one-attr-result.result.error ""))
      (t.is (= (count source-store-db-one-attr-result.result.rows) 2))
      (t.is (result-has-entity-string-row? source-store-db-one-attr-result.result 1 "Ada"))
      (t.is (result-has-entity-string-row? source-store-db-one-attr-result.result 2 "Grace"))
      (t.is source-store-db-filtered-result.result.ok)
      (t.is (= source-store-db-filtered-result.result.error ""))
      (t.is (= (count source-store-db-filtered-result.result.rows) 1))
      (t.is (result-has-entity-string-row? source-store-db-filtered-result.result 1 "Ada"))
      (t.is source-store-db-filtered-retracted-result.result.ok)
      (t.is (= source-store-db-filtered-retracted-result.result.error ""))
      (t.is (= (count source-store-db-filtered-retracted-result.result.rows) 0))
      (t.is source-store-db-fixed-entity-result.result.ok)
      (t.is (= source-store-db-fixed-entity-result.result.error ""))
      (t.is (= (count source-store-db-fixed-entity-result.result.rows) 1))
      (t.is (result-has-string-int-row? source-store-db-fixed-entity-result.result "Ada" 37))
      (t.is source-store-db-fixed-entity-missing-result.result.ok)
      (t.is (= source-store-db-fixed-entity-missing-result.result.error ""))
      (t.is (= (count source-store-db-fixed-entity-missing-result.result.rows) 0))
      (t.is source-store-db-two-attr-result.result.ok)
      (t.is (= source-store-db-two-attr-result.result.error ""))
      (t.is (= (count source-store-db-two-attr-result.result.rows) 2))
      (t.is (result-has-string-int-row? source-store-db-two-attr-result.result "Ada" 37))
      (t.is (result-has-string-int-row? source-store-db-two-attr-result.result "Grace" 41))
      (t.is source-store-db-pull-ok)
      (t.is (= source-store-db-pull-error ""))
      (t.is (= source-store-db-pull.kind .Map))
      (t.is source-store-db-pull-name-ok)
      (t.is (= source-store-db-pull-name.kind .String))
      (t.is (= source-store-db-pull-name.text "Grace"))
      (t.is source-store-db-pull-friend-ok)
      (t.is (= source-store-db-pull-friend.kind .Map))
      (t.is source-store-db-pull-friend-name-ok)
      (t.is (= source-store-db-pull-friend-name.kind .String))
      (t.is (= source-store-db-pull-friend-name.text "Ada"))
      (t.is (not source-only-tx-report.ok))
      (t.is (= source-only-tx-report.error "SQLite source connection is read-only; open a writable SQLite connection to transact"))
      (t.is join-result.ok)
      (t.is (= join-result.error ""))
      (t.is (= (count join-result.rows) 1))
      (t.is (= (count join-result.rows[0].values) 2))
      (t.is (= join-result.rows[0].values[0].kind .String))
      (t.is (= join-result.rows[0].values[0].text "Ada"))
      (t.is (= join-result.rows[0].values[1].kind .String))
      (t.is (= join-result.rows[0].values[1].text "ada@example.com"))
      (t.is source-qualified-result.ok)
      (t.is (= source-qualified-result.error ""))
      (t.is (= (count source-qualified-result.rows) 1))
      (t.is (= (count source-qualified-result.rows[0].values) 1))
      (t.is (= source-qualified-result.rows[0].values[0].kind .String))
      (t.is (= source-qualified-result.rows[0].values[0].text "Ada"))
      (t.is predicate-result.ok)
      (t.is (= predicate-result.error ""))
      (t.is (= (count predicate-result.rows) 1))
      (t.is (= predicate-result.rows[0].values[0].kind .String))
      (t.is (= predicate-result.rows[0].values[0].text "Ada"))
      (t.is predicate-empty-result.ok)
      (t.is (= predicate-empty-result.error ""))
      (t.is (= (count predicate-empty-result.rows) 0))
      (t.is lookup-ref-result.ok)
      (t.is (= lookup-ref-result.error ""))
      (t.is (= (count lookup-ref-result.rows) 1))
      (t.is (= lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= lookup-ref-result.rows[0].values[0].text "Ada"))
      (t.is (not non-unique-lookup-ref-result.ok))
      (t.is (= non-unique-lookup-ref-result.error "lookup ref attribute must be unique"))
      (t.is tuple-lookup-ref-result.ok)
      (t.is (= tuple-lookup-ref-result.error ""))
      (t.is (= (count tuple-lookup-ref-result.rows) 1))
      (t.is (= tuple-lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= tuple-lookup-ref-result.rows[0].values[0].text "ada@example.com"))
      (t.is tuple-ref-direct-result.ok)
      (t.is (= tuple-ref-direct-result.error ""))
      (t.is (= (count tuple-ref-direct-result.rows) 1))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].kind .Vector))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[0].kind .Entity))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[0].entity 1))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[1].kind .String))
      (t.is (= tuple-ref-direct-result.rows[0].values[0].items[1].text "grace-code"))
      (t.is tuple-ref-lookup-ref-result.ok)
      (t.is (= tuple-ref-lookup-ref-result.error ""))
      (t.is (= (count tuple-ref-lookup-ref-result.rows) 1))
      (t.is (= tuple-ref-lookup-ref-result.rows[0].values[0].kind .String))
      (t.is (= tuple-ref-lookup-ref-result.rows[0].values[0].text "Grace"))
      (t.is bound-entity-result.ok)
      (t.is (= bound-entity-result.error ""))
      (t.is (= (count bound-entity-result.rows) 1))
      (t.is (= bound-entity-result.rows[0].values[0].kind .String))
      (t.is (= bound-entity-result.rows[0].values[0].text "ada@example.com"))
      (t.is function-result.ok)
      (t.is (= function-result.error ""))
      (t.is (= (count function-result.rows) 1))
      (t.is (= (count function-result.rows[0].values) 2))
      (t.is (= function-result.rows[0].values[0].kind .String))
      (t.is (= function-result.rows[0].values[0].text "Ada"))
      (t.is (= function-result.rows[0].values[1].kind .Int))
      (t.is (= function-result.rows[0].values[1].int-value 3))
      (t.is tuple-function-result.ok)
      (t.is (= tuple-function-result.error ""))
      (t.is (= (count tuple-function-result.rows) 1))
      (t.is (= (count tuple-function-result.rows[0].values) 2))
      (t.is (= tuple-function-result.rows[0].values[0].kind .String))
      (t.is (= tuple-function-result.rows[0].values[0].text "Ada"))
      (t.is (= tuple-function-result.rows[0].values[1].kind .Entity))
      (t.is (= tuple-function-result.rows[0].values[1].entity 1))
      (t.is or-result.ok)
      (t.is (= or-result.error ""))
      (t.is (= (count or-result.rows) 2))
      (t.is (result-has-string-row? or-result "Ada"))
      (t.is (result-has-string-row? or-result "Grace"))
      (t.is or-join-result.ok)
      (t.is (= or-join-result.error ""))
      (t.is (= (count or-join-result.rows) 2))
      (t.is (result-has-string-row? or-join-result "Ada"))
      (t.is (result-has-string-row? or-join-result "Grace"))
      (t.is named-source-result.ok)
      (t.is (= named-source-result.error ""))
      (t.is (= (count named-source-result.rows) 1))
      (t.is (= named-source-result.rows[0].values[0].kind .String))
      (t.is (= named-source-result.rows[0].values[0].text "Ada"))
      (vev.delete-owned-datoms emails)
      (vev.delete-owned-datoms ada-email)
      (vev.delete-owned-datoms grace-email)
      (vev.delete-owned-value ada-name-value)
      (vev.delete-result-set-owned-values join-result)
      (vev.delete-result-set-owned-values source-qualified-result)
      (vev.delete-result-set-owned-values predicate-result)
      (vev.delete-result-set-owned-values predicate-empty-result)
      (vev.delete-result-set-owned-values lookup-ref-result)
      (vev.delete-result-set-owned-values non-unique-lookup-ref-result)
      (vev.delete-result-set-owned-values tuple-lookup-ref-result)
      (vev.delete-result-set-owned-values tuple-ref-direct-result)
      (vev.delete-result-set-owned-values tuple-ref-lookup-ref-result)
      (vev.delete-result-set-owned-values bound-entity-result)
      (vev.delete-query-shallow prepared.query)
      (vev.delete-query-result durable-text-result)
      (vev.delete-query-result durable-prepared-result)
      (vev.delete-query-result source-only-result)
      (vev.delete-query-result source-store-db-result)
      (vev.delete-query-result source-store-db-one-attr-result)
      (vev.delete-query-result source-store-db-filtered-result)
      (vev.delete-query-result source-store-db-filtered-retracted-result)
      (vev.delete-query-result source-store-db-fixed-entity-result)
      (vev.delete-query-result source-store-db-fixed-entity-missing-result)
      (vev.delete-query-result source-store-db-two-attr-result)
      (vev.delete-owned-value source-store-db-pull)
      (vev.close-store-db! (addr source-store-db))
      (vev.delete-tx-report-shallow source-only-tx-report)
      (vev.close-store source-store)
      (vev.delete-result-set-owned-values function-result)
      (vev.delete-result-set-owned-values tuple-function-result)
      (vev.delete-result-set-owned-values or-result)
      (vev.delete-result-set-owned-values or-join-result)
      (vev.delete-result-set-owned-values named-source-result))
    (vev.close-sqlite-db-snapshot! (addr snapshot))
    (vev.close-sqlite-conn store)))
