(package vev-tests)

(import arr "kvist:arr")
(import fmt "core:fmt")
(import os "core:os")
(import t "kvist:test")
(import vev "../vev")

(defn remove-sqlite-files [path: string]
  (os.remove path)
  (os.remove (fmt.tprintf "%s-wal" path))
  (os.remove (fmt.tprintf "%s-shm" path)))

(defn int-slices-equal? [left: []int, right: []int] -> bool
  (when (not (= (count left) (count right)))
    (return false))
  (for [i (arr.range 0 (count left))]
    (when (not (= left[i] right[i]))
      (return false)))
  true)

(defn result-has-string-row? [result: vev.Result-Set, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .String)
               (= row.values[0].text text))
      (return true)))
  false)

(defn result-has-string-int-row? [result: vev.Result-Set, text: string, value: i64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .String)
               (= row.values[0].text text)
               (= row.values[1].kind .Int)
               (= row.values[1].int-value value))
      (return true)))
  false)

(defn result-has-entity-string-row? [result: vev.Result-Set, entity: u64, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity)
               (= row.values[1].kind .String)
               (= row.values[1].text text))
      (return true)))
  false)

(defn native-tag-value [value: vev.Value] -> vev.Native-Query-Function-Result
  (when (not (= value.kind .String))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result
    (vev.value-string (fmt.tprintf "tag:%s" value.text))))

(t.deftest resident-query-result-wrappers-use-shallow-cleanup
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :user/name "Ada" :user/age 37}])
        prepared (vev.prepare-query-text "[:find ?name :where [1 :user/name ?name]]")
        text-result (vev.q-result-text conn.db "[:find ?name :where [1 :user/name ?name]]")
        prepared-result (vev.q-result-prepared conn.db prepared)
        resident-source (vev.resident-db-read-source (addr conn.db))
        [range-low range-high range-exists range-ok range-error] (vev.db-read-source-eavt-entity-range resident-source 1)
        [name-value name-value-ok name-value-error] (vev.db-read-source-cardinality-one-value-fast-all-current resident-source 1 ":user/name")
        [age-value age-value-ok age-value-error] (vev.db-read-source-cardinality-one-int-value-fast-all-current resident-source 1 ":user/age")
        [name-matches name-matches-ok name-matches-error] (vev.db-read-source-cardinality-one-value-matches-fast-all-current? resident-source 1 ":user/name" (vev.value-string "Ada"))]
    (t.is report.ok)
    (t.is prepared.ok)
    (t.is range-ok)
    (t.is (= range-error ""))
    (t.is range-exists)
    (t.is (> range-high range-low))
    (t.is name-value-ok)
    (t.is (= name-value-error ""))
    (t.is (= name-value.kind .String))
    (t.is (= name-value.text "Ada"))
    (t.is age-value-ok)
    (t.is (= age-value-error ""))
    (t.is (= age-value 37))
    (t.is name-matches-ok)
    (t.is (= name-matches-error ""))
    (t.is name-matches)
    (t.is (not (vev.query-result-owns-values? text-result)))
    (t.is (= (count text-result.result.rows) 1))
    (t.is (= text-result.result.rows[0].values[0].kind .String))
    (t.is (= text-result.result.rows[0].values[0].text "Ada"))
    (t.is (not (vev.query-result-owns-values? prepared-result)))
    (t.is (= (count prepared-result.result.rows) 1))
    (t.is (= prepared-result.result.rows[0].values[0].kind .String))
    (t.is (= prepared-result.result.rows[0].values[0].text "Ada"))
    (vev.delete-query-result text-result)
    (vev.delete-query-result prepared-result)
    (vev.delete-owned-value name-value)
    (vev.delete-query-shallow prepared.query)
    (vev.delete-owned-db conn.db)
    (delete conn.listeners)))

(t.deftest sqlite-initializes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture.sqlite")
  (let [path "tmp.vev.storage-architecture.sqlite"
        [architecture architecture-ok architecture-error] (vev.sqlite-storage-architecture path)
        [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
        [_ latest-ok latest-error] (vev.sqlite-latest-index-root-basis path)]
    (defer (remove-sqlite-files path))
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 0))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 0))
    (t.is (not latest-ok))
    (t.is (= latest-error "sqlite DB has no Vev index roots"))))

(t.deftest sqlite-live-connection-exposes-chunked-index-metadata
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-live.sqlite")
  (let [path "tmp.vev.storage-architecture-live.sqlite"
        [store opened-ok opened-error] (vev.open-sqlite-conn path)
        report (vev.transact-sqlite-text
                 (addr store)
                 "[{:db/id 1 :user/name \"Ada\"} {:db/id 2 :user/name \"Grace\"}]")
        second-report (vev.transact-sqlite-text
                        (addr store)
                        "[{:db/id 3 :user/name \"Frances\"}]")
        [architecture architecture-ok architecture-error] (vev.sqlite-conn-storage-architecture (addr store))
        [root-count root-count-ok root-count-error] (vev.sqlite-conn-index-root-count (addr store))
        [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-conn-index-chunk-count (addr store))
        [basis basis-ok basis-error] (vev.sqlite-conn-latest-index-root-basis (addr store))
        [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":eavt")
        [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":aevt")
        [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":avet")
        [vaet-basis vaet-rows vaet-ok vaet-error] (vev.sqlite-conn-latest-index-chunk-row-count (addr store) ":vaet")
        [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-conn-latest-index-entries (addr store) ":eavt")
        [datom-count datom-count-ok datom-count-error] (vev.sqlite-conn-datom-count (addr store))
        [first-datom first-datom-ok first-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 0)
        [last-datom last-datom-ok last-datom-error] (vev.sqlite-conn-datom-at-log-index (addr store) 2)]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is report.ok)
    (t.is second-report.ok)
    (t.is architecture-ok)
    (t.is (= architecture-error ""))
    (t.is (= architecture "vev-sqlite-chunked-index-v0"))
    (t.is root-count-ok)
    (t.is (= root-count-error ""))
    (t.is (= root-count 2))
    (t.is chunk-count-ok)
    (t.is (= chunk-count-error ""))
    (t.is (= chunk-count 8))
    (t.is basis-ok)
    (t.is (= basis-error ""))
    (t.is (= basis 2))
    (t.is eavt-ok)
    (t.is (= eavt-error ""))
    (t.is (= eavt-basis 2))
    (t.is (= eavt-rows (u64 (count store.conn.db.eavt))))
    (t.is aevt-ok)
    (t.is (= aevt-error ""))
    (t.is (= aevt-basis 2))
    (t.is (= aevt-rows (u64 (count store.conn.db.aevt))))
    (t.is avet-ok)
    (t.is (= avet-error ""))
    (t.is (= avet-basis 2))
    (t.is (= avet-rows (u64 (count store.conn.db.avet))))
    (t.is vaet-ok)
    (t.is (= vaet-error ""))
    (t.is (= vaet-basis 2))
    (t.is (= vaet-rows (u64 (count store.conn.db.vaet))))
    (t.is loaded-eavt-ok)
    (t.is (= loaded-eavt-error ""))
    (t.is (int-slices-equal? (slice loaded-eavt 0) (slice store.conn.db.eavt 0)))
    (t.is datom-count-ok)
    (t.is (= datom-count-error ""))
    (t.is (= datom-count 3))
    (t.is first-datom-ok)
    (t.is (= first-datom-error ""))
    (t.is (= first-datom.e 1))
    (t.is (= first-datom.a ":user/name"))
    (t.is last-datom-ok)
    (t.is (= last-datom-error ""))
    (t.is (= last-datom.e 3))
    (t.is (= last-datom.a ":user/name"))
    (delete loaded-eavt)
    (vev.close-sqlite-conn store)))

(t.deftest sqlite-store-db-retain-keeps-durable-snapshot-queryable
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-retain.sqlite")
  (let [path "tmp.vev.store-db-retain.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          retained (vev.retain-store-db snapshot)]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is (= retained.kind .SQLite-Snapshot))
      (vev.close-store-db! (addr snapshot))
      (vev.close-store read-store)
      (let [retained-result (vev.q-result-store-db-text (addr retained) "[:find ?name :where [1 :user/name ?name]]")]
        (t.is retained-result.result.ok)
        (t.is (= retained-result.result.error ""))
        (t.is (= (count retained-result.result.rows) 1))
        (t.is (= retained-result.result.rows[0].values[0].kind .String))
        (t.is (= retained-result.result.rows[0].values[0].text "Ada"))
        (vev.delete-query-result retained-result)
        (vev.close-store-db! (addr retained))))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-with-text-materializes-immutable-next-db
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-with.sqlite")
  (let [path "tmp.vev.store-db-with.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        write-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is write-report.ok)
    (vev.close-store store)
    (let [[read-store read-opened-ok read-opened-error] (vev.open-store-read-only path)
          [snapshot snapshot-ok snapshot-error] (vev.store-db (addr read-store))
          next-snapshot (vev.db-with-store-db-text (addr snapshot) "[{:db/id 2 :user/name \"Grace\"}]")
          original-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
          next-result (vev.q-result-store-db-text (addr next-snapshot) "[:find ?name :where [?e :user/name ?name]]")]
      (t.is read-opened-ok)
      (t.is (= read-opened-error ""))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (t.is original-result.result.ok)
      (t.is (= (count original-result.result.rows) 1))
      (t.is (result-has-string-row? original-result.result "Ada"))
      (t.is next-result.result.ok)
      (t.is (= (count next-result.result.rows) 2))
      (t.is (result-has-string-row? next-result.result "Ada"))
      (t.is (result-has-string-row? next-result.result "Grace"))
      (vev.delete-query-result original-result)
      (vev.delete-query-result next-result)
      (vev.close-store-db! (addr snapshot))
      (vev.close-store-db! (addr next-snapshot))
      (vev.close-store read-store))
    (vev.delete-tx-report-shallow write-report)))

(t.deftest sqlite-store-db-retain-keeps-original-basis-after-writer-advances
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.store-db-retain-basis.sqlite")
  (let [path "tmp.vev.store-db-retain-basis.sqlite"
        [store opened-ok opened-error] (vev.open-store path)
        first-report (vev.transact-store-text (addr store) "[{:db/id 1 :user/name \"Ada\"}]")
        [snapshot snapshot-ok snapshot-error] (vev.store-db (addr store))
        second-report (vev.transact-store-text (addr store) "[{:db/id 2 :user/name \"Grace\"}]")
        retained (vev.retain-store-db snapshot)
        old-result (vev.q-result-store-db-text (addr snapshot) "[:find ?name :where [?e :user/name ?name]]")
        retained-result (vev.q-result-store-db-text (addr retained) "[:find ?name :where [?e :user/name ?name]]")
        live-result (vev.q-result-store-text (addr store) "[:find ?name :where [?e :user/name ?name]]")]
    (defer (remove-sqlite-files path))
    (t.is opened-ok)
    (t.is (= opened-error ""))
    (t.is first-report.ok)
    (t.is snapshot-ok)
    (t.is (= snapshot-error ""))
    (t.is (= snapshot.kind .SQLite-Snapshot))
    (t.is second-report.ok)
    (t.is (= retained.kind .SQLite-Snapshot))
    (t.is old-result.result.ok)
    (t.is (= (count old-result.result.rows) 1))
    (t.is (result-has-string-row? old-result.result "Ada"))
    (t.is (not (result-has-string-row? old-result.result "Grace")))
    (t.is retained-result.result.ok)
    (t.is (= (count retained-result.result.rows) 1))
    (t.is (result-has-string-row? retained-result.result "Ada"))
    (t.is (not (result-has-string-row? retained-result.result "Grace")))
    (t.is live-result.result.ok)
    (t.is (= (count live-result.result.rows) 2))
    (t.is (result-has-string-row? live-result.result "Ada"))
    (t.is (result-has-string-row? live-result.result "Grace"))
    (vev.delete-query-result old-result)
    (vev.delete-query-result retained-result)
    (vev.delete-query-result live-result)
    (vev.close-store-db! (addr snapshot))
    (vev.close-store-db! (addr retained))
    (vev.close-store store)
    (vev.delete-tx-report-shallow first-report)
    (vev.delete-tx-report-shallow second-report)))

(t.deftest sqlite-persist-writes-bounded-index-chunks
  (defer (free_all context.allocator))
  (remove-sqlite-files "tmp.vev.storage-architecture-chunks.sqlite")
  (let [path "tmp.vev.storage-architecture-chunks.sqlite"
        datoms (make [dynamic]vev.Datom) :defer]
    (for [i (arr.range 1 301)]
      (arr.push! datoms (vev.datom-tx (u64 i) ":item/value" (vev.value-int (i64 i)) 1 true)))
    (arr.push! datoms (vev.datom-tx 301 ":item/name" (vev.value-string "item-301") 1 true))
    (arr.push! datoms (vev.datom-tx 301 ":name" (vev.value-string "parent-name") 1 true))
    (arr.push! datoms (vev.datom-tx 302 ":item/parent" (vev.value-entity 301) 1 true))
    (arr.push! datoms (vev.datom-tx 303 ":item/parent" (vev.value-entity 301) 1 true))
    (arr.push! datoms (vev.datom-tx 302 ":item/child-name" (vev.value-string "child-302") 1 true))
    (arr.push! datoms (vev.datom-tx 303 ":item/child-name" (vev.value-string "child-303") 1 true))
    (arr.push! datoms (vev.datom-tx 304 ":item/parent" (vev.value-entity 302) 1 true))
    (arr.push! datoms (vev.datom-tx 304 ":item/child-name" (vev.value-string "child-304") 1 true))
    (let [db (vev.init-db (slice datoms 0))
          [saved-ok saved-error] (vev.save-db-sqlite path db)
          [root-count root-count-ok root-count-error] (vev.sqlite-index-root-count path)
          [chunk-count chunk-count-ok chunk-count-error] (vev.sqlite-index-chunk-count path)
          [eavt-basis eavt-rows eavt-ok eavt-error] (vev.sqlite-latest-index-chunk-row-count path ":eavt")
          [aevt-basis aevt-rows aevt-ok aevt-error] (vev.sqlite-latest-index-chunk-row-count path ":aevt")
          [avet-basis avet-rows avet-ok avet-error] (vev.sqlite-latest-index-chunk-row-count path ":avet")
          [loaded-eavt loaded-eavt-ok loaded-eavt-error] (vev.sqlite-latest-index-entries path ":eavt")
          [loaded-aevt loaded-aevt-ok loaded-aevt-error] (vev.sqlite-latest-index-entries path ":aevt")
          [eavt-page-first eavt-page-first-ok eavt-page-first-error] (vev.sqlite-latest-index-entry-page path ":eavt" 0 128)
          [eavt-page-cross eavt-page-cross-ok eavt-page-cross-error] (vev.sqlite-latest-index-entry-page path ":eavt" 120 32)
          [eavt-page-tail eavt-page-tail-ok eavt-page-tail-error] (vev.sqlite-latest-index-entry-page path ":eavt" 280 64)
          [eavt-page-count eavt-page-count-ok eavt-page-count-error] (vev.sqlite-latest-index-entry-pages-count path ":eavt" 128)
          [cursor cursor-ok cursor-error] (vev.sqlite-open-index-cursor path ":eavt" 64)
          [snapshot snapshot-ok snapshot-error] (vev.sqlite-open-index-snapshot path 64)
          [db-snapshot db-snapshot-ok db-snapshot-error] (vev.sqlite-open-db-snapshot path 64)
          [reopened reopened-ok reopened-error] (vev.open-conn-sqlite path)]
      (defer (remove-sqlite-files path))
      (t.is saved-ok)
      (t.is (= saved-error ""))
      (t.is root-count-ok)
      (t.is (= root-count-error ""))
      (t.is (= root-count 1))
      (t.is chunk-count-ok)
      (t.is (= chunk-count-error ""))
      (t.is (> chunk-count 4))
      (t.is eavt-ok)
      (t.is (= eavt-error ""))
      (t.is (= eavt-basis 1))
      (t.is (= eavt-rows (u64 (count db.eavt))))
      (t.is aevt-ok)
      (t.is (= aevt-error ""))
      (t.is (= aevt-basis 1))
      (t.is (= aevt-rows (u64 (count db.aevt))))
      (t.is avet-ok)
      (t.is (= avet-error ""))
      (t.is (= avet-basis 1))
      (t.is (= avet-rows (u64 (count db.avet))))
      (t.is loaded-eavt-ok)
      (t.is (= loaded-eavt-error ""))
      (t.is (int-slices-equal? (slice loaded-eavt 0) (slice db.eavt 0)))
      (t.is loaded-aevt-ok)
      (t.is (= loaded-aevt-error ""))
      (t.is (int-slices-equal? (slice loaded-aevt 0) (slice db.aevt 0)))
      (t.is eavt-page-first-ok)
      (t.is (= eavt-page-first-error ""))
      (t.is (int-slices-equal? (slice eavt-page-first 0) (slice db.eavt 0 128)))
      (t.is eavt-page-cross-ok)
      (t.is (= eavt-page-cross-error ""))
      (t.is (int-slices-equal? (slice eavt-page-cross 0) (slice db.eavt 120 152)))
      (t.is eavt-page-tail-ok)
      (t.is (= eavt-page-tail-error ""))
      (t.is (int-slices-equal? (slice eavt-page-tail 0) (slice db.eavt 280 (count db.eavt))))
      (t.is eavt-page-count-ok)
      (t.is (= eavt-page-count-error ""))
      (t.is (= eavt-page-count (count db.eavt)))
      (t.is cursor-ok)
      (t.is (= cursor-error ""))
      (t.is (= (vev.sqlite-index-cursor-count cursor) (count db.eavt)))
      (let [view (vev.db-index-view-from-sqlite-cursor (vev.public-index-order ":eavt") (addr cursor))
            low (vev.lower-bound-index-view db view "eavt-ea" 42 ":item/value" (vev.Value {}))
            high (vev.upper-bound-index-view db view "eavt-ea" 42 ":item/value" (vev.Value {}))]
        (t.is (= (vev.db-index-view-count view) (count db.eavt)))
        (t.is (= (vev.db-index-view-at view 0) db.eavt[0]))
        (t.is (= (vev.db-index-view-at view 129) db.eavt[129]))
        (t.is (= (- high low) 1))
        (t.is (= db.datoms[(vev.db-index-view-at view low)].e 42)))
      (let [[first-entry first-entry-ok first-entry-error] (vev.sqlite-index-cursor-at (addr cursor) 0)
            [middle-entry middle-entry-ok middle-entry-error] (vev.sqlite-index-cursor-at (addr cursor) 129)
            [tail-entry tail-entry-ok tail-entry-error] (vev.sqlite-index-cursor-at (addr cursor) (- (count db.eavt) 1))]
        (t.is first-entry-ok)
        (t.is (= first-entry-error ""))
        (t.is (= first-entry db.eavt[0]))
        (t.is middle-entry-ok)
        (t.is (= middle-entry-error ""))
        (t.is (= middle-entry db.eavt[129]))
        (t.is tail-entry-ok)
        (t.is (= tail-entry-error ""))
        (t.is (= tail-entry db.eavt[(- (count db.eavt) 1)])))
      (t.is snapshot-ok)
      (t.is (= snapshot-error ""))
      (let [snapshot-view (vev.sqlite-index-snapshot-view (addr snapshot) (vev.public-index-order ":eavt"))
            [snapshot-datom snapshot-datom-ok snapshot-datom-error] (vev.sqlite-index-snapshot-datom-at-log-index (addr snapshot) 42)
