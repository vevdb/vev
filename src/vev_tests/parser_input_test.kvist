(package vev-tests)

(import arr "kvist:arr")
(import t "kvist:test")
(import vev "../vev")

(defn parser-map-value [m: vev.Value, key: string] -> [found: vev.Value, ok: bool]
  (vev.map-get-value m (vev.value-keyword key)))

(t.deftest datascript-parser-nested-input-bindings
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        flat-input (vev.value-map
                     ([]vev.Value
                       [(vev.value-keyword ":a") (vev.value-int 1)
                        (vev.value-keyword ":b") (vev.value-int 2)
                        (vev.value-keyword ":c") (vev.value-int 3)]))
        nested-tuple-input (vev.value-map
                             ([]vev.Value
                               [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 7)]))
                                (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 4) (vev.value-int 2)]))]))
        nested-collection-input (vev.value-map
                                  ([]vev.Value
                                    [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))
                                     (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 0) (vev.value-int 4)]))]))
        flat (vev.q-text-with-inputs
               conn.db
               "[:find ?k ?v :in [[?k ?v] ...] :where [(> ?v 1)]]"
               ([]vev.Query-Input [(vev.query-input-map-relation flat-input)]))
        nested-tuple (vev.q-text-with-inputs
                       conn.db
                       "[:find ?k ?min ?max :in [[?k [?min ?max]] ...] :where [(> ?max ?min)]]"
                       ([]vev.Query-Input [(vev.query-input-map-relation nested-tuple-input)]))
        nested-collection (vev.q-text-with-inputs
                            conn.db
                            "[:find ?k ?x :in [[?k [?x ...]] ...] :where [(> ?x 1)]]"
                            ([]vev.Query-Input [(vev.query-input-map-relation nested-collection-input)]))
        ground-scalar (vev.q-text-with-inputs
                        conn.db
                        "[:find ?in :in ?in :where [(ground ?in) _]]"
                        ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ok"))]))
        ground-collection (vev.q-text-collection
                            conn.db
                            "[:find [?vowel ...] :where [(ground [:a :e :i :o :u]) [?vowel ...]]]")
        ground-map-collection (vev.q-text-collection
                                conn.db
                                "{:find [?vowel ...] :where [[(ground [:a :e :i :o :u]) [?vowel ...]]]}")
        ground-tuple (vev.q-text
                       conn.db
                       "[:find ?a ?c :where [(ground [:a :b :c]) [?a _ ?c]]]")
        ground-relation (vev.q-text-with-inputs
                          conn.db
                          "[:find ?x ?z :in ?rows :where [(ground ?rows) [[?x _ ?z] ...]]]"
                          ([]vev.Query-Input
                            [(vev.query-input-scalar
                               (vev.value-vector
                                 ([]vev.Value
                                   [(vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":b") (vev.value-keyword ":c")]))
                                    (vev.value-vector ([]vev.Value [(vev.value-keyword ":d") (vev.value-keyword ":e") (vev.value-keyword ":f")]))])))]))]
    (t.is (= (count flat.rows) 2))
    (t.is (= flat.rows[0].values[0].text ":b"))
    (t.is (= flat.rows[0].values[1].int-value 2))
    (t.is (= flat.rows[1].values[0].text ":c"))
    (t.is (= flat.rows[1].values[1].int-value 3))
    (t.is nested-tuple.ok nested-tuple.error)
    (t.is (= (count nested-tuple.rows) 1))
    (t.is (= nested-tuple.rows[0].values[0].text ":a"))
    (t.is (= nested-tuple.rows[0].values[1].int-value 1))
    (t.is (= nested-tuple.rows[0].values[2].int-value 7))
    (t.is (= (count nested-collection.rows) 3))
    (t.is (= nested-collection.rows[0].values[0].text ":a"))
    (t.is (= nested-collection.rows[0].values[1].int-value 2))
    (t.is (= nested-collection.rows[1].values[0].text ":a"))
    (t.is (= nested-collection.rows[1].values[1].int-value 3))
    (t.is (= nested-collection.rows[2].values[0].text ":b"))
    (t.is (= nested-collection.rows[2].values[1].int-value 4))
    (t.is (= (count ground-scalar.rows) 1))
    (t.is (= ground-scalar.rows[0].values[0].text ":ok"))
    (t.is (= (count ground-collection) 5))
    (t.is (= ground-collection[0].text ":a"))
    (t.is (= ground-collection[4].text ":u"))
    (t.is (= (count ground-map-collection) 5))
    (t.is (= ground-map-collection[0].text ":a"))
    (t.is (= ground-map-collection[4].text ":u"))
    (t.is (= (count ground-tuple.rows) 1))
    (t.is (= ground-tuple.rows[0].values[0].text ":a"))
    (t.is (= ground-tuple.rows[0].values[1].text ":c"))
    (t.is (= (count ground-relation.rows) 2))
    (t.is (= ground-relation.rows[0].values[0].text ":a"))
    (t.is (= ground-relation.rows[0].values[1].text ":c"))
    (t.is (= ground-relation.rows[1].values[0].text ":d"))
    (t.is (= ground-relation.rows[1].values[1].text ":f"))))

(t.deftest prepared-tx-text-failure-has-no-partial-output
  (defer (free_all context.allocator))
  (let [prepared (vev.prepare-tx-text "[[:db/add 1 :name \"Ada\"] [:db/add 2 :bad]]")]
    (t.is (not prepared.ok))
    (t.is (= prepared.error ":db/add expects [op e a v]"))
    (t.is (= (count prepared.tx-data) 0))
    (vev.delete-prepared-tx-data-shallow prepared)))

(t.deftest parser-values-classify-edn-reader-errors
  (defer (free_all context.allocator))
  (let [query (vev.prepared-query-value (vev.prepare-query-text "[:find ?e :where [?e :name]"))
        rules (vev.prepared-rules-value (vev.parse-rules-text "[[(rule ?x) [?x :name _]] trailing"))
        pull (vev.prepared-pull-pattern-value (vev.prepare-pull-pattern-text "[#unknown \"payload\"]"))
        tx (vev.prepared-tx-data-value (vev.prepare-tx-text "[[:db/add 1 :name \"Ada\"]"))
        [query-code query-code-ok] (parser-map-value query ":error-code")
        [rules-code rules-code-ok] (parser-map-value rules ":error-code")
        [pull-code pull-code-ok] (parser-map-value pull ":error-code")
        [tx-code tx-code-ok] (parser-map-value tx ":error-code")]
    (t.is query-code-ok)
    (t.is (= query-code.text ":edn-read"))
    (t.is rules-code-ok)
    (t.is (= rules-code.text ":edn-read"))
    (t.is pull-code-ok)
    (t.is (= pull-code.text ":pull-shape"))
    (t.is tx-code-ok)
    (t.is (= tx-code.text ":edn-read"))))

(t.deftest parser-query-value-renders-return-map
  (defer (free_all context.allocator))
  (let [vector-query (vev.prepared-query-value (vev.prepare-query-text "[:find ?name ?age :keys name age :where [?e :name ?name] [?e :age ?age]]"))
        map-query (vev.prepared-query-value (vev.prepare-query-text "{:find [?name ?age] :strs [name age] :where [[?e :name ?name] [?e :age ?age]]}"))
        syms-query (vev.prepared-query-value (vev.prepare-query-text "[:find ?name ?age :syms name age :where [?e :name ?name] [?e :age ?age]]"))
        [vector-return-map vector-return-map-ok] (parser-map-value vector-query ":return-map")
        [vector-marker vector-marker-ok] (parser-map-value vector-return-map ":marker")
        [vector-keys vector-keys-ok] (parser-map-value vector-return-map ":keys")
        [map-return-map map-return-map-ok] (parser-map-value map-query ":return-map")
        [map-marker map-marker-ok] (parser-map-value map-return-map ":marker")
        [map-keys map-keys-ok] (parser-map-value map-return-map ":keys")
        [syms-return-map syms-return-map-ok] (parser-map-value syms-query ":return-map")
        [syms-marker syms-marker-ok] (parser-map-value syms-return-map ":marker")
        [syms-keys syms-keys-ok] (parser-map-value syms-return-map ":keys")]
    (t.is vector-return-map-ok)
    (t.is vector-marker-ok)
    (t.is (= vector-marker.text ":keys"))
    (t.is vector-keys-ok)
    (t.is (= (count vector-keys.items) 2))
    (t.is (= vector-keys.items[0].kind .Keyword))
    (t.is (= vector-keys.items[0].text ":name"))
    (t.is (= vector-keys.items[1].kind .Keyword))
    (t.is (= vector-keys.items[1].text ":age"))
    (t.is map-return-map-ok)
    (t.is map-marker-ok)
    (t.is (= map-marker.text ":strs"))
    (t.is map-keys-ok)
    (t.is (= (count map-keys.items) 2))
    (t.is (= map-keys.items[0].kind .String))
    (t.is (= map-keys.items[0].text "name"))
    (t.is (= map-keys.items[1].kind .String))
    (t.is (= map-keys.items[1].text "age"))
    (t.is syms-return-map-ok)
    (t.is syms-marker-ok)
    (t.is (= syms-marker.text ":syms"))
    (t.is syms-keys-ok)
    (t.is (= (count syms-keys.items) 2))
    (t.is (= syms-keys.items[0].kind .Symbol))
    (t.is (= syms-keys.items[0].text "name"))
    (t.is (= syms-keys.items[1].kind .Symbol))
    (t.is (= syms-keys.items[1].text "age"))))

(t.deftest parser-clause-text-renders-where-items
  (defer (free_all context.allocator))
  (let [data (vev.prepared-clause-value (vev.parse-clause-text "[$x _ :name ?v]"))
        predicate (vev.prepared-clause-value (vev.parse-clause-text "[(pred ?a 1)]"))
        function (vev.prepared-clause-value (vev.parse-clause-text "[(fn ?a 1) ?x]"))
        rule (vev.prepared-clause-value (vev.parse-clause-text "(friends ?x ?y)"))
        not-clause (vev.prepared-clause-value (vev.parse-clause-text "(not [?e :follows ?x])"))
        or-clause (vev.prepared-clause-value (vev.parse-clause-text "(or [?e :follows ?x] [?e :friend ?x])"))
        bad (vev.prepared-clause-value (vev.parse-clause-text "[]"))
        [data-ok data-ok-ok] (parser-map-value data ":ok")
        [data-clauses data-clauses-ok] (parser-map-value data ":clauses")
        [data-source data-source-ok] (parser-map-value data-clauses.items[0] ":source")
        [data-a data-a-ok] (parser-map-value data-clauses.items[0] ":a")
        [data-a-value data-a-value-ok] (parser-map-value data-a ":value")
        [predicate-predicates predicate-predicates-ok] (parser-map-value predicate ":predicates")
        [predicate-op predicate-op-ok] (parser-map-value predicate-predicates.items[0] ":op")
        [function-functions function-functions-ok] (parser-map-value function ":functions")
        [function-out function-out-ok] (parser-map-value function-functions.items[0] ":out")
        [rule-calls rule-calls-ok] (parser-map-value rule ":rule-calls")
        [rule-call-name rule-call-name-ok] (parser-map-value rule-calls.items[0] ":name")
        [not-groups not-groups-ok] (parser-map-value not-clause ":not-groups")
        [not-clauses not-clauses-ok] (parser-map-value not-groups.items[0] ":clauses")
        [or-groups or-groups-ok] (parser-map-value or-clause ":or-groups")
        [or-branches or-branches-ok] (parser-map-value or-groups.items[0] ":branches")
        [bad-ok bad-ok-ok] (parser-map-value bad ":ok")
        [bad-error bad-error-ok] (parser-map-value bad ":error")
        [bad-code bad-code-ok] (parser-map-value bad ":error-code")]
    (t.is data-ok-ok)
    (t.is data-ok.bool-value)
    (t.is data-clauses-ok)
    (t.is (= (count data-clauses.items) 1))
    (t.is data-source-ok)
    (t.is (= data-source.text "$x"))
    (t.is data-a-ok)
    (t.is data-a-value-ok)
    (t.is (= data-a-value.text ":name"))
    (t.is predicate-predicates-ok)
    (t.is (= (count predicate-predicates.items) 1))
    (t.is predicate-op-ok)
    (t.is (= predicate-op.text "pred"))
    (t.is function-functions-ok)
    (t.is (= (count function-functions.items) 1))
    (t.is function-out-ok)
    (t.is (= function-out.text "?x"))
    (t.is rule-calls-ok)
    (t.is (= (count rule-calls.items) 1))
    (t.is rule-call-name-ok)
    (t.is (= rule-call-name.text "friends"))
    (t.is not-groups-ok)
    (t.is (= (count not-groups.items) 1))
    (t.is not-clauses-ok)
    (t.is (= (count not-clauses.items) 1))
    (t.is or-groups-ok)
    (t.is (= (count or-groups.items) 1))
    (t.is or-branches-ok)
    (t.is (= (count or-branches.items) 2))
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-error-ok)
    (t.is (= bad-error.text "Pattern could not be empty"))
    (t.is bad-code-ok)
    (t.is (= bad-code.text ":query-shape"))))
