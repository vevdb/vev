(t.deftest datascript-component-retract-entity-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :profile]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 1 :name "Ivan"]
              [:db/add 1 :profile (vev.value-entity 3)]
              [:db/add 3 :email "@3"]
              [:db/add 4 :email "@4"]])
        report (vev.transact (addr conn) [[:db.fn/retractEntity 1]])
        parent (vev.q report.db-after
                 [:find ?a ?v
                  :where
                  [1 ?a ?v]])
        child (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [3 ?a ?v]])
        unrelated (vev.q report.db-after
                    [:find ?email
                     :where
                     [4 :email ?email]])]
      (t.is report.ok)
      (t.is (= (count parent.rows) 0))
      (t.is (= (count child.rows) 0))
      (t.is (= (count unrelated.rows) 1))
      (t.is (= unrelated.rows[0].values[0].text "@4"))))

