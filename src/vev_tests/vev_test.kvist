(t.deftest transact-data-supports-retract-without-value-lookup-ref
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :user/email]
                [:db/add 100 :db/valueType :db.type/string]
                [:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.seed-people (addr conn))
        report (vev.transact (addr conn) [[:db/retract [:user/email "ada@example.com"] :user/name]])
        names (vev.q-collection report.db-after
                  [:find [?name ...]
                   :where
