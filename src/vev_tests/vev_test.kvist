(t.deftest datascript-query-fns-lookup-ref-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :name :db/valueType :db.type/string :db/unique :db.unique/identity}
             {:db/id 101 :db/ident :age}
             {:db/id 102 :db/ident :height}])
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 15}
             {:db/id 2 :name "Petr" :age 22 :height 240}])
        [height height-ok] (vev.q-scalar conn.db
                             [:find ?height .
                              :in ?e
                              :where
                              [(get-else $ ?e :height "Unknown") ?height]]
                             [:name "Ivan"])
        some (vev.q conn.db
               [:find ?e ?a ?v
                :in ?e
                :where
                [(get-some $ ?e :weight :age :height) [?a ?v]]]
               [:name "Petr"])
        [text-height text-height-ok] (vev.q-text-scalar-with-inputs
                                        conn.db
                                        "[:find ?height . :in ?e :where [(get-else $ ?e :height \"Unknown\") ?height]]"
                                        ([]vev.Query-Input [(vev.query-input-lookup-ref ":name" (vev.value-string "Ivan"))]))
        text-some (vev.q-text-with-inputs
                    conn.db
                    "[:find ?e ?a ?v :in ?e :where [(get-some $ ?e :weight :age :height) [?a ?v]]]"
                    ([]vev.Query-Input [(vev.query-input-lookup-ref ":name" (vev.value-string "Petr"))]))
        [text-data text-data-ok] (vev.q-text-scalar
                                   conn.db
                                   "[:find ?age . :where [[:name \"Petr\"] :age ?age]]")]
    (t.is height-ok)
    (t.is (= height.text "Unknown"))
    (t.is (= (count some.rows) 1))
    (t.is (= some.rows[0].values[0].kind .Vector))
    (t.is (= some.rows[0].values[0].items[1].text "Petr"))
    (t.is (= some.rows[0].values[1].text ":age"))
    (t.is (= some.rows[0].values[2].int-value 22))
    (t.is text-height-ok)
    (t.is (= text-height.text "Unknown"))
    (t.is text-some.ok)
    (t.is (= (count text-some.rows) 1))
    (t.is (= text-some.rows[0].values[0].kind .Vector))
    (t.is (= text-some.rows[0].values[0].items[1].text "Petr"))
    (t.is (= text-some.rows[0].values[1].text ":age"))
    (t.is (= text-some.rows[0].values[2].int-value 22))
    (t.is text-data-ok)
    (t.is (= text-data.int-value 22))))

(t.deftest datascript-query-function-result-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :age 15}
             {:db/id 2 :age 22}
             {:db/id 3 :age 37}])
        counted (vev.q conn.db
                  [:find ?x ?c
                   :in [?x ...]
                   :where
                   [(count ?x) ?c]]
                  ["a" "abc"])
        vector-tx (vev.q-collection conn.db
                    [:find [?tx-data ...]
                     :where
                     [(ground :db/add) ?op]
                     [(vector ?op -1 :attr 12) ?tx-data]])
        map-tx (vev.q-collection conn.db
                 [:find [?tx-data ...]
                  :where
                  [(hash-map :db/id -1 :age 92 :name "Aaron") ?tx-data]])
        map-order (vev.q-collection conn.db
                    [:find [?m ...]
                     :where
                     [(hash-map :a 1 :b 2) ?m]
                     [(hash-map :b 2 :a 1) ?m]])
        map-get (vev.q conn.db
                  [:find ?m ?v
                   :where
                   [(hash-map :b 1 :d 2) ?m]
                   [(get ?m :d) ?v]])
        summed (vev.q conn.db
                 [:find ?e1 ?e2 ?e3
                  :where
                  [?e1 :age ?a1]
                  [?e2 :age ?a2]
                  [?e3 :age ?a3]
                  [(+ ?a1 ?a2) ?a12]
                  [(= ?a12 ?a3)]])
        incremented (vev.q conn.db
                      [:find ?age ?next
                       :where
                       [_ :age ?age]
                       [(inc ?age) ?next]])
        conflicting (vev.q conn.db
                      [:find ?n
                       :in ?n
                       :where
                       [(+ 1 2) ?n]]
                      4)
        identity-conflict (vev.q conn.db
                            [:find ?n
                             :where
                             [(identity 1) ?n]
                             [(identity 2) ?n]])
        destructured (vev.q conn.db
                       [:find ?n ?x
                        :where
                        [(identity [3 4]) [?n ?x]]])
        destructured-conflict (vev.q conn.db
                                [:find ?n ?x
                                 :where
                                 [(identity [3 4]) [?n ?x]]
                                 [(identity [1 2]) [?n ?x]]])
        pair-unification (vev.q conn.db
                           [:find ?pair ?x
                            :in [[?e ?attr ?pair]]
                            :where
                            [(first ?pair) ?x]
                            [(second ?pair) ?x]]
                           [[1 :pair [:a :a]]
                            [2 :pair [:b :c]]])
        rel-function-conflict (vev.q conn.db
                                [:find ?age
                                 :where
                                 [_ :age ?age]
                                 [(identity 100) ?age]])
        nil-result-filtered (vev.q conn.db
                              [:find ?x
                               :where
                               [(first []) ?x]])
        ground-scalar-output (vev.q conn.db
                               [:find ?in
                                :in ?in
                                :where
                                [(ground ?in) _]]
                               :a)
        ground-relation-output (vev.q conn.db
                                 [:find ?x ?z
                                  :in ?in
                                  :where
                                  [(ground ?in) [[?x _ ?z] ...]]]
                                 [[:a :b :c]
                                  [:d :e :f]])
        function-relation-output (vev.q conn.db
                                   [:find ?x ?z
                                    :where
                                    [(identity [[:a :b :c] [:d :e :f]]) [[?x _ ?z] ...]]])
        function-collection-output (vev.q conn.db
                                     [:find ?x
                                      :where
                                      [(identity [:a :b :c]) [?x ...]]])
        range-output (vev.q conn.db
                       [:find ?label ?x
                        :in [[?label ?bounds]]
                        :where
                        [(first ?bounds) ?min]
                        [(second ?bounds) ?max]
                        [(range ?min ?max) [?x ...]]
                        [(even? ?x)]]
                       [[:a [1 7]]
                        [:b [2 4]]])
        stepped-range-output (vev.q-collection conn.db
                               [:find [?x ...]
                                :where
                                [(range 7 1 -2) [?x ...]]])]
    (t.is (= (count counted.rows) 2))
    (t.is (= counted.rows[0].values[0].text "a"))
    (t.is (= counted.rows[0].values[1].int-value 1))
    (t.is (= counted.rows[1].values[0].text "abc"))
    (t.is (= counted.rows[1].values[1].int-value 3))
    (t.is (= (count vector-tx) 1))
    (t.is (= vector-tx[0].kind .Vector))
    (t.is (= (count vector-tx[0].items) 4))
    (t.is (= vector-tx[0].items[0].text ":db/add"))
    (t.is (= vector-tx[0].items[1].int-value -1))
    (t.is (= vector-tx[0].items[2].text ":attr"))
    (t.is (= vector-tx[0].items[3].int-value 12))
    (t.is (= (count map-tx) 1))
    (t.is (= map-tx[0].kind .Map))
    (t.is (= (count map-tx[0].items) 6))
    (t.is (= map-tx[0].items[0].text ":db/id"))
    (t.is (= map-tx[0].items[1].int-value -1))
    (t.is (= map-tx[0].items[2].text ":age"))
    (t.is (= map-tx[0].items[3].int-value 92))
    (t.is (= map-tx[0].items[4].text ":name"))
    (t.is (= map-tx[0].items[5].text "Aaron"))
    (t.is (= (count map-order) 1))
    (t.is (= map-order[0].kind .Map))
    (t.is (= (count map-get.rows) 1))
    (t.is (= map-get.rows[0].values[0].kind .Map))
    (t.is (= map-get.rows[0].values[1].int-value 2))
    (t.is (= (count summed.rows) 2))
    (t.is (= summed.rows[0].values[0].entity 1))
    (t.is (= summed.rows[0].values[1].entity 2))
    (t.is (= summed.rows[0].values[2].entity 3))
    (t.is (= summed.rows[1].values[0].entity 2))
    (t.is (= summed.rows[1].values[1].entity 1))
    (t.is (= summed.rows[1].values[2].entity 3))
    (t.is (= (count incremented.rows) 3))
    (t.is (= incremented.rows[0].values[0].int-value 15))
    (t.is (= incremented.rows[0].values[1].int-value 16))
    (t.is (= incremented.rows[2].values[0].int-value 37))
    (t.is (= incremented.rows[2].values[1].int-value 38))
    (t.is (= (count conflicting.rows) 0))
    (t.is (= (count identity-conflict.rows) 0))
    (t.is (= (count destructured.rows) 1))
    (t.is (= destructured.rows[0].values[0].int-value 3))
    (t.is (= destructured.rows[0].values[1].int-value 4))
    (t.is (= (count destructured-conflict.rows) 0))
    (t.is (= (count pair-unification.rows) 1))
    (t.is (= pair-unification.rows[0].values[0].kind .Vector))
    (t.is (= pair-unification.rows[0].values[0].items[0].text ":a"))
    (t.is (= pair-unification.rows[0].values[0].items[1].text ":a"))
    (t.is (= pair-unification.rows[0].values[1].text ":a"))
    (t.is (= (count rel-function-conflict.rows) 0))
    (t.is (= (count nil-result-filtered.rows) 0))
    (t.is (= (count ground-scalar-output.rows) 1))
    (t.is (= ground-scalar-output.rows[0].values[0].text ":a"))
    (t.is (= (count ground-relation-output.rows) 2))
    (t.is (= ground-relation-output.rows[0].values[0].text ":a"))
    (t.is (= ground-relation-output.rows[0].values[1].text ":c"))
    (t.is (= ground-relation-output.rows[1].values[0].text ":d"))
    (t.is (= ground-relation-output.rows[1].values[1].text ":f"))
    (t.is (= (count function-relation-output.rows) 2))
    (t.is (= function-relation-output.rows[0].values[0].text ":a"))
    (t.is (= function-relation-output.rows[0].values[1].text ":c"))
    (t.is (= function-relation-output.rows[1].values[0].text ":d"))
    (t.is (= function-relation-output.rows[1].values[1].text ":f"))
    (t.is (= (count function-collection-output.rows) 3))
    (t.is (= function-collection-output.rows[0].values[0].text ":a"))
    (t.is (= function-collection-output.rows[1].values[0].text ":b"))
    (t.is (= function-collection-output.rows[2].values[0].text ":c"))
    (t.is (= (count range-output.rows) 4))
    (t.is (= range-output.rows[0].values[0].text ":a"))
    (t.is (= range-output.rows[0].values[1].int-value 2))
    (t.is (= range-output.rows[1].values[1].int-value 4))
    (t.is (= range-output.rows[2].values[1].int-value 6))
    (t.is (= range-output.rows[3].values[0].text ":b"))
    (t.is (= range-output.rows[3].values[1].int-value 2))
    (t.is (= (count stepped-range-output) 3))
    (t.is (= stepped-range-output[0].int-value 7))
    (t.is (= stepped-range-output[1].int-value 5))
    (t.is (= stepped-range-output[2].int-value 3))))

(t.deftest datascript-query-text-function-result-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :age 15}
             {:db/id 2 :age 22}
             {:db/id 3 :age 37}])
        counted (vev.q-text-with-inputs
                  conn.db
                  "[:find ?x ?c :in [?x ...] :where [(count ?x) ?c]]"
                  ([]vev.Query-Input
                    [(vev.query-input-collection
                       ([]vev.Value [(vev.value-string "a")
                                      (vev.value-string "abc")]))]))
        vector-tx (vev.q-text-collection
                    conn.db
                    "[:find [?tx-data ...] :where [(ground :db/add) ?op] [(vector ?op -1 :attr 12) ?tx-data]]")
        map-tx (vev.q-text-collection
                 conn.db
                 "[:find [?tx-data ...] :where [(hash-map :db/id -1 :age 92 :name \"Aaron\") ?tx-data]]")
        map-order (vev.q-text-collection
                    conn.db
                    "[:find [?m ...] :where [(hash-map :a 1 :b 2) ?m] [(hash-map :b 2 :a 1) ?m]]")
        map-get (vev.q-text
                  conn.db
                  "[:find ?m ?v :where [(hash-map :b 1 :d 2) ?m] [(get ?m :d) ?v]]")
        summed (vev.q-text
                 conn.db
                 "[:find ?e1 ?e2 ?e3 :where [?e1 :age ?a1] [?e2 :age ?a2] [?e3 :age ?a3] [(+ ?a1 ?a2) ?a12] [(= ?a12 ?a3)]]")
        prepared (vev.prepare-query-text
                   "[:find ?age ?next :where [_ :age ?age] [(inc ?age) ?next]]")
        incremented (vev.q-prepared conn.db prepared)
        conflicting (vev.q-text-with-inputs
                      conn.db
                      "[:find ?n :in ?n :where [(+ 1 2) ?n]]"
                      ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 4))]))
        identity-conflict (vev.q-text
                            conn.db
                            "[:find ?n :where [(identity 1) ?n] [(identity 2) ?n]]")
        destructured (vev.q-text
                       conn.db
                       "[:find ?n ?x :where [(identity [3 4]) [?n ?x]]]")
        destructured-conflict (vev.q-text
                                conn.db
                                "[:find ?n ?x :where [(identity [3 4]) [?n ?x] [(identity [1 2]) [?n ?x]]]")
        pair-unification (vev.q-text-with-inputs
                           conn.db
                           "[:find ?pair ?x :in [[?e ?attr ?pair]] :where [(first ?pair) ?x] [(second ?pair) ?x]]"
                           ([]vev.Query-Input
                             [(vev.query-input-relation
                                ([]vev.Value
                                  [(vev.value-int 1)
                                   (vev.value-keyword ":pair")
                                   (vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":a")]))
                                   (vev.value-int 2)
                                   (vev.value-keyword ":pair")
                                   (vev.value-vector ([]vev.Value [(vev.value-keyword ":b") (vev.value-keyword ":c")]))])
                                3)]))
        rel-function-conflict (vev.q-text
                                conn.db
                                "[:find ?age :where [_ :age ?age] [(identity 100) ?age]]")
        nil-result-filtered (vev.q-text
                              conn.db
                              "[:find ?x :where [(first []) ?x]]")
        ground-relation-output (vev.q-text-with-inputs
                                 conn.db
                                 "[:find ?x ?z :in ?in :where [(ground ?in) [[?x _ ?z] ...]]]"
                                 ([]vev.Query-Input
                                   [(vev.query-input-scalar
                                      (vev.value-vector
                                        ([]vev.Value
                                          [(vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":b") (vev.value-keyword ":c")]))
                                           (vev.value-vector ([]vev.Value [(vev.value-keyword ":d") (vev.value-keyword ":e") (vev.value-keyword ":f")]))])))]))
        function-relation-output (vev.q-text
                                   conn.db
                                   "[:find ?x ?z :where [(identity [[:a :b :c] [:d :e :f]]) [[?x _ ?z] ...]]]")
        function-collection-output (vev.q-text
                                     conn.db
                                     "[:find ?x :where [(identity [:a :b :c]) [?x ...]]]")
        range-output (vev.q-text-with-inputs
                       conn.db
                       "[:find ?label ?x :in [[?label [?min ?max]] ...] :where [(range ?min ?max) [?x ...]] [(even? ?x)]]"
                       ([]vev.Query-Input
                         [(vev.query-input-relation
                            ([]vev.Value
                              [(vev.value-keyword ":a")
                               (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 7)]))
                               (vev.value-keyword ":b")
                               (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-int 4)]))])
                            2)]))
        stepped-range-output (vev.q-text-collection
                               conn.db
                               "[:find [?x ...] :where [(range 7 1 -2) [?x ...]]]")]
    (t.is (= (count counted.rows) 2))
    (t.is (= counted.rows[0].values[0].text "a"))
    (t.is (= counted.rows[0].values[1].int-value 1))
    (t.is (= counted.rows[1].values[0].text "abc"))
    (t.is (= counted.rows[1].values[1].int-value 3))
    (t.is (= (count vector-tx) 1))
    (t.is (= vector-tx[0].kind .Vector))
    (t.is (= vector-tx[0].items[0].text ":db/add"))
    (t.is (= vector-tx[0].items[1].int-value -1))
    (t.is (= vector-tx[0].items[2].text ":attr"))
    (t.is (= vector-tx[0].items[3].int-value 12))
    (t.is (= (count map-tx) 1))
    (t.is (= map-tx[0].kind .Map))
    (t.is (= map-tx[0].items[0].text ":db/id"))
    (t.is (= map-tx[0].items[1].int-value -1))
    (t.is (= map-tx[0].items[4].text ":name"))
    (t.is (= map-tx[0].items[5].text "Aaron"))
    (t.is (= (count map-order) 1))
    (t.is (= map-order[0].kind .Map))
    (t.is (= (count map-get.rows) 1))
    (t.is (= map-get.rows[0].values[0].kind .Map))
    (t.is (= map-get.rows[0].values[1].int-value 2))
    (t.is (= (count summed.rows) 2))
    (t.is (= summed.rows[0].values[2].entity 3))
    (t.is (= summed.rows[1].values[2].entity 3))
    (t.is (= (count incremented.rows) 3))
    (t.is (= incremented.rows[0].values[0].int-value 15))
    (t.is (= incremented.rows[2].values[1].int-value 38))
    (t.is (= (count conflicting.rows) 0))
    (t.is (= (count identity-conflict.rows) 0))
    (t.is (= (count destructured.rows) 1))
    (t.is (= destructured.rows[0].values[0].int-value 3))
    (t.is (= destructured.rows[0].values[1].int-value 4))
    (t.is (= (count destructured-conflict.rows) 0))
    (t.is (= (count pair-unification.rows) 1))
    (t.is (= pair-unification.rows[0].values[0].items[0].text ":a"))
    (t.is (= pair-unification.rows[0].values[1].text ":a"))
    (t.is (= (count rel-function-conflict.rows) 0))
    (t.is (= (count nil-result-filtered.rows) 0))
    (t.is (= (count ground-relation-output.rows) 2))
    (t.is (= ground-relation-output.rows[0].values[0].text ":a"))
    (t.is (= ground-relation-output.rows[0].values[1].text ":c"))
    (t.is (= ground-relation-output.rows[1].values[0].text ":d"))
    (t.is (= ground-relation-output.rows[1].values[1].text ":f"))
    (t.is (= (count function-relation-output.rows) 2))
    (t.is (= function-relation-output.rows[0].values[0].text ":a"))
    (t.is (= function-relation-output.rows[1].values[1].text ":f"))
    (t.is (= (count function-collection-output.rows) 3))
    (t.is (= function-collection-output.rows[0].values[0].text ":a"))
    (t.is (= function-collection-output.rows[2].values[0].text ":c"))
    (t.is (= (count range-output.rows) 4))
    (t.is (= range-output.rows[0].values[0].text ":a"))
    (t.is (= range-output.rows[0].values[1].int-value 2))
    (t.is (= range-output.rows[2].values[1].int-value 6))
    (t.is (= range-output.rows[3].values[0].text ":b"))
    (t.is (= range-output.rows[3].values[1].int-value 2))
    (t.is (= (count stepped-range-output) 3))
    (t.is (= stepped-range-output[0].int-value 7))
    (t.is (= stepped-range-output[1].int-value 5))
    (t.is (= stepped-range-output[2].int-value 3))))

(t.deftest datascript-query-named-function-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :age 15}
             {:db/id 2 :age 22}
             {:db/id 3 :age 37}])
        predicate-result (vev.q conn.db
                           [:find ?e
                            :in ?adult
                            :where
                            [?e :age ?a]
                            [(?adult ?a)]]
                           :pos?)
        function-result (vev.q conn.db
                          [:find ?pair ?x
                           :in [[?e ?attr ?pair]] ?first ?second
                           :where
                           [(?first ?pair) ?x]
                           [(?second ?pair) ?x]]
                          [[1 :pair [:a :a]]
                           [2 :pair [:b :c]]]
                          :first
                          "second")
        text-result (vev.q-text-with-inputs
                      conn.db
                      "[:find ?pair ?x :in [[?e ?attr ?pair]] ?first ?second :where [(?first ?pair) ?x] [(?second ?pair) ?x]]"
                      ([]vev.Query-Input
                        [(vev.query-input-relation
                           ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":pair") (vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":a")]))
                                          (vev.value-int 2) (vev.value-keyword ":pair") (vev.value-vector ([]vev.Value [(vev.value-keyword ":b") (vev.value-keyword ":c")]))])
                           3)
                         (vev.query-input-scalar (vev.value-string "first"))
                         (vev.query-input-scalar (vev.value-keyword ":second"))]))]
    (t.is (= (count predicate-result.rows) 3))
    (t.is (= predicate-result.rows[0].values[0].entity 1))
    (t.is (= predicate-result.rows[2].values[0].entity 3))
    (t.is (= (count function-result.rows) 1))
    (t.is (= function-result.rows[0].values[0].items[0].text ":a"))
    (t.is (= function-result.rows[0].values[1].text ":a"))
    (t.is (= (count text-result.rows) 1))
    (t.is (= text-result.rows[0].values[0].items[0].text ":a"))
    (t.is (= text-result.rows[0].values[1].text ":a"))))

(t.deftest datascript-query-registered-native-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        registry ([]vev.Native-Query-Fn
                   [(vev.query-fn "adult-age?" ">=")
                    (vev.query-fn "mk-keyword" "keyword")])
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 15}
             {:db/id 2 :name "Petr" :age 22}
             {:db/id 3 :name "Oleg" :age 37}])
        text-predicate (vev.q-text-with-fns
                         conn.db
                         "[:find ?name :where [?e :name ?name] [?e :age ?a] [(adult-age? ?a 18)]]"
                         registry)
        text-function (vev.q-text-with-fns
                        conn.db
                        "[:find ?name ?label :where [?e :name ?name] [(mk-keyword \"person\" ?name) ?label]]"
                        registry)
        prepared (vev.prepare-query-text
                   "[:find ?name :where [?e :name ?name] [?e :age ?a] [(adult-age? ?a 18)]]")
        prepared-result (vev.q-prepared-with-fns conn.db prepared registry)
        rule-result (vev.q-text-with-rules-and-fns
                      conn.db
                      "[:find ?name :in $ % :where (adult-person ?e) [?e :name ?name]]"
                      "[[(adult-person ?e) [?e :age ?a] [(adult-age? ?a 18)]]]"
                      ([]vev.Query-Input [])
                      registry)
        unknown (vev.q-text
                  conn.db
                  "[:find ?name :where [?e :name ?name] [?e :age ?a] [(adult-age? ?a 18)]]")]
    (t.is (= (count text-predicate.rows) 2))
    (t.is (= text-predicate.rows[0].values[0].text "Petr"))
    (t.is (= text-predicate.rows[1].values[0].text "Oleg"))
    (t.is (= (count text-function.rows) 3))
    (t.is (= text-function.rows[0].values[1].text ":person/Ivan"))
    (t.is (= text-function.rows[1].values[1].text ":person/Petr"))
    (t.is (= (count prepared-result.rows) 2))
    (t.is (= prepared-result.rows[0].values[0].text "Petr"))
    (t.is (= (count rule-result.rows) 2))
    (t.is (= rule-result.rows[1].values[0].text "Oleg"))
    (t.is (not unknown.ok))
    (t.is (= unknown.error "unknown query predicate: adult-age?"))))

(t.deftest datascript-query-native-callback-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        registry ([]vev.Native-Query-Fn
                   [(vev.query-predicate-fn "adult-age?" native-adult-age?)
                    (vev.query-db-predicate-fn "db-age-equals?" native-db-age-equals?)
                    (vev.query-value-fn "even-identity" native-even-identity)
                    (vev.query-value-fn "person-label" native-person-label)])
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 15}
             {:db/id 2 :name "Petr" :age 22}
             {:db/id 3 :name "Oleg" :age 37}
             {:db/id 10 :pred "missing-predicate"}])
        predicate (vev.q-text-with-fns
                    conn.db
                    "[:find ?name :where [?e :name ?name] [?e :age ?a] [(adult-age? ?a 18)]]"
                    registry)
        db-predicate (vev.q-text-with-inputs-and-fns
                       conn.db
                       "[:find ?e :in ?pred :where [?e :age ?a] [(?pred $ ?e 15)]]"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "db-age-equals?"))])
                       registry)
        missing-predicate-from-data (vev.q-text-with-fns
                                      conn.db
                                      "[:find ?e ?a :where [_ :pred ?pred] [?e :age ?a] [(?pred ?a)]]"
                                      registry)
        fn-filter (vev.q-text-with-fns
                    conn.db
                    "[:find ?age ?same :where [?e :age ?age] [(even-identity ?age) ?same]]"
                    registry)
        function (vev.q-text-with-fns
                   conn.db
                   "[:find ?name ?label :where [?e :name ?name] [(person-label \"person\" ?name) ?label]]"
                   registry)
        prepared (vev.prepare-query-text
                   "[:find ?name :where [?e :name ?name] [?e :age ?a] [(adult-age? ?a 18)]]")
        prepared-result (vev.q-prepared-with-fns conn.db prepared registry)]
    (t.is (= (count predicate.rows) 2))
    (t.is (= predicate.rows[0].values[0].text "Petr"))
    (t.is (= predicate.rows[1].values[0].text "Oleg"))
    (t.is db-predicate.ok)
    (t.is (= (count db-predicate.rows) 1))
    (t.is (= db-predicate.rows[0].values[0].entity 1))
    (t.is missing-predicate-from-data.ok)
    (t.is (= (count missing-predicate-from-data.rows) 0))
    (t.is (= (count fn-filter.rows) 1))
    (t.is (= fn-filter.rows[0].values[0].int-value 22))
    (t.is (= fn-filter.rows[0].values[1].int-value 22))
    (t.is (= (count function.rows) 3))
    (t.is (= function.rows[0].values[1].text ":person/Ivan"))
    (t.is (= function.rows[2].values[1].text ":person/Oleg"))
    (t.is (= (count prepared-result.rows) 2))
    (t.is (= prepared-result.rows[1].values[0].text "Oleg"))))

(t.deftest datascript-query-built-in-regex-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        literal (vev.q conn.db
                  [:find ?name
                   :in [?name ...] ?key
                   :where
                   [(re-pattern ?key) ?pattern]
                   [(re-find ?pattern ?name)]]
                  ["abc" "abcX" "aXb"]
                  "X")
        regex-pattern (vev.q conn.db
                        [:find ?name
                         :in [?name ...] ?key
                         :where
                         [(re-pattern ?key) ?pattern]
                         [(re-find ?pattern ?name)]]
                        ["axb" "a-b" "ab" "xyz"]
                        "a.b")
        match-output (vev.q conn.db
                       [:find ?name ?match
                        :in [?name ...] ?key
                        :where
                        [(re-pattern ?key) ?pattern]
                        [(re-find ?pattern ?name) ?match]]
                       ["axb" "a-b" "ab" "xyz"]
                       "a.b")
        text (vev.q-text-with-inputs
               conn.db
               "[:find ?name :in [?name ...] ?key :where [(re-pattern ?key) ?pattern] [(re-find ?pattern ?name)]]"
               ([]vev.Query-Input
                [(vev.query-input-collection
                   ([]vev.Value
                    [(vev.value-string "abc")
                     (vev.value-string "abcX")
                     (vev.value-string "aXb")]))
                 (vev.query-input-scalar (vev.value-string "X"))]))
        text-match-output (vev.q-text-with-inputs
                            conn.db
                            "[:find ?name ?match :in [?name ...] ?key :where [(re-pattern ?key) ?pattern] [(re-find ?pattern ?name) ?match]]"
                            ([]vev.Query-Input
                             [(vev.query-input-collection
                                ([]vev.Value
                                 [(vev.value-string "abc")
                                  (vev.value-string "abcX")
                                  (vev.value-string "aXb")]))
                              (vev.query-input-scalar (vev.value-string "X"))]))
        invalid (vev.q conn.db
                  [:find ?name
                   :in [?name ...] ?key
                   :where
                   [(re-pattern ?key) ?pattern]
                   [(re-find ?pattern ?name)]]
                  ["abc" "abcX" "aXb"]
                  "[")]
    (t.is (= (count literal.rows) 2))
    (t.is (= literal.rows[0].values[0].text "abcX"))
    (t.is (= literal.rows[1].values[0].text "aXb"))
    (t.is (= (count regex-pattern.rows) 2))
    (t.is (= regex-pattern.rows[0].values[0].text "axb"))
    (t.is (= regex-pattern.rows[1].values[0].text "a-b"))
    (t.is (= (count match-output.rows) 2))
    (t.is (= match-output.rows[0].values[1].text "axb"))
    (t.is (= match-output.rows[1].values[1].text "a-b"))
    (t.is (= (count text.rows) 2))
    (t.is (= text.rows[0].values[0].text "abcX"))
    (t.is (= text.rows[1].values[0].text "aXb"))
    (t.is (= (count text-match-output.rows) 2))
    (t.is (= text-match-output.rows[0].values[1].text "X"))
    (t.is (= text-match-output.rows[1].values[1].text "X"))
    (t.is (= (count invalid.rows) 0))))

(t.deftest datascript-query-expanded-built-ins-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :age 37 :active true}
             {:db/id 2 :name "Grace Hopper" :age 44 :active false}
             {:db/id 3 :name "Alan Turing" :age 41}])
        arithmetic (vev.q conn.db
                     [:find ?age ?dec ?half ?rem ?mod ?low ?high ?cmp
                      :where
                      [1 :age ?age]
                      [(dec ?age) ?dec]
                      [(quot ?dec 2) ?half]
                      [(rem ?age 5) ?rem]
                      [(mod -3 5) ?mod]
                      [(min ?age 12 30) ?low]
                      [(max ?age 12 30) ?high]
                      [(compare ?low ?high) ?cmp]])
        boolean-preds (vev.q conn.db
                        [:find ?e
                         :where
                         [?e :active ?active]
                         [(false? ?active)]])
        nil-preds (vev.q conn.db
                    [:find ?e
                     :in [?e ...] ?missing
                     :where
                     [(nil? ?missing)]
                     [(some? ?e)]
                     [(not false)]]
                    [1 2 3]
                    nil)
        strings (vev.q conn.db
                  [:find ?e ?short ?slice ?joined ?kw ?has ?starts ?ends
                   :where
                   [?e :name ?name]
                   [(contains? ?name "Hopper")]
                   [(name :person/name) ?short]
                   [(subs ?name 0 5) ?slice]
                   [(str ?short "-" ?slice "-" 42) ?joined]
                   [(keyword "person" ?short) ?kw]
                   [(contains? ?name "Grace") ?has]
                   [(contains? ?name "Grace") ?starts]
                   [(contains? ?name "Hopper") ?ends]])
        text (vev.q-text conn.db
               "[:find ?name ?n ?label :where [?e :name ?name] [(clojure.string/starts-with? ?name \"Ada\")] [(subs ?name 0 3) ?n] [(str ?n \"!\" ) ?label]]")
        text-keyword (vev.q-text conn.db
                       "[:find ?kw :where [(keyword \"person\" \"name\") ?kw]]")]
    (t.is (= (count arithmetic.rows) 1))
    (t.is (= arithmetic.rows[0].values[0].int-value 37))
    (t.is (= arithmetic.rows[0].values[1].int-value 36))
    (t.is (= arithmetic.rows[0].values[2].int-value 18))
    (t.is (= arithmetic.rows[0].values[3].int-value 2))
    (t.is (= arithmetic.rows[0].values[4].int-value 2))
    (t.is (= arithmetic.rows[0].values[5].int-value 12))
    (t.is (= arithmetic.rows[0].values[6].int-value 37))
    (t.is (= arithmetic.rows[0].values[7].int-value -1))
    (t.is (= (count boolean-preds.rows) 1))
    (t.is (= boolean-preds.rows[0].values[0].entity 2))
    (t.is (= (count nil-preds.rows) 3))
    (t.is (= (count strings.rows) 1))
    (t.is (= strings.rows[0].values[0].entity 2))
    (t.is (= strings.rows[0].values[1].text "name"))
    (t.is (= strings.rows[0].values[2].text "Grace"))
    (t.is (= strings.rows[0].values[3].text "name-Grace-42"))
    (t.is (= strings.rows[0].values[4].text ":person/name"))
    (t.is strings.rows[0].values[5].bool-value)
    (t.is strings.rows[0].values[6].bool-value)
    (t.is strings.rows[0].values[7].bool-value)
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= text.rows[0].values[1].text "Ada"))
    (t.is (= text.rows[0].values[2].text "Ada!"))
    (t.is (= (count text-keyword.rows) 1))
    (t.is (= text-keyword.rows[0].values[0].text ":person/name"))))

(t.deftest datalog-macro-supports-or-clauses
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?name
                  :where
                  (or [?e :user/email "ada@example.com"]
                      [?e :user/email "grace@example.com"])
                  [?e :user/name ?name]])]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[1].values[0].text "Grace"))))

(t.deftest datalog-macro-supports-and-branches-in-or
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?name
                  :where
                  (or (and [?e :user/active true]
                           [?e :user/age 37])
                      [?e :user/email "grace@example.com"])
                  [?e :user/name ?name]])]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[1].values[0].text "Grace"))))

(t.deftest datalog-macro-supports-top-level-and
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?name
                  :where
                  (and [?e :user/active true]
                       [?e :user/age 37])
                  [?e :user/name ?name]])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ada"))))

(t.deftest datascript-query-rules-basic-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :follow]
                  [:db/add 100 :db/valueType :db.type/ref]
                  [:db/add 100 :db/cardinality :db.cardinality/many]
                  [:db/add 5 :follow (vev.value-entity 3)]
                  [:db/add 1 :follow (vev.value-entity 2)]
                  [:db/add 2 :follow (vev.value-entity 3)]
                  [:db/add 3 :follow (vev.value-entity 4)]
                  [:db/add 4 :follow (vev.value-entity 6)]
                  [:db/add 2 :follow (vev.value-entity 4)]
                  [:db/add 2 :age 15]])
        follows (vev.q report.db-after
                  [:find ?e1 ?e2
                   :in $ %
                   :where
                   (follow ?e1 ?e2)]
                  [[(follow ?x ?y)
                    [?x :follow ?y]]])
        joined (vev.q report.db-after
                 [:find ?y ?x
                  :in $ %
                  :where
                  [_ _ ?x]
                  (rule ?x ?y)
                  [(= ?x 2)]]
                 [[(rule ?a ?b)
                   [?a :follow ?b]]])
        joined-even (vev.q report.db-after
                      [:find ?y ?x
                       :in $ %
                       :where
                       [_ _ ?x]
                       (rule ?x ?y)
                       [(even? ?x)]]
                      [[(rule ?a ?b)
                        [?a :follow ?b]]])
        isolated (vev.q-collection report.db-after
                   [:find [?x ...]
                    :in $ %
                    :where
                    [?e _ _]
                    (rule ?x)]
                   [[(rule ?e)
                     [_ ?e _]]])
        branches (vev.q-collection report.db-after
                   [:find [?e2 ...]
                    :in $ ?e1 %
                    :where
                    (follow ?e1 ?e2)]
                   1
                   [[(follow ?e2 ?e1)
                     [?e2 :follow ?e1]]
                    [(follow ?e2 ?e1)
                     [?e2 :follow ?t]
                     [?t :follow ?e1]]])
        recursive (vev.q-collection report.db-after
                    [:find [?e2 ...]
                     :in $ ?e1 %
                     :where
                     (follow ?e1 ?e2)]
                    1
                    [[(follow ?e1 ?e2)
                      [?e1 :follow ?e2]]
                     [(follow ?e1 ?e2)
                      [?e1 :follow ?t]
                      (follow ?t ?e2)]])
        rule-builtins (vev.q report.db-after
                        [:find ?x ?y
                         :in $ %
                         :where
                         (match ?x ?y)]
                        [[(match ?e ?e2)
                          [?e :follow ?e2]
                          [(even? ?e)]
                          [(even? ?e2)]]])
        rule-predicate-input (vev.q report.db-after
                               [:find ?x ?y
                                :in $ % ?even
                                :where
                                (match ?even ?x ?y)]
                               [[(match ?pred ?e ?e2)
                                 [?e :follow ?e2]
                                 [(?pred ?e)]
                                 [(?pred ?e2)]]]
                               :even?)
        rule-predicate-input-text (vev.q-text-with-rules
                                    report.db-after
                                    "[:find ?x ?y :in $ % ?even :where (match ?even ?x ?y)]"
                                    "[[(match ?pred ?e ?e2) [?e :follow ?e2] [(?pred ?e)] [(?pred ?e2)]]]"
                                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":even?"))]))
        native-rule-registry ([]vev.Native-Query-Fn
                               [(vev.query-predicate-fn "always?" native-always?)
                                (vev.query-db-predicate-fn "db-age-equals?" native-db-age-equals?)])
        native-rule-rows (vev.value-vector
                           ([]vev.Value
                             [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":attr") (vev.value-string "a")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":attr") (vev.value-string "b")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":attr") (vev.value-string "a")]))]))
        native-rule-predicate (vev.q-text-relation-db-with-rules-and-fns
                                native-rule-rows
                                "[:find ?p :in $ % ?fn :where (rule ?p ?fn \"a\") (rule ?p ?fn \"b\")]"
                                "[[(rule ?p ?fn ?x) [?p :attr ?x] [(?fn ?x)]]]"
                                ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "always?"))])
                                native-rule-registry)
        db-rule-predicate (vev.q-text-with-rules-and-fns
                            report.db-after
                            "[:find ?x :in $ % ?pred :where (match ?pred ?x)]"
                            "[[(match ?pred ?e) [?e :follow ?next] [(?pred $ ?e 15)]]]"
                            ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "db-age-equals?"))])
                            native-rule-registry)
        rule-wildcard (vev.q-collection
                        report.db-after
                        [:find [?x ...]
                         :in $ %
                         :where
                         (follow ?x _)]
                        [[(follow ?e1 ?e2)
                          [?e1 :follow ?e2]]])
        rule-wildcard-text (vev.q-text-with-rules
                             report.db-after
                             "[:find [?x ...] :in $ % :where (follow ?x _)]"
                             "[[(follow ?e1 ?e2) [?e1 :follow ?e2]]]"
                             ([]vev.Query-Input []))
        rule-constant-wildcard (vev.q-collection
                                 report.db-after
                                 [:find [?ok ...]
                                  :in $ %
                                  :where
                                  (follow 2 _)
                                  [(ground :ok) ?ok]]
                                 [[(follow ?e1 ?e2)
                                   [?e1 :follow ?e2]]])
        rule-constant-wildcard-text (vev.q-text-with-rules
                                      report.db-after
                                      "[:find [?ok ...] :in $ % :where (follow 2 _) [(ground :ok) ?ok]]"
                                      "[[(follow ?e1 ?e2) [?e1 :follow ?e2]]]"
                                      ([]vev.Query-Input []))]
    (t.is (= (count follows.rows) 6))
    (t.is (= follows.rows[0].values[0].entity 1))
    (t.is (= follows.rows[0].values[1].entity 2))
    (t.is (= follows.rows[5].values[0].entity 5))
    (t.is (= follows.rows[5].values[1].entity 3))
    (t.is (= (count joined.rows) 2))
    (t.is (= joined.rows[0].values[0].entity 3))
    (t.is (= joined.rows[0].values[1].entity 2))
    (t.is (= joined.rows[1].values[0].entity 4))
    (t.is (= joined.rows[1].values[1].entity 2))
    (t.is (= (count joined-even.rows) 3))
    (t.is (= joined-even.rows[0].values[0].entity 3))
    (t.is (= joined-even.rows[0].values[1].entity 2))
    (t.is (= joined-even.rows[1].values[0].entity 4))
    (t.is (= joined-even.rows[1].values[1].entity 2))
    (t.is (= joined-even.rows[2].values[0].entity 6))
    (t.is (= joined-even.rows[2].values[1].entity 4))
    (t.is (vev.value-exists? (slice isolated 0) (vev.value-keyword ":follow")))
    (t.is (= (count branches) 3))
    (t.is (= branches[0].entity 2))
    (t.is (= branches[1].entity 3))
    (t.is (= branches[2].entity 4))
