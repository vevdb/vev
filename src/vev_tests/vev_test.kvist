                 (addr conn)
                 "[{:email \"@2\" :_profile [{:name \"Ivan\"} {:name \"Petr\"}]}]")
        result (vev.q-text
                 report.db-after
                 "[:find ?parent ?name ?email :where [?parent :profile ?profile] [?parent :name ?name] [?profile :email ?email]]")]
    (t.is report.ok)
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[1].text "Ivan"))
    (t.is (= result.rows[0].values[2].text "@2"))
    (t.is (= result.rows[1].values[1].text "Petr"))
    (t.is (= result.rows[1].values[2].text "@2"))))

(t.deftest datascript-explode-reverse-attr-requires-ref-schema
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        missing (vev.transact-text
                  (addr conn)
                  "[{:name \"Sergey\" :_parent 1}]")
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :parent]
             [:db/add 100 :db/valueType :db.type/string]])
        non-ref (vev.transact-text
                  (addr conn)
                  "[{:name \"Sergey\" :_parent 1}]")]
    (t.is (not missing.ok))
    (t.is (= missing.error "reverse attribute requires ref schema"))
    (t.is (not non-ref.ok))
    (t.is (= non-ref.error "reverse attribute requires ref schema"))))

(t.deftest datascript-text-map-reverse-ref-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :mentor]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             [:db/add 1 :name "Ivan"]
             [:db/add 2 :name "Petr"]
             [:db/add 3 :name "Oleg"]])
        scalar-report (vev.transact-text
                        (addr conn)
                        "[{:db/id 2 :_mentor 1}]")
        lookup-report (vev.transact-text
                        (addr conn)
                        "[{:db/id 3 :_mentor [:name \"Ivan\"]}]")
        tempid-report (vev.transact-text
                        (addr conn)
                        "[{:db/id \"parent\" :name \"Parent\" :_mentor \"child\"} {:db/id \"child\" :name \"Child\"}]")
        result (vev.q-text
                 conn.db
                 "[:find ?source ?name :where [?target :mentor ?source] [?source :name ?name]]")]
    (t.is scalar-report.ok)
    (t.is lookup-report.ok)
    (t.is tempid-report.ok)
    (t.is (= (count result.rows) 3))
    (t.is (result-has-entity-text? result 2 "Petr"))
    (t.is (result-has-entity-text? result 3 "Oleg"))
    (t.is (result-has-entity-text? result (vev.entity-id (vev.entity-lookup-ref conn.db ":name" (vev.value-string "Parent"))) "Parent"))))

(t.deftest datascript-explode-circular-refs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :comp]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 100 :db/isComponent true]])
        root-report (vev.transact-text
                      (addr conn)
                      "[{:db/id 1 :name \"Name\"}]")
        child-report (vev.transact-text
                       (addr conn)
                       "[{:db/id 1 :comp [{:name \"C\"}]}]")
        root-name (vev.q-text
                    child-report.db-after
                    "[:find ?name :where [1 :name ?name]]")
        child (vev.q-text
                child-report.db-after
                "[:find ?child ?name :where [1 :comp ?child] [?child :name ?name]]")]
    (t.is root-report.ok)
    (t.is child-report.ok)
    (t.is (= (count root-name.rows) 1))
    (t.is (= root-name.rows[0].values[0].text "Name"))
    (t.is (= (count child.rows) 1))
    (t.is (= child.rows[0].values[1].text "C"))))

(t.deftest tx-data-macro-coerces-literal-values
  (defer (free_all context.allocator))
  (let [items (vev.tx-data
                [:db/add 1 :user/name "Ada"]
                [:db/add 1 :user/age 37]
                [:db/add 1 :user/active true]
                [:db/add 1 :user/status :user.status/active]
                [:db/add 1 :user/friend (vev.value-entity 2)])]
    (t.is (= (count items) 5))
    (t.is (= items[0].op ":db/add"))
    (t.is (= items[0].a ":user/name"))
    (t.is (= items[0].v.kind .String))
    (t.is (= items[1].v.kind .Int))
    (t.is (= items[1].v.int-value 37))
    (t.is (= items[2].v.kind .Bool))
    (t.is (= items[2].v.bool-value true))
    (t.is (= items[3].v.kind .Keyword))
    (t.is (= items[3].v.text ":user.status/active"))
    (t.is (= items[4].v.kind .Entity))
    (t.is (= items[4].v.entity 2))))

(t.deftest query-follows-ref-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-string "Ada"))
                   (vev.clause (vev.term-var "e") ":user/friend" (vev.term-var "friend"))
                   (vev.clause (vev.term-var "friend") ":user/name" (vev.term-var "friend-name"))])
        query (vev.query ([]string ["friend" "friend-name"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db-after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 2))
      (t.is (= result.rows[0].values[1].text "Grace"))))

