(t.deftest datascript-query-rule-performance-dedup-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        tx (make [dynamic]vev.Tx-Data) :defer
        _ (append-status-rule-performance-tx! (addr tx) 901)
        report (vev.transact-tx-data (addr conn) (slice tx 0))
        inline (vev.q-text
                 report.db-after
                 "[:find ?e :where [?e :item/status ?status] [(ground \"pending\") ?status]]")
        rule (vev.q-text-with-rules
               report.db-after
               "[:find ?e :in $ % :where [?e :item/status ?status] (pending? ?status)]"
               "[[(pending? ?status) [(ground \"pending\") ?status]]]"
               ([]vev.Query-Input []))
        profiled-query (vev.prepare-query-text "[:find ?e :where [?e :item/status ?status] [(ground \"pending\") ?status]]")
        profiled (vev.q-prepared-profiled report.db-after profiled-query)
        rule-profiled (vev.q-text-profiled-with-rules
                         report.db-after
                         "[:find ?e :in $ % :where [?e :item/status ?status] (pending? ?status)]"
                         "[[(pending? ?status) [(ground \"pending\") ?status]]]"
                         ([]vev.Query-Input []))]
    (t.is report.ok)
    (t.is inline.ok)
    (t.is rule.ok)
    (t.is profiled.result.ok)
    (t.is rule-profiled.result.ok)
    (t.is (= (count inline.rows) 300))
    (t.is (= (count rule.rows) (count inline.rows)))
    (t.is (= (count profiled.result.rows) (count inline.rows)))
    (t.is (= (count rule-profiled.result.rows) (count inline.rows)))
    (t.is (= profiled.stats.steps 2))
    (t.is (= profiled.stats.output-rows 300))
    (t.is (> profiled.stats.clause-candidates 0))
    (t.is (= rule-profiled.stats.output-rows 300))
    (t.is (> rule-profiled.stats.rule-calls 0))
    (t.is (> rule-profiled.stats.rule-iterations 0))
    (t.is (= rule.rows[0].values[0].entity 3))
    (t.is (= rule.rows[299].values[0].entity 900))))

(t.deftest datascript-query-mutual-recursive-rules-subset
