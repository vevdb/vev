(t.deftest datascript-pull-text-api-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :friend]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :friend 2}
             {:db/id 2 :name "David"}
             {:db/id 3 :name "Thomas"}
             [:db/add 1 :friend 3]])
        pulled (vev.pull-text conn.db "[:db/id :name {((limit :friend 1) :as :first-friend) [:name]}]" 1)
        by-lookup (vev.pull-text-lookup-ref conn.db "[:name {:friend [:name]}]" ":name" (vev.value-string "Petr"))
        many (vev.pull-many-text conn.db "[:name]" ([]u64 [1 2 3]))
        prepared (vev.prepare-pull-pattern-text "[:name {:friend [:name]}]")
        list-pattern (vev.pull-text conn.db "[:name {:friend (:name)}]" 1)
        prepared-list (vev.prepare-pull-pattern-text "[:name {:friend (:name)}]")
        prepared-list-pulled (vev.pull-prepared conn.db prepared-list 1)
        prepared-pulled (vev.pull-prepared conn.db prepared 1)
        prepared-lookup (vev.pull-prepared-lookup-ref conn.db prepared ":name" (vev.value-string "Petr"))
        prepared-many (vev.pull-many-prepared conn.db prepared ([]u64 [1 2]))
        many-lookup (vev.pull-many-text-lookup-refs
                      conn.db
                      "[:name]"
                      ([]string [":name" ":name" ":name"])
                      ([]vev.Value [(vev.value-string "Petr")
                                    (vev.value-string "David")
                                    (vev.value-string "Missing")]))
        invalid-prepared (vev.prepare-pull-pattern-text ":name")
        invalid-prepared-result (vev.pull-prepared conn.db invalid-prepared 1)
        invalid (vev.pull-text conn.db ":name" 1)]
    (t.is (= pulled.attrs[0].v.entity 1))
    (t.is (= pulled.attrs[1].v.text "Petr"))
    (t.is (= pulled.attrs[2].a ":first-friend"))
    (t.is (= pulled.attrs[2].v.entity 2))
    (t.is (= pulled.attrs[2].attrs[0].v.text "David"))
    (t.is (= by-lookup.attrs[0].v.text "Petr"))
    (t.is (= by-lookup.attrs[1].attrs[0].v.text "David"))
    (t.is (= (count many) 3))
    (t.is (= many[0].attrs[0].v.text "Petr"))
    (t.is (= many[1].attrs[0].v.text "David"))
    (t.is (= many[2].attrs[0].v.text "Thomas"))
    (t.is prepared.ok)
    (t.is prepared-list.ok)
    (t.is (= list-pattern.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-list-pulled.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-pulled.attrs[0].v.text "Petr"))
    (t.is (= prepared-pulled.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-lookup.attrs[0].v.text "Petr"))
    (t.is (= prepared-lookup.attrs[1].attrs[0].v.text "David"))
    (t.is (= (count prepared-many) 2))
    (t.is (= prepared-many[0].attrs[0].v.text "Petr"))
    (t.is (= prepared-many[1].attrs[0].v.text "David"))
    (t.is (= (count many-lookup) 3))
    (t.is (= many-lookup[0].attrs[0].v.text "Petr"))
    (t.is (= many-lookup[1].attrs[0].v.text "David"))
    (t.is (= (count many-lookup[2].attrs) 0))
    (t.is (not invalid-prepared.ok))
    (t.is (= (count invalid-prepared-result.attrs) 0))
    (t.is (= (count invalid.attrs) 0))))

(t.deftest datascript-pull-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"]}])
        found (vev.pull conn.db [:name :aka] [:name "Petr"])
        missing (vev.pull conn.db [:name :aka] [:name "NotInDatabase"])
        missing-wildcard (vev.pull conn.db [*] [:name "No such name"])]
    (t.is (= (count found.attrs) 3))
    (t.is (= found.attrs[0].v.text "Petr"))
    (t.is (= found.attrs[1].v.text "Devil"))
    (t.is (= found.attrs[2].v.text "Tupen"))
    (t.is (= (count missing.attrs) 0))
    (t.is (= (count missing-wildcard.attrs) 0))))

(t.deftest pull-supports-wildcard
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
