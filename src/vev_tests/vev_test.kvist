    (t.is (= schema-view[0].attr ":aka"))
    (t.is schema-view[0].has-cardinality)
    (t.is (= schema-view[0].cardinality ":db.cardinality/many"))))

(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-var "name"))
                   (vev.clause (vev.term-var "e") ":user/age" (vev.term-var "age"))
                   (vev.clause (vev.term-var "e") ":user/active" (vev.term-bool true))])
        query (vev.query ([]string ["e" "name" "age"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db-after query)]
      (t.is (= (count result.rows) 1))
      (t.is (row-entity? result.rows[0] 0 1))
      (t.is (row-text? result.rows[0] 1 "Ada"))
      (t.is (row-int? result.rows[0] 2 37))))

(t.deftest datascript-query-test-joins-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 15}
                  {:db/id 2 :name "Petr" :age 37}
                  {:db/id 3 :name "Ivan" :age 37}
                  {:db/id 4 :age 15}])
        ivans (vev.q report.db-after
                [:find ?e ?age
                 :where
                 [?e :name "Ivan"]
                 [?e :age ?age]])
        named (vev.q report.db-after
                [:find ?e
                 :where
                 [?e :name]])
        same-names (vev.q report.db-after
                     [:find ?e1 ?e2
                      :where
                      [?e1 :name ?name]
                      [?e2 :name ?name]])
        same-age-names (vev.q report.db-after
                         [:find ?e ?e2 ?name
                          :where
                          [?e :name "Ivan"]
                          [?e :age ?age]
                          [?e2 :age ?age]
                          [?e2 :name ?name]])]
    (t.is (= (count ivans.rows) 2))
    (t.is (= ivans.rows[0].values[0].entity 1))
    (t.is (= ivans.rows[0].values[1].int-value 15))
    (t.is (= ivans.rows[1].values[0].entity 3))
    (t.is (= ivans.rows[1].values[1].int-value 37))
    (t.is (= (count named.rows) 3))
    (t.is (= named.rows[0].values[0].entity 1))
    (t.is (= named.rows[1].values[0].entity 2))
    (t.is (= named.rows[2].values[0].entity 3))
    (t.is (= (count same-names.rows) 5))
    (t.is (= (count same-age-names.rows) 3))
    (t.is (= same-age-names.rows[0].values[0].entity 1))
    (t.is (= same-age-names.rows[0].values[1].entity 1))
    (t.is (= same-age-names.rows[0].values[2].text "Ivan"))
    (t.is (= same-age-names.rows[1].values[0].entity 3))
    (t.is (= same-age-names.rows[1].values[1].entity 2))
    (t.is (= same-age-names.rows[1].values[2].text "Petr"))
    (t.is (= same-age-names.rows[2].values[0].entity 3))
    (t.is (= same-age-names.rows[2].values[1].entity 3))
    (t.is (= same-age-names.rows[2].values[2].text "Ivan"))))

(t.deftest datascript-query-cardinality-many-join-subset
  (defer (free_all context.allocator))
