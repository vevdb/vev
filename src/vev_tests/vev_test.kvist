(t.deftest datascript-query-not-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 10}
                  {:db/id 2 :name "Ivan" :age 20}
                  {:db/id 3 :name "Oleg" :age 10}
                  {:db/id 4 :name "Oleg" :age 20}
                  {:db/id 5 :name "Ivan" :age 10}
                  {:db/id 6 :name "Ivan" :age 20}])
        not-ivan (vev.q-collection report.db-after
                   [:find [?e ...]
                    :where
                    [?e :name]
                    (not [?e :name "Ivan"])])
        not-ivan-age-10 (vev.q-collection report.db-after
                          [:find [?e ...]
                           :where
                           [?e :name]
                           (not [?e :name "Ivan"]
                                [?e :age 10])])
        separate-nots (vev.q-collection report.db-after
                        [:find [?e ...]
                         :where
                         [?e :name]
                         (not [?e :name "Ivan"])
                         (not [?e :age 10])])
        full-exclude (vev.q-collection report.db-after
                       [:find [?e ...]
                        :where
                        [?e :name]
                        (not [?e :age])])
        not-intersecting (vev.q-collection report.db-after
                           [:find [?e ...]
                            :where
                            [?e :name "Ivan"]
                            (not [?e :name "Oleg"])])
        exclude-empty (vev.q-collection report.db-after
                        [:find [?e ...]
                         :where
                         [?e :name]
                         (not
                           [?e :name "Ivan"]
                           [?e :name "Oleg"])])
        nested-excludes (vev.q-collection report.db-after
                          [:find [?e ...]
                           :where
                           [?e :name]
                           (not [?e :name "Ivan"]
                                (not [?e :age 10]))])
        extra-binding (vev.q-collection report.db-after
                        [:find [?e ...]
                         :where
                         [?e :name ?a]
                         (not [?e :age ?f]
                              [?e :age 10])])
        not-join (vev.q report.db-after
                   [:find ?e ?age
                    :where
                    [?e :name]
                    [?e :age ?age]
                    (not-join [?e]
                      [?e :name "Oleg"]
                      [?e :age ?age])])
        not-join-const (vev.q report.db-after
                         [:find ?e ?age
                          :where
                          [?e :age ?age]
                          [?e :age 10]
                          (not-join [?e]
                            [?e :name "Oleg"]
                            [?e :age ?age]
                            [?e :age 10])])
        not-join-extra-binding (vev.q report.db-after
                                  [:find ?e ?age
                                   :where
                                   [?e :age ?age]
                                   (not-join [?age]
                                     [?e :name "Petr"]
                                     [?e :age ?age])])
        const-empty (vev.q-collection report.db-after
                      [:find [?e ...]
                       :where
                       [?e :name "Oleg"]
                       [?e :age 10]
                       (not [?e :age 20])])
        const-const (vev.q-collection report.db-after
                      [:find [?e ...]
                       :where
                       [?e :name "Oleg"]
                       [?e :age 10]
                       (not [?e :age 10])])
        rel-const (vev.q-collection report.db-after
                    [:find [?e ...]
                     :where
                     [?e :name "Oleg"]
                     (not [?e :age 10])])
        two-rels-two-rels (vev.q report.db-after
                            [:find ?e ?e2
                             :where
                             [?e :name "Ivan"]
                             [?e2 :name "Ivan"]
                             (not [?e :age 10]
                                  [?e2 :age 20])])
        two-rels-rel-const (vev.q report.db-after
                             [:find ?e ?e2
                              :where
                              [?e :name "Ivan"]
                              [?e2 :name "Oleg"]
                              (not [?e :age 10]
                                   [?e2 :age 20])])
        two-rels-two-consts (vev.q report.db-after
                              [:find ?e ?e2
                               :where
                               [?e :name "Oleg"]
                               [?e2 :name "Oleg"]
                               (not [?e :age 10]
                                    [?e2 :age 20])])]
    (t.is (= (count not-ivan) 2))
    (t.is (= not-ivan[0].entity 3))
    (t.is (= not-ivan[1].entity 4))
    (t.is (= (count not-ivan-age-10) 4))
    (t.is (= not-ivan-age-10[0].entity 2))
    (t.is (= not-ivan-age-10[1].entity 3))
    (t.is (= not-ivan-age-10[2].entity 4))
    (t.is (= not-ivan-age-10[3].entity 6))
    (t.is (= (count separate-nots) 1))
    (t.is (= separate-nots[0].entity 4))
    (t.is (= (count full-exclude) 0))
    (t.is (= (count not-intersecting) 4))
    (t.is (= not-intersecting[0].entity 1))
    (t.is (= not-intersecting[1].entity 2))
    (t.is (= not-intersecting[2].entity 5))
    (t.is (= not-intersecting[3].entity 6))
    (t.is (= (count exclude-empty) 6))
    (t.is (= exclude-empty[0].entity 1))
    (t.is (= exclude-empty[5].entity 6))
    (t.is (= (count nested-excludes) 4))
    (t.is (= nested-excludes[0].entity 1))
    (t.is (= nested-excludes[1].entity 3))
    (t.is (= nested-excludes[2].entity 4))
    (t.is (= nested-excludes[3].entity 5))
    (t.is (= (count extra-binding) 3))
    (t.is (= extra-binding[0].entity 2))
    (t.is (= extra-binding[1].entity 4))
    (t.is (= extra-binding[2].entity 6))
    (t.is (= (count not-join.rows) 4))
    (t.is (= not-join.rows[0].values[0].entity 1))
    (t.is (= not-join.rows[0].values[1].int-value 10))
    (t.is (= not-join.rows[1].values[0].entity 2))
    (t.is (= not-join.rows[1].values[1].int-value 20))
    (t.is (= (count not-join-const.rows) 2))
    (t.is (= not-join-const.rows[0].values[0].entity 1))
    (t.is (= not-join-const.rows[1].values[0].entity 5))
    (t.is (= (count not-join-extra-binding.rows) 6))
    (t.is (= (count const-empty) 1))
    (t.is (= const-empty[0].entity 3))
    (t.is (= (count const-const) 0))
    (t.is (= (count rel-const) 1))
    (t.is (= rel-const[0].entity 4))
    (t.is (= (count two-rels-two-rels.rows) 12))
    (t.is (result-has-entity-pair? two-rels-two-rels 2 1))
    (t.is (result-has-entity-pair? two-rels-two-rels 6 5))
    (t.is (result-has-entity-pair? two-rels-two-rels 1 1))
    (t.is (result-has-entity-pair? two-rels-two-rels 2 2))
    (t.is (result-has-entity-pair? two-rels-two-rels 5 5))
    (t.is (result-has-entity-pair? two-rels-two-rels 6 6))
    (t.is (result-has-entity-pair? two-rels-two-rels 2 5))
    (t.is (result-has-entity-pair? two-rels-two-rels 1 5))
    (t.is (result-has-entity-pair? two-rels-two-rels 2 6))
    (t.is (result-has-entity-pair? two-rels-two-rels 6 1))
    (t.is (result-has-entity-pair? two-rels-two-rels 5 1))
    (t.is (result-has-entity-pair? two-rels-two-rels 6 2))
    (t.is (= (count two-rels-rel-const.rows) 6))
    (t.is (result-has-entity-pair? two-rels-rel-const 2 3))
    (t.is (result-has-entity-pair? two-rels-rel-const 1 3))
    (t.is (result-has-entity-pair? two-rels-rel-const 2 4))
    (t.is (result-has-entity-pair? two-rels-rel-const 6 3))
    (t.is (result-has-entity-pair? two-rels-rel-const 5 3))
    (t.is (result-has-entity-pair? two-rels-rel-const 6 4))
    (t.is (= (count two-rels-two-consts.rows) 3))
    (t.is (result-has-entity-pair? two-rels-two-consts 4 3))
    (t.is (result-has-entity-pair? two-rels-two-consts 3 3))
    (t.is (result-has-entity-pair? two-rels-two-consts 4 4))))

(t.deftest datalog-macro-supports-missing
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        _ (vev.transact
               (addr conn)
               [[:db/add 3 :user/name "Alan"]])
        result (vev.q conn.db
                   [:find ?name
                    :where
                    [?e :user/name ?name]
                    [(missing? $ ?e :user/email)]])]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text "Alan"))))

(t.deftest datalog-macro-supports-reverse-attrs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?source
                  :where
                  [2 :_user/friend ?source]])
        datascript-spelling (vev.q report.db-after
                              [:find ?source
                               :where
                               [2 :user/_friend ?source]])
        text (vev.q-text report.db-after "[:find ?source :where [2 :user/_friend ?source]]")]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= (count datascript-spelling.rows) 1))
    (t.is (= datascript-spelling.rows[0].values[0].entity 1))
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].entity 1))))

