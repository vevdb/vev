(t.deftest datascript-resolves-current-tx-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :created-at]
             [:db/add 100 :db/valueType :db.type/ref]])
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :name "X"]
                  [:db/add 1 :created-at :db/current-tx]
                  [:db/add :db/current-tx :prop1 "prop1"]
                  [:db/add "datomic.tx" :prop2 "prop2"]
                  [:db/add "datascript.tx" :prop3 "prop3"]])
        [tx tx-ok] (vev.q-scalar report.db-after
                     [:find ?tx .
                      :where
                      [1 :created-at ?tx]])
        props (vev.q report.db-after
                [:find ?p
                 :where
                 [?tx :prop1 "prop1"]
                 [?tx ?p _]])]
    (t.is report.ok)
    (t.is tx-ok)
    (t.is (>= (count report.tempids) 3))
    (for [tempid report.tempids]
      (t.is (= tempid.e tx.entity)))
    (t.is (= (count props.rows) 3))
    (t.is (= props.rows[0].values[0].text ":prop1"))
    (t.is (= props.rows[1].values[0].text ":prop2"))
    (t.is (= props.rows[2].values[0].text ":prop3"))))

(t.deftest datascript-upsert-current-tx-conflict-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
