(t.deftest datascript-map-values-remain-comparable-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        map-1 (vev.value-map ([]vev.Value [(vev.value-keyword ":map") (vev.value-int 1)]))
        map-2 (vev.value-map ([]vev.Value [(vev.value-keyword ":map") (vev.value-int 2)]))
        map-3 (vev.value-map ([]vev.Value [(vev.value-keyword ":map") (vev.value-int 3)]))
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :multi]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 101 :db/ident :index]
             [:db/add 101 :db/index true]])
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":single" map-1)]))
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.retract 1 ":single" map-1)]))
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":single" map-2)]))
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":single" map-3)]))
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":multi" map-1)
                            (vev.add 1 ":multi" map-1)
                            (vev.add 1 ":multi" map-2)]))
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":index" map-1)
                            (vev.add 1 ":index" map-2)
                            (vev.add 1 ":index" map-3)]))
        single (vev.datoms conn.db :eavt 1 :single)
        multi (vev.datoms conn.db :eavt 1 :multi)
        exact-index (vev.datoms conn.db :avet :index map-3 1)]
    (t.is (= (count single) 1))
    (t.is (vev.value-equal? single[0].v map-3))
    (t.is (= (count multi) 2))
    (t.is (vev.value-equal? multi[0].v map-1))
    (t.is (vev.value-equal? multi[1].v map-2))
    (t.is (= (count exact-index) 1))
    (t.is (vev.value-equal? exact-index[0].v map-3))))

(t.deftest datascript-transitive-type-compare-unique-lookup-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :block/uid]
             [:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact
            (addr conn)
            [{:block/uid "2LB4tlJGy"}
             {:block/uid "2ON453J0Z"}
             {:block/uid "2KqLLNbPg"}
             {:block/uid "2L0dcD7yy"}
             {:block/uid "2KqFNrhTZ"}
             {:block/uid "2KdQmItUD"}
             {:block/uid "2O8BcBfIL"}
             {:block/uid "2L4ZbI7nK"}
             {:block/uid "2KotiW36Z"}
             {:block/uid "2O4o-y5J8"}
             {:block/uid "2KimvuGko"}
             {:block/uid "dTR20ficj"}
             {:block/uid "wRmp6bXAx"}
             {:block/uid "rfL-iQOZm"}
             {:block/uid "tya6s422-"}
             {:block/uid 45619}])
        datoms (vev.datoms conn.db :avet :block/uid)
        first-string (vev.entity-lookup-ref conn.db ":block/uid" (vev.value-string "2LB4tlJGy"))
        middle-string (vev.entity-lookup-ref conn.db ":block/uid" (vev.value-string "2O4o-y5J8"))
        last-string (vev.entity-lookup-ref conn.db ":block/uid" (vev.value-string "tya6s422-"))
        int-uid (vev.entity-lookup-ref conn.db ":block/uid" (vev.value-int 45619))]
    (t.is (= (count datoms) 16))
    (t.is (= datoms[0].v.kind .Int))
    (t.is (= datoms[0].v.int-value 45619))
    (t.is (= datoms[1].v.kind .String))
    (t.is first-string.found)
    (t.is middle-string.found)
    (t.is last-string.found)
    (t.is int-uid.found)
    (t.is (not (= (vev.entity-id first-string) (vev.entity-id middle-string))))
    (t.is (not (= (vev.entity-id first-string) (vev.entity-id int-uid))))))

