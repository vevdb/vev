(t.deftest datascript-query-source-relation-join-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan"}
             {:db/id 2 :name "Petr"}
             {:db/id 3 :name "Ivan"}])
        result (vev.q conn.db
                 [:find ?e ?email
                  :in $ $b
                  :where
                  [?e :name ?n]
                  [$b ?n ?email]]
                 [["Ivan" "ivan@mail.ru"]
                  ["Petr" "petr@gmail.com"]])]
    (t.is (= (count result.rows) 3))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].text "ivan@mail.ru"))
    (t.is (= result.rows[1].values[0].entity 2))
    (t.is (= result.rows[1].values[1].text "petr@gmail.com"))
    (t.is (= result.rows[2].values[0].entity 3))
    (t.is (= result.rows[2].values[1].text "ivan@mail.ru"))))

(t.deftest datascript-query-collection-source-datoms-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        result (vev.q conn.db
                 [:find ?n ?a
                  :in $rows
                  :where
                  [$rows ?e :aka "dragon_killer_94"]
                  [$rows ?e :name ?n]
                  [$rows ?e :age ?a]]
                 [[1 :name "Ivan"]
                  [1 :age 19]
                  [1 :aka "dragon_killer_94"]
                  [1 :aka "-=autobot=-"]])
        long-rows (vev.q conn.db
                    [:find ?e ?a ?v ?t
                     :in $rows
                     :where
                     [$rows ?e ?a ?v ?t :db/retract]]
                    [[1 :name "Ivan" 945 :db/add]
                     [1 :age 39 999 :db/retract]])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].int-value 19))
    (t.is (= (count long-rows.rows) 1))
    (t.is (= long-rows.rows[0].values[0].int-value 1))
    (t.is (= long-rows.rows[0].values[1].text ":age"))
    (t.is (= long-rows.rows[0].values[2].int-value 39))
    (t.is (= long-rows.rows[0].values[3].int-value 999))))

(t.deftest datascript-query-multiple-db-sources-subset
  (defer (free_all context.allocator))
  (let [db1 (vev.create-conn)
        db2 (vev.create-conn)
        _ (vev.transact
            (addr db1)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 1 :name "Ivan" :id 1}
             {:db/id 2 :name "Petr" :id 2}
             {:db/id 3 :name "Oleg" :id 3}])
        _ (vev.transact
            (addr db2)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 3 :name "Ivan" :id 3}
             {:db/id 1 :name "Petr" :id 1}
             {:db/id 2 :name "Oleg" :id 2}])
        numeric (vev.q db1.db
                  [:find ?e ?id1 ?id2
                   :in $1 $2 [?e ...]
                   :where
                   [$1 ?e :id ?id1]
                   [$2 ?e :id ?id2]]
                  db1.db db2.db [1 2 3])
        lookup-refs (vev.q db1.db
                      [:find ?e ?id1 ?id2
                       :in $1 $2 [?e ...]
                       :where
                       [$1 ?e :id ?id1]
                       [$2 ?e :id ?id2]]
                      db1.db db2.db [[:name "Ivan"] [:name "Petr"] [:name "Oleg"]])]
    (t.is (= (count numeric.rows) 3))
    (t.is (= numeric.rows[0].values[0].int-value 1))
    (t.is (= numeric.rows[0].values[1].int-value 1))
    (t.is (= numeric.rows[0].values[2].int-value 1))
    (t.is (= numeric.rows[1].values[0].int-value 2))
    (t.is (= numeric.rows[1].values[1].int-value 2))
    (t.is (= numeric.rows[1].values[2].int-value 2))
    (t.is (= numeric.rows[2].values[0].int-value 3))
    (t.is (= numeric.rows[2].values[1].int-value 3))
    (t.is (= numeric.rows[2].values[2].int-value 3))
    (t.is (= (count lookup-refs.rows) 3))
    (t.is (= lookup-refs.rows[0].values[0].kind .Vector))
    (t.is (= lookup-refs.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= lookup-refs.rows[0].values[1].int-value 1))
    (t.is (= lookup-refs.rows[0].values[2].int-value 3))
    (t.is (= lookup-refs.rows[1].values[0].kind .Vector))
    (t.is (= lookup-refs.rows[1].values[0].items[1].text "Petr"))
    (t.is (= lookup-refs.rows[1].values[1].int-value 2))
    (t.is (= lookup-refs.rows[1].values[2].int-value 1))
    (t.is (= lookup-refs.rows[2].values[0].kind .Vector))
    (t.is (= lookup-refs.rows[2].values[0].items[1].text "Oleg"))
    (t.is (= lookup-refs.rows[2].values[1].int-value 3))
    (t.is (= lookup-refs.rows[2].values[2].int-value 2))))

