        report (vev.transact
                   (addr conn)
                   [[:db/add :user/ada :user/name "Ada"]])
        missing (vev.transact
                    (addr conn)
                    [[:db/add :user/missing :user/name "Missing"]])
        result (vev.q report.db-after
                   [:find ?name
                    :where
