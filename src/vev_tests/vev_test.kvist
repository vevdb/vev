(t.deftest datascript-components-multival-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :profile]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 1 :name "Ivan"]
              [:db/add 1 :profile (vev.value-entity 3)]
              [:db/add 1 :profile (vev.value-entity 4)]
              [:db/add 3 :email "@3"]
              [:db/add 4 :email "@4"]])
        pulled (vev.pull conn.db [:name :profile] 1)
        profile-parents (vev.entity-refs (vev.db-entity conn.db 3) ":_profile")
        retract-entity (vev.transact (addr conn) [[:db.fn/retractEntity 1]])
        after-entity-retract (vev.q retract-entity.db-after
                               [:find ?a ?v
                                :in [?e ...]
                                :where
                                [?e ?a ?v]]
                               [1 3 4])]
    (t.is (= (count pulled.attrs) 3))
    (t.is (= pulled.attrs[0].v.text "Ivan"))
    (t.is (= pulled.attrs[1].v.entity 3))
    (t.is (= pulled.attrs[1].attrs[1].v.text "@3"))
    (t.is (= pulled.attrs[2].v.entity 4))
    (t.is (= pulled.attrs[2].attrs[1].v.text "@4"))
    (t.is (= (count profile-parents) 1))
    (t.is (= profile-parents[0].e 1))
    (t.is retract-entity.ok)
    (t.is (= (count after-entity-retract.rows) 0)))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :profile]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 1 :name "Ivan"]
              [:db/add 1 :profile (vev.value-entity 3)]
              [:db/add 1 :profile (vev.value-entity 4)]
              [:db/add 3 :email "@3"]
              [:db/add 4 :email "@4"]])
        retract-attr (vev.transact (addr conn) [[:db.fn/retractAttribute 1 :profile]])
        children-after (vev.q retract-attr.db-after
                         [:find ?a ?v
                          :in [?e ...]
                          :where
                          [?e ?a ?v]]
                         [3 4])
        parent-after (vev.q retract-attr.db-after
                       [:find ?a ?v
                        :where
                        [1 ?a ?v]])]
    (t.is retract-attr.ok)
    (t.is (= (count children-after.rows) 0))
    (t.is (= (count parent-after.rows) 1))
    (t.is (= parent-after.rows[0].values[0].text ":name"))
    (t.is (= parent-after.rows[0].values[1].text "Ivan"))))

(t.deftest transact-data-resolves-string-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/name "Existing"]
                  [:db/add "user" :user/email "ada@example.com"]
                  [:db/add "user" :user/name "Ada"]])
        e report.tempids[0].e
        [current-tx current-tx-ok] (tempid-e (slice report.tempids 0) ":db/current-tx")
        results (vev.q report.db-after
                  [:find ?name
                   :where
                   [?e :user/email "ada@example.com"]
                   [?e :user/name ?name]])]
    (t.is (= (count report.tempids) 2))
    (t.is (= report.tempids[0].tempid "user"))
    (t.is current-tx-ok)
    (t.is (= current-tx report.tx))
    (t.is (> e 1))
    (t.is (= report.tx-data[1].e e))
    (t.is (= report.tx-data[2].e e))
    (t.is (= (count results.rows) 1))
    (t.is (= results.rows[0].values[0].text "Ada"))))

(t.deftest datascript-text-transact-supports-negative-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 100 :db/ident :friend] [:db/add 100 :db/valueType :db.type/ref] [:db/add 100 :db/cardinality :db.cardinality/many] [:db/add 101 :db/ident :score] [:db/add 101 :db/valueType :db.type/long]]")
        report (vev.transact-text
                 (addr conn)
                 "[[:db/add -1 :name \"Ivan\"] [:db/add -2 :name \"Petr\"] [:db/add -2 :friend -1] {:db/id -3 :name \"Sergey\" :friend [-1 -2]} [:db/add 1 :score -1]]")
        prepared (vev.prepare-tx-text
                   "[[:db/add -4 :name \"Oleg\"] [:db/add -5 :name \"Boris\"] [:db/add -5 :friend -4]]")
        prepared-report (vev.transact-prepared (addr conn) prepared)
        cas-tempid (vev.transact-text
                     (addr conn)
                     "[[:db/add -6 :name \"Temp\"] [:db.fn/cas -6 :name \"Temp\" \"Other\"]]")
        [ivan-e ivan-ok] (tempid-e (slice report.tempids 0) "-1")
        [petr-e petr-ok] (tempid-e (slice report.tempids 0) "-2")
        [sergey-e sergey-ok] (tempid-e (slice report.tempids 0) "-3")
        [oleg-e oleg-ok] (tempid-e (slice prepared-report.tempids 0) "-4")
        [boris-e boris-ok] (tempid-e (slice prepared-report.tempids 0) "-5")
        petr-friends (vev.q-text-collection
                       conn.db
                       "[:find [?name ...] :where [?p :name \"Petr\"] [?p :friend ?f] [?f :name ?name]]")
        sergey-friends (vev.q-text-collection
                         conn.db
                         "[:find [?name ...] :where [?p :name \"Sergey\"] [?p :friend ?f] [?f :name ?name]]")
        boris-friends (vev.q-text-collection
                        conn.db
                        "[:find [?name ...] :where [?p :name \"Boris\"] [?p :friend ?f] [?f :name ?name]]")
        [score score-ok] (vev.q-text-scalar
                           conn.db
                           "[:find ?score . :where [1 :score ?score]]")]
    (t.is report.ok)
    (t.is prepared.ok)
    (t.is prepared-report.ok)
    (t.is (not cas-tempid.ok))
    (t.is (= cas-tempid.error "tempids not allowed outside add"))
    (t.is ivan-ok)
    (t.is petr-ok)
    (t.is sergey-ok)
    (t.is oleg-ok)
    (t.is boris-ok)
    (t.is (not (= ivan-e petr-e)))
    (t.is (not (= sergey-e ivan-e)))
    (t.is (not (= oleg-e boris-e)))
    (t.is (= (count petr-friends) 1))
    (t.is (= petr-friends[0].text "Ivan"))
    (t.is (= (count sergey-friends) 2))
    (t.is (= sergey-friends[0].text "Ivan"))
    (t.is (= sergey-friends[1].text "Petr"))
    (t.is (= (count boris-friends) 1))
    (t.is (= boris-friends[0].text "Oleg"))
    (t.is score-ok)
    (t.is (= score.kind .Int))
    (t.is (= score.int-value -1))))

(t.deftest schema-enforces-value-type-cardinality-and-unique
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :user/email]
                  [:db/add 100 :db/valueType :db.type/string]
                  [:db/add 100 :db/cardinality :db.cardinality/one]
                  [:db/add 100 :db/unique :db.unique/identity]
                  [:db/add 101 :db/ident :user/age]
                  [:db/add 101 :db/valueType :db.type/long]
                  [:db/add 102 :db/ident :user/status]
                  [:db/add 102 :db/valueType :db.type/keyword]
                  [:db/add 103 :db/ident :user/admin]
                  [:db/add 103 :db/valueType :db.type/boolean]])
        ok-report (vev.transact
                    (addr conn)
                    [[:db/add 1 :user/email "ada@example.com"]
                     [:db/add 1 :user/age 37]
                     [:db/add 1 :user/status :user.status/active]
                     [:db/add 1 :user/admin true]])
        bad-type (vev.transact
                   (addr conn)
                   [[:db/add 2 :user/age "old"]])
        bad-keyword (vev.transact
                      (addr conn)
                      [[:db/add 2 :user/status "active"]])
        bad-bool (vev.transact
                   (addr conn)
                   [[:db/add 2 :user/admin "true"]])
        duplicate-email (vev.transact
                          (addr conn)
                          [[:db/add 2 :user/email "ada@example.com"]])
        second-email (vev.transact
                       (addr conn)
                       [[:db/add 1 :user/email "ada2@example.com"]])
        current-email (vev.q second-email.db-after
                        [:find ?email
                         :where
                         [1 :user/email ?email]])
        schema-view (vev.db-schema conn.db)]
    (defer (vev.delete-schema schema-view))
    (t.is schema.ok)
    (t.is (= (count schema-view) 4))
    (t.is (= schema-view[0].attr ":user/email"))
    (t.is schema-view[0].has-value-type)
    (t.is (= schema-view[0].value-type ":db.type/string"))
    (t.is schema-view[0].has-cardinality)
    (t.is (= schema-view[0].cardinality ":db.cardinality/one"))
    (t.is schema-view[0].has-unique)
    (t.is (= schema-view[0].unique ":db.unique/identity"))
    (t.is (= schema-view[1].attr ":user/age"))
    (t.is (= schema-view[1].value-type ":db.type/long"))
    (t.is (= schema-view[2].attr ":user/status"))
    (t.is (= schema-view[2].value-type ":db.type/keyword"))
    (t.is (= schema-view[3].attr ":user/admin"))
    (t.is (= schema-view[3].value-type ":db.type/boolean"))
    (t.is ok-report.ok)
    (t.is (not bad-type.ok))
    (t.is (= bad-type.error "schema value type mismatch"))
    (t.is (not bad-keyword.ok))
    (t.is (= bad-keyword.error "schema value type mismatch"))
    (t.is (not bad-bool.ok))
    (t.is (= bad-bool.error "schema value type mismatch"))
    (t.is (not duplicate-email.ok))
    (t.is (= duplicate-email.error "conflicting upsert"))
    (t.is second-email.ok)
    (t.is (= (count current-email.rows) 1))
    (t.is (= current-email.rows[0].values[0].text "ada2@example.com"))))

(t.deftest datascript-unique-value-does-not-upsert
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/value]
             [:db/add 1 :name "Ivan"]])
        conflict (vev.transact
                   (addr conn)
                   [{:name "Ivan" :age 35}])
        lookup-ref (vev.transact
                     (addr conn)
                     [[:db/add [:name "Ivan"] :age 36]])
        [age age-ok] (vev.q-scalar lookup-ref.db-after
                       [:find ?age .
                        :where
                        [1 :age ?age]])]
    (t.is (not conflict.ok))
    (t.is (= conflict.error "schema unique conflict"))
    (t.is lookup-ref.ok)
    (t.is age-ok)
    (t.is (= age.int-value 36))))

(t.deftest datascript-validation-rejects-nil-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact (addr conn) [[:db/add 1 :name nil]])]
    (t.is (not report.ok))
    (t.is (= report.error "cannot store nil"))
    (t.is (= (count conn.db.datoms) 0))))

(t.deftest datascript-validation-rejects-bad-tx-data-runtime-subset
  (defer (free_all context.allocator))
  (let [unknown-op-conn (vev.create-conn)
        unknown-op (vev.transact-tx-data
                     (addr unknown-op-conn)
                     ([]vev.Tx-Data
                       [(vev.Tx-Data {op: ":db/nope" e: 1 a: ":name" v: (vev.value-string "Ivan")})]))
        bad-attr-conn (vev.create-conn)
        bad-attr (vev.transact-tx-data
                   (addr bad-attr-conn)
                   ([]vev.Tx-Data
                     [(vev.add 1 "" (vev.value-string "Ivan"))]))
        bad-lookup-conn (vev.create-conn)
        bad-lookup (vev.transact-tx-data
                     (addr bad-lookup-conn)
                     ([]vev.Tx-Data
                       [(vev.add-lookup-ref "" (vev.value-string "Ivan") ":age" (vev.value-int 37))]))
        retract-tempid-conn (vev.create-conn)
        retract-tempid (vev.transact-tx-data
                         (addr retract-tempid-conn)
                         ([]vev.Tx-Data
                           [(vev.retract-tempid "x" ":name" (vev.value-string "Ivan"))]))
        cas-tempid-conn (vev.create-conn)
        cas-tempid (vev.transact-tx-data
                     (addr cas-tempid-conn)
                     ([]vev.Tx-Data
                       [(vev.cas-tempid "x" ":age" (vev.value-nil) (vev.value-int 1))]))]
    (t.is (not unknown-op.ok))
    (t.is (= unknown-op.error "unknown tx op"))
    (t.is (not bad-attr.ok))
    (t.is (= bad-attr.error "bad entity attribute"))
    (t.is (not bad-lookup.ok))
    (t.is (= bad-lookup.error "bad lookup attribute"))
    (t.is (not retract-tempid.ok))
    (t.is (= retract-tempid.error "tempids not allowed outside add"))
    (t.is (not cas-tempid.ok))
    (t.is (= cas-tempid.error "tempids not allowed outside add"))
    (t.is (= (count unknown-op-conn.db.datoms) 0))
    (t.is (= (count bad-attr-conn.db.datoms) 0))
    (t.is (= (count bad-lookup-conn.db.datoms) 0))
    (t.is (= (count retract-tempid-conn.db.datoms) 0))
    (t.is (= (count cas-tempid-conn.db.datoms) 0))))

(t.deftest datascript-validation-rejects-bad-tx-data-text-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 100 :db/ident :profile] [:db/add 100 :db/valueType :db.type/ref] [:db/add 101 :db/ident :id] [:db/add 101 :db/unique :db.unique/identity]]")
        before-count (count conn.db.datoms)
        bad-root (vev.transact-text (addr conn) "{:profile \"aaa\"}")
        unknown-op (vev.transact-text (addr conn) "[[\"aaa\" :name \"Ivan\"]]")
        bad-attr-vector (vev.transact-text (addr conn) "[[:db/add \"x\" nil \"Ivan\"]]")
        bad-attr-map (vev.transact-text (addr conn) "[{:db/id \"x\" 17 \"Ivan\"}]")
        nil-value-vector (vev.transact-text (addr conn) "[[:db/add \"x\" :name nil]]")
        nil-value-map (vev.transact-text (addr conn) "[{:db/id \"x\" :name nil}]")
        nil-entity (vev.transact-text (addr conn) "[[:db/add nil :name \"Ivan\"]]")
        bad-ref-value (vev.transact-text (addr conn) "[[:db/add \"x\" :profile {}]]")
        tempid-outside-add (vev.transact-text (addr conn) "[[:db/retract \"x\" :name \"Ivan\"]]")
        after-count (count conn.db.datoms)]
    (t.is (= before-count 4))
    (t.is (not bad-root.ok))
    (t.is (= bad-root.error "tx text must be an EDN vector"))
    (t.is (not unknown-op.ok))
    (t.is (= unknown-op.error "tx-data operation must be a keyword"))
    (t.is (not bad-attr-vector.ok))
    (t.is (= bad-attr-vector.error "tx-data attributes must be keywords or strings"))
    (t.is (not bad-attr-map.ok))
    (t.is (= bad-attr-map.error "tx map attributes must be keywords or strings"))
    (t.is (not nil-value-vector.ok))
    (t.is (= nil-value-vector.error "cannot store nil"))
    (t.is (not nil-value-map.ok))
    (t.is (= nil-value-map.error "cannot store nil"))
    (t.is (not nil-entity.ok))
    (t.is (= nil-entity.error "entity id must be int, tempid string, ident keyword, or lookup ref"))
    (t.is (not bad-ref-value.ok))
    (t.is (= bad-ref-value.error "schema value type mismatch"))
    (t.is (not tempid-outside-add.ok))
    (t.is (= tempid-outside-add.error "tempids not allowed outside add"))
    (t.is (= after-count before-count))))

(t.deftest datascript-transact-text-accepts-single-op-vector-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        add (vev.transact-text (addr conn) "[:db/add 1 :name \"Ivan\"]")
        prepared (vev.prepare-tx-text "[:db/add 1 :age 19]")
        prepared-report (vev.transact-prepared (addr conn) prepared)
        retract (vev.transact-text (addr conn) "[:db/retract 1 :name \"Ivan\"]")
        invalid (vev.transact-text (addr conn) "[:db/add nil :name \"Bad\"]")
        name-after (vev.q-collection conn.db
                      [:find [?name ...]
                       :where
                       [1 :name ?name]])
        [age-after age-ok] (vev.q-scalar conn.db
                             [:find ?age .
                              :where
                              [1 :age ?age]])]
    (t.is add.ok)
    (t.is prepared.ok)
    (t.is prepared-report.ok)
    (t.is retract.ok)
    (t.is (not invalid.ok))
    (t.is (= invalid.error "entity id must be int, tempid string, ident keyword, or lookup ref"))
    (t.is (= (count name-after) 0))
    (t.is age-ok)
    (t.is (= age-after.int-value 19))))

(t.deftest datascript-transaction-rejects-large-entity-ids-subset
  (defer (free_all context.allocator))
  (let [direct-conn (vev.create-conn)
        direct (vev.transact
                 (addr direct-conn)
                 [[:db/add 285873023227265 :name "Valerii"]])
        map-conn (vev.create-conn)
        map-report (vev.transact
                     (addr map-conn)
                     [{:db/id 285873023227265 :name "Valerii"}])
        ref-conn (vev.create-conn)
        _ (vev.transact
            (addr ref-conn)
            [[:db/add 100 :db/ident :ref]
             [:db/add 100 :db/valueType :db.type/ref]])
        ref-report (vev.transact
                     (addr ref-conn)
                     [{:db/id 1 :ref 285873023227265}])
        text-conn (vev.create-conn)
        text-report (vev.transact-text
                      (addr text-conn)
                      "[[:db/add 285873023227265 :name \"Valerii\"]]")]
    (t.is (not direct.ok))
    (t.is (= direct.error "entity id exceeds supported range"))
    (t.is (not map-report.ok))
    (t.is (= map-report.error "entity id exceeds supported range"))
    (t.is (not ref-report.ok))
    (t.is (= ref-report.error "entity id exceeds supported range"))
    (t.is (not text-report.ok))
    (t.is (= text-report.error "entity id exceeds supported range"))
    (t.is (= (count direct-conn.db.datoms) 0))
    (t.is (= (count map-conn.db.datoms) 0))
    (t.is (= (count text-conn.db.datoms) 0))))

(t.deftest datascript-tuple-attrs-derived-tx-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        schema (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]])
        [after-a after-a-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-and-b ?tuple]])
        _ (vev.transact (addr conn) [[:db/add 1 :b "B"]])
        [after-b after-b-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-and-b ?tuple]])
        direct (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.add 2 ":a-and-b"
                      (vev.value-vector2
                        (vev.value-string "A")
                        (vev.value-string "B")))]))
        _ (vev.transact (addr conn) [[:db/retract 1 :a "A"]
                                     [:db/retract 1 :b "B"]])
        gone (vev.q conn.db
               [:find ?tuple
                :where
                [1 :a-and-b ?tuple]])
        schema-view (vev.db-schema conn.db)]
    (defer (vev.delete-schema schema-view))
    (t.is schema.ok)
    (t.is (= (count schema-view) 1))
    (t.is (= schema-view[0].attr ":a-and-b"))
    (t.is schema-view[0].has-tuple-attrs)
    (t.is (= (count schema-view[0].tuple-attrs) 2))
    (t.is (= schema-view[0].tuple-attrs[0] ":a"))
    (t.is (= schema-view[0].tuple-attrs[1] ":b"))
    (t.is after-a-ok)
    (t.is (= after-a.kind .Vector))
    (t.is (= after-a.items[0].text "A"))
    (t.is (= after-a.items[1].kind .Nil))
    (t.is after-b-ok)
    (t.is (= after-b.items[0].text "A"))
    (t.is (= after-b.items[1].text "B"))
    (t.is (not direct.ok))
    (t.is (= direct.error "cannot modify tuple attrs directly"))
    (t.is (= (count gone.rows) 0))))

(t.deftest datascript-tuple-attrs-maintains-multiple-tuples-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        two-schema (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice two-schema 0))
        three-schema (vev.transact
                       (addr conn)
                       ([]vev.Tx-Data
                         [(vev.add 101 ":db/ident" (vev.value-keyword ":a-c-d"))
                          (vev.add 101 ":db/tupleAttrs"
                            (vev.value-vector
                              ([]vev.Value
                                [(vev.value-keyword ":a")
                                 (vev.value-keyword ":c")
                                 (vev.value-keyword ":d")])))]))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]])
        [after-a after-a-ok] (vev.q-scalar conn.db
                               [:find ?tuple .
                                :where
                                [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/add 1 :b "B"]
                                     [:db/add 1 :c "C"]
                                     [:db/add 1 :d "D"]])
        [after-all after-all-ok] (vev.q-scalar conn.db
                                   [:find ?tuple .
                                    :where
                                    [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/retract 1 :a "A"]])
        [after-retract-a after-retract-a-ok] (vev.q-scalar conn.db
                                               [:find ?tuple .
                                                :where
                                                [1 :a-c-d ?tuple]])
        _ (vev.transact (addr conn) [[:db/retract 1 :c "C"]
                                     [:db/retract 1 :d "D"]])
        gone (vev.q conn.db
               [:find ?tuple
                :where
                [1 :a-c-d ?tuple]])]
    (t.is three-schema.ok)
    (t.is after-a-ok)
    (t.is (= after-a.items[0].text "A"))
    (t.is (= after-a.items[1].kind .Nil))
    (t.is (= after-a.items[2].kind .Nil))
    (t.is after-all-ok)
    (t.is (= after-all.items[0].text "A"))
    (t.is (= after-all.items[1].text "C"))
    (t.is (= after-all.items[2].text "D"))
    (t.is after-retract-a-ok)
    (t.is (= after-retract-a.items[0].kind .Nil))
    (t.is (= after-retract-a.items[1].text "C"))
    (t.is (= after-retract-a.items[2].text "D"))
    (t.is (= (count gone.rows) 0))))

(t.deftest datascript-tuple-attrs-ignore-correct-direct-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        insert-ok (vev.transact
                    (addr conn)
                    [{:db/id 1
                      :a "A"
                      :b "B"
                      :a-and-b ["A" "B"]}])
        ok (vev.transact
             (addr conn)
             ([]vev.Tx-Data
               [(vev.add 1 ":a-and-b"
                  (vev.value-vector2
                    (vev.value-string "A")
                    (vev.value-string "B")))]))
        bad (vev.transact
              (addr conn)
              ([]vev.Tx-Data
                [(vev.add 1 ":a-and-b"
                   (vev.value-vector2
                     (vev.value-string "A")
                     (vev.value-string "wrong")))]))
        wrong-arity (vev.transact
                      (addr conn)
                      ([]vev.Tx-Data
                        [(vev.add 1 ":a-and-b"
                           (vev.value-vector ([]vev.Value [(vev.value-string "A")])))]))
        nil-component (vev.transact
                        (addr conn)
                        ([]vev.Tx-Data
                          [(vev.add 1 ":a-and-b"
                             (vev.value-vector2
                               (vev.value-string "A")
                               (vev.value-nil)))]))]
    (t.is insert-ok.ok)
    (t.is (= (count insert-ok.tx-data) 3))
    (t.is ok.ok)
    (t.is (= (count ok.tx-data) 0))
    (t.is (not bad.ok))
    (t.is (= bad.error "cannot modify tuple attrs directly"))
    (t.is (not wrong-arity.ok))
    (t.is (= wrong-arity.error "cannot modify tuple attrs directly"))
    (t.is (not nil-component.ok))
    (t.is (= nil-component.error "cannot modify tuple attrs directly"))))

(t.deftest datascript-text-tuple-attrs-ignore-correct-direct-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        insert-ok (vev.transact-text
                    (addr conn)
                    "[{:db/id 1 :a \"A\" :b \"B\" :a-and-b [\"A\" \"B\"]}]")
        ok (vev.transact-text
             (addr conn)
             "[[:db/add 1 :a-and-b [\"A\" \"B\"]]]")
        bad (vev.transact-text
              (addr conn)
              "[[:db/add 1 :a-and-b [\"A\" \"wrong\"]]]")
        wrong-arity (vev.transact-text
                      (addr conn)
                      "[[:db/add 1 :a-and-b [\"A\"]]]")
        nil-component (vev.transact-text
                        (addr conn)
                        "[[:db/add 1 :a-and-b [\"A\" nil]]]")]
    (t.is insert-ok.ok)
    (t.is (= (count insert-ok.tx-data) 3))
    (t.is ok.ok)
    (t.is (= (count ok.tx-data) 0))
    (t.is (not bad.ok))
    (t.is (= bad.error "cannot modify tuple attrs directly"))
    (t.is (not wrong-arity.ok))
    (t.is (= wrong-arity.error "cannot modify tuple attrs directly"))
    (t.is (not nil-component.ok))
    (t.is (= nil-component.error "cannot modify tuple attrs directly"))))

(t.deftest datascript-tuple-attrs-rejects-direct-retract-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]
                                     [:db/add 1 :b "B"]])
        direct (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.retract 1 ":a-and-b"
                      (vev.value-vector2
                        (vev.value-string "A")
                        (vev.value-string "B")))]))
        attr (vev.transact (addr conn) [[:db.fn/retractAttribute 1 :a-and-b]])
        nil-direct (vev.transact
                     (addr conn)
                     ([]vev.Tx-Data
                       [(vev.retract 1 ":a-and-b"
                          (vev.value-vector2
                            (vev.value-string "A")
                            (vev.value-nil)))]))
        still-there (vev.q conn.db
                      [:find ?tuple
                       :where
                       [1 :a-and-b ?tuple]])]
    (t.is (not direct.ok))
    (t.is (= direct.error "cannot modify tuple attrs directly"))
    (t.is (not attr.ok))
    (t.is (= attr.error "cannot modify tuple attrs directly"))
    (t.is (not nil-direct.ok))
    (t.is (= nil-direct.error "cannot modify tuple attrs directly"))
    (t.is (= (count still-there.rows) 1))))

(t.deftest datascript-tuple-attrs-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [[:db/add 1 :a "A"]
                                     [:db/add 1 :b "B"]])
        report (vev.transact
                 (addr conn)
                 [[:db/add [:a-and-b ["A" "B"]] :c "C"]])
        [c c-ok] (vev.q-scalar report.db-after
                   [:find ?c .
                    :where
                    [1 :c ?c]])]
    (t.is report.ok)
    (t.is c-ok)
    (t.is (= c.text "C"))))

(t.deftest datascript-tuple-attrs-nested-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 102 ":ref+name" ":ref" ":name")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :ref]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 101 :db/ident :name]
             [:db/add 101 :db/unique :db.unique/identity]
             [:db/add 102 :db/valueType :db.type/tuple]
             [:db/add 102 :db/unique :db.unique/identity]])
        seed (vev.transact
               (addr conn)
               [{:db/id 1 :name "Ivan"}
                {:db/id 3 :ref 1 :name "Petr"}])
        [tuple tuple-ok] (vev.q-scalar conn.db
                           [:find ?tuple .
                            :where
                            [3 :ref+name ?tuple]])
        nested (vev.transact
                 (addr conn)
                 [[:db/add [:ref+name [[:name "Ivan"] "Petr"]] :age 32]])
        numeric (vev.transact
                  (addr conn)
                  [[:db/add [:ref+name [1 "Petr"]] :score 7]])
        tempid-tuple (vev.transact
                       (addr conn)
                       ([]vev.Tx-Data
                         [(vev.add-tempid "tuple-target" ":ref+name"
                            (vev.value-vector2
                              (vev.value-entity 1)
                              (vev.value-string "Petr")))
                          (vev.add-tempid "tuple-target" ":level" (vev.value-int 9))]))
        tempid-nested-lookup (vev.transact
                               (addr conn)
                               ([]vev.Tx-Data
                                 [(vev.add-tempid "nested-target" ":ref+name"
                                    (vev.value-vector2
                                      (vev.value-vector2
                                        (vev.value-keyword ":name")
                                        (vev.value-string "Ivan"))
                                      (vev.value-string "Petr")))
                                  (vev.add-tempid "nested-target" ":rank" (vev.value-int 11))]))
        [age age-ok] (vev.q-scalar conn.db
                       [:find ?age .
                        :where
                        [3 :age ?age]])
        [score score-ok] (vev.q-scalar conn.db
                           [:find ?score .
                            :where
                            [3 :score ?score]])
        [level level-ok] (vev.q-scalar conn.db
                           [:find ?level .
                            :where
                            [3 :level ?level]])
        [rank rank-ok] (vev.q-scalar conn.db
                         [:find ?rank .
                          :where
                          [3 :rank ?rank]])]
    (t.is seed.ok)
    (t.is tuple-ok)
    (t.is (= tuple.kind .Vector))
    (t.is (= tuple.items[0].kind .Entity))
    (t.is (= tuple.items[0].entity 1))
    (t.is (= tuple.items[1].text "Petr"))
    (t.is nested.ok)
    (t.is numeric.ok)
    (t.is tempid-tuple.ok)
    (t.is (= tempid-tuple.tempids[0].e 3))
    (t.is tempid-nested-lookup.ok)
    (t.is (= tempid-nested-lookup.tempids[0].e 3))
    (t.is age-ok)
    (t.is (= age.int-value 32))
    (t.is score-ok)
    (t.is (= score.int-value 7))
    (t.is level-ok)
    (t.is (= level.int-value 9))
    (t.is rank-ok)
    (t.is (= rank.int-value 11))))

(t.deftest datascript-tuple-attrs-upsert-by-components-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [{:a "A" :b "B" :name "Ivan"}])
        [before-e before-ok] (vev.q-scalar conn.db
                               [:find ?e .
                                :where
                                [?e :name "Ivan"]])
        report (vev.transact (addr conn) [{:a "A" :b "B" :name "Oleg"}])
        result (vev.q report.db-after
                 [:find ?e ?name
                  :where
                  [?e :name ?name]])]
    (t.is before-ok)
    (t.is report.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity before-e.entity))
    (t.is (= result.rows[0].values[1].text "Oleg"))))

(t.deftest datascript-tuple-attrs-upsert-by-tuple-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]
                                     [:db/add 101 :db/ident :c]
                                     [:db/add 101 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                     {:db/id 2 :a "a" :b "b"}])
        first (vev.transact
                (addr conn)
                ([]vev.Tx-Data
                  [(vev.add-tempid "x" ":a-and-b"
                     (vev.value-vector2
                       (vev.value-string "A")
                       (vev.value-string "B")))
                   (vev.add-tempid "x" ":c" (vev.value-string "C"))
                   (vev.add-tempid "y" ":a-and-b"
                     (vev.value-vector2
                       (vev.value-string "a")
                       (vev.value-string "b")))
                   (vev.add-tempid "y" ":c" (vev.value-string "c"))]))
        conflict (vev.transact
                   (addr conn)
                   ([]vev.Tx-Data
                     [(vev.add-tempid "z" ":a-and-b"
                        (vev.value-vector2
                          (vev.value-string "A")
                          (vev.value-string "B")))
                      (vev.add-tempid "z" ":c" (vev.value-string "c"))]))
        changed (vev.transact
                  (addr conn)
                  ([]vev.Tx-Data
                    [(vev.add-tempid "w" ":a-and-b"
                       (vev.value-vector2
                         (vev.value-string "A")
                         (vev.value-string "B")))
                     (vev.add-tempid "w" ":b" (vev.value-string "b"))
                     (vev.add-tempid "w" ":d" (vev.value-string "D"))]))
        result (vev.q conn.db
                 [:find ?e ?b ?c ?d
                  :where
                  [?e :a "A"]
                  [?e :b ?b]
                  [?e :c ?c]
                  [?e :d ?d]])]
    (t.is first.ok)
    (t.is (= first.tempids[0].e 1))
    (t.is (= first.tempids[1].e 2))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "conflicting upsert"))
    (t.is changed.ok)
    (t.is (= changed.tempids[0].e 1))
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].text "b"))
    (t.is (= result.rows[0].values[2].text "C"))
    (t.is (= result.rows[0].values[3].text "D"))))

(t.deftest datascript-text-tuple-attrs-upsert-and-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 100 :db/unique :db.unique/identity] [:db/add 101 :db/ident :c] [:db/add 101 :db/unique :db.unique/identity]]")
        seed (vev.transact-text
               (addr conn)
               "[{:db/id 1 :a \"A\" :b \"B\" :name \"Ivan\"} {:db/id 2 :a \"a\" :b \"b\" :c \"c\"}]")
        by-components (vev.transact-text
                        (addr conn)
                        "[{:a \"A\" :b \"B\" :name \"Oleg\"}]")
        by-lookup-ref (vev.transact-text
                        (addr conn)
                        "[[:db/add [:a-and-b [\"a\" \"b\"]] :name \"Petr\"]]")
        prepared (vev.prepare-tx-text
                   "[[:db/add \"x\" :a-and-b [\"A\" \"B\"]] [:db/add \"x\" :city \"Oslo\"]]")
        by-tuple-value (vev.transact-prepared (addr conn) prepared)
        [x-e x-ok] (tempid-e (slice by-tuple-value.tempids 0) "x")
        before-conflict-count (count conn.db.datoms)
        conflict (vev.transact-text
                   (addr conn)
                   "[{:a-and-b [\"A\" \"B\"] :c \"c\"}]")
        after-conflict-count (count conn.db.datoms)
        result (vev.q-text
                 conn.db
                 "[:find ?e ?name ?city :where [?e :a \"A\"] [?e :name ?name] [?e :city ?city]]")
        lookup-result (vev.q-text
                        conn.db
                        "[:find ?e ?name :where [?e :a \"a\"] [?e :name ?name]]")]
    (t.is seed.ok)
    (t.is by-components.ok)
    (t.is by-lookup-ref.ok)
    (t.is by-tuple-value.ok)
    (t.is x-ok)
    (t.is (= x-e 1))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "conflicting upsert"))
    (t.is (= before-conflict-count after-conflict-count))
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].text "Oleg"))
    (t.is (= result.rows[0].values[2].text "Oslo"))
    (t.is (= (count lookup-result.rows) 1))
    (t.is (= lookup-result.rows[0].values[0].entity 2))
    (t.is (= lookup-result.rows[0].values[1].text "Petr"))))

(t.deftest datascript-tuple-attrs-unique-conflict-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                     {:db/id 2 :a "C" :b "B"}])
        report (vev.transact (addr conn) [[:db/add 2 :a "A"]])
        reverse-report (vev.transact (addr conn) [[:db/add 1 :a "C"]])
        both-report (vev.transact (addr conn) [[:db/add 2 :a "A"]
                                               [:db/add 2 :b "B"]])
        new-entity-report (vev.transact (addr conn) [{:db/id 4 :a "A" :b "B"}])
        [a a-ok] (vev.q-scalar conn.db
                   [:find ?a .
                    :where
                    [2 :a ?a]])]
    (t.is (not report.ok))
    (t.is (= report.error "schema unique conflict"))
    (t.is (not reverse-report.ok))
    (t.is (= reverse-report.error "schema unique conflict"))
    (t.is (not both-report.ok))
    (t.is (= both-report.error "schema unique conflict"))
    (t.is (not new-entity-report.ok))
    (t.is (= new-entity-report.error "schema unique conflict"))
    (t.is a-ok)
    (t.is (= a.text "C"))))

(t.deftest datascript-tuple-attrs-unique-multiple-component-update-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact (addr conn) [[:db/add 1 :a "a"]])
        _ (vev.transact (addr conn) [[:db/add 2 :a "A"]])
        partial-conflict (vev.transact (addr conn) [[:db/add 1 :a "A"]])
        seed (vev.transact (addr conn) [[:db/add 1 :b "b"]
                                        [:db/add 2 :b "b"]
                                        {:db/id 3 :a "a" :b "B"}])
        change-both (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}])
        add-final-free (vev.transact (addr conn) [{:db/id 4 :a "a" :b "b"}])
        result (vev.q conn.db
                 [:find ?e ?tuple
                  :where
                  [?e :a-and-b ?tuple]])]
    (t.is (not partial-conflict.ok))
    (t.is (= partial-conflict.error "schema unique conflict"))
    (t.is seed.ok)
    (t.is change-both.ok)
    (t.is add-final-free.ok)
    (t.is (= (count result.rows) 4))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].items[0].text "A"))
    (t.is (= result.rows[0].values[1].items[1].text "B"))
    (t.is (= result.rows[1].values[0].entity 2))
    (t.is (= result.rows[1].values[1].items[0].text "A"))
    (t.is (= result.rows[1].values[1].items[1].text "b"))
    (t.is (= result.rows[2].values[0].entity 3))
    (t.is (= result.rows[2].values[1].items[0].text "a"))
    (t.is (= result.rows[2].values[1].items[1].text "B"))
    (t.is (= result.rows[3].values[0].entity 4))
    (t.is (= result.rows[3].values[1].items[0].text "a"))
    (t.is (= result.rows[3].values[1].items[1].text "b"))))

(t.deftest datascript-tuple-attrs-index-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/index true]])
        _ (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                     {:db/id 2 :a "A" :b "C"}
                                     {:db/id 3 :a "B" :b "A"}])
        exact (vev.datoms conn.db :avet :a-and-b ["A" "B"])
        range (vev.index-range conn.db :a-and-b ["A" "B"] ["B" "A"])]
    (t.is (= (count exact) 1))
    (t.is (= exact[0].e 1))
    (t.is (= exact[0].v.kind .Vector))
    (t.is (= exact[0].v.items[0].text "A"))
    (t.is (= exact[0].v.items[1].text "B"))
    (t.is (= (count range) 3))
    (t.is (= range[0].e 1))
    (t.is (= range[1].e 2))
    (t.is (= range[2].e 3))))

(t.deftest datascript-tuple-attrs-index-without-explicit-index-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.add 100 ":db/ident" (vev.value-keyword ":a+b+c"))
                    (vev.add 100 ":db/tupleAttrs"
                      (vev.value-vector
                        ([]vev.Value
                          [(vev.value-keyword ":a")
                           (vev.value-keyword ":b")
                           (vev.value-keyword ":c")])))]))
        _ (vev.transact (addr conn) [[:db/add 1 :a "a"]
                                     [:db/add 1 :b "b"]
                                     [:db/add 1 :c "c"]
                                     [:db/add 2 :a "A"]
                                     [:db/add 2 :b "b"]
                                     [:db/add 2 :c "c"]
                                     [:db/add 3 :a "a"]
                                     [:db/add 3 :b "B"]
                                     [:db/add 3 :c "c"]
                                     [:db/add 4 :a "A"]
                                     [:db/add 4 :b "B"]
                                     [:db/add 4 :c "c"]
                                     [:db/add 5 :a "a"]
                                     [:db/add 5 :b "b"]
                                     [:db/add 5 :c "C"]
                                     [:db/add 6 :a "A"]
                                     [:db/add 6 :b "b"]
                                     [:db/add 6 :c "C"]
                                     [:db/add 7 :a "a"]
                                     [:db/add 7 :b "B"]
                                     [:db/add 7 :c "C"]
                                     [:db/add 8 :a "A"]
                                     [:db/add 8 :b "B"]
                                     [:db/add 8 :c "C"]])
        all (vev.datoms conn.db :avet :a+b+c)
        exact (vev.datoms conn.db :avet :a+b+c ["A" "b" "C"])
        nil-exact (vev.datoms conn.db :avet :a+b+c ["A" "b" nil])
        bounded (vev.index-range conn.db :a+b+c ["A" "B" "C"] ["A" "b" "c"])
        nil-prefix (vev.index-range conn.db :a+b+c ["A" "B" nil] ["A" "b" nil])]
    (t.is schema.ok)
    (t.is (= (count all) 8))
    (t.is (= (count exact) 1))
    (t.is (= exact[0].e 6))
    (t.is (= (count nil-exact) 0))
    (t.is (= (count bounded) 4))
    (t.is (= bounded[0].e 8))
    (t.is (= bounded[1].e 4))
    (t.is (= bounded[2].e 6))
    (t.is (= bounded[3].e 2))
    (t.is (= (count nil-prefix) 2))
    (t.is (= nil-prefix[0].e 8))
    (t.is (= nil-prefix[1].e 4))))

(t.deftest datascript-tuple-attrs-query-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                     {:db/id 2 :a "A" :b "C"}
                                     {:db/id 3 :a "B" :b "A"}])
        built (vev.q conn.db
                [:find ?tuple
                 :where
                 [?e :a ?a]
                 [?e :b ?b]
                 [(tuple ?a ?b) ?tuple]])
        split (vev.q conn.db
                [:find ?a ?b
                 :where
                 [?e :a-and-b ?tuple]
                 [(untuple ?tuple) [?a ?b]]])]
    (t.is (= (count built.rows) 3))
    (t.is (= built.rows[0].values[0].kind .Vector))
    (t.is (= built.rows[0].values[0].items[0].text "A"))
    (t.is (= built.rows[0].values[0].items[1].text "B"))
    (t.is (= (count split.rows) 3))
    (t.is (= split.rows[0].values[0].text "A"))
    (t.is (= split.rows[0].values[1].text "B"))
    (t.is (= split.rows[1].values[0].text "A"))
    (t.is (= split.rows[1].values[1].text "C"))
    (t.is (= split.rows[2].values[0].text "B"))
    (t.is (= split.rows[2].values[1].text "A"))))

(t.deftest datascript-tuple-attrs-query-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
