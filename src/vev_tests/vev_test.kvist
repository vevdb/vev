(t.deftest datascript-cas-cardinality-many-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :label]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :label :x]
             [:db/add 1 :label :y]])
        report (vev.transact (addr conn) [[:db.fn/cas 1 :label :y :z]])
        failed (vev.transact (addr conn) [[:db.fn/cas 1 :label :s :t]])
        labels (vev.q-collection report.db-after
                 [:find [?label ...]
                  :where
                  [1 :label ?label]])]
    (t.is report.ok)
    (t.is (not failed.ok))
    (t.is (= failed.error ":db.fn/cas failed on datom [1 :label (:x :y :z)], expected :s"))
    (t.is (= (count labels) 3))
    (t.is (= labels[0].text ":x"))
    (t.is (= labels[1].text ":y"))
    (t.is (= labels[2].text ":z"))))

