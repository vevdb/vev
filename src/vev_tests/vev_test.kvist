    (t.is (not get-else-nil-default-text.ok))
    (t.is (= get-else-nil-default-text.error "get-else: nil default value is not supported"))
    (t.is (= (count get-some.rows) 3))
    (t.is (= get-some.rows[0].values[1].text ":age"))
    (t.is (= get-some.rows[1].values[1].text ":height"))
    (t.is (= get-some.rows[2].values[1].text ":age"))
    (t.is get-some-text.ok)
    (t.is (= (count get-some-text.rows) 3))
    (t.is (= get-some-text.rows[1].values[1].text ":height"))
    (t.is get-some-map-text.ok)
    (t.is (= (count get-some-map-text.rows) 3))
    (t.is (= get-some-map-text.rows[2].values[1].text ":age"))
    (t.is (= (count missing.rows) 2))
    (t.is (= missing.rows[0].values[0].entity 1))
    (t.is (= missing.rows[1].values[0].entity 3))
    (t.is (= (count missing-back-ref) 1))
    (t.is (= missing-back-ref[0].entity 3))
    (t.is (= (count less-than.rows) 2))
    (t.is (= less-than.rows[0].values[0].entity 1))
    (t.is (= less-than.rows[0].values[1].entity 2))
    (t.is (= (count greater-equal) 2))
    (t.is (= greater-equal[0].int-value 22))
    (t.is (= greater-equal[1].int-value 37))
    (t.is (= (count plain-predicate.rows) 2))
    (t.is (= plain-predicate.rows[0].values[0].entity 2))
