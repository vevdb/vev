(t.deftest datascript-pull-xform-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :name]
                [:db/add 101 :db/ident :father]
                [:db/add 101 :db/valueType :db.type/ref]
                [:db/add 102 :db/ident :child]
                [:db/add 102 :db/valueType :db.type/ref]
                [:db/add 102 :db/cardinality :db.cardinality/many]
                {:db/id 1 :name "Petr" :child [2 3]}
                {:db/id 2 :name "David" :father 1}
                {:db/id 3 :name "Thomas" :father 1}])
        scalar (vev.pull conn.db [[:name :xform vector]
                                  [:missing :xform vector]
                                  [:unknown :default "[unknown]" :xform vector]]
                   1)
        forward-ref (vev.pull conn.db [{[:father :xform name] [:name]}] 2)
        reverse-ref (vev.pull conn.db [{[:_father :xform name] [:name]}] 1)
        text (vev.pull-text conn.db "[[:name :xform vector] {[:father :xform name] [:name]}]" 2)
        registry ([]vev.Native-Query-Fn [(vev.pull-xform-fn "tag-value" native-tag-value)])
        callback-text (vev.pull-text-with-fns conn.db "[[:name :xform tag-value]]" 1 registry)
        prepared (vev.prepare-pull-pattern-text "[[:name :xform tag-value]]")
        callback-prepared (vev.pull-prepared-with-fns conn.db prepared 2 registry)
        callback-many (vev.pull-many-text-with-fns conn.db "[[:name :xform tag-value]]" ([]u64 [1 2]) registry)
        callback-query (vev.q-text-with-fns
                         conn.db
                         "[:find (pull ?e [[:name :xform tag-value]]) :where [?e :name \"Petr\"]]"
                         registry)]
    (t.is (= scalar.attrs[0].v.kind .Vector))
    (t.is (= scalar.attrs[0].v.items[0].text "Petr"))
    (t.is (= scalar.attrs[1].v.kind .Vector))
    (t.is (= scalar.attrs[1].v.items[0].kind .Nil))
    (t.is (= scalar.attrs[2].v.text "[unknown]"))
    (t.is (= forward-ref.attrs[0].a ":father"))
    (t.is (= forward-ref.attrs[0].v.text "Petr"))
    (t.is (= (count forward-ref.attrs[0].attrs) 0))
    (t.is (= reverse-ref.attrs[0].a ":_father"))
    (t.is (= reverse-ref.attrs[0].v.text "David"))
    (t.is (= (count reverse-ref.attrs[0].attrs) 0))
    (t.is (= text.attrs[0].v.kind .Vector))
    (t.is (= text.attrs[0].v.items[0].text "David"))
    (t.is (= text.attrs[1].v.text "Petr"))
    (t.is (= callback-text.attrs[0].v.text "tag:Petr"))
    (t.is (= callback-prepared.attrs[0].v.text "tag:David"))
    (t.is (= (count callback-many) 2))
    (t.is (= callback-many[0].attrs[0].v.text "tag:Petr"))
    (t.is (= callback-many[1].attrs[0].v.text "tag:David"))
    (t.is (= (count callback-query.rows) 1))
    (t.is (= callback-query.rows[0].pulls[0].attrs[0].v.text "tag:Petr"))))

(t.deftest datascript-pull-visitor-trace-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :name}
             {:db/id 101 :db/ident :aka :db/cardinality :db.cardinality/many}
             {:db/id 102 :db/ident :child :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"] :child [2 3]}
             {:db/id 2 :name "David"}
             {:db/id 3 :name "Thomas"}])
        simple (vev.pull-visits-pattern-spec
                 conn.db
                 1
                 ([]vev.Pull-Spec [(vev.flat-pull-spec ":name")
                                    (vev.flat-pull-spec ":aka")]))
        with-id (vev.pull-visits-pattern-spec
                  conn.db
                  1
                  ([]vev.Pull-Spec [(vev.flat-pull-spec ":db/id")
                                     (vev.flat-pull-spec ":name")]))
        wildcard (vev.pull-visits-pattern-spec
                   conn.db
                   1
                   ([]vev.Pull-Spec [(vev.flat-pull-spec "*")
                                      (vev.flat-pull-spec ":missing")]))
        nested (vev.pull-visits-pattern-spec
                 conn.db
                 1
                 ([]vev.Pull-Spec [(vev.pull-spec
                                      ":child"
                                      ([]vev.Pull-Spec [(vev.flat-pull-spec ":name")]))]))
        reverse (vev.pull-visits-pattern-spec
                  conn.db
                  2
                  ([]vev.Pull-Spec [(vev.flat-pull-spec ":name")
                                     (vev.flat-pull-spec ":_child")]))
        [pulled traced] (vev.pull-pattern-spec-traced
                          conn.db
                          1
                          ([]vev.Pull-Spec [(vev.flat-pull-spec ":name")]))]
    (t.is (= (count simple) 2))
    (t.is (= simple[0].kind ":db.pull/attr"))
    (t.is simple[0].has-e)
    (t.is (= simple[0].e 1))
    (t.is (= simple[0].a ":name"))
    (t.is (= simple[1].a ":aka"))
    (t.is (= (count with-id) 1))
    (t.is (= with-id[0].a ":name"))
    (t.is (= (count wildcard) 5))
    (t.is (= wildcard[0].kind ":db.pull/wildcard"))
    (t.is (= wildcard[0].e 1))
    (t.is (= wildcard[1].a ":aka"))
    (t.is (= wildcard[2].a ":child"))
    (t.is (= wildcard[3].a ":name"))
    (t.is (= wildcard[4].a ":missing"))
    (t.is (= (count nested) 3))
    (t.is (= nested[0].a ":child"))
    (t.is (= nested[1].e 2))
    (t.is (= nested[1].a ":name"))
    (t.is (= nested[2].e 3))
    (t.is (= nested[2].a ":name"))
    (t.is (= (count reverse) 2))
    (t.is (= reverse[0].a ":name"))
    (t.is (= reverse[1].kind ":db.pull/reverse"))
    (t.is (not reverse[1].has-e))
    (t.is (= reverse[1].a ":child"))
    (t.is reverse[1].has-v)
    (t.is (= reverse[1].v-entity 2))
    (t.is (= pulled.attrs[0].v.text "Petr"))
    (t.is (= (count traced) 1))
    (t.is (= traced[0].a ":name"))))

