(t.deftest datascript-query-rules-basic-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :follow]
                  [:db/add 100 :db/valueType :db.type/ref]
                  [:db/add 100 :db/cardinality :db.cardinality/many]
                  [:db/add 5 :follow (vev.value-entity 3)]
                  [:db/add 1 :follow (vev.value-entity 2)]
                  [:db/add 2 :follow (vev.value-entity 3)]
                  [:db/add 3 :follow (vev.value-entity 4)]
                  [:db/add 4 :follow (vev.value-entity 6)]
                  [:db/add 2 :follow (vev.value-entity 4)]])
        follows (vev.q report.db-after
                  [:find ?e1 ?e2
                   :in $ %
                   :where
                   (follow ?e1 ?e2)]
                  [[(follow ?x ?y)
                    [?x :follow ?y]]])
        joined (vev.q report.db-after
                 [:find ?y ?x
                  :in $ %
                  :where
                  [_ _ ?x]
                  (rule ?x ?y)
                  [(= ?x 2)]]
                 [[(rule ?a ?b)
                   [?a :follow ?b]]])
        joined-even (vev.q report.db-after
                      [:find ?y ?x
                       :in $ %
                       :where
                       [_ _ ?x]
                       (rule ?x ?y)
                       [(even? ?x)]]
                      [[(rule ?a ?b)
                        [?a :follow ?b]]])
        isolated (vev.q-collection report.db-after
                   [:find [?x ...]
                    :in $ %
                    :where
                    [?e _ _]
                    (rule ?x)]
                   [[(rule ?e)
                     [_ ?e _]]])
        branches (vev.q-collection report.db-after
                   [:find [?e2 ...]
                    :in $ ?e1 %
                    :where
                    (follow ?e1 ?e2)]
                   1
                   [[(follow ?e2 ?e1)
                     [?e2 :follow ?e1]]
                    [(follow ?e2 ?e1)
                     [?e2 :follow ?t]
                     [?t :follow ?e1]]])
        recursive (vev.q-collection report.db-after
                    [:find [?e2 ...]
                     :in $ ?e1 %
                     :where
                     (follow ?e1 ?e2)]
                    1
                    [[(follow ?e1 ?e2)
                      [?e1 :follow ?e2]]
                     [(follow ?e1 ?e2)
                      [?e1 :follow ?t]
                      (follow ?t ?e2)]])
        rule-builtins (vev.q report.db-after
                        [:find ?x ?y
                         :in $ %
                         :where
                         (match ?x ?y)]
                        [[(match ?e ?e2)
                          [?e :follow ?e2]
                          [(even? ?e)]
                          [(even? ?e2)]]])
        rule-predicate-input (vev.q report.db-after
                               [:find ?x ?y
                                :in $ % ?even
                                :where
                                (match ?even ?x ?y)]
                               [[(match ?pred ?e ?e2)
                                 [?e :follow ?e2]
                                 [(?pred ?e)]
                                 [(?pred ?e2)]]]
                               :even?)
        rule-predicate-input-text (vev.q-text-with-rules
                                    report.db-after
                                    "[:find ?x ?y :in $ % ?even :where (match ?even ?x ?y)]"
                                    "[[(match ?pred ?e ?e2) [?e :follow ?e2] [(?pred ?e)] [(?pred ?e2)]]]"
                                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":even?"))]))]
    (t.is (= (count follows.rows) 6))
    (t.is (= follows.rows[0].values[0].entity 1))
    (t.is (= follows.rows[0].values[1].entity 2))
    (t.is (= follows.rows[5].values[0].entity 5))
    (t.is (= follows.rows[5].values[1].entity 3))
    (t.is (= (count joined.rows) 2))
    (t.is (= joined.rows[0].values[0].entity 3))
    (t.is (= joined.rows[0].values[1].entity 2))
    (t.is (= joined.rows[1].values[0].entity 4))
    (t.is (= joined.rows[1].values[1].entity 2))
    (t.is (= (count joined-even.rows) 3))
    (t.is (= joined-even.rows[0].values[0].entity 3))
    (t.is (= joined-even.rows[0].values[1].entity 2))
    (t.is (= joined-even.rows[1].values[0].entity 4))
    (t.is (= joined-even.rows[1].values[1].entity 2))
    (t.is (= joined-even.rows[2].values[0].entity 6))
    (t.is (= joined-even.rows[2].values[1].entity 4))
    (t.is (vev.value-exists? (slice isolated 0) (vev.value-keyword ":follow")))
    (t.is (= (count branches) 3))
    (t.is (= branches[0].entity 2))
    (t.is (= branches[1].entity 3))
    (t.is (= branches[2].entity 4))
    (t.is (= (count recursive) 4))
    (t.is (= recursive[0].entity 2))
    (t.is (= recursive[1].entity 3))
    (t.is (= recursive[2].entity 4))
    (t.is (= recursive[3].entity 6))
    (t.is (= (count rule-builtins.rows) 2))
    (t.is (= rule-builtins.rows[0].values[0].entity 2))
    (t.is (= rule-builtins.rows[0].values[1].entity 4))
    (t.is (= rule-builtins.rows[1].values[0].entity 4))
    (t.is (= rule-builtins.rows[1].values[1].entity 6))
    (t.is (= (count rule-predicate-input.rows) 2))
    (t.is (= rule-predicate-input.rows[0].values[0].entity 2))
    (t.is (= rule-predicate-input.rows[0].values[1].entity 4))
    (t.is (= rule-predicate-input.rows[1].values[0].entity 4))
    (t.is (= rule-predicate-input.rows[1].values[1].entity 6))
    (t.is (= (count rule-predicate-input-text.rows) 2))
    (t.is (= rule-predicate-input-text.rows[0].values[0].entity 2))
    (t.is (= rule-predicate-input-text.rows[0].values[1].entity 4))
    (t.is (= rule-predicate-input-text.rows[1].values[0].entity 4))
    (t.is (= rule-predicate-input-text.rows[1].values[1].entity 6))))

(t.deftest datascript-query-mutual-recursive-rules-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 0 :f1 (vev.value-entity 1)]
                  [:db/add 1 :f2 (vev.value-entity 2)]
                  [:db/add 2 :f1 (vev.value-entity 3)]
                  [:db/add 3 :f2 (vev.value-entity 4)]
                  [:db/add 4 :f1 (vev.value-entity 5)]
                  [:db/add 5 :f2 (vev.value-entity 6)]])
        result (vev.q report.db-after
                 [:find ?e1 ?e2
                  :in $ %
                  :where
                  (f1 ?e1 ?e2)]
                 [[(f1 ?e1 ?e2)
                   [?e1 :f1 ?e2]]
                  [(f1 ?e1 ?e2)
                   [?t :f1 ?e2]
                   (f2 ?e1 ?t)]
                  [(f2 ?e1 ?e2)
                   [?e1 :f2 ?e2]]
                  [(f2 ?e1 ?e2)
                   [?t :f2 ?e2]
                   (f1 ?e1 ?t)]])]
    (t.is (= (count result.rows) 9))
    (t.is (result-has-entity-pair? result 0 1))
    (t.is (result-has-entity-pair? result 0 3))
    (t.is (result-has-entity-pair? result 0 5))
    (t.is (result-has-entity-pair? result 1 3))
    (t.is (result-has-entity-pair? result 1 5))
    (t.is (result-has-entity-pair? result 2 3))
    (t.is (result-has-entity-pair? result 2 5))
    (t.is (result-has-entity-pair? result 3 5))
    (t.is (result-has-entity-pair? result 4 5))))

(t.deftest datascript-query-recursive-rules-reach-fixpoint-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]
             [:db/add 3 :follow (vev.value-entity 4)]
             [:db/add 4 :follow (vev.value-entity 5)]
             [:db/add 5 :follow (vev.value-entity 6)]
             [:db/add 6 :follow (vev.value-entity 7)]
             [:db/add 7 :follow (vev.value-entity 8)]
             [:db/add 8 :follow (vev.value-entity 9)]
             [:db/add 9 :follow (vev.value-entity 10)]
             [:db/add 10 :follow (vev.value-entity 11)]
             [:db/add 11 :follow (vev.value-entity 12)]
             [:db/add 12 :follow (vev.value-entity 13)]
             [:db/add 13 :follow (vev.value-entity 14)]
             [:db/add 14 :follow (vev.value-entity 15)]
             [:db/add 15 :follow (vev.value-entity 16)]
             [:db/add 16 :follow (vev.value-entity 17)]
             [:db/add 17 :follow (vev.value-entity 18)]
             [:db/add 18 :follow (vev.value-entity 19)]
             [:db/add 19 :follow (vev.value-entity 20)]
             [:db/add 20 :follow (vev.value-entity 21)]
             [:db/add 21 :follow (vev.value-entity 22)]])
        reachable (vev.q-collection conn.db
                    [:find [?e2 ...]
                     :in $ ?e1 %
                     :where
                     (follow ?e1 ?e2)]
                    1
                    [[(follow ?e1 ?e2)
                      [?e1 :follow ?e2]]
                     [(follow ?e1 ?e2)
                      [?e1 :follow ?t]
                      (follow ?t ?e2)]])]
    (t.is (= (count reachable) 21))
    (t.is (= reachable[0].entity 2))
    (t.is (= reachable[15].entity 17))
    (t.is (= reachable[20].entity 22))))

(t.deftest datascript-query-symmetric-recursive-rules-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :follow]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]])
        result (vev.q conn.db
                 [:find ?e1 ?e2
                  :in $ %
                  :where
                  (follow ?e1 ?e2)]
                 [[(follow ?e1 ?e2)
                   [?e1 :follow ?e2]]
                  [(follow ?e1 ?e2)
                   (follow ?e2 ?e1)]])]
    (t.is (= (count result.rows) 4))
    (t.is (result-has-entity-pair? result 1 2))
    (t.is (result-has-entity-pair? result 2 3))
    (t.is (result-has-entity-pair? result 2 1))
    (t.is (result-has-entity-pair? result 3 2))))

(t.deftest datascript-query-calls-rule-twice-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :attr]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :attr "a"]
             [:db/add 1 :attr "b"]
             [:db/add 2 :attr "a"]])
        result (vev.q-collection conn.db
                 [:find [?p ...]
                  :in $ %
                  :where
                  (rule ?p "a")
                  (rule ?p "b")]
                 [[(rule ?p ?x)
                   [?p :attr ?x]]])]
    (t.is (= (count result) 1))
    (t.is (= result[0].entity 1))))

(t.deftest datascript-query-rules-false-arguments-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :attr true}
             {:db/id 2 :attr false}])
        true-result (vev.q-collection conn.db
                      [:find [?id ...]
                       :in $ %
                       :where
                       (is ?id true)]
                      [[(is ?id ?val)
                        [?id :attr ?val]]])
        false-result (vev.q-collection conn.db
                       [:find [?id ...]
                        :in $ %
                        :where
                        (is ?id false)]
                       [[(is ?id ?val)
                         [?id :attr ?val]]])]
    (t.is (= (count true-result) 1))
    (t.is (= true-result[0].entity 1))
    (t.is (= (count false-result) 1))
    (t.is (= false-result[0].entity 2))))

(t.deftest datascript-query-rules-source-arguments-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        result (vev.q conn.db
                 [:find ?n
                  :in $sexes $ages %
                  :where
                  ($sexes male ?n)
                  ($ages adult ?n)]
                 [["Ivan" :male] ["Darya" :female] ["Oleg" :male] ["Igor" :male]]
                 [["Ivan" 15] ["Oleg" 66] ["Darya" 32]]
                 [[(male ?x)
                   [?x :male]]
                  [(adult ?y)
                   [?y ?a]
                   [(>= ?a 18)]]])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Oleg"))))

(t.deftest datascript-query-rules-preserve-body-order-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada"}
             {:db/id 2 :name "Grace"}])
        ordered-literal (vev.q conn.db
                          [:find ?e
                           :in $ %
                           :where
                           (named-ada ?e)]
                          [[(named-ada ?e)
                            [?e :name ?name]
                            [(= ?name "Ada")]]])
        predicate-before-binding-literal (vev.q conn.db
                                           [:find ?e
                                            :in $ %
                                            :where
                                            (named-ada ?e)]
                                           [[(named-ada ?e)
                                             [(= ?name "Ada")]
                                             [?e :name ?name]]])
        ordered-text (vev.q-text-with-rules conn.db
                       "[:find ?e :in $ % :where (named-ada ?e)]"
                       "[[(named-ada ?e) [?e :name ?name] [(= ?name \"Ada\")]]]")
        predicate-before-binding-text (vev.q-text-with-rules conn.db
                                        "[:find ?e :in $ % :where (named-ada ?e)]"
                                        "[[(named-ada ?e) [(= ?name \"Ada\")] [?e :name ?name]]]")]
    (t.is (= (count ordered-literal.rows) 1))
    (t.is (= ordered-literal.rows[0].values[0].entity 1))
    (t.is (= (count predicate-before-binding-literal.rows) 0))
    (t.is (= (count ordered-text.rows) 1))
    (t.is (= ordered-text.rows[0].values[0].entity 1))
    (t.is (= (count predicate-before-binding-text.rows) 0))))

(t.deftest datascript-query-rules-validation-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada"}])
        unknown-rule (vev.q conn.db
                       [:find ?e
                        :in $ %
                        :where
                        (wat ?e)]
                       [])
        wrong-arity (vev.q conn.db
                      [:find ?e
                       :in $ %
                       :where
                       (named ?e "extra")]
                      [[(named ?e)
                        [?e :name]]])
        bad-param (vev.q conn.db
                    [:find ?e
                     :in $ %
                     :where
                     (named ?e)]
                    [[(named $e)
                      [$e :name]]])
        duplicate-param (vev.q conn.db
                          [:find ?e
                           :in $ %
                           :where
                           (named ?e)]
                          [[(named ?e ?e)
                            [?e :name]]])
        arity-mismatch (vev.q conn.db
                         [:find ?e
                          :in $ %
                          :where
                          (named ?e)]
                         [[(named [?e])
                           [?e :name]]
                          [(named ?e)
                           [?e :name]]])
        required-bound (vev.q conn.db
                         [:find ?name
                          :in $ %
                          :where
                          [?e :name]
                          (named ?e ?name)]
                         [[(named [?entity] ?name)
                           [?entity :name ?name]]])
        required-unbound (vev.q conn.db
                           [:find ?name
                            :in $ %
                            :where
                            (named ?e ?name)]
                           [[(named [?entity] ?name)
                             [?entity :name ?name]]])
        unknown-nested (vev.q conn.db
                         [:find ?e
                          :in $ %
                          :where
                          (outer ?e)]
                         [[(outer ?e)
                           (inner ?e)]])
        unknown-text (vev.q-text-with-rules conn.db
                       "[:find ?e :in $ % :where (wat ?e)]"
                       "[]")
        bad-param-text (vev.q-text-with-rules conn.db
                         "[:find ?e :in $ % :where (named ?e)]"
                         "[[(named $e) [$e :name]]]")
        required-text (vev.q-text-with-rules conn.db
                        "[:find ?name :in $ % :where [?e :name] (named ?e ?name)]"
                        "[[(named [?entity] ?name) [?entity :name ?name]]]")
        required-text-unbound (vev.q-text-with-rules conn.db
                                "[:find ?name :in $ % :where (named ?e ?name)]"
                                "[[(named [?entity] ?name) [?entity :name ?name]]]")
        duplicate-text (vev.q-text-with-rules conn.db
                         "[:find ?e :in $ % :where (named ?e)]"
                         "[[(named [?e] ?e) [?e :name]]]")
        mismatch-text (vev.q-text-with-rules conn.db
                        "[:find ?e :in $ % :where (named ?e)]"
                        "[[(named [?e]) [?e :name]] [(named ?e) [?e :name]]]")
        empty-branch-text (vev.q-text-with-rules conn.db
                            "[:find ?e :in $ % :where (named ?e)]"
                            "[[(named ?e)]]")
        empty-required-text (vev.q-text-with-rules conn.db
                              "[:find ?e :in $ % :where (named ?e)]"
                              "[[(named []) [_]]]")
        duplicate-plain-text (vev.q-text-with-rules conn.db
                               "[:find ?e :in $ % :where (named ?e)]"
                               "[[(named ?e ?name ?e) [?e :name ?name]]]")
        arity-mismatch-required-text (vev.q-text-with-rules conn.db
                                       "[:find ?e :in $ % :where (named ?e)]"
                                       "[[(named ?e) [?e :name]] [(named [?e]) [?e :name]]]")]
    (t.is (not unknown-rule.ok))
    (t.is (= unknown-rule.error "unknown rule: wat"))
    (t.is (not wrong-arity.ok))
    (t.is (= wrong-arity.error "wrong arity for rule: named"))
    (t.is (not bad-param.ok))
    (t.is (= bad-param.error "rule params must be variables: $e"))
    (t.is (not duplicate-param.ok))
    (t.is (= duplicate-param.error "Rule variables should be distinct"))
    (t.is (not arity-mismatch.ok))
    (t.is (= arity-mismatch.error "Arity mismatch for rule: named"))
    (t.is required-bound.ok)
    (t.is (= (count required-bound.rows) 1))
    (t.is (= required-bound.rows[0].values[0].text "Ada"))
    (t.is (not required-unbound.ok))
    (t.is (= required-unbound.error "insufficient bindings for rule: ?e"))
    (t.is (not unknown-nested.ok))
    (t.is (= unknown-nested.error "unknown rule: inner"))
    (t.is (not unknown-text.ok))
    (t.is (= unknown-text.error "unknown rule: wat"))
    (t.is (not bad-param-text.ok))
    (t.is (= bad-param-text.error "rule params must be variables"))
    (t.is required-text.ok)
    (t.is (= (count required-text.rows) 1))
    (t.is (= required-text.rows[0].values[0].text "Ada"))
    (t.is (not required-text-unbound.ok))
    (t.is (= required-text-unbound.error "insufficient bindings for rule: ?e"))
    (t.is (not duplicate-text.ok))
    (t.is (= duplicate-text.error "Rule variables should be distinct"))
    (t.is (not mismatch-text.ok))
    (t.is (= mismatch-text.error "Arity mismatch for rule: named"))
    (t.is (not empty-branch-text.ok))
    (t.is (= empty-branch-text.error "Rule branch should have clauses"))
    (t.is (not empty-required-text.ok))
    (t.is (= empty-required-text.error "Cannot parse rule-vars"))
    (t.is (not duplicate-plain-text.ok))
    (t.is (= duplicate-plain-text.error "Rule variables should be distinct"))
    (t.is (not arity-mismatch-required-text.ok))
    (t.is (= arity-mismatch-required-text.error "Arity mismatch for rule: named"))))

(t.deftest datalog-macro-supports-or-join
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?label
                  :where
                  [?e :user/name ?name]
                  (or-join [?e ?label]
                    (and [?e :user/active true]
                         [?e :user/name ?label])
                    (and [?e :user/active false]
                         [?e :user/email ?label]))])]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].text "Ada"))
    (t.is (= result.rows[1].values[0].text "grace@example.com"))))

(t.deftest datascript-query-or-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 10}
                  {:db/id 2 :name "Ivan" :age 20}
                  {:db/id 3 :name "Oleg" :age 10}
                  {:db/id 4 :name "Oleg" :age 20}
                  {:db/id 5 :name "Ivan" :age 10}
                  {:db/id 6 :name "Ivan" :age 20}])
        intersecting (vev.q-collection report.db-after
                       [:find [?e ...]
                        :where
                        (or [?e :name "Oleg"]
                            [?e :age 10])])
        one-empty (vev.q-collection report.db-after
                    [:find [?e ...]
                     :where
                     (or [?e :name "Oleg"]
                         [?e :age 30])])
        both-empty (vev.q-collection report.db-after
                     [:find [?e ...]
                      :where
                      (or [?e :name "Petr"]
                          [?e :age 30])])
        join-one-var (vev.q-collection report.db-after
                       [:find [?e ...]
                        :where
                        [?e :name "Ivan"]
                        (or [?e :name "Oleg"]
                            [?e :age 10])])
        join-two-vars (vev.q-collection report.db-after
                        [:find [?e ...]
                         :where
                         [?e :age ?a]
                         (or (and [?e :name "Ivan"]
                                  [1 :age ?a])
                             (and [?e :name "Oleg"]
                                  [2 :age ?a]))])
        introduces-vars (vev.q-collection report.db-after
                          [:find [?e ...]
                           :where
                           (or (and [?e :name "Ivan"]
                                    [1 :age ?a])
                               (and [?e :name "Oleg"]
                                    [2 :age ?a]))
                           [?e :age ?a]])
        introduces-vars-different-order (vev.q-collection report.db-after
                                          [:find [?e ...]
                                           :where
                                           (or (and [?e :name "Ivan"]
                                                    [1 :age ?a])
                                               (and [2 :age ?a]
                                                    [?e :name "Oleg"]))
                                           [?e :age ?a]])
        short-circuit-resolution (vev.q-collection report.db-after
                                   [:find [?e ...]
                                    :where
                                    (or (and [?e :age 30]
                                             [?e :name ?n])
                                        (and [?e :age 20]
                                             [?e :name ?n]))
                                    [(ground "Ivan") ?n]])
        or-join (vev.q-collection report.db-after
                  [:find [?e ...]
                   :where
                   (or-join [?e]
                     [?e :name ?n]
                     (and [?e :age ?a]
                          [?e :name ?n]))])
        input-or (vev.q-collection report.db-after
                   [:find [?e ...]
                    :in ?age
                    :where
                    (or [?e :age ?age]
                        [?e :name "Oleg"])]
                   10)
        input-or-join (vev.q-collection report.db-after
                        [:find [?e ...]
                         :in ?age
                         :where
                         (or-join [?e ?age]
                           [?e :age ?age]
                           [?e :name "Oleg"])]
                        10)
        nested-input-or-join (vev.q-collection report.db-after
                               [:find [?e ...]
                                :in ?age
                                :where
                                (or-join [[?age] ?e]
                                  [?e :age ?age]
                                  [?e :name "Oleg"])]
                               10)
        nested-text-or-join (vev.q-text-with-inputs
                              report.db-after
                              "[:find ?e :in ?age :where (or-join [[?age] ?e] [?e :age ?age] [?e :name \"Oleg\"])]"
                              ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 10))]))]
    (t.is (= (count intersecting) 4))
    (t.is (= intersecting[0].entity 3))
    (t.is (= intersecting[1].entity 4))
    (t.is (= intersecting[2].entity 1))
    (t.is (= intersecting[3].entity 5))
    (t.is (= (count one-empty) 2))
    (t.is (= one-empty[0].entity 3))
    (t.is (= one-empty[1].entity 4))
    (t.is (= (count both-empty) 0))
    (t.is (= (count join-one-var) 2))
    (t.is (= join-one-var[0].entity 1))
    (t.is (= join-one-var[1].entity 5))
    (t.is (= (count join-two-vars) 3))
    (t.is (values-has-entity? (slice join-two-vars 0) 1))
    (t.is (values-has-entity? (slice join-two-vars 0) 4))
    (t.is (values-has-entity? (slice join-two-vars 0) 5))
    (t.is (= (count introduces-vars) 3))
    (t.is (values-has-entity? (slice introduces-vars 0) 1))
    (t.is (values-has-entity? (slice introduces-vars 0) 4))
    (t.is (values-has-entity? (slice introduces-vars 0) 5))
    (t.is (= (count introduces-vars-different-order) 3))
    (t.is (values-has-entity? (slice introduces-vars-different-order 0) 1))
    (t.is (values-has-entity? (slice introduces-vars-different-order 0) 4))
    (t.is (values-has-entity? (slice introduces-vars-different-order 0) 5))
    (t.is (= (count short-circuit-resolution) 2))
    (t.is (= short-circuit-resolution[0].entity 2))
    (t.is (= short-circuit-resolution[1].entity 6))
    (t.is (= (count or-join) 6))
    (t.is (= or-join[0].entity 1))
    (t.is (= or-join[5].entity 6))
    (t.is (= (count input-or) 4))
    (t.is (= input-or[0].entity 1))
    (t.is (= input-or[1].entity 3))
    (t.is (= input-or[2].entity 5))
    (t.is (= input-or[3].entity 4))
    (t.is (= (count input-or-join) 4))
    (t.is (= input-or-join[0].entity 1))
    (t.is (= input-or-join[1].entity 3))
    (t.is (= input-or-join[2].entity 5))
    (t.is (= input-or-join[3].entity 4))
    (t.is (= (count nested-input-or-join) 4))
    (t.is (values-has-entity? (slice nested-input-or-join 0) 1))
    (t.is (values-has-entity? (slice nested-input-or-join 0) 3))
    (t.is (values-has-entity? (slice nested-input-or-join 0) 4))
    (t.is (values-has-entity? (slice nested-input-or-join 0) 5))
    (t.is (= (count nested-text-or-join.rows) 4))
    (t.is (result-has-entity? nested-text-or-join 1))
    (t.is (result-has-entity? nested-text-or-join 3))
    (t.is (result-has-entity? nested-text-or-join 4))
    (t.is (result-has-entity? nested-text-or-join 5))))

(t.deftest datascript-query-relation-source-or-join-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source (vev.q conn.db
                 [:find ?a ?b ?c
                  :in $xs
                  :where
                  [$xs ?a ?b ?c]]
                 [[:a1 :b1 :c1]
                  [:a2 :b2 :c2]])
        joined (vev.q conn.db
                 [:find ?a ?b ?c
                  :in $xs $ys
                  :where
                  [$xs ?a ?b ?c]
                  (or-join [?a]
                    [$ys ?a ?b ?d])]
                 [[:a1 :b1 :c1]
                  [:a2 :b2 :c2]
                  [:a3 :b3 :c3]]
                 [[:a1 :b1 :d1]
                  [:a2 :b2* :d2]
                  [:a4 :b4 :d4]])
        generic-source (vev.q conn.db
                         [:find ?person ?age
                          :in $people
                          :where
                          [$people ?person ?age]]
                         [[:ada 37]
                          [:grace 41]])
        mixed-width (vev.q conn.db
                      [:find ?a ?c
                       :in $xs $ys
                       :where
                       (or-join [?a ?c]
                         [$xs ?a ?b ?c]
                         [$ys ?a ?c])]
                      [[:a1 :b1 :c1]]
                      [[:a2 :c2]])]
    (t.is (= (count source.rows) 2))
    (t.is (= source.rows[0].values[0].text ":a1"))
    (t.is (= source.rows[0].values[1].text ":b1"))
    (t.is (= source.rows[0].values[2].text ":c1"))
    (t.is (= (count joined.rows) 2))
    (t.is (= joined.rows[0].values[0].text ":a1"))
    (t.is (= joined.rows[0].values[1].text ":b1"))
    (t.is (= joined.rows[0].values[2].text ":c1"))
    (t.is (= joined.rows[1].values[0].text ":a2"))
    (t.is (= joined.rows[1].values[1].text ":b2"))
    (t.is (= joined.rows[1].values[2].text ":c2"))
    (t.is (= (count generic-source.rows) 2))
    (t.is (= generic-source.rows[0].values[0].text ":ada"))
    (t.is (= generic-source.rows[0].values[1].int-value 37))
    (t.is (= generic-source.rows[1].values[0].text ":grace"))
    (t.is (= generic-source.rows[1].values[1].int-value 41))
    (t.is (= (count mixed-width.rows) 2))
    (t.is (= mixed-width.rows[0].values[0].text ":a1"))
    (t.is (= mixed-width.rows[0].values[1].text ":c1"))
    (t.is (= mixed-width.rows[1].values[0].text ":a2"))
    (t.is (= mixed-width.rows[1].values[1].text ":c2"))))

(t.deftest datascript-query-source-prefixed-not-or-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        source-not (vev.q-collection conn.db
                     [:find [?e ...]
                      :in $names $ages
                      :where
                      [$names ?e :name]
                      ($ages not [?e :age 10])]
                     [[1 :name]
                      [2 :name]]
                     [[1 :age 10]
                      [2 :age 20]])
        source-or (vev.q-collection conn.db
                    [:find [?e ...]
                     :in $names $ages
                     :where
                     [$names ?e :name]
                     ($ages or [?e :age 10])]
                    [[1 :name]
                     [2 :name]]
                    [[1 :age 10]
                     [2 :age 20]])
        source-or-and (vev.q-collection conn.db
                        [:find [?e ...]
                         :in $names $ages
                         :where
                         [$names ?e :name]
                         ($ages or (and [?e :age ?age]
                                        [1 :age ?age]))]
                        [[1 :name]
                         [2 :name]]
                        [[1 :age 10]
                         [2 :age 20]])
        override-not (vev.q-collection conn.db
                       [:find [?e ...]
                        :in $names $ages
                        :where
                        [$names ?e :name ?name]
                        ($ages not [$names ?e :name "Ivan"])]
                       [[1 :name "Ivan"]
                        [2 :name "Oleg"]]
                       [[1 :age 10]
                        [2 :age 20]])
        override-or (vev.q-collection conn.db
                      [:find [?e ...]
                       :in $names $ages
                       :where
                       [$names ?e :name ?name]
                       ($ages or [$names ?e :name "Ivan"])]
                      [[1 :name "Ivan"]
                       [2 :name "Oleg"]]
                      [[1 :age 10]
                       [2 :age 20]])
        nested-not (vev.q-collection conn.db
                     [:find [?e ...]
                      :in $names $ages
                      :where
                      [$names ?e :name]
                      ($ages not (not [?e :age 10]))]
                     [[1 :name]
                      [2 :name]]
                     [[1 :age 10]
                      [2 :age 20]])
        nested-or (vev.q-collection conn.db
                    [:find [?e ...]
                     :in $names $ages
                     :where
                     [$names ?e :name]
                     ($ages or (or [?e :age 10]))]
                    [[1 :name]
                     [2 :name]]
                    [[1 :age 10]
                     [2 :age 20]])
        nested-override-not (vev.q-collection conn.db
                              [:find [?e ...]
                               :in $names $ages
                               :where
                               [$names ?e :name ?name]
                               ($ages not ($names not [?e :name "Ivan"]))]
                              [[1 :name "Ivan"]
                               [2 :name "Oleg"]]
                              [[1 :age 10]
                               [2 :age 20]])
        nested-or-two-branches (vev.q-collection conn.db
                                 [:find [?e ...]
                                  :in $names $ages
                                  :where
                                  [$names ?e :name]
                                  ($ages or (or [?e :age 10]
                                                [?e :age 20]))]
                                 [[1 :name]
                                  [2 :name]]
                                 [[1 :age 10]
                                  [2 :age 20]])
        nested-override-or (vev.q-collection conn.db
                             [:find [?e ...]
                              :in $names $ages
                              :where
                              [$names ?e :name ?name]
                              ($ages or ($names or [?e :name "Ivan"]))]
                             [[1 :name "Ivan"]
                              [2 :name "Oleg"]]
                             [[1 :age 10]
                              [2 :age 20]])]
    (t.is (= (count source-not) 1))
    (t.is (= source-not[0].int-value 2))
    (t.is (= (count source-or) 1))
    (t.is (= source-or[0].int-value 1))
    (t.is (= (count source-or-and) 1))
    (t.is (= source-or-and[0].int-value 1))
    (t.is (= (count override-not) 1))
    (t.is (= override-not[0].int-value 2))
    (t.is (= (count override-or) 1))
    (t.is (= override-or[0].int-value 1))
    (t.is (= (count nested-not) 1))
    (t.is (= nested-not[0].int-value 1))
    (t.is (= (count nested-or) 1))
    (t.is (= nested-or[0].int-value 1))
    (t.is (= (count nested-override-not) 1))
    (t.is (= nested-override-not[0].int-value 1))
    (t.is (= (count nested-or-two-branches) 2))
    (t.is (= nested-or-two-branches[0].int-value 1))
    (t.is (= nested-or-two-branches[1].int-value 2))
    (t.is (= (count nested-override-or) 1))
    (t.is (= nested-override-or[0].int-value 1))))

(t.deftest datascript-query-db-source-prefixed-not-or-subset
  (defer (free_all context.allocator))
  (let [names (vev.create-conn)
        ages (vev.create-conn)
        _ (vev.transact
            (addr names)
            [[:db/add 1 :name "Ivan"]
             [:db/add 2 :name "Oleg"]])
        _ (vev.transact
            (addr ages)
            [[:db/add 1 :age 10]
             [:db/add 2 :age 20]])
        not-explicit (vev.q-collection names.db
                       [:find [?e ...]
                        :in $ $2
                        :where
                        [?e :name]
                        (not [$2 ?e :age 10])]
                       ages.db)
        not-default (vev.q-collection names.db
                      [:find [?e ...]
                       :in $ $2
                       :where
                       [?e :name]
                       ($2 not [?e :age 10])]
                      ages.db)
        not-override (vev.q-collection names.db
                       [:find [?e ...]
                        :in $ $2
                        :where
                        [?e :name]
                        ($2 not [$ ?e :name "Ivan"])]
                       ages.db)
        not-nested (vev.q-collection names.db
                     [:find [?e ...]
                      :in $ $2
                      :where
                      [?e :name]
                      ($2 not (not [?e :age 10]))]
                     ages.db)
        or-explicit (vev.q-collection names.db
                     [:find [?e ...]
                      :in $ $2
                      :where
                      [?e :name]
                      (or [$2 ?e :age 10])]
                     ages.db)
        or-default (vev.q-collection names.db
                    [:find [?e ...]
                     :in $ $2
                     :where
                     [?e :name]
                     ($2 or [?e :age 10])]
                    ages.db)
        or-override (vev.q-collection names.db
                     [:find [?e ...]
                      :in $ $2
                      :where
                      [?e :name]
                      ($2 or [$ ?e :name "Ivan"])]
                     ages.db)
        or-nested (vev.q-collection names.db
                   [:find [?e ...]
                    :in $ $2
                    :where
                    [?e :name]
                    ($2 or (or [?e :age 10]))]
                   ages.db)]
    (t.is (= (count not-explicit) 1))
    (t.is (= not-explicit[0].entity 2))
    (t.is (= (count not-default) 1))
    (t.is (= not-default[0].entity 2))
    (t.is (= (count not-override) 1))
    (t.is (= not-override[0].entity 2))
    (t.is (= (count not-nested) 1))
    (t.is (= not-nested[0].entity 1))
    (t.is (= (count or-explicit) 1))
    (t.is (= or-explicit[0].entity 1))
    (t.is (= (count or-default) 1))
    (t.is (= or-default[0].entity 1))
    (t.is (= (count or-override) 1))
    (t.is (= or-override[0].entity 1))
    (t.is (= (count or-nested) 1))
    (t.is (= or-nested[0].entity 1))))

(t.deftest datalog-macro-supports-find-pull
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
