(t.deftest datalog-macro-supports-not-join
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?name
                  :where
                  [?e :user/name ?name]
                  (not-join [?e]
                    [?e :user/friend ?friend]
                    [?friend :user/name ?name])])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Grace"))))

(t.deftest datascript-query-not-explicit-source-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
