                 [{:db/id 100 :db/ident :value :db/cardinality :db.cardinality/many}
                  {:db/id 1 :name "Petr" :value [10 20 30 40]}
                  {:db/id 2 :name "Ivan" :value [14 16]}
                  {:db/id 3 :name "Oleg" :value 1}])
        result (vev.q report.db-after
                 [:find ?e (pull ?e [:name]) (min ?v) (max ?v)
                  :where
                  [?e :value ?v]])]
    (t.is (= (count result.rows) 3))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= result.rows[0].values[1].int-value 10))
    (t.is (= result.rows[0].values[2].int-value 40))
    (t.is (= result.rows[1].values[0].entity 2))
    (t.is (= result.rows[1].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= result.rows[1].values[1].int-value 14))
    (t.is (= result.rows[1].values[2].int-value 16))
    (t.is (= result.rows[2].values[0].entity 3))
    (t.is (= result.rows[2].pulls[0].attrs[0].v.text "Oleg"))
    (t.is (= result.rows[2].values[1].int-value 1))
    (t.is (= result.rows[2].values[2].int-value 1))))

