(t.deftest db-builds-all-datom-indexes
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        db report.db-after
        datom-count (count db.datoms)]
    (t.is (= (count db.current) datom-count))
    (t.is (= (count db.eavt) datom-count))
    (t.is (= (count db.aevt) datom-count))
    (t.is (= (count db.avet) datom-count))
    (t.is (= (count db.vaet) datom-count))
    (t.is (= db.datoms[db.eavt[0]].e 1))
    (t.is (= db.datoms[db.aevt[0]].a ":user/active"))
    (t.is (= db.datoms[db.avet[0]].a ":user/active"))
    (t.is (= db.datoms[db.vaet[0]].v.kind .Entity))))

(t.deftest datascript-db-diff-subset
  (defer (free_all context.allocator))
  (let [left-conn (vev.create-conn)
        _ (vev.transact (addr left-conn) [
             {:db/id 1 :a 1 :b 2 :c 4}
             {:db/id 2 :a 1}])
        right-conn (vev.create-conn)
        _ (vev.transact (addr right-conn) [{:db/id 1 :b 3 :d 5}])
        _ (vev.transact (addr right-conn) [{:db/id 1 :a 1}])
        diff (vev.db-diff left-conn.db right-conn.db)]
    (t.is (= (count diff.only-left) 3))
    (t.is (= diff.only-left[0].e 1))
    (t.is (= diff.only-left[0].a ":b"))
    (t.is (= diff.only-left[0].v.int-value 2))
    (t.is (= diff.only-left[1].a ":c"))
    (t.is (= diff.only-left[1].v.int-value 4))
    (t.is (= diff.only-left[2].e 2))
    (t.is (= diff.only-left[2].a ":a"))
    (t.is (= diff.only-left[2].v.int-value 1))
    (t.is (= (count diff.only-right) 2))
    (t.is (= diff.only-right[0].a ":b"))
    (t.is (= diff.only-right[0].v.int-value 3))
    (t.is (= diff.only-right[1].a ":d"))
    (t.is (= diff.only-right[1].v.int-value 5))
    (t.is (= (count diff.both) 1))
    (t.is (= diff.both[0].e 1))
    (t.is (= diff.both[0].a ":a"))
    (t.is (= diff.both[0].v.int-value 1))))

(t.deftest datascript-issues-regressions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact (addr conn) [{:attr "A"} {:attr "B"}])
        vector-result (vev.q conn.db
                        [:find ?a ?b
                         :where
                         [_ :attr ?a]
                         [(vector ?a) ?b]])
        left-conn (vev.create-conn)
        _ (vev.transact (addr left-conn) [[:db/add 1 :attr :aa]])
        right-conn (vev.create-conn)
        _ (vev.transact (addr right-conn) [[:db/add 1 :attr "aa"]])
        diff (vev.db-diff left-conn.db right-conn.db)]
    (t.is (= (count vector-result.rows) 2))
    (t.is (= vector-result.rows[0].values[0].text "A"))
    (t.is (= vector-result.rows[0].values[1].kind .Vector))
    (t.is (= vector-result.rows[0].values[1].items[0].text "A"))
    (t.is (= vector-result.rows[1].values[0].text "B"))
    (t.is (= vector-result.rows[1].values[1].kind .Vector))
    (t.is (= vector-result.rows[1].values[1].items[0].text "B"))
    (t.is (= (count diff.only-left) 1))
    (t.is (= diff.only-left[0].a ":attr"))
    (t.is (= diff.only-left[0].v.kind .Keyword))
    (t.is (= diff.only-left[0].v.text ":aa"))
    (t.is (= (count diff.only-right) 1))
    (t.is (= diff.only-right[0].a ":attr"))
    (t.is (= diff.only-right[0].v.kind .String))
    (t.is (= diff.only-right[0].v.text "aa"))
    (t.is (= (count diff.both) 0))))

(t.deftest datascript-filter-db-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 10 :db/ident :aka :db/cardinality :db.cardinality/many}
             {:db/id 1 :name "Petr" :email "petya@spb.ru" :aka ["I" "Great"] :password "<SECRET>"}
             {:db/id 2 :name "Ivan" :aka ["Terrible" "IV"] :password "<PROTECTED>"}
             {:db/id 3 :name "Nikolai" :aka ["II"] :password "<UNKNOWN>"}])
        db conn.db
        no-passwords (vev.filter-db db keep-not-password)
        no-ivan (vev.filter-db db keep-not-entity-2)
        long-akas (vev.filter-db db keep-long-akas)
        no-ivan-no-passwords (vev.filter-db no-ivan keep-not-password)
        no-ivan-long-akas (vev.filter-db no-ivan keep-long-akas)
        long-akas-no-ivan (vev.filter-db long-akas keep-not-entity-2)
        empty-conn (vev.create-conn)
        empty-filtered (vev.filter-db empty-conn.db keep-all)
        all-filtered-out (vev.filter-db db keep-none)
        retracted-ivan-conn (vev.conn-from-db db)
        retracted-ivan (vev.transact (addr retracted-ivan-conn) [[:db.fn/retractEntity 2]])
        no-ivan-diff (vev.db-diff no-ivan retracted-ivan.db-after)
        empty-diff (vev.db-diff empty-conn.db empty-filtered)
        none-diff (vev.db-diff empty-conn.db all-filtered-out)
        passwords (vev.q-collection db [:find [?v ...] :where [_ :password ?v]])
        passwords-filtered (vev.q-collection no-passwords [:find [?v ...] :where [_ :password ?v]])
        passwords-no-ivan (vev.q-collection no-ivan [:find [?v ...] :where [_ :password ?v]])
        passwords-chained (vev.q-collection no-ivan-no-passwords [:find [?v ...] :where [_ :password ?v]])
        akas (vev.q-collection db [:find [?v ...] :where [_ :aka ?v]])
        akas-no-passwords (vev.q-collection no-passwords [:find [?v ...] :where [_ :aka ?v]])
        akas-no-ivan (vev.q-collection no-ivan [:find [?v ...] :where [_ :aka ?v]])
        akas-long (vev.q-collection long-akas [:find [?v ...] :where [_ :aka ?v]])
        akas-no-ivan-long (vev.q-collection no-ivan-long-akas [:find [?v ...] :where [_ :aka ?v]])
        akas-long-no-ivan (vev.q-collection long-akas-no-ivan [:find [?v ...] :where [_ :aka ?v]])
        petr-filtered (vev.db-entity no-passwords 1)
        ivan-filtered (vev.db-entity long-akas 2)
        ivan-akas (vev.entity-values ivan-filtered ":aka")
        password-index (vev.datoms db :aevt :password)
        password-index-filtered (vev.datoms no-passwords :aevt :password)]
    (defer (delete ivan-akas))
    (t.is (= (count passwords) 3))
    (t.is (= (count passwords-filtered) 0))
    (t.is (= (count passwords-no-ivan) 2))
    (t.is (= passwords-no-ivan[0].text "<SECRET>"))
    (t.is (= passwords-no-ivan[1].text "<UNKNOWN>"))
    (t.is (= (count passwords-chained) 0))
    (t.is (= (count akas) 5))
    (t.is (= (count akas-no-passwords) 5))
    (t.is (= (count akas-no-ivan) 3))
    (t.is (= (count akas-long) 3))
    (t.is (= akas-long[0].text "Great"))
    (t.is (= akas-long[1].text "Terrible"))
    (t.is (= akas-long[2].text "II"))
    (t.is (= (count akas-no-ivan-long) 2))
    (t.is (= akas-no-ivan-long[0].text "Great"))
    (t.is (= akas-no-ivan-long[1].text "II"))
    (t.is (= (count akas-long-no-ivan) 2))
    (t.is (= akas-long-no-ivan[0].text "Great"))
    (t.is (= akas-long-no-ivan[1].text "II"))
    (t.is (not (vev.entity-contains? petr-filtered ":password")))
    (t.is (= (count ivan-akas) 1))
    (t.is (= ivan-akas[0].text "Terrible"))
    (t.is (= (count password-index) 3))
    (t.is (= password-index[0].v.text "<SECRET>"))
    (t.is (= password-index[1].v.text "<PROTECTED>"))
    (t.is (= password-index[2].v.text "<UNKNOWN>"))
    (t.is (= (count password-index-filtered) 0))
    (t.is retracted-ivan.ok)
    (t.is (= (count no-ivan-diff.only-left) 0))
    (t.is (= (count no-ivan-diff.only-right) 0))
    (t.is (= (count empty-diff.only-left) 0))
    (t.is (= (count empty-diff.only-right) 0))
    (t.is (= (count none-diff.only-left) 0))
    (t.is (= (count none-diff.only-right) 0))))

(t.deftest datascript-filter-db-double-filtering-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Petr" :age 32}
             {:db/id 2 :name "Oleg"}
             {:db/id 3 :name "Ivan" :age 12}])
        has-age (vev.filter-db conn.db keep-has-age)
        adults (vev.filter-db has-age keep-adult)
        names (vev.q-collection conn.db [:find [?name ...] :where [_ :name ?name]])
        names-with-age (vev.q-collection has-age [:find [?name ...] :where [_ :name ?name]])
        adult-names (vev.q-collection adults [:find [?name ...] :where [_ :name ?name]])]
    (t.is (= (count names) 3))
    (t.is (= names[0].text "Petr"))
    (t.is (= names[1].text "Oleg"))
    (t.is (= names[2].text "Ivan"))
    (t.is (= (count names-with-age) 2))
    (t.is (= names-with-age[0].text "Petr"))
    (t.is (= names-with-age[1].text "Ivan"))
    (t.is (= (count adult-names) 1))
    (t.is (= adult-names[0].text "Petr"))))

(t.deftest datascript-init-db-and-conn-from-datoms-subset
  (defer (free_all context.allocator))
  (let [datoms ([]vev.Datom
                 [(vev.datom-tx 1 ":age" (vev.value-int 17) 3 true)
                  (vev.datom-tx 1 ":name" (vev.value-string "Ivan") 3 true)
                  (vev.datom-tx 1 ":age" (vev.value-int 15) 2 false)])
        db (vev.init-db datoms)
        conn (vev.conn-from-db db)
        conn2 (vev.conn-from-datoms datoms)
        ages (vev.q-collection db
               [:find [?age ...]
                :where
                [1 :age ?age]])
        names (vev.q-collection conn.db
                [:find [?name ...]
                 :where
                 [1 :name ?name]])
        names2 (vev.q-collection conn2.db
                 [:find [?name ...]
                  :where
                  [1 :name ?name]])]
    (t.is (= (count db.current) 2))
    (t.is (= (count ages) 1))
    (t.is (= ages[0].int-value 17))
    (t.is (= conn.next-tx 4))
    (t.is (= conn2.next-tx 4))
    (t.is (= (count names) 1))
    (t.is (= names[0].text "Ivan"))
    (t.is (= (count names2) 1))
    (t.is (= names2[0].text "Ivan"))))

(t.deftest datascript-pure-db-with-tx-data-subset
  (defer (free_all context.allocator))
  (let [empty (vev.init-db ([]vev.Datom []))
        first (vev.with-tx-data
                empty
                ([]vev.Tx-Data
                  [(vev.add 100 ":db/ident" (vev.value-keyword ":aka"))
                   (vev.add 100 ":db/cardinality" (vev.value-keyword ":db.cardinality/many"))
                   (vev.add 1 ":name" (vev.value-string "Ivan"))]))
        original-names (vev.q-collection empty
                         [:find [?name ...]
                          :where
                          [1 :name ?name]])
        first-names (vev.q-collection first.db-after
                      [:find [?name ...]
                       :where
                       [1 :name ?name]])
        second-db (vev.db-with-tx-data
                    first.db-after
                    ([]vev.Tx-Data
                      [(vev.add 1 ":name" (vev.value-string "Petr"))
                       (vev.add 1 ":aka" (vev.value-string "Devil"))
                       (vev.add 1 ":aka" (vev.value-string "Tupen"))]))
        second-name (vev.q-collection second-db
                      [:find [?name ...]
                       :where
                       [1 :name ?name]])
        second-aka (vev.q-collection second-db
                    [:find [?aka ...]
                     :where
                     [1 :aka ?aka]])
        failed (vev.with-tx-data
                 second-db
                 ([]vev.Tx-Data
                   [(vev.Tx-Data {op: ":db/nope" e: 1 a: ":name" v: (vev.value-string "Bad")})]))
        after-failed (vev.q-collection failed.db-after
                       [:find [?name ...]
                        :where
                        [1 :name ?name]])
        text-report (vev.with-text
                      second-db
                      "[[:db/add 2 :name \"Ada\"] [:db/add 2 :aka \"Countess\"]]")
        prepared (vev.prepare-tx-text "[[:db/add 3 :name \"Grace\"]]")
        prepared-report (vev.with-prepared text-report.db-after prepared)
        db-with-text (vev.db-with-text second-db "[[:db/add 4 :name \"Lin\"]]")
        db-with-prepared (vev.db-with-prepared db-with-text (vev.prepare-tx-text "[[:db/add 5 :name \"Mina\"]]"))
        db-with-map-text (vev.db-with-text second-db "[{:db/id 6 :name \"Barbara\"}]")
        bad-text (vev.with-text second-db "{:db/id 6 :name \"Bad Root\"}")
        original-ada (vev.q-collection second-db
                       [:find [?name ...]
                        :where
                        [2 :name ?name]])
        text-ada (vev.q-collection text-report.db-after
                   [:find [?name ...]
                    :where
                    [2 :name ?name]])
        prepared-grace (vev.q-collection prepared-report.db-after
                         [:find [?name ...]
                          :where
                          [3 :name ?name]])
        lin (vev.q-collection db-with-text
              [:find [?name ...]
               :where
               [4 :name ?name]])
        mina (vev.q-collection db-with-prepared
               [:find [?name ...]
                :where
                [5 :name ?name]])
        barbara (vev.q-collection db-with-map-text
                 [:find [?name ...]
                  :where
                  [6 :name ?name]])]
    (t.is first.ok)
    (t.is (= first.tx 1))
    (t.is (= (count original-names) 0))
    (t.is (= (count first-names) 1))
    (t.is (= first-names[0].text "Ivan"))
    (t.is (= (count second-name) 1))
    (t.is (= second-name[0].text "Petr"))
    (t.is (= (count second-aka) 2))
    (t.is (= second-aka[0].text "Devil"))
    (t.is (= second-aka[1].text "Tupen"))
    (t.is (not failed.ok))
    (t.is (= failed.error "unknown tx op"))
    (t.is (= (count after-failed) 1))
    (t.is (= after-failed[0].text "Petr"))
    (t.is text-report.ok)
    (t.is prepared.ok)
    (t.is prepared-report.ok)
    (t.is (= (count original-ada) 0))
    (t.is (= (count text-ada) 1))
    (t.is (= text-ada[0].text "Ada"))
    (t.is (= (count prepared-grace) 1))
    (t.is (= prepared-grace[0].text "Grace"))
    (t.is (= (count lin) 1))
    (t.is (= lin[0].text "Lin"))
    (t.is (= (count mina) 1))
    (t.is (= mina[0].text "Mina"))
    (t.is (= (count barbara) 1))
    (t.is (= barbara[0].text "Barbara"))
    (t.is (not bad-text.ok))
    (t.is (= (count bad-text.db-after.datoms) (count second-db.datoms)))))

(t.deftest datascript-db-with-datoms-preserves-tx-and-retractions-subset
  (defer (free_all context.allocator))
  (let [empty (vev.init-db ([]vev.Datom []))
        db (vev.db-with-datoms
             empty
             ([]vev.Datom
               [(vev.datom-tx 1 ":name" (vev.value-string "Oleg") 0 true)
                (vev.datom-tx 1 ":age" (vev.value-int 17) 1 true)
                (vev.datom-tx 1 ":aka" (vev.value-string "x") 2 true)]))
        rows (vev.datoms db :eavt)
        retracted (vev.db-with-datoms
                    empty
                    ([]vev.Datom
                      [(vev.datom-tx 1 ":name" (vev.value-string "Oleg") 0 true)
                       (vev.datom-tx 1 ":age" (vev.value-int 17) 0 true)
                       (vev.datom-tx 1 ":name" (vev.value-string "Oleg") 0 false)]))
        current (vev.datoms retracted :eavt)]
    (t.is (= (count rows) 3))
    (t.is (= rows[0].a ":age"))
    (t.is (= rows[0].tx 1))
    (t.is (= rows[1].a ":aka"))
    (t.is (= rows[1].tx 2))
    (t.is (= rows[2].a ":name"))
    (t.is (= rows[2].tx 0))
    (t.is (= (count current) 1))
    (t.is (= current[0].a ":age"))
    (t.is (= current[0].tx 0))))

(t.deftest datascript-with-datoms-report-and-conn-subset
  (defer (free_all context.allocator))
  (let [empty (vev.init-db ([]vev.Datom []))
        report (vev.with-datoms
                 empty
                 ([]vev.Datom
                   [(vev.datom-tx 1 ":name" (vev.value-string "Oleg") 0 true)
                    (vev.datom-tx 1 ":age" (vev.value-int 17) 11 true)
                    (vev.datom-tx 1 ":name" (vev.value-string "Oleg") 12 false)]))
        current (vev.datoms report.db-after :eavt)
        conn (vev.create-conn)
        listener-reports (make [dynamic]vev.Tx-Report) :defer
        _ (vev.listen! (addr conn) "datoms" (addr listener-reports))
        conn-report (vev.transact-datoms
                      (addr conn)
                      ([]vev.Datom
                        [(vev.datom-tx 2 ":name" (vev.value-string "Petr") 20 true)
                         (vev.datom-tx 2 ":age" (vev.value-int 37) 21 true)]))
        conn-current (vev.datoms conn.db :eavt)]
    (t.is report.ok)
    (t.is (= report.tx 12))
    (t.is (= (count report.db-before.datoms) 0))
    (t.is (= (count report.tx-data) 3))
    (t.is (= (count current) 1))
    (t.is (= current[0].a ":age"))
    (t.is (= current[0].tx 11))
    (t.is conn-report.ok)
    (t.is (= conn-report.tx 21))
    (t.is (= conn.next-tx 22))
    (t.is (= (count conn-report.tx-data) 2))
    (t.is (= conn-report.tx-data[0].tx 20))
    (t.is (= conn-report.tx-data[1].tx 21))
    (t.is (= (count conn-current) 2))
    (t.is (= (count listener-reports) 1))
    (t.is (= listener-reports[0].tx 21))
    (t.is (= listener-reports[0].tx-data[0].a ":name"))))

(t.deftest datascript-serializable-roundtrip-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 [[:db/add 100 :db/ident :name]
                  [:db/add 100 :db/unique :db.unique/identity]
                  [:db/add 101 :db/ident :aka]
                  [:db/add 101 :db/cardinality :db.cardinality/many]
                  [:db/add 102 :db/ident :friend]
                  [:db/add 102 :db/valueType :db.type/ref]])
        first-report (vev.transact
                       (addr conn)
                       [{:db/id 2
                         :name "Oleg"
                         :attach [:just :values]}])
        report (vev.transact
                 (addr conn)
                 [{:db/id 1
                   :name "Petr"
                   :aka ["Devil" "Tupen"]
                   :friend (vev.value-entity 2)
                   :attach {:some-key :some-value}
                   :score (vev.value-float 42.5)
                   :nan (vev.value-float (math.nan_f64))
                   :inf (vev.value-float (math.inf_f64 1))
                   :neg-inf (vev.value-float (math.inf_f64 -1))
                   :status (vev.value-symbol "active")
                   :quote "Ada \"Lovelace\" \\ math"}])
        retract (vev.transact (addr conn) [[:db/retract 1 :aka "Devil"]])
        data (vev.serializable conn.db)
        restored (vev.from-serializable data)
        restored-conn (vev.conn-from-db restored)
        text-snapshot (vev.serializable-text conn.db)
        [text-restored text-ok text-error] (vev.from-serializable-text text-snapshot)
        text-restored-conn (vev.conn-from-db text-restored)
        original-names (vev.q-collection conn.db
                         [:find [?name ...]
                          :where
                          [?e :name ?name]])
        restored-names (vev.q-collection restored
                         [:find [?name ...]
                          :where
                          [?e :name ?name]])
        restored-aka (vev.q-collection restored
                       [:find [?aka ...]
                        :where
                        [1 :aka ?aka]])
        restored-friend (vev.q restored
                          [:find ?friend-name
                           :where
                           [1 :friend ?friend]
                           [?friend :name ?friend-name]])
        restored-attach (vev.entity-get (vev.db-entity restored 1) ":attach")
        restored-nan (vev.entity-get (vev.db-entity restored 1) ":nan")
        restored-inf (vev.entity-get (vev.db-entity restored 1) ":inf")
        restored-neg-inf (vev.entity-get (vev.db-entity restored 1) ":neg-inf")
        restored-status (vev.entity-get (vev.db-entity restored 1) ":status")
        text-restored-names (vev.q-collection text-restored
                              [:find [?name ...]
                               :where
                               [?e :name ?name]])
        text-restored-aka (vev.q-collection text-restored
                            [:find [?aka ...]
                             :where
                             [1 :aka ?aka]])
        text-restored-friend (vev.q text-restored
                               [:find ?friend-name
                                :where
                                [1 :friend ?friend]
                                [?friend :name ?friend-name]])
        text-restored-attach (vev.entity-get (vev.db-entity text-restored 1) ":attach")
        text-restored-score (vev.entity-get (vev.db-entity text-restored 1) ":score")
        text-restored-nan (vev.entity-get (vev.db-entity text-restored 1) ":nan")
        text-restored-inf (vev.entity-get (vev.db-entity text-restored 1) ":inf")
        text-restored-neg-inf (vev.entity-get (vev.db-entity text-restored 1) ":neg-inf")
        text-restored-status (vev.entity-get (vev.db-entity text-restored 1) ":status")
        text-restored-quote (vev.entity-get (vev.db-entity text-restored 1) ":quote")
        [invalid-db invalid-ok invalid-error] (vev.from-serializable-text "[[1 :name]]")
        restored-next-tx restored-conn.next-tx
        text-restored-next-tx text-restored-conn.next-tx
        next (vev.transact (addr restored-conn) [[:db/add 3 :name "Ivan"]])
        text-next (vev.transact (addr text-restored-conn) [[:db/add 3 :name "Ivan"]])
        next-names (vev.q-collection next.db-after
                     [:find [?name ...]
                      :where
                      [?e :name ?name]])
        text-next-names (vev.q-collection text-next.db-after
                          [:find [?name ...]
                           :where
                           [?e :name ?name]])]
    (defer (vev.delete-serializable data))
    (t.is schema.ok)
    (t.is first-report.ok)
    (t.is report.ok)
    (t.is retract.ok)
    (when (and schema.ok first-report.ok report.ok retract.ok)
      (t.is (= (count data.datoms) (count conn.db.datoms)))
      (t.is (= (count restored.current) (count conn.db.current)))
      (t.is (= (count original-names) (count restored-names)))
      (t.is (= restored-names[0].text "Petr"))
      (t.is (= restored-names[1].text "Oleg"))
      (t.is (= (count restored-aka) 1))
      (t.is (= restored-aka[0].text "Tupen"))
      (t.is (= (count restored-friend.rows) 1))
      (t.is (= restored-friend.rows[0].values[0].text "Oleg"))
      (t.is (= restored-attach.kind .Map))
      (t.is (= restored-attach.items[0].text ":some-key"))
      (t.is (= restored-attach.items[1].text ":some-value"))
      (t.is (= restored-nan.kind .Float))
      (t.is (math.is_nan restored-nan.float-value))
      (t.is (= restored-inf.kind .Float))
      (t.is (math.is_inf restored-inf.float-value 1))
      (t.is (= restored-neg-inf.kind .Float))
      (t.is (math.is_inf restored-neg-inf.float-value -1))
      (t.is (= restored-status.kind .Symbol))
      (t.is (= restored-status.text "active"))
      (t.is (= restored-next-tx 5))
      (t.is (= next.tx 5))
      (t.is next.ok)
      (t.is (= (count next-names) 3))
      (t.is (= next-names[2].text "Ivan"))
      (t.is text-ok)
      (t.is (= text-error ""))
      (t.is (= (count text-restored.current) (count conn.db.current)))
      (t.is (= (count text-restored-names) 2))
      (t.is (= text-restored-names[0].text "Petr"))
      (t.is (= text-restored-names[1].text "Oleg"))
      (t.is (= (count text-restored-aka) 1))
      (t.is (= text-restored-aka[0].text "Tupen"))
      (t.is (= (count text-restored-friend.rows) 1))
      (t.is (= text-restored-friend.rows[0].values[0].text "Oleg"))
      (t.is (= text-restored-attach.kind .Map))
      (t.is (= text-restored-attach.items[0].text ":some-key"))
      (t.is (= text-restored-attach.items[1].text ":some-value"))
      (t.is (= text-restored-score.kind .Float))
      (t.is (= text-restored-score.float-value 42.5))
      (t.is (= text-restored-nan.kind .Float))
      (t.is (math.is_nan text-restored-nan.float-value))
      (t.is (= text-restored-inf.kind .Float))
      (t.is (math.is_inf text-restored-inf.float-value 1))
      (t.is (= text-restored-neg-inf.kind .Float))
      (t.is (math.is_inf text-restored-neg-inf.float-value -1))
      (t.is (= text-restored-status.kind .Symbol))
      (t.is (= text-restored-status.text "active"))
      (t.is (= text-restored-quote.text "Ada \"Lovelace\" \\ math"))
      (t.is (not invalid-ok))
      (t.is (= invalid-error "expected serialized datom vector [e a v tx added]"))
      (t.is (= (count invalid-db.datoms) 0))
      (t.is (= text-restored-next-tx 5))
      (t.is (= text-next.tx 5))
      (t.is text-next.ok)
      (t.is (= (count text-next-names) 3))
      (t.is (= text-next-names[2].text "Ivan")))))

(t.deftest datascript-reset-conn-subset
  (defer (free_all context.allocator))
  (let [conn (vev.conn-from-datoms
               ([]vev.Datom
                 [(vev.make-datom 1 ":age" (vev.value-int 17))
                  (vev.make-datom 1 ":name" (vev.value-string "Ivan"))]))
        next-db (vev.init-db
                  ([]vev.Datom
                    [(vev.make-datom 1 ":age" (vev.value-int 20))
                     (vev.make-datom 1 ":sex" (vev.value-keyword ":male"))]))
        report (vev.reset-conn-with-meta
                 (addr conn)
                 next-db
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":reset/reason" v: (vev.value-string "test")})]))
        attrs (vev.q conn.db
                [:find ?a ?v
                 :where
                 [1 ?a ?v]])]
    (t.is report.ok)
    (t.is (= report.tx 1))
    (t.is (= conn.next-tx 2))
    (t.is (= (count report.tx-data) 4))
    (t.is (= report.tx-data[0].a ":age"))
    (t.is (not report.tx-data[0].added))
    (t.is (= report.tx-data[1].a ":name"))
    (t.is (not report.tx-data[1].added))
    (t.is (= report.tx-data[2].a ":age"))
    (t.is report.tx-data[2].added)
    (t.is (= report.tx-data[3].a ":sex"))
    (t.is report.tx-data[3].added)
    (t.is (= (count report.tx-meta) 1))
    (t.is (= report.tx-meta[0].a ":reset/reason"))
    (t.is (= (count attrs.rows) 2))
    (t.is (= attrs.rows[0].values[0].text ":age"))
    (t.is (= attrs.rows[0].values[1].int-value 20))
    (t.is (= attrs.rows[1].values[0].text ":sex"))
    (t.is (= attrs.rows[1].values[1].text ":male"))))

