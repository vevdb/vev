(t.deftest datascript-transaction-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 31}
             [:db/add 1 :name "Petr"]])
        missing (vev.transact-fn-string (addr conn) birthday-by-name "Bob")
        report (vev.transact-fn-string (addr conn) birthday-by-name "Petr")
        petr (vev.db-entity report.db-after 1)
        created (vev.transact-fn (addr conn) create-oleg)
        new-e created.tempids[0].e
        [created-current-tx created-current-tx-ok] (tempid-e (slice created.tempids 0) ":db/current-tx")
        oleg (vev.db-entity created.db-after new-e)]
    (t.is (not missing.ok))
    (t.is (= missing.error "No entity with name"))
    (t.is report.ok)
    (t.is (= (vev.entity-get petr ":age").int-value 32))
    (t.is (vev.entity-get petr ":had-birthday").bool-value)
    (t.is created.ok)
    (t.is (= (count created.tempids) 2))
    (t.is (= created.tempids[0].tempid "new-person"))
    (t.is created-current-tx-ok)
    (t.is (= created-current-tx created.tx))
    (t.is (= (vev.entity-get oleg ":name").text "Oleg"))))

(t.deftest datascript-ident-transaction-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        registry ([]vev.Tx-Fn-String [(vev.tx-fn-string ":inc-age" birthday-by-name)])
        _ (vev.transact
            (addr conn)
            [{:db/id 10 :db/ident :inc-age}
             {:db/id 11 :db/ident :Petr}])
        unknown (vev.transact-tx-data-with-string-fns
                  (addr conn)
                  (vev.tx-data [:unknown-fn])
                  registry)
        non-fn (vev.transact-tx-data-with-string-fns
                 (addr conn)
                 (vev.tx-data [:Petr])
                 registry)
        missing (vev.transact-tx-data-with-string-fns
                  (addr conn)
                  (vev.tx-data [:inc-age "Bob"])
                  registry)
        report (vev.transact-tx-data-with-string-fns
                 (addr conn)
                 (vev.tx-data
                   [:db/add 1 :name "Petr"]
                   [:db/add 1 :age 31]
                   [:inc-age "Petr"]
                   [:db/add 1 :label "after-call"])
                 registry)
        text-missing (vev.transact-text-with-string-fns
                       (addr conn)
                       "[[:db.fn/call :inc-age \"Bob\"]]"
                       registry)
        text-call (vev.transact-text-with-string-fns
                    (addr conn)
                    "[[:db/add 2 :name \"Ada\"] [:db/add 2 :age 40] [:db.fn/call :inc-age \"Ada\"] [:db/add 2 :label \"after-text-call\"]]"
                    registry)
        prepared (vev.prepare-tx-text
                   "[[:db/add 3 :name \"Grace\"] [:db/add 3 :age 50] [:inc-age \"Grace\"] [:db/add 3 :label \"after-prepared-call\"]]")
        prepared-call (vev.transact-prepared-with-string-fns (addr conn) prepared registry)
        no-registry (vev.transact-text-with-string-fns
                      (addr conn)
                      "[[:inc-age \"Petr\"]]"
                      ([]vev.Tx-Fn-String []))
        unknown-text (vev.transact-text-with-string-fns
                       (addr conn)
                       "[[:unknown-fn \"Petr\"]]"
                       registry)
        bad-call-shape (vev.transact-text-with-string-fns
                         (addr conn)
                         "[[:db.fn/call :inc-age 42]]"
                         registry)
        petr (vev.db-entity report.db-after 1)
        ada (vev.db-entity text-call.db-after 2)
        grace (vev.db-entity prepared-call.db-after 3)]
    (t.is (not unknown.ok))
    (t.is (= unknown.error "transaction fn not found"))
    (t.is (not non-fn.ok))
    (t.is (= non-fn.error "transaction fn not registered"))
    (t.is (not missing.ok))
    (t.is (= missing.error "No entity with name"))
    (t.is report.ok)
    (t.is (= (vev.entity-get petr ":age").int-value 32))
    (t.is (vev.entity-get petr ":had-birthday").bool-value)
    (t.is (= (vev.entity-get petr ":label").text "after-call"))
    (t.is (not text-missing.ok))
    (t.is (= text-missing.error "No entity with name"))
    (t.is text-call.ok)
    (t.is (= (vev.entity-get ada ":age").int-value 41))
    (t.is (vev.entity-get ada ":had-birthday").bool-value)
    (t.is (= (vev.entity-get ada ":label").text "after-text-call"))
    (t.is prepared.ok)
    (t.is prepared-call.ok)
    (t.is (= (vev.entity-get grace ":age").int-value 51))
    (t.is (vev.entity-get grace ":had-birthday").bool-value)
    (t.is (= (vev.entity-get grace ":label").text "after-prepared-call"))
    (t.is (not no-registry.ok))
    (t.is (= no-registry.error "transaction fn not registered"))
    (t.is (not unknown-text.ok))
    (t.is (= unknown-text.error "transaction fn not found"))
    (t.is (not bad-call-shape.ok))
    (t.is (= bad-call-shape.error ":db.fn/call text form currently expects one string argument"))))

