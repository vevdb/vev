(t.deftest datascript-upsert-forward-string-tempid-refs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :ref]
             [:db/add 101 :db/valueType :db.type/ref]
             {:db/id 1 :name "Alice"}
             {:db/id 2 :name "Bob"}])
        report (vev.transact
                 (addr conn)
                 [{:db/id 3 :ref "A"}
                  {:db/id 4 :ref "B"}
                  {:db/id "A" :name "Alice"}
                  {:db/id "B" :name "Bob"}])
        [first-ref first-ok] (vev.q-scalar report.db-after
                               [:find ?ref .
                                :where
                                [3 :ref ?ref]])
        [second-ref second-ok] (vev.q-scalar report.db-after
                                  [:find ?ref .
                                   :where
                                   [4 :ref ?ref]])]
    (t.is report.ok)
    (t.is (= (count report.tempids) 3))
    (t.is (= report.tempids[0].tempid "A"))
    (t.is (= report.tempids[0].e 1))
    (t.is (= report.tempids[1].tempid "B"))
    (t.is (= report.tempids[1].e 2))
    (t.is first-ok)
    (t.is (= first-ref.entity 1))
    (t.is second-ok)
    (t.is (= second-ref.entity 2))))

(t.deftest datascript-upsert-retries-order-subset
  (defer (free_all context.allocator))
  (let [first-conn (vev.create-conn)
        _ (vev.transact
            (addr first-conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]])
        first (vev.transact
                (addr first-conn)
                [{:db/id "a" :age 42}
                 {:db/id "b" :likes "Pizza"}
                 {:db/id "a" :name "Bob"}
                 {:db/id "b" :name "Bob"}])
        first-e first.tempids[0].e
        first-pull (vev.pull first.db-after [*] first-e)
        second-conn (vev.create-conn)
        _ (vev.transact
            (addr second-conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]])
        second (vev.transact
                 (addr second-conn)
                 [{:db/id "a" :age 42}
                  {:db/id "b" :likes "Pizza"}
                  {:db/id "b" :name "Bob"}
                  {:db/id "a" :name "Bob"}])
        second-e second.tempids[0].e
        second-pull (vev.pull second.db-after [*] second-e)]
    (t.is first.ok)
    (t.is (= first.tempids[0].tempid "a"))
    (t.is (= first.tempids[1].tempid "b"))
    (t.is (= first.tempids[1].e first-e))
    (t.is (= first-pull.attrs[0].v.entity first-e))
    (t.is (= first-pull.attrs[1].v.int-value 42))
    (t.is (= first-pull.attrs[2].v.text "Pizza"))
    (t.is (= first-pull.attrs[3].v.text "Bob"))
    (t.is second.ok)
    (t.is (= second.tempids[0].tempid "a"))
    (t.is (= second.tempids[1].tempid "b"))
    (t.is (= second.tempids[1].e second-e))
    (t.is (= second-pull.attrs[0].v.entity second-e))
    (t.is (= second-pull.attrs[1].v.int-value 42))
    (t.is (= second-pull.attrs[2].v.text "Pizza"))
    (t.is (= second-pull.attrs[3].v.text "Bob"))))

