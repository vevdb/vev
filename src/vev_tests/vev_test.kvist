(package vev-tests)

(import arr "kvist:arr")
(import fmt "core:fmt")
(import math "core:math")
(import strings "core:strings")
(import t "kvist:test")
(import vev "../vev")

(defn row-value? [row: vev.Result-Row, index: int, expected: vev.Value] -> bool
  (and (< index (count row.values))
       (vev.value-equal? row.values[index] expected)))

(defn row-entity? [row: vev.Result-Row, index: int, entity: u64] -> bool
  (row-value? row index (vev.value-entity entity)))

(defn row-text? [row: vev.Result-Row, index: int, text: string] -> bool
  (row-value? row index (vev.value-string text)))

(defn row-int? [row: vev.Result-Row, index: int, value: i64] -> bool
  (row-value? row index (vev.value-int value)))

(defn result-has-entity-pair? [result: vev.Result-Set, left: u64, right: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (row-entity? row 0 left)
               (row-entity? row 1 right))
      (return true)))
  false)

(defn result-has-entity? [result: vev.Result-Set, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (row-entity? row 0 entity))
      (return true)))
  false)

(defn result-has-entity-text? [result: vev.Result-Set, entity: u64, text: string] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (row-entity? row 0 entity)
               (row-text? row 1 text))
      (return true)))
  false)

(defn values-has-entity? [values: []vev.Value, entity: u64] -> bool
  (for [value values]
    (when (and (= value.kind .Entity)
               (= value.entity entity))
      (return true)))
  false)

(defn pull-attr-index [attrs: []vev.Pull-Attr, attr: string] -> [index: int, ok: bool]
  (for [item index attrs]
    (when (= item.a attr)
      (return index true)))
  (return 0 false))

(defn pull-deep-friend-name [pulled: vev.Pull-Result, hops: int] -> [name: string, ok: bool]
  (let [attrs: []vev.Pull-Attr (slice pulled.attrs 0)
        step 0]
    (while (< step hops)
      (let [[friend-index friend-ok] (pull-attr-index attrs ":friend")]
        (when (not friend-ok)
          (return "" false))
        (set! attrs (slice attrs[friend-index].attrs 0)))
      (set! step (+ step 1)))
    (let [[name-index name-ok] (pull-attr-index attrs ":name")]
      (when (not name-ok)
        (return "" false))
      (return attrs[name-index].v.text true))))

(defn append-status-rule-performance-tx! [tx: ^[dynamic]vev.Tx-Data, limit: int] -> bool
  (let [ids (arr.range 1 limit) :defer]
    (for [i ids]
      (let [status (if (= (% i 3) 0) "pending" (if (= (% i 3) 1) "started" "stopped"))]
        (arr.push! tx^ (vev.add (u64 i) ":item/status" (vev.value-string status))))))
  true)

(defn tempid-e [tempids: []vev.Tempid, tempid: string] -> [e: u64, ok: bool]
  (for [item tempids]
    (when (= item.tempid tempid)
      (return item.e true)))
  (return 0 false))

(defn keep-not-password [db: vev.DB, datom: vev.Datom] -> bool
  (not (= datom.a ":password")))

(defn keep-not-entity-2 [db: vev.DB, datom: vev.Datom] -> bool
  (not (= datom.e 2)))

(defn keep-long-akas [db: vev.DB, datom: vev.Datom] -> bool
  (when (not (= datom.a ":aka"))
    (return true))
  (let [entity (vev.db-entity db datom.e)
        akas (vev.entity-values entity ":aka")]
    (defer (delete akas))
    (or (<= (count akas) 1)
        (>= (count datom.v.text) 4))))

(defn keep-not-tupen [db: vev.DB, datom: vev.Datom] -> bool
  (not (and (= datom.v.kind .String)
            (= datom.v.text "Tupen"))))

(defn keep-has-age [db: vev.DB, datom: vev.Datom] -> bool
  (vev.entity-contains? (vev.db-entity db datom.e) ":age"))

(defn keep-adult [db: vev.DB, datom: vev.Datom] -> bool
  (let [age (vev.entity-get (vev.db-entity db datom.e) ":age")]
    (and (= age.kind .Int)
         (>= age.int-value 18))))

(defn keep-all [db: vev.DB, datom: vev.Datom] -> bool
  true)

(defn keep-none [db: vev.DB, datom: vev.Datom] -> bool
  false)

(defn birthday-by-name [db: vev.DB, name: string] -> vev.Tx-Fn-Result
  (for [datom-index db.eavt]
    (let [datom db.datoms[datom-index]]
      (when (and (vev.datom-current-at? db datom-index)
                 (= datom.a ":name")
                 (= datom.v.kind .String)
                 (= datom.v.text name))
        (let [age (vev.entity-get (vev.db-entity db datom.e) ":age")]
          (return
            (vev.tx-fn-ok
              ([]vev.Tx-Data
                [(vev.add datom.e ":age" (vev.value-int (+ age.int-value 1)))
                 (vev.add datom.e ":had-birthday" (vev.value-bool true))])))))))
  (vev.tx-fn-error "No entity with name"))

(defn birthday-by-name-and-delta [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result
  (when (not (and (= (count args) 2)
                  (= args[0].kind .String)
                  (= args[1].kind .Int)))
    (return (vev.tx-fn-error "Expected name and delta")))
  (for [datom-index db.eavt]
    (let [datom db.datoms[datom-index]]
      (when (and (vev.datom-current-at? db datom-index)
                 (= datom.a ":name")
                 (= datom.v.kind .String)
                 (= datom.v.text args[0].text))
        (let [age (vev.entity-get (vev.db-entity db datom.e) ":age")]
          (return
            (vev.tx-fn-ok
              ([]vev.Tx-Data
                [(vev.add datom.e ":age" (vev.value-int (+ age.int-value args[1].int-value)))
                 (vev.add datom.e ":birthday-delta" args[1])])))))))
  (vev.tx-fn-error "No entity with name"))

(defn fail-tx-fn-string [db: vev.DB, arg: string] -> vev.Tx-Fn-Result
  (vev.tx-fn-error arg))

(defn create-vera-value-fn [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result
  (when (not (= (count args) 0))
    (return (vev.tx-fn-error "Expected no args")))
  (vev.tx-fn-ok
    ([]vev.Tx-Data
      [(vev.add-tempid "vera" ":name" (vev.value-string "Vera"))])))

(defn native-adult-age? [args: []vev.Value] -> bool
  (and (= (count args) 2)
       (= args[0].kind .Int)
       (= args[1].kind .Int)
       (>= args[0].int-value args[1].int-value)))

(defn native-always? [args: []vev.Value] -> bool
  true)

(defn map-value [m: vev.Value, key: string] -> [found: vev.Value, ok: bool]
  (vev.map-get-value m (vev.value-keyword key)))

(defn native-db-age-equals? [db: vev.DB, args: []vev.Value] -> bool
  (when (not (and (= (count args) 3)
                  (= args[0].kind .Symbol)
                  (= args[0].text "$")
                  (= args[1].kind .Entity)
                  (= args[2].kind .Int)))
    (return false))
  (let [age (vev.entity-get (vev.db-entity db args[1].entity) ":age")]
    (and (= age.kind .Int)
         (= age.int-value args[2].int-value))))

(defn native-even-identity [args: []vev.Value] -> vev.Native-Query-Function-Result
  (when (not (and (= (count args) 1)
                  (= args[0].kind .Int)
                  (= (% args[0].int-value 2) 0)))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result args[0]))

(defn native-person-label [args: []vev.Value] -> vev.Native-Query-Function-Result
  (when (not (and (= (count args) 2)
                  (= args[0].kind .String)
                  (= args[1].kind .String)))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result
    (vev.value-keyword
      (strings.concatenate ([]string [":" args[0].text "/" args[1].text])))))

(defn native-constant-five [args: []vev.Value] -> vev.Native-Query-Function-Result
  (when (not (= (count args) 0))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result (vev.value-int 5)))

(defn native-minmax [args: []vev.Value] -> vev.Native-Query-Function-Result
  (when (not (and (= (count args) 1)
                  (= args[0].kind .Vector)
                  (> (count args[0].items) 0)))
    (return (vev.native-query-function-none)))
  (let [min-value args[0].items[0]
        max-value args[0].items[0]]
    (when (not (= min-value.kind .Int))
      (return (vev.native-query-function-none)))
    (for [item args[0].items]
      (when (not (= item.kind .Int))
        (return (vev.native-query-function-none)))
      (when (< item.int-value min-value.int-value)
        (set! min-value item))
      (when (> item.int-value max-value.int-value)
        (set! max-value item)))
    (vev.native-query-function-result
      (vev.value-vector ([]vev.Value [min-value max-value])))))

(defn native-tag-value [value: vev.Value] -> vev.Native-Query-Function-Result
  (when (not (= value.kind .String))
    (return (vev.native-query-function-none)))
  (vev.native-query-function-result
    (vev.value-string (strings.concatenate ([]string ["tag:" value.text])))))

(defn native-sort-reverse [values: []vev.Value] -> vev.Native-Query-Function-Result
  (let [sorted (arr.into [dynamic]vev.Value values)
        out (make [dynamic]vev.Value)]
    (defer (delete sorted))
    (for [i (arr.range 1 (count sorted))]
      (let [current sorted[i]
            j i]
        (while (and (> j 0)
                    (vev.value-less? sorted[(- j 1)] current))
          (set! sorted[j] sorted[(- j 1)])
          (set! j (- j 1)))
        (set! sorted[j] current)))
    (for [value sorted]
      (arr.push! out value))
    (let [result (vev.value-vector (slice out 0))]
      (delete out)
      (vev.native-query-function-result result))))

(defn create-oleg [db: vev.DB] -> vev.Tx-Fn-Result
  (vev.tx-fn-ok
    ([]vev.Tx-Data
      [(vev.add-tempid "new-person" ":name" (vev.value-string "Oleg"))])))

(defn create-entity-without-db-id [db: vev.DB] -> vev.Tx-Fn-Result
  (vev.tx-fn-ok
    (vev.tx-data {:foo "bar"})))

(defn create-entity-without-db-id-values [db: vev.DB, args: []vev.Value] -> vev.Tx-Fn-Result
  (when (not (= (count args) 0))
    (return (vev.tx-fn-error "Expected no args")))
  (create-entity-without-db-id db))

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                    (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})
                    (vev.Tx-Meta {a: ":tx/reason" v: (vev.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next-tx 2))
    (t.is (= (count report.db-before.datoms) 0))
    (t.is (= (count report.db-after.datoms) 2))
    (t.is (= (count report.tx-data) 2))
    (t.is (= (count report.tx-meta) 2))
    (t.is (= report.tx-meta[0].a ":request/id"))
    (let [meta-value report.tx-meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (vev.q-strings report.db-after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest tx-data-supports-datomic-tx-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id "datomic.tx"
                   :request/id "req-1"
                   :tx/reason :profile-edit}
                  [:db/add 10 :user/name "Ada"]])
        tx-e report.tempids[0].e
        [current-tx current-tx-ok] (tempid-e (slice report.tempids 0) ":db/current-tx")
        tx-props (vev.q report.db-after
                   [:find ?a ?v
                    :where
                    [?tx :request/id "req-1"]
                    [?tx ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 3))
    (t.is (= report.tx-data[0].e tx-e))
    (t.is (= report.tx-data[1].e tx-e))
    (t.is (= tx-e report.tx))
    (t.is (= report.tx-data[2].e 10))
    (t.is (= (count report.tempids) 2))
    (t.is current-tx-ok)
    (t.is (= current-tx report.tx))
    (t.is (= (count tx-props.rows) 2))
    (t.is (= (count report.tx-meta) 2))
    (t.is (= report.tx-meta[0].a ":request/id"))
    (t.is (= report.tx-meta[0].v.text "req-1"))
    (t.is (= report.tx-meta[1].a ":tx/reason"))
    (t.is (= report.tx-meta[1].v.text ":profile-edit"))))

(t.deftest datascript-transaction-report-rendered-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":name" (vev.value-string "Petr"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})]))
        rendered (vev.tx-report-value report)
        prepared (vev.prepare-tx-text "[[:db/add \"person\" :name \"Ada\"]]")
        prepared-rendered (vev.transact-prepared-value (addr conn) prepared)
        text-rendered (vev.transact-text-value (addr conn) "[[:db/add \"other\" :name \"Grace\"]]")
        immutable-rendered (vev.with-text-value conn.db "[[:db/add \"immutable\" :name \"Alan\"]]")
        bad-rendered (vev.transact-text-value (addr conn) "[[:db/add nil :name \"Bad\"]]")
        [ok ok-ok] (map-value rendered ":ok")
        [tx tx-ok] (map-value rendered ":tx")
        [tx-data tx-data-ok] (map-value rendered ":tx-data")
        [first-datom-e first-datom-e-ok] (map-value tx-data.items[0] ":e")
        [first-datom-a first-datom-a-ok] (map-value tx-data.items[0] ":a")
        [first-datom-v first-datom-v-ok] (map-value tx-data.items[0] ":v")
        [first-datom-op first-datom-op-ok] (map-value tx-data.items[0] ":op")
        [tx-meta tx-meta-ok] (map-value rendered ":tx-meta")
        [first-meta-a first-meta-a-ok] (map-value tx-meta.items[0] ":a")
        [first-meta-v first-meta-v-ok] (map-value tx-meta.items[0] ":v")
        [tempids tempids-ok] (map-value prepared-rendered ":tempids")
        [person-e person-e-ok] (vev.map-get-value tempids (vev.value-string "person"))
        [current-tx current-tx-ok] (map-value tempids ":db/current-tx")
        [text-tempids text-tempids-ok] (map-value text-rendered ":tempids")
        [other-e other-e-ok] (vev.map-get-value text-tempids (vev.value-string "other"))
        [immutable-ok immutable-ok-ok] (map-value immutable-rendered ":ok")
        [immutable-tempids immutable-tempids-ok] (map-value immutable-rendered ":tempids")
        [immutable-e immutable-e-ok] (vev.map-get-value immutable-tempids (vev.value-string "immutable"))
        [bad-ok bad-ok-ok] (map-value bad-rendered ":ok")
        [bad-error bad-error-ok] (map-value bad-rendered ":error")
        [bad-tx-data bad-tx-data-ok] (map-value bad-rendered ":tx-data")]
    (t.is ok-ok)
    (t.is ok.bool-value)
    (t.is tx-ok)
    (t.is (= tx.entity report.tx))
    (t.is tx-data-ok)
    (t.is (= tx-data.kind .Vector))
    (t.is (= (count tx-data.items) 1))
    (t.is first-datom-e-ok)
    (t.is (= first-datom-e.entity 1))
    (t.is first-datom-a-ok)
    (t.is (= first-datom-a.text ":name"))
    (t.is first-datom-v-ok)
    (t.is (= first-datom-v.text "Petr"))
    (t.is first-datom-op-ok)
    (t.is (= first-datom-op.text ":db/add"))
    (t.is tx-meta-ok)
    (t.is (= (count tx-meta.items) 1))
    (t.is first-meta-a-ok)
    (t.is (= first-meta-a.text ":request/id"))
    (t.is first-meta-v-ok)
    (t.is (= first-meta-v.text "req-1"))
    (t.is tempids-ok)
    (t.is person-e-ok)
    (t.is (= person-e.kind .Entity))
    (t.is current-tx-ok)
    (t.is (= current-tx.kind .Entity))
    (t.is text-tempids-ok)
    (t.is other-e-ok)
    (t.is (= other-e.kind .Entity))
    (t.is immutable-ok-ok)
    (t.is immutable-ok.bool-value)
    (t.is immutable-tempids-ok)
    (t.is immutable-e-ok)
    (t.is (= immutable-e.kind .Entity))
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-error-ok)
    (t.is (= bad-error.text "entity id must be int, tempid string, ident keyword, or lookup ref"))
    (t.is bad-tx-data-ok)
    (t.is (= (count bad-tx-data.items) 0))))

(t.deftest datascript-query-db-datom-tx-op-terms-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/name "Ada"]
                  [:db/add 1 :user/age 37]])
        literal (vev.q report.db-after
                  [:find ?tx ?name
                   :where
                   [1 :user/name ?name ?tx :db/add]])
        prepared (vev.prepare-query-text "[:find ?tx ?name :where [1 :user/name ?name ?tx :db/add]]")
        prepared-result (vev.q-prepared report.db-after prepared)
        text (vev.q-text
               report.db-after
               "[:find ?tx ?name :where [1 :user/name ?name ?tx :db/add]]")
        tx-only (vev.q report.db-after
                  [:find ?tx ?age
                   :where
                   [1 :user/age ?age ?tx]])
        retract-op (vev.q-text
                     report.db-after
                     "[:find ?name :where [1 :user/name ?name _ :db/retract]]")]
    (t.is (= (count literal.rows) 1))
    (t.is (= literal.rows[0].values[0].entity report.tx))
    (t.is (= literal.rows[0].values[1].text "Ada"))
    (t.is prepared.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].entity report.tx))
    (t.is (= prepared-result.rows[0].values[1].text "Ada"))
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].entity report.tx))
    (t.is (= text.rows[0].values[1].text "Ada"))
    (t.is (= (count tx-only.rows) 1))
    (t.is (= tx-only.rows[0].values[0].entity report.tx))
    (t.is (= tx-only.rows[0].values[1].int-value 37))
    (t.is (= (count retract-op.rows) 0))))

(t.deftest kvist-first-class-keyword-api-helpers
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        first-report (vev.transact-tx-data
                       (addr conn)
                       ([]vev.Tx-Data
                         [(vev.add-kw 1 :name (vev.value-string "Ada"))
                          (vev.add-kw 1 :status (vev.value-kw :active))]))
        _ (vev.transact-ops
            (addr conn)
            ([]vev.Tx-Op [(vev.tx-add-kw 2 :name (vev.value-string "Grace"))
                           (vev.tx-add-kw 2 :status (vev.value-kw :inactive))]))
        clauses ([]vev.Clause
                  [(vev.clause-kw (vev.term-var "e") :status (vev.term-kw :active))])
        query (vev.query ([]string ["e"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q conn.db query)
        entity (vev.db-entity conn.db 1)
        pulled (vev.pull-pattern-spec
                 conn.db
                 1
                 ([]vev.Pull-Spec [(vev.flat-pull-spec-kw :name)
                                    (vev.flat-pull-spec-kw :status)]))]
    (t.is first-report.ok)
    (t.is (= (vev.entity-get-kw entity :name).text "Ada"))
    (t.is (= (vev.entity-get-kw entity :status).text ":active"))
    (t.is (= (count pulled.attrs) 2))
    (t.is (= pulled.attrs[0].a ":name"))
    (t.is (= pulled.attrs[1].v.text ":active"))
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].entity 1))))

(t.deftest datascript-listen-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        reports (make [dynamic]vev.Tx-Report) :defer
        _ (vev.transact (addr conn) [[:db/add 1 :name "Alex"]
                                     [:db/add 2 :name "Boris"]])
        _ (vev.listen! (addr conn) "test" (addr reports))
        first (vev.transact-with-meta
                (addr conn)
                ([]vev.Tx-Op [(vev.tx-add 3 ":name" (vev.value-string "Dima"))
                               (vev.tx-add 3 ":age" (vev.value-int 19))
                               (vev.tx-add 4 ":name" (vev.value-string "Evgeny"))])
                ([]vev.Tx-Meta [(vev.Tx-Meta {a: ":some-metadata" v: (vev.value-int 1)})]))
        second (vev.transact
                 (addr conn)
                 [[:db/add 5 :name "Fedor"]
                  [:db/add 1 :name "Alex2"]
                  [:db/retract 2 :name "Not Boris"]
                  [:db/retract 4 :name "Evgeny"]])
        _ (vev.unlisten! (addr conn) "test")
        _ (vev.transact (addr conn) [[:db/add 6 :name "Georgy"]])]
    (t.is first.ok)
    (t.is second.ok)
    (t.is (= (count reports) 2))
    (t.is (= (count reports[0].tx-data) 3))
    (t.is (= reports[0].tx-data[0].e 3))
    (t.is (= reports[0].tx-data[0].a ":name"))
    (t.is (= reports[0].tx-data[0].v.text "Dima"))
    (t.is (= reports[0].tx-data[1].a ":age"))
    (t.is (= reports[0].tx-data[1].v.int-value 19))
    (t.is (= reports[0].tx-meta[0].a ":some-metadata"))
    (t.is (= reports[0].tx-meta[0].v.int-value 1))
    (t.is (= (count reports[1].tx-data) 4))
    (t.is (= reports[1].tx-data[0].e 5))
    (t.is reports[1].tx-data[0].added)
    (t.is (= reports[1].tx-data[1].e 1))
    (t.is (not reports[1].tx-data[1].added))
    (t.is (= reports[1].tx-data[2].e 1))
    (t.is reports[1].tx-data[2].added)
    (t.is (= reports[1].tx-data[3].e 4))
    (t.is (not reports[1].tx-data[3].added))
    (t.is (= (count reports[1].tx-meta) 0))))

(t.deftest transact-defaults-unschematized-attrs-to-cardinality-one
