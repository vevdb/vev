(t.deftest datascript-query-symbol-comparison-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            ([]vev.Tx-Data
              [(vev.add 1 ":s" (vev.value-symbol "a"))
               (vev.add 2 ":s" (vev.value-symbol "b"))]))
        literal (vev.q-collection conn.db
                  [:find [?e ...]
                   :where
                   [?e :s b]])
        text (vev.q-text conn.db "[:find [?e ...] :where [?e :s b]]")
        text-tx-conn (vev.create-conn)
        _ (vev.transact-text (addr text-tx-conn) "[{:db/id 1 :s a} {:db/id 2 :s b}]")
        text-tx (vev.q-text text-tx-conn.db "[:find [?e ...] :where [?e :s b]]")
        source (vev.q-text-with-inputs
                 conn.db
                 "[:find [?e ...] :in $rows :where [$rows ?e :s b]]"
                 ([]vev.Query-Input
                   [(vev.query-input-scalar
                      (vev.value-vector
                        ([]vev.Value
                          [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":s") (vev.value-symbol "a")]))
                           (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":s") (vev.value-symbol "b")]))])))]))
        schema-conn (vev.create-conn)
        _ (vev.transact
            (addr schema-conn)
            [[:db/add 100 :db/ident :s]
             [:db/add 100 :db/valueType :db.type/symbol]])
        schema-ok (vev.transact-tx-data
                    (addr schema-conn)
                    ([]vev.Tx-Data [(vev.add 1 ":s" (vev.value-symbol "ok"))]))
        schema-bad (vev.transact (addr schema-conn) [[:db/add 2 :s "bad"]])]
    (t.is (= (count literal) 1))
    (t.is (= literal[0].entity 2))
    (t.is text.ok)
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].entity 2))
    (t.is text-tx.ok)
    (t.is (= (count text-tx.rows) 1))
    (t.is (= text-tx.rows[0].values[0].entity 2))
    (t.is source.ok)
    (t.is (= (count source.rows) 1))
    (t.is (= source.rows[0].values[0].int-value 2))
    (t.is schema-ok.ok)
    (t.is (not schema-bad.ok))
    (t.is (= schema-bad.error "schema value type mismatch"))))

(t.deftest datalog-macro-builds-query-from-data-literal
  (defer (free_all context.allocator))
