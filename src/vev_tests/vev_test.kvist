(t.deftest datascript-resolves-current-tx-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :created-at]
             [:db/add 100 :db/valueType :db.type/ref]])
        report (vev.transact
                 (addr conn)
                 [[:db/add 10 :name "X"]
                  [:db/add 10 :created-at :db/current-tx]
                  [:db/add :db/current-tx :prop1 "prop1"]
                  [:db/add "datomic.tx" :prop2 "prop2"]
                  [:db/add "datascript.tx" :prop3 "prop3"]])
        [tx tx-ok] (vev.q-scalar report.db-after
                     [:find ?tx .
                      :where
                      [10 :created-at ?tx]])
        props (vev.q report.db-after
                [:find ?p
                 :where
                 [?tx :prop1 "prop1"]
                 [?tx ?p _]])]
    (t.is report.ok)
    (t.is tx-ok)
    (t.is (= tx.entity report.tx))
    (t.is (>= (count report.tempids) 3))
    (for [tempid report.tempids]
      (t.is (= tempid.e tx.entity)))
    (t.is (= (count props.rows) 3))
    (t.is (= props.rows[0].values[0].text ":prop1"))
    (t.is (= props.rows[1].values[0].text ":prop2"))
    (t.is (= props.rows[2].values[0].text ":prop3"))))

(t.deftest datascript-current-tx-value-alias-tempids
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :created-at]
             [:db/add 100 :db/valueType :db.type/ref]])
        datomic (vev.transact
                  (addr conn)
                  [[:db/add 10 :created-at "datomic.tx"]])
        datascript (vev.transact
                     (addr conn)
                     [[:db/add 11 :created-at "datascript.tx"]])
        [datomic-tx datomic-tx-ok] (tempid-e (slice datomic.tempids 0) "datomic.tx")
        [datascript-tx datascript-tx-ok] (tempid-e (slice datascript.tempids 0) "datascript.tx")
        [datomic-value datomic-value-ok] (vev.q-scalar datomic.db-after
                                           [:find ?tx .
                                            :where
                                            [10 :created-at ?tx]])
        [datascript-value datascript-value-ok] (vev.q-scalar datascript.db-after
                                               [:find ?tx .
                                                :where
                                                [11 :created-at ?tx]])]
    (t.is datomic.ok)
    (t.is datascript.ok)
    (t.is datomic-tx-ok)
    (t.is datascript-tx-ok)
    (t.is datomic-value-ok)
    (t.is datascript-value-ok)
    (t.is (= datomic-tx datomic.tx))
    (t.is (= datascript-tx datascript.tx))
    (t.is (= datomic-value.entity datomic-tx))
    (t.is (= datascript-value.entity datascript-tx))))

