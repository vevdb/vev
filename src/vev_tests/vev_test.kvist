             {:db/id 3 :age 37}])
        counted (vev.q-text-with-inputs
                  conn.db
                  "[:find ?x ?c :in [?x ...] :where [(count ?x) ?c]]"
                  ([]vev.Query-Input
                    [(vev.query-input-collection
                       ([]vev.Value [(vev.value-string "a")
                                      (vev.value-string "abc")]))]))
        vector-tx (vev.q-text-collection
                    conn.db
                    "[:find [?tx-data ...] :where [(ground :db/add) ?op] [(vector ?op -1 :attr 12) ?tx-data]]")
        map-tx (vev.q-text-collection
                 conn.db
                 "[:find [?tx-data ...] :where [(hash-map :db/id -1 :age 92 :name \"Aaron\") ?tx-data]]")
        map-order (vev.q-text-collection
                    conn.db
                    "[:find [?m ...] :where [(hash-map :a 1 :b 2) ?m] [(hash-map :b 2 :a 1) ?m]]")
        map-get (vev.q-text
                  conn.db
                  "[:find ?m ?v :where [(hash-map :b 1 :d 2) ?m] [(get ?m :d) ?v]]")
        summed (vev.q-text
                 conn.db
                 "[:find ?e1 ?e2 ?e3 :where [?e1 :age ?a1] [?e2 :age ?a2] [?e3 :age ?a3] [(+ ?a1 ?a2) ?a12] [(= ?a12 ?a3)]]")
        prepared (vev.prepare-query-text
                   "[:find ?age ?next :where [_ :age ?age] [(inc ?age) ?next]]")
        incremented (vev.q-prepared conn.db prepared)
        conflicting (vev.q-text-with-inputs
                      conn.db
                      "[:find ?n :in ?n :where [(+ 1 2) ?n]]"
                      ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 4))]))
        identity-conflict (vev.q-text
                            conn.db
                            "[:find ?n :where [(identity 1) ?n] [(identity 2) ?n]]")
        destructured (vev.q-text
                       conn.db
                       "[:find ?n ?x :where [(identity [3 4]) [?n ?x]]]")
        destructured-conflict (vev.q-text
                                conn.db
                                "[:find ?n ?x :where [(identity [3 4]) [?n ?x] [(identity [1 2]) [?n ?x]]]")
        pair-unification (vev.q-text-with-inputs
                           conn.db
                           "[:find ?pair ?x :in [[?e ?attr ?pair]] :where [(first ?pair) ?x] [(second ?pair) ?x]]"
                           ([]vev.Query-Input
                             [(vev.query-input-relation
                                ([]vev.Value
                                  [(vev.value-int 1)
                                   (vev.value-keyword ":pair")
                                   (vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":a")]))
                                   (vev.value-int 2)
                                   (vev.value-keyword ":pair")
                                   (vev.value-vector ([]vev.Value [(vev.value-keyword ":b") (vev.value-keyword ":c")]))])
                                3)]))
        rel-function-conflict (vev.q-text
                                conn.db
                                "[:find ?age :where [_ :age ?age] [(identity 100) ?age]]")
        nil-result-filtered (vev.q-text
                              conn.db
                              "[:find ?x :where [(first []) ?x]]")
        ground-relation-output (vev.q-text-with-inputs
                                 conn.db
                                 "[:find ?x ?z :in ?in :where [(ground ?in) [[?x _ ?z] ...]]]"
                                 ([]vev.Query-Input
                                   [(vev.query-input-scalar
                                      (vev.value-vector
                                        ([]vev.Value
                                          [(vev.value-vector ([]vev.Value [(vev.value-keyword ":a") (vev.value-keyword ":b") (vev.value-keyword ":c")]))
                                           (vev.value-vector ([]vev.Value [(vev.value-keyword ":d") (vev.value-keyword ":e") (vev.value-keyword ":f")]))])))]))
        function-relation-output (vev.q-text
                                   conn.db
                                   "[:find ?x ?z :where [(identity [[:a :b :c] [:d :e :f]]) [[?x _ ?z] ...]]]")
        function-collection-output (vev.q-text
                                     conn.db
                                     "[:find ?x :where [(identity [:a :b :c]) [?x ...]]]")]
    (t.is (= (count counted.rows) 2))
