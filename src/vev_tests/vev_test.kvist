(t.deftest datascript-text-upsert-unique-identity-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-text
            (addr conn)
            "[[:db/add 100 :db/ident :name] [:db/add 100 :db/valueType :db.type/string] [:db/add 100 :db/unique :db.unique/identity] [:db/add 101 :db/ident :email] [:db/add 101 :db/valueType :db.type/string] [:db/add 101 :db/unique :db.unique/identity] [:db/add 102 :db/ident :ref] [:db/add 102 :db/valueType :db.type/ref] [:db/add 102 :db/unique :db.unique/identity] [:db/add 103 :db/ident :age] [:db/add 103 :db/valueType :db.type/long] [:db/add 103 :db/cardinality :db.cardinality/one] [:db/add 104 :db/ident :friend] [:db/add 104 :db/valueType :db.type/ref]]")
        _ (vev.transact-text
            (addr conn)
            "[{:db/id 1 :name \"Ivan\" :email \"@1\"} {:db/id 2 :name \"Petr\" :email \"@2\" :ref 3} {:db/id 3 :name \"Dima\" :email \"@3\" :ref 4} {:db/id 4 :name \"Olga\" :email \"@4\" :ref 1}]")
        no-id (vev.transact-text
                (addr conn)
                "[{:name \"Ivan\" :age 35}]")
        no-id-two-attrs (vev.transact-text
                          (addr conn)
                          "[{:name \"Ivan\" :email \"@1\" :age 34}]")
        with-tempid (vev.transact-text
                      (addr conn)
                      "[{:db/id \"ivan\" :name \"Ivan\" :age 36}]")
        list-tempid (vev.transact-text
                      (addr conn)
                      "[[:db/add \"ivan-list\" :age 37] [:db/add \"ivan-list\" :name \"Ivan\"]]")
        second-tempid (vev.transact-text
                        (addr conn)
                        "[[:db/add \"oleg\" :name \"Oleg\"] [:db/add \"oleg\" :email \"@2\"]]")
        by-lookup-ref (vev.transact-text
                        (addr conn)
                        "[{:ref [:name \"Dima\"] :age 38}]")
        prepared (vev.prepare-tx-text
                   "[{:db/id \"igor-1\" :name \"Igor\" :age 35} {:db/id \"igor-2\" :name \"Igor\" :age 36}]")
        intermediate (vev.transact-prepared (addr conn) prepared)
        forward-refs (vev.transact-text
                       (addr conn)
                       "[{:db/id 10 :friend \"alice\"} {:db/id 11 :friend \"petr\"} {:db/id \"alice\" :name \"Ivan\"} {:db/id \"petr\" :email \"@2\"}]")
        negative-ref (vev.transact-text
                       (addr conn)
                       "[{:db/id -1 :name \"Nina\"} {:age 39 :friend -1}]")
        before-conflict-count (count conn.db.datoms)
        conflict (vev.transact-text
                   (addr conn)
                   "[{:name \"Ivan\" :email \"@2\" :age 50}]")
        after-conflict-count (count conn.db.datoms)
        [ivan-age ivan-age-ok] (vev.q-text-scalar
                                 conn.db
                                 "[:find ?age . :where [1 :age ?age]]")
        [petr-age petr-age-ok] (vev.q-text-scalar
                                 conn.db
                                 "[:find ?age . :where [2 :age ?age]]")
        [igor-age igor-age-ok] (vev.q-text-scalar
                                 conn.db
                                 "[:find ?age . :where [?e :name \"Igor\"] [?e :age ?age]]")
        [first-ref first-ref-ok] (vev.q-text-scalar
                                   conn.db
                                   "[:find ?ref . :where [10 :friend ?ref]]")
        [second-ref second-ref-ok] (vev.q-text-scalar
                                     conn.db
                                     "[:find ?ref . :where [11 :friend ?ref]]")
        [nina-ref nina-ref-ok] (vev.q-text-scalar
                                 conn.db
                                 "[:find ?ref . :where [?e :age 39] [?e :friend ?ref]]")
        [nina nina-ok] (vev.q-text-scalar
                         conn.db
                         "[:find ?e . :where [?e :name \"Nina\"]]")
        [ivan-e ivan-ok] (tempid-e (slice with-tempid.tempids 0) "ivan")
        [list-e list-ok] (tempid-e (slice list-tempid.tempids 0) "ivan-list")
        [oleg-e oleg-ok] (tempid-e (slice second-tempid.tempids 0) "oleg")
        [igor-1 igor-1-ok] (tempid-e (slice intermediate.tempids 0) "igor-1")
        [igor-2 igor-2-ok] (tempid-e (slice intermediate.tempids 0) "igor-2")
        [alice alice-ok] (tempid-e (slice forward-refs.tempids 0) "alice")
        [petr petr-ok] (tempid-e (slice forward-refs.tempids 0) "petr")]
    (t.is no-id.ok)
    (t.is no-id-two-attrs.ok)
    (t.is with-tempid.ok)
    (t.is list-tempid.ok)
    (t.is second-tempid.ok)
    (t.is by-lookup-ref.ok)
    (t.is intermediate.ok)
    (t.is forward-refs.ok)
    (t.is negative-ref.ok)
    (t.is ivan-ok)
    (t.is (= ivan-e 1))
    (t.is list-ok)
    (t.is (= list-e 1))
    (t.is oleg-ok)
    (t.is (= oleg-e 2))
    (t.is igor-1-ok)
    (t.is igor-2-ok)
    (t.is (= igor-1 igor-2))
    (t.is alice-ok)
    (t.is (= alice 1))
    (t.is petr-ok)
    (t.is (= petr 2))
    (t.is ivan-age-ok)
    (t.is (= ivan-age.int-value 37))
    (t.is petr-age-ok)
    (t.is (= petr-age.int-value 38))
    (t.is igor-age-ok)
    (t.is (= igor-age.int-value 36))
    (t.is first-ref-ok)
    (t.is (= first-ref.entity 1))
    (t.is second-ref-ok)
    (t.is (= second-ref.entity 2))
    (t.is nina-ref-ok)
    (t.is nina-ok)
    (t.is (= nina-ref.entity nina.entity))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "conflicting upsert"))
    (t.is (= before-conflict-count after-conflict-count))))

(t.deftest transact-data-resolves-lookup-refs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :user/email]
                [:db/add 100 :db/valueType :db.type/string]
                [:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.transact
               (addr conn)
               [[:db/add 1 :user/email "ada@example.com"]])
        report (vev.transact
                   (addr conn)
                   [[:db/add [:user/email "ada@example.com"] :user/name "Ada"]])
        non-unique (vev.transact
                     (addr conn)
                     [[:db/add [:user/name "Ada"] :user/title "Bad"]])
        missing (vev.transact
                    (addr conn)
                    [[:db/add [:user/email "missing@example.com"] :user/name "Missing"]])
        result (vev.q report.db-after
                   [:find ?name
                    :where
                    [1 :user/name ?name]])]
      (t.is report.ok)
      (t.is (= report.tx-data[0].e 1))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text "Ada"))
      (t.is (not non-unique.ok))
      (t.is (= non-unique.error "lookup ref attribute must be unique"))
      (t.is (not missing.ok))
      (t.is (= missing.error "lookup ref not found"))))

(t.deftest datascript-lookup-ref-transact-value-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :friend]
             [:db/add 101 :db/valueType :db.type/ref]])
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan"}
             {:db/id 2 :name "Petr"}])
        add-report (vev.transact
                     (addr conn)
                     [[:db/add 1 :friend [:name "Petr"]]])
        add-result (vev.q add-report.db-after
                     [:find ?friend
                      :where
                      [1 :friend ?friend]])
        retract-report (vev.transact
                         (addr conn)
                         [[:db/retract 1 :friend [:name "Petr"]]])
        retract-result (vev.q retract-report.db-after
                         [:find ?friend
                          :where
                          [1 :friend ?friend]])]
    (t.is add-report.ok)
    (t.is (= (count add-result.rows) 1))
    (t.is (= add-result.rows[0].values[0].entity 2))
    (t.is retract-report.ok)
    (t.is (= (count retract-result.rows) 0))))

