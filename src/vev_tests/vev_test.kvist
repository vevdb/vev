    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].int-value 19))
    (t.is (= (count long.rows) 1))
    (t.is (= long.rows[0].values[0].int-value 1))
    (t.is (= long.rows[0].values[1].text ":age"))
    (t.is (= long.rows[0].values[2].int-value 39))
    (t.is (= long.rows[0].values[3].int-value 999))))

(t.deftest datascript-query-primary-collection-db-prepared-rules-and-fns-subset
  (defer (free_all context.allocator))
  (let [rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 17)]))]))
        registry ([]vev.Native-Query-Fn [(vev.query-fn "adult-age?" ">=")
                                         (vev.query-fn "mk-keyword" "keyword")])
        prepared (vev.prepare-query-text "[:find ?name :in ?min :where [?e :age ?age] [(>= ?age ?min)] [?e :name ?name]]")
        prepared-result (vev.q-prepared-relation-db-with-inputs
                          rows
                          prepared
                          ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 18))]))
        prepared-fn (vev.prepare-query-text "[:find ?tag :where [?e :age ?age] [(adult-age? ?age 18)] [(mk-keyword \"adult\") ?tag]]")
        prepared-fn-result (vev.q-prepared-relation-db-with-fns rows prepared-fn registry)
        text-fn-result (vev.q-text-relation-db-with-fns
                         rows
                         "[:find ?e :where [?e :age ?age] [(adult-age? ?age 18)]]"
                         registry)
        rule-result (vev.q-text-relation-db-with-rules
                      rows
                      "[:find ?name :in % :where (adult ?e) [?e :name ?name]]"
                      "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]]]"
                      ([]vev.Query-Input []))
        prepared-rule-query (vev.prepare-query-text "[:find ?name :in % :where (adult ?e) [?e :name ?name]]")
        prepared-rules (vev.parse-rules-text "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]]]")
        prepared-rule-result (vev.q-prepared-relation-db-with-rules
                               rows
                               prepared-rule-query
                               prepared-rules
                               ([]vev.Query-Input []))
        rule-fn-result (vev.q-text-relation-db-with-rules-and-fns
                         rows
                         "[:find ?name :in % :where (adult ?e) [?e :name ?name]]"
                         "[[(adult ?e) [?e :age ?age] [(adult-age? ?age 18)]]]"
                         ([]vev.Query-Input [])
                         registry)
        prepared-rule-fn-query (vev.prepare-query-text "[:find ?name :in % :where (adult ?e) [?e :name ?name]]")
        prepared-fn-rules (vev.parse-rules-text "[[(adult ?e) [?e :age ?age] [(adult-age? ?age 18)]]]")
        prepared-rule-fn-result (vev.q-prepared-relation-db-with-rules-and-fns
                                  rows
                                  prepared-rule-fn-query
                                  prepared-fn-rules
                                  ([]vev.Query-Input [])
                                  registry)]
    (t.is prepared.ok)
    (t.is prepared-result.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].text "Ivan"))
    (t.is prepared-fn.ok)
    (t.is prepared-fn-result.ok)
    (t.is (= (count prepared-fn-result.rows) 1))
    (t.is (= prepared-fn-result.rows[0].values[0].text ":adult"))
    (t.is text-fn-result.ok)
    (t.is (= (count text-fn-result.rows) 1))
    (t.is (= text-fn-result.rows[0].values[0].int-value 1))
    (t.is rule-result.ok)
    (t.is (= (count rule-result.rows) 1))
    (t.is (= rule-result.rows[0].values[0].text "Ivan"))
    (t.is prepared-rule-query.ok)
    (t.is prepared-rules.ok)
    (t.is prepared-rule-result.ok)
    (t.is (= (count prepared-rule-result.rows) 1))
    (t.is (= prepared-rule-result.rows[0].values[0].text "Ivan"))
    (t.is rule-fn-result.ok)
    (t.is (= (count rule-fn-result.rows) 1))
    (t.is (= rule-fn-result.rows[0].values[0].text "Ivan"))
    (t.is prepared-rule-fn-query.ok)
    (t.is prepared-fn-rules.ok)
    (t.is prepared-rule-fn-result.ok)
    (t.is (= (count prepared-rule-fn-result.rows) 1))
    (t.is (= prepared-rule-fn-result.rows[0].values[0].text "Ivan"))))

(t.deftest datascript-query-v3-primary-collection-patterns-subset
  (defer (free_all context.allocator))
  (let [pairs (vev.value-vector
                ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2)]))
                               (vev.value-vector ([]vev.Value [(vev.value-int 3) (vev.value-int 3)]))
                               (vev.value-vector ([]vev.Value [(vev.value-int 4) (vev.value-int 5)]))
                               (vev.value-vector ([]vev.Value [(vev.value-int 6) (vev.value-int 6)]))]))
        scalars (vev.value-vector
                  ([]vev.Value [(vev.value-int 1)
                                (vev.value-int 2)
                                (vev.value-int 2)
                                (vev.value-int 3)]))
        map-source (vev.value-map
                     ([]vev.Value [(vev.value-keyword ":a") (vev.value-int 1)
                                   (vev.value-keyword ":b") (vev.value-int 2)
                                   (vev.value-keyword ":c") (vev.value-int 2)]))
        conn (vev.create-conn)
        pair-result (vev.q-text-relation-db
                      pairs
                      "[:find ?a :where [?a ?a]]")
        explicit-primary (vev.q-text-relation-db-with-inputs
                           pairs
                           "[:find ?a :in $ ?wanted :where [?a ?wanted]]"
                           ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 3))]))
        explicit-primary-prepared (vev.q-prepared-relation-db-with-inputs
                                    pairs
                                    (vev.prepare-query-text "[:find ?a :in $ ?wanted :where [?a ?wanted]]")
                                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 6))]))
        missing-explicit-input (vev.q-text-relation-db-with-inputs
                                 pairs
                                 "[:find ?a :in $ ?wanted :where [?a ?wanted]]"
                                 ([]vev.Query-Input []))
        extra-implicit-input (vev.q-text-relation-db-with-inputs
                               pairs
                               "[:find ?a :where [?a ?a]]"
                               ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 3))]))
        scalar-primary (vev.q-text-relation-db
                         scalars
                         "[:find ?a :where [?a]]")
        map-primary (vev.q-text-relation-db
                      map-source
                      "[:find ?k ?v :where [?k ?v]]")
        map-filtered (vev.q-text-relation-db
                       map-source
                       "[:find ?k :where [?k 2]]")
        scalar-named (vev.q-text-with-inputs
                       conn.db
                       "[:find ?a :in $xs :where [$xs ?a]]"
                       ([]vev.Query-Input [(vev.query-input-scalar scalars)]))]
    (t.is pair-result.ok)
    (t.is (= (count pair-result.rows) 2))
    (t.is (= pair-result.rows[0].values[0].int-value 3))
    (t.is (= pair-result.rows[1].values[0].int-value 6))
    (t.is explicit-primary.ok)
    (t.is (= (count explicit-primary.rows) 1))
    (t.is (= explicit-primary.rows[0].values[0].int-value 3))
    (t.is explicit-primary-prepared.ok)
    (t.is (= (count explicit-primary-prepared.rows) 1))
    (t.is (= explicit-primary-prepared.rows[0].values[0].int-value 6))
    (t.is (not missing-explicit-input.ok))
    (t.is (= missing-explicit-input.error "wrong number of query inputs: expected 2, got 1"))
    (t.is (not extra-implicit-input.ok))
    (t.is (= extra-implicit-input.error "wrong number of query inputs: expected 1, got 2"))
    (t.is scalar-primary.ok)
    (t.is (= (count scalar-primary.rows) 3))
    (t.is (= scalar-primary.rows[0].values[0].int-value 1))
    (t.is (= scalar-primary.rows[1].values[0].int-value 2))
    (t.is (= scalar-primary.rows[2].values[0].int-value 3))
    (t.is map-primary.ok)
    (t.is (= (count map-primary.rows) 3))
    (t.is (= map-primary.rows[0].values[0].text ":a"))
    (t.is (= map-primary.rows[0].values[1].int-value 1))
    (t.is (= map-primary.rows[1].values[0].text ":b"))
    (t.is (= map-primary.rows[1].values[1].int-value 2))
    (t.is (= map-primary.rows[2].values[0].text ":c"))
    (t.is (= map-primary.rows[2].values[1].int-value 2))
    (t.is map-filtered.ok)
    (t.is (= (count map-filtered.rows) 2))
    (t.is (= map-filtered.rows[0].values[0].text ":b"))
    (t.is (= map-filtered.rows[1].values[0].text ":c"))
    (t.is scalar-named.ok)
    (t.is (= (count scalar-named.rows) 3))
    (t.is (= scalar-named.rows[0].values[0].int-value 1))
    (t.is (= scalar-named.rows[1].values[0].int-value 2))
    (t.is (= scalar-named.rows[2].values[0].int-value 3))))

(t.deftest datascript-query-rejects-non-collection-sources-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        primary (vev.q-text-relation-db
                  (vev.value-keyword ":not-a-source")
                  "[:find ?e :where [?e :name]]")
        named (vev.q-text-with-inputs
                conn.db
                "[:find ?e :in $rows :where [$rows ?e :name]]"
                ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":not-a-source"))]))
        named-ok (vev.q-text-with-inputs
                   conn.db
                   "[:find ?e :in $rows :where [$rows ?e :name]]"
                   ([]vev.Query-Input
                     [(vev.query-input-scalar
                        (vev.value-vector
                          ([]vev.Value
                            [(vev.value-vector
                               ([]vev.Value [(vev.value-int 1)
                                             (vev.value-keyword ":name")]))])))]))]
    (t.is (not primary.ok))
    (t.is (= primary.error "query source is not a collection: __vev_primary_relation_db"))
    (t.is (not named.ok))
    (t.is (= named.error "query source is not a collection: $rows"))
    (t.is named-ok.ok)
    (t.is (= (count named-ok.rows) 1))
    (t.is (= named-ok.rows[0].values[0].int-value 1))))

(t.deftest datascript-parser-query-text-source-qualified-rules
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Petr")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 17)]))]))
        parsed-query (vev.empty-query)
        parsed-rules (make [dynamic]vev.Rule) :defer
        [query-ok query-error] (vev.parse-query-text! (addr parsed-query) "[:find ?name :in $rows % :where ($rows adult-name ?e ?name)]")
        [rules-ok rules-error] (vev.parse-rules-text! (addr parsed-rules) "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) ($rows adult ?e) [?e :name ?name]]]")
        simple (vev.q-text-with-rules
                 conn.db
                 "[:find ?name :in $rows % :where ($rows named ?e ?name)]"
                 "[[(named ?e ?name) [?e :name ?name]]]"
                 ([]vev.Query-Input [(vev.query-input-scalar rows)]))
        direct (vev.q-text-with-rules
                 conn.db
                 "[:find ?name :in $rows % :where ($rows adult-name ?e ?name)]"
                 "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) ($rows adult ?e) [?e :name ?name]]]"
                 ([]vev.Query-Input [(vev.query-input-scalar rows)]))]
    (t.is query-ok query-error)
    (t.is rules-ok rules-error)
    (t.is (= (count parsed-query.rule-calls) 1))
    (t.is parsed-query.rule-calls[0].has-source)
    (t.is (= parsed-query.rule-calls[0].source "$rows"))
    (t.is (= parsed-query.rule-calls[0].name "adult-name"))
    (t.is (= (count parsed-rules) 2))
    (t.is (= (count parsed-rules[1].rule-calls) 1))
    (t.is parsed-rules[1].rule-calls[0].has-source)
    (t.is (= parsed-rules[1].rule-calls[0].source "$rows"))
    (t.is (= parsed-rules[1].rule-calls[0].name "adult"))
    (t.is (= (count simple.rows) 2))
    (t.is (= simple.rows[0].values[0].text "Ivan"))
    (t.is (= simple.rows[1].values[0].text "Petr"))
    (t.is (= (count direct.rows) 1))
    (t.is (= direct.rows[0].values[0].text "Ivan"))))

(t.deftest datascript-parser-map-query-inline-rules-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 19}
             {:db/id 2 :name "Petr" :age 17}])
        rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ada")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 20)]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":name") (vev.value-string "Grace")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":age") (vev.value-int 16)]))]))
        parsed (vev.empty-query)
        [parse-ok parse-error] (vev.parse-query-text!
                                 (addr parsed)
                                 "{:find [?name] :where [(adult-name ?e ?name)] :rules [[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) (adult ?e) [?e :name ?name]]]}")
        result (vev.q-text
                 conn.db
                 "{:find [?name] :where [(adult-name ?e ?name)] :rules [[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) (adult ?e) [?e :name ?name]]]}")
        prepared (vev.prepare-query-text
                   "{:find [?name] :where [(adult-name ?e ?name)] :rules [[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) (adult ?e) [?e :name ?name]]]}")
        prepared-result (vev.q-prepared conn.db prepared)
        source-result (vev.q-text-with-inputs
                        conn.db
                        "{:find [?name] :in [$rows] :where [($rows adult-name ?e ?name)] :rules [[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) ($rows adult ?e) [?e :name ?name]]]}"
                        ([]vev.Query-Input [(vev.query-input-scalar rows)]))
        malformed (vev.q-text
                    conn.db
                    "{:find [?name] :where [(named ?e ?name)] :rules [(named ?e ?name)]}")]
    (t.is parse-ok parse-error)
    (t.is (= (count parsed.rules) 2))
    (t.is (= (count parsed.rule-calls) 1))
    (t.is (= parsed.rule-calls[0].name "adult-name"))
    (t.is result.ok)
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is prepared.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].text "Ivan"))
    (t.is source-result.ok)
    (t.is (= (count source-result.rows) 1))
    (t.is (= source-result.rows[0].values[0].text "Ada"))
    (t.is (not malformed.ok))
    (t.is (= malformed.error "rule definitions must be vectors"))))

(t.deftest datascript-parser-query-text-not-or-and-missing
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :active true :email "ada@example.com"}
             {:db/id 2 :name "Grace Hopper" :active false}
             {:db/id 3 :name "Alan Turing" :active true}])
        missing-email (vev.q-text conn.db "[:find ?name :where [?e :name ?name] [(missing? $ ?e :email)]]")
        inactive-or-ada (vev.q-text conn.db "[:find ?name :where [?e :name ?name] (or [?e :active false] [?e :name \"Ada Lovelace\"])]")
        active-no-email (vev.q-text conn.db "[:find ?name :where [?e :active true] [?e :name ?name] (not [?e :email _])]")
        top-level-and (vev.q-text conn.db "[:find ?name :where (and [?e :active true] [?e :name ?name] [(not= ?name \"Alan Turing\")])]")
        nested-and (vev.q-text conn.db "[:find ?name :where (and [?e :active true] (and [?e :name ?name] [(not= ?name \"Alan Turing\")]))]")
        rule-no-args (vev.q-text conn.db "[:find ?e :in $ % :where (friends)]")
        not-no-clauses (vev.q-text conn.db "[:find ?e :where (not)]")
        not-empty-vars (vev.q-text conn.db "[:find ?e :where [?e :name] (not [_])]")
        not-join-no-clauses (vev.q-text conn.db "[:find ?e :where (not-join [?e])]")
        not-join-empty-vars (vev.q-text conn.db "[:find ?e :where (not-join [] [?e :name])]")
        or-no-branches (vev.q-text conn.db "[:find ?e :where (or)]")
        or-empty-vars (vev.q-text conn.db "[:find ?e :where [?e :name] (or [_])]")
        or-join-no-branches (vev.q-text conn.db "[:find ?e :where (or-join [?e])]")
        or-join-empty-vars (vev.q-text conn.db "[:find ?e :where (or-join [] [?e :name])]")
        nested-not (vev.q-text conn.db "[:find ?name :where [?e :name ?name] (not [?e :name \"Ada Lovelace\"] (not [?e :active true]))]")]
    (t.is (= (count missing-email.rows) 2))
    (t.is (= missing-email.rows[0].values[0].text "Grace Hopper"))
    (t.is (= missing-email.rows[1].values[0].text "Alan Turing"))
    (t.is (= (count inactive-or-ada.rows) 2))
    (t.is (= inactive-or-ada.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= inactive-or-ada.rows[1].values[0].text "Grace Hopper"))
    (t.is (= (count active-no-email.rows) 1))
    (t.is (= active-no-email.rows[0].values[0].text "Alan Turing"))
    (t.is (= (count top-level-and.rows) 1))
    (t.is (= top-level-and.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= (count nested-and.rows) 1))
    (t.is (= nested-and.rows[0].values[0].text "Ada Lovelace"))
    (t.is (not rule-no-args.ok))
    (t.is (= rule-no-args.error "rule-expr requires at least one argument"))
    (t.is (not not-no-clauses.ok))
    (t.is (= not-no-clauses.error "Cannot parse 'not' clause"))
    (t.is (not not-empty-vars.ok))
    (t.is (= not-empty-vars.error "Join variables should not be empty"))
    (t.is (not not-join-no-clauses.ok))
    (t.is (= not-join-no-clauses.error "Cannot parse 'not-join' clause"))
    (t.is (not not-join-empty-vars.ok))
    (t.is (= not-join-empty-vars.error "Join variables should not be empty"))
    (t.is (not or-no-branches.ok))
    (t.is (= or-no-branches.error "Cannot parse 'or' clause"))
    (t.is (not or-empty-vars.ok))
    (t.is (= or-empty-vars.error "Join variables should not be empty"))
    (t.is (not or-join-no-branches.ok))
    (t.is (= or-join-no-branches.error "Cannot parse 'or-join' clause"))
    (t.is (not or-join-empty-vars.ok))
    (t.is (= or-join-empty-vars.error "Join variables should not be empty"))
    (t.is (= (count nested-not.rows) 3))
    (t.is (= nested-not.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= nested-not.rows[1].values[0].text "Grace Hopper"))
    (t.is (= nested-not.rows[2].values[0].text "Alan Turing"))))

(t.deftest datascript-parser-query-text-not-join-or-join
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        not-join (vev.q-text-collection
                   report.db-after
                   "[:find [?name ...] :where [?e :user/name ?name] (not-join [?e] [?e :user/friend ?friend] [?friend :user/name ?name])]")
        or-join (vev.q-text-collection
                  report.db-after
                  "[:find [?label ...] :where [?e :user/name ?name] (or-join [?e ?label] (and [?e :user/active true] [?e :user/name ?label]) (and [?e :user/active false] [?e :user/email ?label]))]")]
    (t.is (= (count not-join) 1))
    (t.is (= not-join[0].text "Grace"))
    (t.is (= (count or-join) 2))
    (t.is (= or-join[0].text "Ada"))
    (t.is (= or-join[1].text "grace@example.com"))))

(t.deftest datascript-parser-query-text-pull-find
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 101 :db/ident :missing]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Ada Lovelace" :friend (vev.value-entity 2)}
             {:db/id 2 :name "Grace Hopper"}
             {:db/id 3 :name "Alan Turing"}
             [:db/add 1 :friend 3]])
        pulled (vev.q-text conn.db "[:find (pull ?e [:db/id :name]) :where [?e :name \"Ada Lovelace\"]]")
        entity-and-pull (vev.q-text conn.db "[:find ?e (pull ?e [:name]) :where [?e :name \"Ada Lovelace\"]]")
        nested (vev.q-text conn.db "[:find (pull ?e [{:friend [:name]}]) :where [?e :name \"Ada Lovelace\"]]")
        options (vev.q-text conn.db "[:find (pull ?e [[:missing :default \"Unknown\" :as :nickname] [:name :as :full-name] [:friend :limit 1]]) :where [?e :name \"Ada Lovelace\"]]")
        nested-options (vev.q-text conn.db "[:find (pull ?e [(default (limit :missing 1) \"Unknown\") ((limit :friend 1) :as :first-friend)]) :where [?e :name \"Ada Lovelace\"]]")
        map-key-options (vev.q-text conn.db "[:find (pull ?e [{((limit :friend 1) :as :first-friend) [:name]}]) :where [?e :name \"Ada Lovelace\"]]")
        recursive-map (vev.q-text conn.db "[:find (pull ?e [:db/id {:friend 1}]) :where [?e :name \"Ada Lovelace\"]]")]
    (t.is (= (count pulled.rows) 1))
    (t.is (= (count pulled.rows[0].values) 0))
    (t.is (= (count pulled.rows[0].pulls) 1))
    (t.is (= pulled.rows[0].pulls[0].attrs[0].v.entity 1))
    (t.is (= pulled.rows[0].pulls[0].attrs[1].v.text "Ada Lovelace"))
    (t.is (= (count entity-and-pull.rows) 1))
    (t.is (= entity-and-pull.rows[0].values[0].entity 1))
    (t.is (= entity-and-pull.rows[0].pulls[0].attrs[0].v.text "Ada Lovelace"))
    (t.is (= (count nested.rows) 1))
    (t.is (= nested.rows[0].pulls[0].attrs[0].v.entity 2))
    (t.is (= nested.rows[0].pulls[0].attrs[0].attrs[0].v.text "Grace Hopper"))
    (t.is (= options.rows[0].pulls[0].attrs[0].a ":nickname"))
    (t.is (= options.rows[0].pulls[0].attrs[0].v.text "Unknown"))
    (t.is (= options.rows[0].pulls[0].attrs[1].a ":full-name"))
    (t.is (= options.rows[0].pulls[0].attrs[1].v.text "Ada Lovelace"))
    (t.is (= (count options.rows[0].pulls[0].attrs) 3))
    (t.is (= options.rows[0].pulls[0].attrs[2].v.entity 2))
    (t.is (= nested-options.rows[0].pulls[0].attrs[0].a ":missing"))
    (t.is (= nested-options.rows[0].pulls[0].attrs[0].v.text "Unknown"))
    (t.is (= nested-options.rows[0].pulls[0].attrs[1].a ":first-friend"))
    (t.is (= nested-options.rows[0].pulls[0].attrs[1].v.entity 2))
    (t.is (= (count map-key-options.rows[0].pulls[0].attrs) 1))
    (t.is (= map-key-options.rows[0].pulls[0].attrs[0].a ":first-friend"))
    (t.is (= map-key-options.rows[0].pulls[0].attrs[0].v.entity 2))
    (t.is (= map-key-options.rows[0].pulls[0].attrs[0].attrs[0].v.text "Grace Hopper"))
    (t.is (= recursive-map.rows[0].pulls[0].attrs[0].v.entity 1))
    (t.is (= recursive-map.rows[0].pulls[0].attrs[1].v.entity 2))
    (t.is (= recursive-map.rows[0].pulls[0].attrs[1].attrs[0].v.entity 2))))

(t.deftest datascript-parser-query-text-find-specs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Petr" :age 44}
             {:db/id 2 :name "Ivan" :age 25}
             {:db/id 3 :name "Sergey" :age 11}])
        names (vev.q-text-collection conn.db "[:find [?name ...] :where [?e :name ?name]]")
        tuple (vev.q-text-tuple conn.db "[:find [?name ?age] :where [1 :name ?name] [1 :age ?age]]")
        [scalar scalar-ok] (vev.q-text-scalar conn.db "[:find ?name . :where [1 :name ?name]]")
        count-coll (vev.q-text-collection conn.db "[:find [(count ?name) ...] :where [?e :name ?name]]")
        [count-scalar count-scalar-ok] (vev.q-text-scalar conn.db "[:find (count ?name) . :where [?e :name ?name]]")
        top (vev.q-text conn.db "[:find (min 2 ?age) :where [?e :age ?age]]")
          keys (vev.q-text-keys conn.db "[:find ?name ?age :keys name age :where [?e :name ?name] [?e :age ?age]]")
          duplicate-return-map (vev.q-text conn.db "[:find ?name ?age :keys name age :strs n a :where [?e :name ?name] [?e :age ?age]]")
          short-return-map (vev.q-text conn.db "[:find ?name ?age :keys name :where [?e :name ?name] [?e :age ?age]]")
          short-strs-return-map (vev.q-text conn.db "[:find ?name ?age :strs name :where [?e :name ?name] [?e :age ?age]]")
          long-syms-return-map (vev.q-text conn.db "[:find ?name ?age :syms name age extra :where [?e :name ?name] [?e :age ?age]]")
          collection-return-map (vev.q-text conn.db "[:find [?name ...] :keys name :where [?e :name ?name]]")
          scalar-return-map (vev.q-text conn.db "[:find ?name . :keys name :where [?e :name ?name]]")
          map-short-return-map (vev.q-text conn.db "{:find [?name ?age] :keys [name] :where [[?e :name ?name] [?e :age ?age]]}")
          map-strs-short-return-map (vev.q-text conn.db "{:find [?name ?age] :strs [name] :where [[?e :name ?name] [?e :age ?age]]}")
          map-syms-long-return-map (vev.q-text conn.db "{:find [?name ?age] :syms [name age extra] :where [[?e :name ?name] [?e :age ?age]]}")
          map-collection-return-map (vev.q-text conn.db "{:find [?name ...] :keys [name] :where [[?e :name ?name]]}")
          map-scalar-return-map (vev.q-text conn.db "{:find [?name .] :keys [name] :where [[?e :name ?name]]}")]
    (t.is (= (count names) 3))
    (t.is (= names[0].text "Petr"))
    (t.is (= names[1].text "Ivan"))
    (t.is (= names[2].text "Sergey"))
    (t.is (= (count tuple) 2))
    (t.is (= tuple[0].text "Petr"))
    (t.is (= tuple[1].int-value 44))
    (t.is scalar-ok)
    (t.is (= scalar.text "Petr"))
    (t.is (= (count count-coll) 1))
    (t.is (= count-coll[0].int-value 3))
    (t.is count-scalar-ok)
    (t.is (= count-scalar.int-value 3))
    (t.is (= (count top.rows) 1))
    (t.is (= (count top.rows[0].values[0].items) 2))
    (t.is (= top.rows[0].values[0].items[0].int-value 11))
    (t.is (= top.rows[0].values[0].items[1].int-value 25))
    (t.is (= (count keys) 3))
    (t.is (= keys[0].items[0].kind .Keyword))
    (t.is (= keys[0].items[0].key "name"))
    (t.is (= keys[0].items[0].value.text "Petr"))
    (t.is (= keys[0].items[1].key "age"))
      (t.is (= keys[0].items[1].value.int-value 44))
      (t.is (not duplicate-return-map.ok))
      (t.is (= duplicate-return-map.error "Only one of :keys/:syms/:strs must be present"))
      (t.is (not short-return-map.ok))
      (t.is (= short-return-map.error "Count of :keys must match count of :find"))
      (t.is (not short-strs-return-map.ok))
      (t.is (= short-strs-return-map.error "Count of :strs must match count of :find"))
      (t.is (not long-syms-return-map.ok))
      (t.is (= long-syms-return-map.error "Count of :syms must match count of :find"))
      (t.is (not collection-return-map.ok))
      (t.is (= collection-return-map.error ":keys does not work with collection :find"))
      (t.is (not scalar-return-map.ok))
      (t.is (= scalar-return-map.error ":keys does not work with single-scalar :find"))
      (t.is (not map-short-return-map.ok))
      (t.is (= map-short-return-map.error "Count of :keys must match count of :find"))
      (t.is (not map-strs-short-return-map.ok))
      (t.is (= map-strs-short-return-map.error "Count of :strs must match count of :find"))
      (t.is (not map-syms-long-return-map.ok))
      (t.is (= map-syms-long-return-map.error "Count of :syms must match count of :find"))
      (t.is (not map-collection-return-map.ok))
      (t.is (= map-collection-return-map.error ":keys does not work with collection :find"))
      (t.is (not map-scalar-return-map.ok))
      (t.is (= map-scalar-return-map.error ":keys does not work with single-scalar :find"))))

(t.deftest datascript-parser-tx-text-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        set-conn (vev.create-conn)
        prepared (vev.prepare-tx-text "[{:db/id 10 :user/name \"Prepared\"}]")
        prepared-report (vev.transact-prepared (addr conn) prepared)
        prepared-name (vev.q-text
                        prepared-report.db-after
                        "[:find ?name :where [10 :user/name ?name]]")
        bad-prepared (vev.prepare-tx-text "{:db/id 1}")
        bad-prepared-report (vev.transact-prepared (addr conn) bad-prepared)
        schema (vev.transact-text
                 (addr conn)
                 "[[:db/add 100 :db/ident :user/email] [:db/add 100 :db/valueType :db.type/string] [:db/add 100 :db/unique :db.unique/identity] [:db/add 101 :db/ident :user/friend] [:db/add 101 :db/valueType :db.type/ref] [:db/add 102 :db/ident :user/address] [:db/add 102 :db/valueType :db.type/ref]]")
        initial (vev.transact-text
                  (addr conn)
                  "[[:db/add 1 :user/email \"ada@example.com\"] [:db/add 1 :user/name \"Ada\"] [:db/add 1 :user/score 42.5] [:db/add 1 :user/friend [:user/email \"ada@example.com\"]] {:db/id \"grace\" :user/name \"Grace\" :user/friend 1} {:user/name \"Generated\"} {:db/id [:user/email \"ada@example.com\"] :user/age 37} {:db/id 3 :user/name \"Parent\" :user/address {:user/city \"London\"}}]")
        set-values (vev.transact-text
                     (addr set-conn)
                     "[[:db/add 101 :db/ident :user/friend] [:db/add 101 :db/valueType :db.type/ref] [:db/add 101 :db/cardinality :db.cardinality/many] {:db/id 4 :user/name \"Set User\" :user/friend #{1 3}}]")
        names (vev.q-text
                initial.db-after
                "[:find ?name :where [?e :user/name ?name]]")
        age (vev.q-text
              initial.db-after
              "[:find ?age :where [1 :user/age ?age]]")
        score (vev.q-text
                initial.db-after
                "[:find ?score :where [1 :user/score ?score]]")
        score-match (vev.q-text
                      initial.db-after
                      "[:find ?e :where [?e :user/score 42.5]]")
        nested (vev.q-text
                 initial.db-after
                 "[:find ?city :where [3 :user/address ?address] [?address :user/city ?city]]")
        cas (vev.transact-text
              (addr conn)
              "[[:db.fn/cas 1 :user/friend [:user/email \"ada@example.com\"] 3]]")
        friend (vev.q-text
                 cas.db-after
                 "[:find ?friend :where [1 :user/friend ?friend]]")
        set-friends (vev.q-text-collection
                      set-values.db-after
                      "[:find [?friend ...] :where [4 :user/friend ?friend]]")
        set-ground (vev.q-text-collection
                     set-values.db-after
                     "[:find [?x ...] :where [(ground #{:a :b}) [?x ...]]]")
        retract (vev.transact-text
                  (addr conn)
                  "[[:db/retract 1 :user/name \"Ada\"] [:db.fn/retractAttribute 3 :user/address] [:db.fn/retractEntity [:user/email \"ada@example.com\"]]]")
        remaining (vev.q-text
                    retract.db-after
                    "[:find ?e :where [?e :user/email \"ada@example.com\"]]")]
    (t.is prepared.ok)
    (t.is prepared-report.ok)
    (t.is (= (count prepared-name.rows) 1))
    (t.is (= prepared-name.rows[0].values[0].text "Prepared"))
    (t.is (not bad-prepared.ok))
    (t.is (not bad-prepared-report.ok))
    (t.is schema.ok)
    (t.is initial.ok)
    (t.is (>= (count names.rows) 3))
    (t.is (= age.rows[0].values[0].int-value 37))
    (t.is (= score.rows[0].values[0].kind .Float))
    (t.is (= score.rows[0].values[0].float-value 42.5))
    (t.is (= score-match.rows[0].values[0].entity 1))
    (t.is (= nested.rows[0].values[0].text "London"))
    (t.is cas.ok)
    (t.is (= friend.rows[0].values[0].entity 3))
    (t.is set-values.ok)
    (t.is (= (count set-friends) 2))
    (t.is (= set-friends[0].entity 1))
    (t.is (= set-friends[1].entity 3))
    (t.is (= (count set-ground) 2))
    (t.is (= set-ground[0].text ":a"))
    (t.is (= set-ground[1].text ":b"))
    (t.is retract.ok)
    (t.is (= (count remaining.rows) 0))))

(t.deftest edn-reader-parses-nested-forms
  (defer (free_all context.allocator))
  (let [doc (vev.empty-edn-doc)
        [ok error] (vev.read-edn-text! (addr doc) "[:find (pull ?e [:name {:friend [:name]}]) :where [?e :active true] [?e :score 42.5]]")
        set-doc (vev.empty-edn-doc)
        [set-ok set-error] (vev.read-edn-text! (addr set-doc) "#{:a :b}")
        bad (vev.empty-edn-doc)
        [bad-ok bad-error] (vev.read-edn-text! (addr bad) "[:find ?e] trailing")]
    (defer (delete doc.nodes))
    (defer (delete set-doc.nodes))
    (defer (delete bad.nodes))
    (t.is ok)
    (t.is (= error ""))
    (when ok
      (let [root doc.nodes[doc.root]
            first doc.nodes[root.first-child]
            second doc.nodes[first.next-sibling]
            pull-symbol doc.nodes[second.first-child]
            pull-var doc.nodes[pull-symbol.next-sibling]
            pattern doc.nodes[pull-var.next-sibling]
            nested-map doc.nodes[doc.nodes[pattern.first-child].next-sibling]
            score-clause (vev.edn-child-at doc doc.root 4)
            score-value (vev.edn-child-at doc score-clause 2)]
        (t.is (= root.kind .Vector))
        (t.is (= root.child-count 5))
        (t.is (= first.kind .Keyword))
        (t.is (= first.text ":find"))
        (t.is (= second.kind .List))
        (t.is (= second.child-count 3))
        (t.is (= pull-symbol.kind .Symbol))
        (t.is (= pull-symbol.text "pull"))
        (t.is (= pattern.kind .Vector))
        (t.is (= nested-map.kind .Map))
        (t.is (= nested-map.child-count 2))
        (t.is (= doc.nodes[score-value].kind .Float))
        (t.is (= doc.nodes[score-value].float-value 42.5))))
    (t.is set-ok)
    (t.is (= set-error ""))
    (when set-ok
      (let [root set-doc.nodes[set-doc.root]]
        (t.is (= root.kind .Set))
        (t.is (= root.child-count 2))))
    (t.is (not bad-ok))
    (t.is (= bad-error "trailing EDN input"))))

