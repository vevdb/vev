    (t.is (= pulled[1].attrs[1].v.text "Tupen"))
    (t.is (= (count pulled[2].attrs) 0))
    (t.is (= (count pulled[3].attrs) 0))
    (t.is (= (count pulled[4].attrs) 0))
    (t.is (= (count rendered) 5))
    (t.is (= rendered[0].kind .Nil))
    (t.is (= rendered[1].kind .Map))
    (t.is (= rendered[2].kind .Nil))
    (t.is (= rendered[3].kind .Nil))
    (t.is (= rendered[4].kind .Nil))))

(t.deftest datascript-pull-other-dbs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"]}])
        filtered (vev.filter-db conn.db keep-not-tupen)
        data (vev.serializable conn.db)
        restored (vev.from-serializable data)
        initialized (vev.init-db (slice conn.db.datoms 0))
        filtered-rendered (vev.pull-result-value filtered (vev.pull filtered [:name :aka] 1))
        restored-rendered (vev.pull-result-value restored (vev.pull restored [:name :aka] 1))
        initialized-rendered (vev.pull-result-value initialized (vev.pull initialized [:name :aka] 1))
        [filtered-aka filtered-aka-ok] (map-value filtered-rendered ":aka")
        [restored-aka restored-aka-ok] (map-value restored-rendered ":aka")
        [initialized-aka initialized-aka-ok] (map-value initialized-rendered ":aka")
        [filtered-name filtered-name-ok] (map-value filtered-rendered ":name")
        [restored-name restored-name-ok] (map-value restored-rendered ":name")
        [initialized-name initialized-name-ok] (map-value initialized-rendered ":name")]
    (defer (vev.delete-serializable data))
    (t.is filtered-name-ok)
    (t.is (= filtered-name.text "Petr"))
    (t.is filtered-aka-ok)
    (t.is (= filtered-aka.kind .Vector))
    (t.is (= (count filtered-aka.items) 1))
    (t.is (= filtered-aka.items[0].text "Devil"))
    (t.is restored-name-ok)
    (t.is (= restored-name.text "Petr"))
    (t.is restored-aka-ok)
    (t.is (= (count restored-aka.items) 2))
    (t.is (= restored-aka.items[0].text "Devil"))
    (t.is (= restored-aka.items[1].text "Tupen"))
    (t.is initialized-name-ok)
    (t.is (= initialized-name.text "Petr"))
    (t.is initialized-aka-ok)
    (t.is (= (count initialized-aka.items) 2))
    (t.is (= initialized-aka.items[0].text "Devil"))
    (t.is (= initialized-aka.items[1].text "Tupen"))))

(t.deftest datascript-pull-rendered-value-shape-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             [:db/add 102 :db/ident :child]
             [:db/add 102 :db/valueType :db.type/ref]
             [:db/add 102 :db/cardinality :db.cardinality/many]
             [:db/add 103 :db/ident :father]
             [:db/add 103 :db/valueType :db.type/ref]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"] :child [2 3]}
             {:db/id 2 :name "David" :father 1}
             {:db/id 3 :name "Thomas" :father 1}])
        pulled (vev.pull conn.db [:db/id :name :aka :father {:child [:name]} :_father] 1)
        rendered (vev.pull-result-value conn.db pulled)
        [id id-ok] (map-value rendered ":db/id")
        [name name-ok] (map-value rendered ":name")
        [aka aka-ok] (map-value rendered ":aka")
        [children children-ok] (map-value rendered ":child")
        [missing missing-ok] (map-value rendered ":father")
        [reverse reverse-ok] (map-value rendered ":_father")
        lookup-missing (vev.pull conn.db [:aka] [:name "Missing"])
        missing-rendered (vev.pull-result-value conn.db lookup-missing)
        many (vev.pull-many conn.db [:name] ([]u64 [1 2]))
        many-rendered (vev.pull-many-result-values conn.db (slice many 0))
        aliased (vev.pull-result-value conn.db (vev.pull conn.db [[:name :as "Name"] [:aka :as :alias]] 1))
        [string-alias string-alias-ok] (vev.map-get-value aliased (vev.value-string "Name"))
        [keyword-alias keyword-alias-ok] (map-value aliased ":alias")
        symbol-aliased (vev.pull-result-value conn.db (vev.pull-text conn.db "[[:name :as person-name]]" 1))
        [symbol-alias symbol-alias-ok] (vev.map-get-value symbol-aliased (vev.value-symbol "person-name"))
        [first-name first-name-ok] (map-value many-rendered[0] ":name")
        [second-name second-name-ok] (map-value many-rendered[1] ":name")
        [child-name child-name-ok] (map-value children.items[0] ":name")
        [reverse-id reverse-id-ok] (map-value reverse.items[0] ":db/id")]
    (t.is (= rendered.kind .Map))
    (t.is id-ok)
    (t.is (= id.kind .Entity))
    (t.is (= id.entity 1))
    (t.is name-ok)
    (t.is (= name.text "Petr"))
    (t.is aka-ok)
    (t.is (= aka.kind .Vector))
    (t.is (= (count aka.items) 2))
    (t.is (= aka.items[0].text "Devil"))
    (t.is (= aka.items[1].text "Tupen"))
    (t.is children-ok)
    (t.is (= children.kind .Vector))
    (t.is (= children.items[0].kind .Map))
    (t.is child-name-ok)
    (t.is (= child-name.text "David"))
    (t.is (not missing-ok))
    (t.is reverse-ok)
    (t.is (= reverse.kind .Vector))
    (t.is reverse-id-ok)
    (t.is (= reverse-id.entity 2))
    (t.is (= missing-rendered.kind .Nil))
    (t.is (= (count many-rendered) 2))
    (t.is string-alias-ok)
    (t.is (= string-alias.text "Petr"))
    (t.is keyword-alias-ok)
    (t.is (= keyword-alias.kind .Vector))
    (t.is (= keyword-alias.items[0].text "Devil"))
    (t.is symbol-alias-ok)
    (t.is (= symbol-alias.text "Petr"))
    (t.is first-name-ok)
    (t.is (= first-name.text "Petr"))
    (t.is second-name-ok)
    (t.is (= second-name.text "David"))))

(t.deftest datascript-pull-text-api-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :friend]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :friend 2}
             {:db/id 2 :name "David"}
             {:db/id 3 :name "Thomas"}
             [:db/add 1 :friend 3]])
        pulled (vev.pull-text conn.db "[:db/id :name {((limit :friend 1) :as :first-friend) [:name]}]" 1)
        by-lookup (vev.pull-text-lookup-ref conn.db "[:name {:friend [:name]}]" ":name" (vev.value-string "Petr"))
        many (vev.pull-many-text conn.db "[:name]" ([]u64 [1 2 3]))
        prepared (vev.prepare-pull-pattern-text "[:name {:friend [:name]}]")
        list-pattern (vev.pull-text conn.db "[:name {:friend (:name)}]" 1)
        prepared-list (vev.prepare-pull-pattern-text "[:name {:friend (:name)}]")
        prepared-list-pulled (vev.pull-prepared conn.db prepared-list 1)
        prepared-pulled (vev.pull-prepared conn.db prepared 1)
        prepared-lookup (vev.pull-prepared-lookup-ref conn.db prepared ":name" (vev.value-string "Petr"))
        prepared-many (vev.pull-many-prepared conn.db prepared ([]u64 [1 2]))
        many-lookup (vev.pull-many-text-lookup-refs
                      conn.db
                      "[:name]"
                      ([]string [":name" ":name" ":name"])
                      ([]vev.Value [(vev.value-string "Petr")
                                    (vev.value-string "David")
                                    (vev.value-string "Missing")]))
        invalid-prepared (vev.prepare-pull-pattern-text ":name")
        invalid-prepared-result (vev.pull-prepared conn.db invalid-prepared 1)
        invalid (vev.pull-text conn.db ":name" 1)]
    (t.is (= pulled.attrs[0].v.entity 1))
    (t.is (= pulled.attrs[1].v.text "Petr"))
    (t.is (= pulled.attrs[2].a ":first-friend"))
    (t.is (= pulled.attrs[2].v.entity 2))
    (t.is (= pulled.attrs[2].attrs[0].v.text "David"))
    (t.is (= by-lookup.attrs[0].v.text "Petr"))
    (t.is (= by-lookup.attrs[1].attrs[0].v.text "David"))
    (t.is (= (count many) 3))
    (t.is (= many[0].attrs[0].v.text "Petr"))
    (t.is (= many[1].attrs[0].v.text "David"))
    (t.is (= many[2].attrs[0].v.text "Thomas"))
    (t.is prepared.ok)
    (t.is prepared-list.ok)
    (t.is (= list-pattern.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-list-pulled.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-pulled.attrs[0].v.text "Petr"))
    (t.is (= prepared-pulled.attrs[1].attrs[0].v.text "David"))
    (t.is (= prepared-lookup.attrs[0].v.text "Petr"))
    (t.is (= prepared-lookup.attrs[1].attrs[0].v.text "David"))
    (t.is (= (count prepared-many) 2))
    (t.is (= prepared-many[0].attrs[0].v.text "Petr"))
    (t.is (= prepared-many[1].attrs[0].v.text "David"))
    (t.is (= (count many-lookup) 3))
    (t.is (= many-lookup[0].attrs[0].v.text "Petr"))
    (t.is (= many-lookup[1].attrs[0].v.text "David"))
    (t.is (= (count many-lookup[2].attrs) 0))
    (t.is (not invalid-prepared.ok))
    (t.is (= (count invalid-prepared-result.attrs) 0))
    (t.is (= (count invalid.attrs) 0))))

(t.deftest datascript-pull-rendered-text-and-prepared-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 101 :db/ident :aka :db/cardinality :db.cardinality/many}
             {:db/id 102 :db/ident :friend :db/valueType :db.type/ref}
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"] :friend 2}
             {:db/id 2 :name "David"}])
        prepared (vev.prepare-pull-pattern-text "[:name :aka {:friend [:name]}]")
        text-value (vev.pull-text-value conn.db "[:name :aka {:friend [:name]}]" 1)
        prepared-value (vev.pull-prepared-value conn.db prepared 1)
        lookup-value (vev.pull-text-lookup-ref-value conn.db "[:name :aka]" ":name" (vev.value-string "Petr"))
        prepared-lookup-value (vev.pull-prepared-lookup-ref-value conn.db prepared ":name" (vev.value-string "Petr"))
        missing-lookup (vev.pull-text-lookup-ref-value conn.db "[:name]" ":name" (vev.value-string "Missing"))
        many-value (vev.pull-many-text-value conn.db "[:name]" ([]u64 [1 2]))
        prepared-many-value (vev.pull-many-prepared-value conn.db prepared ([]u64 [1 2]))
        many-lookup-value (vev.pull-many-text-lookup-refs-value
                            conn.db
                            "[:name]"
                            ([]string [":name" ":name" ":name"])
                            ([]vev.Value [(vev.value-string "Petr")
                                          (vev.value-string "David")
                                          (vev.value-string "Missing")]))
        prepared-many-lookup-value (vev.pull-many-prepared-lookup-refs-value
                                     conn.db
                                     prepared
                                     ([]string [":name" ":name"])
                                     ([]vev.Value [(vev.value-string "Petr")
                                                   (vev.value-string "Missing")]))
        [text-name text-name-ok] (map-value text-value ":name")
        [text-aka text-aka-ok] (map-value text-value ":aka")
        [text-friend text-friend-ok] (map-value text-value ":friend")
        [friend-name friend-name-ok] (map-value text-friend ":name")
        [prepared-name prepared-name-ok] (map-value prepared-value ":name")
        [lookup-name lookup-name-ok] (map-value lookup-value ":name")
        [prepared-lookup-name prepared-lookup-name-ok] (map-value prepared-lookup-value ":name")
        [many-first-name many-first-name-ok] (map-value many-value.items[0] ":name")
        [many-second-name many-second-name-ok] (map-value many-value.items[1] ":name")
        [prepared-many-first-name prepared-many-first-name-ok] (map-value prepared-many-value.items[0] ":name")
        [lookup-many-first-name lookup-many-first-name-ok] (map-value many-lookup-value.items[0] ":name")
        [lookup-many-second-name lookup-many-second-name-ok] (map-value many-lookup-value.items[1] ":name")
        [prepared-lookup-many-first-name prepared-lookup-many-first-name-ok] (map-value prepared-many-lookup-value.items[0] ":name")]
    (t.is (= text-value.kind .Map))
    (t.is text-name-ok)
    (t.is (= text-name.text "Petr"))
    (t.is text-aka-ok)
    (t.is (= text-aka.kind .Vector))
    (t.is (= (count text-aka.items) 2))
    (t.is text-friend-ok)
    (t.is (= text-friend.kind .Map))
    (t.is friend-name-ok)
    (t.is (= friend-name.text "David"))
    (t.is prepared-name-ok)
    (t.is (= prepared-name.text "Petr"))
    (t.is lookup-name-ok)
    (t.is (= lookup-name.text "Petr"))
    (t.is prepared-lookup-name-ok)
    (t.is (= prepared-lookup-name.text "Petr"))
    (t.is (= missing-lookup.kind .Nil))
    (t.is (= many-value.kind .Vector))
    (t.is (= (count many-value.items) 2))
    (t.is many-first-name-ok)
    (t.is (= many-first-name.text "Petr"))
    (t.is many-second-name-ok)
    (t.is (= many-second-name.text "David"))
    (t.is (= prepared-many-value.kind .Vector))
    (t.is (= (count prepared-many-value.items) 2))
    (t.is prepared-many-first-name-ok)
    (t.is (= prepared-many-first-name.text "Petr"))
    (t.is (= many-lookup-value.kind .Vector))
    (t.is (= (count many-lookup-value.items) 3))
    (t.is lookup-many-first-name-ok)
    (t.is (= lookup-many-first-name.text "Petr"))
    (t.is lookup-many-second-name-ok)
    (t.is (= lookup-many-second-name.text "David"))
    (t.is (= many-lookup-value.items[2].kind .Nil))
    (t.is (= prepared-many-lookup-value.kind .Vector))
    (t.is (= (count prepared-many-lookup-value.items) 2))
    (t.is prepared-lookup-many-first-name-ok)
    (t.is (= prepared-lookup-many-first-name.text "Petr"))
    (t.is (= prepared-many-lookup-value.items[1].kind .Nil))))

(t.deftest datascript-pull-text-parser-validation-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             [:db/add 102 :db/ident :friend]
             [:db/add 102 :db/valueType :db.type/ref]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"] :friend 2}
             {:db/id 2 :name "David" :friend 1}])
        string-limit (vev.prepare-pull-pattern-text "[((\"limit\" :aka 1) :as :first-aka)]")
        vector-limit (vev.prepare-pull-pattern-text "[[\"limit\" :aka 1]]")
        nested-default (vev.prepare-pull-pattern-text "[(default (limit :missing 1) \"Unknown\")]")
        string-wildcard (vev.prepare-pull-pattern-text "[\"*\" :name]")
        string-recursion (vev.prepare-pull-pattern-text "[{:friend \"...\"}]")
        pulled-string-limit (vev.pull-prepared conn.db string-limit 1)
        pulled-vector-limit (vev.pull-prepared conn.db vector-limit 1)
        pulled-default (vev.pull-prepared conn.db nested-default 1)
        pulled-wildcard (vev.pull-prepared conn.db string-wildcard 1)
        pulled-recursion (vev.pull-prepared conn.db string-recursion 1)
        bad-option (vev.prepare-pull-pattern-text "[[:aka :limit]]")
        bad-limit-call (vev.prepare-pull-pattern-text "[(limit :aka)]")
        bad-map-key (vev.prepare-pull-pattern-text "[{[:friend :limit] [:name]}]")
        bad-map-value (vev.prepare-pull-pattern-text "[{:friend :name}]")
        partial-query (vev.prepare-query-text "[:find (pull ?e [[:aka :limit]]) :where [?e :name \"Petr\"]]")]
    (t.is string-limit.ok)
    (t.is vector-limit.ok)
    (t.is nested-default.ok)
    (t.is string-wildcard.ok)
    (t.is string-recursion.ok)
    (t.is (= pulled-string-limit.attrs[0].a ":first-aka"))
    (t.is (= pulled-string-limit.attrs[0].v.text "Devil"))
    (t.is (= pulled-vector-limit.attrs[0].v.text "Devil"))
    (t.is (= pulled-default.attrs[0].v.text "Unknown"))
    (t.is (= pulled-wildcard.attrs[0].a ":db/id"))
    (t.is (= pulled-wildcard.attrs[1].a ":aka"))
    (t.is (= pulled-wildcard.attrs[2].a ":friend"))
    (t.is (= pulled-wildcard.attrs[3].a ":name"))
    (t.is (= pulled-recursion.attrs[0].attrs[0].a ":friend"))
    (t.is (not bad-option.ok))
    (t.is (not bad-limit-call.ok))
    (t.is (not bad-map-key.ok))
    (t.is (not bad-map-value.ok))
    (t.is (not partial-query.ok))))

(t.deftest datascript-pull-schema-validation-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :normal]
             [:db/add 101 :db/ident :multival]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             [:db/add 102 :db/ident :ref]
             [:db/add 102 :db/valueType :db.type/ref]
             {:db/id 1 :normal "root" :multival ["a" "b"] :ref 2}
             {:db/id 2 :normal "child"}])
        valid (vev.q-text
                conn.db
                "[:find (pull ?e [{:ref [:normal]} [:multival :limit 1]]) . :where [(ground 1) ?e]]")
        invalid-reverse (vev.q-text
                          conn.db
                          "[:find (pull ?e [:_normal]) . :where [(ground 1) ?e]]")
        invalid-nested (vev.q-text
                         conn.db
                         "[:find (pull ?e [{:normal [:normal]}]) . :where [(ground 1) ?e]]")
        invalid-recursion (vev.q-text
                            conn.db
                            "[:find (pull ?e [{:normal 1}]) . :where [(ground 1) ?e]]")
        invalid-limit (vev.q-text
                        conn.db
                        "[:find (pull ?e [[:normal :limit 1]]) . :where [(ground 1) ?e]]")
        invalid-input (vev.q-text-with-inputs
                        conn.db
                        "[:find (pull ?e ?pattern) . :in $ ?pattern :where [(ground 1) ?e]]"
                        ([]vev.Query-Input
                          [(vev.query-input-pull-pattern
                             ([]vev.Pull-Spec [(vev.pull-spec-limit ":normal" ([]vev.Pull-Spec []) 1)]))]))
        [direct-ok direct-error] (vev.validate-pull-pattern
                                   conn.db
                                   ([]vev.Pull-Spec
                                     [(vev.pull-spec
                                        ":ref"
                                        ([]vev.Pull-Spec [(vev.pull-spec ":normal" ([]vev.Pull-Spec []))]))
                                      (vev.pull-spec-limit ":multival" ([]vev.Pull-Spec []) 1)]))
        [direct-bad-ok direct-bad-error] (vev.validate-pull-pattern
                                           conn.db
                                           ([]vev.Pull-Spec [(vev.pull-spec-limit ":normal" ([]vev.Pull-Spec []) 1)]))]
    (t.is valid.ok)
    (t.is (= (count valid.rows) 1))
    (t.is direct-ok)
    (t.is (= direct-error ""))
    (t.is (not invalid-reverse.ok))
    (t.is (not invalid-nested.ok))
    (t.is (not invalid-recursion.ok))
    (t.is (not invalid-limit.ok))
    (t.is (not invalid-input.ok))
    (t.is (not direct-bad-ok))
    (t.is (= direct-bad-error "pull limit attr must be cardinality many: :normal"))))

(t.deftest datascript-pull-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :aka]
             [:db/add 101 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen"]}])
        found (vev.pull conn.db [:name :aka] [:name "Petr"])
        missing (vev.pull conn.db [:name :aka] [:name "NotInDatabase"])
        missing-wildcard (vev.pull conn.db [*] [:name "No such name"])]
    (t.is (= (count found.attrs) 3))
    (t.is (= found.attrs[0].v.text "Petr"))
    (t.is (= found.attrs[1].v.text "Devil"))
    (t.is (= found.attrs[2].v.text "Tupen"))
    (t.is (= (count missing.attrs) 0))
    (t.is (= (count missing-wildcard.attrs) 0))))

(t.deftest pull-supports-wildcard
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-retract 1 ":user/name" (vev.value-string "Ada"))]))
        pulled (vev.pull report.db-after [*] 1)]
      (t.is (= (count pulled.attrs) 5))
      (t.is (= pulled.attrs[0].a ":db/id"))
      (t.is (= pulled.attrs[0].v.entity 1))
      (t.is (= pulled.attrs[1].a ":user/active"))
      (t.is (= pulled.attrs[2].a ":user/age"))
      (t.is (= pulled.attrs[3].a ":user/email"))
      (t.is (= pulled.attrs[4].a ":user/friend"))))

(t.deftest pull-wildcard-does-not-duplicate-db-id
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        wildcard-only (vev.pull conn.db [*] 1)
        wildcard-first (vev.pull conn.db [* :db/id] 1)
        id-first (vev.pull conn.db [:db/id *] 1)]
      (t.is (= (count wildcard-first.attrs) (count wildcard-only.attrs)))
      (t.is (= (count id-first.attrs) (count wildcard-only.attrs)))
      (t.is (= wildcard-first.attrs[0].a ":db/id"))
      (t.is (= id-first.attrs[0].a ":db/id"))))

