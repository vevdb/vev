(t.deftest query-shape-helpers-return-scalar-collection-and-tuple
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        [scalar scalar-ok] (vev.q-scalar report.db-after
                             [:find ?name .
                              :where
                              [?e :user/email "ada@example.com"]
                              [?e :user/name ?name]])
        collection (vev.q-collection report.db-after
                     [:find [?name ...]
                      :where
                      [?e :user/name ?name]])
        tuple (vev.q-tuple report.db-after
                [:find [?name ?age]
                 :where
                 [?e :user/email "ada@example.com"]
                 [?e :user/name ?name]
                 [?e :user/age ?age]])]
    (t.is scalar-ok)
    (t.is (= scalar.text "Ada"))
    (t.is (= (count collection) 2))
    (t.is (= collection[0].text "Ada"))
    (t.is (= collection[1].text "Grace"))
    (t.is (= (count tuple) 2))
    (t.is (= tuple[0].text "Ada"))
    (t.is (= tuple[1].int-value 37))))

(t.deftest datascript-query-find-specs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Petr" :age 44}
                  {:db/id 2 :name "Ivan" :age 25}
                  {:db/id 3 :name "Sergey" :age 11}])
        names (vev.q-collection report.db-after
                [:find [?name ...]
                 :where
                 [?e :name ?name]])
        tuple (vev.q-tuple report.db-after
                [:find [?name ?age]
                 :where
                 [1 :name ?name]
                 [1 :age ?age]])
        [scalar scalar-ok] (vev.q-scalar report.db-after
                             [:find ?name .
                              :where
                              [1 :name ?name]])
        count-coll (vev.q-collection report.db-after
                     [:find [(count ?name) ...]
                      :where
                      [?e :name ?name]])
        count-tuple (vev.q-tuple report.db-after
                      [:find [(count ?name)]
                       :where
                       [?e :name ?name]])
        [count-scalar count-scalar-ok] (vev.q-scalar report.db-after
                                         [:find (count ?name) .
                                          :where
                                          [?e :name ?name]])
        cut-tuple (vev.q-tuple report.db-after
                    [:find [?name ?age]
                     :where
                     [?e :name ?name]
                     [?e :age ?age]])
        [cut-scalar cut-scalar-ok] (vev.q-scalar report.db-after
                                     [:find ?name .
                                      :where
                                      [?e :name ?name]])]
    (t.is (= (count names) 3))
    (t.is (= names[0].text "Petr"))
    (t.is (= names[1].text "Ivan"))
    (t.is (= names[2].text "Sergey"))
    (t.is (= (count tuple) 2))
    (t.is (= tuple[0].text "Petr"))
    (t.is (= tuple[1].int-value 44))
    (t.is scalar-ok)
    (t.is (= scalar.text "Petr"))
    (t.is (= (count count-coll) 1))
    (t.is (= count-coll[0].int-value 3))
    (t.is (= (count count-tuple) 1))
    (t.is (= count-tuple[0].int-value 3))
    (t.is count-scalar-ok)
    (t.is (= count-scalar.int-value 3))
    (t.is (= (count cut-tuple) 2))
    (t.is (= cut-tuple[0].text "Petr"))
    (t.is (= cut-tuple[1].int-value 44))
    (t.is cut-scalar-ok)
    (t.is (= cut-scalar.text "Petr"))))

(t.deftest datascript-query-input-placeholder-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        tuple (vev.q conn.db
                [:find ?x ?z
                 :in [?x _ ?z]]
                [:x :y :z])
        relation (vev.q conn.db
                   [:find ?x ?z
                    :in [[?x _ ?z]]]
                   [[:x :y :z]
                    [:a :b :c]])]
    (t.is (= (count tuple.rows) 1))
    (t.is (= tuple.rows[0].values[0].text ":x"))
    (t.is (= tuple.rows[0].values[1].text ":z"))
    (t.is (= (count relation.rows) 2))
    (t.is (= relation.rows[0].values[0].text ":x"))
    (t.is (= relation.rows[0].values[1].text ":z"))
    (t.is (= relation.rows[1].values[0].text ":a"))
    (t.is (= relation.rows[1].values[1].text ":c"))))

(t.deftest datascript-query-map-relation-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        filtered (vev.q conn.db
                   [:find ?k ?v
                    :in [[?k ?v]]
                    :where
                    [(> ?v 1)]]
                   {:a 1 :b 2 :c 3})
        nested (vev.q conn.db
                 [:find ?m ?value
                  :in [[?k ?m]] ?lookup
                  :where
                  [(get ?m ?lookup) ?value]]
                 {:a {:b 1}
                  :c {:d 2}}
                 :d)]
    (t.is (= (count filtered.rows) 2))
    (t.is (= filtered.rows[0].values[0].text ":b"))
    (t.is (= filtered.rows[0].values[1].int-value 2))
    (t.is (= filtered.rows[1].values[0].text ":c"))
    (t.is (= filtered.rows[1].values[1].int-value 3))
    (t.is (= (count nested.rows) 1))
    (t.is (= nested.rows[0].values[0].kind .Map))
    (t.is (= nested.rows[0].values[1].int-value 2))))

(t.deftest datascript-query-native-function-input-binding-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :person/name "Joe"}])
        registry ([]vev.Native-Query-Fn
                   [(vev.query-value-fn "constant-five" native-constant-five)
                    (vev.query-value-fn "minmax" native-minmax)])
        nested-source (vev.value-map
                        ([]vev.Value
                          [(vev.value-keyword ":a")
                           (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3) (vev.value-int 4)]))
                           (vev.value-keyword ":b")
                           (vev.value-vector ([]vev.Value [(vev.value-int 5) (vev.value-int 6) (vev.value-int 7)]))
                           (vev.value-keyword ":c")
                           (vev.value-vector ([]vev.Value [(vev.value-int 3)]))]))
        nested (vev.q-text-with-inputs-and-fns
                 conn.db
                 "[:find ?k ?min ?max :in [[?k ?v] ...] ?minmax :where [(?minmax ?v) [?min ?max]] [(> ?max ?min)]]"
                 ([]vev.Query-Input
                   [(vev.query-input-scalar nested-source)
                    (vev.query-input-scalar (vev.value-string "minmax"))])
                 registry)
        unrelated (vev.q-text-with-fns
                    conn.db
                    "[:find ?name :where [?e :person/name ?name] [(constant-five) ?result] [(< ?result 3)]]"
                    registry)]
    (t.is nested.ok)
    (t.is (= (count nested.rows) 2))
    (t.is (= nested.rows[0].values[0].text ":a"))
    (t.is (= nested.rows[0].values[1].int-value 1))
    (t.is (= nested.rows[0].values[2].int-value 4))
    (t.is (= nested.rows[1].values[0].text ":b"))
    (t.is (= nested.rows[1].values[1].int-value 5))
    (t.is (= nested.rows[1].values[2].int-value 7))
    (t.is unrelated.ok)
    (t.is (= (count unrelated.rows) 0))))

(t.deftest datascript-query-constant-substitution-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 5 :a "5a"]
             [:db/add 5 :b "5b"]
             [:db/add 5 :c "5c"]
             [:db/add 6 :b "6b"]])
        value (vev.q conn.db
                [:find ?v
                 :where
                 [5 :b ?v]])
        attr (vev.q conn.db
               [:find ?a
                :where
                [5 ?a "5b"]])
        entity (vev.q conn.db
                 [:find ?e
                  :where
                  [?e :b "5b"]])
        input-entity (vev.q conn.db
                       [:find ?a ?v
                        :in ?e
                        :where
                        [?e ?a ?v]]
                       5)
        input-value (vev.q conn.db
                      [:find ?e ?a
                       :in ?v
                       :where
                       [?e ?a ?v]]
                      "5b")]
    (t.is (= (count value.rows) 1))
    (t.is (= value.rows[0].values[0].text "5b"))
    (t.is (= (count attr.rows) 1))
    (t.is (= attr.rows[0].values[0].text ":b"))
    (t.is (= (count entity.rows) 1))
    (t.is (= entity.rows[0].values[0].entity 5))
    (t.is (= (count input-entity.rows) 3))
    (t.is (= input-entity.rows[0].values[0].text ":a"))
    (t.is (= input-entity.rows[0].values[1].text "5a"))
    (t.is (= input-entity.rows[1].values[0].text ":b"))
    (t.is (= input-entity.rows[1].values[1].text "5b"))
    (t.is (= input-entity.rows[2].values[0].text ":c"))
    (t.is (= input-entity.rows[2].values[1].text "5c"))
    (t.is (= (count input-value.rows) 1))
    (t.is (= input-value.rows[0].values[0].entity 5))
    (t.is (= input-value.rows[0].values[1].text ":b"))))

