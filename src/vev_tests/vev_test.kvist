(t.deftest datascript-retract-without-value-issue-339-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :aka]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 101 :db/ident :friend]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 1 :name "Ivan"]
             [:db/add 1 :age 15]
             [:db/add 1 :aka "X"]
             [:db/add 1 :aka "Y"]
             [:db/add 1 :aka "Z"]
             [:db/add 1 :friend 2]
             [:db/add 2 :name "Petr"]
             [:db/add 2 :age 37]
             [:db/add 2 :employed? true]
             [:db/add 2 :married? false]])
        original conn.db
        report (vev.with-tx-data
                 original
                 ([]vev.Tx-Data
                   [(vev.retract-attr 1 ":name")
                    (vev.retract-attr 1 ":aka")
                    (vev.retract-attr 2 ":employed?")
                    (vev.retract-attr 2 ":married?")]))
        ivan-names (vev.q-collection report.db-after
                    [:find [?v ...]
                     :where
                     [1 :name ?v]])
        ivan-akas (vev.q-collection report.db-after
                   [:find [?v ...]
                    :where
                    [1 :aka ?v]])
        ivan-ages (vev.q-collection report.db-after
                   [:find [?v ...]
                    :where
                    [1 :age ?v]])
        ivan-friends (vev.q-collection report.db-after
                      [:find [?v ...]
                       :where
                       [1 :friend ?v]])
        petr-names (vev.q-collection report.db-after
                    [:find [?v ...]
                     :where
                     [2 :name ?v]])
        petr-ages (vev.q-collection report.db-after
                   [:find [?v ...]
                    :where
                    [2 :age ?v]])
        employed-after-retract (vev.q-collection report.db-after
                                [:find [?v ...]
                                 :where
                                 [2 :employed? ?v]])
        married-after-retract (vev.q-collection report.db-after
                               [:find [?v ...]
                                :where
                                [2 :married? ?v]])
        mismatch (vev.with-tx-data
                   original
                   ([]vev.Tx-Data [(vev.retract 2 ":employed?" (vev.value-bool false))]))
        employed (vev.q-collection mismatch.db-after
                   [:find [?v ...]
                    :where
                    [2 :employed? ?v]])]
    (t.is report.ok)
    (t.is (= (count ivan-names) 0))
    (t.is (= (count ivan-akas) 0))
    (t.is (= (count employed-after-retract) 0))
    (t.is (= (count married-after-retract) 0))
    (t.is (= (count ivan-ages) 1))
    (t.is (= ivan-ages[0].int-value 15))
    (t.is (= (count ivan-friends) 1))
    (t.is (= ivan-friends[0].entity 2))
    (t.is (= (count petr-names) 1))
    (t.is (= petr-names[0].text "Petr"))
    (t.is (= (count petr-ages) 1))
    (t.is (= petr-ages[0].int-value 37))
    (t.is mismatch.ok)
    (t.is (= (count employed) 1))
    (t.is employed[0].bool-value)))

(t.deftest datascript-retract-fns-not-found-and-idempotent-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 1 :name "Ivan"]])
        missing-retract (vev.transact (addr conn) [[:db/retract 2 :name "Petr"]])
        missing-attr (vev.transact (addr conn) [[:db.fn/retractAttribute 2 :name]])
        missing-entity (vev.transact (addr conn) [[:db.fn/retractEntity 2]])
        missing-entity-op (vev.transact (addr conn) [[:db/retractEntity 2]])
        missing-lookup-retract (vev.transact (addr conn) [[:db/retract [:name "Petr"] :name "Petr"]])
        missing-lookup-attr (vev.transact (addr conn) [[:db.fn/retractAttribute [:name "Petr"] :name]])
        missing-lookup-entity (vev.transact (addr conn) [[:db.fn/retractEntity [:name "Petr"]]])
        after-missing (vev.q-collection conn.db
                        [:find [?name ...]
                         :where
                         [?e :name ?name]])
        retract-once (vev.transact (addr conn) [[:db/retract 1 :name "Ivan"]])
        retract-twice (vev.transact (addr conn) [[:db/retract 1 :name "Ivan"]
                                                 [:db/retract 1 :name "Ivan"]])
        names-once (vev.q-collection retract-once.db-after
                     [:find [?name ...]
                      :where
                      [?e :name ?name]])
        names-twice (vev.q-collection retract-twice.db-after
                      [:find [?name ...]
                       :where
                       [?e :name ?name]])]
    (t.is missing-retract.ok)
    (t.is missing-attr.ok)
    (t.is missing-entity.ok)
    (t.is missing-entity-op.ok)
    (t.is missing-lookup-retract.ok)
    (t.is missing-lookup-attr.ok)
    (t.is missing-lookup-entity.ok)
    (t.is (= (count after-missing) 1))
    (t.is (= after-missing[0].text "Ivan"))
    (t.is retract-once.ok)
    (t.is retract-twice.ok)
    (t.is (= (count names-once) 0))
    (t.is (= (count names-twice) 0))))

