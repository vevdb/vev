        _ (vev.transact
            (addr conn)
            [[:db/add 1 :friend 1]])
        expected-lookup (vev.transact
                          (addr conn)
                          [[:db.fn/cas 1 :friend [:name "Ivan"] 2]])
        replacement-lookup (vev.transact
                             (addr conn)
                             [[:db.fn/cas 1 :friend 2 [:name "Petr"]]])
        [friend friend-ok] (vev.q-scalar replacement-lookup.db-after
                              [:find ?friend .
                               :where
                               [1 :friend ?friend]])]
    (t.is expected-lookup.ok)
    (t.is replacement-lookup.ok)
    (t.is friend-ok)
    (t.is (= friend.entity 2))))

