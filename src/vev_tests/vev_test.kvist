             [:db/add 2 :friend (vev.value-entity 3)]
             [:db/add 3 :friend (vev.value-entity 1)]])
        pulled (vev.pull conn.db [:db/id {:_friend ...}] 1)
        parent pulled.attrs[1]
        grandparent parent.attrs[1]
        repeated grandparent.attrs[1]]
    (t.is (= parent.v.entity 3))
    (t.is (= grandparent.v.entity 2))
    (t.is (= repeated.v.entity 1))
    (t.is (= (count repeated.attrs) 1))
    (t.is (= repeated.attrs[0].a ":db/id"))
    (t.is (= repeated.attrs[0].v.entity 1))))

