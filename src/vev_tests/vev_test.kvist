(t.deftest datalog-with-keeps-duplicate-visible-values
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        _ (vev.transact
               (addr conn)
               [[:db/add 3 :user/name "Alan"]
                [:db/add 3 :user/age 37]])
        result (vev.q conn.db
                   [:find ?age
                    :with ?e
                    :where
                    [?e :user/age ?age]])
        text-result (vev.q-text-collection
                      conn.db
                      "[:find [?age ...] :with ?e :where [?e :user/age ?age]]")
        age-37-count 0]
      (for [row result.rows]
        (when (= row.values[0].int-value 37)
          (set! age-37-count (+ age-37-count 1))))
      (t.is (= (count result.rows) 3))
      (t.is (= age-37-count 2))
      (t.is (= (count text-result) 3))
      (t.is (= text-result[0].int-value 37))
      (t.is (= text-result[1].int-value 41))
      (t.is (= text-result[2].int-value 37))))

