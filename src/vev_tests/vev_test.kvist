(t.deftest datascript-retract-int-does-not-match-float-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-tx-data
            (addr conn)
            ([]vev.Tx-Data [(vev.add 1 ":num" (vev.value-float 42.5))]))
        report (vev.transact (addr conn) [[:db/retract 1 :num 42]])
        values (vev.q-collection report.db-after
                [:find [?num ...]
                 :where
                 [1 :num ?num]])]
    (t.is report.ok)
    (t.is (= (count values) 1))
    (t.is (= values[0].kind .Float))
    (t.is (= values[0].float-value 42.5))))

