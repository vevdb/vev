        retract-report (vev.transact
                         (addr conn)
                         [[:db/retract 1 :friend [:name "Petr"]]])
        retract-result (vev.q retract-report.db-after
                         [:find ?friend
                          :where
                          [1 :friend ?friend]])]
    (t.is add-report.ok)
    (t.is (= (count add-result.rows) 1))
    (t.is (= add-result.rows[0].values[0].entity 2))
    (t.is retract-report.ok)
    (t.is (= (count retract-result.rows) 0))))

