(t.deftest datascript-retract-entity-removes-incoming-refs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :name "Ivan"]
             [:db/add 1 :friend (vev.value-entity 2)]
             [:db/add 2 :name "Petr"]])
        report (vev.transact (addr conn) [[:db.fn/retractEntity 2]])
        refs (vev.q report.db-after
               [:find ?friend
                :where
                [1 :friend ?friend]])
        parent (vev.q report.db-after
                 [:find ?name
                  :where
                  [1 :name ?name]])
        child (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [2 ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count refs.rows) 0))
    (t.is (= (count child.rows) 0))
    (t.is (= parent.rows[0].values[0].text "Ivan"))))

(t.deftest datascript-retract-entity-reports-adjacent-retractions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :a1 1 :a2 2 :a3 3}
             {:db/id 2 :a1 1 :a2 2 :a3 3}
             {:db/id 3 :a1 1 :a2 2 :a3 3}])
        report (vev.transact (addr conn) [[:db.fn/retractEntity 1]
                                          [:db.fn/retractEntity 2]])
        first (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [1 ?a ?v]])
        second (vev.q report.db-after
                 [:find ?a ?v
                  :where
                  [2 ?a ?v]])
        third (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [3 ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 6))
    (for [datom report.tx-data]
      (t.is (not datom.added)))
    (t.is (= (count first.rows) 0))
    (t.is (= (count second.rows) 0))
    (t.is (= (count third.rows) 3))))

