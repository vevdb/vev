(t.deftest datascript-map-vector-values-support-tempid-refs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]])
        report (vev.transact
                 (addr conn)
                 [{:db/id "sergey" :name "Sergey" :friend ["ivan" "petr"]}
                  {:db/id "ivan" :name "Ivan"}
                  {:db/id "petr" :name "Petr"}
                  {:db/id "boris" :name "Boris" :friend "oleg"}
                  {:db/id "oleg" :name "Oleg" :friend "boris"}])
        sergey-friends (vev.q-collection report.db-after
                         [:find [?friend-name ...]
                          :where
                          [?e :name "Sergey"]
                          [?e :friend ?friend]
                          [?friend :name ?friend-name]])
        boris-friends (vev.q-collection report.db-after
                        [:find [?friend-name ...]
                         :where
                         [?e :name "Boris"]
                         [?e :friend ?friend]
                         [?friend :name ?friend-name]])
        oleg-friends (vev.q-collection report.db-after
                       [:find [?friend-name ...]
                        :where
                        [?e :name "Oleg"]
                        [?e :friend ?friend]
                        [?friend :name ?friend-name]])]
    (t.is report.ok)
    (t.is (= (count sergey-friends) 2))
    (t.is (= sergey-friends[0].text "Ivan"))
    (t.is (= sergey-friends[1].text "Petr"))
    (t.is (= (count boris-friends) 1))
    (t.is (= boris-friends[0].text "Oleg"))
    (t.is (= (count oleg-friends) 1))
    (t.is (= oleg-friends[0].text "Boris"))))

