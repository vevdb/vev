    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].kind .Entity))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].kind .String))
    (t.is (= result.rows[0].values[1].text "Ada"))))

(t.deftest frontend-parity-kvist-literals-edn-text-and-prepared
  (defer (free_all context.allocator))
  (let [literal-conn (vev.create-conn)
        text-conn (vev.create-conn)
        literal-report (vev.transact
                         (addr literal-conn)
                         [[:db/add 100 :db/ident :user/friend]
                          [:db/add 100 :db/valueType :db.type/ref]
                          {:db/id 1 :user/name "Ada" :user/email "ada@example.com" :user/friend 2}
                          {:db/id 2 :user/name "Grace" :user/email "grace@example.com"}])
        text-report (vev.transact-text
                      (addr text-conn)
                      "[[:db/add 100 :db/ident :user/friend] [:db/add 100 :db/valueType :db.type/ref] {:db/id 1 :user/name \"Ada\" :user/email \"ada@example.com\" :user/friend 2} {:db/id 2 :user/name \"Grace\" :user/email \"grace@example.com\"}]")
        literal-query (vev.q
                        literal-conn.db
                        [:find ?name
                         :in [?email ...]
                         :where [?e :user/email ?email]
                                [?e :user/name ?name]]
                        ["ada@example.com" "grace@example.com"])
        text-query (vev.q-text-with-inputs
                     text-conn.db
                     "[:find ?name :in [?email ...] :where [?e :user/email ?email] [?e :user/name ?name]]"
                     ([]vev.Query-Input
                       [(vev.query-input-collection
                          ([dynamic]vev.Value
                            [(vev.value-string "ada@example.com")
                             (vev.value-string "grace@example.com")]))]))
        prepared (vev.prepare-query-text
                   "[:find ?name :in [?email ...] :where [?e :user/email ?email] [?e :user/name ?name]]")
        prepared-query (vev.q-prepared-with-input-text
                         text-conn.db
                         prepared
                         "[[\"ada@example.com\" \"grace@example.com\"]]")
        literal-pull (vev.pull
                       literal-conn.db
                       [:user/name {:user/friend [:user/name]}]
                       1)
        text-pull (vev.pull-text
                    text-conn.db
                    "[:user/name {:user/friend [:user/name]}]"
                    1)
        [literal-friend-index literal-friend-ok] (pull-attr-index (slice literal-pull.attrs 0) ":user/friend")
        [text-friend-index text-friend-ok] (pull-attr-index (slice text-pull.attrs 0) ":user/friend")]
    (t.is literal-report.ok)
    (t.is text-report.ok)
    (t.is literal-query.ok)
    (t.is text-query.ok)
    (t.is prepared-query.ok)
    (t.is (= (count literal-query.rows) 2))
    (t.is (= (count text-query.rows) 2))
    (t.is (= (count prepared-query.rows) 2))
    (t.is (= literal-query.rows[0].values[0].text text-query.rows[0].values[0].text))
    (t.is (= text-query.rows[0].values[0].text prepared-query.rows[0].values[0].text))
    (t.is (= literal-query.rows[1].values[0].text text-query.rows[1].values[0].text))
    (t.is (= text-query.rows[1].values[0].text prepared-query.rows[1].values[0].text))
    (t.is (= literal-pull.attrs[0].v.text "Ada"))
    (t.is (= text-pull.attrs[0].v.text "Ada"))
    (t.is literal-friend-ok)
    (t.is text-friend-ok)
    (t.is (= literal-pull.attrs[literal-friend-index].attrs[0].v.text "Grace"))
    (t.is (= text-pull.attrs[text-friend-index].attrs[0].v.text "Grace"))))

(t.deftest frontend-parity-advanced-query-forms
  (defer (free_all context.allocator))
  (let [literal-conn (vev.create-conn)
        text-conn (vev.create-conn)
        _ (vev.seed-people (addr literal-conn))
        _ (vev.seed-people (addr text-conn))
        literal-not (vev.q literal-conn.db
                      [:find ?name
                       :where
                       [?e :user/name ?name]
                       (not [?e :user/active true])])
        text-not (vev.q-text text-conn.db
                   "[:find ?name :where [?e :user/name ?name] (not [?e :user/active true])]")
        literal-or (vev.q literal-conn.db
                     [:find ?label
                      :where
                      [?e :user/name ?name]
                      (or-join [?e ?label]
                        (and [?e :user/active true]
                             [?e :user/name ?label])
                        (and [?e :user/active false]
                             [?e :user/email ?label]))])
        text-or (vev.q-text text-conn.db
                  "[:find ?label :where [?e :user/name ?name] (or-join [?e ?label] (and [?e :user/active true] [?e :user/name ?label]) (and [?e :user/active false] [?e :user/email ?label]))]")
        literal-get-else (vev.q literal-conn.db
                           [:find ?name ?email
                            :where
                            [?e :user/name ?name]
                            [(get-else $ ?e :user/email "none") ?email]])
        text-get-else (vev.q-text text-conn.db
                        "[:find ?name ?email :where [?e :user/name ?name] [(get-else $ ?e :user/email \"none\") ?email]]")]
    (t.is literal-not.ok)
    (t.is text-not.ok)
    (t.is (= (count literal-not.rows) (count text-not.rows)))
    (t.is (= literal-not.rows[0].values[0].text text-not.rows[0].values[0].text))
    (t.is literal-or.ok)
    (t.is text-or.ok)
    (t.is (= (count literal-or.rows) (count text-or.rows)))
    (t.is (= literal-or.rows[0].values[0].text text-or.rows[0].values[0].text))
    (t.is (= literal-or.rows[1].values[0].text text-or.rows[1].values[0].text))
    (t.is literal-get-else.ok)
    (t.is text-get-else.ok)
    (t.is (= (count literal-get-else.rows) (count text-get-else.rows)))
    (t.is (= literal-get-else.rows[0].values[0].text text-get-else.rows[0].values[0].text))
    (t.is (= literal-get-else.rows[0].values[1].text text-get-else.rows[0].values[1].text))
    (t.is (= literal-get-else.rows[1].values[0].text text-get-else.rows[1].values[0].text))
    (t.is (= literal-get-else.rows[1].values[1].text text-get-else.rows[1].values[1].text))))

(t.deftest datascript-parser-binding-api-subset
  (defer (free_all context.allocator))
  (let [scalar (vev.parse-binding-text "?x")
        ignore (vev.parse-binding-text "_")
        collection (vev.parse-binding-text "[?x ...]")
        tuple (vev.parse-binding-text "[?x ?y]")
        tuple-ignore (vev.parse-binding-text "[_ ?y]")
        nested (vev.parse-binding-text "[[_ [?x ...]] ...]")
        relation (vev.parse-binding-text "[[?a ?b ?c]]")
        bad (vev.parse-binding-text ":key")]
    (t.is scalar.ok)
    (t.is (= scalar.binding.kind .Var))
    (t.is (= scalar.binding.name "?x"))
    (t.is ignore.ok)
    (t.is (= ignore.binding.kind .Ignore))
    (t.is collection.ok)
    (t.is (= collection.binding.kind .Collection))
    (t.is (= collection.binding.items[0].kind .Var))
    (t.is (= collection.binding.items[0].name "?x"))
    (t.is tuple.ok)
    (t.is (= tuple.binding.kind .Tuple))
    (t.is (= (count tuple.binding.items) 2))
    (t.is (= tuple.binding.items[0].name "?x"))
    (t.is (= tuple.binding.items[1].name "?y"))
    (t.is tuple-ignore.ok)
    (t.is (= tuple-ignore.binding.items[0].kind .Ignore))
    (t.is (= tuple-ignore.binding.items[1].name "?y"))
    (t.is nested.ok)
    (t.is (= nested.binding.kind .Collection))
    (t.is (= nested.binding.items[0].kind .Tuple))
    (t.is (= nested.binding.items[0].items[0].kind .Ignore))
    (t.is (= nested.binding.items[0].items[1].kind .Collection))
    (t.is (= nested.binding.items[0].items[1].items[0].name "?x"))
    (t.is relation.ok)
    (t.is (= relation.binding.kind .Tuple))
    (t.is (= relation.binding.items[0].kind .Tuple))
    (t.is (= relation.binding.items[0].items[2].name "?c"))
    (t.is (not bad.ok))
    (t.is (= bad.error "unsupported :in binding form"))))

(t.deftest datascript-parser-in-with-api-subset
  (defer (free_all context.allocator))
  (let [simple (vev.parse-in-text "[?x]")
        source-rules (vev.parse-in-text "[$ $1 % _ ?x]")
        nested (vev.parse-in-text "[$ [[_ [?x ...]] ...]]")
        bad-in (vev.parse-in-text "[?x :key]")
        with-vars (vev.parse-with-text "[?x ?y]")
        bad-with (vev.parse-with-text "[?x _]")]
    (t.is simple.ok)
    (t.is (= (count simple.bindings) 1))
    (t.is (= simple.bindings[0].kind .Var))
    (t.is (= simple.bindings[0].name "?x"))
    (t.is source-rules.ok)
    (t.is (= (count source-rules.bindings) 5))
    (t.is (= source-rules.bindings[0].name "$"))
    (t.is (= source-rules.bindings[1].name "$1"))
    (t.is (= source-rules.bindings[2].name "%"))
    (t.is (= source-rules.bindings[3].kind .Ignore))
    (t.is (= source-rules.bindings[4].name "?x"))
    (t.is nested.ok)
    (t.is (= (count nested.bindings) 2))
    (t.is (= nested.bindings[0].name "$"))
    (t.is (= nested.bindings[1].kind .Collection))
    (t.is (= nested.bindings[1].items[0].kind .Tuple))
    (t.is (= nested.bindings[1].items[0].items[1].kind .Collection))
    (t.is (= nested.bindings[1].items[0].items[1].items[0].name "?x"))
    (t.is (not bad-in.ok))
    (t.is (= bad-in.error "unsupported :in binding form"))
    (t.is with-vars.ok)
    (t.is (= (count with-vars.vars) 2))
    (t.is (= with-vars.vars[0] "?x"))
    (t.is (= with-vars.vars[1] "?y"))
    (t.is (not bad-with.ok))
    (t.is (= bad-with.error "Cannot parse :with clause"))))

(t.deftest datascript-parser-rules-api-subset
  (defer (free_all context.allocator))
  (let [plain (vev.parse-rules-text "[[(rule ?x) [?x :name _]]]")
        required (vev.parse-rules-text "[[(rule [?x] ?y) [?x :friend ?y]]]")
        branches (vev.parse-rules-text "[[(rule ?x) [?x :a true] [(missing? $ ?x :b)]] [(rule ?x) [?x :c true]] [(other ?x) [?x :d true]]]")
        source-call (vev.parse-rules-text "[[(adult ?e) [?e :age ?age] [(>= ?age 18)]] [(adult-name ?e ?name) ($rows adult ?e) [?e :name ?name]]]")
        recursive (vev.parse-rules-text "[[(reachable ?x ?y) [?x :next ?y]] [(reachable ?x ?y) [?x :next ?z] (reachable ?z ?y)] [(named-reachable ?x ?name) (reachable ?x ?y) [?y :name ?name]]]")
        reachable-rules (vev.rules-for-call (slice recursive.rules 0) "reachable") :defer
        named-reachable-rules (vev.rules-for-call (slice recursive.rules 0) "named-reachable") :defer
        reachable-plan (vev.rule-call-plan (slice recursive.rules 0) "reachable")
        named-reachable-plan (vev.rule-call-plan (slice recursive.rules 0) "named-reachable")
        bad-empty (vev.parse-rules-text "[[(rule) [_]]]")
        bad-duplicate (vev.parse-rules-text "[[(rule ?x ?y ?x) [_]]]")
        bad-branch (vev.parse-rules-text "[[(rule ?x)]]")]
    (t.is plain.ok)
    (t.is (= (count plain.rules) 1))
    (t.is (= plain.rules[0].name "rule"))
    (t.is (= plain.rules[0].required-param-count 0))
    (t.is (= (count plain.rules[0].params) 1))
    (t.is (= plain.rules[0].params[0] "?x"))
    (t.is (= (count plain.rules[0].clauses) 1))
    (t.is (= plain.rules[0].clauses[0].a.value.text ":name"))
    (t.is (= plain.rules[0].clauses[0].v.kind .Wildcard))
    (t.is required.ok)
    (t.is (= required.rules[0].required-param-count 1))
    (t.is (= (count required.rules[0].params) 2))
    (t.is (= required.rules[0].params[0] "?x"))
    (t.is (= required.rules[0].params[1] "?y"))
    (t.is branches.ok)
    (t.is (= (count branches.rules) 3))
    (t.is (= branches.rules[0].name "rule"))
    (t.is (= branches.rules[1].name "rule"))
    (t.is (= branches.rules[2].name "other"))
    (t.is (= (count branches.rules[0].body-steps) 2))
    (t.is (= branches.rules[0].body-steps[0].kind .Clause))
    (t.is (= branches.rules[0].body-steps[1].kind .Not))
    (t.is source-call.ok)
    (t.is (= (count source-call.rules[1].rule-calls) 1))
    (t.is source-call.rules[1].rule-calls[0].has-source)
    (t.is (= source-call.rules[1].rule-calls[0].source "$rows"))
    (t.is (= source-call.rules[1].rule-calls[0].name "adult"))
    (t.is recursive.ok)
    (t.is (vev.rule-name-recursive? (slice recursive.rules 0) "reachable"))
    (t.is (not (vev.rule-name-recursive? (slice recursive.rules 0) "named-reachable")))
    (t.is (vev.rule-name-depends-on-recursive? (slice recursive.rules 0) "named-reachable"))
    (t.is (not (vev.rule-call-can-use-acyclic-depth? (slice recursive.rules 0) "named-reachable")))
    (t.is (= (vev.non-recursive-rule-depth (slice recursive.rules 0) "named-reachable") 3))
    (t.is (= (count reachable-rules) 2))
    (t.is (= (count named-reachable-rules) 3))
    (t.is reachable-plan.recursive)
    (t.is (= (count reachable-plan.rules) 2))
    (t.is named-reachable-plan.recursive)
    (t.is (= (count named-reachable-plan.rules) 3))
    (vev.delete-rule-call-plan reachable-plan)
    (vev.delete-rule-call-plan named-reachable-plan)
    (t.is (not bad-empty.ok))
    (t.is (= bad-empty.error "Cannot parse rule-vars"))
    (t.is (not bad-duplicate.ok))
    (t.is (= bad-duplicate.error "Rule variables should be distinct"))
    (t.is (not bad-branch.ok))
    (t.is (= bad-branch.error "Rule branch should have clauses"))))

(t.deftest datascript-parser-value-rendering-subset
  (defer (free_all context.allocator))
  (let [binding (vev.prepared-binding-value (vev.parse-binding-text "[?x [?y ...]]"))
        in-value (vev.prepared-in-value (vev.parse-in-text "[$ % [?x ...]]"))
        with-value (vev.prepared-with-value (vev.parse-with-text "[?x ?y]"))
        rules-value (vev.prepared-rules-value
                      (vev.parse-rules-text
                        "[[(adult [?e] ?name) [?e :age ?age] [(>= ?age 18)] [?e :name ?name]] [(adult-name ?e ?name) ($rows adult ?e ?name)]]"))
        query-value (vev.prepared-query-value
                      (vev.prepare-query-text
                        "[:find ?name (count ?e) :with ?tag :in $ % [?tag ...] :where [?e :name ?name] (adult ?e ?name)]"))
        tx-value (vev.prepared-tx-data-value
                   (vev.prepare-tx-text
                     "[[:db/add \"person\" :name \"Ada\"] [:db.fn/cas [:name \"Ada\"] :age nil 37]]"))
        bad-query (vev.prepared-query-value (vev.prepare-query-text "[:where [?e :name ?name]]"))
        [binding-ok binding-ok?] (map-value binding ":ok")
        [binding-shape binding-shape-ok] (map-value binding ":binding")
        [binding-items binding-items-ok] (map-value binding-shape ":items")
        [in-bindings in-bindings-ok] (map-value in-value ":bindings")
        [with-vars with-vars-ok] (map-value with-value ":vars")
        [rules rules-ok] (map-value rules-value ":rules")
        [first-rule-name first-rule-name-ok] (map-value rules.items[0] ":name")
        [first-rule-required first-rule-required-ok] (map-value rules.items[0] ":required-param-count")
        [first-rule-where first-rule-where-ok] (map-value rules.items[0] ":where")
        [second-rule-calls second-rule-calls-ok] (map-value rules.items[1] ":rule-calls")
        [query-find query-find-ok] (map-value query-value ":find")
        [query-with query-with-ok] (map-value query-value ":with")
        [query-input-specs query-input-specs-ok] (map-value query-value ":input-specs")
        [query-rules-input query-rules-input-ok] (map-value query-value ":rules-input")
        [query-where query-where-ok] (map-value query-value ":where")
        [query-aggregate-count query-aggregate-count-ok] (map-value query-value ":aggregate-count")
        [tx-data tx-data-ok] (map-value tx-value ":tx-data")
        [first-tx-op first-tx-op-ok] (map-value tx-data.items[0] ":op")
        [first-tx-e first-tx-e-ok] (map-value tx-data.items[0] ":e")
        [second-tx-e second-tx-e-ok] (map-value tx-data.items[1] ":e")
        [bad-ok bad-ok-ok] (map-value bad-query ":ok")
        [bad-error bad-error-ok] (map-value bad-query ":error")]
    (t.is binding-ok?)
    (t.is binding-ok.bool-value)
    (t.is binding-shape-ok)
    (t.is binding-items-ok)
    (t.is (= (count binding-items.items) 2))
    (t.is in-bindings-ok)
    (t.is (= (count in-bindings.items) 3))
    (t.is with-vars-ok)
    (t.is (= with-vars.items[0].text "?x"))
    (t.is (= with-vars.items[1].text "?y"))
    (t.is rules-ok)
    (t.is (= (count rules.items) 2))
    (t.is first-rule-name-ok)
    (t.is (= first-rule-name.text "adult"))
    (t.is first-rule-required-ok)
    (t.is (= first-rule-required.int-value 1))
    (t.is first-rule-where-ok)
    (t.is (= (count first-rule-where.items) 3))
    (t.is second-rule-calls-ok)
    (t.is (= (count second-rule-calls.items) 1))
    (t.is query-find-ok)
    (t.is (= (count query-find.items) 1))
    (t.is (= query-find.items[0].text "?name"))
    (t.is query-with-ok)
    (t.is (= query-with.items[0].text "?tag"))
    (t.is query-input-specs-ok)
    (t.is (= (count query-input-specs.items) 1))
    (t.is query-rules-input-ok)
    (t.is query-rules-input.bool-value)
    (t.is query-where-ok)
    (t.is (= (count query-where.items) 2))
    (t.is query-aggregate-count-ok)
    (t.is (= query-aggregate-count.int-value 1))
    (t.is tx-data-ok)
    (t.is (= (count tx-data.items) 2))
    (t.is first-tx-op-ok)
    (t.is (= first-tx-op.text ":db/add"))
    (t.is first-tx-e-ok)
    (t.is (= first-tx-e.text "person"))
    (t.is second-tx-e-ok)
    (t.is (= second-tx-e.kind .Vector))
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-error-ok)
    (t.is (= bad-error.text "query text must start with [:find"))))

(t.deftest datascript-parser-query-text-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :active true :age 37}
             {:db/id 2 :name "Grace Hopper" :active false :age 41}])
        collection-query (vev.empty-query)
        [collection-ok collection-error] (vev.parse-query-text! (addr collection-query) "[:find [?name ...] :where [_ :name ?name]]")
        prepared (vev.prepare-query-text "[:find ?name :where [?e :name ?name] [?e :active true]]")
        prepared-result (vev.q-prepared conn.db prepared)
        prepared-input (vev.prepare-query-text "[:find ?e :in ?name :where [?e :name ?name]]")
        prepared-input-result (vev.q-prepared-with-inputs
                                conn.db
                                prepared-input
                                ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Grace Hopper"))]))
        bad-prepared (vev.prepare-query-text "[:where [?e :name ?name]]")
        bad-prepared-result (vev.q-prepared conn.db bad-prepared)
        relation (vev.q-text conn.db "[:find ?e ?name :where [?e :name ?name] [?e :active true]]")
        collection (vev.result-collection (vev.q-query conn.db collection-query))
        constant (vev.q-text conn.db "[:find ?e :where [?e :name \"Grace Hopper\"]]")
        numeric (vev.q-text conn.db "[:find ?name :where [1 :age 37] [1 :name ?name]]")
        negative-entity-term (vev.q-text conn.db "[:find ?name :where [-1 :name ?name]]")
        negative-value-term (vev.q-text conn.db "[:find ?e :where [?e :score -1]]")
        map-query (vev.q-text-with-inputs
                    conn.db
                    "{:find [?e] :in [$ ?attr ?value] :where [[?e ?attr ?value]]}"
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":name"))
                                         (vev.query-input-scalar (vev.value-string "Ada Lovelace"))]))
        map-relation (vev.q-text-with-inputs
                       conn.db
                       "{:find [?e ?email] :in [$ [[?name ?email]]] :where [[?e :name ?name]]}"
                       ([]vev.Query-Input [(vev.query-input-relation
                                             ([]vev.Value [(vev.value-string "Ada Lovelace")
                                                           (vev.value-string "ada@example.com")
                                                           (vev.value-string "Grace Hopper")
                                                           (vev.value-string "grace@example.com")])
                                             2)]))
        map-no-where (vev.q-text-with-inputs
                       conn.db
                       "{:find [?x] :in [?x]}"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ok"))]))
        map-keys (vev.q-text-keys
                   conn.db
                   "{:find [?name ?age] :keys [name age] :where [[?e :name ?name] [?e :age ?age]]}")
        bad (vev.q-text conn.db "[:where [?e :name ?name]]")
        missing-input (vev.q-text-with-inputs
                        conn.db
                        "[:find ?x :in ?x]"
                        ([]vev.Query-Input []))
        extra-input (vev.q-text-with-inputs
                      conn.db
                      "[:find ?e :where [?e :name ?name]]"
                      ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "unused"))]))
        unknown-find (vev.q-text conn.db "[:find ?missing :where [?e :name]]")
        unknown-with (vev.q-text conn.db "[:find ?e :with ?missing :where [?e :name]]")
        unknown-find-many (vev.q-text-with-inputs
                             conn.db
                             "[:find ?e ?x ?t :in ?x :where [?e :name]]"
                             ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "input"))]))
        unknown-with-many (vev.q-text conn.db "[:find ?name :with ?e ?missing :where [?e :name ?name]]")
        unknown-find-and-with (vev.q-text conn.db "[:find ?missing ?also-missing :with ?with-missing :where [?e :name]]")
        unknown-find-literal (vev.q conn.db
                               [:find ?missing
                                :where
                                [?e :name]])
        find-with-overlap (vev.q-text conn.db "[:find ?e :with ?e :where [?e :name]]")
        duplicate-in (vev.q-text-with-inputs
                       conn.db
                       "[:find ?e :in ?x ?x :where [?e :name]]"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "a"))
                                            (vev.query-input-scalar (vev.value-string "b"))]))
        duplicate-with (vev.q-text conn.db "[:find ?name :with ?e ?e :where [?e :name ?name]]")
        missing-rules-var (vev.q-text conn.db "[:find ?e :where (rule ?e)]")
        missing-rules-var-map (vev.q-text conn.db "{:find [?e] :where [(rule ?e)]}")
        missing-rules-var-literal (vev.q conn.db
                                    [:find ?e
                                     :where
                                     (rule ?e)])
        unknown-source (vev.q-text conn.db "[:find ?name :where [$2 ?e :name ?name]]")
        empty-pattern (vev.q-text conn.db "[:find ?e :where []]")
        zero-predicate-query (vev.empty-query)
        zero-function-query (vev.empty-query)
        [zero-predicate-ok zero-predicate-error] (vev.parse-query-text! (addr zero-predicate-query) "[:find ?e :where [?e :name] [(custom-pred)]]")
        [zero-function-ok zero-function-error] (vev.parse-query-text! (addr zero-function-query) "[:find ?e ?x :where [?e :name] [(custom-fn) ?x]]")
        aggregate-extra-query (vev.empty-query)
        [aggregate-extra-ok aggregate-extra-error] (vev.parse-query-text! (addr aggregate-extra-query) "[:find (count ?name 1 $x) :in $x :where [?e :name ?name]]")
        zero-predicate-runtime (vev.q-text conn.db "[:find ?e :where [?e :name] [(custom-pred)]]")
        zero-function-runtime (vev.q-text conn.db "[:find ?e ?x :where [?e :name] [(custom-fn) ?x]]")
        unknown-predicate (vev.q-text-with-inputs
                             conn.db
                             "[:find ?e :in [?e ...] :where [(fun ?e)]]"
                             ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1)]))]))
        unknown-function (vev.q-text-with-inputs
                           conn.db
                           "[:find ?e ?x :in [?e ...] :where [(fun ?e) ?x]]"
                           ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1)]))]))
        unbound-predicate (vev.q-text conn.db "[:find ?x :where [(zero? ?x)]]")
        unbound-function (vev.q-text conn.db "[:find ?x :where [(inc ?x) ?y]]")
        unbound-not (vev.q-text conn.db "[:find ?e :where [?e :name] (not [?a :name \"Ada Lovelace\"])]")
        not-before-binding (vev.q-text conn.db "[:find ?e :where (not [?e :name \"Ada Lovelace\"]) [?e :name]]")
        predicate-before-binding (vev.q-text conn.db "[:find ?name :where [(= ?name \"Ada Lovelace\")] [?e :name ?name]]")
        mismatched-or (vev.q-text conn.db "[:find ?e :where (or [?e :name _] [?e :age ?a])]")
        symbol-constant (vev.q-text conn.db "[:find ?e :where [?e :name sym]]")
        dollar-symbol-constant (vev.q-text conn.db "[:find ?e :where [?e :name $src-sym]]")
        relation-source (vev.q-text-with-inputs
                          conn.db
                          "[:find ?name :in $rows :where [$rows ?e :name ?name]]"
                          ([]vev.Query-Input
                            [(vev.query-input-scalar
                               (vev.value-vector
                                    ([]vev.Value
                                      [(vev.value-vector
                                         ([]vev.Value [(vev.value-int 1)
                                                       (vev.value-keyword ":name")
                                                       (vev.value-string "Ada Lovelace")]))])))]))
        source-one-wide (vev.q-text-with-inputs
                          conn.db
                          "[:find ?e :in $ids :where [$ids ?e]]"
                          ([]vev.Query-Input
                            [(vev.query-input-collection
                               ([]vev.Value [(vev.value-entity 1)
                                             (vev.value-entity 2)]))]))
        source-two-wide (vev.q-text-with-inputs
                          conn.db
                          "[:find ?e :in $pairs :where [$pairs ?e :name]]"
                          ([]vev.Query-Input
                            [(vev.query-input-relation
                               ([]vev.Value [(vev.value-entity 1) (vev.value-keyword ":name")
                                             (vev.value-entity 2) (vev.value-keyword ":age")])
                               2)]))
        source-symbol-value (vev.q-text-with-inputs
                              conn.db
                              "[:find ?e :in $rows :where [$rows ?e :status $src-sym]]"
                              ([]vev.Query-Input
                                [(vev.query-input-scalar
                                   (vev.value-vector
                                     ([]vev.Value
                                       [(vev.value-vector
                                          ([]vev.Value [(vev.value-entity 1)
                                                        (vev.value-keyword ":status")
                                                        (vev.value-symbol "$src-sym")]))])))]))]
    (defer (delete collection))
    (t.is (= (count relation.rows) 1))
    (t.is (= relation.rows[0].values[0].entity 1))
    (t.is (= relation.rows[0].values[1].text "Ada Lovelace"))
    (t.is collection-ok)
    (t.is (= collection-error ""))
    (t.is (= (count collection) 2))
    (t.is (= collection[0].text "Ada Lovelace"))
    (t.is (= collection[1].text "Grace Hopper"))
    (t.is prepared.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].text "Ada Lovelace"))
    (t.is prepared-input.ok)
    (t.is (= (count prepared-input-result.rows) 1))
    (t.is (= prepared-input-result.rows[0].values[0].entity 2))
    (t.is (not bad-prepared.ok))
    (t.is (not bad-prepared-result.ok))
    (t.is (= (count constant.rows) 1))
    (t.is (= constant.rows[0].values[0].entity 2))
    (t.is (= (count numeric.rows) 1))
    (t.is (= numeric.rows[0].values[0].text "Ada Lovelace"))
    (t.is (not negative-entity-term.ok))
    (t.is (= negative-entity-term.error "query entity integer terms must be non-negative"))
    (t.is negative-value-term.ok)
    (t.is (= (count negative-value-term.rows) 0))
    (t.is (= (count map-query.rows) 1))
    (t.is (= map-query.rows[0].values[0].entity 1))
    (t.is (= (count map-relation.rows) 2))
    (t.is (= map-relation.rows[0].values[0].entity 1))
    (t.is (= map-relation.rows[0].values[1].text "ada@example.com"))
    (t.is (= map-relation.rows[1].values[0].entity 2))
    (t.is (= map-relation.rows[1].values[1].text "grace@example.com"))
    (t.is (= (count map-no-where.rows) 1))
    (t.is (= map-no-where.rows[0].values[0].text ":ok"))
    (t.is (= (count map-keys) 2))
    (t.is (= map-keys[0].items[0].key "name"))
    (t.is (= map-keys[0].items[0].value.text "Ada Lovelace"))
    (t.is (= map-keys[0].items[1].key "age"))
    (t.is (= map-keys[0].items[1].value.int-value 37))
    (t.is (not bad.ok))
    (t.is (= bad.error "query text must start with [:find"))
    (t.is (= (count bad.rows) 0))
    (t.is (not missing-input.ok))
    (t.is (= missing-input.error "wrong number of query inputs: expected 1, got 0"))
    (t.is (not extra-input.ok))
    (t.is (= extra-input.error "wrong number of query inputs: expected 0, got 1"))
    (t.is (not unknown-find.ok))
    (t.is (= unknown-find.error "Query for unknown vars: [?missing]"))
    (t.is (not unknown-with.ok))
    (t.is (= unknown-with.error "Query for unknown vars: [?missing]"))
    (t.is (not unknown-find-many.ok))
    (t.is (= unknown-find-many.error "Query for unknown vars: [?t]"))
    (t.is (not unknown-with-many.ok))
    (t.is (= unknown-with-many.error "Query for unknown vars: [?missing]"))
    (t.is (not unknown-find-and-with.ok))
    (t.is (= unknown-find-and-with.error "Query for unknown vars: [?missing ?also-missing ?with-missing]"))
    (t.is (not unknown-find-literal.ok))
    (t.is (= unknown-find-literal.error "Query for unknown vars: [?missing]"))
    (t.is (not find-with-overlap.ok))
    (t.is (= find-with-overlap.error ":find and :with should not use same variables: ?e"))
    (t.is (not duplicate-in.ok))
    (t.is (= duplicate-in.error "Vars used in :in should be distinct"))
    (t.is (not duplicate-with.ok))
    (t.is (= duplicate-with.error "Vars used in :with should be distinct"))
    (t.is (not missing-rules-var.ok))
    (t.is (= missing-rules-var.error "Missing rules var '%' in :in"))
    (t.is (not missing-rules-var-map.ok))
    (t.is (= missing-rules-var-map.error "Missing rules var '%' in :in"))
    (t.is (not missing-rules-var-literal.ok))
    (t.is (= missing-rules-var-literal.error "Missing rules var '%' in :in"))
    (t.is (not unknown-source.ok))
    (t.is (= unknown-source.error "unknown query source: $2"))
    (t.is (not empty-pattern.ok))
    (t.is (= empty-pattern.error "Pattern could not be empty"))
    (t.is zero-predicate-ok zero-predicate-error)
    (t.is zero-function-ok zero-function-error)
    (t.is aggregate-extra-ok aggregate-extra-error)
    (t.is (= (count aggregate-extra-query.aggregates) 1))
    (t.is (= aggregate-extra-query.aggregates[0].op "count"))
    (t.is (= aggregate-extra-query.aggregates[0].var "?name"))
    (t.is (= (count aggregate-extra-query.aggregates[0].args) 3))
    (t.is (= aggregate-extra-query.aggregates[0].args[0].kind .Var))
    (t.is (= aggregate-extra-query.aggregates[0].args[1].value.kind .Int))
    (t.is (= aggregate-extra-query.aggregates[0].args[1].value.int-value 1))
    (t.is (= aggregate-extra-query.aggregates[0].args[2].value.kind .Symbol))
    (t.is (= aggregate-extra-query.aggregates[0].args[2].value.text "$x"))
    (t.is (not zero-predicate-runtime.ok))
    (t.is (= zero-predicate-runtime.error "unknown query predicate: custom-pred"))
    (t.is (not zero-function-runtime.ok))
    (t.is (= zero-function-runtime.error "unknown query function: custom-fn"))
    (t.is (not unknown-predicate.ok))
    (t.is (= unknown-predicate.error "unknown query predicate: fun"))
    (t.is (not unknown-function.ok))
    (t.is (= unknown-function.error "unknown query function: fun"))
    (t.is (not unbound-predicate.ok))
    (t.is (= unbound-predicate.error "insufficient bindings for zero?: ?x"))
    (t.is (not unbound-function.ok))
    (t.is (= unbound-function.error "insufficient bindings for inc: ?x"))
    (t.is (not unbound-not.ok))
    (t.is (= unbound-not.error "insufficient bindings for not: ?a"))
    (t.is (not not-before-binding.ok))
    (t.is (= not-before-binding.error "insufficient bindings for not: ?e"))
    (t.is (not predicate-before-binding.ok))
    (t.is (= predicate-before-binding.error "insufficient bindings for =: ?name"))
    (t.is (not mismatched-or.ok))
    (t.is (= mismatched-or.error "or branches must use same vars"))
    (t.is (= (count symbol-constant.rows) 0))
    (t.is (= (count dollar-symbol-constant.rows) 0))
    (t.is relation-source.ok)
    (t.is (= (count relation-source.rows) 1))
    (t.is (= relation-source.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= (count source-one-wide.rows) 2))
    (t.is (= source-one-wide.rows[0].values[0].entity 1))
    (t.is (= source-one-wide.rows[1].values[0].entity 2))
    (t.is (= (count source-two-wide.rows) 1))
    (t.is (= source-two-wide.rows[0].values[0].entity 1))
    (t.is (= (count source-symbol-value.rows) 1))
    (t.is (= source-symbol-value.rows[0].values[0].entity 1))))

(t.deftest datascript-parser-query-section-validation-subset
  (defer (free_all context.allocator))
  (let [duplicate-where (vev.prepare-query-text "[:find ?e :where [?e :name] :where [?e :age]]")
        duplicate-in (vev.prepare-query-text "[:find ?e :in ?x :in ?y :where [?e :name]]")
        duplicate-with (vev.prepare-query-text "[:find ?e :with ?x :with ?y :where [?e :name]]")
        out-of-order-with (vev.prepare-query-text "[:find ?e :where [?e :name] :with ?name]")
        out-of-order-in (vev.prepare-query-text "[:find ?e :where [?e :name] :in ?name]")
        duplicate-return (vev.prepare-query-text "[:find ?e :keys e :strs e :where [?e :name]]")
        map-unsupported (vev.prepare-query-text "{:find [?e] :foo [?x] :where [[?e :name]]}")
        map-duplicate-find (vev.prepare-query-text "{:find [?e] :find [?name] :where [[?e :name ?name]]}")
        map-duplicate-where (vev.prepare-query-text "{:find [?e] :where [[?e :name]] :where [[?e :age]]}")
        map-duplicate-return (vev.prepare-query-text "{:find [?e] :keys [e] :strs [e] :where [[?e :name]]}")]
    (t.is (not duplicate-where.ok))
    (t.is (= duplicate-where.error "query text has duplicate :where section"))
    (t.is (not duplicate-in.ok))
    (t.is (= duplicate-in.error "query text has duplicate :in section"))
    (t.is (not duplicate-with.ok))
    (t.is (= duplicate-with.error "query text has duplicate :with section"))
    (t.is (not out-of-order-with.ok))
    (t.is (= out-of-order-with.error "query sections must appear in :find :with :in :where order"))
    (t.is (not out-of-order-in.ok))
    (t.is (= out-of-order-in.error "query sections must appear in :find :with :in :where order"))
    (t.is (not duplicate-return.ok))
    (t.is (= duplicate-return.error "Only one of :keys/:syms/:strs must be present"))
    (t.is (not map-unsupported.ok))
    (t.is (= map-unsupported.error "query map contains unsupported key"))
    (t.is (not map-duplicate-find.ok))
    (t.is (= map-duplicate-find.error "query map has duplicate :find section"))
    (t.is (not map-duplicate-where.ok))
    (t.is (= map-duplicate-where.error "query map has duplicate :where section"))
    (t.is (not map-duplicate-return.ok))
    (t.is (= map-duplicate-return.error "Only one of :keys/:syms/:strs must be present"))))

(t.deftest datascript-query-result-dedupe-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :age 10 :email "a@example.com"}
             {:db/id 2 :age 10 :email "b@example.com"}
             {:db/id 3 :age 20 :email "c@example.com"}
             {:db/id 4 :age 10 :email "a@example.com"}])
        distinct-ages (vev.q-text conn.db "[:find ?age :where [?e :age ?age]]")
        with-ages (vev.q-text conn.db "[:find ?age :with ?e :where [?e :age ?age]]")
        email-ages (vev.q-text conn.db "[:find ?age ?email :where [?e :age ?age] [?e :email ?email]]")]
    (t.is distinct-ages.ok)
    (t.is (= (count distinct-ages.rows) 2))
    (t.is with-ages.ok)
    (t.is (= (count with-ages.rows) 4))
    (t.is email-ages.ok)
    (t.is (= (count email-ages.rows) 3))))

(t.deftest datascript-query-rendered-text-and-prepared-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :name}
             {:db/id 101 :db/ident :friend :db/valueType :db.type/ref}
             {:db/id 1 :name "Petr" :friend 2}
             {:db/id 2 :name "David"}])
        prepared (vev.prepare-query-text "[:find ?name :where [?e :name ?name]]")
        text-value (vev.q-text-value conn.db "[:find ?name :where [?e :name ?name]]")
        prepared-value (vev.q-prepared-value conn.db prepared)
        input-value (vev.q-text-value-with-inputs
                      conn.db
                      "[:find ?name :in $ ?needle :where [?e :name ?needle] [?e :name ?name]]"
                      ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Petr"))]))
        input-text-value (vev.q-text-value-with-input-text
                           conn.db
                           "[:find ?name :in ?needle :where [?e :name ?needle] [?e :name ?name]]"
                           "[\"Petr\"]")
        input-text-collection-value (vev.q-text-value-with-input-text
                                      conn.db
                                      "[:find ?name :in [?needle ...] :where [?e :name ?needle] [?e :name ?name]]"
                                      "[[\"Petr\" \"David\"]]")
        input-text-tuple-value (vev.q-text-value-with-input-text
                                 conn.db
                                 "[:find ?e :in [?name ?friend] :where [?e :name ?name] [?e :friend ?friend]]"
                                 "[[\"Petr\" 2]]")
        input-text-relation-value (vev.q-text-value-with-input-text
                                    conn.db
                                    "[:find ?name :in [[?name ?friend]] :where [?e :name ?name] [?e :friend ?friend]]"
                                    "[[[\"Petr\" 2] [\"Nobody\" 2]]]")
        prepared-input-text (vev.prepare-query-text "[:find ?name :in ?needle :where [?e :name ?needle] [?e :name ?name]]")
        prepared-input-text-value (vev.q-prepared-value-with-input-text conn.db prepared-input-text "[\"David\"]")
        pull-value (vev.q-text-value conn.db "[:find (pull ?e [:name]) :where [?e :name \"Petr\"]]")
        bad-value (vev.q-text-value conn.db "[:where [?e :name ?name]]")
        [text-ok text-ok-ok] (map-value text-value ":ok")
        [text-rows text-rows-ok] (map-value text-value ":rows")
        [text-first-values text-first-values-ok] (map-value text-rows.items[0] ":values")
        [prepared-rows prepared-rows-ok] (map-value prepared-value ":rows")
        [prepared-first-values prepared-first-values-ok] (map-value prepared-rows.items[0] ":values")
        [input-rows input-rows-ok] (map-value input-value ":rows")
        [input-first-values input-first-values-ok] (map-value input-rows.items[0] ":values")
        [input-text-rows input-text-rows-ok] (map-value input-text-value ":rows")
        [input-text-first-values input-text-first-values-ok] (map-value input-text-rows.items[0] ":values")
        [input-text-collection-rows input-text-collection-rows-ok] (map-value input-text-collection-value ":rows")
        [input-text-tuple-rows input-text-tuple-rows-ok] (map-value input-text-tuple-value ":rows")
        [input-text-relation-rows input-text-relation-rows-ok] (map-value input-text-relation-value ":rows")
        [prepared-input-text-rows prepared-input-text-rows-ok] (map-value prepared-input-text-value ":rows")
        [prepared-input-text-first-values prepared-input-text-first-values-ok] (map-value prepared-input-text-rows.items[0] ":values")
        [pull-rows pull-rows-ok] (map-value pull-value ":rows")
        [pull-first-pulls pull-first-pulls-ok] (map-value pull-rows.items[0] ":pulls")
        [pulled-name pulled-name-ok] (map-value pull-first-pulls.items[0] ":name")
        [bad-ok bad-ok-ok] (map-value bad-value ":ok")
        [bad-error bad-error-ok] (map-value bad-value ":error")
        [bad-rows bad-rows-ok] (map-value bad-value ":rows")]
    (t.is text-ok-ok)
    (t.is text-ok.bool-value)
    (t.is text-rows-ok)
    (t.is (= text-rows.kind .Vector))
    (t.is (= (count text-rows.items) 2))
    (t.is text-first-values-ok)
    (t.is (= text-first-values.kind .Vector))
    (t.is (= text-first-values.items[0].text "Petr"))
    (t.is prepared-rows-ok)
    (t.is prepared-first-values-ok)
    (t.is (= prepared-first-values.items[0].text "Petr"))
    (t.is input-rows-ok)
    (t.is (= (count input-rows.items) 1))
    (t.is input-first-values-ok)
    (t.is (= input-first-values.items[0].text "Petr"))
    (t.is input-text-rows-ok)
    (t.is (= (count input-text-rows.items) 1))
    (t.is input-text-first-values-ok)
    (t.is (= input-text-first-values.items[0].text "Petr"))
    (t.is input-text-collection-rows-ok)
    (t.is (= (count input-text-collection-rows.items) 2))
    (t.is input-text-tuple-rows-ok)
    (t.is (= (count input-text-tuple-rows.items) 1))
    (t.is input-text-relation-rows-ok)
    (t.is (= (count input-text-relation-rows.items) 1))
    (t.is prepared-input-text-rows-ok)
    (t.is (= (count prepared-input-text-rows.items) 1))
    (t.is prepared-input-text-first-values-ok)
    (t.is (= prepared-input-text-first-values.items[0].text "David"))
    (t.is pull-rows-ok)
    (t.is pull-first-pulls-ok)
    (t.is (= pull-first-pulls.kind .Vector))
    (t.is (= (count pull-first-pulls.items) 1))
    (t.is pulled-name-ok)
    (t.is (= pulled-name.text "Petr"))
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-error-ok)
    (t.is (= bad-error.text "query text must start with [:find"))
    (t.is bad-rows-ok)
    (t.is (= (count bad-rows.items) 0))))

(t.deftest datascript-query-profiled-text-and-prepared-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada" :status "pending"}
             {:db/id 2 :name "Grace" :status "started"}
             {:db/id 3 :name "Barbara" :status "pending"}])
        text-profiled (vev.q-text-profiled
                        conn.db
                        "[:find ?e :where [?e :status \"pending\"] [?e :name ?name]]")
        prepared (vev.prepare-query-text "[:find ?name :in $ ?status :where [?e :status ?status] [?e :name ?name]]")
        prepared-profiled (vev.q-prepared-profiled-with-inputs
                             conn.db
                             prepared
                             ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "pending"))]))
        rendered (vev.q-text-profiled-value
                   conn.db
                   "[:find ?e :where [?e :status \"pending\"] [?e :name ?name]]")
        [rendered-result rendered-result-ok] (map-value rendered ":result")
        [rendered-stats rendered-stats-ok] (map-value rendered ":stats")
        [rendered-rows rendered-rows-ok] (map-value rendered-result ":rows")
        [rendered-candidates rendered-candidates-ok] (map-value rendered-stats ":clause-candidates")
        [rendered-steps rendered-steps-ok] (map-value rendered-stats ":steps")
        [rendered-output rendered-output-ok] (map-value rendered-stats ":output-rows")
        bad-rendered (vev.q-text-profiled-value conn.db "[:where [?e :name ?name]]")
        [bad-result bad-result-ok] (map-value bad-rendered ":result")
        [bad-stats bad-stats-ok] (map-value bad-rendered ":stats")
        [bad-ok bad-ok-ok] (map-value bad-result ":ok")
        [bad-output bad-output-ok] (map-value bad-stats ":output-rows")]
    (t.is text-profiled.result.ok)
    (t.is (= (count text-profiled.result.rows) 2))
    (t.is (= text-profiled.stats.input-bindings 1))
    (t.is (= text-profiled.stats.steps 2))
    (t.is (= text-profiled.stats.output-rows 2))
    (t.is (> text-profiled.stats.clause-candidates 0))
    (t.is prepared-profiled.result.ok)
    (t.is (= (count prepared-profiled.result.rows) 2))
    (t.is (= prepared-profiled.stats.steps 2))
    (t.is (= prepared-profiled.stats.output-rows 2))
    (t.is rendered-result-ok)
    (t.is rendered-stats-ok)
    (t.is rendered-rows-ok)
    (t.is (= (count rendered-rows.items) 2))
    (t.is rendered-candidates-ok)
    (t.is (> rendered-candidates.int-value 0))
    (t.is rendered-steps-ok)
    (t.is (= rendered-steps.int-value 2))
    (t.is rendered-output-ok)
    (t.is (= rendered-output.int-value 2))
    (t.is bad-result-ok)
    (t.is bad-stats-ok)
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-output-ok)
    (t.is (= bad-output.int-value 0))))

(t.deftest query-pure-clauses-use-indexed-planner
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada" :age 37 :email "ada@example.com"}
             {:db/id 2 :name "Grace" :age 41 :email "grace@example.com"}
             {:db/id 3 :name "Barbara" :age 39 :email "barbara@example.com"}])
        result (vev.q-text-profiled-with-inputs
                 conn.db
                 "[:find ?name ?age :in $ ?email :where [?e :age ?age] [?e :email ?email] [?e :name ?name]]"
                 ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "grace@example.com"))]))]
    (t.is result.result.ok)
    (t.is (= (count result.result.rows) 1))
    (t.is (= result.result.rows[0].values[0].text "Grace"))
    (t.is (= result.result.rows[0].values[1].int-value 41))
    (t.is (= result.stats.steps 3))
    (t.is (= result.stats.clauses 3))
    (t.is (= result.stats.clause-candidates 3))
    (t.is (= result.stats.max-intermediate-bindings 1))))

(t.deftest datascript-query-rendered-rules-and-sources-values-subset
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact
            (addr left)
            [{:db/id 1 :name "Petr" :friend 2}
             {:db/id 2 :name "David"}])
        _ (vev.transact
            (addr right)
            [{:db/id 2 :status :active}
             {:db/id 3 :status :archived}])
        rules-text "[[(friend-name ?e ?name) [?e :friend ?f] [?f :name ?name]]]"
        query-text "[:find ?name :in $ % ?e :where (friend-name ?e ?name)]"
        prepared (vev.prepare-query-text query-text)
        prepared-rules (vev.parse-rules-text rules-text)
        inputs ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))])
        text-rules-value (vev.q-text-value-with-rules left.db query-text rules-text inputs)
        prepared-rules-value (vev.q-prepared-value-with-rules left.db prepared prepared-rules inputs)
        sources ([]vev.DB-Source [(vev.db-source "$left" left.db)
                                  (vev.db-source "$right" right.db)])
        source-value (vev.q-text-value-with-sources
                       left.db
                       "[:find ?name ?status :where [$left ?e :name ?name] [$right ?e :status ?status]]"
                       ([]vev.Query-Input [])
                       sources)
        prepared-source (vev.prepare-query-text-with-sources
                          "[:find ?name ?status :where [$left ?e :name ?name] [$right ?e :status ?status]]"
                          sources)
        prepared-source-value (vev.q-prepared-value-with-sources
                                left.db
                                prepared-source
                                ([]vev.Query-Input [])
                                sources)
        bad-rules-value (vev.q-text-value-with-rules
                          left.db
                          query-text
                          "[[(friend-name ?e ?name)]]"
                          inputs)
        [text-rules-rows text-rules-rows-ok] (map-value text-rules-value ":rows")
        [text-rules-values text-rules-values-ok] (map-value text-rules-rows.items[0] ":values")
        [prepared-rules-rows prepared-rules-rows-ok] (map-value prepared-rules-value ":rows")
        [prepared-rules-values prepared-rules-values-ok] (map-value prepared-rules-rows.items[0] ":values")
        [source-rows source-rows-ok] (map-value source-value ":rows")
        [source-values source-values-ok] (map-value source-rows.items[0] ":values")
        [prepared-source-rows prepared-source-rows-ok] (map-value prepared-source-value ":rows")
        [prepared-source-values prepared-source-values-ok] (map-value prepared-source-rows.items[0] ":values")
        [bad-ok bad-ok-ok] (map-value bad-rules-value ":ok")
        [bad-error bad-error-ok] (map-value bad-rules-value ":error")]
    (t.is text-rules-rows-ok)
    (t.is (= (count text-rules-rows.items) 1))
    (t.is text-rules-values-ok)
    (t.is (= text-rules-values.items[0].text "David"))
    (t.is prepared-rules-rows-ok)
    (t.is (= (count prepared-rules-rows.items) 1))
    (t.is prepared-rules-values-ok)
    (t.is (= prepared-rules-values.items[0].text "David"))
    (t.is source-rows-ok)
    (t.is (= (count source-rows.items) 1))
    (t.is source-values-ok)
    (t.is (= source-values.items[0].text "David"))
    (t.is (= source-values.items[1].text ":active"))
    (t.is prepared-source-rows-ok)
    (t.is (= (count prepared-source-rows.items) 1))
    (t.is prepared-source-values-ok)
    (t.is (= prepared-source-values.items[0].text "David"))
    (t.is (= prepared-source-values.items[1].text ":active"))
    (t.is bad-ok-ok)
    (t.is (not bad-ok.bool-value))
    (t.is bad-error-ok)
    (t.is (= bad-error.text "Rule branch should have clauses"))))

(t.deftest datascript-parser-query-text-predicates-and-functions
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :age 37}
             {:db/id 2 :name "Grace Hopper" :age 41}
             {:db/id 3 :name "Alan Turing" :age 40}])
        older (vev.q-text conn.db "[:find ?name :where [?e :age ?age] [(> ?age 40)] [?e :name ?name]]")
        even-age (vev.q-text conn.db "[:find ?name :where [?e :age ?age] [(even? ?age)] [?e :name ?name]]")
        next-age (vev.q-text conn.db "[:find ?name ?next :where [?e :age ?age] [(inc ?age) ?next] [(> ?next 40)] [?e :name ?name]]")
        destructured (vev.q-text conn.db "[:find ?name ?age :where [?e :name ?n] [?e :age ?a] [(vector ?n ?a) [?name ?age]] [(= ?name \"Ada Lovelace\")]]")]
    (t.is (= (count older.rows) 1))
    (t.is (= older.rows[0].values[0].text "Grace Hopper"))
    (t.is (= (count even-age.rows) 1))
    (t.is (= even-age.rows[0].values[0].text "Alan Turing"))
    (t.is (= (count next-age.rows) 2))
    (t.is (= next-age.rows[0].values[0].text "Grace Hopper"))
    (t.is (= next-age.rows[0].values[1].int-value 42))
    (t.is (= next-age.rows[1].values[0].text "Alan Turing"))
    (t.is (= next-age.rows[1].values[1].int-value 41))
    (t.is (= (count destructured.rows) 1))
    (t.is (= destructured.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= destructured.rows[0].values[1].int-value 37))))

(t.deftest datascript-parser-query-text-inputs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada" :age 37 :email "ada@example.com"}
             {:db/id 2 :name "Grace" :age 85 :email "grace@example.com"}])
        scalar (vev.q-text-with-inputs
                 conn.db
                 "[:find ?name :in ?email :where [?e :email ?email] [?e :name ?name]]"
                 ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "ada@example.com"))]))
        collection (vev.q-text-with-inputs
                     conn.db
                     "[:find ?name :in [?email ...] :where [?e :email ?email] [?e :name ?name]]"
                     ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "ada@example.com") (vev.value-string "grace@example.com")]))]))
        tuple (vev.q-text-with-inputs
                conn.db
                "[:find ?e :in [?name ?age] :where [?e :name ?name] [?e :age ?age]]"
                ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37)]))]))
        relation (vev.q-text-with-inputs
                   conn.db
                   "[:find ?e :in [[?name ?age]] :where [?e :name ?name] [?e :age ?age]]"
                   ([]vev.Query-Input [(vev.query-input-relation ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37) (vev.value-string "Nope") (vev.value-int 0)]) 2)]))
        map-input (vev.value-map
                    ([]vev.Value
                      [(vev.value-keyword ":ada") (vev.value-string "ada@example.com")
                       (vev.value-keyword ":grace") (vev.value-string "grace@example.com")]))
        nested-flat-input (vev.value-map
                            ([]vev.Value
                              [(vev.value-keyword ":ada") (vev.value-int 37)
                               (vev.value-keyword ":grace") (vev.value-int 85)]))
        nested-tuple-input (vev.value-map
                             ([]vev.Value
                               [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 7)]))
                                (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 4) (vev.value-int 2)]))]))
        nested-collection-input (vev.value-map
                                  ([]vev.Value
                                    [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))
                                     (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 0) (vev.value-int 4)]))]))
        map-relation (vev.q-text-with-inputs
                       conn.db
                       "[:find ?k ?name :in [[?k ?email]] :where [?e :email ?email] [?e :name ?name]]"
                       ([]vev.Query-Input [(vev.query-input-scalar map-input)]))
        nested-flat (vev.q-text-with-inputs
                      conn.db
                      "[:find ?k ?age :in [[?k ?age] ...] :where [(> ?age 40)]]"
                      ([]vev.Query-Input [(vev.query-input-scalar nested-flat-input)]))
        nested-tuple (vev.q-text-with-inputs
                       conn.db
                       "[:find ?k ?min ?max :in [[?k [?min ?max]] ...] :where [(> ?max ?min)]]"
                       ([]vev.Query-Input [(vev.query-input-scalar nested-tuple-input)]))
        nested-collection (vev.q-text-with-inputs
                            conn.db
                            "[:find ?k ?x :in [[?k [?x ...]] ...] :where [(> ?x 1)]]"
                            ([]vev.Query-Input [(vev.query-input-scalar nested-collection-input)]))
        no-where (vev.q-text-with-inputs
                   conn.db
                   "[:find ?x :in ?x]"
                   ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ok"))]))
        ignored (vev.q-text-with-inputs
                  conn.db
                  "[:find ?name :in _ ?email :where [?e :email ?email] [?e :name ?name]]"
                  ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ignored"))
                                       (vev.query-input-scalar (vev.value-string "grace@example.com"))]))
        ignored-no-where (vev.q-text-with-inputs
                           conn.db
                           "[:find ?x :in _ ?x]"
                           ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ignored"))
                                                (vev.query-input-scalar (vev.value-keyword ":kept"))]))
        ignored-missing (vev.q-text-with-inputs
                          conn.db
                          "[:find ?x :in _ ?x]"
                          ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":only"))]))]
    (t.is (= (count scalar.rows) 1))
    (t.is (= scalar.rows[0].values[0].text "Ada"))
    (t.is (= (count collection.rows) 2))
    (t.is (= tuple.rows[0].values[0].entity 1))
    (t.is (= relation.rows[0].values[0].entity 1))
    (t.is (= (count map-relation.rows) 2))
    (t.is (= map-relation.rows[0].values[0].text ":ada"))
    (t.is (= map-relation.rows[0].values[1].text "Ada"))
    (t.is (= map-relation.rows[1].values[0].text ":grace"))
    (t.is (= map-relation.rows[1].values[1].text "Grace"))
    (t.is (= (count nested-flat.rows) 1))
    (t.is (= nested-flat.rows[0].values[0].text ":grace"))
    (t.is (= nested-flat.rows[0].values[1].int-value 85))
    (t.is (= (count nested-tuple.rows) 1))
    (t.is (= nested-tuple.rows[0].values[0].text ":a"))
    (t.is (= nested-tuple.rows[0].values[1].int-value 1))
    (t.is (= nested-tuple.rows[0].values[2].int-value 7))
    (t.is (= (count nested-collection.rows) 3))
    (t.is (= nested-collection.rows[0].values[0].text ":a"))
    (t.is (= nested-collection.rows[0].values[1].int-value 2))
    (t.is (= nested-collection.rows[1].values[0].text ":a"))
    (t.is (= nested-collection.rows[1].values[1].int-value 3))
    (t.is (= nested-collection.rows[2].values[0].text ":b"))
    (t.is (= nested-collection.rows[2].values[1].int-value 4))
    (t.is (= no-where.rows[0].values[0].text ":ok"))
    (t.is ignored.ok)
    (t.is (= (count ignored.rows) 1))
    (t.is (= ignored.rows[0].values[0].text "Grace"))
    (t.is ignored-no-where.ok)
    (t.is (= (count ignored-no-where.rows) 1))
    (t.is (= ignored-no-where.rows[0].values[0].text ":kept"))
    (t.is (not ignored-missing.ok))
    (t.is (= ignored-missing.error "wrong number of query inputs: expected 2, got 1"))))

(t.deftest datascript-query-input-binding-validation-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        bad-tuple-scalar (vev.q-text-with-inputs
                           conn.db
                           "[:find ?a ?b :in [?a ?b]]"
                           ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        short-tuple (vev.q-text-with-inputs
                      conn.db
                      "[:find ?a ?b :in [?a ?b]]"
                      ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-keyword ":a")]))]))
        bad-collection (vev.q-text-with-inputs
                         conn.db
                         "[:find ?a :in [?a ...]]"
                         ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        bad-relation (vev.q-text-with-inputs
                       conn.db
                       "[:find ?a ?b :in [[?a ?b]]]"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        relation-width (vev.q-text-with-inputs
                         conn.db
                         "[:find ?a ?b :in [[?a ?b]]]"
                         ([]vev.Query-Input [(vev.query-input-relation ([]vev.Value [(vev.value-keyword ":a")
                                                                                     (vev.value-keyword ":b")
                                                                                     (vev.value-keyword ":c")])
                                                                       3)]))]
    (t.is (not bad-tuple-scalar.ok))
    (t.is (= bad-tuple-scalar.error "cannot bind query input to tuple"))
    (t.is (not short-tuple.ok))
    (t.is (= short-tuple.error "not enough values to bind tuple input"))
    (t.is (not bad-collection.ok))
    (t.is (= bad-collection.error "cannot bind query input to collection ?a"))
    (t.is (not bad-relation.ok))
    (t.is (= bad-relation.error "cannot bind query input to relation"))
    (t.is (not relation-width.ok))
    (t.is (= relation-width.error "query relation input width mismatch"))))

(t.deftest datascript-parser-query-text-rules
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :follow]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]
             [:db/add 3 :follow (vev.value-entity 4)]
             [:db/add 4 :follow (vev.value-entity 6)]
             [:db/add 1 :name "Ada"]
             [:db/add 2 :name "Grace"]
             [:db/add 2 :height 240]])
        direct (vev.q-text-with-rules
                 conn.db
                 "[:find ?e1 ?e2 :in $ % :where (follow ?e1 ?e2)]"
                 "[[(follow ?x ?y) [?x :follow ?y]]]"
                 ([]vev.Query-Input []))
        recursive (vev.q-text-with-rules
                    conn.db
                    "[:find [?e2 ...] :in $ ?e1 % :where (follow ?e1 ?e2)]"
                    "[[(follow ?e1 ?e2) [?e1 :follow ?e2]] [(follow ?e1 ?e2) [?e1 :follow ?t] (follow ?t ?e2)]]"
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))]))
        filtered (vev.q-text-with-rules
                   conn.db
                   "[:find ?x ?y :in $ % :where (match ?x ?y)]"
                   "[[(match ?e ?e2) [?e :follow ?e2] [(even? ?e)] [(even? ?e2)]]]"
                   ([]vev.Query-Input []))
        grouped (vev.q-text-with-rules
                   conn.db
                   "[:find ?x ?y :in $ % :where (grouped-match ?x ?y)]"
                   "[[(grouped-match ?e ?e2) (and [?e :follow ?e2] [(even? ?e)] [(even? ?e2)])]]"
                   ([]vev.Query-Input []))
        get-else (vev.q-text-with-rules
                   conn.db
                   "[:find ?e ?height :in $ % :where (named-height ?e ?height)]"
                   "[[(named-height ?e ?height) [?e :name] [(get-else $ ?e :height 300) ?height]]]"
                   ([]vev.Query-Input []))
        get-some (vev.q-text-with-rules
                   conn.db
                   "[:find ?e ?a ?v :in $ % :where (named-some ?e ?a ?v)]"
                   "[[(named-some ?e ?a ?v) [?e :name] [(get-some $ ?e :height :name) [?a ?v]]]]"
                   ([]vev.Query-Input []))
        bad-get-else (vev.q-text-with-rules
                       conn.db
                       "[:find ?e ?height :in $ % :where (named-height ?e ?height)]"
                       "[[(named-height ?e ?height) [?e :name] [(get-else $ ?e :height nil) ?height]]]"
                       ([]vev.Query-Input []))]
    (t.is (= (count direct.rows) 4))
    (t.is (= direct.rows[0].values[0].entity 1))
    (t.is (= direct.rows[0].values[1].entity 2))
    (t.is (= (count recursive.rows) 4))
    (t.is (= recursive.rows[0].values[0].entity 2))
    (t.is (= recursive.rows[3].values[0].entity 6))
    (t.is (= (count filtered.rows) 1))
    (t.is (= filtered.rows[0].values[0].entity 4))
    (t.is (= filtered.rows[0].values[1].entity 6))
    (t.is (= (count grouped.rows) 1))
    (t.is (= grouped.rows[0].values[0].entity 4))
    (t.is (= grouped.rows[0].values[1].entity 6))
    (t.is get-else.ok)
    (t.is (= (count get-else.rows) 2))
    (t.is (= get-else.rows[0].values[0].entity 1))
    (t.is (= get-else.rows[0].values[1].int-value 300))
    (t.is (= get-else.rows[1].values[0].entity 2))
    (t.is (= get-else.rows[1].values[1].int-value 240))
    (t.is get-some.ok)
    (t.is (= (count get-some.rows) 2))
    (t.is (= get-some.rows[0].values[1].text ":name"))
    (t.is (= get-some.rows[0].values[2].text "Ada"))
    (t.is (= get-some.rows[1].values[1].text ":height"))
    (t.is (= get-some.rows[1].values[2].int-value 240))
    (t.is (not bad-get-else.ok))
    (t.is (= bad-get-else.error "get-else: nil default value is not supported"))))

(t.deftest datascript-prepared-query-and-rules-text-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :follow]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]
             [:db/add 3 :follow (vev.value-entity 4)]
             [:db/add 1 :age 10]
             [:db/add 2 :age 20]
             [:db/add 3 :age 30]
             [:db/add 4 :age 40]])
        prepared (vev.prepare-query-text "[:find [?e2 ...] :in $ ?e1 % :where (reachable ?e1 ?e2)]")
        attached-prepared (vev.prepare-query-text-with-rules
                            "[:find [?e2 ...] :in $ ?e1 % :where (reachable ?e1 ?e2)]"
                            "[[(reachable ?e1 ?e2) [?e1 :follow ?e2]] [(reachable ?e1 ?e2) [?e1 :follow ?t] (reachable ?t ?e2)]]")
        rules (vev.parse-rules-text "[[(reachable ?e1 ?e2) [?e1 :follow ?e2]] [(reachable ?e1 ?e2) [?e1 :follow ?t] (reachable ?t ?e2)]]")
        result (vev.q-prepared-with-rules
                 conn.db
                 prepared
                 rules
                 ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))]))
        repeated (vev.q-prepared-with-rules
                   conn.db
                   prepared
                   rules
                   ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 2))]))
        attached-result (vev.q-prepared-with-inputs
                          conn.db
                          attached-prepared
                          ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))]))
        attached-repeated (vev.q-prepared-with-inputs
                            conn.db
                            attached-prepared
                            ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 2))]))
        fn-query (vev.prepare-query-text "[:find [?e ...] :in $ ?min % :where (adult ?e ?min)]")
        fn-rules (vev.parse-rules-text "[[(adult ?e ?min) [?e :age ?age] [(>= ?age ?min)]]]")
        fn-result (vev.q-prepared-with-rules-and-fns
                    conn.db
                    fn-query
                    fn-rules
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-int 30))])
                    ([]vev.Native-Query-Fn []))
        bad-rules (vev.parse-rules-text "[[(broken) [_]]]")
        bad-result (vev.q-prepared-with-rules conn.db prepared bad-rules ([]vev.Query-Input []))
        bad-attached (vev.prepare-query-text-with-rules
                       "[:find [?e2 ...] :in $ ?e1 % :where (reachable ?e1 ?e2)]"
                       "[[(broken) [_]]]")]
    (t.is prepared.ok)
    (t.is attached-prepared.ok)
    (t.is rules.ok)
    (t.is result.ok)
    (t.is (= (count result.rows) 3))
    (t.is (= result.rows[0].values[0].entity 2))
    (t.is (= result.rows[1].values[0].entity 3))
    (t.is (= result.rows[2].values[0].entity 4))
    (t.is repeated.ok)
    (t.is (= (count repeated.rows) 2))
    (t.is (= repeated.rows[0].values[0].entity 3))
    (t.is (= repeated.rows[1].values[0].entity 4))
    (t.is attached-result.ok)
    (t.is (= (count attached-result.rows) 3))
    (t.is (= attached-result.rows[0].values[0].entity 2))
    (t.is (= attached-result.rows[1].values[0].entity 3))
    (t.is (= attached-result.rows[2].values[0].entity 4))
    (t.is attached-repeated.ok)
    (t.is (= (count attached-repeated.rows) 2))
    (t.is (= attached-repeated.rows[0].values[0].entity 3))
    (t.is (= attached-repeated.rows[1].values[0].entity 4))
    (t.is fn-query.ok)
    (t.is fn-rules.ok)
    (t.is fn-result.ok)
    (t.is (= (count fn-result.rows) 2))
    (t.is (= fn-result.rows[0].values[0].entity 3))
    (t.is (= fn-result.rows[1].values[0].entity 4))
    (t.is (not bad-rules.ok))
    (t.is (not bad-result.ok))
    (t.is (= bad-result.error bad-rules.error))
    (t.is (not bad-attached.ok))
    (t.is (= bad-attached.error bad-rules.error))))

(t.deftest datascript-parser-query-text-sources
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact
            (addr left)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 1 :name "Ivan" :id 1}
             {:db/id 2 :name "Petr" :id 2}
             {:db/id 3 :name "Oleg" :id 3}])
        _ (vev.transact
            (addr right)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 3 :name "Ivan" :id 3}
             {:db/id 1 :name "Petr" :id 1}
             {:db/id 2 :name "Oleg" :id 2}])
        numeric (vev.q-text-with-sources
                  left.db
                  "[:find ?e ?id1 ?id2 :in $1 $2 [?e ...] :where [$1 ?e :id ?id1] [$2 ?e :id ?id2]]"
                  ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))])
                  ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        lookup-refs (vev.q-text-with-sources
                      left.db
                      "[:find ?e ?id1 ?id2 :in $1 $2 [?e ...] :where [$1 ?e :id ?id1] [$2 ?e :id ?id2]]"
                      ([]vev.Query-Input [(vev.query-input-collection-lookup-refs ([]string [":name" ":name" ":name"]) ([]vev.Value [(vev.value-string "Ivan") (vev.value-string "Petr") (vev.value-string "Oleg")]))])
                      ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        map-sources (vev.q-text-with-sources
                      left.db
                      "{:find [?e ?id1 ?id2] :in [$1 $2 [?e ...]] :where [[$1 ?e :id ?id1] [$2 ?e :id ?id2]]}"
                      ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))])
                      ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        pulled (vev.q-text-with-sources
                 left.db
                 "[:find ?e (pull $2 ?e [:name]) :in $1 $2 :where [$1 ?e :id 1]]"
                 ([]vev.Query-Input [])
                 ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        source-not (vev.q-text-with-sources
                     left.db
                     "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 not [?e :id 1])]"
                     ([]vev.Query-Input [])
                     ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        source-not-join (vev.q-text-with-sources
                          left.db
                          "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 not-join [?e] [?e :name \"Petr\"])]"
                          ([]vev.Query-Input [])
                          ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        source-or (vev.q-text-with-sources
                    left.db
                    "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 or [?e :name \"Ivan\"] [?e :name \"Oleg\"])]"
                    ([]vev.Query-Input [])
                    ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        source-or-join (vev.q-text-with-sources
                         left.db
                         "[:find ?e :in $1 $2 :where [$1 ?e :id] ($2 or-join [?e] [?e :name \"Ivan\"] [?e :name \"Oleg\"])]"
                         ([]vev.Query-Input [])
                 ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))]
    (t.is (= (count numeric.rows) 3))
    (t.is (= numeric.rows[0].values[0].int-value 1))
    (t.is (= numeric.rows[0].values[1].int-value 1))
    (t.is (= numeric.rows[0].values[2].int-value 1))
    (t.is (= (count lookup-refs.rows) 3))
    (t.is (= lookup-refs.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= lookup-refs.rows[1].values[0].items[1].text "Petr"))
    (t.is (= lookup-refs.rows[2].values[0].items[1].text "Oleg"))
    (t.is (= (count map-sources.rows) 3))
    (t.is (= map-sources.rows[0].values[0].int-value 1))
    (t.is (= map-sources.rows[0].values[1].int-value 1))
    (t.is (= map-sources.rows[0].values[2].int-value 1))
    (t.is (= map-sources.rows[2].values[0].int-value 3))
    (t.is (= map-sources.rows[2].values[1].int-value 3))
    (t.is (= map-sources.rows[2].values[2].int-value 3))
    (t.is (= (count pulled.rows) 1))
    (t.is (= pulled.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= (count source-not.rows) 2))
    (t.is (= source-not.rows[0].values[0].entity 2))
    (t.is (= source-not.rows[1].values[0].entity 3))
    (t.is (= (count source-not-join.rows) 2))
    (t.is (= source-not-join.rows[0].values[0].entity 2))
    (t.is (= source-not-join.rows[1].values[0].entity 3))
    (t.is (= (count source-or.rows) 2))
    (t.is (= source-or.rows[0].values[0].entity 2))
    (t.is (= source-or.rows[1].values[0].entity 3))
    (t.is (= (count source-or-join.rows) 2))
    (t.is (= source-or-join.rows[0].values[0].entity 2))
    (t.is (= source-or-join.rows[1].values[0].entity 3))))

(t.deftest datascript-parser-query-text-relation-source-inputs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "dragon_killer_94")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "-=autobot=-")]))]))
        long-rows (vev.value-vector
                    ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan") (vev.value-int 945) (vev.value-keyword ":db/add")]))
                                   (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 39) (vev.value-int 999) (vev.value-keyword ":db/retract")]))]))
        result (vev.q-text-with-inputs
                 conn.db
                 "[:find ?n ?a :in $rows :where [$rows ?e :aka \"dragon_killer_94\"] [$rows ?e :name ?n] [$rows ?e :age ?a]]"
                 ([]vev.Query-Input [(vev.query-input-scalar rows)]))
        long (vev.q-text-with-inputs
               conn.db
               "[:find ?e ?a ?v ?t :in $rows :where [$rows ?e ?a ?v ?t :db/retract]]"
               ([]vev.Query-Input [(vev.query-input-scalar long-rows)]))]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].int-value 19))
    (t.is (= (count long.rows) 1))
    (t.is (= long.rows[0].values[0].int-value 1))
    (t.is (= long.rows[0].values[1].text ":age"))
    (t.is (= long.rows[0].values[2].int-value 39))
    (t.is (= long.rows[0].values[3].int-value 999))))

(t.deftest datascript-query-typed-relation-source-inputs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        relation (vev.q-text-with-inputs
                   conn.db
                   "[:find ?n ?a :in $rows :where [$rows ?e :aka \"dragon_killer_94\"] [$rows ?e :name ?n] [$rows ?e :age ?a]]"
                   ([]vev.Query-Input
                     [(vev.query-input-relation
                        ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")
                                      (vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)
                                      (vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "dragon_killer_94")])
                        3)]))
        collection (vev.q-text-with-inputs
                     conn.db
                     "[:find ?e ?a ?v ?t :in $rows :where [$rows ?e ?a ?v ?t :db/retract]]"
                     ([]vev.Query-Input
                       [(vev.query-input-collection
                          ([]vev.Value
                            [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan") (vev.value-int 945) (vev.value-keyword ":db/add")]))
                             (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 39) (vev.value-int 999) (vev.value-keyword ":db/retract")]))]))]))
        map-value (vev.value-map
                    ([]vev.Value [(vev.value-keyword ":a") (vev.value-int 1)
                                  (vev.value-keyword ":b") (vev.value-int 2)]))
        map-source (vev.q-text-with-inputs
                     conn.db
                     "[:find ?k ?v :in $rows :where [$rows ?k ?v]]"
                     ([]vev.Query-Input [(vev.query-input-scalar map-value)]))
        wrong-width (vev.q-text-with-inputs
                      conn.db
                      "[:find ?e ?a ?v :in $rows :where [$rows ?e ?a ?v]]"
                      ([]vev.Query-Input
                        [(vev.query-input-relation
                           ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name")])
                           2)]))
        non-source (vev.q-text-with-inputs
                     conn.db
                     "[:find ?e :in $rows :where [$rows ?e :name]]"
                     ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":not-a-source"))]))]
    (t.is relation.ok)
    (t.is (= (count relation.rows) 1))
    (t.is (= relation.rows[0].values[0].text "Ivan"))
    (t.is (= relation.rows[0].values[1].int-value 19))
    (t.is collection.ok)
    (t.is (= (count collection.rows) 1))
    (t.is (= collection.rows[0].values[0].int-value 1))
    (t.is (= collection.rows[0].values[1].text ":age"))
    (t.is (= collection.rows[0].values[2].int-value 39))
    (t.is (= collection.rows[0].values[3].int-value 999))
    (t.is map-source.ok)
    (t.is (= (count map-source.rows) 2))
    (t.is (= map-source.rows[0].values[0].text ":a"))
    (t.is (= map-source.rows[0].values[1].int-value 1))
    (t.is wrong-width.ok)
    (t.is (= (count wrong-width.rows) 0))
    (t.is (not non-source.ok))
    (t.is (= non-source.error "query source is not a collection: $rows"))))

(t.deftest datascript-query-primary-collection-db-subset
  (defer (free_all context.allocator))
