(t.deftest datascript-pull-drops-empty-ref-map-results-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :child]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :name "Petr"]
             [:db/add 2 :name "David"]
             [:db/add 3 :name "Thomas"]
             [:db/add 1 :child (vev.value-entity 2)]
             [:db/add 1 :child (vev.value-entity 3)]])
        forward (vev.pull conn.db [:name {:child [:missing]}] 1)
        reverse (vev.pull conn.db [:name {:_child [:missing]}] 2)]
    (t.is (= (count forward.attrs) 1))
    (t.is (= forward.attrs[0].a ":name"))
    (t.is (= forward.attrs[0].v.text "Petr"))
    (t.is (= (count reverse.attrs) 1))
    (t.is (= reverse.attrs[0].a ":name"))
    (t.is (= reverse.attrs[0].v.text "David"))))

(t.deftest datascript-pull-component-attr-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :part]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 10 :name "Part A"]
              [:db/add 10 :part (vev.value-entity 11)]
              [:db/add 10 :part (vev.value-entity 15)]
              [:db/add 11 :name "Part A.A"]
              [:db/add 11 :part (vev.value-entity 12)]
              [:db/add 12 :name "Part A.A.A"]
              [:db/add 15 :name "Part A.B"]])
        pulled (vev.pull conn.db [:name :part] 10)
        explicit (vev.pull conn.db [:name {:part [:name]}] 10)
        depth-one (vev.pull conn.db [:name {:part 1}] 10)
        child pulled.attrs[1]
        grandchild child.attrs[2]
        explicit-first explicit.attrs[1]
        explicit-second explicit.attrs[2]
        depth-first depth-one.attrs[1]
        depth-second depth-one.attrs[2]]
      (t.is (= (count pulled.attrs) 3))
      (t.is (= pulled.attrs[0].v.text "Part A"))
      (t.is (= child.v.entity 11))
      (t.is (= child.attrs[0].a ":db/id"))
      (t.is (= child.attrs[1].v.text "Part A.A"))
      (t.is (= grandchild.v.entity 12))
      (t.is (= grandchild.attrs[1].v.text "Part A.A.A"))
      (t.is (= pulled.attrs[2].v.entity 15))
      (t.is (= pulled.attrs[2].attrs[1].v.text "Part A.B"))
      (t.is (= (count explicit.attrs) 3))
      (t.is (= explicit-first.attrs[0].v.text "Part A.A"))
      (t.is (= (count explicit-first.attrs) 1))
      (t.is (= explicit-second.attrs[0].v.text "Part A.B"))
      (t.is (= (count explicit-second.attrs) 1))
      (t.is (= (count depth-one.attrs) 3))
      (t.is (= depth-first.attrs[0].v.text "Part A.A"))
      (t.is (= (count depth-first.attrs) 1))
      (t.is (= depth-second.attrs[0].v.text "Part A.B"))
      (t.is (= (count depth-second.attrs) 1))))

(t.deftest datascript-pull-component-reverse-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :ref]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [{:db/id 1
               :name "1"
               :ref {:name "2"
                     :ref {:name "3"}}}])
        pulled (vev.pull conn.db
                 [:name {:ref [:name {:ref [:name {:_ref [:name]}]}]}]
                 1)
        child pulled.attrs[1]
        grandchild child.attrs[1]
        reverse-parent grandchild.attrs[1]]
      (t.is (= pulled.attrs[0].v.text "1"))
      (t.is (= child.attrs[0].v.text "2"))
      (t.is (= grandchild.attrs[0].v.text "3"))
      (t.is (= reverse-parent.attrs[0].v.text "2"))))

(t.deftest datascript-pull-reverse-component-shape-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
             (addr conn)
             [[:db/add 100 :db/ident :part]
              [:db/add 100 :db/valueType :db.type/ref]
              [:db/add 100 :db/cardinality :db.cardinality/many]
              [:db/add 100 :db/isComponent true]])
        _ (vev.transact
             (addr conn)
             [[:db/add 10 :name "Part A"]
              [:db/add 10 :part (vev.value-entity 11)]
              [:db/add 11 :name "Part A.A"]
              [:db/add 11 :part (vev.value-entity 12)]
              [:db/add 12 :name "Part A.A.A"]
              [:db/add 12 :part (vev.value-entity 14)]
              [:db/add 14 :name "Part A.A.A.B"]])
        parent-id (vev.pull conn.db [:name :_part] 11)
        parent-name (vev.pull conn.db [:name {:_part [:name]}] 11)
        reverse-ellipsis (vev.pull conn.db [:name {:_part ...}] 14)
        reverse-depth (vev.pull conn.db [:name {:_part 2}] 14)
        parent-id-attr parent-id.attrs[1]
        parent-name-attr parent-name.attrs[1]
        ellipsis-parent reverse-ellipsis.attrs[1]
        ellipsis-grandparent ellipsis-parent.attrs[1]
        ellipsis-root ellipsis-grandparent.attrs[1]
        depth-parent reverse-depth.attrs[1]
        depth-grandparent depth-parent.attrs[1]]
    (t.is (= (count parent-id.attrs) 2))
    (t.is (= parent-id.attrs[0].v.text "Part A.A"))
    (t.is (= parent-id-attr.a ":_part"))
    (t.is (= parent-id-attr.v.entity 10))
    (t.is (= (count parent-id-attr.attrs) 0))
    (t.is (= (count parent-name.attrs) 2))
    (t.is (= parent-name-attr.v.entity 10))
    (t.is (= (count parent-name-attr.attrs) 1))
    (t.is (= parent-name-attr.attrs[0].v.text "Part A"))
    (t.is (= reverse-ellipsis.attrs[0].v.text "Part A.A.A.B"))
    (t.is (= ellipsis-parent.v.entity 12))
    (t.is (= ellipsis-parent.attrs[0].v.text "Part A.A.A"))
    (t.is (= ellipsis-grandparent.v.entity 11))
    (t.is (= ellipsis-grandparent.attrs[0].v.text "Part A.A"))
    (t.is (= ellipsis-root.v.entity 10))
    (t.is (= ellipsis-root.attrs[0].v.text "Part A"))
    (t.is (= reverse-depth.attrs[0].v.text "Part A.A.A.B"))
    (t.is (= depth-parent.v.entity 12))
    (t.is (= depth-parent.attrs[0].v.text "Part A.A.A"))
    (t.is (= depth-grandparent.v.entity 11))
    (t.is (= depth-grandparent.attrs[0].v.text "Part A.A"))
    (t.is (= (count depth-grandparent.attrs) 1))))

(t.deftest pull-supports-nested-ref-maps
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        pulled (vev.pull conn.db [{:user/friend [:user/name]}] 1)
        result (vev.q conn.db
                   [:find (pull ?e [{:user/friend [:user/name]}])
                    :where
                    [?e :user/email "ada@example.com"]])]
      (t.is (= (count pulled.attrs) 1))
      (t.is (= pulled.attrs[0].a ":user/friend"))
      (t.is (= pulled.attrs[0].v.entity 2))
      (t.is (= (count pulled.attrs[0].attrs) 1))
      (t.is (= pulled.attrs[0].attrs[0].a ":user/name"))
      (t.is (= pulled.attrs[0].attrs[0].v.text "Grace"))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].pulls[0].attrs[0].attrs[0].v.text "Grace"))))

(t.deftest pull-supports-multiple-nested-map-entries
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
