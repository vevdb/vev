(t.deftest datascript-query-return-map-all-rows-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Petr" :age 44}
                  {:db/id 2 :name "Ivan" :age 25}
                  {:db/id 3 :name "Sergey" :age 11}])
        keys (vev.q-keys report.db-after
               [:find ?name ?age :keys n a
                :where
                [?e :name ?name]
                [?e :age ?age]])
        strs (vev.q-strs report.db-after
               [:find ?name ?age :strs n a
                :where
                [?e :name ?name]
