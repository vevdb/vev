(t.deftest datascript-cas-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :weight]
             [:db/add 100 :db/valueType :db.type/long]
             [:db/add 100 :db/cardinality :db.cardinality/one]
             [:db/add 1 :weight 200]])
        first (vev.transact (addr conn) [[:db.fn/cas 1 :weight 200 300]])
        second (vev.transact (addr conn) [[:db/cas 1 :weight 300 400]])
        failed (vev.transact (addr conn) [[:db.fn/cas 1 :weight 200 210]])
        [current current-ok] (vev.q-scalar second.db-after
                  [:find ?weight .
                   :where
                   [1 :weight ?weight]])]
    (t.is first.ok)
    (t.is second.ok)
    (t.is (not failed.ok))
    (t.is (= failed.error ":db.fn/cas failed on datom [1 :weight 400], expected 200"))
    (t.is current-ok)
    (t.is (= current.int-value 400))))

