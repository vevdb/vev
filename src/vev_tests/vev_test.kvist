(t.deftest datascript-pull-default-limit-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        ops (make [dynamic]vev.Tx-Op)
        idx 0
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :aka :db/cardinality :db.cardinality/many}])]
    (defer (delete ops))
    (while (< idx 1001)
      (arr.push! ops (vev.tx-add 1 ":aka" (vev.value-int (i64 idx))))
      (set! idx (+ idx 1)))
    (vev.transact-ops (addr conn) (slice ops 0))
    (let [default-limit (vev.pull conn.db [:aka] 1)
          explicit-limit (vev.pull conn.db [[:aka :limit 1001]] 1)
          nil-limit (vev.pull conn.db [[:aka :limit nil]] 1)]
      (t.is (= (count default-limit.attrs) 1000))
      (t.is (= (count explicit-limit.attrs) 1001))
      (t.is (= (count nil-limit.attrs) 1001)))))

(t.deftest datascript-pull-repeated-specs-collapse-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 100 :db/ident :aka :db/cardinality :db.cardinality/many}
             {:db/id 101 :db/ident :friend :db/valueType :db.type/ref}
             {:db/id 1 :name "Petr" :aka ["Devil" "Tupen" "Devil Jr."] :friend 2}
             {:db/id 2 :name "David"}])
        direct (vev.pull conn.db
                 [:aka
                  [:aka :default "missing"]
                  [:aka :limit 1]]
                 1)
        missing (vev.pull conn.db
                  [:missing
                   [:missing :default "fallback"]]
                  1)
        nested (vev.pull conn.db
                 [{:friend [:missing
                            [:missing :default "nested"]]}]
                 1)
        text (vev.pull-text conn.db "[:aka [:aka :default \"missing\"] [:aka :limit 1]]" 1)]
    (t.is (= (count direct.attrs) 1))
    (t.is (= direct.attrs[0].a ":aka"))
    (t.is (= direct.attrs[0].v.text "Devil"))
    (t.is (= (count missing.attrs) 1))
    (t.is (= missing.attrs[0].a ":missing"))
    (t.is (= missing.attrs[0].v.text "fallback"))
    (t.is (= (count nested.attrs[0].attrs) 1))
    (t.is (= nested.attrs[0].attrs[0].a ":missing"))
    (t.is (= nested.attrs[0].attrs[0].v.text "nested"))
    (t.is (= (count text.attrs) 1))
    (t.is (= text.attrs[0].a ":aka"))
    (t.is (= text.attrs[0].v.text "Devil"))))

