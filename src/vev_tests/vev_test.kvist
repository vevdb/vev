    (t.is (= (count child.rows) 0))
    (t.is (= parent.rows[0].values[0].text "Ivan"))))

(t.deftest datascript-retract-entity-reports-adjacent-retractions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :a1 1 :a2 2 :a3 3}
             {:db/id 2 :a1 1 :a2 2 :a3 3}
             {:db/id 3 :a1 1 :a2 2 :a3 3}])
        report (vev.transact (addr conn) [[:db.fn/retractEntity 1]
                                          [:db.fn/retractEntity 2]])
        first (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [1 ?a ?v]])
        second (vev.q report.db-after
                 [:find ?a ?v
                  :where
                  [2 ?a ?v]])
        third (vev.q report.db-after
                [:find ?a ?v
                 :where
                 [3 ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 6))
    (t.is (= report.tx-data[0].e 1))
    (t.is (= report.tx-data[0].a ":a1"))
    (t.is (= report.tx-data[0].v.int-value 1))
    (t.is (not report.tx-data[0].added))
    (t.is (= report.tx-data[1].e 1))
    (t.is (= report.tx-data[1].a ":a2"))
    (t.is (= report.tx-data[1].v.int-value 2))
    (t.is (not report.tx-data[1].added))
    (t.is (= report.tx-data[2].e 1))
    (t.is (= report.tx-data[2].a ":a3"))
    (t.is (= report.tx-data[2].v.int-value 3))
    (t.is (not report.tx-data[2].added))
    (t.is (= report.tx-data[3].e 2))
    (t.is (= report.tx-data[3].a ":a1"))
    (t.is (= report.tx-data[3].v.int-value 1))
    (t.is (not report.tx-data[3].added))
    (t.is (= report.tx-data[4].e 2))
    (t.is (= report.tx-data[4].a ":a2"))
    (t.is (= report.tx-data[4].v.int-value 2))
    (t.is (not report.tx-data[4].added))
    (t.is (= report.tx-data[5].e 2))
    (t.is (= report.tx-data[5].a ":a3"))
    (t.is (= report.tx-data[5].v.int-value 3))
    (t.is (not report.tx-data[5].added))
    (t.is (= (count first.rows) 0))
    (t.is (= (count second.rows) 0))
    (t.is (= (count third.rows) 3))))

