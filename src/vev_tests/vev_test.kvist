(t.deftest datascript-explode-nested-maps-multi-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :profile]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]])
        vector-report (vev.transact
                        (addr conn)
                        [{:db/id 1
                          :name "Ivan"
                          :profile [{:db/id 7 :email "@2"}
                                    {:db/id 8 :email "@3"}]}])
        vector-result (vev.q vector-report.db-after
                        [:find ?profile ?email
                         :where
                         [1 :profile ?profile]
                         [?profile :email ?email]])
        set-report (vev.transact-text
                     (addr conn)
                     "[{:db/id 2 :name \"Petr\" :profile #{{:email \"@4\"} {:email \"@5\"}}}]")
        set-result (vev.q-text
                     set-report.db-after
                     "[:find ?profile ?email :where [2 :profile ?profile] [?profile :email ?email]]")]
    (t.is vector-report.ok)
    (t.is (= (count vector-result.rows) 2))
    (t.is (= vector-result.rows[0].values[0].entity 7))
    (t.is (= vector-result.rows[0].values[1].text "@2"))
    (t.is (= vector-result.rows[1].values[0].entity 8))
    (t.is (= vector-result.rows[1].values[1].text "@3"))
    (t.is set-report.ok)
    (t.is (= (count set-result.rows) 2))
    (t.is (= set-result.rows[0].values[1].text "@4"))
    (t.is (= set-result.rows[1].values[1].text "@5"))))

