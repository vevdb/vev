                                     :user/manager [:user/name]}] 1)]
      (t.is (= (count pulled.attrs) 2))
      (t.is (= pulled.attrs[0].a ":user/friend"))
      (t.is (= pulled.attrs[0].attrs[0].v.text "Grace"))
      (t.is (= pulled.attrs[1].a ":user/manager"))
      (t.is (= pulled.attrs[1].attrs[0].v.text "Grace"))))

(t.deftest db-snapshot-survives-later-transacts
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))]))
        snapshot (vev.db (addr conn))
        _ (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        old-results (vev.q-strings snapshot (vev.query-name-by-email "a@example.com"))
        current-results (vev.q-strings conn.db (vev.query-name-by-email "a@example.com"))]
        (t.is (= (count old-results) 0))
        (t.is (= (count current-results) 1))
        (t.is (= current-results[0] "Andreas"))))

(t.deftest retract-hides-fact-from-current-queries
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        add-report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                       [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                        (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        retract-report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                           [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))]))
        old-results (vev.q-strings add-report.db-after (vev.query-name-by-email "a@example.com"))
        current-results (vev.q-strings retract-report.db-after (vev.query-name-by-email "a@example.com"))]
    (t.is (= (count old-results) 1))
    (t.is (= old-results[0] "Andreas"))
    (t.is (= (count current-results) 0))
    (t.is (= (count retract-report.db-after.datoms) 3))
    (t.is (= (count retract-report.db-after.current) 1))
    (t.is (= retract-report.tx-data[0].added false))))

(t.deftest readd-after-retract-makes-fact-current-once
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                  (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        _ (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                 [(vev.tx-retract 1 ":user/name" (vev.value-string "Andreas"))]))
        report (vev.transact-ops
                   (addr conn)
                   ([]vev.Tx-Op
                     [(vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))]))
        results (vev.q-strings report.db-after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas"))
      (t.is (= (count report.db-after.current) 2))
      (t.is (= (count report.db-after.datoms) 4))))
