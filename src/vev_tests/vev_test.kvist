(t.deftest datascript-query-avg-uses-numeric-division-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        fractional (vev.q conn.db
                     [:find (sum ?x) (avg ?x)
                      :in [?x ...]]
                     [1 2])
        float-values (vev.q-text-with-inputs
                       conn.db
                       "[:find (sum ?x) (avg ?x) :in [?x ...]]"
                       ([]vev.Query-Input
                         [(vev.query-input-collection
                            ([]vev.Value [(vev.value-float 1.5) (vev.value-float 2.5)]))]))
        text (vev.q-text-with-inputs
               conn.db
               "[:find (sum ?x) (avg ?x) :in [?x ...]]"
               ([]vev.Query-Input
                 [(vev.query-input-collection
                    ([]vev.Value [(vev.value-int 1) (vev.value-int 2)]))]))]
    (t.is (= fractional.rows[0].values[0].int-value 3))
    (t.is (= fractional.rows[0].values[1].kind .Float))
    (t.is (= fractional.rows[0].values[1].float-value 1.5))
    (t.is (= float-values.rows[0].values[0].kind .Float))
    (t.is (= float-values.rows[0].values[0].float-value 4.0))
    (t.is (= float-values.rows[0].values[1].kind .Float))
    (t.is (= float-values.rows[0].values[1].float-value 2.0))
    (t.is (= text.rows[0].values[0].int-value 3))
    (t.is (= text.rows[0].values[1].kind .Float))
    (t.is (= text.rows[0].values[1].float-value 1.5))))

(t.deftest datascript-query-aggregates-relation-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        with-result (vev.q conn.db
                      [:find ?heads
                       :with ?monster
                       :in [[?monster ?heads]]]
                      [["Cerberus" 3]
                       ["Medusa" 1]
                       ["Cyclops" 1]
                       ["Chimera" 1]])
        aggregate-result (vev.q conn.db
                           [:find (sum ?heads) (min ?heads) (max ?heads) (count ?heads) (count-distinct ?heads) (avg ?heads)
                            :with ?monster
                            :in [[?monster ?heads]]]
                           [["Cerberus" 3]
                            ["Medusa" 1]
                            ["Cyclops" 1]
                            ["Chimera" 1]])
        deduped-aggregate-result (vev.q conn.db
                                   [:find (sum ?heads)
                                    :in [[?monster ?heads]]]
                                   [["Cerberus" 3]
                                    ["Medusa" 1]
                                    ["Cyclops" 1]
                                    ["Chimera" 1]])
        median-result (vev.q conn.db
                        [:find (median ?x)
                         :in [?x ...]]
                        [10 15 20 35 75])
        variance-result (vev.q conn.db
                          [:find (variance ?x)
                           :in [?x ...]]
                          [10 15 20 35 75])
        stddev-result (vev.q conn.db
                         [:find (stddev ?x)
                          :in [?x ...]]
                         [10 15 20 35 75])
        custom-result (vev.q conn.db
                        [:find ?color (aggregate ?agg ?x)
                         :in [[?color ?x]] ?agg]
                        [[:red 1] [:red 2] [:red 3] [:red 4] [:red 5]
                         [:blue 7] [:blue 8]]
                        :sort-reverse)
        custom-text (vev.q-text-with-inputs
                      conn.db
                      "[:find ?color (aggregate ?agg ?x) :in [[?color ?x]] ?agg]"
                      ([]vev.Query-Input
                        [(vev.query-input-relation
                           ([]vev.Value [(vev.value-keyword ":red") (vev.value-int 1)
                                          (vev.value-keyword ":red") (vev.value-int 2)
                                          (vev.value-keyword ":red") (vev.value-int 3)
                                          (vev.value-keyword ":red") (vev.value-int 4)
                                          (vev.value-keyword ":red") (vev.value-int 5)
                                          (vev.value-keyword ":blue") (vev.value-int 7)
                                          (vev.value-keyword ":blue") (vev.value-int 8)])
                           2)
                         (vev.query-input-scalar (vev.value-string "sort-reverse"))]))
        callback-registry ([]vev.Native-Query-Fn
                            [(vev.query-aggregate-fn "native-sort-reverse" native-sort-reverse)])
        callback-inputs ([]vev.Query-Input
                          [(vev.query-input-relation
                             ([]vev.Value [(vev.value-keyword ":red") (vev.value-int 1)
                                            (vev.value-keyword ":red") (vev.value-int 2)
                                            (vev.value-keyword ":red") (vev.value-int 3)
                                            (vev.value-keyword ":red") (vev.value-int 4)
                                            (vev.value-keyword ":red") (vev.value-int 5)
                                            (vev.value-keyword ":blue") (vev.value-int 7)
                                            (vev.value-keyword ":blue") (vev.value-int 8)])
                             2)
                           (vev.query-input-scalar (vev.value-string "native-sort-reverse"))])
        custom-callback-text (vev.q-text-with-inputs-and-fns
                               conn.db
                               "[:find ?color (aggregate ?agg ?x) :in [[?color ?x]] ?agg]"
                               callback-inputs
                               callback-registry)
        prepared-custom (vev.prepare-query-text
                          "[:find ?color (aggregate ?agg ?x) :in [[?color ?x]] ?agg]")
        custom-callback-prepared (vev.q-prepared-with-inputs-and-fns
                                   conn.db
                                   prepared-custom
                                   callback-inputs
                                   callback-registry)]
    (t.is (= (count with-result.rows) 4))
    (t.is (= with-result.rows[0].values[0].int-value 3))
    (t.is (= with-result.rows[1].values[0].int-value 1))
    (t.is (= with-result.rows[2].values[0].int-value 1))
    (t.is (= with-result.rows[3].values[0].int-value 1))
    (t.is (= (count aggregate-result.rows) 1))
    (t.is (= aggregate-result.rows[0].values[0].int-value 6))
    (t.is (= aggregate-result.rows[0].values[1].int-value 1))
    (t.is (= aggregate-result.rows[0].values[2].int-value 3))
    (t.is (= aggregate-result.rows[0].values[3].int-value 4))
    (t.is (= aggregate-result.rows[0].values[4].int-value 2))
    (t.is (= aggregate-result.rows[0].values[5].kind .Float))
    (t.is (= aggregate-result.rows[0].values[5].float-value 1.5))
    (t.is (= (count deduped-aggregate-result.rows) 1))
    (t.is (= deduped-aggregate-result.rows[0].values[0].int-value 4))
    (t.is (= median-result.rows[0].values[0].int-value 20))
    (t.is (= variance-result.rows[0].values[0].int-value 554))
    (t.is (> stddev-result.rows[0].values[0].float-value 23.5))
    (t.is (< stddev-result.rows[0].values[0].float-value 23.6))
    (t.is (= (count custom-result.rows) 2))
    (t.is (= custom-result.rows[0].values[0].text ":red"))
    (t.is (= custom-result.rows[0].values[1].items[0].int-value 5))
    (t.is (= custom-result.rows[0].values[1].items[4].int-value 1))
    (t.is (= custom-result.rows[1].values[0].text ":blue"))
    (t.is (= custom-result.rows[1].values[1].items[0].int-value 8))
    (t.is (= custom-result.rows[1].values[1].items[1].int-value 7))
    (t.is (= (count custom-text.rows) 2))
    (t.is (= custom-text.rows[0].values[1].items[0].int-value 5))
    (t.is (= custom-text.rows[1].values[1].items[0].int-value 8))
    (t.is (= (count custom-callback-text.rows) 2))
    (t.is (= custom-callback-text.rows[0].values[1].items[0].int-value 5))
    (t.is (= custom-callback-text.rows[0].values[1].items[4].int-value 1))
    (t.is (= custom-callback-text.rows[1].values[1].items[0].int-value 8))
    (t.is (= (count custom-callback-prepared.rows) 2))
    (t.is (= custom-callback-prepared.rows[0].values[1].items[0].int-value 5))
    (t.is (= custom-callback-prepared.rows[1].values[1].items[0].int-value 8))))

