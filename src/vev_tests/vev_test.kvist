                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "-=autobot=-")]))]))
        long-rows (vev.value-vector
                    ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan") (vev.value-int 945) (vev.value-keyword ":db/add")]))
                                   (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 39) (vev.value-int 999) (vev.value-keyword ":db/retract")]))]))
        result (vev.q-text-relation-db
