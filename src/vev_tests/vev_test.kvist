(t.deftest datascript-query-pull-basics-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Petr" :age 44}
                  {:db/id 2 :name "Ivan" :age 25}
                  {:db/id 3 :name "Oleg" :age 11}])
        names (vev.q report.db-after
                [:find (pull ?e [:name])
                 :where
                 [?e :age ?a]
                 [(>= ?a 18)]])
        wildcard (vev.q report.db-after
                   [:find (pull ?e [*])
                    :where
                    [?e :age ?a]
                    [(>= ?a 18)]])
        entity-and-pull (vev.q report.db-after
                          [:find ?e (pull ?e [:name])
                           :where
                           [?e :age ?a]
                           [(>= ?a 18)]])
        entity-age-and-pull (vev.q report.db-after
                              [:find ?e ?a (pull ?e [:name])
                               :where
                               [?e :age ?a]
                               [(>= ?a 18)]])
        input-pattern (vev.q report.db-after
                        [:find (pull ?e ?pattern)
                         :in $ ?pattern
                         :where
                         [?e :age ?a]
                         [(>= ?a 18)]]
                        [:name])
        values-and-input-pattern (vev.q report.db-after
                                   [:find ?e ?a ?pattern (pull ?e ?pattern)
                                    :in $ ?pattern
                                    :where
                                    [?e :age ?a]
                                    [(>= ?a 18)]]
                                   [:name])]
    (t.is (= (count names.rows) 2))
    (t.is (= names.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= names.rows[1].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= (count wildcard.rows) 2))
    (t.is (= wildcard.rows[0].pulls[0].attrs[0].a ":db/id"))
    (t.is (= wildcard.rows[0].pulls[0].attrs[1].a ":age"))
    (t.is (= wildcard.rows[0].pulls[0].attrs[2].a ":name"))
    (t.is (= (count entity-and-pull.rows) 2))
    (t.is (= entity-and-pull.rows[0].values[0].entity 1))
    (t.is (= entity-and-pull.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= entity-and-pull.rows[1].values[0].entity 2))
    (t.is (= entity-and-pull.rows[1].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= (count entity-age-and-pull.rows) 2))
    (t.is (= entity-age-and-pull.rows[0].values[0].entity 1))
    (t.is (= entity-age-and-pull.rows[0].values[1].int-value 44))
    (t.is (= entity-age-and-pull.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= (count input-pattern.rows) 2))
    (t.is (= input-pattern.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= input-pattern.rows[1].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= (count values-and-input-pattern.rows) 2))
    (t.is (= values-and-input-pattern.rows[0].values[0].entity 1))
    (t.is (= values-and-input-pattern.rows[0].values[1].int-value 44))
    (t.is (= values-and-input-pattern.rows[0].values[2].kind .Vector))
    (t.is (= values-and-input-pattern.rows[0].values[2].items[0].text ":name"))
    (t.is (= values-and-input-pattern.rows[0].pulls[0].attrs[0].v.text "Petr"))))

(t.deftest datascript-query-pull-find-spec-shapes-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Petr" :age 44}
             {:db/id 2 :name "Ivan" :age 25}
             {:db/id 3 :name "Oleg" :age 11}])
        [scalar scalar-ok] (vev.q-pull-scalar conn.db
                             [:find (pull ?e [:name]) .
                              :where
                              [?e :age 25]])
        collection (vev.q-pull-collection conn.db
                     [:find [(pull ?e [:name]) ...]
                      :where
                      [?e :age ?a]])
        tuple (vev.q-row-tuple conn.db
                [:find [?e (pull ?e [:name])]
                 :where
                 [?e :age 25]])
        [input-scalar input-scalar-ok] (vev.q-pull-scalar conn.db
                                         [:find (pull ?e ?pattern) .
                                          :in $ ?pattern
                                          :where
                                          [(ground 2) ?e]]
                                         [:name])
        [named-input-scalar named-input-scalar-ok] (vev.q-pull-scalar conn.db
                                                     [:find (pull ?e p) .
                                                      :in $ p
                                                      :where
                                                      [(ground 2) ?e]]
                                                     [:name])
        text-collection (vev.q-text-pull-collection
                          conn.db
                          "[:find [(pull ?e [:name]) ...] :where [?e :age ?a]]")
        text-tuple (vev.q-text-row-tuple
                     conn.db
                     "[:find [?e (pull ?e [:name])] :where [?e :age 25]]")
        [text-scalar text-scalar-ok] (vev.q-text-pull-scalar
                                       conn.db
                                       "[:find (pull ?e [:name]) . :where [?e :age 25]]")
        [text-input-pattern text-input-pattern-ok] (vev.q-text-pull-scalar-with-inputs
                                                     conn.db
                                                     "[:find (pull ?e ?pattern) . :in $ ?pattern :where [(ground 2) ?e]]"
                                                     ([]vev.Query-Input
                                                       [(vev.query-input-pull-pattern
                                                          ([]vev.Pull-Spec [(vev.pull-spec ":name" ([]vev.Pull-Spec []))]))]))
        [text-named-input-pattern text-named-input-pattern-ok] (vev.q-text-pull-scalar-with-inputs
                                                                 conn.db
                                                                 "[:find (pull ?e p) . :in $ p :where [(ground 2) ?e]]"
                                                                 ([]vev.Query-Input
                                                                   [(vev.query-input-pull-pattern
                                                                      ([]vev.Pull-Spec [(vev.pull-spec ":name" ([]vev.Pull-Spec []))]))]))
        [text-map-input-pattern text-map-input-pattern-ok] (vev.q-text-pull-scalar-with-inputs
                                                             conn.db
                                                             "{:find [(pull ?e ?pattern) .] :in [$ ?pattern] :where [[(ground 2) ?e]]}"
                                                             ([]vev.Query-Input
                                                               [(vev.query-input-pull-pattern
                                                                  ([]vev.Pull-Spec [(vev.pull-spec ":name" ([]vev.Pull-Spec []))]))]))]
    (t.is scalar-ok)
    (t.is (= scalar.attrs[0].a ":name"))
    (t.is (= scalar.attrs[0].v.text "Ivan"))
    (t.is (= (count collection) 3))
    (t.is (= collection[0].attrs[0].v.text "Petr"))
    (t.is (= collection[1].attrs[0].v.text "Ivan"))
    (t.is (= collection[2].attrs[0].v.text "Oleg"))
    (t.is (= (count tuple.values) 1))
    (t.is (= tuple.values[0].entity 2))
    (t.is (= (count tuple.pulls) 1))
    (t.is (= tuple.pulls[0].attrs[0].v.text "Ivan"))
    (t.is input-scalar-ok)
    (t.is (= input-scalar.attrs[0].v.text "Ivan"))
    (t.is named-input-scalar-ok)
    (t.is (= named-input-scalar.attrs[0].v.text "Ivan"))
    (t.is (= (count text-collection) 3))
    (t.is (= text-collection[0].attrs[0].v.text "Petr"))
    (t.is (= text-collection[1].attrs[0].v.text "Ivan"))
    (t.is (= text-collection[2].attrs[0].v.text "Oleg"))
    (t.is (= (count text-tuple.values) 1))
    (t.is (= text-tuple.values[0].entity 2))
    (t.is (= text-tuple.pulls[0].attrs[0].v.text "Ivan"))
    (t.is text-scalar-ok)
    (t.is (= text-scalar.attrs[0].v.text "Ivan"))
    (t.is text-input-pattern-ok)
    (t.is (= text-input-pattern.attrs[0].v.text "Ivan"))
    (t.is text-named-input-pattern-ok)
    (t.is (= text-named-input-pattern.attrs[0].v.text "Ivan"))
    (t.is text-map-input-pattern-ok)
    (t.is (= text-map-input-pattern.attrs[0].v.text "Ivan"))))

(t.deftest datascript-query-pull-lookup-refs-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             {:db/id 1 :name "Petr" :age 44}
             {:db/id 2 :name "Ivan" :age 25}
             {:db/id 3 :name "Oleg" :age 11}])
        result (vev.q conn.db
                 [:find ?ref ?a (pull ?ref [:db/id :name])
                  :in [?ref ...]
                  :where
                  [?ref :age ?a]
                  [(>= ?a 18)]]
                 [[:name "Ivan"] [:name "Oleg"] [:name "Petr"]])]
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].kind .Vector))
    (t.is (= result.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= result.rows[0].values[1].int-value 25))
    (t.is (= result.rows[0].pulls[0].attrs[0].v.entity 2))
    (t.is (= result.rows[0].pulls[0].attrs[1].v.text "Ivan"))
    (t.is (= result.rows[1].values[0].kind .Vector))
    (t.is (= result.rows[1].values[0].items[1].text "Petr"))
    (t.is (= result.rows[1].values[1].int-value 44))
    (t.is (= result.rows[1].pulls[0].attrs[0].v.entity 1))
    (t.is (= result.rows[1].pulls[0].attrs[1].v.text "Petr"))))

(t.deftest datascript-query-pull-multiple-sources-subset
  (defer (free_all context.allocator))
  (let [conn1 (vev.create-conn)
        conn2 (vev.create-conn)
        _ (vev.transact
            (addr conn1)
            [{:db/id 1 :name "Ivan" :age 25}])
        _ (vev.transact
            (addr conn2)
            [{:db/id 1 :name "Petr" :age 25}])
        from-first (vev.q conn1.db
                     [:find ?e (pull $1 ?e [:name])
                      :in $1 $2
                      :where
                      [$1 ?e :age 25]]
                     conn1.db conn2.db)
        from-second (vev.q conn1.db
                      [:find ?e (pull $2 ?e [:name])
                       :in $1 $2
                       :where
                       [$2 ?e :age 25]]
                      conn1.db conn2.db)
        default-source (vev.q conn2.db
                         [:find ?e (pull ?e [:name])
                          :in $1 $
                          :where
                          [$ ?e :age 25]]
                         conn1.db)]
    (t.is (= (count from-first.rows) 1))
    (t.is (= from-first.rows[0].values[0].entity 1))
    (t.is (= from-first.rows[0].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= (count from-second.rows) 1))
    (t.is (= from-second.rows[0].values[0].entity 1))
    (t.is (= from-second.rows[0].pulls[0].attrs[0].v.text "Petr"))
    (t.is (= (count default-source.rows) 1))
    (t.is (= default-source.rows[0].values[0].entity 1))
    (t.is (= default-source.rows[0].pulls[0].attrs[0].v.text "Petr"))))

(t.deftest datascript-query-pull-aggregates-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
