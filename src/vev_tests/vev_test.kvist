    (t.is (= nil-nil[2].e 4))
    (t.is (= nil-nil[3].e 5))
    (t.is (= nil-nil[4].e 3))
    (t.is (= (count age-15-20) 3))
    (t.is (= age-15-20[0].e 1))
    (t.is (= age-15-20[1].e 2))
    (t.is (= age-15-20[2].e 5))
    (t.is (= (count age-7-45) 5))
    (t.is (= age-7-45[0].e 3))
    (t.is (= age-7-45[1].e 1))
    (t.is (= age-7-45[2].e 2))
    (t.is (= age-7-45[3].e 5))
    (t.is (= age-7-45[4].e 4))
    (t.is (= (count age-0-100) 5))
