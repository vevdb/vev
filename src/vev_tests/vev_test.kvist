(t.deftest datascript-pull-dual-recursion-depths-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 101 :db/ident :enemy]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 1 :friend (vev.value-entity 2)]
             [:db/add 2 :enemy (vev.value-entity 3)]
             [:db/add 3 :friend (vev.value-entity 4)]
             [:db/add 4 :enemy (vev.value-entity 5)]])
        pulled (vev.pull conn.db [:db/id {:friend 2 :enemy 1}] 1)
        friend pulled.attrs[1]
        enemy friend.attrs[1]
        friend-again enemy.attrs[1]]
    (t.is (= pulled.attrs[0].v.entity 1))
    (t.is (= friend.v.entity 2))
    (t.is (= enemy.v.entity 3))
    (t.is (= friend-again.v.entity 4))
    (t.is (= (count friend-again.attrs) 1))
    (t.is (= friend-again.attrs[0].v.entity 4))))

(t.deftest datascript-pull-deep-recursion-subset
  (defer (free_all context.allocator))
  (let [start 100
        depth 3000
        datoms (make [dynamic]vev.Datom) :defer
        _ (arr.push! datoms (vev.make-datom (u64 start) ":name" (vev.value-string (fmt.tprintf "Person-%d" start))))]
    (for [i (arr.range (+ start 1) depth)]
      (arr.push! datoms (vev.make-datom (u64 i) ":name" (vev.value-string (fmt.tprintf "Person-%d" i))))
      (arr.push! datoms (vev.make-datom (u64 (- i 1)) ":friend" (vev.value-entity (u64 i)))))
    (let [db (vev.init-db (slice datoms 0))
          pulled (vev.pull db [:name {:friend ...}] (u64 start))
          [deep-name deep-ok] (pull-deep-friend-name pulled (- (- depth 1) start))]
      (t.is deep-ok)
      (t.is (= deep-name "Person-2999")))))

(t.deftest pull-many-returns-multiple-entities
  (defer (free_all context.allocator))
