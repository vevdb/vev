(t.deftest datascript-pull-bounded-reverse-recursion-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :name "Ada"]
             [:db/add 1 :friend (vev.value-entity 2)]
             [:db/add 2 :name "Grace"]
             [:db/add 2 :friend (vev.value-entity 3)]
             [:db/add 3 :name "Katherine"]])
        pulled (vev.pull conn.db [:db/id {:_friend 2}] 3)
        parent pulled.attrs[1]
        grandparent parent.attrs[1]]
    (t.is (= pulled.attrs[0].v.entity 3))
    (t.is (= parent.v.entity 2))
    (t.is (= parent.attrs[0].v.entity 2))
    (t.is (= grandparent.v.entity 1))
    (t.is (= grandparent.attrs[0].v.entity 1))
    (t.is (= (count grandparent.attrs) 1))))

(t.deftest datascript-pull-ellipsis-recursion-acyclic-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :name "Ada"]
             [:db/add 1 :friend (vev.value-entity 2)]
             [:db/add 2 :name "Grace"]
             [:db/add 2 :friend (vev.value-entity 3)]
             [:db/add 3 :name "Katherine"]])
        forward (vev.pull conn.db [:db/id {:friend ...}] 1)
        reverse (vev.pull conn.db [:db/id {:_friend ...}] 3)
        f1 forward.attrs[1]
        r1 reverse.attrs[1]
        f2 f1.attrs[1]
        r2 r1.attrs[1]]
    (t.is (= (count forward.attrs) 2))
    (t.is (= (count reverse.attrs) 2))
    (t.is (= (count f1.attrs) 2))
    (t.is (= (count r1.attrs) 2))
    (t.is (= f1.v.entity 2))
    (t.is (= f2.v.entity 3))
    (t.is (= f2.attrs[0].v.entity 3))
    (t.is (= (count f2.attrs) 1))
    (t.is (= r1.v.entity 2))
    (t.is (= r2.v.entity 1))
    (t.is (= r2.attrs[0].v.entity 1))
    (t.is (= (count r2.attrs) 1))))

(t.deftest datascript-pull-ellipsis-recursion-cycle-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :friend]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 1 :name "Ada"]
             [:db/add 1 :friend (vev.value-entity 2)]
             [:db/add 2 :name "Grace"]
             [:db/add 2 :friend (vev.value-entity 3)]
             [:db/add 3 :name "Katherine"]
             [:db/add 3 :friend (vev.value-entity 1)]])
        pulled (vev.pull conn.db [:db/id :name {:friend ...}] 1)
        first-friend pulled.attrs[2]
        second-friend first-friend.attrs[2]
        repeated second-friend.attrs[2]]
    (t.is (= repeated.v.entity 1))
    (t.is (= (count repeated.attrs) 1))
    (t.is (= repeated.attrs[0].a ":db/id"))
    (t.is (= repeated.attrs[0].v.entity 1))))

(t.deftest datascript-pull-ellipsis-reverse-recursion-cycle-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
