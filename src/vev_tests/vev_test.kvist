(t.deftest datascript-entity-api-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 10 :db/ident :aka :db/cardinality :db.cardinality/many}
                  {:db/id 11 :db/ident :children :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}
                  {:db/id 12 :db/ident :father :db/valueType :db.type/ref}
                  {:db/id 13 :db/ident :email :db/unique :db.unique/identity}
                  {:db/id 1 :name "Ivan" :age 19 :email "ivan@example.com" :aka ["X" "Y"] :children [10]}
                  {:db/id 10 :father 1 :children [100 101]}
                  {:db/id 100 :father 10}
                  {:db/id 101 :father 10}
                  {:db/id 200 :father 999}])
        ivan (vev.db-entity report.db-after 1)
	        by-email (vev.entity-lookup-ref report.db-after ":email" (vev.value-string "ivan@example.com"))
	        aka (vev.entity-values ivan ":aka")
	        children (vev.entity-refs ivan ":children")
        child children[0]
        grandkids (vev.entity-refs child ":children")
        reverse-children-on-root (vev.entity-refs ivan ":_children")
        reverse-children-on-child (vev.entity-refs child ":_children")
        reverse-father (vev.entity-refs ivan ":_father")
        reverse-father-on-child (vev.entity-refs child ":_father")
        reverse-father-on-grandchild (vev.entity-refs grandkids[0] ":_father")
        reverse-children-on-grandchild (vev.entity-refs grandkids[0] ":_children")
        nested-reverse-children (vev.entity-refs reverse-children-on-grandchild[0] ":_children")
        schema-attr (vev.entity-ident report.db-after ":children")
        missing (vev.db-entity report.db-after 777)
        dangling (vev.entity-refs (vev.db-entity report.db-after 200) ":father")
        [first-age first-age-ok] (vev.entity-first-value ivan ":age")
        [missing-age _] (vev.entity-first-value missing ":age")
        [first-child first-child-ok] (vev.entity-first-ref ivan ":children")
        [first-reverse-father first-reverse-father-ok] (vev.entity-first-ref ivan ":_father")
        touched (vev.touch ivan)]
    (t.is ivan.found)
    (t.is (= (vev.entity-id ivan) 1))
    (t.is (= (vev.entity-get ivan ":db/id").entity 1))
    (t.is (= (vev.entity-get ivan ":name").text "Ivan"))
    (t.is (= (vev.entity-get ivan ":age").int-value 19))
    (t.is (vev.entity-contains? ivan ":age"))
    (t.is (not (vev.entity-contains? ivan ":missing")))
    (t.is first-age-ok)
    (t.is (= first-age.int-value 19))
    (t.is (= missing-age.kind .Nil))
    (t.is (vev.entity-has-value? ivan ":age"))
    (t.is (not (vev.entity-has-value? ivan ":missing")))
    (t.is first-child-ok)
    (t.is (= first-child.e 10))
    (t.is first-reverse-father-ok)
    (t.is (= first-reverse-father.e 10))
    (t.is by-email.found)
    (t.is (= by-email.e 1))
    (t.is (= (count aka) 2))
    (t.is (= aka[0].text "X"))
    (t.is (= aka[1].text "Y"))
    (t.is (= (count children) 1))
    (t.is (= child.e 10))
    (t.is (= (vev.entity-ref child ":father").e 1))
    (t.is (= (count grandkids) 2))
    (t.is (= grandkids[0].e 100))
    (t.is (= grandkids[1].e 101))
    (t.is (= (count reverse-children-on-root) 0))
    (t.is (= (count reverse-children-on-child) 1))
    (t.is (= reverse-children-on-child[0].e 1))
    (t.is (= (count reverse-father) 1))
    (t.is (= reverse-father[0].e 10))
    (t.is (= (count reverse-father-on-child) 2))
    (t.is (= reverse-father-on-child[0].e 100))
    (t.is (= reverse-father-on-child[1].e 101))
    (t.is (= (count reverse-father-on-grandchild) 0))
    (t.is (= (count reverse-children-on-grandchild) 1))
    (t.is (= reverse-children-on-grandchild[0].e 10))
    (t.is (= (count nested-reverse-children) 1))
    (t.is (= nested-reverse-children[0].e 1))
    (t.is schema-attr.found)
    (t.is (= schema-attr.e 11))
    (t.is (not missing.found))
    (t.is (= (vev.entity-get missing ":name").kind .Nil))
    (t.is (= (count dangling) 0))
    (t.is (= touched.e 1))
    (t.is (> (count touched.attrs) 0))))

(t.deftest datalog-macro-accepts-source-var-existence-clauses
  (defer (free_all context.allocator))
