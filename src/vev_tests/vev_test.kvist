    (t.is (= exact[0].v.items[1].text "B"))
    (t.is (= (count range) 3))
    (t.is (= range[0].e 1))
    (t.is (= range[1].e 2))
    (t.is (= range[2].e 3))))

(t.deftest datascript-tuple-attrs-index-without-explicit-index-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema (vev.transact
                 (addr conn)
                 ([]vev.Tx-Data
                   [(vev.add 100 ":db/ident" (vev.value-keyword ":a+b+c"))
                    (vev.add 100 ":db/tupleAttrs"
                      (vev.value-vector
                        ([]vev.Value
                          [(vev.value-keyword ":a")
                           (vev.value-keyword ":b")
                           (vev.value-keyword ":c")])))]))
        _ (vev.transact (addr conn) [[:db/add 1 :a "a"]
                                     [:db/add 1 :b "b"]
                                     [:db/add 1 :c "c"]
                                     [:db/add 2 :a "A"]
                                     [:db/add 2 :b "b"]
                                     [:db/add 2 :c "c"]
                                     [:db/add 3 :a "a"]
                                     [:db/add 3 :b "B"]
                                     [:db/add 3 :c "c"]
                                     [:db/add 4 :a "A"]
                                     [:db/add 4 :b "B"]
                                     [:db/add 4 :c "c"]
                                     [:db/add 5 :a "a"]
                                     [:db/add 5 :b "b"]
                                     [:db/add 5 :c "C"]
                                     [:db/add 6 :a "A"]
                                     [:db/add 6 :b "b"]
                                     [:db/add 6 :c "C"]
                                     [:db/add 7 :a "a"]
                                     [:db/add 7 :b "B"]
                                     [:db/add 7 :c "C"]
                                     [:db/add 8 :a "A"]
                                     [:db/add 8 :b "B"]
                                     [:db/add 8 :c "C"]])
        all (vev.datoms conn.db :avet :a+b+c)
        exact (vev.datoms conn.db :avet :a+b+c ["A" "b" "C"])
        nil-exact (vev.datoms conn.db :avet :a+b+c ["A" "b" nil])
        bounded (vev.index-range conn.db :a+b+c ["A" "B" "C"] ["A" "b" "c"])
        nil-prefix (vev.index-range conn.db :a+b+c ["A" "B" nil] ["A" "b" nil])]
    (t.is schema.ok)
    (t.is (= (count all) 8))
    (t.is (= (count exact) 1))
    (t.is (= exact[0].e 6))
    (t.is (= (count nil-exact) 0))
    (t.is (= (count bounded) 4))
    (t.is (= bounded[0].e 8))
    (t.is (= bounded[1].e 4))
    (t.is (= bounded[2].e 6))
    (t.is (= bounded[3].e 2))
    (t.is (= (count nil-prefix) 2))
    (t.is (= nil-prefix[0].e 8))
    (t.is (= nil-prefix[1].e 4))))

(t.deftest datascript-tuple-attrs-query-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                     {:db/id 2 :a "A" :b "C"}
                                     {:db/id 3 :a "B" :b "A"}])
        built (vev.q conn.db
                [:find ?tuple
                 :where
                 [?e :a ?a]
                 [?e :b ?b]
                 [(tuple ?a ?b) ?tuple]])
        split (vev.q conn.db
                [:find ?a ?b
                 :where
                 [?e :a-and-b ?tuple]
                 [(untuple ?tuple) [?a ?b]]])]
    (t.is (= (count built.rows) 3))
    (t.is (= built.rows[0].values[0].kind .Vector))
    (t.is (= built.rows[0].values[0].items[0].text "A"))
    (t.is (= built.rows[0].values[0].items[1].text "B"))
    (t.is (= (count split.rows) 3))
    (t.is (= split.rows[0].values[0].text "A"))
    (t.is (= split.rows[0].values[1].text "B"))
    (t.is (= split.rows[1].values[0].text "A"))
    (t.is (= split.rows[1].values[1].text "C"))
    (t.is (= split.rows[2].values[0].text "B"))
    (t.is (= split.rows[2].values[1].text "A"))))

(t.deftest datascript-tuple-attrs-query-lookup-ref-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        schema-tx (vev.tuple-attrs-schema-tx 100 ":a-and-b" ":a" ":b")
        _ (vev.transact-tx-data (addr conn) (slice schema-tx 0))
        _ (vev.transact (addr conn) [[:db/add 100 :db/unique :db.unique/identity]])
        seed (vev.transact (addr conn) [{:db/id 1 :a "A" :b "B"}
                                        {:db/id 2 :a "A" :b "b"}
                                        {:db/id 3 :a "a" :b "B"}
                                        {:db/id 4 :a "a" :b "b"}])
        exact (vev.datoms conn.db :avet :a-and-b ["a" "B"])
        by-value (vev.q conn.db
                   [:find ?e
                    :where
                    [?e :a-and-b ["a" "B"]]])
        by-lookup-ref (vev.q conn.db
                        [:find ?tuple
                         :where
                         [[:a-and-b ["a" "B"]] :a-and-b ?tuple]])
        by-text-lookup-ref (vev.q-text
                             conn.db
                             "[:find ?tuple :where [[:a-and-b [\"a\" \"B\"]] :a-and-b ?tuple]]")
        pulled (vev.pull conn.db [:a :b :a-and-b] [:a-and-b ["a" "B"]])
        text-pulled (vev.pull-text-lookup-ref
                      conn.db
                      "[:a :b :a-and-b]"
                      ":a-and-b"
                      (vev.value-vector2
                        (vev.value-string "a")
                        (vev.value-string "B")))
        prepared-pattern (vev.prepare-pull-pattern-text "[:a :b :a-and-b]")
        prepared-pulled (vev.pull-prepared-lookup-ref
                          conn.db
                          prepared-pattern
                          ":a-and-b"
                          (vev.value-vector2
                            (vev.value-string "a")
                            (vev.value-string "B")))]
    (t.is seed.ok)
    (t.is (= (count exact) 1))
    (t.is (= exact[0].e 3))
    (t.is (= (count by-value.rows) 1))
    (t.is (= by-value.rows[0].values[0].entity 3))
    (t.is (= (count by-lookup-ref.rows) 1))
    (t.is (= by-lookup-ref.rows[0].values[0].kind .Vector))
    (t.is (= by-lookup-ref.rows[0].values[0].items[0].text "a"))
    (t.is (= by-lookup-ref.rows[0].values[0].items[1].text "B"))
    (t.is (= (count by-text-lookup-ref.rows) 1))
    (t.is (= by-text-lookup-ref.rows[0].values[0].kind .Vector))
    (t.is (= by-text-lookup-ref.rows[0].values[0].items[0].text "a"))
    (t.is (= by-text-lookup-ref.rows[0].values[0].items[1].text "B"))
    (t.is (= (count pulled.attrs) 3))
    (t.is (= pulled.attrs[0].v.text "a"))
    (t.is (= pulled.attrs[1].v.text "B"))
    (t.is (= pulled.attrs[2].v.kind .Vector))
    (t.is (= pulled.attrs[2].v.items[0].text "a"))
    (t.is (= pulled.attrs[2].v.items[1].text "B"))
    (t.is (= (count text-pulled.attrs) 3))
    (t.is (= text-pulled.attrs[0].v.text "a"))
    (t.is (= text-pulled.attrs[1].v.text "B"))
    (t.is (= text-pulled.attrs[2].v.items[0].text "a"))
    (t.is (= text-pulled.attrs[2].v.items[1].text "B"))
    (t.is prepared-pattern.ok)
    (t.is (= (count prepared-pulled.attrs) 3))
    (t.is (= prepared-pulled.attrs[0].v.text "a"))
    (t.is (= prepared-pulled.attrs[1].v.text "B"))
    (t.is (= prepared-pulled.attrs[2].v.items[0].text "a"))
    (t.is (= prepared-pulled.attrs[2].v.items[1].text "B"))))

(t.deftest datascript-tuple-attrs-rejects-invalid-values-subset
  (defer (free_all context.allocator))
  (let [non-vector-conn (vev.create-conn)
        non-vector (vev.transact
                     (addr non-vector-conn)
                     ([]vev.Tx-Data
                       [(vev.add 100 ":db/ident" (vev.value-keyword ":bad"))
                        (vev.add 100 ":db/tupleAttrs" (vev.value-keyword ":a"))]))
        empty-conn (vev.create-conn)
        empty (vev.transact
                (addr empty-conn)
                ([]vev.Tx-Data
                  [(vev.add 100 ":db/ident" (vev.value-keyword ":bad"))
                   (vev.add 100 ":db/tupleAttrs"
                     (vev.value-vector ([]vev.Value [])))]))
        non-keyword-conn (vev.create-conn)
        non-keyword (vev.transact
                      (addr non-keyword-conn)
                      ([]vev.Tx-Data
                        [(vev.add 100 ":db/ident" (vev.value-keyword ":bad"))
                         (vev.add 100 ":db/tupleAttrs"
                           (vev.value-vector
                             ([]vev.Value
                               [(vev.value-string "a")
                                (vev.value-keyword ":b")])))]))]
    (t.is (not non-vector.ok))
    (t.is (= non-vector.error "invalid tuple schema"))
    (t.is (not empty.ok))
    (t.is (= empty.error "invalid tuple schema"))
    (t.is (not non-keyword.ok))
    (t.is (= non-keyword.error "invalid tuple schema"))))

