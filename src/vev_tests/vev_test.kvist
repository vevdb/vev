(package vev-tests)

(import arr "kvist:arr")
(import t "kvist:test")
(import vev "../vev")

(defn result-has-entity-pair? [result: vev.Result-Set, left: u64, right: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 2)
               (= row.values[0].entity left)
               (= row.values[1].entity right))
      (return true)))
  false)

(defn result-has-entity? [result: vev.Result-Set, entity: u64] -> bool
  (for [row result.rows]
    (when (and (= (count row.values) 1)
               (= row.values[0].kind .Entity)
               (= row.values[0].entity entity))
      (return true)))
  false)

(defn values-has-entity? [values: []vev.Value, entity: u64] -> bool
  (for [value values]
    (when (and (= value.kind .Entity)
               (= value.entity entity))
      (return true)))
  false)

(defn tempid-e [tempids: []vev.Tempid, tempid: string] -> [e: u64, ok: bool]
  (for [item tempids]
    (when (= item.tempid tempid)
      (return item.e true)))
  (return 0 false))

(defn keep-not-password [db: vev.DB, datom: vev.Datom] -> bool
  (not (= datom.a ":password")))

(defn keep-not-entity-2 [db: vev.DB, datom: vev.Datom] -> bool
  (not (= datom.e 2)))

(defn keep-long-akas [db: vev.DB, datom: vev.Datom] -> bool
  (when (not (= datom.a ":aka"))
    (return true))
  (let [entity (vev.db-entity db datom.e)
        akas (vev.entity-values entity ":aka")]
    (defer (delete akas))
    (or (<= (count akas) 1)
        (>= (count datom.v.text) 4))))

(defn keep-has-age [db: vev.DB, datom: vev.Datom] -> bool
  (vev.entity-contains? (vev.db-entity db datom.e) ":age"))

(defn keep-adult [db: vev.DB, datom: vev.Datom] -> bool
  (let [age (vev.entity-get (vev.db-entity db datom.e) ":age")]
    (and (= age.kind .Int)
         (>= age.int-value 18))))

(defn birthday-by-name [db: vev.DB, name: string] -> vev.Tx-Fn-Result
  (for [datom-index db.eavt]
    (let [datom db.datoms[datom-index]]
      (when (and (vev.datom-current-at? db datom-index)
                 (= datom.a ":name")
                 (= datom.v.kind .String)
                 (= datom.v.text name))
        (let [age (vev.entity-get (vev.db-entity db datom.e) ":age")]
          (return
            (vev.tx-fn-ok
              ([]vev.Tx-Data
                [(vev.add datom.e ":age" (vev.value-int (+ age.int-value 1)))
                 (vev.add datom.e ":had-birthday" (vev.value-bool true))])))))))
  (vev.tx-fn-error "No entity with name"))

(defn create-oleg [db: vev.DB] -> vev.Tx-Fn-Result
  (vev.tx-fn-ok
    ([]vev.Tx-Data
      [(vev.add-tempid "new-person" ":name" (vev.value-string "Oleg"))])))

(t.deftest transact-reports-snapshots-and-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact-with-meta
                 (addr conn)
                 ([]vev.Tx-Op
                   [(vev.tx-add 1 ":user/email" (vev.value-string "a@example.com"))
                    (vev.tx-add 1 ":user/name" (vev.value-string "Andreas"))])
                 ([]vev.Tx-Meta
                   [(vev.Tx-Meta {a: ":request/id" v: (vev.value-string "req-1")})
                    (vev.Tx-Meta {a: ":tx/reason" v: (vev.value-keyword ":profile-edit")})]))]
    (t.is (= report.tx 1))
    (t.is (= conn.next-tx 2))
    (t.is (= (count report.db-before.datoms) 0))
    (t.is (= (count report.db-after.datoms) 2))
    (t.is (= (count report.tx-data) 2))
    (t.is (= (count report.tx-meta) 2))
    (t.is (= report.tx-meta[0].a ":request/id"))
    (let [meta-value report.tx-meta[0].v]
      (t.is (= meta-value.text "req-1")))
    (let [results (vev.q-strings report.db-after (vev.query-name-by-email "a@example.com"))]
      (t.is (= (count results) 1))
      (t.is (= results[0] "Andreas")))))

(t.deftest tx-data-supports-datomic-tx-metadata
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id "datomic.tx"
                   :request/id "req-1"
                   :tx/reason :profile-edit}
                  [:db/add 1 :user/name "Ada"]])
        tx-e report.tempids[0].e
        [current-tx current-tx-ok] (tempid-e (slice report.tempids 0) ":db/current-tx")
        tx-props (vev.q report.db-after
                   [:find ?a ?v
                    :where
                    [?tx :request/id "req-1"]
                    [?tx ?a ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 3))
    (t.is (= report.tx-data[0].e tx-e))
    (t.is (= report.tx-data[1].e tx-e))
    (t.is (= report.tx-data[2].e 1))
    (t.is (= (count report.tempids) 2))
    (t.is current-tx-ok)
    (t.is (= current-tx report.tx))
    (t.is (= (count tx-props.rows) 2))
    (t.is (= (count report.tx-meta) 2))
    (t.is (= report.tx-meta[0].a ":request/id"))
    (t.is (= report.tx-meta[0].v.text "req-1"))
    (t.is (= report.tx-meta[1].a ":tx/reason"))
    (t.is (= report.tx-meta[1].v.text ":profile-edit"))))

(t.deftest datascript-query-db-datom-tx-op-terms-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/name "Ada"]
                  [:db/add 1 :user/age 37]])
        literal (vev.q report.db-after
                  [:find ?tx ?name
                   :where
                   [1 :user/name ?name ?tx :db/add]])
        prepared (vev.prepare-query-text "[:find ?tx ?name :where [1 :user/name ?name ?tx :db/add]]")
        prepared-result (vev.q-prepared report.db-after prepared)
        text (vev.q-text
               report.db-after
               "[:find ?tx ?name :where [1 :user/name ?name ?tx :db/add]]")
        tx-only (vev.q report.db-after
                  [:find ?tx ?age
                   :where
                   [1 :user/age ?age ?tx]])
        retract-op (vev.q-text
                     report.db-after
                     "[:find ?name :where [1 :user/name ?name _ :db/retract]]")]
    (t.is (= (count literal.rows) 1))
    (t.is (= literal.rows[0].values[0].entity report.tx))
    (t.is (= literal.rows[0].values[1].text "Ada"))
    (t.is prepared.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].entity report.tx))
    (t.is (= prepared-result.rows[0].values[1].text "Ada"))
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].entity report.tx))
    (t.is (= text.rows[0].values[1].text "Ada"))
    (t.is (= (count tx-only.rows) 1))
    (t.is (= tx-only.rows[0].values[0].entity report.tx))
    (t.is (= tx-only.rows[0].values[1].int-value 37))
    (t.is (= (count retract-op.rows) 0))))

(t.deftest datascript-listen-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        reports (make [dynamic]vev.Tx-Report) :defer
        _ (vev.transact (addr conn) [[:db/add 1 :name "Alex"]
                                     [:db/add 2 :name "Boris"]])
        _ (vev.listen! (addr conn) "test" (addr reports))
        first (vev.transact-with-meta
                (addr conn)
                ([]vev.Tx-Op [(vev.tx-add 3 ":name" (vev.value-string "Dima"))
                               (vev.tx-add 3 ":age" (vev.value-int 19))
                               (vev.tx-add 4 ":name" (vev.value-string "Evgeny"))])
                ([]vev.Tx-Meta [(vev.Tx-Meta {a: ":some-metadata" v: (vev.value-int 1)})]))
        second (vev.transact
                 (addr conn)
                 [[:db/add 5 :name "Fedor"]
                  [:db/add 1 :name "Alex2"]
                  [:db/retract 2 :name "Not Boris"]
                  [:db/retract 4 :name "Evgeny"]])
        _ (vev.unlisten! (addr conn) "test")
        _ (vev.transact (addr conn) [[:db/add 6 :name "Georgy"]])]
    (t.is first.ok)
    (t.is second.ok)
    (t.is (= (count reports) 2))
    (t.is (= (count reports[0].tx-data) 3))
    (t.is (= reports[0].tx-data[0].e 3))
    (t.is (= reports[0].tx-data[0].a ":name"))
    (t.is (= reports[0].tx-data[0].v.text "Dima"))
    (t.is (= reports[0].tx-data[1].a ":age"))
    (t.is (= reports[0].tx-data[1].v.int-value 19))
    (t.is (= reports[0].tx-meta[0].a ":some-metadata"))
    (t.is (= reports[0].tx-meta[0].v.int-value 1))
    (t.is (= (count reports[1].tx-data) 4))
    (t.is (= reports[1].tx-data[0].e 5))
    (t.is reports[1].tx-data[0].added)
    (t.is (= reports[1].tx-data[1].e 1))
    (t.is (not reports[1].tx-data[1].added))
    (t.is (= reports[1].tx-data[2].e 1))
    (t.is reports[1].tx-data[2].added)
    (t.is (= reports[1].tx-data[3].e 4))
    (t.is (not reports[1].tx-data[3].added))
    (t.is (= (count reports[1].tx-meta) 0))))

(t.deftest transact-defaults-unschematized-attrs-to-cardinality-one
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        first-report (vev.transact
                       (addr conn)
                       [[:db/add 1 :name "Ivan"]])
        second-report (vev.transact
                        (addr conn)
                        [[:db/add 1 :name "Oleg"]])
        names (vev.q-collection second-report.db-after
                [:find [?name ...]
                 :where
                 [1 :name ?name]])]
    (t.is first-report.ok)
    (t.is second-report.ok)
    (t.is (= (count names) 1))
    (t.is (= names[0].text "Oleg"))))

(t.deftest transact-preserves-schema-cardinality-many
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 100 :db/ident :aka :db/cardinality :db.cardinality/many}
                  [:db/add 1 :aka "X"]
                  [:db/add 1 :aka "Y"]])
        akas (vev.q-collection report.db-after
               [:find [?aka ...]
                :where
                [1 :aka ?aka]])
        schema-view (vev.db-schema report.db-after)]
    (defer (vev.delete-schema schema-view))
    (t.is report.ok)
    (t.is (= (count akas) 2))
    (t.is (= akas[0].text "X"))
    (t.is (= akas[1].text "Y"))
    (t.is (= (count schema-view) 1))
    (t.is (= schema-view[0].attr ":aka"))
    (t.is schema-view[0].has-cardinality)
    (t.is (= schema-view[0].cardinality ":db.cardinality/many"))))

(t.deftest query-joins-and-returns-multiple-columns
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        clauses ([]vev.Clause
                  [(vev.clause (vev.term-var "e") ":user/name" (vev.term-var "name"))
                   (vev.clause (vev.term-var "e") ":user/age" (vev.term-var "age"))
                   (vev.clause (vev.term-var "e") ":user/active" (vev.term-bool true))])
        query (vev.query ([]string ["e" "name" "age"]) ([]string []) ([]string []) ([]string []) ([]vev.Tuple-Input []) ([]vev.Relation-Input []) clauses ([]vev.Predicate []) ([]vev.Function-Clause []) ([]vev.Rule []) ([]vev.Rule-Call []) ([]vev.Get-Else []) ([]vev.Get-Some []) ([]vev.Ground []) ([]vev.Not-Group []) ([]vev.Or-Group []) ([]vev.Pull-Find []) ([]vev.Aggregate-Find []))
        result (vev.q report.db-after query)]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].kind .Entity))
      (t.is (= result.rows[0].values[0].entity 1))
      (t.is (= result.rows[0].values[1].text "Ada"))
      (t.is (= result.rows[0].values[2].kind .Int))
      (t.is (= result.rows[0].values[2].int-value 37))))

(t.deftest datascript-query-test-joins-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [{:db/id 1 :name "Ivan" :age 15}
                  {:db/id 2 :name "Petr" :age 37}
                  {:db/id 3 :name "Ivan" :age 37}
                  {:db/id 4 :age 15}])
        ivans (vev.q report.db-after
                [:find ?e ?age
                 :where
                 [?e :name "Ivan"]
                 [?e :age ?age]])
        named (vev.q report.db-after
                [:find ?e
                 :where
                 [?e :name]])
        same-names (vev.q report.db-after
                     [:find ?e1 ?e2
                      :where
                      [?e1 :name ?name]
                      [?e2 :name ?name]])
        same-age-names (vev.q report.db-after
                         [:find ?e ?e2 ?name
                          :where
                          [?e :name "Ivan"]
                          [?e :age ?age]
                          [?e2 :age ?age]
                          [?e2 :name ?name]])]
    (t.is (= (count ivans.rows) 2))
    (t.is (= ivans.rows[0].values[0].entity 1))
    (t.is (= ivans.rows[0].values[1].int-value 15))
    (t.is (= ivans.rows[1].values[0].entity 3))
    (t.is (= ivans.rows[1].values[1].int-value 37))
    (t.is (= (count named.rows) 3))
    (t.is (= named.rows[0].values[0].entity 1))
    (t.is (= named.rows[1].values[0].entity 2))
    (t.is (= named.rows[2].values[0].entity 3))
    (t.is (= (count same-names.rows) 5))
    (t.is (= (count same-age-names.rows) 3))
    (t.is (= same-age-names.rows[0].values[0].entity 1))
    (t.is (= same-age-names.rows[0].values[1].entity 1))
    (t.is (= same-age-names.rows[0].values[2].text "Ivan"))
    (t.is (= same-age-names.rows[1].values[0].entity 3))
    (t.is (= same-age-names.rows[1].values[1].entity 2))
    (t.is (= same-age-names.rows[1].values[2].text "Petr"))
    (t.is (= same-age-names.rows[2].values[0].entity 3))
    (t.is (= same-age-names.rows[2].values[1].entity 3))
    (t.is (= same-age-names.rows[2].values[2].text "Ivan"))))

(t.deftest datascript-query-cardinality-many-join-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :aka]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             {:db/id 1 :name "Ivan" :aka ["ivolga" "pi"]}
             {:db/id 2 :name "Petr" :aka ["porosenok" "pi"]}])
        result (vev.q conn.db
                 [:find ?n1 ?n2
                  :where
                  [?e1 :aka ?x]
                  [?e2 :aka ?x]
                  [?e1 :name ?n1]
                  [?e2 :name ?n2]])]
    (t.is (= (count result.rows) 4))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].text "Ivan"))
    (t.is (= result.rows[1].values[0].text "Ivan"))
    (t.is (= result.rows[1].values[1].text "Petr"))
    (t.is (= result.rows[2].values[0].text "Petr"))
    (t.is (= result.rows[2].values[1].text "Ivan"))
    (t.is (= result.rows[3].values[0].text "Petr"))
    (t.is (= result.rows[3].values[1].text "Petr"))))

(t.deftest datascript-query-symbol-comparison-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            ([]vev.Tx-Data
              [(vev.add 1 ":s" (vev.value-symbol "a"))
               (vev.add 2 ":s" (vev.value-symbol "b"))]))
        literal (vev.q-collection conn.db
                  [:find [?e ...]
                   :where
                   [?e :s b]])
        text (vev.q-text conn.db "[:find [?e ...] :where [?e :s b]]")
        text-tx-conn (vev.create-conn)
        _ (vev.transact-text (addr text-tx-conn) "[{:db/id 1 :s a} {:db/id 2 :s b}]")
        text-tx (vev.q-text text-tx-conn.db "[:find [?e ...] :where [?e :s b]]")
        source (vev.q-text-with-inputs
                 conn.db
                 "[:find [?e ...] :in $rows :where [$rows ?e :s b]]"
                 ([]vev.Query-Input
                   [(vev.query-input-scalar
                      (vev.value-vector
                        ([]vev.Value
                          [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":s") (vev.value-symbol "a")]))
                           (vev.value-vector ([]vev.Value [(vev.value-int 2) (vev.value-keyword ":s") (vev.value-symbol "b")]))])))]))
        schema-conn (vev.create-conn)
        _ (vev.transact
            (addr schema-conn)
            [[:db/add 100 :db/ident :s]
             [:db/add 100 :db/valueType :db.type/symbol]])
        schema-ok (vev.transact-tx-data
                    (addr schema-conn)
                    ([]vev.Tx-Data [(vev.add 1 ":s" (vev.value-symbol "ok"))]))
        schema-bad (vev.transact (addr schema-conn) [[:db/add 2 :s "bad"]])]
    (t.is (= (count literal) 1))
    (t.is (= literal[0].entity 2))
    (t.is text.ok)
    (t.is (= (count text.rows) 1))
    (t.is (= text.rows[0].values[0].entity 2))
    (t.is text-tx.ok)
    (t.is (= (count text-tx.rows) 1))
    (t.is (= text-tx.rows[0].values[0].entity 2))
    (t.is source.ok)
    (t.is (= (count source.rows) 1))
    (t.is (= source.rows[0].values[0].int-value 2))
    (t.is schema-ok.ok)
    (t.is (not schema-bad.ok))
    (t.is (= schema-bad.error "schema value type mismatch"))))

(t.deftest datalog-macro-builds-query-from-data-literal
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.seed-people (addr conn))
        result (vev.q report.db-after
                 [:find ?e ?name
                  :where
                  [?e :user/name ?name]
                  [?e :user/active true]])]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].kind .Entity))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].kind .String))
    (t.is (= result.rows[0].values[1].text "Ada"))))

(t.deftest datascript-parser-query-text-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :active true :age 37}
             {:db/id 2 :name "Grace Hopper" :active false :age 41}])
        collection-query (vev.empty-query)
        [collection-ok collection-error] (vev.parse-query-text! (addr collection-query) "[:find [?name ...] :where [_ :name ?name]]")
        prepared (vev.prepare-query-text "[:find ?name :where [?e :name ?name] [?e :active true]]")
        prepared-result (vev.q-prepared conn.db prepared)
        prepared-input (vev.prepare-query-text "[:find ?e :in ?name :where [?e :name ?name]]")
        prepared-input-result (vev.q-prepared-with-inputs
                                conn.db
                                prepared-input
                                ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "Grace Hopper"))]))
        bad-prepared (vev.prepare-query-text "[:where [?e :name ?name]]")
        bad-prepared-result (vev.q-prepared conn.db bad-prepared)
        relation (vev.q-text conn.db "[:find ?e ?name :where [?e :name ?name] [?e :active true]]")
        collection (vev.result-collection (vev.q-query conn.db collection-query))
        constant (vev.q-text conn.db "[:find ?e :where [?e :name \"Grace Hopper\"]]")
        numeric (vev.q-text conn.db "[:find ?name :where [1 :age 37] [1 :name ?name]]")
        map-query (vev.q-text-with-inputs
                    conn.db
                    "{:find [?e] :in [$ ?attr ?value] :where [[?e ?attr ?value]]}"
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":name"))
                                         (vev.query-input-scalar (vev.value-string "Ada Lovelace"))]))
        map-relation (vev.q-text-with-inputs
                       conn.db
                       "{:find [?e ?email] :in [$ [[?name ?email]]] :where [[?e :name ?name]]}"
                       ([]vev.Query-Input [(vev.query-input-relation
                                             ([]vev.Value [(vev.value-string "Ada Lovelace")
                                                           (vev.value-string "ada@example.com")
                                                           (vev.value-string "Grace Hopper")
                                                           (vev.value-string "grace@example.com")])
                                             2)]))
        map-no-where (vev.q-text-with-inputs
                       conn.db
                       "{:find [?x] :in [?x]}"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ok"))]))
        map-keys (vev.q-text-keys
                   conn.db
                   "{:find [?name ?age] :keys [name age] :where [[?e :name ?name] [?e :age ?age]]}")
        bad (vev.q-text conn.db "[:where [?e :name ?name]]")
        missing-input (vev.q-text-with-inputs
                        conn.db
                        "[:find ?x :in ?x]"
                        ([]vev.Query-Input []))
        extra-input (vev.q-text-with-inputs
                      conn.db
                      "[:find ?e :where [?e :name ?name]]"
                      ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "unused"))]))
        unknown-find (vev.q-text conn.db "[:find ?missing :where [?e :name]]")
        unknown-with (vev.q-text conn.db "[:find ?e :with ?missing :where [?e :name]]")
        unknown-find-literal (vev.q conn.db
                               [:find ?missing
                                :where
                                [?e :name]])
        find-with-overlap (vev.q-text conn.db "[:find ?e :with ?e :where [?e :name]]")
        duplicate-in (vev.q-text-with-inputs
                       conn.db
                       "[:find ?e :in ?x ?x :where [?e :name]]"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "a"))
                                            (vev.query-input-scalar (vev.value-string "b"))]))
        duplicate-with (vev.q-text conn.db "[:find ?name :with ?e ?e :where [?e :name ?name]]")
        missing-rules-var (vev.q-text conn.db "[:find ?e :where (rule ?e)]")
        missing-rules-var-map (vev.q-text conn.db "{:find [?e] :where [(rule ?e)]}")
        missing-rules-var-literal (vev.q conn.db
                                    [:find ?e
                                     :where
                                     (rule ?e)])
        unknown-source (vev.q-text conn.db "[:find ?name :where [$2 ?e :name ?name]]")
        unknown-predicate (vev.q-text-with-inputs
                             conn.db
                             "[:find ?e :in [?e ...] :where [(fun ?e)]]"
                             ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1)]))]))
        unknown-function (vev.q-text-with-inputs
                           conn.db
                           "[:find ?e ?x :in [?e ...] :where [(fun ?e) ?x]]"
                           ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1)]))]))
        unbound-predicate (vev.q-text conn.db "[:find ?x :where [(zero? ?x)]]")
        unbound-function (vev.q-text conn.db "[:find ?x :where [(inc ?x) ?y]]")
        unbound-not (vev.q-text conn.db "[:find ?e :where [?e :name] (not [?a :name \"Ada Lovelace\"])]")
        not-before-binding (vev.q-text conn.db "[:find ?e :where (not [?e :name \"Ada Lovelace\"]) [?e :name]]")
        predicate-before-binding (vev.q-text conn.db "[:find ?name :where [(= ?name \"Ada Lovelace\")] [?e :name ?name]]")
        mismatched-or (vev.q-text conn.db "[:find ?e :where (or [?e :name _] [?e :age ?a])]")
        relation-source (vev.q-text-with-inputs
                          conn.db
                          "[:find ?name :in $rows :where [$rows ?e :name ?name]]"
                          ([]vev.Query-Input
                            [(vev.query-input-scalar
                               (vev.value-vector
                                 ([]vev.Value
                                   [(vev.value-vector
                                      ([]vev.Value [(vev.value-int 1)
                                                    (vev.value-keyword ":name")
                                                    (vev.value-string "Ada Lovelace")]))])))]))]
    (defer (delete collection))
    (t.is (= (count relation.rows) 1))
    (t.is (= relation.rows[0].values[0].entity 1))
    (t.is (= relation.rows[0].values[1].text "Ada Lovelace"))
    (t.is collection-ok)
    (t.is (= collection-error ""))
    (t.is (= (count collection) 2))
    (t.is (= collection[0].text "Ada Lovelace"))
    (t.is (= collection[1].text "Grace Hopper"))
    (t.is prepared.ok)
    (t.is (= (count prepared-result.rows) 1))
    (t.is (= prepared-result.rows[0].values[0].text "Ada Lovelace"))
    (t.is prepared-input.ok)
    (t.is (= (count prepared-input-result.rows) 1))
    (t.is (= prepared-input-result.rows[0].values[0].entity 2))
    (t.is (not bad-prepared.ok))
    (t.is (not bad-prepared-result.ok))
    (t.is (= (count constant.rows) 1))
    (t.is (= constant.rows[0].values[0].entity 2))
    (t.is (= (count numeric.rows) 1))
    (t.is (= numeric.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= (count map-query.rows) 1))
    (t.is (= map-query.rows[0].values[0].entity 1))
    (t.is (= (count map-relation.rows) 2))
    (t.is (= map-relation.rows[0].values[0].entity 1))
    (t.is (= map-relation.rows[0].values[1].text "ada@example.com"))
    (t.is (= map-relation.rows[1].values[0].entity 2))
    (t.is (= map-relation.rows[1].values[1].text "grace@example.com"))
    (t.is (= (count map-no-where.rows) 1))
    (t.is (= map-no-where.rows[0].values[0].text ":ok"))
    (t.is (= (count map-keys) 2))
    (t.is (= map-keys[0].items[0].key "name"))
    (t.is (= map-keys[0].items[0].value.text "Ada Lovelace"))
    (t.is (= map-keys[0].items[1].key "age"))
    (t.is (= map-keys[0].items[1].value.int-value 37))
    (t.is (not bad.ok))
    (t.is (= bad.error "query text must start with [:find"))
    (t.is (= (count bad.rows) 0))
    (t.is (not missing-input.ok))
    (t.is (= missing-input.error "wrong number of query inputs: expected 1, got 0"))
    (t.is (not extra-input.ok))
    (t.is (= extra-input.error "wrong number of query inputs: expected 0, got 1"))
    (t.is (not unknown-find.ok))
    (t.is (= unknown-find.error "Query for unknown vars: ?missing"))
    (t.is (not unknown-with.ok))
    (t.is (= unknown-with.error "Query for unknown vars: ?missing"))
    (t.is (not unknown-find-literal.ok))
    (t.is (= unknown-find-literal.error "Query for unknown vars: ?missing"))
    (t.is (not find-with-overlap.ok))
    (t.is (= find-with-overlap.error ":find and :with should not use same variables: ?e"))
    (t.is (not duplicate-in.ok))
    (t.is (= duplicate-in.error "Vars used in :in should be distinct"))
    (t.is (not duplicate-with.ok))
    (t.is (= duplicate-with.error "Vars used in :with should be distinct"))
    (t.is (not missing-rules-var.ok))
    (t.is (= missing-rules-var.error "Missing rules var '%' in :in"))
    (t.is (not missing-rules-var-map.ok))
    (t.is (= missing-rules-var-map.error "Missing rules var '%' in :in"))
    (t.is (not missing-rules-var-literal.ok))
    (t.is (= missing-rules-var-literal.error "Missing rules var '%' in :in"))
    (t.is (not unknown-source.ok))
    (t.is (= unknown-source.error "unknown query source: $2"))
    (t.is (not unknown-predicate.ok))
    (t.is (= unknown-predicate.error "unknown query predicate: fun"))
    (t.is (not unknown-function.ok))
    (t.is (= unknown-function.error "unknown query function: fun"))
    (t.is (not unbound-predicate.ok))
    (t.is (= unbound-predicate.error "insufficient bindings for zero?: ?x"))
    (t.is (not unbound-function.ok))
    (t.is (= unbound-function.error "insufficient bindings for inc: ?x"))
    (t.is (not unbound-not.ok))
    (t.is (= unbound-not.error "insufficient bindings for not: ?a"))
    (t.is (not not-before-binding.ok))
    (t.is (= not-before-binding.error "insufficient bindings for not: ?e"))
    (t.is (not predicate-before-binding.ok))
    (t.is (= predicate-before-binding.error "insufficient bindings for =: ?name"))
    (t.is (not mismatched-or.ok))
    (t.is (= mismatched-or.error "or branches must use same vars"))
    (t.is relation-source.ok)
    (t.is (= (count relation-source.rows) 1))
    (t.is (= relation-source.rows[0].values[0].text "Ada Lovelace"))))

(t.deftest datascript-parser-query-text-predicates-and-functions
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace" :age 37}
             {:db/id 2 :name "Grace Hopper" :age 41}
             {:db/id 3 :name "Alan Turing" :age 40}])
        older (vev.q-text conn.db "[:find ?name :where [?e :age ?age] [(> ?age 40)] [?e :name ?name]]")
        even-age (vev.q-text conn.db "[:find ?name :where [?e :age ?age] [(even? ?age)] [?e :name ?name]]")
        next-age (vev.q-text conn.db "[:find ?name ?next :where [?e :age ?age] [(inc ?age) ?next] [(> ?next 40)] [?e :name ?name]]")
        destructured (vev.q-text conn.db "[:find ?name ?age :where [?e :name ?n] [?e :age ?a] [(vector ?n ?a) [?name ?age]] [(= ?name \"Ada Lovelace\")]]")]
    (t.is (= (count older.rows) 1))
    (t.is (= older.rows[0].values[0].text "Grace Hopper"))
    (t.is (= (count even-age.rows) 1))
    (t.is (= even-age.rows[0].values[0].text "Alan Turing"))
    (t.is (= (count next-age.rows) 2))
    (t.is (= next-age.rows[0].values[0].text "Grace Hopper"))
    (t.is (= next-age.rows[0].values[1].int-value 42))
    (t.is (= next-age.rows[1].values[0].text "Alan Turing"))
    (t.is (= next-age.rows[1].values[1].int-value 41))
    (t.is (= (count destructured.rows) 1))
    (t.is (= destructured.rows[0].values[0].text "Ada Lovelace"))
    (t.is (= destructured.rows[0].values[1].int-value 37))))

(t.deftest datascript-parser-query-text-inputs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada" :age 37 :email "ada@example.com"}
             {:db/id 2 :name "Grace" :age 85 :email "grace@example.com"}])
        scalar (vev.q-text-with-inputs
                 conn.db
                 "[:find ?name :in ?email :where [?e :email ?email] [?e :name ?name]]"
                 ([]vev.Query-Input [(vev.query-input-scalar (vev.value-string "ada@example.com"))]))
        collection (vev.q-text-with-inputs
                     conn.db
                     "[:find ?name :in [?email ...] :where [?e :email ?email] [?e :name ?name]]"
                     ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "ada@example.com") (vev.value-string "grace@example.com")]))]))
        tuple (vev.q-text-with-inputs
                conn.db
                "[:find ?e :in [?name ?age] :where [?e :name ?name] [?e :age ?age]]"
                ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37)]))]))
        relation (vev.q-text-with-inputs
                   conn.db
                   "[:find ?e :in [[?name ?age]] :where [?e :name ?name] [?e :age ?age]]"
                   ([]vev.Query-Input [(vev.query-input-relation ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37) (vev.value-string "Nope") (vev.value-int 0)]) 2)]))
        map-input (vev.value-map
                    ([]vev.Value
                      [(vev.value-keyword ":ada") (vev.value-string "ada@example.com")
                       (vev.value-keyword ":grace") (vev.value-string "grace@example.com")]))
        nested-flat-input (vev.value-map
                            ([]vev.Value
                              [(vev.value-keyword ":ada") (vev.value-int 37)
                               (vev.value-keyword ":grace") (vev.value-int 85)]))
        nested-tuple-input (vev.value-map
                             ([]vev.Value
                               [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 7)]))
                                (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 4) (vev.value-int 2)]))]))
        nested-collection-input (vev.value-map
                                  ([]vev.Value
                                    [(vev.value-keyword ":a") (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))
                                     (vev.value-keyword ":b") (vev.value-vector ([]vev.Value [(vev.value-int 0) (vev.value-int 4)]))]))
        map-relation (vev.q-text-with-inputs
                       conn.db
                       "[:find ?k ?name :in [[?k ?email]] :where [?e :email ?email] [?e :name ?name]]"
                       ([]vev.Query-Input [(vev.query-input-scalar map-input)]))
        nested-flat (vev.q-text-with-inputs
                      conn.db
                      "[:find ?k ?age :in [[?k ?age] ...] :where [(> ?age 40)]]"
                      ([]vev.Query-Input [(vev.query-input-scalar nested-flat-input)]))
        nested-tuple (vev.q-text-with-inputs
                       conn.db
                       "[:find ?k ?min ?max :in [[?k [?min ?max]] ...] :where [(> ?max ?min)]]"
                       ([]vev.Query-Input [(vev.query-input-scalar nested-tuple-input)]))
        nested-collection (vev.q-text-with-inputs
                            conn.db
                            "[:find ?k ?x :in [[?k [?x ...]] ...] :where [(> ?x 1)]]"
                            ([]vev.Query-Input [(vev.query-input-scalar nested-collection-input)]))
        no-where (vev.q-text-with-inputs
                   conn.db
                   "[:find ?x :in ?x]"
                   ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":ok"))]))]
    (t.is (= (count scalar.rows) 1))
    (t.is (= scalar.rows[0].values[0].text "Ada"))
    (t.is (= (count collection.rows) 2))
    (t.is (= tuple.rows[0].values[0].entity 1))
    (t.is (= relation.rows[0].values[0].entity 1))
    (t.is (= (count map-relation.rows) 2))
    (t.is (= map-relation.rows[0].values[0].text ":ada"))
    (t.is (= map-relation.rows[0].values[1].text "Ada"))
    (t.is (= map-relation.rows[1].values[0].text ":grace"))
    (t.is (= map-relation.rows[1].values[1].text "Grace"))
    (t.is (= (count nested-flat.rows) 1))
    (t.is (= nested-flat.rows[0].values[0].text ":grace"))
    (t.is (= nested-flat.rows[0].values[1].int-value 85))
    (t.is (= (count nested-tuple.rows) 1))
    (t.is (= nested-tuple.rows[0].values[0].text ":a"))
    (t.is (= nested-tuple.rows[0].values[1].int-value 1))
    (t.is (= nested-tuple.rows[0].values[2].int-value 7))
    (t.is (= (count nested-collection.rows) 3))
    (t.is (= nested-collection.rows[0].values[0].text ":a"))
    (t.is (= nested-collection.rows[0].values[1].int-value 2))
    (t.is (= nested-collection.rows[1].values[0].text ":a"))
    (t.is (= nested-collection.rows[1].values[1].int-value 3))
    (t.is (= nested-collection.rows[2].values[0].text ":b"))
    (t.is (= nested-collection.rows[2].values[1].int-value 4))
    (t.is (= no-where.rows[0].values[0].text ":ok"))))

(t.deftest datascript-query-input-binding-validation-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        bad-tuple-scalar (vev.q-text-with-inputs
                           conn.db
                           "[:find ?a ?b :in [?a ?b]]"
                           ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        short-tuple (vev.q-text-with-inputs
                      conn.db
                      "[:find ?a ?b :in [?a ?b]]"
                      ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-keyword ":a")]))]))
        bad-collection (vev.q-text-with-inputs
                         conn.db
                         "[:find ?a :in [?a ...]]"
                         ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        bad-relation (vev.q-text-with-inputs
                       conn.db
                       "[:find ?a ?b :in [[?a ?b]]]"
                       ([]vev.Query-Input [(vev.query-input-scalar (vev.value-keyword ":a"))]))
        relation-width (vev.q-text-with-inputs
                         conn.db
                         "[:find ?a ?b :in [[?a ?b]]]"
                         ([]vev.Query-Input [(vev.query-input-relation ([]vev.Value [(vev.value-keyword ":a")
                                                                                     (vev.value-keyword ":b")
                                                                                     (vev.value-keyword ":c")])
                                                                       3)]))]
    (t.is (not bad-tuple-scalar.ok))
    (t.is (= bad-tuple-scalar.error "cannot bind query input to tuple"))
    (t.is (not short-tuple.ok))
    (t.is (= short-tuple.error "not enough values to bind tuple input"))
    (t.is (not bad-collection.ok))
    (t.is (= bad-collection.error "cannot bind query input to collection ?a"))
    (t.is (not bad-relation.ok))
    (t.is (= bad-relation.error "cannot bind query input to relation"))
    (t.is (not relation-width.ok))
    (t.is (= relation-width.error "query relation input width mismatch"))))

(t.deftest datascript-parser-query-text-rules
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :follow]
             [:db/add 100 :db/valueType :db.type/ref]
             [:db/add 100 :db/cardinality :db.cardinality/many]
             [:db/add 1 :follow (vev.value-entity 2)]
             [:db/add 2 :follow (vev.value-entity 3)]
             [:db/add 3 :follow (vev.value-entity 4)]
             [:db/add 4 :follow (vev.value-entity 6)]
             [:db/add 1 :name "Ada"]
             [:db/add 2 :name "Grace"]
             [:db/add 2 :height 240]])
        direct (vev.q-text-with-rules
                 conn.db
                 "[:find ?e1 ?e2 :in $ % :where (follow ?e1 ?e2)]"
                 "[[(follow ?x ?y) [?x :follow ?y]]]"
                 ([]vev.Query-Input []))
        recursive (vev.q-text-with-rules
                    conn.db
                    "[:find [?e2 ...] :in $ ?e1 % :where (follow ?e1 ?e2)]"
                    "[[(follow ?e1 ?e2) [?e1 :follow ?e2]] [(follow ?e1 ?e2) [?e1 :follow ?t] (follow ?t ?e2)]]"
                    ([]vev.Query-Input [(vev.query-input-scalar (vev.value-entity 1))]))
        filtered (vev.q-text-with-rules
                   conn.db
                   "[:find ?x ?y :in $ % :where (match ?x ?y)]"
                   "[[(match ?e ?e2) [?e :follow ?e2] [(even? ?e)] [(even? ?e2)]]]"
                   ([]vev.Query-Input []))
        grouped (vev.q-text-with-rules
                   conn.db
                   "[:find ?x ?y :in $ % :where (grouped-match ?x ?y)]"
                   "[[(grouped-match ?e ?e2) (and [?e :follow ?e2] [(even? ?e)] [(even? ?e2)])]]"
                   ([]vev.Query-Input []))
        get-else (vev.q-text-with-rules
                   conn.db
                   "[:find ?e ?height :in $ % :where (named-height ?e ?height)]"
                   "[[(named-height ?e ?height) [?e :name] [(get-else $ ?e :height 300) ?height]]]"
                   ([]vev.Query-Input []))
        get-some (vev.q-text-with-rules
                   conn.db
                   "[:find ?e ?a ?v :in $ % :where (named-some ?e ?a ?v)]"
                   "[[(named-some ?e ?a ?v) [?e :name] [(get-some $ ?e :height :name) [?a ?v]]]]"
                   ([]vev.Query-Input []))
        bad-get-else (vev.q-text-with-rules
                       conn.db
                       "[:find ?e ?height :in $ % :where (named-height ?e ?height)]"
                       "[[(named-height ?e ?height) [?e :name] [(get-else $ ?e :height nil) ?height]]]"
                       ([]vev.Query-Input []))]
    (t.is (= (count direct.rows) 4))
    (t.is (= direct.rows[0].values[0].entity 1))
    (t.is (= direct.rows[0].values[1].entity 2))
    (t.is (= (count recursive.rows) 4))
    (t.is (= recursive.rows[0].values[0].entity 2))
    (t.is (= recursive.rows[3].values[0].entity 6))
    (t.is (= (count filtered.rows) 1))
    (t.is (= filtered.rows[0].values[0].entity 4))
    (t.is (= filtered.rows[0].values[1].entity 6))
    (t.is (= (count grouped.rows) 1))
    (t.is (= grouped.rows[0].values[0].entity 4))
    (t.is (= grouped.rows[0].values[1].entity 6))
    (t.is get-else.ok)
    (t.is (= (count get-else.rows) 2))
    (t.is (= get-else.rows[0].values[0].entity 1))
    (t.is (= get-else.rows[0].values[1].int-value 300))
    (t.is (= get-else.rows[1].values[0].entity 2))
    (t.is (= get-else.rows[1].values[1].int-value 240))
    (t.is get-some.ok)
    (t.is (= (count get-some.rows) 2))
    (t.is (= get-some.rows[0].values[1].text ":name"))
    (t.is (= get-some.rows[0].values[2].text "Ada"))
    (t.is (= get-some.rows[1].values[1].text ":height"))
    (t.is (= get-some.rows[1].values[2].int-value 240))
    (t.is (not bad-get-else.ok))
    (t.is (= bad-get-else.error "get-else: nil default value is not supported"))))

(t.deftest datascript-parser-query-text-sources
  (defer (free_all context.allocator))
  (let [left (vev.create-conn)
        right (vev.create-conn)
        _ (vev.transact
            (addr left)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 1 :name "Ivan" :id 1}
             {:db/id 2 :name "Petr" :id 2}
             {:db/id 3 :name "Oleg" :id 3}])
        _ (vev.transact
            (addr right)
            [{:db/id 100 :db/ident :name :db/unique :db.unique/identity}
             {:db/id 3 :name "Ivan" :id 3}
             {:db/id 1 :name "Petr" :id 1}
             {:db/id 2 :name "Oleg" :id 2}])
        numeric (vev.q-text-with-sources
                  left.db
                  "[:find ?e ?id1 ?id2 :in $1 $2 [?e ...] :where [$1 ?e :id ?id1] [$2 ?e :id ?id2]]"
                  ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))])
                  ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        lookup-refs (vev.q-text-with-sources
                      left.db
                      "[:find ?e ?id1 ?id2 :in $1 $2 [?e ...] :where [$1 ?e :id ?id1] [$2 ?e :id ?id2]]"
                      ([]vev.Query-Input [(vev.query-input-collection-lookup-refs ([]string [":name" ":name" ":name"]) ([]vev.Value [(vev.value-string "Ivan") (vev.value-string "Petr") (vev.value-string "Oleg")]))])
                      ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        map-sources (vev.q-text-with-sources
                      left.db
                      "{:find [?e ?id1 ?id2] :in [$1 $2 [?e ...]] :where [[$1 ?e :id ?id1] [$2 ?e :id ?id2]]}"
                      ([]vev.Query-Input [(vev.query-input-collection ([]vev.Value [(vev.value-int 1) (vev.value-int 2) (vev.value-int 3)]))])
                      ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))
        pulled (vev.q-text-with-sources
                 left.db
                 "[:find ?e (pull $2 ?e [:name]) :in $1 $2 :where [$1 ?e :id 1]]"
                 ([]vev.Query-Input [])
                 ([]vev.DB-Source [(vev.db-source "$1" left.db) (vev.db-source "$2" right.db)]))]
    (t.is (= (count numeric.rows) 3))
    (t.is (= numeric.rows[0].values[0].int-value 1))
    (t.is (= numeric.rows[0].values[1].int-value 1))
    (t.is (= numeric.rows[0].values[2].int-value 1))
    (t.is (= (count lookup-refs.rows) 3))
    (t.is (= lookup-refs.rows[0].values[0].entity 1))
    (t.is (= lookup-refs.rows[1].values[0].entity 2))
    (t.is (= lookup-refs.rows[2].values[0].entity 3))
    (t.is (= (count map-sources.rows) 3))
    (t.is (= map-sources.rows[0].values[0].int-value 1))
    (t.is (= map-sources.rows[0].values[1].int-value 1))
    (t.is (= map-sources.rows[0].values[2].int-value 1))
    (t.is (= map-sources.rows[2].values[0].int-value 3))
    (t.is (= map-sources.rows[2].values[1].int-value 3))
    (t.is (= map-sources.rows[2].values[2].int-value 3))
    (t.is (= (count pulled.rows) 1))
    (t.is (= pulled.rows[0].pulls[0].attrs[0].v.text "Petr"))))

(t.deftest datascript-parser-query-text-relation-source-inputs
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "dragon_killer_94")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":aka") (vev.value-string "-=autobot=-")]))]))
        long-rows (vev.value-vector
                    ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan") (vev.value-int 945) (vev.value-keyword ":db/add")]))
                                   (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 39) (vev.value-int 999) (vev.value-keyword ":db/retract")]))]))
        result (vev.q-text-with-inputs
                 conn.db
                 "[:find ?n ?a :in $rows :where [$rows ?e :aka \"dragon_killer_94\"] [$rows ?e :name ?n] [$rows ?e :age ?a]]"
                 ([]vev.Query-Input [(vev.query-input-scalar rows)]))
        long (vev.q-text-with-inputs
               conn.db
               "[:find ?e ?a ?v ?t :in $rows :where [$rows ?e ?a ?v ?t :db/retract]]"
               ([]vev.Query-Input [(vev.query-input-scalar long-rows)]))]
    (t.is (= (count result.rows) 1))
    (t.is (= result.rows[0].values[0].text "Ivan"))
    (t.is (= result.rows[0].values[1].int-value 19))
    (t.is (= (count long.rows) 1))
    (t.is (= long.rows[0].values[0].int-value 1))
    (t.is (= long.rows[0].values[1].text ":age"))
    (t.is (= long.rows[0].values[2].int-value 39))
    (t.is (= long.rows[0].values[3].int-value 999))))

(t.deftest datascript-query-primary-collection-db-subset
  (defer (free_all context.allocator))
  (let [rows (vev.value-vector
               ([]vev.Value [(vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":name") (vev.value-string "Ivan")]))
                              (vev.value-vector ([]vev.Value [(vev.value-int 1) (vev.value-keyword ":age") (vev.value-int 19)]))
