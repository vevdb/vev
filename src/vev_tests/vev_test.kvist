    (t.is (= result.rows[1].values[0].entity 2))
    (t.is (= result.rows[1].pulls[0].attrs[0].v.text "Ivan"))
    (t.is (= result.rows[1].values[1].int-value 14))
    (t.is (= result.rows[1].values[2].int-value 16))
    (t.is (= result.rows[2].values[0].entity 3))
    (t.is (= result.rows[2].pulls[0].attrs[0].v.text "Oleg"))
    (t.is (= result.rows[2].values[1].int-value 1))
    (t.is (= result.rows[2].values[2].int-value 1))))

