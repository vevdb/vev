            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 1 :name "Ivan"]
             [:db/add 2 :name "Oleg"]])
        converges (vev.transact (addr conn) [{:db/id "x" :age 35}
                                             {:db/id "x" :name "Ivan" :age 36}])
        conflict (vev.transact (addr conn) [{:db/id "y" :name "Ivan" :age 35}
                                            {:db/id "y" :name "Oleg" :age 36}])
        [age age-ok] (vev.q-scalar converges.db-after
                       [:find ?age .
                        :where
                        [1 :age ?age]])]
    (t.is converges.ok)
    (t.is (= converges.tempids[0].e 1))
    (t.is age-ok)
    (t.is (= age.int-value 36))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "conflicting upsert"))))

(t.deftest datascript-upsert-vector-ordering-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 1 :name "Ivan"]
             [:db/add 2 :name "Oleg"]])
        unique-first (vev.transact-tx-data
                       (addr conn)
                       ([]vev.Tx-Data
                         [(vev.add-tempid "x" ":name" (vev.value-string "Ivan"))
                          (vev.add-tempid "x" ":age" (vev.value-int 12))]))
        unique-last (vev.transact-tx-data
                      (addr conn)
                      ([]vev.Tx-Data
                        [(vev.add-tempid "y" ":age" (vev.value-int 13))
                         (vev.add-tempid "y" ":name" (vev.value-string "Ivan"))]))
        conflict (vev.transact-tx-data
                   (addr conn)
                   ([]vev.Tx-Data
                     [(vev.add-tempid "z" ":name" (vev.value-string "Ivan"))
                      (vev.add-tempid "z" ":age" (vev.value-int 35))
                      (vev.add-tempid "z" ":name" (vev.value-string "Oleg"))
                      (vev.add-tempid "z" ":age" (vev.value-int 36))]))
        [age age-ok] (vev.q-scalar conn.db
                         [:find ?age .
                          :where
                          [1 :age ?age]])]
    (t.is unique-first.ok)
    (t.is (= unique-first.tempids[0].e 1))
    (t.is unique-last.ok)
    (t.is (= unique-last.tempids[0].e 1))
    (t.is age-ok)
    (t.is (= age.int-value 13))
    (t.is (not conflict.ok))
    (t.is (= conflict.error "conflicting upsert"))))

