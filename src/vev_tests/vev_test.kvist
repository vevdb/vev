                [?e :age ?age]])]
    (t.is (= (count keys) 3))
    (t.is (= keys[0].items[0].kind .Keyword))
    (t.is (= keys[0].items[0].key "n"))
    (t.is (= keys[0].items[0].value.text "Petr"))
    (t.is (= keys[0].items[1].key "a"))
    (t.is (= keys[0].items[1].value.int-value 44))
    (t.is (= keys[2].items[0].value.text "Sergey"))
    (t.is (= (count strs) 3))
    (t.is (= strs[1].items[0].kind .String))
    (t.is (= strs[1].items[0].key "n"))
    (t.is (= strs[1].items[0].value.text "Ivan"))
    (t.is (= (count syms) 3))
    (t.is (= syms[2].items[0].kind .Symbol))
    (t.is (= syms[2].items[0].key "n"))
    (t.is (= syms[2].items[0].value.text "Sergey"))))

