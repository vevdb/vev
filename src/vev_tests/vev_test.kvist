(t.deftest datascript-db-diff-subset
  (defer (free_all context.allocator))
  (let [left-conn (vev.create-conn)
        _ (vev.transact (addr left-conn) [
             {:db/id 1 :a 1 :b 2 :c 4}
             {:db/id 2 :a 1}])
        right-conn (vev.create-conn)
        _ (vev.transact (addr right-conn) [{:db/id 1 :b 3 :d 5}])
        _ (vev.transact (addr right-conn) [{:db/id 1 :a 1}])
        diff (vev.db-diff left-conn.db right-conn.db)]
    (t.is (= (count diff.only-left) 3))
    (t.is (= diff.only-left[0].e 1))
    (t.is (= diff.only-left[0].a ":b"))
    (t.is (= diff.only-left[0].v.int-value 2))
    (t.is (= diff.only-left[1].a ":c"))
    (t.is (= diff.only-left[1].v.int-value 4))
    (t.is (= diff.only-left[2].e 2))
    (t.is (= diff.only-left[2].a ":a"))
    (t.is (= diff.only-left[2].v.int-value 1))
    (t.is (= (count diff.only-right) 2))
    (t.is (= diff.only-right[0].a ":b"))
    (t.is (= diff.only-right[0].v.int-value 3))
    (t.is (= diff.only-right[1].a ":d"))
    (t.is (= diff.only-right[1].v.int-value 5))
    (t.is (= (count diff.both) 1))
    (t.is (= diff.both[0].e 1))
    (t.is (= diff.both[0].a ":a"))
    (t.is (= diff.both[0].v.int-value 1))))

(t.deftest datascript-issues-regressions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact (addr conn) [{:attr "A"} {:attr "B"}])
        vector-result (vev.q conn.db
                        [:find ?a ?b
                         :where
                         [_ :attr ?a]
                         [(vector ?a) ?b]])
        left-conn (vev.create-conn)
        _ (vev.transact (addr left-conn) [[:db/add 1 :attr :aa]])
        right-conn (vev.create-conn)
        _ (vev.transact (addr right-conn) [[:db/add 1 :attr "aa"]])
        diff (vev.db-diff left-conn.db right-conn.db)]
    (t.is (= (count vector-result.rows) 2))
    (t.is (= vector-result.rows[0].values[0].text "A"))
    (t.is (= vector-result.rows[0].values[1].kind .Vector))
    (t.is (= vector-result.rows[0].values[1].items[0].text "A"))
    (t.is (= vector-result.rows[1].values[0].text "B"))
    (t.is (= vector-result.rows[1].values[1].kind .Vector))
    (t.is (= vector-result.rows[1].values[1].items[0].text "B"))
    (t.is (= (count diff.only-left) 1))
    (t.is (= diff.only-left[0].a ":attr"))
    (t.is (= diff.only-left[0].v.kind .Keyword))
    (t.is (= diff.only-left[0].v.text ":aa"))
    (t.is (= (count diff.only-right) 1))
    (t.is (= diff.only-right[0].a ":attr"))
    (t.is (= diff.only-right[0].v.kind .String))
    (t.is (= diff.only-right[0].v.text "aa"))
    (t.is (= (count diff.both) 0))))

(t.deftest datascript-filter-db-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 10 :db/ident :aka :db/cardinality :db.cardinality/many}
             {:db/id 1 :name "Petr" :email "petya@spb.ru" :aka ["I" "Great"] :password "<SECRET>"}
             {:db/id 2 :name "Ivan" :aka ["Terrible" "IV"] :password "<PROTECTED>"}
             {:db/id 3 :name "Nikolai" :aka ["II"] :password "<UNKNOWN>"}])
        db conn.db
        no-passwords (vev.filter-db db keep-not-password)
        no-ivan (vev.filter-db db keep-not-entity-2)
        long-akas (vev.filter-db db keep-long-akas)
        no-ivan-no-passwords (vev.filter-db no-ivan keep-not-password)
        no-ivan-long-akas (vev.filter-db no-ivan keep-long-akas)
        long-akas-no-ivan (vev.filter-db long-akas keep-not-entity-2)
        passwords (vev.q-collection db [:find [?v ...] :where [_ :password ?v]])
        passwords-filtered (vev.q-collection no-passwords [:find [?v ...] :where [_ :password ?v]])
        passwords-no-ivan (vev.q-collection no-ivan [:find [?v ...] :where [_ :password ?v]])
        passwords-chained (vev.q-collection no-ivan-no-passwords [:find [?v ...] :where [_ :password ?v]])
        akas (vev.q-collection db [:find [?v ...] :where [_ :aka ?v]])
        akas-no-passwords (vev.q-collection no-passwords [:find [?v ...] :where [_ :aka ?v]])
        akas-no-ivan (vev.q-collection no-ivan [:find [?v ...] :where [_ :aka ?v]])
        akas-long (vev.q-collection long-akas [:find [?v ...] :where [_ :aka ?v]])
        akas-no-ivan-long (vev.q-collection no-ivan-long-akas [:find [?v ...] :where [_ :aka ?v]])
        akas-long-no-ivan (vev.q-collection long-akas-no-ivan [:find [?v ...] :where [_ :aka ?v]])
        petr-filtered (vev.db-entity no-passwords 1)
        ivan-filtered (vev.db-entity long-akas 2)
        ivan-akas (vev.entity-values ivan-filtered ":aka")]
    (defer (delete ivan-akas))
    (t.is (= (count passwords) 3))
    (t.is (= (count passwords-filtered) 0))
    (t.is (= (count passwords-no-ivan) 2))
    (t.is (= passwords-no-ivan[0].text "<SECRET>"))
    (t.is (= passwords-no-ivan[1].text "<UNKNOWN>"))
    (t.is (= (count passwords-chained) 0))
    (t.is (= (count akas) 5))
    (t.is (= (count akas-no-passwords) 5))
    (t.is (= (count akas-no-ivan) 3))
    (t.is (= (count akas-long) 3))
    (t.is (= akas-long[0].text "Great"))
    (t.is (= akas-long[1].text "Terrible"))
    (t.is (= akas-long[2].text "II"))
    (t.is (= (count akas-no-ivan-long) 2))
    (t.is (= akas-no-ivan-long[0].text "Great"))
    (t.is (= akas-no-ivan-long[1].text "II"))
    (t.is (= (count akas-long-no-ivan) 2))
    (t.is (= akas-long-no-ivan[0].text "Great"))
    (t.is (= akas-long-no-ivan[1].text "II"))
    (t.is (not (vev.entity-contains? petr-filtered ":password")))
    (t.is (= (count ivan-akas) 1))
    (t.is (= ivan-akas[0].text "Terrible"))))

(t.deftest datascript-filter-db-double-filtering-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
