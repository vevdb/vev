             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :age]
             [:db/add 101 :db/valueType :db.type/long]
             [:db/add 101 :db/cardinality :db.cardinality/one]
             [:db/add 2 :name "Petr"]
             [:db/add 3 :name "Dima"]
             [:db/add 2 :ref 3]])
        report (vev.transact
                 (addr conn)
                 [{:ref 3 :age 36}])
        [age age-ok] (vev.q-scalar report.db-after
                       [:find ?age .
                        :where
                        [2 :age ?age]])]
    (t.is report.ok)
    (t.is (= (count report.tempids) 2))
    (t.is (= report.tempids[0].e 2))
    (t.is age-ok)
    (t.is (= age.int-value 36))))

