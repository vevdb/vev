(t.deftest transact-data-uses-datomic-shaped-ops
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :user/email "ada@example.com"]
                  [:db/add 1 :user/name "Ada"]
                  [:db/retract 1 :user/name "Ada"]])
        results (vev.q-strings report.db-after (vev.query-name-by-email "ada@example.com"))]
    (t.is (= (count report.tx-data) 3))
    (t.is (= report.tx-data[0].added true))
    (t.is (= report.tx-data[2].added false))
    (t.is (= (count results) 0))))

(t.deftest datascript-transact-skips-nil-items
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :attr 2]
                  nil
                  [:db/add 3 :attr 4]])
        result (vev.q report.db-after
                 [:find ?e ?v
                  :where
                  [?e :attr ?v]])]
    (t.is report.ok)
    (t.is (= (count report.tx-data) 2))
    (t.is (= (count result.rows) 2))
    (t.is (= result.rows[0].values[0].entity 1))
    (t.is (= result.rows[0].values[1].int-value 2))
    (t.is (= result.rows[1].values[0].entity 3))
    (t.is (= result.rows[1].values[1].int-value 4))))

(t.deftest datascript-transaction-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ivan" :age 31}
             [:db/add 1 :name "Petr"]])
        missing (vev.transact-fn-string (addr conn) birthday-by-name "Bob")
        report (vev.transact-fn-string (addr conn) birthday-by-name "Petr")
        petr (vev.db-entity report.db-after 1)
        created (vev.transact-fn (addr conn) create-oleg)
        new-e created.tempids[0].e
        [created-current-tx created-current-tx-ok] (tempid-e (slice created.tempids 0) ":db/current-tx")
        oleg (vev.db-entity created.db-after new-e)
        map-created (vev.transact-fn (addr conn) create-entity-without-db-id)
        [foo foo-ok] (vev.q-scalar map-created.db-after
                       [:find ?foo .
                        :where
                        [?e :foo ?foo]])]
    (t.is (not missing.ok))
    (t.is (= missing.error "No entity with name"))
    (t.is report.ok)
    (t.is (= (vev.entity-get petr ":age").int-value 32))
    (t.is (vev.entity-get petr ":had-birthday").bool-value)
    (t.is created.ok)
    (t.is (= (count created.tempids) 2))
    (t.is (= created.tempids[0].tempid "new-person"))
    (t.is created-current-tx-ok)
    (t.is (= created-current-tx created.tx))
    (t.is (= (vev.entity-get oleg ":name").text "Oleg"))
    (t.is map-created.ok)
    (t.is foo-ok)
    (t.is (= foo.text "bar"))))

(t.deftest datascript-ident-transaction-functions-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        registry ([]vev.Tx-Fn-String [(vev.tx-fn-string ":inc-age" birthday-by-name)
                                       (vev.tx-fn-values ":inc-age-by" birthday-by-name-and-delta)
                                       (vev.tx-fn-string ":fail-tx" fail-tx-fn-string)
                                       (vev.tx-fn-values ":create-vera" create-vera-value-fn)
                                       (vev.tx-fn-values ":create-map" create-entity-without-db-id-values)])
        listener-reports (make [dynamic]vev.Tx-Report) :defer
        _ (vev.transact
            (addr conn)
            [{:db/id 10 :db/ident :inc-age}
             {:db/id 12 :db/ident :inc-age-by}
             {:db/id 15 :db/ident :fail-tx}
             {:db/id 13 :db/ident :create-vera}
             {:db/id 14 :db/ident :create-map}
             {:db/id 11 :db/ident :Petr}])
        duplicate-registry ([]vev.Tx-Fn-String [(vev.tx-fn-string ":inc-age" birthday-by-name)
                                                (vev.tx-fn-values ":inc-age" birthday-by-name-and-delta)])
        before-duplicate-datom-count (count conn.db.datoms)
        duplicate-report (vev.transact-tx-data-with-string-fns
                           (addr conn)
                           (vev.tx-data [:inc-age "Petr"])
                           duplicate-registry)
        unknown (vev.transact-tx-data-with-string-fns
                  (addr conn)
                  (vev.tx-data [:unknown-fn])
                  registry)
        non-fn (vev.transact-tx-data-with-string-fns
                 (addr conn)
                 (vev.tx-data [:Petr])
                 registry)
        missing (vev.transact-tx-data-with-string-fns
                  (addr conn)
                  (vev.tx-data [:inc-age "Bob"])
                  registry)
        report (vev.transact-tx-data-with-string-fns
                 (addr conn)
                 (vev.tx-data
                   [:db/add 1 :name "Petr"]
                   [:db/add 1 :age 31]
                   [:inc-age "Petr"]
                   [:db/add 1 :label "after-call"])
                 registry)
        text-missing (vev.transact-text-with-string-fns
                       (addr conn)
                       "[[:db.fn/call :inc-age \"Bob\"]]"
                       registry)
        text-call (vev.transact-text-with-string-fns
                    (addr conn)
                    "[[:db/add 2 :name \"Ada\"] [:db/add 2 :age 40] [:db.fn/call :inc-age \"Ada\"] [:db/add 2 :label \"after-text-call\"]]"
                    registry)
        text-value-call (vev.transact-text-with-string-fns
                          (addr conn)
                          "[[:db/add 4 :name \"Lin\"] [:db/add 4 :age 20] [:db.fn/call :inc-age-by \"Lin\" 5] [:db/add 4 :label \"after-value-call\"]]"
                          registry)
        prepared (vev.prepare-tx-text
                   "[[:db/add 3 :name \"Grace\"] [:db/add 3 :age 50] [:inc-age \"Grace\"] [:db/add 3 :label \"after-prepared-call\"]]")
        prepared-call (vev.transact-prepared-with-string-fns (addr conn) prepared registry)
        prepared-values (vev.prepare-tx-text
                          "[[:db/add 5 :name \"Mina\"] [:db/add 5 :age 30] [:inc-age-by \"Mina\" 7] [:create-vera] [:create-map]]")
        prepared-value-call (vev.transact-prepared-with-string-fns (addr conn) prepared-values registry)
        literal-value-call (vev.transact-tx-data-with-string-fns
                             (addr conn)
                             (vev.tx-data
                               [:db/add 6 :name "Nia"]
                               [:db/add 6 :age 60]
                               [:inc-age-by "Nia" 4])
                             registry)
        no-registry (vev.transact-text-with-string-fns
                      (addr conn)
                      "[[:inc-age \"Petr\"]]"
                      ([]vev.Tx-Fn-String []))
        unknown-text (vev.transact-text-with-string-fns
                       (addr conn)
                       "[[:unknown-fn \"Petr\"]]"
                       registry)
        bad-call-shape (vev.transact-text-with-string-fns
                         (addr conn)
                         "[[:db.fn/call :inc-age 42]]"
                         registry)
        _ (vev.listen! (addr conn) "tx-fn-failures" (addr listener-reports))
        before-failure-next-tx conn.next-tx
        before-failure-datom-count (count conn.db.datoms)
        literal-fail (vev.transact-tx-data-with-string-fns
                       (addr conn)
                       (vev.tx-data
                         [:db/add 7 :name "RollbackLiteral"]
                         [:fail-tx "literal failure"]
                         [:db/add 8 :name "AfterLiteralFailure"])
                       registry)
        text-fail (vev.transact-text-with-string-fns
                    (addr conn)
                    "[[:db/add 9 :name \"RollbackText\"] [:db.fn/call :fail-tx \"text failure\"] [:db/add 10 :name \"AfterTextFailure\"]]"
                    registry)
        prepared-fail (vev.prepare-tx-text
                        "[[:db/add 11 :name \"RollbackPrepared\"] [:fail-tx \"prepared failure\"] [:db/add 12 :name \"AfterPreparedFailure\"]]")
        prepared-fail-report (vev.transact-prepared-with-string-fns (addr conn) prepared-fail registry)
        rollback-query (vev.q conn.db
                         [:find ?e ?name
                          :where
                          [?e :name ?name]
                          [(= ?name "RollbackLiteral")]])
        text-rollback-query (vev.q conn.db
                              [:find ?e ?name
                               :where
                               [?e :name ?name]
                               [(= ?name "RollbackText")]])
        prepared-rollback-query (vev.q conn.db
                                  [:find ?e ?name
                                   :where
                                   [?e :name ?name]
                                   [(= ?name "RollbackPrepared")]])
        pure-text-fn (vev.with-text-with-string-fns
                       report.db-after
                       "[[:db/add 20 :name \"Ruth\"] [:db/add 20 :age 10] [:inc-age \"Ruth\"]]"
                       registry)
        pure-prepared-fn (vev.prepare-tx-text
                           "[[:db/add 21 :name \"Sofia\"] [:db/add 21 :age 11] [:inc-age-by \"Sofia\" 3]]")
        pure-prepared-report (vev.with-prepared-with-string-fns report.db-after pure-prepared-fn registry)
        pure-db-text (vev.db-with-text-with-string-fns
                       report.db-after
                       "[[:db/add 22 :name \"Tara\"] [:db/add 22 :age 12] [:inc-age \"Tara\"]]"
                       registry)
        pure-db-prepared (vev.db-with-prepared-with-string-fns
                           report.db-after
                           (vev.prepare-tx-text "[[:db/add 23 :name \"Uma\"] [:db/add 23 :age 13] [:inc-age-by \"Uma\" 2]]")
                           registry)
        base-ruth (vev.q report.db-after
                    [:find ?age
                     :where
                     [?e :name "Ruth"]
                     [?e :age ?age]])
        ruth (vev.db-entity pure-text-fn.db-after 20)
        sofia (vev.db-entity pure-prepared-report.db-after 21)
        tara (vev.db-entity pure-db-text 22)
        uma (vev.db-entity pure-db-prepared 23)
        petr (vev.db-entity report.db-after 1)
        ada (vev.db-entity text-call.db-after 2)
        lin (vev.db-entity text-value-call.db-after 4)
        grace (vev.db-entity prepared-call.db-after 3)
        mina (vev.db-entity prepared-value-call.db-after 5)
        nia (vev.db-entity literal-value-call.db-after 6)
        [vera-e vera-ok] (tempid-e (slice prepared-value-call.tempids 0) "vera")
        vera (vev.db-entity prepared-value-call.db-after vera-e)
        [foo foo-ok] (vev.q-scalar prepared-value-call.db-after
                       [:find ?foo .
                        :where
                        [?e :foo ?foo]])]
    (t.is (not duplicate-report.ok))
    (t.is (= duplicate-report.error "duplicate transaction fn registration: :inc-age"))
    (t.is (= duplicate-report.tx 0))
    (t.is (= (count duplicate-report.db-after.datoms) before-duplicate-datom-count))
    (t.is (not unknown.ok))
    (t.is (= unknown.error "transaction fn not found"))
    (t.is (not non-fn.ok))
    (t.is (= non-fn.error "transaction fn not registered"))
    (t.is (not missing.ok))
    (t.is (= missing.error "No entity with name"))
    (t.is report.ok)
    (t.is (= (vev.entity-get petr ":age").int-value 32))
    (t.is (vev.entity-get petr ":had-birthday").bool-value)
    (t.is (= (vev.entity-get petr ":label").text "after-call"))
    (t.is (not text-missing.ok))
    (t.is (= text-missing.error "No entity with name"))
    (t.is text-call.ok)
    (t.is (= (vev.entity-get ada ":age").int-value 41))
    (t.is (vev.entity-get ada ":had-birthday").bool-value)
    (t.is (= (vev.entity-get ada ":label").text "after-text-call"))
    (t.is text-value-call.ok)
    (t.is (= (vev.entity-get lin ":age").int-value 25))
    (t.is (= (vev.entity-get lin ":birthday-delta").int-value 5))
    (t.is (= (vev.entity-get lin ":label").text "after-value-call"))
    (t.is prepared.ok)
    (t.is prepared-call.ok)
    (t.is (= (vev.entity-get grace ":age").int-value 51))
    (t.is (vev.entity-get grace ":had-birthday").bool-value)
    (t.is (= (vev.entity-get grace ":label").text "after-prepared-call"))
    (t.is prepared-values.ok)
    (t.is prepared-value-call.ok)
    (t.is (= (vev.entity-get mina ":age").int-value 37))
    (t.is (= (vev.entity-get mina ":birthday-delta").int-value 7))
    (t.is vera-ok)
    (t.is (= (vev.entity-get vera ":name").text "Vera"))
    (t.is foo-ok)
    (t.is (= foo.text "bar"))
    (t.is literal-value-call.ok)
    (t.is (= (vev.entity-get nia ":age").int-value 64))
    (t.is (= (vev.entity-get nia ":birthday-delta").int-value 4))
    (t.is (not no-registry.ok))
    (t.is (= no-registry.error "transaction fn not registered"))
    (t.is (not unknown-text.ok))
    (t.is (= unknown-text.error "transaction fn not found"))
    (t.is (not bad-call-shape.ok))
    (t.is (= bad-call-shape.error "transaction fn expects one string argument"))
    (t.is (not literal-fail.ok))
    (t.is (= literal-fail.error "literal failure"))
    (t.is (not text-fail.ok))
    (t.is (= text-fail.error "text failure"))
    (t.is prepared-fail.ok)
    (t.is (not prepared-fail-report.ok))
    (t.is (= prepared-fail-report.error "prepared failure"))
    (t.is (= conn.next-tx before-failure-next-tx))
    (t.is (= (count conn.db.datoms) before-failure-datom-count))
    (t.is (= (count listener-reports) 0))
    (t.is (= (count rollback-query.rows) 0))
    (t.is (= (count text-rollback-query.rows) 0))
    (t.is (= (count prepared-rollback-query.rows) 0))
    (t.is pure-text-fn.ok)
    (t.is pure-prepared-fn.ok)
    (t.is pure-prepared-report.ok)
    (t.is (= (count base-ruth.rows) 0))
    (t.is (= (vev.entity-get ruth ":age").int-value 11))
    (t.is (vev.entity-get ruth ":had-birthday").bool-value)
    (t.is (= (vev.entity-get sofia ":age").int-value 14))
    (t.is (= (vev.entity-get sofia ":birthday-delta").int-value 3))
    (t.is (= (vev.entity-get tara ":age").int-value 13))
    (t.is (vev.entity-get tara ":had-birthday").bool-value)
    (t.is (= (vev.entity-get uma ":age").int-value 15))
    (t.is (= (vev.entity-get uma ":birthday-delta").int-value 2))))

(t.deftest transact-data-supports-retract-without-value
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        report (vev.transact (addr conn) [[:db/retract 1 :user/name]])
        result (vev.q report.db-after
                   [:find ?age
                    :where
                    [1 :user/age ?age]])
        names (vev.q report.db-after
                  [:find ?name
                   :where
                   [1 :user/name ?name]])]
      (t.is report.ok)
      (t.is (= (count report.tx-data) 1))
      (t.is (= report.tx-data[0].a ":user/name"))
      (t.is (= report.tx-data[0].v.text "Ada"))
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].int-value 37))
      (t.is (= (count names.rows) 0))))

