(t.deftest datascript-query-aggregate-multiple-args-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        by-name (vev.q conn.db
                  [:find (count ?name)
                   :in [[?name ?age]]]
                  [["Ada" 37]
                   ["Ada" 41]
                   ["Ada" 41]
                   ["Grace" 37]])
        by-pair (vev.q conn.db
                  [:find (count ?name ?age)
                   :in [[?name ?age]]]
                  [["Ada" 37]
                   ["Ada" 41]
                   ["Ada" 41]
                   ["Grace" 37]])
        text-by-pair (vev.q-text-with-inputs
                       conn.db
                       "[:find (count ?name ?age) :in [[?name ?age]]]"
                       ([]vev.Query-Input
                         [(vev.query-input-relation
                            ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37)
                                           (vev.value-string "Ada") (vev.value-int 41)
                                           (vev.value-string "Ada") (vev.value-int 41)
                                           (vev.value-string "Grace") (vev.value-int 37)])
                            2)]))
        text-with-constant (vev.q-text-with-inputs
                             conn.db
                             "[:find (count ?name 1) :in [[?name ?age]]]"
                             ([]vev.Query-Input
                               [(vev.query-input-relation
                                  ([]vev.Value [(vev.value-string "Ada") (vev.value-int 37)
                                                 (vev.value-string "Ada") (vev.value-int 41)
                                                 (vev.value-string "Grace") (vev.value-int 37)])
                                  2)]))
        prepared (vev.prepare-query-text "[:find (count ?name ?age) :in [[?name ?age]]]")]
    (t.is (= by-name.rows[0].values[0].int-value 2))
    (t.is (= by-pair.rows[0].values[0].int-value 3))
    (t.is (= text-by-pair.rows[0].values[0].int-value 3))
    (t.is (= text-with-constant.rows[0].values[0].int-value 2))
    (t.is prepared.ok)))

