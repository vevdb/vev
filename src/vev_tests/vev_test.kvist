(t.deftest datalog-macro-preserves-where-order-validation
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [{:db/id 1 :name "Ada Lovelace"}])
        not-before-binding (vev.q conn.db
                             [:find ?e
                              :where
                              (not [?e :name "Ada Lovelace"])
                              [?e :name]])
        predicate-before-binding (vev.q conn.db
                                   [:find ?name
                                    :where
                                    [(= ?name "Ada Lovelace")]
                                    [?e :name ?name]])]
    (t.is (not not-before-binding.ok))
    (t.is (= not-before-binding.error "insufficient bindings for not: ?e"))
    (t.is (not predicate-before-binding.ok))
    (t.is (= predicate-before-binding.error "insufficient bindings for =: ?name"))))

