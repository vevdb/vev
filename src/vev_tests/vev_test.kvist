        _ (vev.transact
               (addr conn)
               [[:db/add 1 :name "Parent"]
                [:db/add 2 :name "Child"]
                [:db/add 1 :child (vev.value-entity 2)]])
        forward (vev.pull conn.db [:db/id [:child :default 1]] 2)
        reverse (vev.pull conn.db [:db/id [:_child :default 2]] 1)]
      (t.is (= (count forward.attrs) 2))
      (t.is (= forward.attrs[0].v.entity 2))
      (t.is (= forward.attrs[1].a ":child"))
      (t.is (= forward.attrs[1].v.int-value 1))
      (t.is (= (count reverse.attrs) 2))
      (t.is (= reverse.attrs[0].v.entity 1))
      (t.is (= reverse.attrs[1].a ":_child"))
      (t.is (= reverse.attrs[1].v.int-value 2))))

(t.deftest datascript-pull-xform-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :name]
                [:db/add 101 :db/ident :father]
                [:db/add 101 :db/valueType :db.type/ref]
                [:db/add 102 :db/ident :child]
                [:db/add 102 :db/valueType :db.type/ref]
                [:db/add 102 :db/cardinality :db.cardinality/many]
                {:db/id 1 :name "Petr" :child [2 3]}
                {:db/id 2 :name "David" :father 1}
                {:db/id 3 :name "Thomas" :father 1}])
        scalar (vev.pull conn.db [[:name :xform vector]
                                  [:missing :xform vector]
                                  [:unknown :default "[unknown]" :xform vector]]
                   1)
        forward-ref (vev.pull conn.db [{[:father :xform name] [:name]}] 2)
        reverse-ref (vev.pull conn.db [{[:_father :xform name] [:name]}] 1)
        text (vev.pull-text conn.db "[[:name :xform vector] {[:father :xform name] [:name]}]" 2)]
    (t.is (= scalar.attrs[0].v.kind .Vector))
    (t.is (= scalar.attrs[0].v.items[0].text "Petr"))
    (t.is (= scalar.attrs[1].v.kind .Vector))
    (t.is (= scalar.attrs[1].v.items[0].kind .Nil))
    (t.is (= scalar.attrs[2].v.text "[unknown]"))
    (t.is (= forward-ref.attrs[0].a ":father"))
    (t.is (= forward-ref.attrs[0].v.text "Petr"))
    (t.is (= (count forward-ref.attrs[0].attrs) 0))
    (t.is (= reverse-ref.attrs[0].a ":_father"))
    (t.is (= reverse-ref.attrs[0].v.text "David"))
    (t.is (= (count reverse-ref.attrs[0].attrs) 0))
    (t.is (= text.attrs[0].v.kind .Vector))
    (t.is (= text.attrs[0].v.items[0].text "David"))
    (t.is (= text.attrs[1].v.text "Petr"))))

