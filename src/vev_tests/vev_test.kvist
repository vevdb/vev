(t.deftest datalog-macro-supports-get-else
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        _ (vev.transact
               (addr conn)
               [[:db/add 3 :user/name "Alan"]])
        present (vev.q conn.db
                    [:find ?email
                     :where
                     [?e :user/name "Ada"]
                     [(get-else $ ?e :user/email "none") ?email]])
        missing (vev.q conn.db
                    [:find ?email
                     :where
                     [?e :user/name "Alan"]
                     [(get-else $ ?e :user/email "none") ?email]])]
      (t.is (= (count present.rows) 1))
      (t.is (= present.rows[0].values[0].text "ada@example.com"))
      (t.is (= (count missing.rows) 1))
      (t.is (= missing.rows[0].values[0].text "none"))))

(t.deftest datalog-macro-supports-get-some
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.seed-people (addr conn))
        _ (vev.transact
               (addr conn)
               [[:db/add 3 :user/name "Alan"]])
        result (vev.q conn.db
                   [:find ?attr ?value
                    :where
                    [?e :user/name "Ada"]
                    [(get-some $ ?e :user/missing :user/email :user/age) [?attr ?value]]])
        missing (vev.q conn.db
                    [:find ?attr ?value
                     :where
                     [?e :user/name "Alan"]
                     [(get-some $ ?e :user/email :user/age) [?attr ?value]]])]
      (t.is (= (count result.rows) 1))
      (t.is (= result.rows[0].values[0].text ":user/email"))
      (t.is (= result.rows[0].values[1].text "ada@example.com"))
      (t.is (= (count missing.rows) 0))))

(t.deftest datalog-macro-supports-lookup-ref-entity-terms
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
               (addr conn)
               [[:db/add 100 :db/ident :user/email]
                [:db/add 100 :db/valueType :db.type/string]
                [:db/add 100 :db/unique :db.unique/identity]])
        _ (vev.seed-people (addr conn))
        name (vev.q conn.db
                 [:find ?name
                  :where
                  [[:user/email "ada@example.com"] :user/name ?name]])
        email (vev.q conn.db
                  [:find ?email
                   :where
                   [(get-else $ [:user/email "ada@example.com"] :user/email "none") ?email]])
        some (vev.q conn.db
                 [:find ?attr ?value
                  :where
                  [(get-some $ [:user/email "ada@example.com"] :user/missing :user/name) [?attr ?value]]])]
      (t.is (= (count name.rows) 1))
      (t.is (= name.rows[0].values[0].text "Ada"))
      (t.is (= (count email.rows) 1))
      (t.is (= email.rows[0].values[0].text "ada@example.com"))
      (t.is (= (count some.rows) 1))
      (t.is (= some.rows[0].values[0].text ":user/name"))
      (t.is (= some.rows[0].values[1].text "Ada"))))

(t.deftest datascript-lookup-ref-query-inline-values-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/valueType :db.type/string]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :friend]
             [:db/add 101 :db/valueType :db.type/ref]])
        report (vev.transact
                 (addr conn)
                 [[:db/add 1 :name "Ivan"]
                  [:db/add 1 :age 35]
                  [:db/add 1 :friend (vev.value-entity 2)]
                  [:db/add 2 :name "Petr"]])
        friend (vev.q-collection report.db-after
                  [:find [?v ...]
                   :where
                   [[:name "Ivan"] :friend ?v]])
        entity (vev.q-collection report.db-after
                 [:find [?e ...]
                  :where
                  [?e :friend [:name "Petr"]]])
        missing-entity-text (vev.q-text report.db-after
                              "[:find ?v :where [[:name :missing] :friend ?v]]")
        missing-value-text (vev.q-text report.db-after
                             "[:find ?e :where [?e :friend [:name :missing]]]")
        non-unique-entity-text (vev.q-text report.db-after
                                 "[:find ?v :where [[:age 35] :friend ?v]]")
        non-unique-value-text (vev.q-text report.db-after
                                "[:find ?e :where [?e :friend [:age 35]]]")]
    (t.is (= (count friend) 1))
    (t.is (= friend[0].entity 2))
    (t.is (= (count entity) 1))
    (t.is (= entity[0].entity 1))
    (t.is (not missing-entity-text.ok))
    (t.is (= missing-entity-text.error "lookup ref not found"))
    (t.is (not missing-value-text.ok))
    (t.is (= missing-value-text.error "lookup ref not found"))
    (t.is (not non-unique-entity-text.ok))
    (t.is (= non-unique-entity-text.error "lookup ref attribute must be unique"))
    (t.is (not non-unique-value-text.ok))
    (t.is (= non-unique-value-text.error "lookup ref attribute must be unique"))))

(t.deftest datascript-lookup-ref-query-input-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :email]
             [:db/add 101 :db/unique :db.unique/identity]
             [:db/add 102 :db/ident :friend]
             [:db/add 102 :db/valueType :db.type/ref]])
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :name "Ivan"]
             [:db/add 1 :email "ivan@example.com"]
             [:db/add 1 :age 15]
             [:db/add 1 :friend 2]
             [:db/add 2 :name "Petr"]
             [:db/add 2 :email "petr@example.com"]
             [:db/add 2 :age 22]
             [:db/add 2 :friend 3]
             [:db/add 3 :name :person/ivan]
             [:db/add 3 :age 35]])
        age (vev.q-collection conn.db
              [:find [?age ...]
               :in ?e
               :where
               [?e :age ?age]]
              [:name "Ivan"])
        ages (vev.q-collection conn.db
               [:find [?age ...]
                :in [?e ...]
                :where
                [?e :age ?age]]
               [[:name "Ivan"] [:name "Petr"]])
        mixed-attr-ages (vev.q-collection conn.db
                          [:find [?age ...]
                           :in [?e ...]
                           :where
                           [?e :age ?age]]
                          [[:name "Ivan"] [:email "petr@example.com"]])
        keyword-age (vev.q-collection conn.db
                      [:find [?age ...]
                       :in ?e
                       :where
                       [?e :age ?age]]
                      [:name :person/ivan])
        keyword-values (vev.q-collection conn.db
                         [:find [?value ...]
                          :in [?value ...]
                          :where
                          [(ground true) ?ok]]
                         [:person/ivan :person/petr])
        pair (vev.q conn.db
               [:find ?e ?v
                :in ?e ?v
                :where
                [?e :friend ?v]]
               [:name "Ivan"]
               [:name "Petr"])
        pair-text (vev.q-text-with-inputs
                    conn.db
                    "[:find ?e ?v :in ?e ?v :where [?e :friend ?v]]"
                    ([]vev.Query-Input [(vev.query-input-lookup-ref ":name" (vev.value-string "Ivan"))
                                         (vev.query-input-lookup-ref ":name" (vev.value-string "Petr"))]))
        pairs (vev.q conn.db
                [:find ?e ?v
                 :in [?e ...] [?v ...]
                 :where
                 [?e :friend ?v]]
                [[:name "Ivan"] [:name "Petr"] [:name :person/ivan]]
                [[:name "Ivan"] [:name "Petr"] [:name :person/ivan]])
        pairs-text (vev.q-text-with-inputs
                     conn.db
                     "[:find ?e ?v :in [?e ...] [?v ...] :where [?e :friend ?v]]"
                     ([]vev.Query-Input [(vev.query-input-collection-lookup-refs
                                            ([]string [":name" ":name" ":name"])
                                            ([]vev.Value [(vev.value-string "Ivan")
                                                          (vev.value-string "Petr")
                                                          (vev.value-keyword ":person/ivan")]))
                                          (vev.query-input-collection-lookup-refs
                                            ([]string [":name" ":name" ":name"])
                                            ([]vev.Value [(vev.value-string "Ivan")
                                                          (vev.value-string "Petr")
                                                          (vev.value-keyword ":person/ivan")]))]))
        missing (vev.q-collection conn.db
                  [:find [?age ...]
                   :in ?e
                   :where
                   [?e :age ?age]]
                  [:name "Sergey"])
        mixed-entity-inputs (vev.q-collection conn.db
                              [:find [?e ...]
                               :in [?e ...]
                               :where
                               [?e :friend 3]]
                              [1 2 3 "A"])]
    (t.is (= (count age) 1))
    (t.is (= age[0].int-value 15))
    (t.is (= (count ages) 2))
    (t.is (= ages[0].int-value 15))
    (t.is (= ages[1].int-value 22))
    (t.is (= (count mixed-attr-ages) 2))
    (t.is (= mixed-attr-ages[0].int-value 15))
    (t.is (= mixed-attr-ages[1].int-value 22))
    (t.is (= (count keyword-age) 1))
    (t.is (= keyword-age[0].int-value 35))
    (t.is (= (count keyword-values) 2))
    (t.is (= keyword-values[0].text ":person/ivan"))
    (t.is (= keyword-values[1].text ":person/petr"))
    (t.is (= (count pair.rows) 1))
    (t.is (= pair.rows[0].values[0].kind .Vector))
    (t.is (= pair.rows[0].values[0].items[0].text ":name"))
    (t.is (= pair.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= pair.rows[0].values[1].kind .Vector))
    (t.is (= pair.rows[0].values[1].items[0].text ":name"))
    (t.is (= pair.rows[0].values[1].items[1].text "Petr"))
    (t.is pair-text.ok)
    (t.is (= (count pair-text.rows) 1))
    (t.is (= pair-text.rows[0].values[0].kind .Vector))
    (t.is (= pair-text.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= pair-text.rows[0].values[1].kind .Vector))
    (t.is (= pair-text.rows[0].values[1].items[1].text "Petr"))
    (t.is (= (count pairs.rows) 2))
    (t.is (= pairs.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= pairs.rows[0].values[1].items[1].text "Petr"))
    (t.is (= pairs.rows[1].values[0].items[1].text "Petr"))
    (t.is (= pairs.rows[1].values[1].items[1].text ":person/ivan"))
    (t.is pairs-text.ok)
    (t.is (= (count pairs-text.rows) 2))
    (t.is (= pairs-text.rows[0].values[0].items[1].text "Ivan"))
    (t.is (= pairs-text.rows[0].values[1].items[1].text "Petr"))
    (t.is (= pairs-text.rows[1].values[0].items[1].text "Petr"))
    (t.is (= pairs-text.rows[1].values[1].items[1].text ":person/ivan"))
    (t.is (= (count missing) 0))
    (t.is (= (count mixed-entity-inputs) 1))
    (t.is (= mixed-entity-inputs[0].int-value 2))))

(t.deftest datascript-lookup-ref-datoms-index-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 100 :db/ident :name]
             [:db/add 100 :db/unique :db.unique/identity]
             [:db/add 101 :db/ident :friends]
             [:db/add 101 :db/valueType :db.type/ref]
             [:db/add 101 :db/cardinality :db.cardinality/many]])
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :name "Ivan"]
             [:db/add 1 :friends (vev.value-entity 2)]
             [:db/add 1 :friends (vev.value-entity 3)]
             [:db/add 2 :name "Petr"]
             [:db/add 2 :friends (vev.value-entity 3)]
             [:db/add 3 :name "Oleg"]])
        eavt (vev.datoms conn.db :eavt [:name "Ivan"])
        eavt-friend (vev.datoms conn.db :eavt [:name "Ivan"] :friends [:name "Petr"])
        aevt (vev.datoms conn.db :aevt :friends [:name "Ivan"])
        aevt-friend (vev.datoms conn.db :aevt :friends [:name "Ivan"] [:name "Petr"])
        avet (vev.datoms conn.db :avet :friends [:name "Oleg"])
        avet-bounded (vev.datoms conn.db :avet :friends [:name "Oleg"] [:name "Ivan"])
        seek-lookup (vev.seek-datoms conn.db :eavt [:name "Ivan"] :friends [:name "Oleg"])
        seek-resolved (vev.seek-datoms conn.db :eavt 1 :friends 3)
        seek-aevt-lookup (vev.seek-datoms conn.db :aevt :friends [:name "Petr"])
        seek-aevt-resolved (vev.seek-datoms conn.db :aevt :friends 2)
        seek-avet-lookup (vev.seek-datoms conn.db :avet :friends [:name "Oleg"])
        seek-avet-resolved (vev.seek-datoms conn.db :avet :friends 3)
        range-exact (vev.index-range conn.db :friends [:name "Oleg"] [:name "Oleg"])
        range-bounded (vev.index-range conn.db :friends [:name "Petr"] [:name "Oleg"])]
    (t.is (= (count eavt) 3))
    (t.is (= eavt[0].e 1))
    (t.is (= eavt[0].a ":friends"))
    (t.is (= eavt[1].a ":friends"))
    (t.is (= eavt[2].a ":name"))
    (t.is (= (count eavt-friend) 1))
    (t.is (= eavt-friend[0].e 1))
    (t.is (= eavt-friend[0].v.entity 2))
    (t.is (= (count aevt) 2))
    (t.is (= aevt[0].v.entity 2))
    (t.is (= aevt[1].v.entity 3))
    (t.is (= (count aevt-friend) 1))
    (t.is (= aevt-friend[0].v.entity 2))
    (t.is (= (count avet) 2))
    (t.is (= avet[0].e 1))
    (t.is (= avet[1].e 2))
    (t.is (= (count avet-bounded) 1))
    (t.is (= avet-bounded[0].e 1))
    (t.is (= avet-bounded[0].v.entity 3))
    (t.is (= (count seek-lookup) (count seek-resolved)))
    (t.is (= seek-lookup[0].e seek-resolved[0].e))
    (t.is (= seek-lookup[0].a seek-resolved[0].a))
    (t.is (= seek-lookup[0].v.entity seek-resolved[0].v.entity))
    (t.is (= (count seek-aevt-lookup) (count seek-aevt-resolved)))
    (t.is (= seek-aevt-lookup[0].e seek-aevt-resolved[0].e))
    (t.is (= seek-aevt-lookup[0].v.entity seek-aevt-resolved[0].v.entity))
    (t.is (= (count seek-avet-lookup) (count seek-avet-resolved)))
    (t.is (= seek-avet-lookup[0].e seek-avet-resolved[0].e))
    (t.is (= seek-avet-lookup[0].v.entity seek-avet-resolved[0].v.entity))
    (t.is (= (count range-exact) 2))
    (t.is (= range-exact[0].e 1))
    (t.is (= range-exact[1].e 2))
    (t.is (= (count range-bounded) 3))
    (t.is (= range-bounded[0].v.entity 2))
    (t.is (= range-bounded[1].v.entity 3))
    (t.is (= range-bounded[2].v.entity 3))))

(t.deftest datascript-index-api-subset
  (defer (free_all context.allocator))
  (let [conn (vev.create-conn)
        _ (vev.transact
            (addr conn)
            [[:db/add 1 :name "Petr"]
             [:db/add 1 :age 44]
             [:db/add 2 :name "Ivan"]
             [:db/add 2 :age 25]
             [:db/add 3 :name "Sergey"]
             [:db/add 3 :age 11]])
        first (vev.find-datom conn.db :eavt)
        first-e (vev.find-datom conn.db :eavt 1)
        first-ea (vev.find-datom conn.db :eavt 1 :age)
        first-name (vev.find-datom conn.db :eavt 1 :name)
        petr (vev.find-datom conn.db :eavt 1 :name "Petr")
        second-age (vev.find-datom conn.db :eavt 2 :age)
        second-name (vev.find-datom conn.db :eavt 2 :name)
        missing-entity (vev.find-datom conn.db :eavt 4)
        missing (vev.find-datom conn.db :eavt 1 :name "Ivan")
        seek (vev.seek-datoms conn.db :avet :name "Petr")
        rseek-name (vev.rseek-datoms conn.db :avet :name "Petr")
        rseek-age (vev.rseek-datoms conn.db :avet :age 26)
        rseek-age-exact (vev.rseek-datoms conn.db :avet :age 25)
        range-name (vev.index-range conn.db :name "I" "Sergey")
        range-before (vev.index-range conn.db :name nil "P")
        range-after (vev.index-range conn.db :name "R" nil)
        range-age (vev.index-range conn.db :age 15 25)
        empty-conn (vev.create-conn)
        empty-found (vev.find-datom empty-conn.db :eavt)]
    (t.is first.found)
    (t.is (= first.datom.e 1))
    (t.is (= first.datom.a ":age"))
    (t.is first-e.found)
    (t.is (= first-e.datom.e 1))
    (t.is (= first-e.datom.a ":age"))
    (t.is first-ea.found)
    (t.is (= first-ea.datom.v.int-value 44))
    (t.is first-name.found)
    (t.is (= first-name.datom.v.text "Petr"))
    (t.is petr.found)
    (t.is (= petr.datom.e 1))
    (t.is (= petr.datom.v.text "Petr"))
    (t.is second-age.found)
    (t.is (= second-age.datom.v.int-value 25))
    (t.is second-name.found)
    (t.is (= second-name.datom.v.text "Ivan"))
    (t.is (not missing-entity.found))
    (t.is (not missing.found))
    (t.is (= (count seek) 2))
    (t.is (= seek[0].e 1))
    (t.is (= seek[1].e 3))
    (t.is (= (count rseek-name) 5))
    (t.is (= rseek-name[0].e 1))
    (t.is (= rseek-name[1].e 2))
    (t.is (= rseek-name[4].e 3))
    (t.is (= (count rseek-age) 2))
    (t.is (= rseek-age[0].e 2))
    (t.is (= rseek-age[1].e 3))
    (t.is (= (count rseek-age-exact) 2))
    (t.is (= rseek-age-exact[0].e 2))
    (t.is (= rseek-age-exact[1].e 3))
    (t.is (= (count range-name) 3))
    (t.is (= range-name[0].v.text "Ivan"))
    (t.is (= range-name[1].v.text "Petr"))
    (t.is (= range-name[2].v.text "Sergey"))
    (t.is (= (count range-before) 1))
    (t.is (= range-before[0].v.text "Ivan"))
    (t.is (= (count range-after) 1))
    (t.is (= range-after[0].v.text "Sergey"))
    (t.is (= (count range-age) 1))
    (t.is (= range-age[0].v.int-value 25))
    (t.is (not empty-found.found))))

