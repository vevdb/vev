(def opening-release-pull-query '[:find [(pull $ ?release [*])] :in $ ?artist-name :where [?release :release/artists ?artist] [?artist :artist/name ?artist-name] [?release :release/name ?release-name]])
(def tuple-binding-query '[:find [(pull $ ?release [*])] :in $ [?artist-name ?release-name] :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]])
(def request-map-query '[:find (pull $ ?release [:release/name :release/artistCredit :release/year {:release/script [*]} {:release/media [{:medium/tracks [:track/name]}]}]) :in $ ?artist-name :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist]])
(def collection-binding-query '[:find ?release-name :in $ [?artist-name ...] :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]])
(def relation-binding-query '[:find ?release :in $ [[?artist-name ?release-name]] :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]])
(def relation-find-missing-db-query '[:find ?artist-name ?release-name :in ?artist-name :where [?release :release/name ?release-name] [?release :release/artists ?artist] [?artist :artist/name ?artist-name]])
(def relation-find-query '[:find ?artist-name ?release-name :in $ ?artist-name :where [?release :release/name ?release-name] [?release :release/artists ?artist] [?artist :artist/name ?artist-name]])
(def collection-find-query '[:find [?release-name ...] :in $ ?artist-name :where [?artist :artist/name ?artist-name] [?release :release/artists ?artist] [?release :release/name ?release-name]])
(def tuple-find-query '[:find [?year ?month ?day] :in $ ?name :where [?artist :artist/name ?name] [?artist :artist/startDay ?day] [?artist :artist/startMonth ?month] [?artist :artist/startYear ?year]])
(def scalar-find-query '[:find ?year . :in $ ?name :where [?artist :artist/name ?name] [?artist :artist/startYear ?year]])
(def return-map-find-query '[:find ?artist-name ?release-name :keys artist release :in $ ?artist-name :where [?release :release/name ?release-name] [?release :release/artists ?artist] [?artist :artist/name ?artist-name]])
(def function-expression-query '[:find ?track-name ?minutes :in $ ?artist-name :where [?artist :artist/name ?artist-name] [?track :track/artists ?artist] [?track :track/duration ?millis] [(quot ?millis 60000) ?minutes] [?track :track/name ?track-name]])
(def artist-type-gender-query '[:find ?id ?type ?gender :in $ ?name :where [?e :artist/name ?name] [?e :artist/gid ?id] [?e :artist/type ?teid] [?teid :db/ident ?type] [?e :artist/gender ?geid] [?geid :db/ident ?gender]])
(def min-track-duration-query '[:find [(min ?dur)] :where [?e :track/duration ?dur]])
(def sum-medium-track-count-query '[:find (sum ?count) . :with ?medium :where [?medium :medium/trackCount ?count]])
(def artist-name-count-query '[:find (count ?name) (count-distinct ?name) :with ?artist :where [?artist :artist/name ?name]])
(def tracks-by-artist-name-query '[:find ?title :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?t :track/artists ?a] [?t :track/name ?title]])
(def pre-1970-release-names-query '[:find ?name :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [(< ?year 1970)] [?r :release/name ?name]])
(def pre-1970-release-names-switched-query '[:find ?name :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [?r :release/name ?name] [(< ?year 1970)]])
(def pre-1970-track-titles-broad-query '[:find ?title :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [?r :release/name ?name] [(< ?year 1970)] [?t :track/artists ?a] [?t :track/name ?title]])
(def pre-1970-track-titles-with-release-name-query '[:find ?title :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [?r :release/name ?name] [(< ?year 1970)] [?r :release/media ?m] [?m :medium/tracks ?t] [?t :track/name ?title]])
(def pre-1970-track-titles-query '[:find ?title :in $ ?artist-name :where [?a :artist/name ?artist-name] [?r :release/artists ?a] [?r :release/year ?year] [(< ?year 1970)] [?r :release/media ?m] [?m :medium/tracks ?t] [?t :track/name ?title]])

(def track-release-rules '[[(track-release ?t ?r) [?m :medium/tracks ?t] [?r :release/media ?m]]])
(def track-release-rule-query '[:find ?title ?album ?year :in $ % ?artist-name :where [?a :artist/name ?artist-name] [?t :track/artists ?a] [?t :track/name ?title] (track-release ?t ?r) [?r :release/name ?album] [?r :release/year ?year]])
(def mbrainz-track-release-rule-query '[:find ?title ?album ?year :in $ % ?artist-name :where [?a :artist/name ?artist-name] [?t :track/artists ?a] [?t :track/name ?title] (track-release ?t ?r) [?r :release/name ?album] [?r :release/year ?year]])
(def mbrainz-track-search-info-query '[:find ?title ?artist ?album ?year :in $ % ?search :where (track-search ?search ?track) (track-info ?track ?title ?artist ?album ?year)])
(def mbrainz-collab-query '[:find ?aname ?aname2 :in $ % [?aname ...] :where (collab ?aname ?aname2)])
(def mbrainz-collab-net-2-query '[:find ?aname ?aname2 :in $ % [?aname ...] :where (collab-net-2 ?aname ?aname2)])
(def mbrainz-collab-nested-query '[:find ?aname2 :in $ % [[?aname]] :where (collab ?aname ?aname2)])
(def mbrainz-bill-withers-collaboration-query '[:find ?aname ?tname :in $ ?artist-name :where [?a :artist/name ?artist-name] [?t :track/artists ?a] [?t :track/name ?tname] [(!= "Outro" ?tname)] [(!= "[outro]" ?tname)] [(!= "Intro" ?tname)] [(!= "[intro]" ?tname)] [?t2 :track/name ?tname] [?t2 :track/artists ?a2] [(!= ?a2 ?a)] [?a2 :artist/name ?aname]])
(def track-exercise-rules '[[(track-artist ?t ?artist-name) [?t :track/artists ?a] [?a :artist/name ?artist-name]] [(track-release ?t ?release-name ?release-year) [?m :medium/tracks ?t] [?r :release/media ?m] [?r :release/name ?release-name] [?r :release/year ?release-year]]])
(def track-rules-exercise-query '[:find ?track-name ?artist-name ?release-name ?release-year :in $ % ?track-name :where [?t :track/name ?track-name] (track-artist ?t ?artist-name) (track-release ?t ?release-name ?release-year)])
(def track-info-rules '[[(track-artist ?t ?artist-name) [?t :track/artists ?a] [?a :artist/name ?artist-name]] [(track-release ?t ?release-name ?release-year) [?m :medium/tracks ?t] [?r :release/media ?m] [?r :release/name ?release-name] [?r :release/year ?release-year]] [(track-info ?t ?artist-name ?release-name ?release-year) (track-artist ?t ?artist-name) (track-release ?t ?release-name ?release-year)]])
(def track-info-rule-query '[:find ?track-name ?artist-name ?release-name ?release-year :in $ % ?track-name :where [?t :track/name ?track-name] (track-info ?t ?artist-name ?release-name ?release-year)])

(def pull-release-name-query '[:find (pull ?e [:release/name]) :in $ ?artist-name :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def pull-release-name-dynamic-pattern-query '[:find (pull ?e pattern) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def pull-release-and-artist-query '[:find (pull ?e [:release/name]) (pull ?a [*]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def pull-release-name-and-artists-query '[:find (pull ?e [:release/name :release/artists]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def duplicate-pull-release-query '[:find (pull ?e [:release/name]) (pull ?e [:release/artists]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def nested-pull-release-artists-query '[:find (pull ?e [:release/name {:release/artists [*]}]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def nested-pull-release-artists-country-query '[:find (pull ?e [:release/name {:release/artists [*]} {:release/country [*]}]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def deep-pull-release-artists-country-query '[:find (pull ?e [:release/name {:release/artists [* {:artist/country [*]}]} {:release/country [*]}]) :in $ ?artist-name pattern :where [?a :artist/name ?artist-name] [?e :release/artists ?a]])
(def direct-pull-expression-in-query-query '[:find [(pull ?e [:release/name]) ...] :in $ ?artist :where [?e :release/artists ?artist]])
(def direct-dynamic-pattern-input-query '[:find [(pull ?e pattern) ...] :in $ ?artist pattern :where [?e :release/artists ?artist]])

(def dylan-harrison-cd-query '[:find ?medium . :in $ ?release :where [?release :release/media ?medium]])
(def ghost-riders-query '[:find ?track . :in $ ?release ?trackno :where [?release :release/media ?medium] [?medium :medium/tracks ?track] [?track :track/position ?trackno]])
(def nested-release-media-tracks-pattern '[{:release/media [{:medium/tracks [:track/name {:track/artists [:artist/name]}]}]}])

(defn value-map-get [value: d.Value, key: string] -> [found: d.Value, ok: bool]
  (when (not (= value.kind .Map))
    (return (d.value-nil) false))
  (let [target (d.value-keyword key)
        index 0]
    (while (< (+ index 1) (count value.items))
      (let [candidate value.items[index]]
        (when (d.value-equal? candidate target)
          (return value.items[(+ index 1)] true)))
      (set! index (+ index 2))))
  (return (d.value-nil) false))

(defn value-vector-count [value: d.Value] -> int
  (if (= value.kind .Vector)
    (return (count value.items))
    (return 0)))

(defn mode-track-count [values: []d.Value] -> d.Native-Query-Function-Result
  (let [best: i64 0
        best-count 0
        found false]
    (for [candidate values]
      (when (= candidate.kind .Int)
        (let [candidate-count 0]
          (for [value values]
            (when (and (= value.kind .Int)
                       (= value.int-value candidate.int-value))
              (set! candidate-count (+ candidate-count 1))))
          (when (or (not found) (> candidate-count best-count))
            (set! found true)
            (set! best candidate.int-value)
            (set! best-count candidate-count)))))
    (if found
      (d.native-query-function-result (d.value-int best))
      (d.native-query-function-none))))

(defn value-map-count [value: d.Value] -> int
  (if (= value.kind .Map)
    (return (/ (count value.items) 2))
    (return 0)))

(defn value-pull-ref-count [value: d.Value] -> int
  (cond
    (= value.kind .Vector) (count value.items)
    (= value.kind .Map) 1
    :else 0))

(defn value-vector-has-map-string? [value: d.Value, key: string, expected: string] -> bool
  (when (not (= value.kind .Vector))
    (return false))
  (for [item value.items]
    (let [[child child-ok] (value-map-get item key)]
      (when (and child-ok (= child.kind .String) (= child.text expected))
        (return true))))
  false)

(defn nested-media-track-count [value: d.Value] -> [media-count: int, track-count: int]
  (let [[media media-ok] (value-map-get value ":release/media")
        total 0]
    (when (not (and media-ok (= media.kind .Vector)))
      (return 0 0))
    (for [medium media.items]
      (let [[tracks tracks-ok] (value-map-get medium ":medium/tracks")]
        (when (and tracks-ok (= tracks.kind .Vector))
          (set! total (+ total (count tracks.items))))))
    (return (count media.items) total)))

(defn nested-first-track-ok? [value: d.Value] -> bool
  (let [[media media-ok] (value-map-get value ":release/media")]
    (when (not (and media-ok (= media.kind .Vector) (> (count media.items) 0)))
      (return false))
    (let [[tracks tracks-ok] (value-map-get media.items[0] ":medium/tracks")]
      (when (not (and tracks-ok (= tracks.kind .Vector) (> (count tracks.items) 0)))
        (return false))
      (let [first-track tracks.items[0]
            [track-name track-name-ok] (value-map-get first-track ":track/name")
            [artists artists-ok] (value-map-get first-track ":track/artists")]
        (and track-name-ok (= track-name.kind .String) (= track-name.text "Jumpin' Jack Flash / Youngblood") artists-ok (value-vector-has-map-string? artists ":artist/name" "Leon Russell"))))))

(defn query-scalar-entity! [snapshot: d.DB, query: Data, inputs: string] -> [entity: u64, ok: bool]
  (let [result (d.try-q-data query snapshot inputs)]
    (defer (d.close result))
    (when (not (and result.ok (= (count result.rows) 1) (= (count result.rows[0].values) 1)))
      (return 0 false))
    (let [value result.rows[0].values[0]]
      (if (= value.kind .Entity)
        (return value.entity true)
        (return 0 false)))))

(defn check-result! [label: string, result: d.Result, expected: int, passed: ^bool]
  (let [rows (count result.rows)
        ok (and result.ok (= rows expected))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok rows expected result.error)
    (when (not ok)
      (set! passed^ false))))

(defn validate-query! [snapshot: d.DB, label: string, query: Data, inputs: string, expected: int, passed: ^bool]
  (let [result (d.try-q-data query snapshot inputs)]
    (check-result! label result expected passed)
    (d.close result)))

(defn validate-query-no-input! [snapshot: d.DB, label: string, query: Data, expected: int, passed: ^bool]
  (let [result (d.try-q-data query snapshot)]
    (check-result! label result expected passed)
    (d.close result)))

(defn validate-query-result! [label: string, result: d.Result, expected: int, passed: ^bool]
  (check-result! label result expected passed)
  (d.close result))

(defn query-result-relation-input-text [result: d.Result] -> string
  (let [parts (make [dynamic]string) :defer
        owned-parts (make [dynamic]string) :defer]
    (arr.push! parts "[#{")
    (for [row row-index result.rows]
      (when (> row-index 0)
        (arr.push! parts " "))
      (arr.push! parts "[")
      (for [value value-index row.values]
        (when (> value-index 0)
          (arr.push! parts " "))
        (let [value-text (d.value-serializable-text value)]
          (arr.push! parts value-text)
          (arr.push! owned-parts value-text)))
      (arr.push! parts "]"))
    (arr.push! parts "}]")
    (let [out (strings.concatenate (slice parts 0))]
      (for [part owned-parts]
        (delete part))
      out)))

(defn selected-section? [selected: string, label: string] -> bool
  (or (= selected "all")
      (= selected label)
      (strings.has_suffix label selected)))

(defn validate-focused-mbrainz-data-query! [snapshot: d.DB, selected: string, passed: ^bool] -> bool
  (let [ran false]
    (when (selected-section? selected "mbrainz-title-by-artist")
      (set! ran true)
      (validate-query-result! "mbrainz-title-by-artist"
        (d.q
          [:find ?title
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]]
          snapshot
          "John Lennon")
        70 passed))
    (when (selected-section? selected "mbrainz-title-album-year-by-artist")
      (set! ran true)
      (validate-query-result! "mbrainz-title-album-year-by-artist"
        (d.q
          [:find ?title ?album ?year
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]
           [?m :medium/tracks ?t]
           [?r :release/media ?m]
           [?r :release/name ?album]
           [?r :release/year ?year]]
          snapshot
          "John Lennon")
        93 passed))
    (when (selected-section? selected "mbrainz-pre-1970-title-album-year")
      (set! ran true)
      (validate-query-result! "mbrainz-pre-1970-title-album-year"
        (d.q
          [:find ?title ?album ?year
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]
           [?m :medium/tracks ?t]
           [?r :release/media ?m]
           [?r :release/name ?album]
           [?r :release/year ?year]
           [(< ?year 1970)]]
          snapshot
          "John Lennon")
        18 passed))
    (when (selected-section? selected "mbrainz-track-release-rule")
      (set! ran true)
      (validate-rule-query-file! snapshot
        "mbrainz-track-release-rule"
        mbrainz-track-release-rule-query
        mbrainz-sample-rules-path
        "[\"John Lennon\"]"
        93
        passed))
    (when (selected-section? selected "mbrainz-track-search-info")
      (set! ran true)
      (validate-rule-query-file! snapshot
        "mbrainz-track-search-info"
        mbrainz-track-search-info-query
        mbrainz-sample-rules-path
        "[\"always\"]"
        92
        passed))
    (when (selected-section? selected "mbrainz-collab")
      (set! ran true)
      (validate-rule-query-file! snapshot
        "mbrainz-collab"
        mbrainz-collab-query
        mbrainz-sample-rules-path
        "[[\"John Lennon\" \"Paul McCartney\" \"George Harrison\" \"Ringo Starr\"]]"
        5
        passed))
    (when (selected-section? selected "mbrainz-collab-net-2")
      (set! ran true)
      (validate-rule-query-file! snapshot
        "mbrainz-collab-net-2"
        mbrainz-collab-net-2-query
        mbrainz-sample-rules-path
        "[[\"George Harrison\"]]"
        3
        passed))
    (when (selected-section? selected "mbrainz-collab-nested")
      (set! ran true)
      (let [[rules-data read-err] (os.read_entire_file mbrainz-sample-rules-path context.allocator)]
        (when (!= read-err nil)
          (fmt.printf "source=kvist section=mbrainz-collab-nested ok=false rows=0 expected=2 error=failed to read rules\n")
          (set! passed^ false))
        (when (= read-err nil)
          (defer (delete rules-data))
          (let [first-result (d.try-q-data-rules-text
                               mbrainz-collab-nested-query
                               snapshot
                               (string rules-data)
                               "[[[\"Diana Ross\"]]]")
                second-input (query-result-relation-input-text first-result)]
            (defer (delete second-input))
            (defer (d.close first-result))
            (validate-rule-query-text! snapshot
              "mbrainz-collab-nested"
              mbrainz-collab-nested-query
              (string rules-data)
              second-input
              2
              passed)))))
    (when (selected-section? selected "mbrainz-bill-withers-collaborations")
      (set! ran true)
      (validate-query! snapshot
        "mbrainz-bill-withers-collaborations"
        mbrainz-bill-withers-collaboration-query
        "[\"Bill Withers\"]"
        83
        passed))
    ran))

(defn validate-log! [conn: d.Conn, passed: ^bool]
  (let [[tx-ids tx-ids-ok tx-ids-error] (d.log-tx-ids conn)]
    (defer (delete tx-ids))
    (when (not tx-ids-ok)
      (fmt.printf "source=kvist section=log-tx-ids ok=false rows=0 expected=9 error=%s\n" tx-ids-error)
      (set! passed^ false)
      (return))
    (let [tx-ids-count (count tx-ids)
          tx-ids-ok-count (= tx-ids-count 9)]
      (fmt.printf "source=kvist section=log-tx-ids ok=%v rows=%d expected=9 error=\n" tx-ids-ok-count tx-ids-count)
      (when (not tx-ids-ok-count)
        (set! passed^ false)))
    (when (= (count tx-ids) 0)
      (fmt.printf "source=kvist section=log-tx-data ok=false rows=0 expected=1 error=no tx ids\n")
      (set! passed^ false)
      (return))
    (let [[tx-data tx-data-ok tx-data-error] (d.log-tx-data conn tx-ids[0])
          tx-data-present (and tx-data-ok (> (count tx-data) 2))]
      (defer (delete tx-data))
      (fmt.printf "source=kvist section=log-tx-data ok=%v rows=%d expected=1 error=%s\n" tx-data-present (if tx-data-present 1 0) tx-data-error)
      (when (not tx-data-present)
        (set! passed^ false)))))

(defn validate-scalar-int-result! [label: string, result: d.Result, expected: i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 1)
                (= result.rows[0].values[0].kind .Int)
                (= result.rows[0].values[0].int-value expected))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-scalar-int-vector-result! [label: string, result: d.Result, expected: []i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 1)
                (= result.rows[0].values[0].kind .Vector)
                (= (count result.rows[0].values[0].items) (count expected)))]
    (when ok
      (for [expected-value index expected]
        (when (not (and (= result.rows[0].values[0].items[index].kind .Int)
                        (= result.rows[0].values[0].items[index].int-value expected-value)))
          (set! ok false))))
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn int-vector-equals? [value: d.Value, expected: []i64] -> bool
  (when (not (and (= value.kind .Vector)
                  (= (count value.items) (count expected))))
    (return false))
  (for [expected-value index expected]
    (when (not (and (= value.items[index].kind .Int)
                    (= value.items[index].int-value expected-value)))
      (return false)))
  true)

(defn validate-two-int-vector-result! [label: string, result: d.Result, expected-first: []i64, expected-second: []i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 2)
                (int-vector-equals? result.rows[0].values[0] expected-first)
                (int-vector-equals? result.rows[0].values[1] expected-second))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn string-vector-size? [value: d.Value, expected-count: int] -> bool
  (when (not (and (= value.kind .Vector)
                  (= (count value.items) expected-count)))
    (return false))
  (for [item value.items]
    (when (not (= item.kind .String))
      (return false)))
  true)

(defn validate-two-string-vector-size-result! [label: string, result: d.Result, expected-count: int, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 2)
                (string-vector-size? result.rows[0].values[0] expected-count)
                (string-vector-size? result.rows[0].values[1] expected-count))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-query-error! [snapshot: d.DB, label: string, query: Data, inputs: string, expected-error: string, passed: ^bool]
  (let [result (d.try-q-data query snapshot inputs)
        ok (and (not result.ok)
                (strings.contains result.error expected-error))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (if ok 1 0) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-rule-query! [snapshot: d.DB, label: string, query: Data, rules: Data, inputs: string, expected: int, passed: ^bool]
  (let [result (d.try-q-data-rules query snapshot rules inputs)]
    (check-result! label result expected passed)
    (d.close result)))

(defn validate-rule-query-text! [snapshot: d.DB, label: string, query: Data, rules: string, inputs: string, expected: int, passed: ^bool]
  (let [result (d.try-q-data-rules-text query snapshot rules inputs)]
    (check-result! label result expected passed)
    (d.close result)))

(defn validate-rule-query-file! [snapshot: d.DB, label: string, query: Data, rules-path: string, inputs: string, expected: int, passed: ^bool]
  (let [[data read-err] (os.read_entire_file rules-path context.allocator)]
    (when (!= read-err nil)
      (fmt.printf "source=kvist section=%s ok=false rows=0 expected=%d error=failed to read rules\n" label expected)
      (set! passed^ false)
      (return))
    (defer (delete data))
    (validate-rule-query-text! snapshot label query (string data) inputs expected passed)))

(defn check-pull! [label: string, ok: bool, passed: ^bool]
  (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (if ok 1 0) 1 "")
  (when (not ok)
    (set! passed^ false)))

(defn pull-query-row-has-release-name? [row: d.Row, expected: string] -> bool
  (when (not (= (count row.pulls) 1))
    (return false))
  (let [attrs row.pulls[0].attrs]
    (when (not (= (count attrs) 1))
      (return false))
    (and (= attrs[0].a ":release/name")
         (= attrs[0].v.kind .String)
         (= attrs[0].v.text expected))))

(defn pull-query-result-has-release-name? [result: d.Result, expected: string] -> bool
  (for [row result.rows]
    (when (pull-query-row-has-release-name? row expected)
      (return true)))
  false)

(defn validate-pull-query! [snapshot: d.DB, label: string, query: Data, inputs: string, expected: int, expected-name: string, passed: ^bool]
  (let [result (d.try-q-data query snapshot inputs)
        rows (count result.rows)
        ok (and result.ok
                (= rows expected)
                (pull-query-result-has-release-name? result expected-name))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok rows expected result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-direct-pull! [snapshot: d.DB, passed: ^bool]
  (do
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[:artist/name :artist/startYear]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [artist-year artist-year-ok] (value-map-get artist ":artist/startYear")]
