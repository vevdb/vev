    (check-pull! "pull-default-option-string" (and artist-ok (= artist-error "") artist-name-ok (= artist-name.kind .String) (= artist-name.text "Paul McCartney") artist-end-ok (= artist-end.kind .String) (= artist-end.text "N/A")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[:artist/name :died-in-1966?]" ":artist/gid" (d.value-uuid "ba550d0e-adac-4864-b88b-407cab5e76af"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [_ died-ok] (value-map-get artist ":died-in-1966?")]
    (check-pull! "pull-absent-attribute" (and artist-ok (= artist-error "") artist-name-ok (= artist-name.kind .String) (= artist-name.text "Paul McCartney") (not died-ok)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[(:track/_artists :limit 10)]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-explicit-limit" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 10)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[{(:track/_artists :limit 10) [:track/name]}]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-limit-subspec" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 10) (value-vector-has-map-string? tracks ":track/name" "Whole Lotta Love") (value-vector-has-map-string? tracks ":track/name" "Stairway to Heaven")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[{(:track/_artists :limit 10 :as \"Tracks\") [:track/name]}]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (d.map-get-value artist (d.value-string "Tracks"))
        [_ attr-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-limit-subspec-as" (and artist-ok (= artist-error "") tracks-ok (not attr-ok) (= (value-vector-count tracks) 10) (value-vector-has-map-string? tracks ":track/name" "Whole Lotta Love") (value-vector-has-map-string? tracks ":track/name" "Stairway to Heaven")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[(:track/_artists :limit nil)]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-no-limit" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 128)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-text snapshot "[:penguins]" ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))]
    (check-pull! "pull-empty-results" (and artist-ok (= artist-error "") (= artist.kind .Map) (= (value-map-count artist) 0)) passed))
  (let [[track track-ok] (query-scalar-entity! snapshot ghost-riders-query "[[:release/gid #uuid \"67bbc160-ac45-4caf-baae-a7e9f5180429\"] 11]")]
    (if track-ok
      (let [[track-pull track-pull-ok track-pull-error] (d.try-pull-text snapshot "[{:track/artists [:penguins]}]" track)
            [artists artists-ok] (value-map-get track-pull ":track/artists")]
        (check-pull! "pull-empty-results-in-collection" (and track-pull-ok (= track-pull-error "") artists-ok (= (value-vector-count artists) 2) (= artists.items[0].kind .Map) (= (value-map-count artists.items[0]) 0) (= artists.items[1].kind .Map) (= (value-map-count artists.items[1]) 0)) passed))
      (check-pull! "pull-empty-results-in-collection" false passed)))))

(defn main []
  (let [uri (if (> (count os.args) 1) os.args[1] default-uri)
        selected (if (> (count os.args) 2) os.args[2] "all")
        conn (d.connect-read-only uri)
        snapshot (d.db conn)
        passed true]
    (defer (d.close conn))
    (defer (d.close snapshot))
    (do
      (when (not (= selected "all"))
        (let [ran (validate-focused-mbrainz-data-query! snapshot selected (addr passed))]
          (when (not ran)
            (fmt.printf "source=kvist section=%s ok=false rows=0 expected=1 error=unknown focused MusicBrainz workload\n" selected)
            (set! passed false))
          (fmt.printf "source=kvist section=summary ok=%v\n" passed)
          (return)))
      (validate-query-result! "opening-release-pulls"
        (d.q
          [:find [(pull $ ?release [*])]
           :in $ ?artist-name
           :where
           [?release :release/artists ?artist]
           [?artist :artist/name ?artist-name]
           [?release :release/name ?release-name]]
          snapshot
          "John Lennon")
        21 (addr passed))
      (validate-query-result! "tuple-binding-release-pulls"
        (d.q
          [:find [(pull $ ?release [*])]
           :in $ [?artist-name ?release-name]
           :where
           [?artist :artist/name ?artist-name]
           [?release :release/artists ?artist]
           [?release :release/name ?release-name]]
          snapshot
          ["John Lennon" "Mind Games"])
        4 (addr passed))
      (validate-query-result! "request-map-release-pulls"
        (d.q
          [:find (pull $ ?release [:release/name :release/artistCredit :release/year {:release/script [*]} {:release/media [{:medium/tracks [:track/name]}]}])
           :in $ ?artist-name
           :where
           [?artist :artist/name ?artist-name]
           [?release :release/artists ?artist]]
          snapshot
          "Elis Regina")
        10 (addr passed))
      (validate-query-result! "collection-binding-releases"
        (d.q
          [:find ?release-name
           :in $ [?artist-name ...]
           :where
           [?artist :artist/name ?artist-name]
           [?release :release/artists ?artist]
           [?release :release/name ?release-name]]
          snapshot
          ["Paul McCartney" "George Harrison"])
        14 (addr passed))
      (validate-query-result! "relation-binding-releases"
        (d.q
          [:find ?release
           :in $ [[?artist-name ?release-name]]
           :where
           [?artist :artist/name ?artist-name]
           [?release :release/artists ?artist]
           [?release :release/name ?release-name]]
          snapshot
          [["John Lennon" "Mind Games"] ["Paul McCartney" "Ram"]])
        5 (addr passed))
      (validate-query-error! snapshot "relation-find-missing-db" relation-find-missing-db-query "[\"elvis presley\"]" ":in does not include $" (addr passed))
      (validate-query-result! "relation-find-releases"
        (d.q
          [:find ?artist-name ?release-name
           :in $ ?artist-name
           :where
           [?release :release/name ?release-name]
           [?release :release/artists ?artist]
           [?artist :artist/name ?artist-name]]
          snapshot
          "Elvis Presley")
        29 (addr passed))
      (validate-query-result! "collection-find-releases"
        (d.q
          [:find [?release-name ...]
           :in $ ?artist-name
           :where
           [?artist :artist/name ?artist-name]
           [?release :release/artists ?artist]
           [?release :release/name ?release-name]]
          snapshot
          "John Lennon")
        12 (addr passed))
      (validate-query-result! "tuple-find-artist-start"
        (d.q
          [:find [?year ?month ?day]
           :in $ ?name
           :where
           [?artist :artist/name ?name]
           [?artist :artist/startDay ?day]
           [?artist :artist/startMonth ?month]
           [?artist :artist/startYear ?year]]
          snapshot
          "John Lennon")
        1 (addr passed))
      (validate-query-result! "scalar-find-artist-start"
        (d.q
          [:find ?year .
           :in $ ?name
           :where
           [?artist :artist/name ?name]
           [?artist :artist/startYear ?year]]
          snapshot
          "John Lennon")
        1 (addr passed))
      (validate-scalar-int-result! "artist-not-canada-count"
        (d.q
          [:find (count ?eid) .
           :where
           [?eid :artist/name]
           (not [?eid :artist/country :country/CA])]
          snapshot)
        4538 (addr passed))
      (validate-scalar-int-result! "artist-not-release-1970-count"
        (d.q
          [:find (count ?artist) .
           :where
           [?artist :artist/name]
           (not-join [?artist]
             [?release :release/artists ?artist]
             [?release :release/year 1970])]
          snapshot)
        3263 (addr passed))
      (validate-scalar-int-result! "live-at-carnegie-not-bill-withers-count"
        (d.q
          [:find (count ?r) .
           :where
           [?r :release/name "Live at Carnegie Hall"]
           (not-join [?r]
             [?r :release/artists ?a]
             [?a :artist/name "Bill Withers"])]
          snapshot)
        2 (addr passed))
      (validate-scalar-int-result! "artist-or-type-gender-count"
        (d.q
          [:find (count ?artist) .
           :where
           (or [?artist :artist/type :artist.type/group]
               (and [?artist :artist/type :artist.type/person]
                    [?artist :artist/gender :artist.gender/female]))]
          snapshot)
        2323 (addr passed))
      (validate-scalar-int-result! "release-or-canada-artist-or-1970-count"
        (d.q
          [:find (count ?release) .
           :where
           [?release :release/name]
           (or-join [?release]
             (and [?release :release/artists ?artist]
                  [?artist :artist/country :country/CA])
             [?release :release/year 1970])]
          snapshot)
        2124 (addr passed))
      (validate-query-result! "artist-start-before-1600"
        (d.q
          [:find ?name ?year
           :where
           [?artist :artist/name ?name]
           [?artist :artist/startYear ?year]
           [(< ?year 1600)]]
          snapshot)
        2 (addr passed))
      (validate-query-result! "return-map-releases"
        (d.q
          [:find ?artist-name ?release-name
           :keys artist release
           :in $ ?artist-name
           :where
           [?release :release/name ?release-name]
           [?release :release/artists ?artist]
           [?artist :artist/name ?artist-name]]
          snapshot
          "Paul McCartney")
        3 (addr passed))
      (validate-query-result! "function-expression-track-minutes"
        (d.q
          [:find ?track-name ?minutes
           :in $ ?artist-name
           :where
           [?artist :artist/name ?artist-name]
           [?track :track/artists ?artist]
           [?track :track/duration ?millis]
           [(quot ?millis 60000) ?minutes]
           [?track :track/name ?track-name]]
          snapshot
          "John Lennon")
        71 (addr passed))
      (validate-query-result! "mbrainz-title-by-artist"
        (d.q
          [:find ?title
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]]
          snapshot
          "John Lennon")
        70 (addr passed))
      (validate-query-result! "mbrainz-title-album-year-by-artist"
        (d.q
          [:find ?title ?album ?year
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]
           [?m :medium/tracks ?t]
           [?r :release/media ?m]
           [?r :release/name ?album]
           [?r :release/year ?year]]
          snapshot
          "John Lennon")
        93 (addr passed))
      (validate-query-result! "mbrainz-pre-1970-title-album-year"
        (d.q
          [:find ?title ?album ?year
           :in $ ?artist-name
           :where
           [?a :artist/name ?artist-name]
           [?t :track/artists ?a]
           [?t :track/name ?title]
           [?m :medium/tracks ?t]
           [?r :release/media ?m]
           [?r :release/name ?album]
           [?r :release/year ?year]
           [(< ?year 1970)]]
          snapshot
