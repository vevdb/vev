  (let [[release-media release-media-ok release-media-error] (d.try-pull-lookup-text snapshot "[:release/media]" ":release/gid" (d.value-uuid "24824319-9bb8-3d1e-a2c5-b8b864dafd1b"))
        [media media-ok] (value-map-get release-media ":release/media")]
