(defn validate-log! [conn: d.Conn, passed: ^bool]
  (let [log-value (d.log conn)
        tx-ids: Data (d.q log-tx-ids-query log-value)]
    (validate-data-value! "log-tx-ids" tx-ids '#{1 2 3 4 5 6 7 8 9} 9 passed)
    (when (= (count tx-ids) 0)
      (fmt.printf "source=kvist section=log-tx-data ok=false rows=0 expected=1 error=no tx ids\n")
      (set! passed^ false)
      (return))
    (let [tx-data: Data (d.q log-tx-data-entities-query log-value 1)
          tx-data-count (count tx-data)
          ; The subset import creates Vev transactions; tx 1 is its schema batch.
          tx-data-ok (= tx-data-count 214)]
      (fmt.printf "source=kvist section=log-tx-data ok=%v rows=%d expected=214 error=\n" tx-data-ok tx-data-count)
      (when (not tx-data-ok)
        (set! passed^ false)))))

(defn validate-collection-functions! [passed: ^bool]
  (validate-data-value! "word-prefixes"
    (d.q word-prefix-query ["hello" "antidisestablishmentarianism"])
    '["hello" "antid"]
    2 passed))

(defn data-collection-contains-keyword? [value: Data, expected: string] -> bool
  (for [index (arr.range 0 (core.count value))]
    (let [item (kdata.item-at value index)]
      (when (and (kdata.keyword? item)
                 (= (kdata.keyword item) expected))
        (return true))))
  false)

(defn data-string-collections-equal? [left: Data, right: Data] -> bool
  (when (not (= (core.count left) (core.count right)))
    (return false))
  (for [index (arr.range 0 (core.count left))]
    (let [item (kdata.item-at left index)]
      (when (not (kdata.string? item))
        (return false))
      (let [expected (kdata.string item)
            found false]
        (for [right-index (arr.range 0 (core.count right))]
          (let [candidate (kdata.item-at right right-index)]
            (when (and (kdata.string? candidate)
                       (= (kdata.string candidate) expected))
              (set! found true))))
        (when (not found)
          (return false)))))
  true)

(defn workshop-unique-attrs? [result: Data] -> bool
  (and (= (core.count result) 8)
       (data-collection-contains-keyword? result ":country/name")
       (data-collection-contains-keyword? result ":label/gid")
       (data-collection-contains-keyword? result ":script/name")
       (data-collection-contains-keyword? result ":db/ident")
       (data-collection-contains-keyword? result ":artist/gid")
       (data-collection-contains-keyword? result ":language/name")
       (data-collection-contains-keyword? result ":release/gid")
       (data-collection-contains-keyword? result ":abstractRelease/gid")))

(defn validate-attribute-result! [label: string, result: Data, passed: ^bool]
  (let [ok (workshop-unique-attrs? result)]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=8 error=\n" label ok (core.count result))
    (when (not ok)
      (set! passed^ false))))

