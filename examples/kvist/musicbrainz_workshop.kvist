    "attrs-with-value-42"
    (d.q attrs-with-value-42-query snapshot)
    passed))

(defn validate-dynamic-attributes! [snapshot: d.DB, passed: ^bool]
  (validate-attribute-result!
    "attrs-with-property"
    (d.q attrs-with-property-query snapshot [:db/unique])
    passed))

(defn validate-country-inputs! [snapshot: d.DB, passed: ^bool]
  (let [lookup-ref: Data (d.q country-artists-query snapshot [:country/name "Belgium"])
        ident: Data (d.q country-artists-query snapshot :country/BE)
        entity: Data (d.q country-artists-query snapshot belgium-entity-id)
        dynamic-reference: Data (d.q dynamic-reference-country-query snapshot :country/BE [:artist/country])
        resolved-reference: Data (d.q dynamic-reference-country-entid-query snapshot :country/BE [:artist/country])
        ok (and (= (core.count entity) 10)
                (= (core.count dynamic-reference) 0)
                (data-string-collections-equal? lookup-ref ident)
                (data-string-collections-equal? ident entity)
                (data-string-collections-equal? ident resolved-reference))]
    (fmt.printf "source=kvist section=country-input-equivalence ok=%v rows=%d unresolved=%d resolved=%d expected=10 error=\n"
      ok
      (core.count entity)
      (core.count dynamic-reference)
      (core.count resolved-reference))
    (when (not ok)
      (set! passed^ false))))

(defn validate-scalar-int-result! [label: string, result: d.Result, expected: i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 1)
                (= result.rows[0].values[0].kind .Int)
                (= result.rows[0].values[0].int-value expected))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-scalar-int-vector-result! [label: string, result: d.Result, expected: []i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 1)
                (= result.rows[0].values[0].kind .Vector)
                (= (count result.rows[0].values[0].items) (count expected)))]
    (when ok
      (for [expected-value index expected]
        (when (not (and (= result.rows[0].values[0].items[index].kind .Int)
                        (= result.rows[0].values[0].items[index].int-value expected-value)))
          (set! ok false))))
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn int-vector-equals? [value: d.Value, expected: []i64] -> bool
  (when (not (and (= value.kind .Vector)
                  (= (count value.items) (count expected))))
    (return false))
  (for [expected-value index expected]
    (when (not (and (= value.items[index].kind .Int)
                    (= value.items[index].int-value expected-value)))
      (return false)))
  true)

(defn validate-two-int-vector-result! [label: string, result: d.Result, expected-first: []i64, expected-second: []i64, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 2)
                (int-vector-equals? result.rows[0].values[0] expected-first)
                (int-vector-equals? result.rows[0].values[1] expected-second))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn string-vector-size? [value: d.Value, expected-count: int] -> bool
  (when (not (and (= value.kind .Vector)
                  (= (count value.items) expected-count)))
    (return false))
  (for [item value.items]
    (when (not (= item.kind .String))
      (return false)))
  true)

(defn validate-two-string-vector-size-result! [label: string, result: d.Result, expected-count: int, passed: ^bool]
  (let [ok (and result.ok
                (= (count result.rows) 1)
                (= (count result.rows[0].values) 2)
                (string-vector-size? result.rows[0].values[0] expected-count)
                (string-vector-size? result.rows[0].values[1] expected-count))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (count result.rows) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-query-error! [snapshot: d.DB, label: string, query: Data, inputs: string, expected-error: string, passed: ^bool]
  (let [result (d.try-q-data query snapshot inputs)
        ok (and (not result.ok)
                (strings.contains result.error expected-error))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (if ok 1 0) 1 result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-rule-query! [snapshot: d.DB, label: string, query: Data, rules: Data, inputs: string, expected: int, passed: ^bool]
  (let [arguments (edn.read inputs) :defer-with kdata.release
        result (d.try-q query snapshot rules (get arguments 0))]
    (check-result! label result expected passed)
    (d.close result)))

(defn check-pull! [label: string, ok: bool, passed: ^bool]
  (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok (if ok 1 0) 1 "")
  (when (not ok)
    (set! passed^ false)))

(defn pull-query-row-has-release-name? [row: d.Row, expected: string] -> bool
  (when (not (= (count row.pulls) 1))
    (return false))
  (let [attrs row.pulls[0].attrs]
    (when (not (= (count attrs) 1))
      (return false))
    (and (= attrs[0].a ":release/name")
         (= attrs[0].v.kind .String)
         (= attrs[0].v.text expected))))

(defn pull-query-result-has-release-name? [result: d.Result, expected: string] -> bool
  (for [row result.rows]
    (when (pull-query-row-has-release-name? row expected)
      (return true)))
  false)

(defn validate-pull-query! [snapshot: d.DB, label: string, query: Data, inputs: string, expected: int, expected-name: string, passed: ^bool]
  (let [result (d.try-q-data query snapshot inputs)
        rows (count result.rows)
        ok (and result.ok
                (= rows expected)
                (pull-query-result-has-release-name? result expected-name))]
    (fmt.printf "source=kvist section=%s ok=%v rows=%d expected=%d error=%s\n" label ok rows expected result.error)
    (when (not ok)
      (set! passed^ false))
    (d.close result)))

(defn validate-direct-pull! [snapshot: d.DB, passed: ^bool]
  (do
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[:artist/name :artist/startYear] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [artist-year artist-year-ok] (value-map-get artist ":artist/startYear")]
    (check-pull! "pull-attribute-name" (and artist-ok artist-name-ok artist-year-ok (= artist-error "") (= artist-name.text "Led Zeppelin") (= artist-year.int-value 1968)) passed))
  (let [[country country-ok country-error] (d.try-pull-lookup-data snapshot '[:artist/country] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [country-value country-value-ok] (value-map-get country ":artist/country")
        [country-id country-id-ok] (value-map-get country-value ":db/id")]
    ; Entity ids belong to the database value, not the import source's local
    ; numbering. Datomic and Vev both expose the referenced entity here.
    (check-pull! "pull-artist-country" (and country-ok country-value-ok country-id-ok (= country-error "") (> country-id.entity 0)) passed))
  (let [[reverse-country _ _] (d.try-pull-lookup-data snapshot '[:artist/_country] ":db/ident" (d.value-keyword ":country/GB"))
        [artists artists-ok] (value-map-get reverse-country ":artist/_country")]
    (check-pull! "pull-reverse-country" (and artists-ok (= (value-vector-count artists) 482)) passed))
  (let [[release-media release-media-ok release-media-error] (d.try-pull-lookup-data snapshot '[:release/media] ":release/gid" (d.value-uuid "24824319-9bb8-3d1e-a2c5-b8b864dafd1b"))
        [media media-ok] (value-map-get release-media ":release/media")]
    (check-pull! "pull-release-media-default" (and release-media-ok media-ok (= release-media-error "") (= (value-vector-count media) 1)) passed))
  (let [[medium medium-ok] (query-scalar-entity! snapshot dylan-harrison-cd-query "[[:release/gid #uuid \"67bbc160-ac45-4caf-baae-a7e9f5180429\"]]")]
    (if medium-ok
      (let [[reverse-media reverse-media-ok reverse-media-error] (d.try-pull-data snapshot '[:release/_media] medium)
            [releases releases-ok] (value-map-get reverse-media ":release/_media")]
        (check-pull! "pull-reverse-component" (and reverse-media-ok releases-ok (= reverse-media-error "") (= (value-pull-ref-count releases) 1)) passed))
      (check-pull! "pull-reverse-component" false passed)))
  (let [[track track-ok] (query-scalar-entity! snapshot ghost-riders-query "[[:release/gid #uuid \"67bbc160-ac45-4caf-baae-a7e9f5180429\"] 11]")]
    (if track-ok
      (let [[track-pull track-pull-ok track-pull-error] (d.try-pull-data snapshot '[:track/name {:track/artists [:db/id :artist/name]}] track)
            [track-name track-name-ok] (value-map-get track-pull ":track/name")
            [artists artists-ok] (value-map-get track-pull ":track/artists")]
        (check-pull! "pull-map-specifications" (and track-pull-ok (= track-pull-error "") track-name-ok (= track-name.text "Ghost Riders in the Sky") artists-ok (= (value-vector-count artists) 2) (value-vector-has-map-string? artists ":artist/name" "George Harrison") (value-vector-has-map-string? artists ":artist/name" "Bob Dylan")) passed))
      (check-pull! "pull-map-specifications" false passed)))
  (let [[nested nested-ok nested-error] (d.try-pull-lookup-data snapshot nested-release-media-tracks-pattern ":release/gid" (d.value-uuid "f3bdff34-9a85-4adc-a014-922eef9cdaa5"))
        [media-count track-count] (nested-media-track-count nested)]
    (check-pull! "pull-nested-map-specifications" (and nested-ok (= nested-error "") (= media-count 6) (= track-count 19) (nested-first-track-ok? nested)) passed))
  (let [[wildcard wildcard-ok wildcard-error] (d.try-pull-lookup-data snapshot '[*] ":release/gid" (d.value-uuid "f3bdff34-9a85-4adc-a014-922eef9cdaa5"))
        [release-name release-name-ok] (value-map-get wildcard ":release/name")
        [release-year release-year-ok] (value-map-get wildcard ":release/year")
        [release-gid release-gid-ok] (value-map-get wildcard ":release/gid")]
    (check-pull! "pull-wildcard-specification" (and wildcard-ok (= wildcard-error "") (= (value-map-count wildcard) 13) release-name-ok (= release-name.kind .String) (= release-name.text "The Concert for Bangla Desh") release-year-ok (= release-year.kind .Int) (= release-year.int-value 1971) release-gid-ok (= release-gid.kind .Uuid) (= release-gid.text "f3bdff34-9a85-4adc-a014-922eef9cdaa5")) passed))
  (let [[track track-ok] (query-scalar-entity! snapshot ghost-riders-query "[[:release/gid #uuid \"67bbc160-ac45-4caf-baae-a7e9f5180429\"] 11]")]
    (if track-ok
      (let [[track-pull track-pull-ok track-pull-error] (d.try-pull-data snapshot '[* {:track/artists [:artist/name]}] track)
            [track-name track-name-ok] (value-map-get track-pull ":track/name")
            [track-position track-position-ok] (value-map-get track-pull ":track/position")
            [track-duration track-duration-ok] (value-map-get track-pull ":track/duration")
            [artists artists-ok] (value-map-get track-pull ":track/artists")]
        (check-pull! "pull-wildcard-map-specification" (and track-pull-ok (= track-pull-error "") (= (value-map-count track-pull) 6) track-name-ok (= track-name.kind .String) (= track-name.text "Ghost Riders in the Sky") track-position-ok (= track-position.kind .Int) (= track-position.int-value 11) track-duration-ok (= track-duration.kind .Int) (= track-duration.int-value 218506) artists-ok (= (value-vector-count artists) 2) (value-vector-has-map-string? artists ":artist/name" "George Harrison") (value-vector-has-map-string? artists ":artist/name" "Bob Dylan")) passed))
      (check-pull! "pull-wildcard-map-specification" false passed)))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[:artist/name (:artist/endYear :default 0)] ":artist/gid" (d.value-uuid "ba550d0e-adac-4864-b88b-407cab5e76af"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [artist-end artist-end-ok] (value-map-get artist ":artist/endYear")]
    (check-pull! "pull-default-option" (and artist-ok (= artist-error "") artist-name-ok (= artist-name.kind .String) (= artist-name.text "Paul McCartney") artist-end-ok (= artist-end.kind .Int) (= artist-end.int-value 0)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[:artist/name (:artist/endYear :default "N/A")] ":artist/gid" (d.value-uuid "ba550d0e-adac-4864-b88b-407cab5e76af"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [artist-end artist-end-ok] (value-map-get artist ":artist/endYear")]
    (check-pull! "pull-default-option-string" (and artist-ok (= artist-error "") artist-name-ok (= artist-name.kind .String) (= artist-name.text "Paul McCartney") artist-end-ok (= artist-end.kind .String) (= artist-end.text "N/A")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[:artist/name :died-in-1966?] ":artist/gid" (d.value-uuid "ba550d0e-adac-4864-b88b-407cab5e76af"))
        [artist-name artist-name-ok] (value-map-get artist ":artist/name")
        [_ died-ok] (value-map-get artist ":died-in-1966?")]
    (check-pull! "pull-absent-attribute" (and artist-ok (= artist-error "") artist-name-ok (= artist-name.kind .String) (= artist-name.text "Paul McCartney") (not died-ok)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[(:track/_artists :limit 10)] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-explicit-limit" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 10)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[{(:track/_artists :limit 10) [:track/name]}] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-limit-subspec" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 10) (value-vector-has-map-string? tracks ":track/name" "Whole Lotta Love") (value-vector-has-map-string? tracks ":track/name" "Stairway to Heaven")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[{(:track/_artists :limit 10 :as "Tracks") [:track/name]}] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (d.map-get-value artist (d.value-string "Tracks"))
        [_ attr-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-limit-subspec-as" (and artist-ok (= artist-error "") tracks-ok (not attr-ok) (= (value-vector-count tracks) 10) (value-vector-has-map-string? tracks ":track/name" "Whole Lotta Love") (value-vector-has-map-string? tracks ":track/name" "Stairway to Heaven")) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[(:track/_artists :limit nil)] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))
        [tracks tracks-ok] (value-map-get artist ":track/_artists")]
    (check-pull! "pull-no-limit" (and artist-ok (= artist-error "") tracks-ok (= (value-vector-count tracks) 128)) passed))
  (let [[artist artist-ok artist-error] (d.try-pull-lookup-data snapshot '[:penguins] ":artist/gid" (d.value-uuid "678d88b2-87b0-403b-b63d-5da7465aecc3"))]
    (check-pull! "pull-empty-results" (and artist-ok (= artist-error "") (= artist.kind .Nil)) passed))
  (let [[track track-ok] (query-scalar-entity! snapshot ghost-riders-query "[[:release/gid #uuid \"67bbc160-ac45-4caf-baae-a7e9f5180429\"] 11]")]
    (if track-ok
      (let [[track-pull track-pull-ok track-pull-error] (d.try-pull-data snapshot '[{:track/artists [:penguins]}] track)
            empty? (= track-pull.kind .Nil)]
        (check-pull! "pull-empty-results-in-collection" (and track-pull-ok (= track-pull-error "") empty?) passed))
      (check-pull! "pull-empty-results-in-collection" false passed)))))

(defn main []
  (let [uri (if (> (count os.args) 1) os.args[1] default-uri)
        selected (if (> (count os.args) 2) os.args[2] "all")
        conn (d.connect-read-only uri)
        snapshot (d.db conn)
        passed true]
    (defer (d.close conn))
    (defer (d.close snapshot))
    (do
      (when (not (= selected "all"))
        (let [opening? (= selected "opening-query-shapes")
              negation? (= selected "negation-disjunction")
              predicates? (= selected "predicate-functions")
              built-ins? (= selected "built-in-functions")
              log? (= selected "transaction-log")
              collection-functions? (= selected "collection-functions")
              source-less-aggregates? (= selected "source-less-aggregates")
              numeric-attributes? (= selected "numeric-attributes")
              dynamic-attributes? (= selected "dynamic-attributes")
              country-inputs? (= selected "country-inputs")
              ran (if (or opening? negation? predicates? built-ins? log? collection-functions? source-less-aggregates? numeric-attributes? dynamic-attributes? country-inputs?)
                    true
                    (validate-focused-mbrainz-data-query! snapshot selected (addr passed)))]
          (when opening?
            (validate-opening-query-shapes! snapshot (addr passed)))
          (when negation?
            (validate-negation-disjunction! snapshot (addr passed)))
          (when predicates?
            (validate-predicate-functions! snapshot (addr passed)))
          (when built-ins?
            (validate-built-in-functions! snapshot (addr passed)))
          (when log?
            (validate-log! conn (addr passed)))
          (when collection-functions?
            (validate-collection-functions! (addr passed)))
          (when source-less-aggregates?
            (validate-source-less-aggregates! (addr passed)))
          (when numeric-attributes?
            (validate-numeric-attributes! snapshot (addr passed)))
          (when dynamic-attributes?
            (validate-dynamic-attributes! snapshot (addr passed)))
          (when country-inputs?
            (validate-country-inputs! snapshot (addr passed)))
          (when (not ran)
            (fmt.printf "source=kvist section=%s ok=false rows=0 expected=1 error=unknown focused MusicBrainz workload\n" selected)
            (set! passed false))
          (fmt.printf "source=kvist section=summary ok=%v\n" passed)
          (return)))
      (validate-opening-query-shapes! snapshot (addr passed))
      (validate-negation-disjunction! snapshot (addr passed))
      (validate-predicate-functions! snapshot (addr passed))
      (validate-built-in-functions! snapshot (addr passed))
      (validate-collection-functions! (addr passed))
      (validate-numeric-attributes! snapshot (addr passed))
      (validate-dynamic-attributes! snapshot (addr passed))
      (validate-country-inputs! snapshot (addr passed))
      (validate-query-result! "return-map-releases"
        (d.try-q return-map-find-query snapshot "Paul McCartney")
        3 (addr passed))
      (validate-query-result! "mbrainz-title-by-artist"
        (d.try-q mbrainz-title-by-artist-query snapshot "John Lennon")
        70 (addr passed))
      (validate-query-result! "mbrainz-title-album-year-by-artist"
        (d.try-q mbrainz-title-album-year-by-artist-query snapshot "John Lennon")
        93 (addr passed))
      (validate-query-result! "mbrainz-pre-1970-title-album-year"
        (d.try-q mbrainz-pre-1970-title-album-year-query snapshot "John Lennon")
        18 (addr passed))
      (validate-rule-query! snapshot
        "mbrainz-track-release-rule"
        mbrainz-track-release-rule-query
        mbrainz-sample-rules
        "[\"John Lennon\"]"
        93
        (addr passed))
      (validate-rule-query! snapshot
        "mbrainz-track-search-info"
        mbrainz-track-search-info-query
        mbrainz-sample-rules
        "[\"always\"]"
        92
        (addr passed))
      (validate-rule-query! snapshot
        "mbrainz-collab"
        mbrainz-collab-query
        mbrainz-sample-rules
        "[[\"John Lennon\" \"Paul McCartney\" \"George Harrison\" \"Ringo Starr\"]]"
        5
        (addr passed))
      (validate-rule-query! snapshot
        "mbrainz-collab-net-2"
        mbrainz-collab-net-2-query
        mbrainz-sample-rules
        "[[\"George Harrison\"]]"
        3
        (addr passed))
      (let [first-result: Data (d.q mbrainz-collab-nested-query snapshot mbrainz-sample-rules [["Diana Ross"]])
            second-result: Data (d.q mbrainz-collab-nested-query snapshot mbrainz-sample-rules first-result)]
        (validate-data-count! "mbrainz-collab-nested" second-result 2 (addr passed)))
      (validate-query! snapshot
        "mbrainz-bill-withers-collaborations"
        mbrainz-bill-withers-collaboration-query
        "[\"Bill Withers\"]"
        83
        (addr passed))
      (validate-log! conn (addr passed))
      (validate-data-count! "artist-type-gender"
        (d.q artist-type-gender-query snapshot "Janis Joplin")
        1 (addr passed))
      (validate-source-less-aggregates! (addr passed))
      (let [empty-conn (d.create-conn)
            empty-db (d.db empty-conn)]
        (defer (d.close empty-db))
        (defer (d.close empty-conn))
        (validate-scalar-int-vector-result! "distinct-values"
          (d.try-q distinct-values-query empty-db [1 1 2 2 2 3])
          ([]i64 [1 2 3]) (addr passed)))
      (validate-query-result! "min-track-duration"
        (d.try-q min-track-duration-query snapshot)
        1 (addr passed))
      (validate-two-int-vector-result! "top-track-duration"
        (d.try-q top-track-duration-query snapshot)
        ([]i64 [3000 4000 5000 6000 7000])
        ([]i64 [3894000 3407000 2928000 2802000 2775000])
        (addr passed))
      (validate-two-string-vector-size-result! "random-artist-names"
        (d.try-q random-artist-name-query snapshot)
        2 (addr passed))
      (validate-query-result! "sum-medium-track-count"
        (d.try-q sum-medium-track-count-query snapshot)
        1 (addr passed))
      (validate-data-scalar-int! "custom-mode-aggregate"
        (d.q-with-fns custom-mode-aggregate-query snapshot
          ([]d.Native-Query-Fn [(d.query-aggregate-fn "user/mode" mode-track-count)]))
        2 (addr passed))
      (validate-query-result! "artist-name-counts"
        (d.try-q artist-name-count-query snapshot)
        1 (addr passed))
      (validate-query! snapshot "tracks-by-artist-name" tracks-by-artist-name-query "[\"John Lennon\"]" 70 (addr passed))
      (validate-query! snapshot "pre-1970-release-names" pre-1970-release-names-query "[\"John Lennon\"]" 3 (addr passed))
      (validate-query! snapshot "pre-1970-release-names-switched" pre-1970-release-names-switched-query "[\"John Lennon\"]" 3 (addr passed))
      (validate-query! snapshot "pre-1970-track-titles-broad" pre-1970-track-titles-broad-query "[\"John Lennon\"]" 70 (addr passed))
      (validate-query! snapshot "pre-1970-track-titles-with-release-name" pre-1970-track-titles-with-release-name-query "[\"John Lennon\"]" 17 (addr passed))
      (validate-query! snapshot "pre-1970-track-titles" pre-1970-track-titles-query "[\"John Lennon\"]" 17 (addr passed))
      (validate-rule-query! snapshot "track-release-rule-query" track-release-rule-query track-release-rules "[\"John Lennon\"]" 93 (addr passed))
      (validate-rule-query! snapshot "track-rules-exercise" track-rules-exercise-query track-exercise-rules "[\"Yer Blues\"]" 3 (addr passed))
      (validate-rule-query! snapshot "track-info-rules-composition" track-info-rule-query track-info-rules "[\"Yer Blues\"]" 3 (addr passed))
      (validate-query! snapshot "pull-release-name" pull-release-name-query "[\"Led Zeppelin\"]" 8 (addr passed))
      (validate-query! snapshot "dynamic-pull-pattern" pull-release-name-dynamic-pattern-query "[\"Led Zeppelin\" [:release/name]]" 8 (addr passed))
      (validate-query! snapshot "pull-release-and-artist" pull-release-and-artist-query "[\"Led Zeppelin\" [:release/name]]" 8 (addr passed))
      (validate-query! snapshot "pull-release-name-and-artists" pull-release-name-and-artists-query "[\"Led Zeppelin\" [:release/name]]" 8 (addr passed))
      (validate-query-error! snapshot "duplicate-pull-same-var" duplicate-pull-release-query "[\"Led Zeppelin\" [:release/name]]" "duplicate pull" (addr passed))
      (validate-query! snapshot "nested-pull-release-artists" nested-pull-release-artists-query "[\"Led Zeppelin\" [:release/name]]" 8 (addr passed))
      (validate-query! snapshot "nested-pull-release-artists-country" nested-pull-release-artists-country-query "[\"Led Zeppelin\" [:release/name]]" 14 (addr passed))
      (validate-query! snapshot "deep-pull-release-artists-country" deep-pull-release-artists-country-query "[\"Led Zeppelin\" [:release/name]]" 14 (addr passed))
      (validate-direct-pull! snapshot (addr passed))
      (validate-pull-query! snapshot "direct-pull-expression-in-query" direct-pull-expression-in-query-query "[[:artist/gid #uuid \"678d88b2-87b0-403b-b63d-5da7465aecc3\"]]" 8 "Led Zeppelin" (addr passed))
      (validate-pull-query! snapshot "direct-dynamic-pattern-input" direct-dynamic-pattern-input-query "[[:artist/gid #uuid \"678d88b2-87b0-403b-b63d-5da7465aecc3\"] [:release/name]]" 8 "Led Zeppelin" (addr passed))
      (fmt.printf "source=kvist section=summary ok=%v\n" passed))))
